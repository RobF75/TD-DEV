.head 8 -  Set sSQLPopHandle = " SELECT 
  Service_Parts_Used.Part_Id, 
  Part.Part_Type, 
  Part.Part_Name, 
  Part.Location, 
  Service_Parts_Used.Quantity_Used, 
  Service_Parts_Used.Quantity_Used 
FROM 
  Service_Parts_Used, 
  Part 
WHERE 
  Service_Parts_Used.Service_No = :1 AND 
  Service_Parts_Used.Vehicle_Id = :2 AND 
  Service_Parts_Used.Part_Id = Part.Part_Id 
ORDER BY 2,3 "
.head 8 -  Set sNAMEPopHandle = 'POPSERVPUSED'
.head 8 -  Set sBINDPopHandle = ':hWndParent.clsfrmServPartsUsed.nServiceNo, :hWndParent.clsfrmServPartsUsed.nVehicleId'

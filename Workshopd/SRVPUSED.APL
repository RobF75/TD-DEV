FROM 
  Service_Parts_Used, 
  Part 
WHERE 
  Service_Parts_Used.Service_No = :1 AND 
  Service_Parts_Used.Vehicle_Id = :2 AND 
  Service_Parts_Used.Part_Id = :3 AND 
  Service_Parts_Used.Part_Id = Part.Part_Id "
.head 8 -  Set sNAMERefreshHandle = 'REFSERVPUSED'

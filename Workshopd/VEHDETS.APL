.head 6 +  Message Actions
.head 7 +  On PAM_clsFRMDETS_CHECKROWNEW
.head 8 -  Call GetNextVehicleId( dfVehicleId, SH_cls_Execute )
.head 8 +  If dfVehicleId > 0
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Call SalMessageBox( 'An error has occured in allocating the next vehicle Id. Please try and save again.', 'Warning', MB_Ok )
.head 9 -  Return TRUE
.head 7 +  On PAM_clsFRMDETS_ROWDELETED
.head 8 +  If DeleteVehicleServices( dfVehicleId, SH_cls_Execute )
.head 9 -  Call DeleteVehicleServices( 0, SH_cls_Commit )
.head 8 +  If DeleteVehicleVehicleParts( dfVehicleId, SH_cls_Execute )
.head 9 -  Call DeleteVehicleVehicleParts( 0, SH_cls_Commit )
.head 8 +  If DeleteVehicleCheckList( cmbVehicleType, SH_cls_Execute )
.head 9 -  Call DeleteVehicleCheckList( '', SH_cls_Commit )
.head 8 -  Return TRUE

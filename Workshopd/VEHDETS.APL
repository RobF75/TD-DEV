.head 5 +  Function: GetNextVehicleId
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  Receive Number: nNextVehicleId
.head 7 -  Number: nActionType
.head 6 +  Static Variables
.head 7 -  ! hcSqlHandle: fcOurHandle
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  String: sBind
.head 7 -  String: sInto
.head 7 -  String: sName
.head 7 -  Number: nOurHandleNo
.head 7 -  !
.head 7 -  Number: nInd
.head 7 -  Number: nGotVehicleId
.head 6 +  Actions
.head 7 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetNextVehicleId' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = " SELECT Max( Vehicle_Id ) + 1
FROM Vehicle "
.head 9 -  Set sName = 'NEXTVEHID'
.head 9 -  Set sBind = ''
.head 9 -  Set sInto = ':nGotVehicleId'
.head 9 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 9 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 -  Set nNextVehicleId = NUMBER_Null
.head 9 -  Set nGotVehicleId = NUMBER_Null
.head 9 -  !
.head 9 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 10 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 11 +  If NOT nGotVehicleId > 0
.head 12 -  Set nGotVehicleId = 1
.head 11 -  Set nNextVehicleId = nGotVehicleId
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )

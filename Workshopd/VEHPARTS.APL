.head 3 +  Function: GetNextVehPartsInstNo
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Receive Number: nNextInstNo
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  ! hcSqlHandle: fcOurHandle
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 5 -  !
.head 5 -  Number: nInd
.head 5 -  Number: nGotInstNo
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetNextVehPartsInstNo' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT Max( Instance_No ) + 1
FROM Vehicle_Parts "
.head 7 -  Set sName = 'NEXTVHPRTINST'
.head 7 -  Set sBind = ''
.head 7 -  Set sInto = ':nGotInstNo'
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set nNextInstNo = NUMBER_Null
.head 7 -  Set nGotInstNo = NUMBER_Null
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 +  If NOT nGotInstNo > 0
.head 10 -  Set nGotInstNo = 1
.head 9 -  Set nNextInstNo = nGotInstNo
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 3 +  Function: GetVehPartCombination
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nVehicleId
.head 5 -  Number: nPartId
.head 5 -  Receive Boolean: bExists
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  ! hcSqlHandle: fcOurHandle
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 5 -  !
.head 5 -  Number: nInd
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetVehPartCombination' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT Instance_No
FROM Vehicle_Parts 
WHERE Vehicle_Id = :1 AND Part_Id = :2 "
.head 7 -  Set sName = 'EXISTSVHPRTCMB'
.head 7 -  Set sBind = ':nVehicleId, :nPartId'
.head 7 -  Set sInto = ''
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set bExists = FALSE
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 -  Set bExists = TRUE
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 3 +  Function: InsertVehPartsCombition
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nVehicleId
.head 5 -  Number: nPartId
.head 5 -  Number: nQuantityNeeded
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  ! hcSqlHandle: fcOurHandle
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 5 -  !
.head 5 -  Number: nInd
.head 5 -  Number: nInstanceNo
.head 5 -  Boolean: bOk
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'InsertVehPartsCombition' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " INSERT INTO Vehicle_Parts 
( 
  Instance_No, 
  Vehicle_Id, 
  Part_Id, 
  Quantity_Needed 
) VALUES ( :1, :2, :3, :4 ) "
.head 7 -  Set sName = 'INSVEHPRTCOMB'
.head 7 -  Set sBind = ':nInstanceNo, :nVehicleId, :nPartId, :nQuantityNeeded'
.head 7 -  Set sInto = ''
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 +  If GetNextVehPartsInstNo( nInstanceNo, SH_cls_Execute )
.head 8 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Commit
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Commit( )
.head 6 +  Case SH_cls_Rollback
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Set bOk =  TRUE
.head 7 +  If NOT GetNextVehPartsInstNo( nInstanceNo, SH_cls_Disconnect )
.head 8 -  Set bOk =  FALSE
.head 7 +  If NOT haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 8 -  Set bOk =  FALSE
.head 7 -  Return bOk

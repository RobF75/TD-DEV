:clsfrmPartVehicles.tblPartVehicles.colVehicleDriver, 
:clsfrmPartVehicles.tblPartVehicles.colQuantityNeeded'
.head 8 -  !
.head 8 -  Set sSQLInsertHandle = " INSERT INTO Vehicle_Parts 
( Vehicle_Id, Instance_No, Part_Id, Quantity_Needed ) VALUES ( :1, :2, :3, :4 ) "
.head 8 -  Set sNAMEInsertHandle = 'INSPARTVEH'
.head 8 -  Set sBINDInsertHandle = ':clsfrmPartVehicles.tblPartVehicles.colVehicleId, 
:clsfrmPartVehicles.tblPartVehicles.colInstanceNo, 
:hWndParent.clsfrmPartVehicles.nPartId, 
:clsfrmPartVehicles.tblPartVehicles.colQuantityNeeded'
.head 8 -  Set sINTOInsertHandle = ''
.head 8 -  !

.head 8 -  Set sSQLPopHandle = " SELECT 
  Vehicle_Parts.Instance_No, 
  Part.Part_Id, 
  Part.Part_Type, 
  Part.Part_Name, 
  Part.Location, 
  Vehicle_Parts.Quantity_Needed 
FROM 
  Vehicle_Parts, 
  Part 
WHERE 
  Vehicle_Parts.Vehicle_Id = :1 AND 
  Vehicle_Parts.Part_Id = Part.Part_Id 
ORDER BY 3,4 "
.head 8 -  Set sNAMEPopHandle = 'POPVEHPARTS'
.head 8 -  Set sBINDPopHandle = ':hWndParent.clsfrmVehParts.nVehicleId'
.head 8 -  Set sINTOPopHandle = ':clsfrmVehParts.tblVehParts.colInstanceNo, 
:clsfrmVehParts.tblVehParts.colPartId, 
:clsfrmVehParts.tblVehParts.colPartType, 
:clsfrmVehParts.tblVehParts.colPartName, 
:clsfrmVehParts.tblVehParts.colPartLocation, 
:clsfrmVehParts.tblVehParts.colQuantityNeeded'
.head 8 -  !
.head 8 -  Set sSQLRefreshHandle = "  SELECT 
  Vehicle_Parts.Instance_No, 
  Vehicle_Parts.Part_Id, 
  Part.Part_Type, 
  Part.Part_Name, 
  Part.Location, 
  Vehicle_Parts.Quantity_Needed 
FROM 
  Vehicle_Parts, 
  Part 
WHERE 
  Vehicle_Parts.Vehicle_Id = :1 AND 
  Vehicle_Parts.Instance_No = :2 AND 
  Vehicle_Parts.Part_Id = :3 AND 
  Vehicle_Parts.Part_Id = Part.Part_Id "
.head 8 -  Set sNAMERefreshHandle = 'REFVEHPARTS'
.head 8 -  Set sBINDRefreshHandle = ':hWndParent.clsfrmVehParts.nVehicleId, :clsfrmVehParts.tblVehParts.colInstanceNo, :clsfrmVehParts.tblVehParts.colPartId'
.head 8 -  Set sINTORefreshHandle = ':clsfrmVehParts.tblVehParts.colInstanceNo, 
:clsfrmVehParts.tblVehParts.colPartId, 
:clsfrmVehParts.tblVehParts.colPartType, 
:clsfrmVehParts.tblVehParts.colPartName, 
:clsfrmVehParts.tblVehParts.colPartLocation, 
:clsfrmVehParts.tblVehParts.colQuantityNeeded'
.head 8 -  !
.head 8 -  Set sSQLInsertHandle = " INSERT INTO Vehicle_Parts 
( Vehicle_Id, Instance_No, Part_Id, Quantity_Needed ) VALUES ( :1, :2, :3, :4 ) "
.head 8 -  Set sNAMEInsertHandle = 'INSVEHPARTS'
.head 8 -  Set sBINDInsertHandle = ':hWndParent.clsfrmVehParts.nVehicleId, 
:clsfrmVehParts.tblVehParts.colInstanceNo, 
:clsfrmVehParts.tblVehParts.colPartId, 
:clsfrmVehParts.tblVehParts.colQuantityNeeded'
.head 8 -  Set sINTOInsertHandle = ''
.head 8 -  !
.head 8 -  Set sSQLUpdateHandle = " UPDATE Vehicle_Parts 
SET Quantity_Needed = :4 
WHERE 
  Vehicle_Id = :1 AND  
  Instance_No = :2 AND 
  Part_Id = :3 "
.head 8 -  Set sNAMEUpdateHandle = 'UPDTVEHPARTS'
.head 8 -  Set sBINDUpdateHandle = ':hWndParent.clsfrmVehParts.nVehicleId, 
:clsfrmVehParts.tblVehParts.colInstanceNo, 
:clsfrmVehParts.tblVehParts.colPartId, 
:clsfrmVehParts.tblVehParts.colQuantityNeeded'
.head 8 -  Set sINTOUpdateHandle = ''

.head 8 -  Set sSQLPopHandle = " SELECT 
  Vehicle_Parts.Instance_No, 
  Vehicle.Vehicle_Id, 
  Vehicle.Vehicle_Type, 
  Vehicle.Make, 
  Vehicle.Location, 
  Vehicle.Reg_No, 
  Vehicle.Driver, 
  Vehicle_Parts.Quantity_Needed 
FROM 
  Vehicle_Parts, 
  Vehicle  
WHERE 
  Vehicle_Parts.Part_Id = :1 AND 
  Vehicle_Parts.Vehicle_Id = Vehicle.Vehicle_Id 
ORDER BY 3,4 "
.head 8 -  Set sNAMEPopHandle = 'POPPARTVEH'
.head 8 -  Set sBINDPopHandle = ':hWndParent.clsfrmPartVehicles.nPartId'
.head 8 -  Set sINTOPopHandle = ':clsfrmPartVehicles.tblPartVehicles.colInstanceNo, 
:clsfrmPartVehicles.tblPartVehicles.colVehicleId, 
:clsfrmPartVehicles.tblPartVehicles.colVehicleType, 
:clsfrmPartVehicles.tblPartVehicles.colVehicleMake, 
:clsfrmPartVehicles.tblPartVehicles.colVehicleLocation, 
:clsfrmPartVehicles.tblPartVehicles.colVehicleRegoNo, 
:clsfrmPartVehicles.tblPartVehicles.colVehicleDriver, 
:clsfrmPartVehicles.tblPartVehicles.colQuantityNeeded'
.head 8 -  !
.head 8 -  Set sSQLRefreshHandle = " SELECT 
  Vehicle_Parts.Instance_No, 
  Vehicle.Vehicle_Id, 
  Vehicle.Vehicle_Type, 
  Vehicle.Make, 
  Vehicle.Location, 
  Vehicle.Reg_No, 
  Vehicle.Driver, 
  Vehicle_Parts.Quantity_Needed 
FROM 
  Vehicle_Parts, 
  Vehicle  
WHERE 
  Vehicle_Parts.Vehicle_Id = :1 AND 
  Vehicle_Parts.Instance_No = :2 AND 
  Vehicle_Parts.Part_Id = :3 AND 
  Vehicle_Parts.Vehicle_Id = Vehicle.Vehicle_Id "
.head 8 -  Set sNAMERefreshHandle = 'REFPARTVEH'
.head 8 -  Set sBINDRefreshHandle = ':clsfrmPartVehicles.tblPartVehicles.colVehicleId, :clsfrmPartVehicles.tblPartVehicles.colInstanceNo, :hWndParent.clsfrmPartVehicles.nPartId'
.head 8 -  Set sINTORefreshHandle = ':clsfrmPartVehicles.tblPartVehicles.colInstanceNo, 
:clsfrmPartVehicles.tblPartVehicles.colVehicleId, 
:clsfrmPartVehicles.tblPartVehicles.colVehicleType, 
:clsfrmPartVehicles.tblPartVehicles.colVehicleMake, 

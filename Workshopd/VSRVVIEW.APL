.head 6 +  Message Actions
.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 -  Set sSQLPopHandle = ' SELECT 
  Vehicle.Vehicle_Type, 
  Vehicle.Make, 
  Vehicle.Reg_No, 
  Vehicle.Driver, 
  Vehicle_Service.Service_Due_Date, 
  Vehicle_Service.Service_Due_Dist, 
  Vehicle_Service.Service_Done_Date, 
  Vehicle_Service.Service_Done_Dist, 
  Vehicle_Service.Service_Mechanic, 
  Vehicle_Service.General_Conditions, 
  Vehicle_Service.Further_Require, 
  Vehicle_Service.Done_Above_Service  
FROM 
  Vehicle_Service, 
  Vehicle 
WHERE 
  Vehicle_Service.Vehicle_Id = Vehicle.Vehicle_Id AND 
  @MONTH( Vehicle_Service.Service_Due_Date ) = :1 AND 
  @YEAR( Vehicle_Service.Service_Due_Date )+1900 = :2 
ORDER BY 
  Vehicle_Service.Service_Due_Date, 
  Vehicle_Service.Service_Done_Date, 
  Vehicle_Service.Service_No '
.head 8 -  Set sNAMEPopHandle = 'POPVSVIEWR'
.head 8 -  Set sBINDPopHandle = ':hWndParent.clsdlgVehServiceViewer.nMonth, :hWndParent.clsdlgVehServiceViewer.nYear'
.head 8 -  Set sINTOPopHandle = ':clsdlgVehServiceViewer.tblVehServViewer.colVehType,
:clsdlgVehServiceViewer.tblVehServViewer.colVehMake,
:clsdlgVehServiceViewer.tblVehServViewer.colVehRego, 
:clsdlgVehServiceViewer.tblVehServViewer.colVehDriver, 
:clsdlgVehServiceViewer.tblVehServViewer.colServDueDate,
:clsdlgVehServiceViewer.tblVehServViewer.colServDueDist,
:clsdlgVehServiceViewer.tblVehServViewer.colServDoneDate,
:clsdlgVehServiceViewer.tblVehServViewer.colServDoneDist,
:clsdlgVehServiceViewer.tblVehServViewer.colServMechanic,
:clsdlgVehServiceViewer.tblVehServViewer.colServGenConditions,
:clsdlgVehServiceViewer.tblVehServViewer.colServFurtherReq,
:clsdlgVehServiceViewer.tblVehServViewer.colServDoneAbove'
.head 8 -  !

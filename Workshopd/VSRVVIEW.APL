.head 6 +  Select Case SalDateMonth( SalDateCurrent(  ) )
.head 7 +  Case 1
.head 8 -  Set rbJan = TRUE
.head 8 -  Break
.head 7 +  Case 2
.head 8 -  Set rbFeb = TRUE
.head 8 -  Break
.head 7 +  Case 3
.head 8 -  Set rbMarch = TRUE
.head 8 -  Break
.head 7 +  Case 4
.head 8 -  Set rbApril = TRUE
.head 8 -  Break
.head 7 +  Case 5
.head 8 -  Set rbMay = TRUE
.head 8 -  Break
.head 7 +  Case 6
.head 8 -  Set rbJune = TRUE
.head 8 -  Break
.head 7 +  Case 7
.head 8 -  Set rbJuly = TRUE
.head 8 -  Break
.head 7 +  Case 8
.head 8 -  Set rbAug = TRUE
.head 8 -  Break
.head 7 +  Case 9
.head 8 -  Set rbSep = TRUE
.head 8 -  Break
.head 7 +  Case 10
.head 8 -  Set rbOct = TRUE
.head 8 -  Break
.head 7 +  Case 11
.head 8 -  Set rbNov = TRUE
.head 8 -  Break
.head 7 +  Case 12
.head 8 -  Set rbDec = TRUE
.head 8 -  Break
.head 6 -  Call SalSendMsg( hWndForm, PAM_VSRVVIEW_POPULATE, 0, 0 )
.head 6 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 5 +  On PAM_VSRVVIEW_POPULATE
.head 6 -  Set nYear = ccYear.GetYear( )
.head 6 +  If rbJan
.head 7 -  Set nMonth = 1
.head 6 +  Else If rbFeb
.head 7 -  Set nMonth = 2
.head 6 +  Else If rbMarch
.head 7 -  Set nMonth = 3
.head 6 +  Else If rbApril
.head 7 -  Set nMonth = 4
.head 6 +  Else If rbMay
.head 7 -  Set nMonth = 5
.head 6 +  Else If rbJune
.head 7 -  Set nMonth = 6
.head 6 +  Else If rbJuly
.head 7 -  Set nMonth = 7
.head 6 +  Else If rbAug
.head 7 -  Set nMonth = 8
.head 6 +  Else If rbSep
.head 7 -  Set nMonth = 9
.head 6 +  Else If rbOct
.head 7 -  Set nMonth = 10
.head 6 +  Else If rbNov
.head 7 -  Set nMonth = 11
.head 6 +  Else
.head 7 -  Set nMonth = 12
.head 6 -  Return SalSendMsg( tblVehServViewer, PAM_clsTBL_POPULATE, 0, 0 )

.head 4 -  Call GetThisServiceDetails( 0, 0, dtServiceDoneDate, dtServiceDueDate, sServiceDueDistance, sServiceDoneDistance, sServiceMechanic, sFurther_Require, SH_cls_Disconnect )
.head 4 -  Call GetLastServiceNextTimeDetails( 0, 0, dtServiceDoneDate, dtTmp, sTmp,sTmp,sFurther_Require, SH_cls_Disconnect )

.head 4 -  Set sReportType = 'VIEW'
.head 4 -  !
.head 4 -  ! Set sReportSql = " SELECT 
  Left_Condition, 
  Right_Condition 
FROM 
  Vehicle_Check_List 
INTO 
  :frmPrintServiceDueReport.sLeft_Condition,
  :frmPrintServiceDueReport.sRight_Condition
WHERE 
  Vehicle_Type = :frmPrintServiceDueReport.sVehicle_Type
ORDER BY 
  Seq_No"
.head 4 -  Set sReportSql = "SELECT 
	Vehicle_Id,
  	Vehicle_Type, 
  	Location, 
  	Make, 
  	Model, 
  	Reg_No, 
  	Driver 
FROM 
  	Vehicle 
INTO
	:frmPrintServiceDueReport.nVehicleId,
	:frmPrintServiceDueReport.sVehicle_Type, 
	:frmPrintServiceDueReport.sLocation, 
	:frmPrintServiceDueReport.sMake, 
	:frmPrintServiceDueReport.sModel, 
	:frmPrintServiceDueReport.sReg_No, 
	:frmPrintServiceDueReport.sDriver
ORDER BY
	Location,
	Vehicle_Type,
	Make"
.head 3 +  On SAM_ReportStart
.head 4 -  Set sVehicle_Type = ''
.head 4 -  Set sLocation = ''
.head 4 -  Set sMake = ''

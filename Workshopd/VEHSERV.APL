.head 4 -  ! Call GetLastServiceNextTimeDetails( nVehicleId, nServiceNo, sFurther_Require, SH_cls_Execute )
.head 4 -  Return SalSendClassMessage( SAM_ReportStart, wParam, lParam )
.head 3 +  On PAM_clsFRM_REPORTFETCHNEXT
.head 4 -  ! Call GetServiceVehicleDetails( nVehicleId, sVehicle_Type, sLocation, sMake, sModel, sReg_No, sDriver, SH_cls_Execute )
.head 4 +  If GetVehicleServiceNumbers( nVehicleId, naServiceNo, SH_cls_Execute )
.head 5 -  Set sFurther_Require = STRING_Null
.head 5 -  Call GetThisServiceDetails( nVehicleId, naServiceNo[0], dtServiceDoneDate, dtServiceDueDate, sServiceDueDistance, sServiceDoneDistance, sServiceMechanic, sFurther_Require, SH_cls_Execute )
.head 5 +  If naServiceNo[1] != NUMBER_Null
.head 6 -  Call GetLastServiceNextTimeDetails( nVehicleId, naServiceNo[1], dtLastServiceDoneDate, dtLastServiceDoneDate, sLastServiceDueDistance, sLastServiceDoneDistance, sLastFurther_Require, SH_cls_Execute )
.head 5 +  If sFurther_Require = STRING_Null
.head 6 -  Set sFurther_Require = sLastFurther_Require
.head 5 +  If dtServiceDoneDate = DATETIME_Null
.head 6 -  Set dtServiceDoneDate = dtLastServiceDoneDate
.head 5 +  If dtServiceDueDate = DATETIME_Null
.head 6 -  Set dtServiceDueDate = dtLastServiceDueDate
.head 5 +  If sServiceDueDistance = STRING_Null
.head 6 -  Set sServiceDueDistance = sLastServiceDueDistance
.head 5 +  If sServiceDoneDistance = STRING_Null
.head 6 -  Set sServiceDoneDistance = sLastServiceDoneDistance
.head 4 +  Else
.head 5 -  Set dtServiceDoneDate = DATETIME_Null
.head 5 -  Set dtServiceDueDate = DATETIME_Null
.head 5 -  Set dtLastServiceDoneDate = DATETIME_Null
.head 5 -  Set sServiceDueDistance = STRING_Null
.head 5 -  Set sServiceDoneDistance = STRING_Null
.head 5 -  Set sLastServiceDueDistance = STRING_Null
.head 5 -  Set sLastServiceDoneDistance = STRING_Null
.head 5 -  Set sServiceMechanic = STRING_Null
.head 5 -  Set sFurther_Require = STRING_Null
.head 5 -  Set sLastFurther_Require = STRING_Null
.head 4 -  Return TRUE

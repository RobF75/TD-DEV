.head 5 +  On SAM_Create
.head 6 -  Set nVehicleId = NUMBER_Null
.head 6 -  Set nServiceNo = NUMBER_Null
.head 6 -  Return SalSendClassMessage( SAM_Create, wParam, lParam )
.head 5 +  On SAM_Click
.head 6 -  Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
.head 6 +  If nVehicleId > 0 AND nServiceNo > 0
.head 7 -  Call SalCreateWindow( frmPrintServiceReport, hWndItem, nVehicleId, nServiceNo )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'No vehicle service selected!', 'Warning', MB_Ok )
.head 7 -  Return FALSE

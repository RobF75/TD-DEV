.head 3 +  Function: DeleteServPartsUsed
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nServiceNo
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  ! hcSqlHandle: fcOurHandle
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 5 -  !
.head 5 -  Number: nInd
.head 5 -  Number: nPartUsedId
.head 5 -  Number: nQuantityUsed
.head 5 -  Boolean: bOk
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'DeleteServPartsUsed' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT Part_Id, Quantity_Used 
FROM Service_Parts_Used 
WHERE Service_No = :1 "
.head 7 -  Set sName = 'GTSRVPRTUSED'
.head 7 -  Set sBind = ':nServiceNo'
.head 7 -  Set sInto = ':nPartUsedId, :nQuantityUsed'
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 -  Set bOk = TRUE
.head 8 +  While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 +  If NOT IncrementPartQuantity( nPartUsedId, nQuantityUsed, SH_cls_Execute )
.head 10 -  Set bOk = FALSE
.head 9 +  If NOT DelServPartUsed( nServiceNo, nPartUsedId, SH_cls_Execute )
.head 10 -  Set bOk = FALSE
.head 8 -  Return bOk
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Commit
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT IncrementPartQuantity( 0, 0, SH_cls_Commit )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT DelServPartUsed( 0, 0, SH_cls_Commit )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case SH_cls_Rollback
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT IncrementPartQuantity( 0, 0, SH_cls_Rollback )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT DelServPartUsed( 0, 0, SH_cls_Rollback )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT IncrementPartQuantity( 0, 0, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT DelServPartUsed( 0, 0, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 3 +  Function: DelServPartUsed
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nServiceNo
.head 5 -  Number: nPartId
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  ! hcSqlHandle: fcOurHandle
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 5 -  !
.head 5 -  Number: nInd
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'DelServPartUsed' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " DELETE FROM Service_Parts_Used 
WHERE Service_No = :1 AND Part_Id = :2 "
.head 7 -  Set sName = 'DLSNSRV1PUSD'
.head 7 -  Set sBind = ':nServiceNo, :nPartId'
.head 7 -  Set sInto = ''
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Execute( )
.head 6 +  Case SH_cls_Commit
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Commit( )
.head 6 +  Case SH_cls_Rollback
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 3 +  Function: IncrementPartQuantity
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nPartId
.head 5 -  Number: nIncQuantity
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  ! hcSqlHandle: fcOurHandle
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 5 -  !
.head 5 -  Number: nInd
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'IncrementPartQuantity' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " UPDATE Part 
SET Quantity_On_Hand = Quantity_On_Hand + :2
WHERE Part_Id = :1 "
.head 7 -  Set sName = 'INCPRTQNTY'
.head 7 -  Set sBind = ':nPartId, :nIncQuantity'
.head 7 -  Set sInto = ''
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 +  If nIncQuantity = NUMBER_Null
.head 8 -  Set nIncQuantity = 0
.head 7 -  !
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Execute( )
.head 6 +  Case SH_cls_Commit
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Commit( )
.head 6 +  Case SH_cls_Rollback
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )

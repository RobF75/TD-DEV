.head 6 +  If SalIsNull( dfPalletTotal ) OR dfPalletTotal = 0
.head 7 -  Call SalSendMsg( pbMakeFullyGradedFigure, PAM_DISABLE, 0, 0 )
.head 6 +  Else
.head 7 -  Call SalSendMsg( pbMakeFullyGradedFigure, PAM_ENABLE, 0, 0 )
.head 5 +  On PAM_ROWACTION
.head 6 -  Set dfPalletTotal = dfPalletTotal + colCount
.head 6 -  Return TRUE
.head 5 +  On PAM_NOROWS
.head 6 -  Return TRUE

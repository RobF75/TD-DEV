.head 6 -  Set frmItmGrad.tblPallet.sSQLTABLENAME = ' GRADED_PALLETS, PALLET_CONTENTS '
.head 6 -  Set frmItmGrad.tblPallet.sSQLPOPTABLENAME = ' GRADED_PALLETS, PALLET_CONTENTS '
.head 6 -  Set frmItmGrad.tblPallet.sSQLWHERE = ' WHERE PALLET_DATETIME > :frmItmGrad.dtYearBegin AND 
PALLET_DATETIME < :frmItmGrad.dtYearEnd AND 
PALLET_CONTENTS.ITEM_NO = :frmItmGrad.nItemNo AND 
PALLET_CONTENTS.CONTENT_DATETIME = GRADED_PALLETS.PALLET_DATETIME '
.head 6 -  Set frmItmGrad.tblPallet.sROWID = ' GRADED_PALLETS.ROWID '

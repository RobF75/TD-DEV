.head 2 +  Message Actions
.head 3 +  On SAM_CreateComplete
.head 4 -  !
.head 4 -  ! Connect Cursors
.head 4 -  !
.head 4 -  Set bLocalSqlPopDetails = ConnectCursor(hLocalSqlPopDetails)
.head 4 -  Set bLocalSqlDoDetails = ConnectCursor(hLocalSqlDoDetails)
.head 4 -  Call PopWndHdl( hWndPushButton, TRUE )
.head 4 -  !
.head 4 -  Set sHelpFileName = 'n:\\apps\\gupta\\help\\grading.hlp'
.head 4 -  Set bNew = FALSE
.head 4 -  Set bEdit = FALSE
.head 4 -  Set bModified = FALSE
.head 4 -  Set nReturnType = nReturnNormal
.head 4 -  !
.head 4 -  ! nYr is the 95 year instead of 1995 before 1997
.head 4 -  Set nYr = nYear
.head 4 -  ! If we want to construct a datetime to go from after a year then if it is less than
1997 it is stored by us as 97 not 1997 so we need to add 1900 on to get to a 
legitimate date
.head 4 +  If nYear < 97
.head 5 -  Set nYear = nYear + 1900
.head 4 -  Set dtYearBegin = SalDateConstruct( nYear, 01, 01, 01, 01, 01 )
.head 4 -  Set dtYearEnd = SalDateConstruct( nYear, 12, 31, 23, 59, 59 )
.head 4 -  Call SalSendMsg( frmItmGrad.tblItem, PAM_DISABLE, 0, 0 )
.head 4 -  Call SalSendMsg( frmItmGrad.tblPallet, PAM_POPULATE,0 ,0)
.head 3 +  On SAM_Destroy
.head 4 -  Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
.head 4 +  If bLocalSqlPopDetails
.head 5 -  Call SqlDisconnect( hLocalSqlPopDetails )
.head 4 +  If bLocalSqlDoDetails
.head 5 -  Call SqlDisconnect( hLocalSqlDoDetails )
.head 4 -  Call SalSendMsg( hWndPushButton, PAM_ENABLE, 0, 0 )
.head 3 +  On SAM_Close
.head 4 -  Call SalSendValidateMsg(  )
.head 4 +  If bEdit
.head 5 +  If NOT ForgetChanges(  )
.head 6 -  Return FALSE
.head 5 +  Else
.head 6 -  Set bEdit = FALSE
.head 4 -  Call SalWaitCursor( TRUE )

.head 2 +  Functions
.head 3 +  ! Function: GetCustRegionId
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 +  Parameters 
.head 5 -  Number: nCustNo
.head 5 -  Receive String: sRegionId
.head 5 -  Number: SH_cls_ExecuteOrDisconnect
.head 4 +  Static Variables 
.head 5 -  Sql Handle: hSqlHandle
.head 5 -  Boolean: bHandleConnected
.head 5 -  Boolean: bHandlePrepared
.head 4 +  Local variables 
.head 5 -  String: sSql
.head 5 -  Number: nInd
.head 5 -  Boolean: bOk
.head 5 -  String: sGotRegionId
.head 4 +  Actions 
.head 5 +  If SH_cls_ExecuteOrDisconnect != SH_cls_Disconnect
.head 6 +  If NOT bHandleConnected
.head 7 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 7 +  If bHandleConnected
.head 8 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 8 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 7 +  Else 
.head 8 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 8 -  Return FALSE
.head 6 +  If NOT bHandlePrepared
.head 7 -  Set sSql = ' SELECT Region_Id FROM Customer_Master INTO :sGotRegionId
  WHERE Cust_No = :nCustNo '
.head 7 +  If SqlPrepare( hSqlHandle, sSql )
.head 8 -  Set bHandlePrepared = TRUE
.head 7 +  Else 
.head 8 -  Set bHandlePrepared = FALSE
.head 6 -  Set sRegionId = ''
.head 6 -  Set sGotRegionId = ''
.head 6 +  If SqlExecute( hSqlHandle )
.head 7 -  Call SqlFetchNext( hSqlHandle, nInd )
.head 7 -  Set sRegionId = sGotRegionId
.head 7 -  Return TRUE
.head 6 +  Else 
.head 7 -  Set bHandlePrepared = FALSE
.head 7 -  Call SalMessageBox( 'SqlExecute had a error in GetMeetAddress, Contact programmers please!', 'ERROR', MB_Ok )
.head 7 -  Return FALSE
.head 5 +  Else 
.head 6 -  Set bOk = TRUE
.head 6 -  Set bHandlePrepared = FALSE
.head 6 +  If bHandleConnected
.head 7 -  Set bHandleConnected = FALSE
.head 7 -  Set bOk = SqlDisconnect( hSqlHandle )
.head 6 -  Return bOk

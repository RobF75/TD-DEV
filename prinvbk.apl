.head 4 +  Functions 
.head 5 +  Function: GetSubItemDetails
.head 6 -  Description: 
.head 6 +  Returns 
.head 7 -  Boolean: 
.head 6 +  Parameters 
.head 7 -  Number: nItemNo
.head 7 -  Number: nExecuteOrDisconnect
.head 6 +  Static Variables 
.head 7 -  Sql Handle: hSqlHandle
.head 7 -  Boolean: bHandleConnected
.head 7 -  Boolean: bHandlePrepared
.head 6 +  Local variables 
.head 7 -  String: sSql
.head 7 -  String: sWhere
.head 7 -  String: sTables
.head 7 -  Number: nInd
.head 6 +  Actions 
.head 7 +  If nExecuteOrDisconnect != nDisconnect
.head 8 +  If NOT bHandleConnected
.head 9 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 9 +  If bHandleConnected
.head 10 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 10 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 9 +  Else 
.head 10 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 10 -  Return -1
.head 8 +  If NOT bHandlePrepared
.head 9 -  Set sSql = sgSql
.head 9 -  Set sTables = 'Stock_Item '
.head 9 -  ! Set sTables = 'Stock_Item, Cultivar'
.head 9 -  Set sWhere = ' WHERE  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Cultivar_Id = Cultivar.Cult_Id(+) '
.head 9 -  ! Set sWhere = ' WHERE  Stock_Item.Item_No = :nItemNo '
.head 9 -  Call CallBuildSql( hWndForm, nSELECT, PAM_SUBITEMDETAILS, sTables, sWhere )
.head 9 +  If SqlPrepare( hSqlHandle, sgSql )
.head 10 -  Set bHandlePrepared = TRUE
.head 9 +  Else 
.head 10 -  Set bHandlePrepared = FALSE
.head 9 -  Set sgSql = sSql
.head 8 -  Call SalSendMsgToChildren( hWndForm, PAM_INITIALIZE, 0, 0 )
.head 8 +  If SqlExecute( hSqlHandle )
.head 9 +  If SqlFetchNext( hSqlHandle, nInd )
.head 10 -  Return TRUE
.head 9 +  Else 
.head 10 -  Return FALSE
.head 8 +  Else 
.head 9 -  Set bHandlePrepared = FALSE
.head 9 -  Call SalMessageBox( 'SqlExecute had a error in function GetCustNames! Please contact programmers!', 'Error', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  Else 
.head 8 -  Set bHandlePrepared = FALSE
.head 8 +  If bHandleConnected
.head 9 -  Set bHandleConnected = FALSE
.head 9 -  Call SqlDisconnect( hSqlHandle )
.head 8 -  Return FALSE
.head 5 +  Function: GetCustAmtDepositPaid
.head 6 -  Description: 
.head 6 +  Returns 
.head 7 -  Boolean: 
.head 6 +  Parameters 
.head 7 -  Number: nCustNo
.head 7 -  Receive Number: nAmtDepositPaid
.head 7 -  Number: nExecuteOrDisconnect
.head 6 +  Static Variables 
.head 7 -  Sql Handle: hSqlHandle
.head 7 -  Boolean: bHandleConnected
.head 7 -  Boolean: bHandlePrepared
.head 6 +  Local variables 
.head 7 -  String: sSql
.head 7 -  Number: nInd
.head 7 -  Number: nGotAmtDepositPaid
.head 6 +  Actions 
.head 7 +  If nExecuteOrDisconnect != nDisconnect
.head 8 +  If NOT bHandleConnected
.head 9 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 9 +  If bHandleConnected
.head 10 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 10 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 9 +  Else 
.head 10 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 10 -  Return -1
.head 8 +  If NOT bHandlePrepared
.head 9 -  Set sSql = ' SELECT Dep_Amount_Paid 
  FROM Outstand_Deposit
  INTO :nGotAmtDepositPaid 
  WHERE Cust_No = :nCustNo AND Dep_Amount_Paid > 0 
  AND DEP_YEAR_OF_SALE = :frmPrintInvBook.dfYear '
.head 9 -  ! Set sSql = ' SELECT Dep_Amount_Paid 
  FROM Outstand_Deposit
  INTO :nGotAmtDepositPaid 
  WHERE Cust_No = :nCustNo AND Dep_Amount_Paid > 0 '
.head 9 +  If SqlPrepare( hSqlHandle, sSql )
.head 10 -  Set bHandlePrepared = TRUE
.head 9 +  Else 
.head 10 -  Set bHandlePrepared = FALSE
.head 8 -  Set nGotAmtDepositPaid = 0
.head 8 -  Set nAmtDepositPaid = 0
.head 8 +  If SqlExecute( hSqlHandle )
.head 9 +  If SqlFetchNext( hSqlHandle, nInd )
.head 10 -  Set nAmtDepositPaid = nGotAmtDepositPaid
.head 10 -  Return TRUE
.head 9 +  Else 
.head 10 -  Return FALSE
.head 8 +  Else 
.head 9 -  Set bHandlePrepared = FALSE
.head 9 -  Call SalMessageBox( 'SqlExecute had a error in function GetCustAmtDepositPaid! Please contact programmers!', 'Error', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  Else 
.head 8 -  Set bHandlePrepared = FALSE
.head 8 +  If bHandleConnected
.head 9 -  Set bHandleConnected = FALSE
.head 9 -  Call SqlDisconnect( hSqlHandle )
.head 8 -  Return FALSE
.head 4 +  Window Variables 
.head 5 -  Number: nTotalAvail
.head 5 -  String: sSQLWHERERPFC
.head 5 -  String: sSQLWHERENORPFC
.head 5 -  String: sSQLWHERERD1RPFC
.head 5 -  String: sSQLWHERERD1NORPFC
.head 4 +  Message Actions 
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLTABLENAME = ' Customer_Order '
.head 6 -  Set sSQLPOPTABLENAME = ' Customer_Order, Customer_Master '
.head 6 -  Set sROWID = ' CUSTOMER_ORDER.ROWID '
.head 6 -  Set sSQLWHERENORPFC = " WHERE Customer_Order.Cust_No = Customer_Master.Cust_No AND 
    Customer_Order.Year_Of_Sale = :frmPrintInvBook.dfYear AND 
    Customer_Order.Stock_Item_No = :frmPrintInvBook.dfItemNo AND NOT 
    ( Customer_Order.Sale_Cat = 'FC' OR Customer_Order.Sale_Cat = 'RP' ) "
.head 6 -  Set sSQLWHERERPFC = " WHERE Customer_Order.Cust_No = Customer_Master.Cust_No AND 
    Customer_Order.Year_Of_Sale = :frmPrintInvBook.dfYear AND 
    Customer_Order.Stock_Item_No = :frmPrintInvBook.dfItemNo AND 
    ( Customer_Order.Sale_Cat = 'FC' OR Customer_Order.Sale_Cat = 'RP' ) "
.head 6 -  !
.head 6 -  Set sSQLWHERERD1NORPFC = " WHERE Customer_Order.Cust_No = Customer_Master.Cust_No AND 
    Customer_Order.Year_Of_Sale = :frmPrintInvBook.dfYear AND 
    ( Customer_Order.Stock_Item_No = :frmPrintInvBook.dfItemNo OR 
      Customer_Order.Stock_Item_No = :frmPrintInvBook.dfRD1ItemNo ) AND NOT 
    ( Customer_Order.Sale_Cat = 'FC' OR Customer_Order.Sale_Cat = 'RP' ) "
.head 6 -  Set sSQLWHERERD1RPFC = " WHERE Customer_Order.Cust_No = Customer_Master.Cust_No AND 
    Customer_Order.Year_Of_Sale = :frmPrintInvBook.dfYear AND 
    ( Customer_Order.Stock_Item_No = :frmPrintInvBook.dfItemNo OR
      Customer_Order.Stock_Item_No = :frmPrintInvBook.dfRD1ItemNo ) AND 
    ( Customer_Order.Sale_Cat = 'FC' OR Customer_Order.Sale_Cat = 'RP' ) "
.head 6 -  !
.head 6 -  Set sSQLWHERE = sSQLWHERENORPFC
.head 6 -  Set sORDERBY = ' ORDER BY Customer_Order.Ord_Date '
.head 5 +  On PAM_POPULATE
.head 6 +  If wParam = 1
.head 7 +  If frmPrintInvBook.bIncludeRD1Items
.head 8 -  Set sSQLWHERE = sSQLWHERERD1RPFC
.head 7 +  Else 
.head 8 -  Set sSQLWHERE = sSQLWHERERPFC
.head 7 -  Set nTotalAvail = frmPrintInvBook.dfTotalAvail - frmPrintInvBook.dfAmtOnOrdAsSubs
.head 6 +  Else 
.head 7 +  If frmPrintInvBook.bIncludeRD1Items
.head 8 -  Set sSQLWHERE = sSQLWHERERD1NORPFC
.head 7 +  Else 
.head 8 -  Set sSQLWHERE = sSQLWHERENORPFC
.head 6 -  Call SalSendClassMessage( PAM_POPULATE, wParam, lParam )
.head 5 +  On SAM_FetchRowDone
.head 6 +  If SalIsNull( colConfAmt )
.head 7 -  Set colQuantity = colOrdAmt
.head 6 +  Else 
.head 7 -  Set colQuantity = colConfAmt
.head 6 +  If colAllocFlag = 'Y'
.head 7 -  Set colAllocated = 'YES'
.head 6 +  Else 
.head 7 -  Set colAllocated = 'NO'
.head 6 -  !
.head 6 -  Call GetBusAddressBindNewLogic( colCustNo, ' Area_Code, Phone_No ', ' :frmPrintInvBook.tblOrderedBy.colAreaCode, :frmPrintInvBook.tblOrderedBy.colPhoneNo ', nExecute )
.head 6 -  !
.head 6 +  If frmPrintInvBook.bIncludeRD1Items
.head 7 -  Call GetItemTreeType( colItemNo, colMR1RD1TreeType, nExecute )
.head 6 -  !
.head 6 +  If frmPrintInvBook.dfGenericFlag != 'Y'
.head 7 -  Set nTotalAvail = nTotalAvail - colQuantity
.head 7 -  Set colAvailable = nTotalAvail
.head 6 -  !
.head 6 -  Call GetCustAmtDepositPaid( colCustNo, colAmtDepositPaid, nExecute )
.head 5 +  On PAM_RESET
.head 6 -  Call PushWndHdl( hWndNULL )
.head 6 -  Call SalSendClassMessage( PAM_RESET, wParam, lParam )
.head 5 +  On PAM_NOROWS
.head 6 -  Return TRUE
.head 5 +  On SAM_Destroy
.head 6 -  Call GetSubItemDetails( 0, nDisconnect )
.head 6 -  Call GetBusAddressBindNewLogic( 0, '', '', nDisconnect )
.head 6 -  Call GetItemTreeType( 0, colMR1RD1TreeType, nDisconnect )
.head 6 -  Call GetCustAmtDepositPaid( 0, colAmtDepositPaid, nDisconnect )
.head 6 -  Call SalSendClassMessage( SAM_Destroy, wParam, lParam )

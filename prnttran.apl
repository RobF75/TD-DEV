.head 6 -  Set sSql =
" 
SELECT 
	TRANS_HISTORY.Cust_No, 
	CUSTOMER_MASTER.CUST_NAME, 
	TRANS_HISTORY.HIST_REFERENCE_ID,
	TRANS_HISTORY.HIST_TRANS_TYPE, 
	TRANS_HISTORY.HIST_TRANS_CODE,
	TRANS_HISTORY.HIST_TRANS_AMOUNT, 
	TRANS_HISTORY.HIST_GST,
	TRANS_HISTORY.HIST_TRANS_DATE,
	TRANS_HISTORY.HIST_TRANS_NOTES
FROM 
	TRANS_HISTORY, 
	Customer_Master
INTO 
	:frmPrintTranAudit.nHistCustNo,
	:frmPrintTranAudit.sHistCustName, 
	:frmPrintTranAudit.sHistRefId,
	:frmPrintTranAudit.sHistTransType,
	:frmPrintTranAudit.sHistTransCode,
	:frmPrintTranAudit.nHistTransAmt, 
	:frmPrintTranAudit.nHistTransGST, 
	:frmPrintTranAudit.dtHistInvDate, 
	:frmPrintTranAudit.sHistTransNotes 
WHERE 
	TRANS_HISTORY.HIST_TRANS_DATE >= :frmPrintTranAudit.dtFromDate AND
	TRANS_HISTORY.HIST_TRANS_DATE <= :frmPrintTranAudit.dtToDate AND
 	TRANS_HISTORY.CUST_NO = CUSTOMER_MASTER.CUST_NO AND 
	(TRANS_HISTORY.HIST_TRANS_TYPE NOT LIKE 'INVOICE' AND 
	TRANS_HISTORY.HIST_TRANS_TYPE NOT LIKE 'CREDNOTE') and
	hist_company = :sCompany
ORDER BY 
	TRANS_HISTORY.HIST_TRANS_DATE
"   

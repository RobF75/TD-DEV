TRANS_HISTORY.HIST_TRANS_TYPE, TRANS_HISTORY.HIST_TRANS_CODE,TRANS_HISTORY.HIST_TRANS_AMOUNT, TRANS_HISTORY.HIST_TRANS_DATE

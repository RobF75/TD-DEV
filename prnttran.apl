.head 6 -  Set sSql =
"
SELECT 
	TRANSACTION.Cust_No, 
	CUSTOMER_MASTER.CUST_NAME, 
	TRANSACTION.REFERENCE_ID,
	TRANSACTION.TRANSACTION_TYPE, 
	TRANSACTION.TRANSACTION_CODE,
	TRANSACTION.TRANSACTION_AMOUNT, 
	TRANSACTION.TRANS_GST,
	TRANSACTION.TRANSACTION_DATE,
	TRANSACTION.TRANSACTION_NOTES
FROM 
	TRANSACTION, 
	Customer_Master
INTO 
	:frmPrintTranAudit.nCustNo,
	:frmPrintTranAudit.sCustName, 
	:frmPrintTranAudit.sRefId,
	:frmPrintTranAudit.sTransType,
	:frmPrintTranAudit.sTransCode,
	:frmPrintTranAudit.nTransAmt, 
	:frmPrintTranAudit.nTransGST, 
	:frmPrintTranAudit.dtInvDate, 
	:frmPrintTranAudit.sTransNotes 
WHERE 
	TRANSACTION.TRANSACTION_DATE >= :frmPrintTranAudit.dtFromDate AND
	TRANSACTION.TRANSACTION_DATE <= :frmPrintTranAudit.dtToDate AND
	 TRANSACTION.CUST_NO = CUSTOMER_MASTER.CUST_NO AND 
  	(TRANSACTION.TRANSACTION_TYPE NOT LIKE 'INVOICE' 
		AND TRANSACTION.TRANSACTION_TYPE NOT LIKE 'CREDNOTE') and
	Company = :sCompany
ORDER BY 
	TRANSACTION.TRANSACTION_DATE
"   

.head 6 -  !
.head 3 +  On SAM_ReportFinish
.head 4 -  Call SetDefaultPrinter(  )
.head 4 -  Call SalWaitCursor( FALSE )
.head 4 +  If bHistHdlConnected
.head 5 -  Call SqlDisconnect( hSqlHistHandle )
.head 5 -  Set bHistHdlConnected = FALSE
.head 5 -  Set bHistHdlPrepared = FALSE
.head 4 +  If bTransHdlConnected
.head 5 -  Call SqlDisconnect( hSqlTransHandle )
.head 5 -  Set bTransHdlConnected = FALSE
.head 5 -  Set bTransHdlPrepared = FALSE
.head 4 -  Call SalPostMsg( SalParentWindow( hWndForm ), PAM_REPORTFINISHED, nPullSheet, 0 )
.head 4 -  Call SalDestroyWindow( hWndForm )
.head 4 -  Return TRUE

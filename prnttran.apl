  INTO :frmPrintTranAudit.nHistCustNo,:frmPrintTranAudit.sHistCustName, :frmPrintTranAudit.sHistRefId,
:frmPrintTranAudit.sHistTransType,:frmPrintTranAudit.sHistTransCode,:frmPrintTranAudit.nHistTransAmt, :frmPrintTranAudit.dtHistInvDate 

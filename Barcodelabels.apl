.head 6 -  Set sSelect = 
"SELECT
	customer_master.Cust_no,
	Cust_Name,
	Supplier_Number,
	customer_order.stock_item_no,
	cult_desc,
	conf_amt,
	fine_line,
	retail_price,
	barcode
INTO
	:nCustNo,
	:sCustName,
	:sSupplier,
	:nItemNo,
	:sCultDesc,
	:nConfAmt,
	:nFineline,
	:nPrice,
	:sBarcode
FROM
	Customer_Master,
	Load_Customers,
	customer_order,
	Customer_item,
	stock_item
WHERE
	Customer_master.Cust_No = Load_Customers.Cust_No and
	customer_item.cust_no = customer_master.cust_no and
	customer_order.stock_item_no = stock_item.item_no and
	customer_order.cust_no = customer_item.cust_no and
	stock_item.item_no = customer_item.stock_item_no and
	load_customers.load_id = customer_order.load_id and
	customer_order.Load_Id = :sLoadId and
	customer_master.fineline = 'Y' 
ORDER BY
	Load_Customers.Sequence_no,
	stock_item.variety_type,
	stock_item.variety,
	stock_item.cult_desc
"
.head 6 -  ! Set sLabelSelect = 
	"
	SELECT
		fine_line,
		retail_price,
		barcode
	INTO
		:nFineline,
		:nPrice,
		:sBarcode
	FROM
		Customer_Item
	WHERE
		Customer_Item.Stock_Item_No = :nItemNo and
		Customer_Item.Cust_No = :nGetCustNo
	"


.head 6 -  ! Set sAssSelect = 
	"
	SELECT
		customer_master.Cust_no,

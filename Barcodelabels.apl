.head 3 +  Function: GetParentModuleDetails
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Receive Number: nItemNo
.head 5 -  Date/Time: dtOrdDT

	FROM
		Customer_Master,
		Load_Customers
	WHERE
		Customer_Master.Cust_No = Load_Customers.Cust_No and
		Load_Id = :sLoadId and
		customer_master.fineline = 'Y' 
	ORDER BY
		Load_Customers.Sequence_no
	"

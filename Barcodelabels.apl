.head 5 -  String: sName
.head 5 -  Number: nSqlHandleNo
.head 5 -  ! Number: nSqlRootHandleNo
.head 5 -  !
.head 5 -  Number: nInd
.head 5 -  !
.head 5 -  Boolean: bOk
.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GETPARENTMODDETS' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = 
" SELECT 
	Cult_Desc,
	Fineline,
	Retail_Price,
	Barcode,
	Parent_Item_No
FROM
	Customer_Item,
	Stock_Item
	Customer_Order
WHERE 
	Customer_Item.Stock_Item_No = Stock_Item.Item_No AND
	Customer_Order.Stock_Item_No = Customer_Item.Stock_Item_No AND
	Parent_Item_No = :1 AND 
              Customer_Order.Cust_No = :2 AND
	Customer_Item.Cust_No = :2 AND
	Customer_Order.Order_Date_Time = :3 
"
.head 7 -  Set sName = 'GETPARENTMODDETS'
.head 7 -  Set sBind = ':nItemNo, :nCustNo'
.head 7 -  Set sInto = ':sCultDesc, :sFineline, :nPrice, :sBarcode, :nParentItemNo'
.head 7 -  !
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect()
.head 3 +  Function: SetItemBarcodedFlag
.head 4 -  Description: Set Customer_Order table Barcodes_Printed flag For Load_ID
This function does its own commit and rollbacks
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  String: sLoadId
.head 5 -  Number: nInstNo
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  ! hcSqlHandle: fcOurHandle
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nSqlHandleNo
.head 5 -  !
.head 5 -  Number: nInd
.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'SETBARCODEFLAG1' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " UPDATE Customer_Order
SET
  Barcodes_Printed = 'Y'
WHERE
  Cust_No = :1 AND
  Load_Id = :2 AND
  Load_Cust_Inst_No = :3 AND
  (Barcodes_Printed = 'N' OR Barcodes_Printed IS NULL)"
.head 7 -  Set sName = 'SETBARCODEFLAG1'
.head 7 -  Set sBind = ':nCustNo, :sLoadId, :nInstNo'
.head 7 -  Set sInto = ''
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 -  Call SetItemBarcodedFlag( 0, '', 0, SH_cls_Commit )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Commit
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Commit( )
.head 6 +  Case SH_cls_Rollback
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )

.head 6 -  Set sSql = 
"SELECT
	customer_master.Cust_no,
	Cust_Name,
	Supplier_Number,
	Bitmap,
	customer_order.stock_item_no,
	cult_desc,
	tree_type.type_description,
	variety_type,
	conf_amt,
	fine_line,
	retail_price,
	barcode,
	Module_Child,
	Order_Date_Time
FROM
	Customer_Master,
	Load_Customers,
	customer_order,
	Customer_item,
	stock_item,
	Tree_Type
WHERE
	Tree_Type.tree_type = stock_item.tree_type and
	Customer_master.Cust_No = Load_Customers.Cust_No and
	customer_item.cust_no = customer_master.cust_no and
	customer_order.stock_item_no = stock_item.item_no and
	customer_order.cust_no = customer_item.cust_no and
	stock_item.item_no = customer_item.stock_item_no and
	load_customers.load_id = customer_order.load_id and
	customer_order.Load_Id = :1 and
	customer_master.fineline = 'Y' and
	Customer_Order.Cust_No in ( :2 )
ORDER BY
	Load_Customers.Sequence_no,
	stock_item.variety_type desc,
	stock_item.variety desc,
	stock_item.cult_desc desc
"
.head 6 -  Set sBind = ':sLoadId, :sCustNos'
.head 6 -  Set sInto = ':nCustNo,
	:sCustName,
	:sSupplier,
	:sBitmap,
	:nItemNo,
	:sCultDesc,
	:sType,
	:sVarietyType
	:nConfAmt,
	:sFineline,
	:nPrice,
	:sBarcode,
	:sModuleChild,
	:dtOrdDT'
.head 6 -  Set sName = 'SELCUSTFINE1'
.head 6 -  Call fcLabelsOnLoadHdl.Setup( sSql, sName, sBind, sInto )
.head 6 -  Call SqlVarSetup( fcLabelsOnLoadHdl.hSqlHandle )
.head 4 +  Else If nActionType = nSelectedCustOrdOLoad
.head 5 -  Call MakeDateTimeList( dtOrdDT, ' , ', '', sTmp )
.head 5 -  Set nCustNo = naArrayNos[0]

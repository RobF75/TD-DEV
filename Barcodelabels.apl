.head 6 -  Set sSql = 
"SELECT
	customer_master.Cust_no,
	Cust_Name,
	Supplier_Number,
	Bitmap,
	customer_order.stock_item_no,
	cult_desc,
	tree_type.type_description,
	variety_type,
	conf_amt,
	fine_line,

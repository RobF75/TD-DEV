	cult_desc,
	conf_amt
into
	:nItemNo,
	:sCultDesc,
	:nConfAmt
from
	customer_order,
	stock_item
where
	customer_order.stock_item_no = stock_item.item_no and
	customer_order.load_id = :sLoadId and
	customer_order.conf_amt > 0 and
	year_of_sale = :nYear and
	customer_order.cust_no = :nCustNo
"

.head 8 -  Set sSQLRefreshHandle = " SELECT 'Y',
Invoice_Items.Creditor_No,
Creditor.Creditor_Name,
Creditor.Creditor_Add1,
Creditor.Creditor_Add2,
Creditor.Creditor_Suburb,
Creditor.Creditor_Postcode,
Creditor.Creditor_State,
Invoice_Items.Item_Id,
Payable_Items.Item_Description,
Item_Status,
No_Of_Items,
Invoice_Unit_Price,
Item_Disc_Given,
Extended_Price,
Invoice_Items.Invoice_No,
Payable_Invoice.Invoice_Status,
Payable_Invoice.Invoice_Amount,
Payable_Invoice.Amount_Outstanding,
Payable_Invoice.Invoice_Date,
Invoice_Items.Seq_No,
GL_Code,
Comments
FROM
  Invoice_Items, Payable_Items, Payable_Invoice, Creditor 
WHERE
Invoice_Items.Creditor_No = Creditor.Creditor_No and 
Invoice_Items.Creditor_No = Payable_Invoice.Creditor_No and
Invoice_Items.Invoice_No = Payable_Invoice.Invoice_No and
Invoice_Items.Item_Id = Payable_Items.Item_Id and 
Invoice_Items.Creditor_No = :1 and 
Invoice_Items.Invoice_No = :2 and 
Invoice_Items.Seq_No = :3"

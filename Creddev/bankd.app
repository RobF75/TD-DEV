.head 11 +  ! Else
.head 12 -  Set sPayStatusCodes = sPayStatusCodes||", '"||sGotCode||"'"
.head 11 +  If sPayStatusCodes = ''
.head 12 -  Set sPayStatusCodes = '"'||sGotCode||'"'
.head 11 +  Else

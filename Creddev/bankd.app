.head 7 +  On PAM_clsTBL_SAVEROWEDITED
.head 8 +  If SalIsWindowVisible( pbReconcile )
.head 9 +  If haSqlHandles[ nSqlUpdHandleNo ].Execute( )
.head 10 -  Call haSqlHandles[ nSqlUpdHandleNo ].Commit( )
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Else
.head 9 -  Return SalSendClassMessage( PAM_clsTBL_SAVEROWEDITED, wParam, lParam )

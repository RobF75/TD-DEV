.head 5 +  On PAM_clsMDI_CHILDCHANG
.head 6 -  Set dfBankBranch = hWndBank.(mdiMain.frmBank).tblBank.colBranch
.head 6 -  Set dfBankId = hWndBank.(mdiMain.frmBank).tblBank.colBankId
.head 6 -  Set dfBankName =  hWndBank.(mdiMain.frmBank).tblBank.colName
.head 6 -  Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_POPULATE, 0, 0 )
.head 6 -  Call SalPostMsg( hWndSign, PAM_clsMDI_CHILDCHANG, 0, 0 )
.head 6 -  Call SalPostMsg( hWndMovement, PAM_clsMDI_CHILDCHANG, 0, 0 )
.head 6 -  Call SalBringWindowToTop( hWndAccounts )
.head 5 +  On SAM_CreateComplete
.head 6 -  Call SalPostMsg( mdiMain.pbSign, PAM_clsPB_ENABLE, 0, 0 )
.head 6 -  Call SalPostMsg( mdiMain.pbDateMovement, PAM_clsPB_ENABLE, 0, 0 )
.head 6 -  Set dfBankBranch = hWndBank.(mdiMain.frmBank).tblBank.colBranch
.head 6 -  Set dfBankId = hWndBank.(mdiMain.frmBank).tblBank.colBankId

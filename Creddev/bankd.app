.head 7 +  On PAM_clsMDI_RECALC
.head 8 +  If colCleared = 'Y'
.head 9 +  If colMoveCRDR = 'CR'
.head 10 -  Set dfCalcdBal = dfCalcdBal + colAmount
.head 9 +  Else
.head 10 -  Set dfCalcdBal = dfCalcdBal - colAmount
.head 10 -  ! Set dfDiff = dfOpenBal - dfCloseBal
.head 10 +  ! If dfDiff = 0
.head 11 -  Call SalShowWindow( pbReconcile )
.head 10 +  ! Else
.head 11 -  Call SalHideWindow( pbReconcile )
.head 8 -  ! Want to reverse the addition/subtraction
.head 8 +  Else
.head 9 +  If colMoveCRDR = 'CR'
.head 10 -  Set dfCalcdBal = dfCalcdBal - colAmount
.head 9 +  Else
.head 10 -  Set dfCalcdBal = dfCalcdBal + colAmount
.head 8 -  Set dfDiff = dfCloseBal - dfCalcdBal
.head 8 +  If dfDiff = 0
.head 9 -  Call SalShowWindow( pbReconcile )
.head 8 +  Else
.head 9 -  Call SalHideWindow( pbReconcile )
.head 7 -  ! on a rowedited - want to check if the update on the table has been done via the reconcile pb or the

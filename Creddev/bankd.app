.head 6 +  Functions
.head 7 +  Function: AddToStatus
.head 8 -  Description: When the user has entered a status code which doesnt exist in the table, we
prompt them for a  description and action and then add it 
.head 8 +  Returns
.head 9 -  Boolean:
.head 8 +  Parameters
.head 9 -  String: sStatusCode
.head 9 -  String: sStatusDesc
.head 9 -  String: sPay
.head 9 -  Number: nActionType
.head 8 -  Static Variables
.head 8 +  Local variables
.head 9 -  String: sSql
.head 9 -  String: sName
.head 9 -  String: sBind
.head 9 -  String: sInto
.head 9 -  Number: nSqlHandleNo
.head 9 -  Number: nInd
.head 8 +  Actions
.head 9 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'AddStatus' )
.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set sSql = ' Insert Into Status_codes
(Status_Code,
Description,
Pay)
Values 
( :1, :2, :3)'
.head 11 -  Set sName = 'AddStatus'
.head 11 -  Set sBind = ':sStatusCode, :sStatusDesc, :sPay'
.head 11 -  Set sInto = ''
.head 11 -  ! !
.head 11 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 11 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 11 -  !
.head 11 +  If haSqlHandles[nSqlHandleNo ].Execute( )
.head 12 -  Return TRUE
.head 11 +  Else
.head 12 -  Return FALSE
.head 10 +  Case SH_cls_Commit
.head 11 -  Call haSqlHandles[nSqlHandleNo ].Commit( )
.head 10 +  Case SH_cls_Rollback
.head 11 -  Call haSqlHandles[nSqlHandleNo ].Rollback( )
.head 10 +  Case SH_cls_Disconnect
.head 11 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 11 -  Return TRUE
.head 7 +  Function: VerifyChqNo
.head 8 -  Description: When the user has entered a cheque no verify that we dont have any cheques entered for this account
which are greater than the number entered
.head 8 +  Returns
.head 9 -  Boolean:
.head 8 +  Parameters
.head 9 -  Number: nStartingChqNo
.head 9 -  Number: nEndingChqNo
.head 9 -  String: sBankId
.head 9 -  String: sAccNo
.head 9 -  Number: nActionType
.head 8 -  Static Variables
.head 8 +  Local variables
.head 9 -  String: sSql
.head 9 -  String: sName
.head 9 -  String: sBind
.head 9 -  String: sInto
.head 9 -  Number: nSqlHandleNo
.head 9 -  Number: nInd
.head 9 -  Number: nGotChqNo
.head 8 +  Actions
.head 9 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'VChqNo' )
.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set sSql = ' SELECT
 Cheque_No
FROM
Account_Movement
WHERE
Bank_Id = :1 and Account_No = :2 and Cheque_No BETWEEN :3 and :4'
.head 11 -  Set sName = 'VChqNo'
.head 11 -  Set sBind = ':sBankId, :sAccNo, :nStartingChqNo, :nEndingChqNo'
.head 11 -  Set sInto = ':nGotChqNo'
.head 11 -  ! !
.head 11 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 11 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 11 -  !
.head 11 +  If haSqlHandles[nSqlHandleNo ].Execute( )
.head 12 +  If haSqlHandles[nSqlHandleNo ].FetchNext( nInd )
.head 13 -  ! ie there is a cheque no in the system which is greater than the starting cheque no to be used
.head 13 -  Return FALSE
.head 12 +  Else
.head 13 -  Return TRUE
.head 11 +  Else
.head 12 -  Return TRUE
.head 10 +  Case SH_cls_Disconnect
.head 11 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 11 -  Return TRUE
.head 7 +  Function: UpdateForCheque
.head 8 -  Description: To scroll through the table picking out for each creditor for each invoice that
has items paid on it and summing them to enable us to update the parent
invoices amount outstanding
.head 8 +  Returns
.head 9 -  Boolean:
.head 8 +  Parameters
.head 9 -  String: sBankId
.head 9 -  String: sAccNo
.head 9 -  Number: nActionType
.head 8 -  Static Variables
.head 8 +  Local variables
.head 9 -  Number: nCredNo[*]
.head 9 -  String: sInvNo[*]
.head 9 -  Number: nTotal[*]
.head 9 -  Number: nChqNo[*]
.head 9 -  String: sCredName[*]
.head 9 -  Number: nSeqNo
.head 9 -  Number: i
.head 9 -  Boolean: bOk
.head 8 +  Actions
.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set nRow = TBL_MinRow
.head 11 -  Set i = 0
.head 11 +  While SalTblFindNextRow( hWndForm, nRow, wParam, lParam )
.head 12 -  Call SalTblFetchRow( hWndForm, nRow )
.head 12 +  If colConfPay = 'Y'
.head 13 +  If colCredNo = nCredNo[i]
.head 14 +  If colInvNo = sInvNo[i]
.head 15 -  Set nTotal[i] = nTotal[i] + colExtPrice
.head 14 +  Else
.head 15 -  Set i = i + 1
.head 15 -  Set nCredNo[i] = colCredNo
.head 15 -  Set nTotal[i] = colExtPrice
.head 15 -  Set sInvNo[i] = colInvNo
.head 15 -  Set nChqNo[i] = colChqNo
.head 15 -  Set sCredName[i] = colCredName
.head 13 +  Else
.head 14 -  Set i = i + 1
.head 14 -  Set nCredNo[i] = colCredNo
.head 14 -  Set nTotal[i] = colExtPrice
.head 14 -  Set sInvNo[i] = colInvNo
.head 14 -  Set nChqNo[i] = colChqNo
.head 14 -  Set sCredName[i] = colCredName
.head 11 -  Set i = 1
.head 11 -  Set bOk = TRUE
.head 11 +  While nCredNo[i] != 0 and bOk
.head 12 +  If UpdCredInv( nCredNo[i], sInvNo[i], nTotal[i], SH_cls_Execute ) 
.head 13 -  Set bOk = InsAccMove( sBankId, sAccNo, nCredNo[i], sCredName[i], sInvNo[i], nTotal[i], nChqNo[i], SH_cls_Execute ) 
.head 12 -  Set i = i + 1
.head 11 +  If bOk
.head 12 -  Call UpdCredInv( 0, '', 0, SH_cls_Commit )
.head 12 -  Call InsAccMove( '', '', 0, '', '', 0, 0, SH_cls_Commit )
.head 11 +  Else
.head 12 -  Call UpdCredInv( 0, '', 0, SH_cls_Rollback )
.head 12 -  Call InsAccMove( '', '', 0, '', '', 0, 0, SH_cls_Rollback )
.head 12 -  Return FALSE
.head 11 -  ! Need to process through the table again to set the status to paid, insert records into
the cheque application file for each item and insert into sold by table for each item, when this
is done we will return and send a sam_click to the table save changes to update the status
.head 11 -  Set nRow = TBL_MinRow
.head 11 -  Set bOk = TRUE
.head 11 +  While SalTblFindNextRow( hWndForm, nRow, wParam, lParam ) and bOk
.head 12 -  Call SalTblFetchRow( hWndForm, nRow )
.head 12 +  If colConfPay = 'Y'
.head 13 -  Set colItemStatus = 'PAID'
.head 13 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_Edited, TRUE )
.head 13 +  If ExtractAccMoveSeqNo ( sBankId, sAccNo, colChqNo, nSeqNo, SH_cls_Execute )
.head 14 +  If InsChqApp( nSeqNo, colCredNo, colInvNo, colSeqNo, SH_cls_Execute )
.head 15 -  Set bOk = InsSoldBy( colItemId, colCredNo, colUnitPrice, SH_cls_Execute )
.head 14 +  Else
.head 15 -  Set bOk = FALSE
.head 13 +  Else
.head 14 -  Set bOk = FALSE
.head 13 +  ! If NOT ExtractAccMoveSeqNo ( sBankId, sAccNo, colChqNo, nSeqNo, SH_cls_Execute )
.head 14 -  Set bOk = FALSE
.head 13 +  ! If InsChqApp( nSeqNo, colCredNo, colInvNo, colSeqNo, SH_cls_Execute )
.head 14 -  Set bOk = InsSoldBy( colItemId, colCredNo, colUnitPrice, SH_cls_Execute )
.head 11 +  If bOk
.head 12 -  Call InsChqApp( 0, 0, '', 0, SH_cls_Commit )
.head 12 -  Call InsSoldBy( 0, 0,  0, SH_cls_Commit )
.head 11 +  Else
.head 12 -  Call InsChqApp( 0, 0, '', 0, SH_cls_Rollback )
.head 12 -  Call InsSoldBy( 0, 0, 0, SH_cls_Rollback )
.head 11 -  Return TRUE
.head 10 +  Case SH_cls_Disconnect
.head 11 -  Call UpdCredInv( 0, '', 0, SH_cls_Disconnect )
.head 11 -  Call InsAccMove( '', '', 0, '', '', 0, 0, SH_cls_Disconnect )
.head 11 -  Call ExtractAccMoveSeqNo( '', '', 0, nSeqNo, SH_cls_Disconnect )
.head 11 -  Call InsChqApp( 0, 0, '', 0, SH_cls_Disconnect )
.head 11 -  Call InsSoldBy( 0, 0, 0, SH_cls_Disconnect )
.head 11 -  Return TRUE
.head 7 +  Function: UpdateInvoice
.head 8 -  Description: To scroll through the table picking out for each item in there to check if the parent
invoice has all of its children items paid and if so to reset the parent invoice to being
status of paid
.head 8 +  Returns
.head 9 -  Boolean:
.head 8 +  Parameters
.head 9 -  Number: nActionType
.head 8 -  Static Variables
.head 8 +  Local variables
.head 9 -  Boolean: bOk
.head 9 -  Number: nRow
.head 9 -  String: sLastInvNo
.head 8 +  Actions
.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set nRow = TBL_MinRow
.head 11 -  Set sLastInvNo = ''
.head 11 +  While SalTblFindNextRow( hWndForm, nRow, wParam, lParam )
.head 12 -  Call SalTblFetchRow( hWndForm, nRow )
.head 12 +  If colItemStatus = 'PAID'
.head 13 +  If sLastInvNo != colInvNo
.head 14 +  If AllItemsPaid (colCredNo, colInvNo, SH_cls_Execute )
.head 15 +  If SetInvStatus (colCredNo, colInvNo, 'PAID', SH_cls_Execute)
.head 16 -  Call SetInvStatus ( 0,'', '', SH_cls_Commit )
.head 15 +  Else
.head 16 -  Call SetInvStatus ( 0, '', '', SH_cls_Rollback )
.head 14 -  Set sLastInvNo = colInvNo
.head 11 -  Return TRUE
.head 10 +  Case SH_cls_Disconnect
.head 11 -  Call AllItemsPaid (0 , '', SH_cls_Disconnect )
.head 11 -  Call SetInvStatus( 0, '', '', SH_cls_Disconnect )
.head 11 -  Return TRUE
.head 7 +  Function: AllItemsPaid
.head 8 -  Description:
.head 8 +  Returns
.head 9 -  Boolean:
.head 8 +  Parameters
.head 9 -  Number: nCredNo
.head 9 -  String: sInvNo
.head 9 -  Number: nActionType
.head 8 -  Static Variables
.head 8 +  Local variables
.head 9 -  String: sSql

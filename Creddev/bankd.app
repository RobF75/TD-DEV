.head 6 -  Call SalSendMsgToChildren( hWndAccounts, PAM_clsTBL_REFRESHROW, wParam, lParam )
.head 5 +  On SAM_Close
.head 6 -  Set hWndAccounts = hWndNULL
.head 6 -  Call SalPostMsg( mdiMain.pbAccounts, PAM_clsPB_ENABLE, 0, 0 )
.head 6 -  Call SalPostMsg( mdiMain.pbSign, PAM_clsPB_DISABLE, 0, 0 )
.head 6 -  Call SalSendClassMessage( SAM_Close, wParam, lParam )
.head 5 +  On SAM_Activate
.head 6 +  If wParam
.head 7 -  Call SalShowWindow( pbGenChq )
.head 6 +  Else
.head 7 -  Call SalHideWindow( pbGenChq )
.head 5 +  On PAM_cls_REFRESHAFTRCHILDCHANGE
.head 6 -  Return FALSE
.head 5 +  On PAM_clsDLG_RETURN
.head 6 -  ! This is being sent on the return of the dialog box with the dates selected and the bOk
.head 6 -  ! This value will determine if the user has pressed OK with dates or pressed exit
.head 6 -  Call PopNumber( nOk, TRUE )
.head 6 -  Call PopDateTime( dtToDate, TRUE )
.head 6 -  Call PopDateTime( dtFromDate, TRUE )
.head 6 +  If nOk = TRUE
.head 7 -  Call SalPostMsg( mdiMain.pbMovement, SAM_Click, 0, 0 )
.head 5 +  On PAM_clsTBL_CHECKCHANGES
.head 6 -  Set hWndMDIChild = SalGetFirstChild( hWndAccounts, TYPE_ChildTable )
.head 6 +  While hWndMDIChild != hWndNULL
.head 7 +  If NOT SalSendMsg( hWndMDIChild, PAM_clsTBL_CHECKCHANGES, wParam, lParam )
.head 8 -  Return TRUE
.head 7 -  Set hWndMDIChild = SalGetNextChild( hWndMDIChild, TYPE_ChildTable )
.head 6 -  Return FALSE

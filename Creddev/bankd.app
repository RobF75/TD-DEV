.head 9 -  String: sInto
.head 9 -  Number: nSqlHandleNo
.head 9 -  Number: nInd
.head 9 -  String: sGotStatus
.head 8 +  Actions
.head 9 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'AllPaid' )
.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set sSql = ' SELECT
 Item_Status
FROM
Invoice_Items 
WHERE
Creditor_no = :1 and Invoice_No = :2'
.head 11 -  Set sName = 'AllPaid'
.head 11 -  Set sBind = ':nCredNo, :sInvNo'
.head 11 -  Set sInto = ':sGotStatus'
.head 11 -  ! !
.head 11 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 11 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 11 -  !
.head 11 +  If haSqlHandles[nSqlHandleNo ].Execute( )
.head 12 +  While haSqlHandles[nSqlHandleNo ].FetchNext( nInd )
.head 13 +  If sGotStatus != 'PAID'
.head 14 -  Return FALSE
.head 12 -  Return TRUE
.head 11 +  Else
.head 12 -  Return FALSE
.head 10 +  Case SH_cls_Disconnect
.head 11 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 11 -  Return TRUE

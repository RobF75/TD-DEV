.head 3 +  On PAM_clsDLG_POPFIELDS
.head 4 -  Call PopString( dfAccountName, TRUE )
.head 4 -  Call PopString( dfAccountNo, TRUE )
.head 4 -  Call PopString( dfBankBranch, TRUE )
.head 4 -  Call PopString( dfBankName, TRUE )
.head 4 -  Call PopString( dfBankId, TRUE )
.head 4 -  Call PopDateTime( dtFromDate[0], TRUE )
.head 4 -  Call PopDateTime( dtToDate[0], TRUE )
.head 3 +  On SAM_CreateComplete
.head 4 -  Set nOk = FALSE
.head 4 -  Call SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 3 +  On PAM_clsDLG_PUSHFIELDS
.head 4 -  Call ccFromDate.GetSelectedDates( dtFromDate )
.head 4 -  Call ccToDate.GetSelectedDates( dtToDate )
.head 4 -  ! Since only one date is allowed to be selected
.head 4 -  Call PushDateTime( dtFromDate[0] )
.head 4 -  Call PushDateTime( dtToDate[0] )
.head 4 -  ! This value will determine if the user has pressed OK with dates or pressed exit
.head 4 -  Call PushNumber( nOk )
.head 3 +  On PAM_clsPB_OKACTION
.head 4 -  Set nOk = TRUE
.head 4 -  Call SalPostMsg( pbExit, SAM_Click, 0, 0 )

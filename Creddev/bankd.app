.head 8 +  Message Actions
.head 9 -  ! Still need to identify if the row was edited before this and to inhibit the rowedited flag
.head 9 +  On SAM_SetFocus
.head 10 -  ! If the row edited flag is false we dont want to set the row edited flag if they are just unconfirming
a row so that a cheque will not be printed
.head 10 +  If SalTblQueryRowFlags( hWndForm, lParam, ROW_Edited )
.head 11 -  Set bRowEdited = TRUE
.head 10 +  Else
.head 11 -  Set bRowEdited = FALSE
.head 9 +  On SAM_AnyEdit
.head 10 +  If bRowEdited = FALSE
.head 11 -  Call SalPostMsg( hWndItem, PAM_clsCB_CLEAR, wParam, lParam )
.head 9 +  On PAM_clsCB_CLEAR
.head 10 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, FALSE )

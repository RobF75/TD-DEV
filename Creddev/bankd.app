.head 8 +  Message Actions
.head 9 +  On PAM_clsTBL_EDITCHECK
.head 10 +  If SalTblQueryRowFlags( hWndForm, ROW_New, lParam )
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 +  If colCleared = 'Y'
.head 12 -  Return FALSE
.head 11 +  Else
.head 12 -  Return TRUE
.head 9 +  On SAM_Create
.head 10 -  Call colMove.SetKey( 'MOVEMENT_TYPES' )
.head 10 -  Call SalSendClassMessage( SAM_Create, wParam, lParam )
.head 9 +  On SAM_Validate
.head 10 -  Set nlbIndex = SalListQuerySelection( hWndItem )
.head 10 -  ! then the user has added an entry to the list box
.head 10 +  If nlbIndex = LB_Err
.head 11 +  If SalModalDialog( dlgMove, hWndForm, colMove, sMoveDesc, sMoveAction )
.head 12 +  If AddToMovement (colMove, sMoveDesc, sMoveAction, SH_cls_Execute )
.head 13 -  Call AddToMovement (colMove,sMoveDesc, sMoveAction, SH_cls_Commit )
.head 13 -  Call CacheManager.ResetCache( 'MOVEMENT_TYPES' )
.head 13 -  ! Call CacheManager.ResetCache( 'MOVEMENT_TYPES', 'SELECT MOVEMENT_TYPE FROM MOVEMENT_TYPES ORDER BY MOVEMENT_TYPE' )
.head 13 -  Call SalSendClassMessage( PAM_clsDF_CLEAR, wParam, lParam )
.head 13 -  ! This should fill another cache with the movement action codes relating to the first cache in the same order
.head 13 -  Call CacheManager.ResetCache( 'MOVEMENT_TYPES1' )
.head 13 -  ! Call CacheManager.ResetCache( 'MOVEMENT_TYPES1', 'SELECT ACTION FROM MOVEMENT_TYPES ORDER BY MOVEMENT_TYPE' )
.head 13 -  Call SalSendMsg( colMoveCRDR, PAM_clsDF_CLEAR, wParam, lParam )
.head 12 +  Else
.head 13 -  Call AddToMovement (colMove, sMoveDesc, sMoveAction, SH_cls_Rollback )
.head 13 -  Return VALIDATE_Cancel
.head 11 +  Else
.head 12 -  Return VALIDATE_Cancel
.head 10 -  Call SalPostMsg( colMoveCRDR, PAM_clsTBLCOL_RESET, SalListQuerySelection( hWndItem ), lParam )
.head 10 -  Return VALIDATE_Ok
.head 9 +  On PAM_clsTBL_DATAVAL
.head 10 +  If SalTblQueryRowFlags( hWndForm, ROW_New, lParam )
.head 11 +  If MyValue = 'CHEQUE'
.head 12 +  If colManual = 'Y'
.head 13 -  Return TRUE
.head 12 +  Else
.head 13 -  Call SalMessageBox( 'To enter a cheque through this process, manual needs to be set to Y', 'Error', MB_Ok )
.head 13 -  Return FALSE
.head 10 -  Return TRUE

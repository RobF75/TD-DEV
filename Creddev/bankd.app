.head 8 -  Description:
.head 8 +  Returns
.head 9 -  Boolean:
.head 8 +  Parameters
.head 9 -  Number: nCredNo
.head 9 -  String: sInvNo
.head 9 -  String: sStatus
.head 9 -  Number: nActionType
.head 8 -  Static Variables
.head 8 +  Local variables
.head 9 -  String: sSql
.head 9 -  String: sName
.head 9 -  String: sBind
.head 9 -  String: sInto
.head 9 -  Number: nSqlHandleNo
.head 9 -  Number: nInd
.head 8 +  Actions
.head 9 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'SetInvSt' )

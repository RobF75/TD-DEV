.head 8 +  Actions
.head 9 -  ! If wanting to set rows dependent on CR/DR status
.head 9 +  If bSelect
.head 10 -  Call SalTblQueryScroll( hWndForm, nScrollRow, nMinRow, nMaxRow )
.head 10 -  Set nRow = nMinRow
.head 10 +  While nRow <= nMaxRow
.head 11 -  ! Row_UnusedFlag1 = CR Row
.head 11 -  ! Row_UnusedFlag2 = DR Row
.head 11 -  Call SalTblFetchRow( hWndForm, nRow )
.head 11 +  If colMoveCRDR = 'CR'
.head 12 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_UnusedFlag1, bSelect )
.head 11 +  Else
.head 12 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_UnusedFlag2, bSelect )
.head 11 -  Set nRow = nRow + 1
.head 9 -  ! Otherwise set all to no flags set
.head 9 +  Else
.head 10 -  Call SalTblSetFlagsAnyRows( hWndForm, ROW_UnusedFlag1|ROW_UnusedFlag2, FALSE, 0, 0 )
.head 7 +  Function: AddToMovement
.head 8 -  Description: When the user has entered a movement type which doesnt exist in the table, we
prompt them for a  description and action and then add it 
.head 8 +  Returns
.head 9 -  Boolean:
.head 8 +  Parameters
.head 9 -  String: sMoveType
.head 9 -  String: sMoveDesc
.head 9 -  String: sAction
.head 9 -  Number: nActionType
.head 8 -  Static Variables
.head 8 +  Local variables
.head 9 -  String: sSql
.head 9 -  String: sName
.head 9 -  String: sBind
.head 9 -  String: sInto
.head 9 -  Number: nSqlHandleNo
.head 9 -  Number: nInd
.head 8 +  Actions
.head 9 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'AddMove' )
.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set sSql = ' Insert Into Movement_Types
(Movement_type,
Movement_Desc,
Action)
Values 
( :1, :2, :3)'
.head 11 -  Set sName = 'AddMove'
.head 11 -  Set sBind = ':sMoveType, :sMoveDesc, :sAction'
.head 11 -  Set sInto = ''
.head 11 -  ! !
.head 11 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 11 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 11 -  !
.head 11 +  If haSqlHandles[nSqlHandleNo ].Execute( )
.head 12 -  Return TRUE
.head 11 +  Else
.head 12 -  Return FALSE
.head 10 +  Case SH_cls_Commit
.head 11 -  Call haSqlHandles[nSqlHandleNo ].Commit( )
.head 11 -  Return TRUE
.head 10 +  Case SH_cls_Rollback
.head 11 -  Call haSqlHandles[nSqlHandleNo ].Rollback( )
.head 11 -  Return TRUE
.head 10 +  Case SH_cls_Disconnect
.head 11 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 11 -  Return TRUE
.head 7 +  Function: SetNextRowIndex
.head 8 -  Description:
.head 8 +  Returns
.head 9 -  Boolean:
.head 8 +  Parameters
.head 9 -  Receive Number: nRowIndex
.head 9 -  Number: nRowNo
.head 9 -  ! Receive Number: nRowWithGL[*]
.head 8 -  Static Variables
.head 8 +  Local variables
.head 9 -  Number: i
.head 8 +  Actions
.head 9 -  Set i = 0
.head 9 +  Loop
.head 10 -  ! The first element in the array is set to Number_null in the sam_createcomplete of the table
so we can identify whether the first element being 0 is the row number 0 or the initialization
of the array 
.head 10 +  If i = 0
.head 11 +  If nRowWithGL[i] = NUMBER_Null
.head 12 -  Set nRowWithGL[i] = nRowNo
.head 12 -  Set nRowIndex = i
.head 12 -  Break
.head 11 +  Else
.head 12 -  Set i = i + 1
.head 10 +  Else
.head 11 +  If nRowWithGL[i] = 0
.head 12 -  Set nRowWithGL[i] = nRowNo
.head 12 -  Set nRowIndex = i
.head 12 -  Break
.head 11 +  Else
.head 12 -  Set i = i + 1
.head 9 -  Return TRUE
.head 7 +  Function: GetRowIndex
.head 8 -  Description: To retrieve from the array of row numbers what the rowindex is to access the array of GLcodes of
the row being processed
.head 8 +  Returns
.head 9 -  Boolean:
.head 8 +  Parameters
.head 9 -  Receive Number: nGLArrayIndex
.head 9 -  Number: nRowBeingProcessed
.head 8 -  Static Variables
.head 8 +  Local variables
.head 9 -  Number: i
.head 8 +  Actions
.head 9 -  Set i = 0
.head 9 +  Loop
.head 10 +  If nRowWithGL[i] = NUMBER_Null

.head 8 -  Set hWndParent = mdiMain.frmGenChq
.head 8 -  Set sSQLPopHandle = "SELECT
'Y',
Invoice_Items.Creditor_No,
Creditor.Creditor_Name,
Creditor.Creditor_Add1,
Creditor.Creditor_Add2,
Creditor.Creditor_Suburb,
Creditor.Creditor_Postcode,
Creditor.Creditor_State,
Invoice_Items.Item_Id,
Payable_Items.Item_Description,
Item_Status,
No_Of_Items,
Invoice_Unit_Price,
Item_Disc_Given,
Extended_Price,
Invoice_Items.Invoice_No,
Payable_Invoice.Invoice_Status,
Payable_Invoice.Invoice_Amount,
Payable_Invoice.Amount_Outstanding,
Payable_Invoice.Invoice_Date,
Invoice_Items.Seq_No,
GL_Code,
Comments
FROM
  Invoice_Items, Payable_Items, Payable_Invoice, Creditor, Status_Codes SC_A,
 Status_Codes SC_B
WHERE Invoice_Items.Creditor_No = Creditor.Creditor_No and 
Invoice_Items.Creditor_No = Payable_Invoice.Creditor_No and
Invoice_Items.Invoice_No = Payable_Invoice.Invoice_No and
Invoice_Items.Item_Status = SC_A.Status_Code and 
Payable_Invoice.Invoice_Status = SC_B.Status_Code and
Invoice_Items.Item_Id = Payable_Items.Item_Id and 
SC_A.Pay = 'Y' and SC_B.Pay = 'Y' ORDER BY Invoice_Items.Creditor_No, Invoice_Items.Invoice_No"
.head 8 -  Set sNAMEPopHandle = 'PAYINVITM'
.head 8 -  Set sBINDPopHandle = ''

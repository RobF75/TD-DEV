.head 8 +  Message Actions
.head 9 +  On SAM_Create
.head 10 -  Call colItemStatus.SetKey( 'STATUS_CODES' )
.head 10 -  Call SalSendClassMessage( SAM_Create, wParam, lParam )
.head 9 +  On SAM_Validate
.head 10 -  Set nlbIndex = SalListQuerySelection( hWndItem )
.head 10 -  ! then the user has added an entry to the list box
.head 10 +  If nlbIndex = LB_Err
.head 11 +  If SalModalDialog( dlgStatus, hWndForm, colItemStatus, sStatusDesc, sPay )
.head 12 +  If AddToStatus (colItemStatus, sStatusDesc, sPay, SH_cls_Execute )
.head 13 -  Call AddToStatus (colItemStatus,sStatusDesc, sPay, SH_cls_Commit )
.head 13 -  Call CacheManager.ResetCache( 'STATUS_CODES' )
.head 13 -  ! Call CacheManager.ResetCache( 'STATUS_CODES', 'SELECT STATUS_CODE FROM STATUS_CODES ORDER BY STATUS_CODE' )
.head 13 -  Call SalSendClassMessage( PAM_clsDF_CLEAR, wParam, lParam )
.head 12 +  Else
.head 13 -  Call AddToStatus (colItemStatus,sStatusDesc, sPay, SH_cls_Rollback )
.head 13 -  Return VALIDATE_Cancel
.head 11 +  Else
.head 12 -  Return VALIDATE_Cancel
.head 10 -  Return VALIDATE_Ok

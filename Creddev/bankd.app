.head 7 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'UpdAccBal' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = " Update Bank_Account
Set 
Opening_Balance = :3,
Open_Balance_Date = :4
WHERE
  Bank_Id = :1 and Account_No = :2"
.head 9 -  Set sName = 'UpdAccBal'
.head 9 -  Set sBind = ':sBankId, :sAccNo, :nOpenBal, :dtOpenDate'
.head 9 -  Set sInto = ''
.head 9 -  ! !
.head 9 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 9 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 +  If haSqlHandles[nSqlHandleNo ].Execute( )
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Case SH_cls_Commit
.head 9 -  Call haSqlHandles[nSqlHandleNo ].Commit( )
.head 8 +  Case SH_cls_Rollback
.head 9 -  Call haSqlHandles[nSqlHandleNo ].Rollback( )
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 9 -  Return TRUE

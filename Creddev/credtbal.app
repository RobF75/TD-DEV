.head 7 +  If NOT ChqNoAlreadyReported ( nChqNo, sAccNo )
.head 8 -  Set bOkToReport = TRUE
.head 6 +  Else
.head 7 -  Set bProcChq = FALSE
.head 7 -  Set bProcInvoice = TRUE
.head 6 +  If bOkToReport
.head 7 -  Call SetChqNoReported (nChqNo, sAccNo)
.head 7 -  Return TRUE
.head 4 -  Return FALSE
.head 3 +  On SAM_ReportFinish
.head 4 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 4 -  Call haSqlHandles[ nSqlHandleNoApp ].Disconnect( )
.head 4 -  Call haSqlHandles[ nSqlHandleNoChq ].Disconnect( )
.head 4 -  Return TRUE

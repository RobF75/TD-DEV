.head 2 +  Message Actions
.head 3 +  On SAM_CreateComplete
.head 4 -  Call SalHideWindow( hWndForm )
.head 4 -  Set sFormTitle = 'Trial Balance Listing month end date of '||sEOMDate
.head 4 -  Call SalSetWindowText( hWndForm, sFormTitle )
.head 4 -  Set dtBOMDate = SalDateMonthBegin( dtEOMDate )
.head 4 -  !
.head 4 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CrTBal' )
.head 4 -  Set sInto = ':nCredNo,
 :sCredName,
 :sAdd1,
:sAdd2,
:sSuburb,
:sPCode,
:sState,
:sPhone,
:sFax,
:sNotes,
:sDiscRecd,
:sInvNo,
:nInvAmt,
:nInvAmtOuts,
:dtInvDate,
:sInvStatus,
:sInvComments'
.head 4 -  Set sBind = ':dtEOMDate'
.head 4 -  Set sName = 'CrTBal'
.head 4 -  Set sSql = "SELECT
Creditor.Creditor_no,
creditor_name,
Creditor_Add1,
Creditor_Add2,
Creditor_Suburb,
Creditor_Postcode,
Creditor_State,
Cred_Phone_No,
Creditor_Fax_no,
Creditor_Notes,
discount_received,
Payable_Invoice.Invoice_No,
Invoice_Amount,
Amount_Outstanding,
invoice_Date,
invoice_status,
invoice_comments
FROM
creditor, payable_invoice
WHERE
Invoice_Date <= :1 
and creditor.Creditor_no = payable_invoice.Creditor_no
ORDER BY creditor_name, invoice_date"
.head 4 -  !
.head 4 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 4 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 4 -  !
.head 4 -  Set nSqlHandleNoApp = SqlHandlesGetReferenceNo( 'CrTBalApp' )
.head 4 -  Set sInto = ':nAppId'
.head 4 -  Set sBind = ':dtBOMDate, :dtEOMDate :nCredNo, :sInvNo'
.head 4 -  Set sName = 'CrTBalApp'
.head 4 -  Set sSql = "SELECT
Application_Id
FROM
Cheque_Application
WHERE
Application_Date BETWEEN :1 AND :2 
and cheque_application.Creditor_no = :3
and cheque_application.Invoice_no = :4"
.head 4 -  !
.head 4 -  Call haSqlHandles[ nSqlHandleNoApp ].Setup( sSql, sName, sBind, sInto )
.head 4 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNoApp ].hSqlHandle )
.head 4 -  !
.head 4 -  Set nSqlHandleNoChq = SqlHandlesGetReferenceNo( 'CrTBalChq' )
.head 4 -  Set sInto = ':nChqNo,
:nAccSeqNo,
:sAccNo,
 :sManual,
:dtIssued,
:nAmount'
.head 4 -  Set sBind = ' :nCredNo, :sInvNo'
.head 4 -  Set sName = 'CrTBalChq'
.head 4 -  Set sSql = "SELECT
Cheque_No,
Account_Movement.Account_Seq_No,
Account_no,
Manually_Written,
Date_Issued,
Amount
FROM
Cheque_Application, Account_Movement
WHERE
cheque_application.Creditor_no = :1
and cheque_application.Invoice_no = :2
and account_movement.Account_seq_no = Cheque_Application.Account_Seq_no
and movement_Type = 'CHEQUE' "
.head 4 -  !
.head 4 -  Call haSqlHandles[ nSqlHandleNoChq ].Setup( sSql, sName, sBind, sInto )
.head 4 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNoChq ].hSqlHandle )
.head 4 -  !
.head 4 -  Return SalSendMsg( hWndForm, PAM_clsTBL_PRINTTABLEREPORT, 0, 0 )
.head 3 -  !
.head 3 +  On PAM_clsTBL_PRINTTABLEREPORT

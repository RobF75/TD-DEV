.head 3 +  On SAM_CreateComplete
.head 4 -  Set sFromDate = SalFmtFormatDateTime( dtFromDate, 'dd-MMM-yy' )
.head 4 -  Set sToDate = SalFmtFormatDateTime( dtToDate, 'dd-MMM-yy' )
.head 4 -  Set sFormTitle = 'Cash Payments Listing between '||sFromDate||' and '||sToDate
.head 4 -  Set nInc = 0
.head 4 -  Set nColNo = 9
.head 4 -  Call SalSetWindowText( hWndForm, sFormTitle )
.head 4 -  !
.head 4 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CashPay' )
.head 4 -  Set sInto = ':colChqNo, 
:colManual,
 :colDateIssued,
 :colAmount,
 :colCredNo,
 :colCredName,
 :colGLCode,
 :colPrice,
 :colGLDesc'
.head 4 -  Set sBind = ':dtFromDate, :dtToDate'
.head 4 -  Set sName = 'CashPay'
.head 4 -  Set sSql = "SELECT
Cheque_No,
Manually_Written,
Date_Issued,
Amount,
Creditor.Creditor_no,
creditor_name,
GL_code,
extended_price,
gl_account_desc
FROM
Account_Movement, Cheque_Application, creditor, invoice_items,general_ledger  
WHERE
Date_Issued BETWEEN :1 AND :2 
and account_movement.Movement_type = 'CHEQUE' 
and Account_movement.Account_seq_no = Cheque_Application.Account_Seq_no
and invoice_items.creditor_no = cheque_application.creditor_no and
invoice_items.invoice_no = cheque_application.invoice_no
and invoice_items.seq_no = cheque_application.seq_no
and creditor.creditor_no = cheque_application.creditor_no 
and gl_code = gl_account_code(+)
 ORDER BY Cheque_no"
.head 4 -  !
.head 4 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 4 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 4 -  !
.head 4 -  ! Call haSqlHandles[ nSqlHandleNo ].PrepareAndExecute( )
.head 4 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDCOLUMN, wParam, lParam )
.head 4 -  !
.head 4 -  Return SalSendMsg( hWndForm, PAM_clsTBL_POPULATE, 0, 0 )
.head 3 +  On PAM_clsTBL_POPULATE
.head 4 -  Call haSqlHandles[ nSqlHandleNo ].TablePopulate( hWndForm, TBL_FillAll )
.head 4 -  ! Call SalTblSetRange( hWndForm, 0, TBL_MaxRow  )
.head 4 -  ! Set nCounter = 0
.head 4 +  ! While SqlFetchNext( haSqlHandles[ nSqlHandleNo ].hSqlHandle, nFetch )
.head 5 -  Call SalTblFetchRow( hWndForm, nCounter )
.head 5 -  Set nCounter = nCounter + 1
.head 4 -  Set nNewRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
.head 4 -  Call SalTblSetContext( hWndForm, nNewRow )
.head 4 -  Set i = 0
.head 4 +  While sColId[i] != STRING_Null
.head 5 -  Call SalTblSetColumnText( hWndForm, SalStrToNumber( sColId[i] ), sTotPrice[i] )
.head 5 -  Set i = i + 1
.head 4 -  Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_SUMVALUE, wParam, lParam )
.head 4 -  !
.head 4 -  Call SalReportTableCreate( 'cashpay.qrp', hWndForm, nError )
.head 4 -  Call SalReportTableView( hWndForm, hWndNULL, 'cashpay.qrp', nError )
.head 4 -  ! Set nParamArray[RPT_PrintParamOptions] = RPT_PrintAll
.head 4 -  ! Set nParamArray[RPT_PrintParamFirstPage] = 

.head 3 +  On PAM_clsTBL_ADDCOLUMN
.head 4 -  Set nSqlHandleNoCol = SqlHandlesGetReferenceNo( 'CashPayCol' )
.head 4 -  Set sInto = ':sGotDesc'
.head 4 -  Set sBind = ':dtFromDate, :dtToDate'
.head 4 -  Set sName = 'CashPayCol'
.head 4 -  Set sSql = "SELECT
DISTINCT
gl_account_desc
FROM
Account_Movement, Cheque_Application, creditor, invoice_items,general_ledger  
WHERE
Date_Issued BETWEEN :1 AND :2 
and account_movement.Movement_type = 'CHEQUE' 
and Account_movement.Account_seq_no = Cheque_Application.Account_Seq_no
and invoice_items.creditor_no = cheque_application.creditor_no and
invoice_items.invoice_no = cheque_application.invoice_no
and invoice_items.seq_no = cheque_application.seq_no
and creditor.creditor_no = cheque_application.creditor_no 
and gl_code = gl_account_code(+)"
.head 4 -  !
.head 4 -  Call haSqlHandles[ nSqlHandleNoCol ].Setup( sSql, sName, sBind, sInto )
.head 4 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNoCol ].hSqlHandle )
.head 4 -  !
.head 4 -  Set i = 0
.head 4 -  !
.head 4 +  If haSqlHandles[ nSqlHandleNoCol ].Execute( )
.head 5 +  While haSqlHandles[ nSqlHandleNoCol].FetchNext( nFetch )
.head 6 -  Set sGLDesc[i] = SalStrLeftX( sGotDesc, 20 )
.head 6 -  Set i = i + 1
.head 4 -  !
.head 4 -  Set i = 0
.head 4 -  !
.head 4 +  While sGLDesc[i] !=STRING_Null
.head 5 -  Set bColExists = FALSE
.head 5 -  Set sTemp = SalStrLeftX( sGLDesc[i], 20 )
.head 5 -  Set hWndCol = hWndNULL
.head 5 -  Set hWndCol = SalGetFirstChild( hWndForm, TYPE_TableColumn )
.head 5 +  While hWndCol != hWndNULL
.head 6 -  Call SalTblGetColumnTitle( hWndCol, sTitle, 20 ) 
.head 6 +  If sTemp = sTitle
.head 7 -  Set bColExists = TRUE
.head 7 -  Set nColId = SalTblQueryColumnID( hWndCol )
.head 7 -  Break
.head 7 -  ! Then we've found a column for this GLcode
.head 6 -  Set hWndCol = SalGetNextChild( hWndCol, TYPE_TableColumn )
.head 5 +  If NOT bColExists
.head 6 -  Set nColId = SalTblCreateColumn( hWndForm, 10, 1, 15, sTemp )
.head 5 -  Set sColId[i] = SalNumberToStrX( nColId, 0 )
.head 5 -  Set i = i + 1
.head 3 +  On SAM_FetchRowDone
.head 4 -  ! Want to use the GLCode retrieved and check to see if there is a column already defined for this code, if not, 
create a new one and slot the price data in that column also
.head 4 -  Set sTemp = SalStrLeftX( colGLDesc, 20 )
.head 4 -  !
.head 4 -  Set i = 0
.head 4 +  While sGLDesc[i] != STRING_Null
.head 5 +  If sGLDesc[i] = sTemp
.head 6 -  Break
.head 5 -  Set i = i + 1
.head 4 -  Set nColId = SalStrToNumber( sColId[i] )
.head 4 -  Set hWndCol = SalTblGetColumnWindow( hWndForm, nColId, COL_GetID )
.head 4 -  Set nTotPrice = SalStrToNumber( sTotPrice[i] )
.head 4 -  Set nTotPrice = nTotPrice + colPrice
.head 4 -  Set sTotPrice[i] = SalNumberToStrX( nTotPrice, 2 )
.head 4 -  Set sPrice = SalNumberToStrX( colPrice, 2 )
.head 4 -  Call SalSetWindowText( hWndCol, sPrice )

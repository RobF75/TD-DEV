.head 8 -  Set mdiMain.frmSeller.tblSeller.bUnDeleteAllowed = FALSE
.head 8 -  Set mdiMain.frmSeller.tblSeller.nTableFillType = TBL_FillNormal
.head 8 -  !
.head 8 -  Set sSQLPopHandle = 'SELECT
  Sold_By_Seq_No,
Sold_By.Creditor_No,
Last_Price_Per,
Creditor_Item_Code,
Date_Paid,
Creditor_Name,
Creditor_Contact,
Cred_Phone_No,
Creditor_Fax_No
FROM
  Sold_By, Creditor
WHERE Item_Id = :1 and Sold_By.Creditor_No = Creditor.Creditor_no
ORDER BY
  Last_Price_Per ASC '
.head 8 -  Set sNAMEPopHandle = 'SLDBYITM'
.head 8 -  Set sBINDPopHandle = ':mdiMain.frmSeller.dfItemNo'
.head 8 -  Set sINTOPopHandle = ':mdiMain.frmSeller.tblSeller.colSeqNo,
:mdiMain.frmSeller.tblSeller.colCredNo,
:mdiMain.frmSeller.tblSeller.colPricePaid,
:mdiMain.frmSeller.tblSeller.colCredItemCode,
:mdiMain.frmSeller.tblSeller.colDatePaid,
:mdiMain.frmSeller.tblSeller.colCredName,
:mdiMain.frmSeller.tblSeller.colContact,
:mdiMain.frmSeller.tblSeller.colPhone,
:mdiMain.frmSeller.tblSeller.colFax'
.head 8 -  ! ! !
.head 8 -  Set sSQLRefreshHandle = 'SELECT
Sold_By.Creditor_No,
Last_Price_Per,
Creditor_Item_Code,
Date_Paid,
Creditor_Name,
Creditor_Contact,
Cred_Phone_No,
Creditor_Fax_No
FROM
  Sold_By, Creditor 
WHERE
  Sold_By_Seq_No = :1 AND Sold_By.Creditor_no = Creditor.Creditor_no'
.head 8 -  Set sNAMERefreshHandle = 'REFSBYITM'
.head 8 -  Set sBINDRefreshHandle = ':mdiMain.frmSeller.tblSeller.colSeqNo'
.head 8 -  Set sINTORefreshHandle = ':mdiMain.frmSeller.tblSeller.colCredNo,
:mdiMain.frmSeller.tblSeller.colPricePaid,
:mdiMain.frmSeller.tblSeller.colCredItemCode,
:mdiMain.frmSeller.tblSeller.colDatePaid,
:mdiMain.frmSeller.tblSeller.colCredName,
:mdiMain.frmSeller.tblSeller.colContact,
:mdiMain.frmSeller.tblSeller.colPhone,
:mdiMain.frmSeller.tblSeller.colFax'
.head 8 -  ! ! !

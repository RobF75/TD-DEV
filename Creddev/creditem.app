.head 6 +  On SAM_Click
.head 7 +  If hWndSeller = hWndNULL
.head 8 -  Set nRow = TBL_MinRow
.head 8 +  If SalTblFindNextRow( hWndItem.(mdiMain.frmItem).tblItem, nRow, ROW_Selected, 0 )

.head 8 -  Set mdiMain.frmSeller.tblSeller.bAddAllowed = FALSE
.head 8 -  Set mdiMain.frmSeller.tblSeller.bClearSelectAllowed = TRUE
.head 8 -  Set mdiMain.frmSeller.tblSeller.bDeleteAllowed = FALSE

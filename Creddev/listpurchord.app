.head 4 -  Set sReportType = 'VIEW'
.head 3 +  On SAM_CreateComplete
.head 4 +  If NOT SalModalDialog( dlgSelection, hWndForm, bShowAll )
.head 5 -  Call SalDestroyWindow( hWndForm )
.head 4 -  Call SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 3 +  On SAM_ReportStart
.head 4 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'PurchOrd' )
.head 4 +  If bShowAll
.head 5 -  Set sSql = " SELECT 
  Purch_Order_No,
 Purchase_Order.Creditor_no,
Ordered_By,
Purch_Order_Date,
Purch_Order_Items.Item_Id,
Required_For,
Purch_Order_Price,
Purch_Ord_Quantity,
Item_Description,
Creditor_Name,
Creditor_Contact,
Cred_Phone_No,
Creditor_Fax_No,
Discount_Given,
Disc_Percentage
FROM 
  Purchase_Order, Creditor, Purch_Order_Items, Payable_Items 
WHERE 
  Purchase_Order.Creditor_No = Creditor.Creditor_no and
Purch_Order_No = Purchase_Order_No and 
Purch_Order_Items.Item_Id = Payable_Items.Item_Id
ORDER BY Creditor.Creditor_name, Purch_Order_Date DESC "
.head 5 -  Set sName = 'AllPurchOrd'
.head 4 +  Else
.head 5 -  Set sSql = " SELECT 
  Purch_Order_No,
 Purchase_Order.Creditor_no,
Ordered_By,
Purch_Order_Date,
Purch_Order_Items.Item_Id,
Required_For,
Purch_Order_Price,
Purch_Ord_Quantity,
Item_Description,
Creditor_Name,
Creditor_Contact,
Cred_Phone_No,
Creditor_Fax_No,
Discount_Given,
Disc_Percentage
FROM 
  Purchase_Order, Creditor, Purch_Order_Items, Payable_Items 
WHERE 
  Purchase_Order.Creditor_No = Creditor.Creditor_no and
Purch_Order_No = Purchase_Order_No and 
Purch_Order_Items.Item_Id = Payable_Items.Item_Id
and NOT EXISTS (SELECT Invoice_Items.Purchase_Order_No FROM Invoice_Items
WHERE Purch_Order_No = Invoice_Items.Purchase_Order_No)  
ORDER BY Creditor.Creditor_name, Purch_Order_Date DESC "
.head 5 -  Set sName = 'PurchOrd'
.head 4 -  Set sBind = ''
.head 4 -  Set sInto = ':frmPurchOrd.sPurchOrd, 
:frmPurchOrd.nCredNo, 
:frmPurchOrd.sOrderedBy, 
:frmPurchOrd.dtPurchDate, 
:frmPurchOrd.nItemId, 
:frmPurchOrd.sReqdFor,
:frmPurchOrd.nPrice,
:frmPurchOrd.nQuantity,
:frmPurchOrd.sItemDesc,
:frmPurchOrd.sCredName, 
:frmPurchOrd.sContact, 
:frmPurchOrd.sPhone, 
:frmPurchOrd.sFax, 
:frmPurchOrd.sDiscGiven, 
:frmPurchOrd.nDiscPercent'
.head 4 -  ! !
.head 4 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 4 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchInit
.head 4 -  !
.head 4 +  If NOT haSqlHandles[nSqlHandleNo].Execute( )
.head 5 -  Return FALSE
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchNext
.head 4 +  If haSqlHandles[nSqlHandleNo].FetchNext( nInd )
.head 5 -  Return TRUE
.head 4 +  Else
.head 5 -  Return FALSE
.head 3 +  On SAM_ReportFinish
.head 4 -  Call haSqlHandles[nSqlHandleNo].Disconnect( )
.head 4 -  Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )

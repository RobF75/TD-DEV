:frmPurchOrd.sItemDesc,
:frmPurchOrd.sReqdFor,
:frmPurchOrd.nPrice,
:frmPurchOrd.nQuantity'
.head 4 -  Set sReportInto = 'sPurchOrd,
nCredNo,
sCredName,
sContact,
sPhone,
sFax,
sDiscGiven,
nDiscPercent,
sOrderedBy,
dtPurchDate,
nItemId,
sItemDesc,

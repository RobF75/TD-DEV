.head 2 +  Message Actions
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set sReportFileNameNoPath = 'purchord.qrp'
.head 4 -  Set sReportBind = ':frmPurchOrd.sPurchOrd, 
:frmPurchOrd.nCredNo, 
:frmPurchOrd.sCredName, 
:frmPurchOrd.sContact, 
:frmPurchOrd.sPhone, 
:frmPurchOrd.sFax, 
:frmPurchOrd.sDiscGiven, 

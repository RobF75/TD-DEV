.head 2 +  Window Variables
.head 3 -  String: sCode
.head 3 -  String: sDesc
.head 3 -  String: sComment
.head 3 -  String: sItemDesc
.head 3 -  String: sSalesTax
.head 3 -  Number: nLastPrice
.head 3 -  String: sItemComments
.head 2 +  Message Actions
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set frmPrGL.bReportBeginAutomatically = TRUE
.head 4 -  Set frmPrGL.sReportBind = ':frmPrGL.sCode, :frmPrGL.sDesc, :frmPrGL.sComment, :frmPrGL.sItemDesc, 
:frmPrGL.sSalesTax, :frmPrGL.nLastPrice, :frmPrGL.sItemComments' 
.head 4 -  Set frmPrGL.sReportFileNameNoPath = 'glitems.qrp'
.head 4 -  Set frmPrGL.sReportInto = 'GLCode, GLDesc, GLComment, ItemDesc, SalesTaxExempt, LastPrice, ItemComments' 
.head 4 -  Set frmPrGL.sReportType = 'PRINT'
.head 4 -  Set frmPrGL.sReportSql = ' SELECT DISTINCT
GL_Code,
GL_Account_Desc,
GL_Comments,
Item_Description,
Sales_Tax_Exempt,
Last_Unit_Price,
Item_Comments
FROM
Invoice_Items, General_Ledger, Payable_Items
INTO
:frmPrGL.sCode,
:frmPrGL.sDesc,
:frmPrGL.sComment,
:frmPrGL.sItemDesc,
:frmPrGL.sSalesTax,
:frmPrGL.nLastPrice,
:frmPrGL.sItemComments
 WHERE GL_Code = GL_Account_Code(+) and Invoice_Items.Item_Id = Payable_Items.Item_Id 
ORDER BY GL_Code'

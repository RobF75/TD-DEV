.head 8 -  Set sSQLPopHandle = 'SELECT DISTINCT
  Invoice_Items.Item_ID,
Item_Description,
Sales_Tax_Exempt,
Last_Unit_Price,
Item_Comments
FROM
  Invoice_Items, Payable_Items
WHERE GL_Code = :1 and Invoice_Items.Item_Id = Payable_Items.Item_Id 
ORDER BY
  2 '
.head 8 -  Set sNAMEPopHandle = 'GLITEMS'
.head 8 -  Set sBINDPopHandle = ':mdiMain.frmItems.dfGLCode'
.head 8 -  Set sINTOPopHandle = ':mdiMain.frmItems.tblItems.colItemId,
:mdiMain.frmItems.tblItems.colItemDesc,
:mdiMain.frmItems.tblItems.colSalesTax,
:mdiMain.frmItems.tblItems.colLastPrice,
:mdiMain.frmItems.tblItems.colComments'
.head 8 -  ! ! !
.head 8 -  Set sSQLRefreshHandle = 'SELECT
Item_Description,
Sales_Tax_Exempt,
Last_Unit_Price,
Item_Comments
FROM
   Invoice_Items, Payable_Items
WHERE
 GL_Code = :1 and Invoice_Items.Item_id = :2 and Invoice_Items.Item_Id = Payable_Items.Item_Id '
.head 8 -  Set sNAMERefreshHandle = 'REFGLITM'
.head 8 -  Set sBINDRefreshHandle = ':mdiMain.frmItems.dfGLCode, :mdiMain.frmItems.tblItems.colItemId'

.head 2 +  Application Actions
.head 3 +  On SAM_AppStartup
.head 4 -  !
.head 4 +  If strArgArray[0] = ''
.head 5 -  Set SqlDatabase = 'stock'
.head 5 -  Set SqlUser = 'ron'
.head 5 -  Set SqlPassword = 'ron'
.head 4 +  Else
.head 5 -  Set SqlDatabase = strArgArray[1]
.head 5 -  Set SqlUser = strArgArray[2]
.head 5 -  Set SqlPassword = strArgArray[3]
.head 4 -  !
.head 4 -  Call CheckProgramExistance( "Creditor", TRUE )
.head 4 -  !
.head 4 -  Call CacheManager.Init( )
.head 4 -  Call CacheManager.AddCache( 'STATUS_CODES', 'SELECT STATUS_CODE FROM STATUS_CODES ORDER BY STATUS_CODE' )
.head 4 -  Call CacheManager.AddCache( 'GENERAL_LEDGER', 'SELECT GL_ACCOUNT_CODE FROM GENERAL_LEDGER ORDER BY GL_ACCOUNT_DESC' )
.head 4 -  Call CacheManager.AddCache( 'GENERAL_LEDGER1', 'SELECT GL_ACCOUNT_DESC FROM GENERAL_LEDGER ORDER BY GL_ACCOUNT_DESC' )
.head 4 -  Call CacheManager.AddCache( 'ITEM', 'SELECT ITEM_ID FROM PAYABLE_ITEMS ORDER BY ITEM_DESCRIPTION' )
.head 4 -  Call CacheManager.AddCache( 'ITEM1', 'SELECT ITEM_DESCRIPTION FROM PAYABLE_ITEMS ORDER BY ITEM_DESCRIPTION' )
.head 4 -  !
.head 4 -  Call SqlHandlesSetup(  )
.head 3 +  On SAM_AppExit
.head 4 -  Call SqlHandlesDisconnectClose(  )

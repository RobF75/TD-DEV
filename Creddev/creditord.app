.head 6 -  Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_POPULATE, 0, 0 )
.head 6 -  Call SalPostMsg( hWndPOItems, PAM_cls_CHILDCHANGED, 0, 0 )
.head 6 -  Call SalBringWindowToTop( hWndPO )

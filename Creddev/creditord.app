.head 8 -  Set nReturn = SalSendClassMessage( PAM_clsTBL_REFRESHROW, wParam, lParam )
.head 8 -  ! Seems to be that if only 1 row is in the table, especially after the one row is added, sam_rowValidate
doesnt get processed on the click of the row
.head 8 +  If hWndForm.clsTableGeneral.__nTableTotalRows = 1
.head 9 -  Call SalSendMsg( hWndForm, SAM_RowValidate, wParam, lParam )
.head 8 -  Return nReturn
.head 7 +  On SAM_RowValidate
.head 8 -  ! First off we need to check if any of the child windows to this form, if selecting creditor row then all child windows
of the MDI are checked, have data changed which needs to be saved
.head 8 +  If hWndPOItems != hWndNULL
.head 9 +  If SalSendMsg( hWndPOItems, PAM_clsTBL_CHECKCHANGES, wParam, lParam )
.head 10 -  Return VALIDATE_Cancel
.head 9 +  Else
.head 10 -  Call SalPostMsg( hWndPOItems.(mdiMain.frmPOItems), PAM_cls_CHILDCHANGED, 0, 0 )

.head 4 +  Functions
.head 5 +  Function: FreightCodeIdExists
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  String: sFreightCodeId
.head 7 -  Number: SH_cls_ExecuteOrDisconnect
.head 6 +  Static Variables
.head 7 -  Sql Handle: hSqlHandle
.head 7 -  Boolean: bHandleConnected
.head 7 -  Boolean: bHandlePrepared
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  Number: nInd
.head 7 -  Boolean: bOk
.head 6 +  Actions
.head 7 +  If SH_cls_ExecuteOrDisconnect != SH_cls_Disconnect
.head 8 +  If NOT bHandleConnected
.head 9 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 9 +  If bHandleConnected
.head 10 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 10 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 9 +  Else
.head 10 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 10 -  Return FALSE
.head 8 +  If NOT bHandlePrepared
.head 9 -  Set sSql = ' SELECT Freight_Code FROM Freight_Codes WHERE Freight_Code = :sFreightCodeId '
.head 9 +  If SqlPrepare( hSqlHandle, sSql )
.head 10 -  Set bHandlePrepared = TRUE
.head 9 +  Else
.head 10 -  Set bHandlePrepared = FALSE
.head 8 +  If SqlExecute( hSqlHandle )
.head 9 -  Call SqlFetchNext( hSqlHandle, nInd )
.head 9 +  If nInd = FETCH_EOF
.head 10 -  Return FALSE
.head 9 +  Else
.head 10 -  Return TRUE
.head 8 +  Else
.head 9 -  Set bHandlePrepared = FALSE
.head 9 -  Call SalMessageBox( 'SqlExecute had a error in LoadIdExists, Contact programmers please!', 'ERROR', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Set bOk = TRUE
.head 8 -  Set bHandlePrepared = FALSE
.head 8 +  If bHandleConnected
.head 9 -  Set bHandleConnected = FALSE
.head 9 -  Set bOk = SqlDisconnect( hSqlHandle )
.head 8 -  Return bOk
.head 4 -  Window Variables
.head 4 +  Message Actions
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLTABLENAME = ' FREIGHT_CODES '
.head 6 -  Set sSQLPOPTABLENAME = ' FREIGHT_CODES '
.head 6 -  Set sSQLWHERE = ''
.head 6 -  Set sORDERBY = ' ORDER BY FREIGHT_CODE '
.head 6 -  Set sTableHeading = 'Freight Codes'
.head 6 -  Set hWndRowNewColumn = colFreightCode
.head 5 +  On SAM_Destroy
.head 6 -  Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
.head 6 -  Call FreightCodeIdExists( '', SH_cls_Disconnect )

.head 3 +  Function: GetMessageLegend
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Receive String: sMessage
.head 5 -  Receive Number: nMessageLegendNo
.head 5 -  Receive Number: nQuantity
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  String: sMessageLegend[*]
.head 5 -  Number: nAmt[*]
.head 5 -  Number: nLastMessageLegend
.head 4 +  Local variables
.head 5 -  Number: nCount
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case nSelectLegendNo
.head 7 -  Set nMessageLegendNo = 0
.head 7 -  Set nCount = 0
.head 7 +  While nCount < nLastMessageLegend
.head 8 +  If sMessageLegend[nCount] = sMessage
.head 9 -  Set nMessageLegendNo = nCount + 1
.head 9 -  Set nAmt[nCount] = nAmt[nCount] + nQuantity
.head 9 -  Return TRUE
.head 8 -  Set nCount = nCount + 1
.head 7 -  Set nLastMessageLegend = nLastMessageLegend + 1
.head 7 -  Set sMessageLegend[nLastMessageLegend-1] = sMessage
.head 7 -  Set nAmt[nCount] = nAmt[nCount] + nQuantity
.head 7 -  Set nMessageLegendNo = nLastMessageLegend
.head 7 -  Return TRUE
.head 6 +  Case nSelectLegendMessage
.head 7 -  Set sMessage = ''
.head 7 -  Set nCount = 0
.head 7 +  While nCount < nLastMessageLegend
.head 8 +  If nCount = nMessageLegendNo - 1
.head 9 -  Set sMessage = sMessageLegend[nCount]
.head 9 -  Set nQuantity = nAmt[nCount]
.head 9 -  Return TRUE
.head 8 -  Set nCount = nCount + 1
.head 7 -  Return FALSE
.head 6 +  Case nClearLegend
.head 7 -  Set nCount = 0
.head 7 +  While nCount < nLastMessageLegend
.head 8 -  Set sMessageLegend[nCount] = ''
.head 8 -  Set nAmt[nCount] = 0
.head 8 -  Set nCount = nCount + 1
.head 7 -  Set nLastMessageLegend = 0
.head 7 -  Return TRUE

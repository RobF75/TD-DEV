.head 3 +  Function: CalculateMessageLegend
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Boolean: bUseStockItemCount
.head 5 -  Window Handle: hWndTable
.head 5 -  Number: nYear
.head 5 -  Receive String: sMessageLegend[1:*]

.head 5 +  While nCurrentPos < nLastArrayEntry
.head 6 +  If sMessageLegend[ nCurrentPos ] = sTreeTypeMessage
.head 7 -  Return nCurrentPos 
.head 6 -  Set nCurrentPos = nCurrentPos + 1
.head 5 -  Return 0

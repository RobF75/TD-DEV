.head 4 +  Actions
.head 5 -  Set bSqlHandle = SqlConnect( hSqlHandle ) 
.head 5 +  If bSqlHandle
.head 6 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 5 +  Else
.head 6 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -  Return FALSE
.head 5 -  Set bStockCountMessageTaken = FALSE
.head 5 +  If bUseStockItemCount
.head 6 -  Set bCalculateLegend = FALSE
.head 6 -  ! Get amount of trees ordered by customer, if we have a confirmed amount
use it ever ordered amount
.head 6 +  If NOT SalIsNull( hWndTable.colConfAmt )
.head 7 -  Set nAmount = hWndTable.colConfAmt
.head 6 +  Else
.head 7 -  Set nAmount = hWndTable.colOrdAmt

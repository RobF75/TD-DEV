.head 6 -  Call SqlClearImmediate(  )
.head 6 +  If nItemNo = 0
.head 7 -  Return FALSE
.head 5 +  Else
.head 6 -  Call SqlClearImmediate(  )
.head 6 -  Return FALSE
.head 5 -  Set nAmtReqd = 0
.head 5 -  Set sgSql =  'SELECT Dep_Amount_Reqd FROM Outstand_Deposit INTO
 :nAmtReqd WHERE Cust_No = :nCustNo AND Dep_Year_Of_Sale = :nYear'
.head 5 +  If SqlImmediate( sgSql )
.head 6 -  Call SqlClearImmediate(  )
.head 6 +  If nAmtReqd = 0
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  Else
.head 6 -  Call SqlClearImmediate(  )
.head 6 -  Return FALSE

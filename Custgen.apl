.head 5 -  Set nLastSelectedRowOrdDT = -1
.head 5 -  Set nRow = TBL_MinRow
.head 5 +  While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
.head 6 -  Call SalTblFetchRow( hWndTable, nRow )
.head 6 -  Set nLastSelectedRowOrdDT = nLastSelectedRowOrdDT + 1
.head 6 -  Set dtSelectedRowOrdDTArray[ nLastSelectedRowOrdDT ] = hWndTable.colDateTime
.head 5 -  Set bTurnOffCheckToSelectRow = FALSE
.head 3 +  Function: CheckToSelectRow
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Date/Time: dtSelectedRowOrdDTArray[*]
.head 5 -  Number: nLastSelectedRowOrdDT
.head 5 -  Date/Time: dtColDateTime
.head 5 -  Window Handle: hWndTable
.head 5 -  Number: nRow
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nCount
.head 5 -  Boolean: bFound
.head 4 +  Actions
.head 5 -  Set bFound = FALSE
.head 5 -  Set nCount = 0
.head 5 +  While nCount <= nLastSelectedRowOrdDT AND NOT bFound
.head 6 +  If dtSelectedRowOrdDTArray[ nCount ] = dtColDateTime
.head 7 -  Set bFound = TRUE
.head 7 +  If NOT SalTblQueryRowFlags( hWndTable, nRow, ROW_Selected )
.head 8 -  Call SalTblSetFocusRow( hWndTable, nRow )
.head 8 -  Call SalTblSetContext( hWndTable, nRow )
.head 8 -  Call SalTblSetRowFlags( hWndTable, nRow, ROW_Selected, TRUE )
.head 6 -  Set nCount = nCount + 1
.head 5 +  If bFound
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 3 +  Function: ForceBackEndToSelectToReset
.head 4 -  Description: Because the rows are selected on SAM_FetchRow if on table 
click the user select new rows or modifies,  This functions brings
back the backend result set rows so that they can be selected
before reseting the nLastSelectedRowOrdDT counter of the 
rows that are being remembered.  So that next time pulling,
invoicing etc. is run we have the rows selected in the table and
we can correctly reset the remembered rows.
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Window Handle: hWndTable
.head 5 -  Receive Number: nLastSelectedRowOrdDT
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nRow
.head 5 -  Number: nOriginalRowContext
.head 4 +  Actions
.head 5 +  If nLastSelectedRowOrdDT > -1
.head 6 -  Call SalWaitCursor( TRUE )
.head 6 -  Set nOriginalRowContext = SalTblQueryContext( hWndTable )
.head 6 -  Set nRow = TBL_MinRow
.head 6 +  While SalTblFindNextRow( hWndTable, nRow, 0, 0 )
.head 7 -  Call SalTblFetchRow( hWndTable, nRow )
.head 6 -  Call SalTblFetchRow( hWndTable, nOriginalRowContext )
.head 6 -  Set nLastSelectedRowOrdDT = -1
.head 6 -  Call SalWaitCursor( FALSE )

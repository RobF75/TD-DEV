.head 4 +  Actions
.head 5 -  Set bSqlHandle = SqlConnect( hSqlHandle ) 
.head 5 +  If bSqlHandle
.head 6 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 5 +  Else
.head 6 -  Call SalWaitCursor( FALSE )
.head 6 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -  Call SalWaitCursor( TRUE )
.head 6 -  Return ''
.head 5 -  !
.head 5 -  Set sLoadId = ''
.head 5 +  Select Case nLoadType
.head 6 +  Case nRailLoad
.head 7 -  Set sLoadIdLike = 'RAIL%'
.head 7 -  Break
.head 6 +  Case nMailLoad
.head 7 -  Set sLoadIdLike = 'MAIL%'
.head 7 -  Break
.head 6 +  Default
.head 7 -  Set sLoadIdLike = ''
.head 5 -  Set sSql = 'SELECT Region_Load.Load_Id FROM Region_Load, Customer_Master 
INTO :sLoadId WHERE Customer_Master.Cust_No = :nCustNo AND 
Customer_Master.Region_Id = Region_Load.Region_Id AND 
Region_Load.Load_Id LIKE :sLoadIdLike '
.head 5 +  If SqlPrepareAndExecute( hSqlHandle, sSql )
.head 6 -  Call SqlFetchNext( hSqlHandle, nInd )
.head 6 +  If bSqlHandle
.head 7 -  Call SqlDisconnect( hSqlHandle )
.head 6 -  Return sLoadId
.head 5 +  Else
.head 6 +  If bSqlHandle
.head 7 -  Call SqlDisconnect( hSqlHandle )
.head 6 -  Call SalWaitCursor( FALSE )
.head 6 -  Call SalMessageBox( 'Error occured in GetCustRailMailLoadId( ), no Load Id was retrieved, Please Contact programmers! ', 'Error', MB_Ok )
.head 6 -  Call SalWaitCursor( TRUE )
.head 6 -  Return ''

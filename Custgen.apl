.head 5 -  Set sLoadId = ''
.head 5 -  !
.head 5 +  Select Case nLoadType
.head 6 +  Case nPickUpLoad
.head 7 -  Set sLoadId = 'PICKUPS'
.head 7 -  Break
.head 6 +  Case nRailLoad
.head 7 -  Set sLoadId = GetCustRailMailLoadId( nCustNo, nLoadType )
.head 7 -  Break
.head 6 +  Case nMailLoad
.head 7 -  Set sLoadId = GetCustRailMailLoadId( nCustNo, nLoadType )
.head 5 +  If sLoadId != ''
.head 6 -  Call UpdateLoadCustomers( sLoadId, nCustNo )
.head 6 -  Set bPulled = FALSE
.head 6 -  Set nRow = TBL_MinRow
.head 6 +  While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
.head 7 -  Call SalTblFetchRow( hWndTable, nRow )
.head 7 +  If hWndTable.colPullFlag != 'Y'
.head 8 -  Call UpdateCustOrdLoadId( hSqlUpdateHdl, bSqlUpdateHdlConnected, bSqlUpdateHdlPrepared, sLoadId, nCustNo, hWndTable )
.head 7 +  Else
.head 8 -  Set bPulled = TRUE
.head 6 -  Call SalSendMsg( hWndTable, PAM_REPOPULATE, 0, 0 )
.head 6 -  Call SalWaitCursor( FALSE )
.head 6 +  If bPulled
.head 7 -  Call SalMessageBox( 'One or more selected orders could not be assigned because they were pulled!', 'NOTE', MB_Ok )
.head 5 +  Else
.head 6 -  Call SalWaitCursor( FALSE )
.head 6 -  Call SalMessageBox( 'Error Occured in Obtaining the correct Load_Id to Use! Order Have not been Assigned!', 'Error', MB_Ok )
.head 3 +  Function: GetCustRailMailLoadId
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  String:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Number: nLoadType
.head 4 -  Static Variables

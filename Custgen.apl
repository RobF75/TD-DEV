.head 5 -  Set nClearArrayInc = ngMinRange
.head 5 +  While nClearArrayInc <= ngMaxRange
.head 6 -  Set ngRowSelected[nClearArrayInc] = NUMBER_Null
.head 6 -  Set nClearArrayInc = nClearArrayInc + 1
.head 5 -  Set ngArrayInc = 0
.head 5 -  ! Call SalSetArrayBounds( ngRowSelected, AC_Dynamic, AC_Dynamic )
.head 3 +  Function: POSFreightCharge
.head 4 -  Description: If no stock items have been purchased then need to calculate the
applicable freight charge for the POS and add it to the customers
freight charge
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Boolean: bLocalSqlA
.head 5 -  Sql Handle: hLocalSqlA
.head 4 +  Actions
.head 5 -  ! LOCAL SQL HANDLE CONNECTION, DISCONNECT ARE on exit pointS
.head 5 -  Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
.head 5 +  If bLocalSqlA
.head 6 -  Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
.head 5 +  Else
.head 6 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -  Return FALSE
.head 5 -  !
.head 5 -  Set sgSql = 'SELECT PRICE_BREAK.AMOUNT, PRICE_BREAK.NO_TREES FROM
FREIGHT_CHARGE,PRICE_BREAK INTO :ngPercAmt, :ngNoTrees WHERE
FREIGHT_CODE = :frmOrders.tblOrder.colPOSFrCode AND PRICE_BREAK.PRICE_BREAK_ID
= FREIGHT_CHARGE.PRICE_BREAK_ID ORDER BY FREIGHT_BRK_LEVEL'
.head 5 +  If NOT SqlOK( hLocalSqlA, sgSql )
.head 6 +  If bLocalSqlA
.head 7 -  Call SqlDisconnect( hLocalSqlA )
.head 6 -  Return FALSE
.head 5 +  While SqlFetchNext( hLocalSqlA, ngFetch )
.head 6 +  If ngFetch = FETCH_EOF
.head 7 +  If bLocalSqlA
.head 8 -  Call SqlDisconnect( hLocalSqlA )
.head 7 -  Return FALSE
.head 6 +  If frmOrders.tblOrder.colConfAmt <= ngNoTrees
.head 7 -  Set frmOrders.dfDelCharge = frmOrders.dfDelCharge + ngPercAmt
.head 7 +  If bLocalSqlA
.head 8 -  Call SqlDisconnect( hLocalSqlA )
.head 7 -  Return TRUE
.head 5 +  If bLocalSqlA
.head 6 -  Call SqlDisconnect( hLocalSqlA )
.head 3 +  Function: FirstPOSRecord
.head 4 -  Description: To set up the first POS record for a customer after their stock item orders
have been processed
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Call SalSendMsg( frmOrders.tblOrder, PAM_POPULATE, 0, 0 )
.head 5 -  ! eg no rows fit the selection
.head 5 +  If ngCount2 = 0
.head 6 -  Return FALSE
.head 5 -  Set ngTRow = -1
.head 5 -  Call SalTblFindNextRow( frmOrders.tblOrder, ngTRow, 0, 0 )
.head 5 -  Call SalTblFetchRow( frmOrders.tblOrder, ngTRow )
.head 5 -  !
.head 5 -  Call OurSendMsgToChildren(  frmOrders.tblOrder, PAM_EXTENDPRICES, 0, 0 )
.head 5 +  If nMySendMsgError
.head 6 -  Set bOk = FALSE
.head 6 -  Return FALSE
.head 5 +  If bgUpdateFiles = TRUE
.head 6 +  If NOT UpdateOrderForInvoice( frmOrders.tblOrder, frmOrders.tblOrder.colItemNo,
 frmOrders.tblOrder.colSubsItemNo, frmOrders.tblOrder.colYr, frmOrders.tblOrder.colConfAmt, CUSTORDROWIDPOS )
.head 7 -  Set frmOrders.bFilesUpdated = FALSE
.head 7 -  Return FALSE
.head 5 +  If ngTRow = ngCount2 - 1
.head 6 -  !
.head 6 +  If SalSendMsg( tblInvoiceTotals, PAM_LOOKUPCUST, 0, frmOrders.dfCustNo )
.head 7 -  Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, nUseStoredTotals, 0 )
.head 6 +  Else
.head 7 -  Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, 0, 0 )
.head 7 -  Call PushNumber( frmOrders.dfCustNo )
.head 7 -  Call PushNumber( frmOrders.dfDelCharge )
.head 7 -  Call PushNumber( frmOrders.dfPackCharge )
.head 7 -  Call PushNumber( frmOrders.dfLabCharge )
.head 7 -  Call SalSendMsg( tblInvoiceTotals, PAM_ADDROW, 0, 0 )
.head 6 -  ! Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, 0, 0 )
.head 6 +  If bgUpdateFiles = TRUE
.head 7 +  If NOT UpdateInvoiceTotalsToFile( frmOrders, frmOrders.dfDeposit )
.head 8 -  Set bOk = FALSE
.head 8 -  Set frmOrders.bFilesUpdated = FALSE
.head 8 -  Return FALSE
.head 7 -  Call UpdateLoadCustInvFlag( frmOrders.tblOrder.colLoad, frmOrders.dfCustNo, 'Y', nExecute )
.head 5 -  Return TRUE
.head 3 +  Function: PrintInvoice
.head 4 -  Description: To physically print the invoice for the customer
 we process the orders that have been selected for that customer
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Boolean: bPickUpAddress
.head 4 +  Actions
.head 5 -  Set ngSITotal = 0
.head 5 -  Set ngRoyTot = 0
.head 5 -  Set ngOrdTotal = 0
.head 5 -  Set ngTotAmt = 0
.head 5 -  Set frmOrders.dfTotRoyalties = 0
.head 5 -  !
.head 5 -  Call GetShipAddressHdlNewLogic( frmOrders.dfCustNo, frmOrders.dfYr, frmOrders, PAM_SHIPADDRESS, bPickUpAddress, nExecute )
.head 5 +  If bPickUpAddress
.head 6 -  Set frmOrders.dfSHAdd1 = sPICKUPADDRESSLINE1
.head 6 -  Set frmOrders.dfSHAdd2 = sPICKUPADDRESSLINE2
.head 5 -  !
.head 5 -  Call GetBusAddressHdlNewLogic( frmOrders.dfCustNo, frmOrders, PAM_BUSADDRESS, nExecute )
.head 5 -  !
.head 5 -  !
.head 5 -  !
.head 5 -  ! Because the orders selected may all be on different loads we need to calculate
the freight charge on an order basis and not a load basis 
.head 5 -  ! Call FreightCharges(  )
.head 5 -  ! Need to reset the cumulated fields on frmOrders
.head 5 -  Call SalSendMsgToChildren( frmOrders, PAM_REFRESH, 0, 0 )
.head 5 -  Call SumOrdConf( frmOrders.dfCustNo, frmOrders.dfYr )
.head 5 +  If NOT SalIsNull( frmOrders.dfLabCode )
.head 6 -  Set frmOrders.dfLabperTree = LabelCharges( frmOrders.dfLabCode )
.head 5 +  If NOT SalIsNull( frmOrders.dfPackCode )
.head 6 -  Set frmOrders.dfPackPerc = LabelCharges( frmOrders.dfPackCode )
.head 5 -  ! Call ProcessDeposit( frmOrders, frmOrders.dfCustNo, frmOrders.dfYr,
 frmOrders.dfDeposit )
.head 5 -  Call MyProcessDeposit( frmOrders.hSqlHdlDepAmt, frmOrders.bHdlDepAmtConnected, frmOrders.bHdlDepAmtPrepared, 
frmOrders.hSqlHdlAmtUnAplid, frmOrders.bHdlAmtUnAplidConnected, frmOrders.bHdlAmtUnAplidPrepared, 
frmOrders, frmOrders.dfCustNo, frmOrders.dfYr, frmOrders.dfDeposit )
.head 5 -  Call CheckForPOS( frmOrders.dfCustNo, frmOrders.dfYr )
.head 5 -  Set ngTRow = -1
.head 5 -  ! Set bgNilSI = FALSE
.head 5 -  Return TRUE
.head 3 +  Function: SumOrdConf
.head 4 -  Description: To sum the ordered and confirmed values as label charges require these
and freight charges is now done on an order basis not a customer basis
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Number: nCustno
.head 5 -  Number: nYr
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sCustno
.head 5 -  String: sYr
.head 4 +  Actions
.head 5 -  Set ngTotTrees = 0
.head 5 -  Set ngTotTreesOrd = 0
.head 5 -  Call SalNumberToStr( nCustno, 0, sCustno )
.head 5 -  Call SalNumberToStr( nYr, 0, sYr )
.head 5 -  Set sgSql = 'SELECT SUM(CONF_AMT),SUM(ORDERED_AMOUNT)
 FROM CUSTOMER_ORDER
 INTO :ngTotTrees,:ngTotTreesOrd WHERE CUST_NO = '||sCustno||' AND
YEAR_OF_SALE = '||sYr
.head 5 -  Call SqlImmediate( sgSql )
.head 5 -  Call SqlClearImmediate(  )
.head 3 +  Function: OrderGoAhead
.head 4 -  Description: If the customer has stops for any reason of orders being placed then we
want error messages to appear
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If frmOrders.dfDontSell = 'Y'
.head 6 -  Call SalMessageBox( 'This Customer is flagged as DONT SELL TO!,
You need authorisation from the office manager before continuing to add the order?
Please note any comments from customer details before requesting
the authorisation.', 'Warning', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  If frmOrders.dfCredStop = 'Y'
.head 6 -  Call SalMessageBox( 'This Customer is flagged as CREDIT STOP!,
You need to refer to Accounts Payable re releasing this customer from Credit Stop status.', 'Warning', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  If frmOrders.dfClAcc = 'Y'
.head 6 -  Call SalMessageBox( 'This Customer is flagged as a CLOSED ACCOUNT!,
You need to refer to Accounts Payable re this customer.', 'Warning', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  If frmOrders.dfCusttype = 'OPP'
.head 6 +  If IDCANCEL = SalMessageBox( 'This customer is an OPPOSITION customer, do you still want to accept this order?', 'Warning', MB_OkCancel )
.head 7 -  Return FALSE
.head 5 +  Else If frmOrders.dfCusttype = 'BAD'
.head 6 -  Call SalMessageBox( 'This customer is a BAD DEBT customer, please contact accounts', 'Warning', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  Else If frmOrders.dfCusttype = 'BOR'
.head 6 -  Call SalMessageBox( 'This customer is a BAD DEBT customer, please contact Accounts', 'Warning', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  If frmOrders.dfBadDebt = 'Y'
.head 6 -  Call SalMessageBox( 'This customer is a BAD DEBT customer, please contact accounts', 'Warning', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  If frmOrders.dfCredLimit > 0
.head 6 +  If frmOrders.dfAR > frmOrders.dfCredLimit
.head 7 -  Call SalMessageBox( 'This customer has exceeded his credit limit.   Please contact accounts
to OK any further orders and increasing his Credit Limit' , 'Warning', MB_Ok )
.head 7 -  Return FALSE
.head 5 -  Return TRUE

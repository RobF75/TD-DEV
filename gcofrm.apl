.head 5 +  On PAM_WRITEINSERTSUPDATES
.head 6 +  If SalIsNull( frmGardenCentreOrdFrm.dfOrderDate )
.head 7 -  Call SalMessageBox( 'Please enter a order date first!', 'Warning', MB_Ok )
.head 7 -  Return FALSE
.head 6 +  If SalIsNull( dfPurchOrdNo )
.head 7 -  Call CheckCustPurchOrdNoReqd( dfCustNo, bReqd, SH_cls_Execute )
.head 7 +  If bReqd
.head 8 +  If IDYES = SalMessageBox( 'This customer requires a purchase order number! Do you have one to enter!', 'Warning', MB_YesNo )
.head 9 -  Call SalSetFocus( dfPurchOrdNo )
.head 9 -  Return FALSE
.head 6 -  !
.head 6 +  If MyTableDataVal( hWndForm )
.head 7 -  Call MyTableLoop( hWndForm, hWndForm, PAM_ROWACTION, ROW_Edited, 0, 'Adding Orders', nLowToHi )
.head 5 +  On PAM_ROWACTION
.head 6 -  Call SalTblSetFocusRow( hWndForm, lParam )
.head 6 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_Selected, TRUE )
.head 6 -  Set naBatchLocationIds[0] = NUMBER_Null
.head 6 -  Set naBatchLocAllocated[0] = NUMBER_Null
.head 6 +  If colConfAmt != NUMBER_Null
.head 7 -  Set nOrderedTotal = nOrderedTotal + colConfAmt
.head 6 +  Else
.head 7 -  Set nOrderedTotal = nOrderedTotal + colOrdAmt
.head 6 +  If NewAddOrder( frmGardenCentreOrdFrm.dfCustNo, frmGardenCentreOrdFrm.dfYear, frmGardenCentreOrdFrm.dfOrderDate, colItemNo, colOrdAmt, colConfAmt,  frmGardenCentreOrdFrm.dfOrderBookNo, 'NM', 'Y', naBatchLocationIds, naBatchLocAllocated, 
NUMBER_Null, frmGardenCentreOrdFrm, 
PAM_UPDATE, dtTmp, 
SH_cls_Execute|nItemCheck )
.head 7 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_New, FALSE )
.head 7 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, FALSE )
.head 6 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_Selected, FALSE )
.head 6 -  Return TRUE
.head 5 +  On SAM_Destroy
.head 6 -  Call NewAddOrder( 0, 0, DATETIME_Null, 0, 0, 0, '', '', '', naBatchLocationIds, naBatchLocAllocated, 0, hWndNULL, 0, dtTmp, SH_cls_Disconnect )
.head 6 -  Call CheckItemIsOkForCust( 0, 0, 0, bOk, SH_cls_Disconnect )
.head 6 -  Call CheckCustPurchOrdNoReqd( 0, bReqd, SH_cls_Disconnect )
.head 6 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

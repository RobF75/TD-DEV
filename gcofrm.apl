.head 4 -  Call SalWaitCursor( FALSE )
.head 4 -  !
.head 4 -  Call SalHideWindow( SalParentWindow( hWndForm ) )
.head 4 -  !
.head 3 +  On SAM_Destroy
.head 4 -  !
.head 4 -  Call SalShowWindow( SalParentWindow( hWndForm ) )
.head 4 -  Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
.head 4 -  !
.head 4 -  Call SalMapEnterToTab( FALSE )
.head 4 -  Call SalPostMsg( SalParentWindow( hWndForm ), PAM_REPOPULATE, 0, 0 )
.head 4 -  Call SalSendClassMessage( SAM_Destroy, wParam, lParam )

.head 5 +  Function: tfOnCreate
.head 6 -  Description:
.head 6 -  Returns
.head 6 -  Parameters
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  Number: nStyle
.head 6 +  Actions
.head 7 -  ! Make it a M!Table ;o)
.head 7 -  Call MTblSubClass( hWndForm )
.head 7 -  ! Remove the clientedge
.head 7 -  Set nStyle = GetWindowLongA( hWndForm, GWL_EXSTYLE )
.head 7 -  Call VisNumberBitClear( nStyle, WS_EX_CLIENTEDGE )
.head 7 -  Call SetWindowLongA( hWndForm, GWL_EXSTYLE, nStyle )
.head 7 -  ! Set some general variables
.head 7 -  Set t_nBackColorGrayed = GetSysColor( COLOR_3DFACE )
.head 7 -  Set t_nTextColorGrayed = COLOR_DarkGray
.head 7 -  Set t_nRowFlagColorValue = ROW_UserFlag1
.head 7 -  Set t_nRowFlagFontName = ROW_UserFlag2
.head 7 -  Set t_sTextDefault = "(Default)"
.head 7 -  ! Remove the row header
.head 7 -  Call SalTblDefineRowHeader( hWndForm, STRING_Null, 0, 0, hWndNULL )
.head 7 -  ! Remove the column header
.head 7 -  Call MTblSetFlags( hWndForm, MTBL_FLAG_NO_COLUMN_HEADER, TRUE )
.head 7 -  ! Suppress last column line
.head 7 -  Call SalTblSetTableFlags( hWndForm, TBL_Flag_SuppressLastColLine, TRUE )
.head 7 -  ! Make buttons permanently visible
.head 7 -  Call MTblSetFlags( hWndForm, MTBL_FLAG_BUTTONS_PERMANENT, TRUE )
.head 7 -  ! Remove lines in the free column area
.head 7 -  Call MTblSetFlags( hWndForm, MTBL_FLAG_NO_FREE_ROW_AREA_LINES, TRUE )
.head 7 -  ! Paint background color of rows over the entire table
.head 7 -  Call MTblSetFlags( hWndForm, MTBL_FLAG_COLOR_ENTIRE_ROW, TRUE )
.head 7 -  ! Suppress row focus frame and row selections
.head 7 -  Call MTblSetFlags( hWndForm, MTBL_FLAG_SUPPRESS_FOCUS | MTBL_FLAG_SUPPRESS_ROW_SELECTION, TRUE )
.head 7 -  ! Define row and column lines
.head 7 -  Call MTblDefineRowLines( hWndForm, MTLS_SOLID, t_nBackColorGrayed )
.head 7 -  Call MTblDefineColLines( hWndForm, MTLS_SOLID, t_nBackColorGrayed )
.head 7 -  ! Define the tree
.head 7 -  Call MTblDefineTree( hWndForm, colProp, 8, 12 )
.head 7 -  ! Call MTblSetTreeFlags( hWndForm, MTBL_TREE_FLAG_FLAT_STRUCT, TRUE )
.head 7 -  ! Set background color of the node column
.head 7 -  ! Call MTblSetColumnBackColor( colNode, t_nBackColorGrayed, 0 )
.head 7 -  ! Set node colors
.head 7 -  Call MTblSetTreeNodeColors( hWndForm, MTBL_COLOR_UNDEF, MTBL_COLOR_UNDEF, COLOR_White )
.head 7 -  ! Make sure that the width of drop down lists are adapted to their content
.head 7 -  Call MTblSetFlags( hWndForm, MTBL_FLAG_ADAPT_LIST_WIDTH, TRUE )
.head 7 -  ! Insert the property structure
.head 7 -  Call tfInsertProps( )
.head 7 -  ! Auto-size columns
.head 7 -  Call MTblAutoSizeColumn( hWndForm, hWndNULL, MTASC_ALLROWS | MTASC_HIDDENROWS | MTASC_DDBTNSPACE | MTASC_BTNSPACE )

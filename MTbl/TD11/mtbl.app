.head 2 +  Functions
.head 3 +  Function: wfDo
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nRet
.head 5 -  String: sText
.head 4 +  Actions
.head 5 -  Call SalWaitCursor( TRUE )
.head 5 -  Call wfSaveSettings( )
.head 5 -  ! Set nRet = MTblExportToExcel( frmMain.tbl1, frmMain.ExcExp.Language, frmMain.ExcExp.ExcelStartCell, frmMain.ExcExp.ExcelFlags, frmMain.ExcExp.ExpFlags, frmMain.ExcExp.RowFlagsOn, frmMain.ExcExp.RowFlagsOff, frmMain.ExcExp.ColFlagsOn, 
frmMain.ExcExp.ColFlagsOff )
.head 5 -  Set nRet = MTblExportToExcelEx( frmMain.tbl1, frmMain.ExcExp )
.head 5 -  Call SalWaitCursor( FALSE )
.head 5 +  If nRet < 1
.head 6 +  Select Case nRet
.head 7 +  Case MTE_ERR_CANCELLED
.head 8 -  Set sText = "Export cancelled."
.head 8 -  Break
.head 7 +  Case MTE_ERR_RUNNING_INSTANCE
.head 8 -  Set sText = "Error getting running instance"
.head 8 -  Break
.head 7 +  Case MTE_ERR_NEW_INSTANCE
.head 8 -  Set sText = "Error creating new instance"
.head 8 -  Break
.head 7 +  Case MTE_ERR_OLE_EXCEPTION
.head 8 -  Set sText = "An OLE exception has occured"
.head 8 -  Break
.head 7 +  Case MTE_ERR_EXCEPTION
.head 8 -  Set sText = "An exception has occured"
.head 8 -  Break
.head 7 +  Case MTE_ERR_NOT_SUBCLASSED
.head 8 -  Set sText = "Table isn't subclassed"
.head 8 -  Break
.head 7 +  Case MTE_ERR_INVALID_LANG
.head 8 -  Set sText = "Invalid language"
.head 8 -  Break
.head 7 +  Default
.head 8 -  Set sText = "Export failed."
.head 8 -  Break
.head 6 -  Call SalMessageBox( sText, "Export error", MB_IconHand | MB_Ok )
.head 3 +  Function: wfReadSettings
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  ! Language
.head 5 -  Call cmbLanguage.Populate( )
.head 5 -  Call cmbLanguage.SelectValue( frmMain.ExcExp.Language )
.head 5 -  ! Excel start cell
.head 5 -  Set dfsStartCell = frmMain.ExcExp.ExcelStartCell
.head 5 -  ! Save as
.head 5 -  Set dfsSaveAsFile = frmMain.ExcExp.ExcelSaveAsFile
.head 5 -  ! Template
.head 5 -  Set dfsTemplateFile = frmMain.ExcExp.ExcelTemplateFile
.head 5 -  ! Sheet name
.head 5 -  Set dfsSheetName = frmMain.ExcExp.ExcelSheetName
.head 5 -  ! Excel flags
.head 5 -  Set cbNewInst = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_NEW_INSTANCE
.head 5 -  Set cbRunningInst = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_RUNNING_INSTANCE
.head 5 -  Set cbHideInst = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_HIDE_INSTANCE
.head 5 -  Set cbCloseInst = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_CLOSE_INSTANCE
.head 5 -  Set cbNewWBook = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_NEW_WORKBOOK
.head 5 -  Set cbCloseWBook = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_CLOSE_WORKBOOK
.head 5 -  Set cbNewWSheet = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_NEW_WORKSHEET
.head 5 -  Set cbCurPos = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_CURRENT_POS
.head 5 -  Set cbStrColsAsText = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_STRING_COLS_AS_TEXT
.head 5 -  Set cbNullsAsSpace = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_NULLS_AS_SPACE
.head 5 -  Set cbNoClipboard = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_NO_CLIPBOARD
.head 5 -  Set cbNoAutoFitCol = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_NO_AUTO_FIT_COL
.head 5 -  Set cbNoAutoFitRow = frmMain.ExcExp.ExcelFlags & MTE_EXCEL_NO_AUTO_FIT_ROW
.head 5 -  ! Export flags
.head 5 -  Set cbColHdrs = frmMain.ExcExp.ExpFlags & MTE_COL_HEADERS
.head 5 -  Set cbColors = frmMain.ExcExp.ExpFlags & MTE_COLORS
.head 5 -  Set cbFonts = frmMain.ExcExp.ExpFlags & MTE_FONTS
.head 5 -  Set cbGrid = frmMain.ExcExp.ExpFlags & MTE_GRID
.head 5 -  Set cbShowStatus = frmMain.ExcExp.ExpFlags & MTE_SHOW_STATUS
.head 5 -  Set cbSplitRows = frmMain.ExcExp.ExpFlags & MTE_SPLIT_ROWS
.head 5 -  ! Rows to export
.head 5 +  If frmMain.ExcExp.RowFlagsOn & ROW_Selected
.head 6 -  Set rbSelectedRows = TRUE
.head 5 -  ! Columns to export
.head 5 +  If frmMain.ExcExp.ColFlagsOn & COL_Selected
.head 6 -  Set rbSelectedCols = TRUE
.head 3 +  Function: wfSaveSettings
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  : ExcExp
.head 6 -  Class: fcMTblExcelExpParams
.head 4 +  Actions
.head 5 -  ! Language
.head 5 -  Set ExcExp.Language = cmbLanguage.GetSelectedValue( )
.head 5 -  ! Excel start cell
.head 5 -  Set ExcExp.ExcelStartCell = dfsStartCell
.head 5 -  ! Save as
.head 5 -  Set ExcExp.ExcelSaveAsFile = dfsSaveAsFile
.head 5 -  ! Template
.head 5 -  Set ExcExp.ExcelTemplateFile = dfsTemplateFile
.head 5 -  ! Sheet name
.head 5 -  Set ExcExp.ExcelSheetName = dfsSheetName
.head 5 -  ! Excel flags
.head 5 +  If cbNewInst
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_NEW_INSTANCE
.head 5 +  If cbRunningInst
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_RUNNING_INSTANCE
.head 5 +  If cbHideInst
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_HIDE_INSTANCE
.head 5 +  If cbCloseInst
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_CLOSE_INSTANCE
.head 5 +  If cbNewWBook
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_NEW_WORKBOOK
.head 5 +  If cbCloseWBook
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_CLOSE_WORKBOOK
.head 5 +  If cbNewWSheet
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_NEW_WORKSHEET
.head 5 +  If cbCurPos
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_CURRENT_POS
.head 5 +  If cbStrColsAsText
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_STRING_COLS_AS_TEXT
.head 5 +  If cbNullsAsSpace
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_NULLS_AS_SPACE
.head 5 +  If cbNoClipboard
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_NO_CLIPBOARD
.head 5 +  If cbNoAutoFitCol
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_NO_AUTO_FIT_COL
.head 5 +  If cbNoAutoFitRow
.head 6 -  Set ExcExp.ExcelFlags = ExcExp.ExcelFlags | MTE_EXCEL_NO_AUTO_FIT_ROW
.head 5 -  ! Export flags
.head 5 +  If cbColHdrs
.head 6 -  Set ExcExp.ExpFlags = ExcExp.ExpFlags | MTE_COL_HEADERS
.head 5 +  If cbColors
.head 6 -  Set ExcExp.ExpFlags = ExcExp.ExpFlags | MTE_COLORS
.head 5 +  If cbFonts
.head 6 -  Set ExcExp.ExpFlags = ExcExp.ExpFlags | MTE_FONTS
.head 5 +  If cbGrid
.head 6 -  Set ExcExp.ExpFlags = ExcExp.ExpFlags | MTE_GRID
.head 5 +  If cbShowStatus

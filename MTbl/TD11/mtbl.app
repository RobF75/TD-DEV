.head 6 +  Actions
.head 7 +  If MTblGetOwnerDrawnItem( hWndForm, p_nID, odi )
.head 8 -  ! Test
.head 8 -  ! Call GetClipBox( odi.DC, nClipLeft, nClipTop, nClipRight, nClipBottom )
.head 8 -  ! Set column handle
.head 8 +  Select Case odi.Type
.head 9 -  Case MTBL_ODI_CELL
.head 9 +  Case MTBL_ODI_COLHDR
.head 10 -  Set hWndCol = odi.HWndParam
.head 10 -  Break
.head 8 -  ! Get selection colors
.head 8 -  Call MTblGetSelectionColors( hWndForm, nSelTextColor, nSelBackColor )
.head 8 -  ! Get effective highlighting
.head 8 -  Call hili.Init( )
.head 8 +  If NOT odi.Printing
.head 9 -  Call item.DefineFromODI( odi, TRUE )
.head 9 -  Call MTblGetEffHighlighting( item, hili )
.head 8 -  ! Get effective back color
.head 8 +  If hili.BackColor != MTBL_COLOR_UNDEF
.head 9 -  Set nBackColor = hili.BackColor
.head 8 +  Else
.head 9 +  If odi.Selected AND nSelBackColor != MTBL_COLOR_UNDEF
.head 10 -  Set nBackColor = nSelBackColor
.head 9 +  Else
.head 10 +  Select Case odi.Type
.head 11 +  Case MTBL_ODI_CELL
.head 12 -  Call MTblGetEffCellBackColor( hWndCol, odi.NParam, nBackColor )
.head 12 -  Break
.head 11 +  Case MTBL_ODI_COLHDR
.head 12 -  Call MTblGetEffColumnHdrBackColor( hWndCol, nBackColor )
.head 12 -  Break
.head 11 +  Case MTBL_ODI_COLHDRGRP
.head 12 -  Call MTblGetEffColHdrGrpBackColor( hWndForm, odi.NParam, nBackColor )
.head 12 -  Break
.head 11 +  Case MTBL_ODI_ROWHDR
.head 12 -  Call MTblGetEffRowHdrBackColor( hWndForm, odi.NParam, nBackColor )
.head 12 -  Break
.head 11 +  Case MTBL_ODI_CORNER
.head 12 +  If SalTblQueryTableFlags( hWndForm, TBL_Flag_GrayedHeaders )
.head 13 -  Set nBackColor = GetSysColor( COLOR_3DFACE )
.head 12 +  Else
.head 13 -  Set nBackColor = SalColorGet( hWndForm, COLOR_IndexWindow )
.head 12 -  Break
.head 8 -  ! Fill background
.head 8 -  Set nColor = nBackColor
.head 8 -  Set nBrush = CreateSolidBrush( nColor )
.head 8 -  Set nOldBrush = SelectObject( odi.DC, nBrush )
.head 8 -  Call FillRect( odi.DC, odi.Left, odi.Top, odi.Right, odi.Bottom, nBrush )
.head 8 -  Call SelectObject( odi.DC, nOldBrush )
.head 8 -  Call DeleteObject( nBrush )
.head 8 -  ! Draw an image
.head 8 -  Set nImage = tnImgOk
.head 8 -  Call MImgGetSize( nImage, nImgWid, nImgHt )
.head 8 +  If odi.Printing
.head 9 -  Set nImgWid = nImgWid * odi.XResFactor
.head 9 -  Set nImgHt = nImgHt * odi.YResFactor
.head 9 -  Set nImageCopy = MImgCreateCopy( nImage )
.head 9 -  Call MImgStripOpacity( nImageCopy, nBackColor )
.head 9 -  Set nImage = nImageCopy
.head 8 -  Set nImgLeft = odi.Left + odi.XLeading
.head 8 -  Call MImgDrawAligned( nImage, odi.DC, nImgLeft, odi.Top, odi.Right, odi.Bottom, nImgWid, nImgHt, MIMG_ALIGN_LEFT | MIMG_ALIGN_VCENTER, 0 )
.head 8 +  If nImageCopy
.head 9 -  Call MImgDelete( nImageCopy )
.head 8 -  ! Draw a rectangle
.head 8 -  Set nColor = COLOR_Red
.head 8 -  Set nPen = CreatePen( PS_DOT, 1, nColor )
.head 8 -  Set nOldPen = SelectObject( odi.DC, nPen )
.head 8 -  Set nRectLeft = nImgLeft + nImgWid + odi.XLeading
.head 8 -  Call MoveToEx( odi.DC, nRectLeft, odi.Top, nOldX, nOldY )
.head 8 -  Call LineTo( odi.DC, odi.Right, odi.Top )
.head 8 -  Call MoveToEx( odi.DC, odi.Right - 1, odi.Top, nOldX, nOldY )
.head 8 -  Call LineTo( odi.DC, odi.Right - 1, odi.Bottom )
.head 8 -  Call MoveToEx( odi.DC, odi.Right - 1, odi.Bottom - 1, nOldX, nOldY )
.head 8 -  Call LineTo( odi.DC, nRectLeft, odi.Bottom - 1 )
.head 8 -  Call MoveToEx( odi.DC, nRectLeft, odi.Bottom - 1, nOldX, nOldY )
.head 8 -  Call LineTo( odi.DC, nRectLeft, odi.Top )
.head 8 -  Call SelectObject( odi.DC, nOldPen )
.head 8 -  Call DeleteObject( nPen )
.head 8 -  ! Draw an ellipse
.head 8 -  Set nBrush = CreateSolidBrush( COLOR_Yellow )
.head 8 -  Set nOldBrush = SelectObject( odi.DC, nBrush )
.head 8 -  Set nLeft = nRectLeft + 1
.head 8 -  Call Ellipse( odi.DC, nLeft, odi.Top + 1, odi.Right - 1, odi.Bottom - 1  )
.head 8 -  Call SelectObject( odi.DC, nOldBrush )
.head 8 -  Call DeleteObject( nBrush )
.head 8 -  ! Draw some text
.head 8 -  Set nOldBkMode = SetBkMode( odi.DC, TRANSPARENT )
.head 8 +  If hili.TextColor != MTBL_COLOR_UNDEF
.head 9 -  Set nColor = hili.TextColor
.head 8 +  Else
.head 9 +  If odi.Selected AND nSelTextColor != MTBL_COLOR_UNDEF
.head 10 -  Set nColor = nSelTextColor
.head 9 +  Else
.head 10 +  Select Case odi.Type
.head 11 +  Case MTBL_ODI_CELL
.head 12 -  Call MTblGetEffCellTextColor( hWndCol, odi.NParam, nColor )
.head 12 -  Break
.head 11 +  Case MTBL_ODI_COLHDR
.head 12 -  Call MTblGetEffColumnHdrTextColor( hWndCol, nColor )
.head 12 -  Break
.head 11 +  Case MTBL_ODI_COLHDRGRP
.head 12 -  Call MTblGetEffColHdrGrpTextColor( hWndForm, odi.NParam, nColor )
.head 12 -  Break
.head 11 -  Case MTBL_ODI_ROWHDR
.head 11 +  Case MTBL_ODI_CORNER
.head 12 -  Set nColor = SalColorGet( hWndForm, COLOR_IndexWindowText )
.head 12 -  Break
.head 8 -  Set nOldTextColor = SetTextColor( odi.DC, nColor )
.head 8 +  Select Case odi.Type
.head 9 +  Case MTBL_ODI_CELL
.head 10 -  Call MTblGetEffCellFont( hWndCol, odi.NParam, sFontName, nFontSize, nFontEnh )
.head 10 -  Break
.head 9 +  Case MTBL_ODI_COLHDR
.head 10 -  Call MTblGetEffColumnHdrFont( hWndCol, sFontName, nFontSize, nFontEnh )
.head 10 -  Break
.head 9 +  Case MTBL_ODI_COLHDRGRP
.head 10 -  Call MTblGetEffColHdrGrpFont( hWndForm, odi.NParam, sFontName, nFontSize, nFontEnh )
.head 10 -  Break
.head 9 -  Case MTBL_ODI_ROWHDR
.head 9 +  Case MTBL_ODI_CORNER
.head 10 -  Call SalFontGet( hWndForm, sFontName, nFontSize, nFontEnh )
.head 10 -  Break
.head 8 +  If hili.FontEnh != MTBL_FONT_UNDEF_ENH
.head 9 +  If nFontEnh = MTBL_FONT_UNDEF_ENH
.head 10 -  Set nFontEnh = hili.FontEnh
.head 9 +  Else
.head 10 -  Set nFontEnh = nFontEnh | hili.FontEnh
.head 8 +  If odi.Printing
.head 9 -  Set nFontSize = nFontSize * odi.YResFactor
.head 8 -  Set nFont = VisFontLoad( sFontName, nFontSize, nFontEnh  )
.head 8 -  Set nOldFont =  SelectObject( odi.DC, nFont )
.head 8 -  Set nLeft = nRectLeft
.head 8 -  Call DrawTextA( odi.DC, "I'm ownerdrawn", -1, nLeft, odi.Top, odi.Right, odi.Bottom, DT_SINGLELINE | DT_CENTER | DT_VCENTER )
.head 8 -  Call SelectObject( odi.DC, nOldFont )
.head 8 -  Call VisFontFree( nFont )
.head 8 -  Call SetBkMode( odi.DC, nOldBkMode )
.head 8 -  Call SetTextColor( odi.DC, nOldTextColor )
.head 5 +  Function: tfOnEndCellTab

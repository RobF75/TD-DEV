.head 5 -  Number: nNewRow
.head 5 -  String: sFile
.head 4 +  Actions
.head 5 +  While n < frmMain.wnLang
.head 6 +  If MTblGetLanguageFile( frmMain.wnaLang[n], sFile )
.head 7 -  Set nNewRow = SalTblInsertRow( tblLang, TBL_MaxRow )
.head 7 +  If nNewRow != TBL_Error
.head 8 -  Call SalTblSetRowFlags( tblLang, nNewRow, ROW_New, FALSE  )
.head 8 -  Set tblLang.colNr = frmMain.wnaLang[n]
.head 8 -  Set tblLang.colName = frmMain.wsaLang[n]
.head 8 -  Set tblLang.colFile = sFile
.head 8 -  Call MTblDisableCell( tblLang.colNr, nNewRow, TRUE )
.head 6 -  Set n = n + 1
.head 5 -  Call MTblAutoSizeColumn( tblLang, hWndNULL, MTASC_ALLROWS | MTASC_BTNSPACE )

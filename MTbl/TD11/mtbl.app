.head 7 -  Call SalTblSetFocusCell( tblLang, n, tblLang.colFile, 0, -1 )
.head 7 -  Call SalMessageBox( "Please enter a file", "Register Language", MB_IconAsterisk | MB_Ok )
.head 7 -  Break
.head 6 +  If NOT MTblRegisterLanguage( tblLang.colNr, tblLang.colFile )
.head 7 -  Set bError = TRUE
.head 7 -  Break
.head 6 -  Call MTblGetLanguageFile( tblLang.colNr, tblLang.colFile )

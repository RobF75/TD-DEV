.head 6 +  Actions
.head 7 -  Set colHandle = SalWindowHandleToNumber( hWndpCol )
.head 7 -  !
.head 7 +  If NOT MTblGetColumnTitle( hWndpCol, sTitle )
.head 8 -  Call SalTblGetColumnTitle( hWndpCol, sTitle, 1024 )
.head 7 -  Set colTitle = sTitle
.head 7 -  !
.head 7 -  Set colVisible = SalIsWindowVisible( hWndpCol )
.head 7 -  !
.head 7 -  Set colEditable = SalIsWindowEnabled( hWndpCol )
.head 7 -  !
.head 7 +  If SalTblQueryColumnFlags( hWndpCol, COL_RightJustify )
.head 8 -  Set colJustify = "Right"
.head 7 +  Else If SalTblQueryColumnFlags( hWndpCol, COL_CenterJustify )
.head 8 -  Set colJustify = "Center"
.head 7 +  Else
.head 8 -  Set colJustify = "Left"
.head 7 -  !
.head 7 -  Set colWordWrap = SalTblQueryColumnFlags( hWndpCol, COL_MultilineCell )
.head 7 -  !
.head 7 -  Set colInvisible = SalTblQueryColumnFlags( hWndpCol, COL_Invisible )
.head 7 -  !
.head 7 -  Set colIndOverfl = SalTblQueryColumnFlags( hWndpCol, COL_IndicateOverflow )
.head 7 -  !
.head 7 -  Set colDimTitle = SalTblQueryColumnFlags( hWndpCol, COL_DimTitle )
.head 5 +  Function: SetCol
.head 6 -  Description:
.head 6 -  Returns
.head 6 -  Parameters
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  Window Handle: hWndCol
.head 6 +  Actions
.head 7 -  Set hWndCol = SalNumberToWindowHandle( colHandle )
.head 7 -  !
.head 7 -  Call MTblSetColumnTitle( hWndCol, colTitle )
.head 7 -  !
.head 7 +  If colVisible
.head 8 -  Call SalShowWindow( hWndCol )
.head 7 +  Else
.head 8 -  Call SalHideWindow( hWndCol )
.head 7 -  !
.head 7 +  If colEditable
.head 8 -  Call SalEnableWindow( hWndCol )
.head 7 +  Else
.head 8 -  Call SalDisableWindow( hWndCol )
.head 7 -  !
.head 7 +  If colJustify = "Right"
.head 8 -  Call SalTblSetColumnFlags( hWndCol, COL_CenterJustify, FALSE )
.head 8 -  Call SalTblSetColumnFlags( hWndCol, COL_RightJustify, TRUE )
.head 7 +  Else If colJustify = "Center"
.head 8 -  Call SalTblSetColumnFlags( hWndCol, COL_RightJustify, FALSE )
.head 8 -  Call SalTblSetColumnFlags( hWndCol, COL_CenterJustify, TRUE )
.head 7 +  Else
.head 8 -  Call SalTblSetColumnFlags( hWndCol, COL_RightJustify, FALSE )
.head 8 -  Call SalTblSetColumnFlags( hWndCol, COL_CenterJustify, FALSE )
.head 7 -  !
.head 7 -  Call SalTblSetColumnFlags( hWndCol, COL_MultilineCell, colWordWrap )
.head 7 -  !
.head 7 -  Call SalTblSetColumnFlags( hWndCol, COL_Invisible, colInvisible )
.head 7 -  !
.head 7 -  Call SalTblSetColumnFlags( hWndCol, COL_IndicateOverflow, colIndOverfl )
.head 7 -  !
.head 7 -  Call SalTblSetColumnFlags( hWndCol, COL_DimTitle, colDimTitle )

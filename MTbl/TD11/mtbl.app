.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  Select Case p_nRet
.head 6 +  Case MTGR_RET_ERROR
.head 7 -  Return "Error"
.head 6 +  Case MTGR_RET_INVISIBLE
.head 7 -  Return "Invisible"
.head 6 +  Case MTGR_RET_PARTLY_VISIBLE
.head 7 -  Return "Partly visible"
.head 6 +  Case MTGR_RET_VISIBLE
.head 7 -  Return "Visible"
.head 6 +  Default
.head 7 -  Return ''

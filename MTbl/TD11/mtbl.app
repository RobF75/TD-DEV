.head 5 +  If bColumnMsg AND NOT cbColumn
.head 6 -  Return TRUE
.head 5 +  If NOT bColumnMsg AND NOT cbTable
.head 6 -  Return TRUE
.head 5 -  !
.head 5 -  Set bMTM_ColSelChanged = ( SalStrLeftX( spTxt, 17 ) = "MTM_ColSelChanged" )
.head 5 -  Set bMTM_RowSelChanged = ( SalStrLeftX( spTxt, 17 ) = "MTM_RowSelChanged" )
.head 5 -  !
.head 5 -  Set spTxt = "<" || SalNumberToStrX( wnMsgNr, 0 ) || ">" || spTxt
.head 5 -  Set nIdx = SalListAdd( lbLog, spTxt )
.head 5 -  !
.head 5 +  If nIdx >= 0
.head 6 +  If bMTM_ColSelChanged
.head 7 -  Set nCols = MTblGetColSelChanges( frmMain.tbl1, hWndaCols, baChanges )
.head 7 +  If nCols < 0
.head 8 -  Set s = "    MTblGetColSelChanges failed!"
.head 8 -  Set nIdxSub = SalListAdd( lbLog, s )
.head 7 +  Else
.head 8 -  Call SalListRedraw( lbLog, FALSE )
.head 8 -  Set n = 0
.head 8 +  While n < nCols
.head 9 -  Call MTblGetColumnTitle( hWndaCols[n], s )
.head 9 -  Set s = "    '" || s || "': " || VisStrChoose( baChanges[n], "TRUE", "FALSE" )
.head 9 -  Set nIdxSub =  SalListAdd( lbLog, s )
.head 9 -  Set n = n + 1
.head 8 -  Call SalListRedraw( lbLog, TRUE )
.head 6 +  If bMTM_RowSelChanged
.head 7 -  Set nRows = MTblGetRowSelChanges( frmMain.tbl1, naRows, baChanges )
.head 7 +  If nRows < 0
.head 8 -  Set s = "    MTblGetRowSelChanges failed!"

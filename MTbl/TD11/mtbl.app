.head 4 +  Actions
.head 5 -  ! Get focus
.head 5 -  Call SalTblQueryFocus( frmMain.tbl1, nRow, hWndCol )
.head 5 -  ! Set cells disabled
.head 5 -  Set nSel = SalListQueryMultiCount( lbCols )
.head 5 -  Call SalListGetMultiSelect( lbCols, naSel )
.head 5 -  Set hWndCol = hWndNULL
.head 5 +  While MTblFindNextCol( frmMain.tbl1, hWndCol, 0, 0 )
.head 6 -  Set bDisable = FALSE
.head 6 -  Set n = 0
.head 6 +  While n < nSel
.head 7 +  If lbCols.GetHandle( naSel[n] ) = hWndCol
.head 8 -  Set bDisable = TRUE
.head 8 -  Break
.head 7 -  Set n = n + 1
.head 6 +  If NOT MTblDisableCell( hWndCol, nRow, bDisable )
.head 7 -  Set bError = TRUE
.head 7 -  Break
.head 5 +  If bError
.head 6 -  Set sText = "Error while disabling/enabling cells."
.head 6 -  Call SalMessageBox( sText, "Disable Cells Error", MB_IconHand | MB_Ok )
.head 5 -  !
.head 5 -  Return NOT bError

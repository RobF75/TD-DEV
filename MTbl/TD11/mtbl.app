.head 9 -  Set pl.FontEnh = pl.FontEnh | FONT_EnhBold
.head 8 +  If colFontItalic
.head 9 -  Set frmMain.PP.Titles[n].FontEnh = frmMain.PP.Titles[n].FontEnh | FONT_EnhItalic
.head 8 +  If colFontUnderline
.head 9 -  Set pl.FontEnh = pl.FontEnh | FONT_EnhUnderline
.head 8 +  If colFontStrikeOut
.head 9 -  Set pl.FontEnh = pl.FontEnh | FONT_EnhStrikeOut

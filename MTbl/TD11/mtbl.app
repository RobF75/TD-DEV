.head 6 -  Set nIdx = VisArrayFindNumber( frmMain.wnaLang, tblLang.colNr )
.head 6 +  If nIdx < 0
.head 7 -  Call frmMain.wfAddLang( tblLang.colNr, tblLang.colName )
.head 6 +  Else
.head 7 -  Set frmMain.wsaLang[nIdx] = tblLang.colName
.head 6 -  !
.head 6 -  Call SalTblSetRowFlags( tblLang, n, ROW_New | ROW_Edited, FALSE )
.head 5 +  If bError
.head 6 -  Call SalMessageBox( "Language registration failed", "Register Language", MB_IconStop | MB_Ok )
.head 3 +  Function: wfUpdate

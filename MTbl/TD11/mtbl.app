.head 3 +  Function: wfDo
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Boolean: bOk
.head 5 -  Date/Time: dtStart
.head 5 -  Date/Time: dtStop
.head 5 -  Number: nFlags
.head 5 -  String: sText
.head 4 +  Actions
.head 5 -  ! Get flags
.head 5 +  If rbTopDown
.head 6 -  Set nFlags = MTST_TOPDOWN
.head 5 +  Else
.head 6 -  Set nFlags = MTST_BOTTOMUP
.head 5 -  ! Sort tree
.head 5 -  Call SalWaitCursor( TRUE )
.head 5 -  Set dtStart = SalDateCurrent( )
.head 5 -  Set bOk = MTblSortTree( frmMain.tbl1, nFlags )
.head 5 -  Set dtStop = SalDateCurrent( )
.head 5 -  Call SalWaitCursor( FALSE )
.head 5 -  !
.head 5 +  If bOk
.head 6 -  Set frmMain.wnSortTreeFlags = nFlags
.head 6 -  !
.head 6 -  Set sText = SalFmtFormatNumber( ( dtStop - dtStart ) * 86400, "#.##0,00" )
.head 6 -  Set sText = "Tree sorted in " || sText || " seconds."
.head 6 -  Call SalMessageBox( sText, "Tree sort time", MB_IconAsterisk | MB_Ok )
.head 5 +  Else
.head 6 -  Call SalMessageBox( "Sorting failed", "Sort Tree", MB_IconHand | MB_Ok )
.head 5 -  !
.head 5 -  Return bOk

.head 8 -  Set col2 = 1
.head 7 +  Else If npRow = 10 AND NOT tbSetNoOwnerdrawn
.head 8 -  Call MTblSetOwnerDrawnItem( col2, npRow, MTBL_ODI_CELL, TRUE )
.head 7 +  Else
.head 8 -  Set col2 = nRnd
.head 7 -  ! Column 3
.head 7 -  Set col3 = tdtPopulate + ( nRnd / 86400 )
.head 7 -  ! Column 4
.head 7 +  If npRow = 0
.head 8 -  Set col4 = "I'm a hyperlink"

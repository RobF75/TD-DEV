.head 4 +  Actions
.head 5 -  ! Initialize Excel export parameters
.head 5 -  Set ExcExp.Language = MTE_LNG_ENGLISH
.head 5 -  Set ExcExp.ExcelFlags = MTE_EXCEL_NEW_WORKSHEET
.head 5 -  Set ExcExp.ExpFlags = MTE_COL_HEADERS | MTE_COLORS | MTE_FONTS | MTE_GRID | MTE_SHOW_STATUS
.head 5 -  ! Initialize Open Office Caqlc export parameters
.head 5 -  Set OOCalcExp.Language = MTE_LNG_ENGLISH
.head 5 -  Set OOCalcExp.CalcFlags = MTE_EXCEL_NEW_WORKSHEET
.head 5 -  Set OOCalcExp.ExpFlags = MTE_COL_HEADERS | MTE_COLORS | MTE_FONTS | MTE_GRID | MTE_SHOW_STATUS
.head 5 -  ! Initialize HTML export parameters
.head 5 -  Set HTMLExp.File = "c:\\mtbl.htm"
.head 5 -  Set HTMLExp.HTMLFlags = MTE_HTML_OPEN_FILE
.head 5 -  Set HTMLExp.ExpFlags = MTE_COL_HEADERS | MTE_COLORS | MTE_FONTS | MTE_GRID
.head 5 -  ! Initialize print parameters
.head 5 -  Call PP.Init( )
.head 5 -  Set PP.PrinterName = MTblPrintGetDefPrinterName( )
.head 5 -  Set PP.Preview = TRUE
.head 5 -  ! Title lines
.head 5 -  Call pl.Init( )
.head 5 -  Set pl.Flags = MTPL_NO_IMAGE_SCALE
.head 5 -  Set pl.CenterImage = tbl1.tnImgOnk
.head 5 -  Call PP.AddTitle( pl )
.head 5 -  !
.head 5 -  Call pl.Init( )
.head 5 -  Set pl.Flags = MTPL_NO_TEXT_SCALE
.head 5 -  Set pl.CenterText = "M!Table Demo Application"
.head 5 -  Set pl.FontSizeMulti = 1.5
.head 5 -  Set pl.FontEnh = FONT_EnhBold
.head 5 -  Set pl.FontColor = COLOR_Black
.head 5 -  Call PP.AddTitle( pl )
.head 5 -  ! Some lines with positioned texts
.head 5 -  Call pl.Init( )
.head 5 -  Set pl.Flags = MTPL_NO_TEXT_SCALE
.head 5 -  Set pl.FontSizeMulti = 0.9
.head 5 -  !
.head 5 -  Call plpt.Init( )
.head 5 -  Set plpt.Text = "Author:"
.head 5 -  Set plpt.Left = 0
.head 5 -  Set plpt.Width = 10
.head 5 -  Call pl.AddPosText( plpt )
.head 5 -  !
.head 5 -  Call plpt.Init( )
.head 5 -  Set plpt.Text = "Michael Stoll"
.head 5 -  Set plpt.Left = 11
.head 5 -  Set plpt.Width = 0	! Dynamic
.head 5 -  Call pl.AddPosText( plpt )
.head 5 -  !
.head 5 -  Call PP.AddTitle( pl )
.head 5 -  !
.head 5 -  Call pl.Init( )
.head 5 -  Set pl.Flags = MTPL_NO_TEXT_SCALE
.head 5 -  Set pl.FontSizeMulti = 0.9
.head 5 -  !
.head 5 -  Call plpt.Init( )
.head 5 -  Set plpt.Text = "Version:"
.head 5 -  Set plpt.Left = 0
.head 5 -  Set plpt.Width = 10
.head 5 -  Call pl.AddPosText( plpt )
.head 5 -  !
.head 5 -  Call plpt.Init( )
.head 5 -  Set plpt.Text = MTblGetVersion( )
.head 5 -  Set plpt.Left = 11
.head 5 -  Set plpt.Width = 0	! Dynamic
.head 5 -  Call pl.AddPosText( plpt )
.head 5 -  !
.head 5 -  Call PP.AddTitle( pl )
.head 5 -  ! Blank title line
.head 5 -  Call pl.Init( )
.head 5 -  Set pl.CenterText = " "
.head 5 -  Set pl.FontSizeMulti = 1
.head 5 -  Call PP.AddTitle( pl )
.head 5 -  ! Some total lines
.head 5 -  Call pl.Init( )
.head 5 -  Set pl.CenterText = " "
.head 5 -  Set pl.FontSizeMulti = 1
.head 5 -  Call PP.AddTotal( pl )
.head 5 -  !
.head 5 -  Call pl.Init( )
.head 5 -  Set pl.CenterText = "*** End of report ***"
.head 5 -  Set pl.FontSizeMulti = 1
.head 5 -  Set pl.FontEnh = FONT_EnhBold
.head 5 -  Set pl.LeftImage = tbl1.tnImgOk
.head 5 -  Set pl.RightImage = tbl1.tnImgOk
.head 5 -  Call PP.AddTotal( pl )
.head 5 -  ! Page header
.head 5 -  Call pl.Init( )
.head 5 -  Set pl.Flags = MTPL_NO_TEXT_SCALE
.head 5 -  Set pl.RightText = SalFmtFormatDateTime( SalDateCurrent( ), "dd.MM.yyyy" )
.head 5 -  Set pl.FontSizeMulti = 1

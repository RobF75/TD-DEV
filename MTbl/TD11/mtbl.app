.head 4 +  Actions
.head 5 -  ! Fill column combo
.head 5 -  Call cmbCols.AddHandle( "<no>", hWndNULL )
.head 5 -  Call cmbCols.Populate( 0, 0 )
.head 5 -  ! Read settings
.head 5 -  Call wfReadSettings( )
.head 3 +  Function: wfDo
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Boolean: bOk
.head 4 +  Actions
.head 5 -  Set bOk = wfSaveSettings( )
.head 5 -  !
.head 5 +  If NOT bOk
.head 6 -  Call SalMessageBox( "SalTblDefineRowHeader failed.", "Error", MB_IconHand | MB_Ok )
.head 3 +  Function: wfReadSettings
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Window Handle: hWndCol
.head 4 +  Actions
.head 5 -  Call SalTblQueryRowHeader( frmMain.tbl1, dfsTitle, 2048, dfnWidth, wnFlags, hWndCol )
.head 5 -  ! Column
.head 5 -  Call cmbCols.SelectHandle( hWndCol )
.head 5 -  ! Options
.head 5 +  If wnFlags & TBL_RowHdr_Visible
.head 6 -  Set cbVisible = TRUE
.head 5 +  If wnFlags & TBL_RowHdr_Sizable
.head 6 -  Set cbSizable = TRUE
.head 5 +  If wnFlags & TBL_RowHdr_MarkEdits
.head 6 -  Set cbMarkEdits = TRUE
.head 5 +  If wnFlags & TBL_RowHdr_ShareColor
.head 6 -  Set cbShareColor = TRUE
.head 5 +  If wnFlags & TBL_RowHdr_AllowRowSizing
.head 6 -  Set cbAllowRowSizing = TRUE
.head 3 +  Function: wfSaveSettings
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Window Handle: hWndCol
.head 4 +  Actions
.head 5 -  ! Column
.head 5 -  Set hWndCol = cmbCols.GetSelectedHandle( )
.head 5 -  ! Options
.head 5 -  Call wfSetFlag( TBL_RowHdr_Visible, cbVisible )
.head 5 -  Call wfSetFlag( TBL_RowHdr_Sizable, cbSizable )
.head 5 -  Call wfSetFlag( TBL_RowHdr_MarkEdits, cbMarkEdits )
.head 5 -  Call wfSetFlag( TBL_RowHdr_ShareColor, cbShareColor )
.head 5 -  Call wfSetFlag( TBL_RowHdr_AllowRowSizing, cbAllowRowSizing )
.head 5 -  ! Set
.head 5 -  Return SalTblDefineRowHeader( frmMain.tbl1, dfsTitle, dfnWidth, wnFlags, hWndCol )
.head 3 +  Function: wfSetFlag
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: p_nFlag
.head 5 -  Boolean: p_bSet
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If p_bSet
.head 6 -  Set wnFlags = VisNumberBitSet( wnFlags, p_nFlag )
.head 5 +  Else
.head 6 -  Set wnFlags = VisNumberBitClear( wnFlags, p_nFlag )
.head 5 -  Return TRUE

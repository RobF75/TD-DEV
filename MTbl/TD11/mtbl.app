.head 3 +  Function: wfReadSettings
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: n
.head 5 -  Number: nPr
.head 5 -  String: saPrinters[*]
.head 4 +  Actions
.head 5 -  ! Printer
.head 5 -  Set n = 0
.head 5 -  Set nPr = MTblPrintGetPrinterNames( saPrinters )
.head 5 +  While n < nPr
.head 6 -  Call SalListAdd( cmbPrinter, saPrinters[n] )
.head 6 -  Set n = n + 1
.head 5 -  Call SalListSelectString( cmbPrinter, 0, frmMain.PP.PrinterName )
.head 5 -  ! Document Name
.head 5 -  Set dfDocName = frmMain.PP.DocName
.head 5 -  ! Language
.head 5 -  Call cmbLanguage.Populate( )
.head 5 -  Call cmbLanguage.SelectValue( frmMain.PP.Language )
.head 5 -  ! Rows to print
.head 5 +  If frmMain.PP.RowFlagsOn & ROW_Selected
.head 6 -  Set rbSelectedRows = TRUE
.head 5 -  ! Columns to print
.head 5 +  If frmMain.PP.ColFlagsOn & COL_Selected
.head 6 -  Set rbSelectedCols = TRUE
.head 5 -  ! Scale
.head 5 -  Set dfScale = frmMain.PP.Scale * 100
.head 5 -  ! Copies
.head 5 -  Set dfCopies = frmMain.PP.Copies
.head 5 -  ! Preview
.head 5 -  Set cbPreview = frmMain.PP.Preview
.head 5 -  ! Column headers
.head 5 -  Set cbColHeaders = frmMain.PP.ColHeaders
.head 5 -  ! Page Nr's
.head 5 -  Set cbPageNrs = frmMain.PP.PageNrs
.head 5 -  Call SalSendMsg( cbPageNrs, SAM_Click, 0, 0 )
.head 5 -  Set cbNoPageNrsScale = frmMain.PP.NoPageNrsScale
.head 5 -  ! Fit cell size
.head 5 -  Set cbFitCellSize = frmMain.PP.FitCellSize
.head 5 -  ! Spread columns
.head 5 -  Set cbSpreadCols = frmMain.PP.SpreadCols
.head 5 -  ! Orientation
.head 5 +  If frmMain.PP.Orientation = MTP_OR_PORTRAIT
.head 6 -  Set rbPortrait = TRUE
.head 5 +  Else If frmMain.PP.Orientation = MTP_OR_LANDSCAPE
.head 6 -  Set rbLandscape = TRUE
.head 5 -  ! Grid type
.head 5 +  If frmMain.PP.GridType = MTP_GT_TABLE
.head 6 -  Set rbTableGrid = TRUE
.head 5 +  Else If frmMain.PP.GridType = MTP_GT_STANDARD
.head 6 -  Set rdStandardGrid = TRUE
.head 5 +  Else If frmMain.PP.GridType = MTP_GT_STANDARD2
.head 6 -  Set rbStandard2Grid = TRUE
.head 5 +  Else If frmMain.PP.GridType = MTP_GT_STANDARD3
.head 6 -  Set rbStandard3Grid = TRUE
.head 5 +  Else If frmMain.PP.GridType = MTP_GT_STANDARD4
.head 6 -  Set rbStandard4Grid = TRUE
.head 5 +  Else If frmMain.PP.GridType = MTP_GT_NO
.head 6 -  Set rbNoGrid = TRUE
.head 5 -  ! Margins
.head 5 -  Set dfLeftMargin = frmMain.PP.LeftMargin
.head 5 -  Set dfRightMargin = frmMain.PP.RightMargin
.head 5 -  Set dfTopMargin = frmMain.PP.TopMargin
.head 5 -  Set dfBottomMargin = frmMain.PP.BottomMargin
.head 5 -  ! Preview window

.head 5 -  Set dfPrevWndHeight = frmMain.PP.PrevWndHeight
.head 5 -  Set cbPrevWndFullPage = frmMain.PP.PrevWndFullPage
.head 3 +  Function: wfSaveSettings
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: n
.head 4 +  Actions
.head 5 -  ! Printer
.head 5 -  Set frmMain.PP.PrinterName = cmbPrinter
.head 5 -  ! Document Name
.head 5 -  Set frmMain.PP.DocName = dfDocName
.head 5 -  ! Language
.head 5 -  Set n = cmbLanguage.GetSelectedValue( )
.head 5 -  Set frmMain.PP.Language = n
.head 5 -  ! Rows to print
.head 5 +  If rbSelectedRows
.head 6 -  Set frmMain.PP.RowFlagsOn = ROW_Selected
.head 5 +  Else
.head 6 -  Set frmMain.PP.RowFlagsOn = 0
.head 5 -  ! Columns to print
.head 5 +  If rbSelectedCols
.head 6 -  Set frmMain.PP.ColFlagsOn = COL_Selected
.head 5 +  Else
.head 6 -  Set frmMain.PP.ColFlagsOn = COL_Visible
.head 5 -  ! Scale
.head 5 -  Set frmMain.PP.Scale = dfScale / 100
.head 5 -  ! Copies
.head 5 -  Set frmMain.PP.Copies = dfCopies
.head 5 -  ! Preview
.head 5 -  Set frmMain.PP.Preview = cbPreview
.head 5 -  ! Column headers
.head 5 -  Set frmMain.PP.ColHeaders = cbColHeaders
.head 5 -  ! Page Nr's
.head 5 -  Set frmMain.PP.PageNrs = cbPageNrs
.head 5 -  Set frmMain.PP.NoPageNrsScale = cbNoPageNrsScale
.head 5 -  ! Fit cell size
.head 5 -  Set frmMain.PP.FitCellSize = cbFitCellSize
.head 5 -  ! Spread columns
.head 5 -  Set frmMain.PP.SpreadCols = cbSpreadCols
.head 5 -  ! Orientation
.head 5 +  If rbPortrait
.head 6 -  Set frmMain.PP.Orientation = MTP_OR_PORTRAIT
.head 5 +  Else If rbLandscape
.head 6 -  Set frmMain.PP.Orientation = MTP_OR_LANDSCAPE
.head 5 -  ! Grid type
.head 5 +  If rbTableGrid
.head 6 -  Set frmMain.PP.GridType = MTP_GT_TABLE
.head 5 +  Else If rdStandardGrid
.head 6 -  Set frmMain.PP.GridType = MTP_GT_STANDARD
.head 5 +  Else If rbStandard2Grid
.head 6 -  Set frmMain.PP.GridType = MTP_GT_STANDARD2
.head 5 +  Else If rbStandard3Grid
.head 6 -  Set frmMain.PP.GridType = MTP_GT_STANDARD3
.head 5 +  Else If rbStandard4Grid
.head 6 -  Set frmMain.PP.GridType = MTP_GT_STANDARD4
.head 5 +  Else If rbNoGrid
.head 6 -  Set frmMain.PP.GridType = MTP_GT_NO
.head 5 -  ! Margins
.head 5 -  Set frmMain.PP.LeftMargin = dfLeftMargin
.head 5 -  Set frmMain.PP.RightMargin = dfRightMargin
.head 5 -  Set frmMain.PP.TopMargin = dfTopMargin
.head 5 -  Set frmMain.PP.BottomMargin = dfBottomMargin
.head 5 -  ! Preview window
.head 5 -  Set frmMain.PP.PrevWndTitle = dfPrevWndTitle
.head 5 -  Set frmMain.PP.PrevWndState = SalListQuerySelection( cmbPrevWndState )
.head 5 -  Set frmMain.PP.PrevWndLeft = dfPrevWndLeft
.head 5 -  Set frmMain.PP.PrevWndTop = dfPrevWndTop
.head 5 -  Set frmMain.PP.PrevWndWidth = dfPrevWndWidth
.head 5 -  Set frmMain.PP.PrevWndHeight = dfPrevWndHeight
.head 5 -  Set frmMain.PP.PrevWndFullPage = cbPrevWndFullPage

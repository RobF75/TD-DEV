.head 4 +  Functions
.head 5 +  Function: tfOnBtnClick
.head 6 -  Description:
.head 6 -  Returns
.head 6 +  Parameters
.head 7 -  Number: npwP
.head 7 -  Number: nplP
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  String: sMsg
.head 7 -  Window Handle: hWndCol
.head 7 -  !
.head 7 -  Number: nx
.head 7 -  Number: ny
.head 7 -  Number: nl
.head 7 -  Number: nt
.head 7 -  Number: nr
.head 7 -  Number: nb
.head 7 -  Number: nm
.head 7 -  String: sClassName
.head 7 -  Window Handle: hWnd
.head 6 +  Actions
.head 7 +  If npwP
.head 8 -  Set hWndCol = SalNumberToWindowHandle( npwP )
.head 8 -  Call MTblGetColumnTitle( hWndCol, sMsg )
.head 8 -  Set sMsg = "'" || sMsg || "'"
.head 8 +  If nplP != TBL_Error
.head 9 -  Set sMsg = "Button click in column " || sMsg || ", row #" || SalNumberToStrX( nplP, 0 ) || "."
.head 8 +  Else
.head 9 -  Set sMsg = "Button click in column header " || sMsg || "."
.head 8 -  Call SalMessageBox( sMsg, "M!Table Button", MB_IconAsterisk )
.head 8 -  ! Test
.head 8 -  ! Call GetCursorPos( nx, ny )
.head 8 -  ! Set hWnd = WindowFromPoint( nx, ny )
.head 8 +  ! If hWnd
.head 9 -  Call SalStrSetBufferLength( sClassName, 256 )
.head 9 -  Call GetClassNameA( hWnd, sClassName, 255 )
.head 9 +  If sClassName = "MTblBtn"
.head 10 +  If GetWindowRect( hWnd, nl, nt, nr, nb )
.head 11 -  Set nm = nl + SalNumberTruncate( ( nr - nl ) / 2, 10, 0 )
.head 11 +  If nx <= nm
.head 12 -  Set sMsg = "Left button part clicked"
.head 11 +  Else 
.head 12 -  Set sMsg = "Right button part clicked"
.head 11 -  Call SalMessageBox( sMsg, "M!Table Button", MB_IconAsterisk )
.head 5 +  Function: tfOnColPosChanged
.head 6 -  Description:
.head 6 -  Returns
.head 6 -  Parameters
.head 6 -  Static Variables
.head 6 -  Local variables
.head 6 +  Actions
.head 7 -  Call tfUpdateDlgs( )
.head 5 +  Function: tfOnColSelChanged
.head 6 -  Description:
.head 6 -  Returns
.head 6 -  Parameters
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  Boolean: baChanges[*]
.head 7 -  Number: n
.head 7 -  Number: nCount
.head 7 -  Window Handle: hWndaCols[*]
.head 6 +  Actions
.head 7 -  ! Set nCount = MTblGetColSelChanges( hWndForm, hWndaCols, baChanges )
.head 7 +  ! While n < nCount
.head 8 -  Call MTblSetColumnHdrFont( hWndaCols[n], MTBL_FONT_UNDEF_NAME, MTBL_FONT_UNDEF_SIZE, VisNumberChoose( baChanges[n], FONT_EnhUnderline | FONT_EnhBold, FONT_EnhUnderline ), MTSF_REDRAW )
.head 8 -  Set n = n + 1
.head 5 +  Function: tfOnContextMenu
.head 6 -  Description:
.head 6 -  Returns
.head 6 +  Parameters
.head 7 -  Number: p_wParam
.head 7 -  Number: p_lParam
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  Number: nFlags
.head 7 -  Number: nFocusRow
.head 7 -  Number: nMergeRow
.head 7 -  Number: nMFlags
.head 7 -  Number: nRow
.head 7 -  Number: nX
.head 7 -  Number: nY
.head 7 -  String: sMenu
.head 7 -  Window Handle: hWndCol
.head 7 -  Window Handle: hWndMergeCol
.head 7 -  Window Handle: hWndFocusCol
.head 6 +  Actions
.head 7 -  Set nX = p_wParam
.head 7 -  Set nY = p_lParam
.head 7 -  Call ScreenToClient( hWndForm, nX, nY )
.head 7 -  !
.head 7 +  If MTblObjFromPoint( hWndForm, nX, nY, nRow, hWndCol, nFlags, nMFlags )
.head 8 -  ! Cell?
.head 8 +  If nRow != TBL_Error AND hWndCol
.head 9 -  Call SalTblQueryFocus( hWndForm, nFocusRow, hWndFocusCol )
.head 9 +  If hWndCol != hWndFocusCol OR nRow != nFocusRow
.head 10 +  If nMFlags & MTOFP_OVERMERGEDCELL AND MTblGetMergeCell( hWndCol, nRow, hWndMergeCol, nMergeRow )
.head 11 -  Set whWndMenuCol = hWndMergeCol
.head 11 -  Set wnMenuRow = nMergeRow
.head 10 +  Else
.head 11 -  Set whWndMenuCol = hWndCol
.head 11 -  Set wnMenuRow = nRow
.head 10 -  Call wMenuItem.DefineAsCell( whWndMenuCol, wnMenuRow )
.head 10 -  Set sMenu = "menCells"
.head 10 +  If tfIsCellModeActive( )
.head 11 -  Call MTblSetFocusCell( hWndForm, wnMenuRow, whWndMenuCol, 0 )
.head 10 +  Else
.head 11 -  Call SalTblSetFocusRow( hWndForm, wnMenuRow )
.head 10 -  Call SalTblSetContext( hWndForm, wnMenuRow )
.head 8 -  ! Row?
.head 8 +  Else If nRow != TBL_Error AND NOT hWndCol AND ( nFlags & TBL_XOverRowHeader )
.head 9 -  Call SalTblSetFocusRow( hWndForm, nRow )
.head 9 -  Call SalTblSetContext( hWndForm, nRow )
.head 9 -  Set wnMenuRow = nRow
.head 9 -  Call wMenuItem.DefineAsRowHdr( hWndForm, wnMenuRow )
.head 9 -  Call wMenuItem2.DefineAsRow( hWndForm, wnMenuRow )
.head 9 -  Set sMenu = "menRow"
.head 8 -  ! Column Header?
.head 8 +  Else If nRow = TBL_Error AND hWndCol AND ( nFlags & TBL_YOverColumnHeader ) AND NOT ( nMFlags & MTOFP_OVERCOLHDRGRP )
.head 9 -  Set whWndMenuCol = hWndCol
.head 9 -  Set wnMenuRow = TBL_Error
.head 9 -  Call wMenuItem.DefineAsColHdr( whWndMenuCol )
.head 9 -  Call wMenuItem2.DefineAsCol( whWndMenuCol )
.head 9 -  Set sMenu = "menColHdr"
.head 8 -  ! Column Header Free?
.head 8 +  Else If nRow = TBL_Error AND NOT hWndCol AND ( nFlags & TBL_YOverColumnHeader ) AND NOT ( nFlags & TBL_XOverRowHeader )
.head 9 -  Set whWndMenuCol = hWndNULL
.head 9 -  Set wnMenuRow = TBL_Error
.head 9 -  Set sMenu = "menColHdrFree"
.head 8 -  ! Column Header Group?
.head 8 +  Else If nRow = TBL_Error AND hWndCol AND ( nFlags & TBL_YOverColumnHeader ) AND ( nMFlags & MTOFP_OVERCOLHDRGRP )
.head 9 -  Set whWndMenuCol = hWndCol
.head 9 -  Set wnMenuRow = TBL_Error
.head 9 -  Call wMenuItem.DefineAsColHdrGrp( hWndForm, MTblGetColHdrGrp( whWndMenuCol ) )
.head 9 -  Set sMenu = "menColHdrGrp"
.head 8 -  ! Corner?
.head 8 +  Else If nRow = TBL_Error AND NOT hWndCol AND ( nFlags & TBL_XOverRowHeader ) AND ( nFlags & TBL_YOverColumnHeader )
.head 9 -  Set whWndMenuCol = hWndNULL
.head 9 -  Set wnMenuRow = TBL_Error
.head 9 -  Call wMenuItem.DefineAsCorner( hWndForm )
.head 9 -  Set sMenu = "menCorner"
.head 8 -  ! Show menu
.head 8 +  If sMenu
.head 9 -  Call SalTrackPopupMenu( frmMain, sMenu, TPM_CursorX | TPM_CursorY, 0, 0 )

.head 5 -  Window Handle: hWndCol
.head 4 +  Actions
.head 5 -  ! Get font data
.head 5 +  If NOT cbUndefName
.head 6 -  Set sName = cmbName
.head 6 +  If NOT sName
.head 7 -  Call SalMessageBox( "Please enter a name.", "Font", MB_IconAsterisk | MB_Ok )
.head 7 -  Return FALSE
.head 5 +  Else
.head 6 -  Set sName = MTBL_FONT_UNDEF_NAME
.head 5 -  !
.head 5 +  If NOT cbUndefSize
.head 6 -  Set nSize = SalStrToNumber( cmbSize )
.head 6 +  If nSize < 0
.head 7 -  Call SalMessageBox( "Please enter a size >= 0.", "Font", MB_IconAsterisk | MB_Ok )
.head 7 -  Return FALSE
.head 5 +  Else
.head 6 -  Set nSize = MTBL_FONT_UNDEF_SIZE
.head 5 -  !
.head 5 +  If NOT cbUndefEnh
.head 6 +  If cbBold
.head 7 -  Set nEnh = nEnh | FONT_EnhBold
.head 6 +  If cbItalic
.head 7 -  Set nEnh = nEnh | FONT_EnhItalic
.head 6 +  If cbUnderline
.head 7 -  Set nEnh = nEnh | FONT_EnhUnderline
.head 6 +  If cbStrikeOut
.head 7 -  Set nEnh = nEnh | FONT_EnhStrikeOut
.head 5 +  Else
.head 6 -  Set nEnh = MTBL_FONT_UNDEF_ENH
.head 5 -  !
.head 5 -  Set p_Font.Name = sName
.head 5 -  Set p_Font.Size = nSize
.head 5 -  Set p_Font.Enh = nEnh
.head 5 -  !
.head 5 -  Call SalEndDialog( hWndForm, 1 )

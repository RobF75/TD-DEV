.head 7 +  If npwP
.head 8 -  Set hWndCol = SalNumberToWindowHandle( npwP )
.head 8 -  Call MTblGetColumnTitle( hWndCol, sMsg )
.head 8 -  Set sMsg = "'" || sMsg || "'"
.head 8 -  Set sMsg = "Hyperlink click in column " || sMsg || ", row #" || SalNumberToStrX( nplP, 0 ) || "!"
.head 8 -  Call SalMessageBox( sMsg, "M!Table Hyperlink", MB_IconAsterisk )
.head 5 +  Function: tfOnLoadChildRows
.head 6 -  Description:
.head 6 -  Returns
.head 6 +  Parameters
.head 7 -  Number: npRow
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  Number: n
.head 7 -  Number: nInsRows
.head 7 -  Number: nParentRow
.head 7 -  Number: nRow
.head 7 -  Number: nRowLevel
.head 6 +  Actions
.head 7 -  Set nParentRow = npRow
.head 7 -  Set nInsRows = 5
.head 7 -  Set tbSetNoOwnerdrawn = TRUE
.head 7 -  Set tbSetNoCellType = TRUE
.head 7 +  While n < nInsRows
.head 8 -  Set nRow = MTblInsertChildRow( hWndForm, nParentRow, MTICR_REDRAW )
.head 8 -  !
.head 8 +  If nRow != TBL_Error
.head 9 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_New, FALSE )
.head 9 -  Set nRowLevel = MTblGetRowLevel( hWndForm, nRow )
.head 9 +  If nRowLevel < 3
.head 10 -  Call MTblSetRowFlags( hWndForm, nRow, MTBL_ROW_CANEXPAND, TRUE, 0 )
.head 9 -  !
.head 9 -  Call tfSetRow( nRow )
.head 8 +  Else
.head 9 -  Break
.head 8 -  !
.head 8 -  Set n = n + 1
.head 7 -  Set tbSetNoOwnerdrawn = FALSE
.head 7 -  Set tbSetNoCellType = FALSE
.head 7 -  Return 0
.head 5 +  Function: tfOnFetchRowDone
.head 6 -  Description:
.head 6 -  Returns
.head 6 +  Parameters
.head 7 -  Number: npRow
.head 6 -  Static Variables
.head 6 -  Local variables
.head 6 +  Actions
.head 7 +  If tnPopMode < POP_DB_FILLALL
.head 8 -  Call tfSetRow( npRow )
.head 8 +  If SalNumberMod( npRow, 2 ) = 0
.head 9 -  Call MTblSetRowFlags( hWndForm, npRow, MTBL_ROW_CANEXPAND, TRUE, 0 )
.head 7 +  Else
.head 8 -  Call MTblSetRowHeight( hWndForm, npRow, 50, MTSRH_REDRAW )
.head 8 -  Call SalTblSetContext( hWndForm, npRow )
.head 8 -  Set col1 = col1 || " (#" || SalNumberToStrX( npRow, 0 ) || ")"
.head 8 -  Call tfSetDynaCols( )

.head 6 -  Set whl.BackColor = MTBL_COLOR_UNDEF
.head 6 -  Set whl.TextColor = MTBL_COLOR_UNDEF
.head 6 -  Set whl.FontEnh = MTBL_FONT_UNDEF_ENH
.head 6 -  Set whl.Image = 0
.head 6 -  Set whl.ImageExp = 0
.head 5 -  !
.head 5 -  Call wfShowBackColor( )
.head 5 -  Call wfShowTextColor( )
.head 5 -  !
.head 5 -  Set bUndef = ( whl.FontEnh = MTBL_FONT_UNDEF_ENH )
.head 5 -  Set cbUndefEnh = bUndef
.head 5 -  Call SalSendMsg( cbUndefEnh, SAM_Click, 0, 0 )
.head 5 +  If NOT bUndef
.head 6 -  Set cbBold = whl.FontEnh & FONT_EnhBold
.head 6 -  Set cbItalic = whl.FontEnh & FONT_EnhItalic
.head 6 -  Set cbUnderline = whl.FontEnh & FONT_EnhUnderline
.head 6 -  Set cbStrikeOut = whl.FontEnh & FONT_EnhStrikeOut
.head 5 -  !

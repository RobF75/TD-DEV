.head 5 -  Number: naFontSizes[*]
.head 5 -  String: sOldVal
.head 4 +  Actions
.head 5 -  Set sOldVal = cmbSize
.head 5 -  Call SalListClear( cmbSize )
.head 5 -  !
.head 5 +  If p_sFontName
.head 6 -  Set nFontSizes = MTblEnumFontSizes( p_sFontName, naFontSizes )

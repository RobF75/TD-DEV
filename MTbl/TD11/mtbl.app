.head 4 +  Actions
.head 5 +  If MTblQueryCornerImageFlags( frmMain.tbl1, MTSI_ALIGN_TILE )
.head 6 -  Set nFlags = nFlags | MTSI_ALIGN_TILE
.head 5 -  !
.head 5 +  If MTblQueryCornerImageFlags( frmMain.tbl1, MTSI_ALIGN_HCENTER )
.head 6 -  Set nFlags = nFlags | MTSI_ALIGN_HCENTER
.head 5 +  If MTblQueryCornerImageFlags( frmMain.tbl1, MTSI_ALIGN_RIGHT )
.head 6 -  Set nFlags = nFlags | MTSI_ALIGN_RIGHT
.head 5 -  !
.head 5 +  If MTblQueryCornerImageFlags( frmMain.tbl1, MTSI_ALIGN_TOP )
.head 6 -  Set nFlags = nFlags | MTSI_ALIGN_TOP
.head 5 +  If MTblQueryCornerImageFlags( frmMain.tbl1, MTSI_ALIGN_VCENTER )
.head 6 -  Set nFlags = nFlags | MTSI_ALIGN_VCENTER
.head 5 +  If MTblQueryCornerImageFlags( frmMain.tbl1, MTSI_ALIGN_BOTTOM )
.head 6 -  Set nFlags = nFlags | MTSI_ALIGN_BOTTOM
.head 5 -  !
.head 5 +  If MTblQueryCornerImageFlags( frmMain.tbl1, MTSI_NOLEAD_LEFT )
.head 6 -  Set nFlags = nFlags | MTSI_NOLEAD_LEFT
.head 5 +  If MTblQueryCornerImageFlags( frmMain.tbl1, MTSI_NOLEAD_TOP )
.head 6 -  Set nFlags = nFlags | MTSI_NOLEAD_TOP
.head 5 -  !
.head 5 -  Return nFlags

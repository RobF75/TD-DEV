.head 4 +  Actions
.head 5 -  Set hWndCol = cmbCols.GetSelectedHandle( )
.head 5 -  Set nType = SalListQuerySelection( cmbType )
.head 5 +  If nType = COL_CellType_CheckBox
.head 6 +  If cbCheckBoxIgnoreCase
.head 7 -  Set nFlags = nFlags | COL_CheckBox_IgnoreCase
.head 5 +  If nType = COL_CellType_DropDownList
.head 6 +  If cbDropDownListSorted
.head 7 -  Set nFlags = nFlags | COL_DropDownList_Sorted
.head 6 +  If cbDropDownListVScroll
.head 7 -  Set nFlags = nFlags | COL_DropDownList_VScroll
.head 6 +  If cbDropDownListAuto
.head 7 -  Set nFlags = nFlags | COL_DropDownList_Auto
.head 6 +  If cbDropDownListEditable
.head 7 -  Set nFlags = nFlags | COL_DropDownList_Editable
.head 5 -  !
.head 5 +  If NOT MTblDefineCellType( hWndCol, w_nRow, nType, nFlags, dfnLines, dfsCheckedVal, dfsUnCheckedVal )
.head 6 -  Call SalMessageBox( "Setting cell type failed.", "Cell type", MB_IconHand | MB_Ok )
.head 6 -  Return FALSE
.head 5 -  Call wfUpdate( )
.head 5 -  !
.head 5 -  Return TRUE

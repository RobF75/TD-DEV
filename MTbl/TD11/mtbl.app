.head 5 -  Set dfLastMerged = sLastMergedCol
.head 5 +  If nLastMergedRow = TBL_Error
.head 6 -  Set nLastMergedRow = NUMBER_Null
.head 5 -  Set dfLastMergedRow = nLastMergedRow
.head 5 -  ! Get merge cell
.head 5 -  Call MTblGetMergeCell( cmbCols.GetSelectedHandle( ), w_nRow, hWndMergeCol, nMergeRow )
.head 5 +  If hWndMergeCol
.head 6 -  Call MTblGetColumnTitle( hWndMergeCol, sMergeCol )
.head 5 -  Set dfMerge = sMergeCol
.head 5 +  If nMergeRow = TBL_Error
.head 6 -  Set nMergeRow = NUMBER_Null
.head 5 -  Set dfMergeRow = nMergeRow

.head 6 +  Actions
.head 7 +  If SalMessageBox( "Would you like to add a row?", "SAM_EndCellTab", MB_IconQuestion | MB_YesNo ) = IDYES
.head 8 -  Set nRow = SalTblInsertRow( hWndForm, npRow + 1 )
.head 8 +  If nRow != TBL_Error
.head 9 -  Call SalTblSetFocusCell( hWndForm, nRow, col2, 0, -1 )
.head 9 -  Call tfUpdateDlgs( )
.head 9 -  Return TRUE

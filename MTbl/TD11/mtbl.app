.head 4 +  Actions
.head 5 -  ! Set title
.head 5 -  Call SalSetWindowText( hWndForm, "Cell merge for row " || SalNumberToStrX( w_nRow, 0 ) )
.head 5 -  ! Get merge
.head 5 -  Call MTblGetCellMergeEx( cmbCols.GetSelectedHandle( ), w_nRow, dfMerged, dfMergedRows )
.head 5 -  ! Get last merged cell
.head 5 -  Call MTblGetLastMergedCell( cmbCols.GetSelectedHandle( ), w_nRow, hWndLastMergedCol, nLastMergedRow )
.head 5 +  If hWndLastMergedCol

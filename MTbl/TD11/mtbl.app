.head 4 +  Actions
.head 5 -  ! Fill column combo
.head 5 -  Call cmbCols.Populate( 0, 0 )
.head 5 -  ! Select column
.head 5 +  If p_whWndCol
.head 6 -  Call cmbCols.SelectHandle( p_whWndCol )
.head 5 +  Else
.head 6 -  Call SalListSetSelect( cmbCols, 0 )
.head 3 +  Function: wfGet
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nBrush
.head 5 -  Number: nFlags
.head 5 -  Number: nDC
.head 5 -  Number: nRet
.head 5 -  Window Handle: hWndCol
.head 4 +  Actions
.head 5 -  Call SalClearField( dfLeft )
.head 5 -  Call SalClearField( dfTop )
.head 5 -  Call SalClearField( dfRight )
.head 5 -  Call SalClearField( dfBottom )
.head 5 -  !
.head 5 -  Set hWndCol = cmbCols.GetSelectedHandle( )
.head 5 -  !
.head 5 +  If cbVisiblePart
.head 6 -  Set nFlags = nFlags | MTGR_VISIBLE_PART
.head 5 +  If cbExclColHdrGrp
.head 6 -  Set nFlags = nFlags | MTGR_EXCLUDE_COLHDRGRP
.head 5 -  !
.head 5 -  Set nRet = MTblGetColHdrRectEx( hWndCol, dfLeft, dfTop, dfRight, dfBottom, nFlags )
.head 5 -  Set dfsRet = wfRetText( nRet )
.head 5 +  If nRet = MTGR_RET_ERROR
.head 6 -  Call SalMessageBox( "Error getting column header rect." , "Get ColHdr Rect", MB_IconStop | MB_Ok )
.head 6 -  Return FALSE
.head 5 +  Else If nRet = MTGR_RET_INVISIBLE AND cbVisiblePart
.head 6 -  Call SalMessageBox( "No part of the column header visible." , "Get ColHdr Rect Info", MB_IconAsterisk | MB_Ok )
.head 6 -  Return FALSE
.head 5 -  !
.head 5 +  If cbFill AND nRet != MTGR_RET_INVISIBLE
.head 6 -  Set nDC = GetDC( frmMain.tbl1 )
.head 6 +  If nDC
.head 7 -  Set nBrush = CreateSolidBrush( COLOR_Blue )
.head 7 +  If nBrush
.head 8 -  Call FillRect( nDC, dfLeft, dfTop, dfRight + 1, dfBottom + 1, nBrush )
.head 8 -  Call DeleteObject( nBrush )
.head 7 -  Call ReleaseDC( frmMain.tbl1, nDC )
.head 3 +  Function: wfRetText
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  String:
.head 4 +  Parameters

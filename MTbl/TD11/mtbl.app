.head 7 +  Else
.head 8 -  Call SalListRedraw( lbLog, FALSE )
.head 8 -  Set n = 0
.head 8 +  While n < nRows
.head 9 -  Set s = "    Row #" || SalNumberToStrX( naRows[n], 0 ) || ": " || VisStrChoose( baChanges[n], "TRUE", "FALSE" )
.head 9 -  Set nIdxSub =  SalListAdd( lbLog, s )
.head 9 -  Set n = n + 1
.head 8 -  Call SalListRedraw( lbLog, TRUE )
.head 6 -  !
.head 6 -  Set wnMsgNr = wnMsgNr + 1
.head 6 -  Call SalListSetSelect( lbLog, SalNumberMax( nIdx, nIdxSub ) )
.head 6 -  !
.head 6 -  Return TRUE

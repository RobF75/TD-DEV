.head 5 -  Number: nColFlagsOff
.head 4 +  Actions
.head 5 -  Call SalWaitCursor( TRUE )
.head 5 +  If rbSelectedRows
.head 6 -  Set nRowFlagsOn = ROW_Selected
.head 5 +  If rbSelectedCols
.head 6 -  Set nColFlagsOn = COL_Selected
.head 5 +  If cbHeaders
.head 6 -  Set bOk = MTblCopyRowsAndHeaders( frmMain.tbl1, nRowFlagsOn, nRowFlagsOff, nColFlagsOn, nColFlagsOff )
.head 5 +  Else
.head 6 -  Set bOk = MTblCopyRows( frmMain.tbl1, nRowFlagsOn, nRowFlagsOff, nColFlagsOn, nColFlagsOff )
.head 5 -  Call SalWaitCursor( FALSE )
.head 5 +  If NOT bOk
.head 6 -  Call SalMessageBox( "Copying rows failed.", "Error", MB_IconStop | MB_Ok )

.head 4 +  Actions
.head 5 -  Call SalWaitCursor( TRUE )
.head 5 -  Call wfSaveSettings( )
.head 5 -  Set nRet = MTblPrint( frmMain.tbl1, frmMain.PP )
.head 5 -  Call SalWaitCursor( FALSE )
.head 5 +  If nRet < 1
.head 6 +  Select Case nRet
.head 7 +  Case MTP_ERR_MARGINS_TOO_BIG
.head 8 -  Set sText = "Margins too big."
.head 8 -  Break
.head 7 +  Case MTP_ERR_NO_COLS_TO_PRINT
.head 8 -  Set sText = "No columns to print."
.head 8 -  Break
.head 7 +  Case MTP_ERR_NO_PRINTER
.head 8 -  Set sText = "No printer installed."
.head 8 -  Break
.head 7 +  Case MTP_ERR_INVALID_PRINTER
.head 8 -  Set sText = "Invalid printer name."
.head 8 -  Break
.head 7 +  Case MTP_ERR_INITIALIZE
.head 8 -  Set sText = "Initialization error."
.head 8 -  Break
.head 7 +  Case MTP_ERR_NOT_SUBCLASSED
.head 8 -  Set sText = "Table isn't subclassed."
.head 8 -  Break
.head 7 +  Case MTP_ERR_INVALID_LANG
.head 8 -  Set sText = "Invalid language."
.head 8 -  Break
.head 7 +  Default
.head 8 -  Set sText = "Printing failed."
.head 8 -  Break
.head 6 -  Call SalMessageBox( sText, "Printing error", MB_IconHand | MB_Ok )

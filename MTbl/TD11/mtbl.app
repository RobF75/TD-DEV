.head 5 -  !
.head 5 -  Set whl.FontEnh = 0
.head 5 +  If NOT cbUndefEnh
.head 6 +  If cbBold
.head 7 -  Set whl.FontEnh = whl.FontEnh | FONT_EnhBold
.head 6 +  If cbItalic
.head 7 -  Set whl.FontEnh = whl.FontEnh | FONT_EnhItalic
.head 6 +  If cbUnderline
.head 7 -  Set whl.FontEnh = whl.FontEnh | FONT_EnhUnderline
.head 6 +  If cbStrikeOut
.head 7 -  Set whl.FontEnh = whl.FontEnh | FONT_EnhStrikeOut
.head 5 +  Else
.head 6 -  Set whl.FontEnh = MTBL_FONT_UNDEF_ENH
.head 5 -  !
.head 5 -  Set whl.Image = ccImgNormal.GetImage( )
.head 5 -  Set whl.ImageExp = ccImgExp.GetImage( )
.head 5 -  !
.head 5 +  If NOT MTblDefineHighlighting( frmMain.tbl1, nItem, nPart, whl, MTDHL_REDRAW )

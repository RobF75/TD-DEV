.head 3 +  Function: wfSwapRows
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: n
.head 5 -  Number: nRow
.head 5 -  Number: naRows[*]
.head 4 +  Actions
.head 5 -  Set nRow = TBL_MinRow
.head 5 +  While SalTblFindNextRow( tbl1, nRow, ROW_Selected, ROW_Hidden )
.head 6 -  Set naRows[n] = nRow
.head 6 -  Set n = n + 1
.head 6 +  If n > 2
.head 7 -  Break
.head 5 +  If n != 2
.head 6 -  Call SalMessageBox( "Please select exactly 2 rows you want to swap.", "Swap Rows", MB_IconAsterisk | MB_Ok )
.head 6 -  Return FALSE
.head 5 +  If naRows[0] < 0 OR naRows[1] < 0
.head 6 -  Call SalMessageBox( "Split Rows are not supported.", "Swap Rows", MB_IconAsterisk | MB_Ok )
.head 6 -  Return FALSE
.head 5 +  If NOT MTblSwapRows( tbl1, naRows[0], naRows[1], MTSR_REDRAW )
.head 6 -  Call SalMessageBox( "Swap Rows failed.", "Swap Rows", MB_IconHand | MB_Ok )
.head 6 -  Return FALSE
.head 5 -  Call tbl1.tfUpdateDlgs( )
.head 5 -  Return TRUE

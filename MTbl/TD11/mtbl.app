.head 8 -  ! Set font of the property cell
.head 8 -  Call MTblSetCellFont( colProp, p_nRow, MTBL_FONT_UNDEF_NAME, MTBL_FONT_UNDEF_SIZE, FONT_EnhBold, MTSF_REDRAW )
.head 7 -  ! Property?

.head 8 -  Set col1 = "I'm a merged cell"
.head 7 +  Else
.head 8 -  Set col1 = sText
.head 7 -  ! Column 2
.head 7 +  If npRow = 3 AND NOT tbSetNoCellType
.head 8 -  Set sCheckedVal = "1"
.head 8 -  Set sUncheckedVal = "0"

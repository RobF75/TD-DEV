.head 4 +  Actions
.head 5 -  ! Font name
.head 5 -  Set bUndef = ( p_sName = MTBL_FONT_UNDEF_NAME )
.head 5 -  Set cbUndefName = bUndef
.head 5 -  Call SalSendMsg( cbUndefName, SAM_Click, 0, 0 )
.head 5 +  If NOT bUndef
.head 6 -  Set cmbName = p_sName
.head 5 -  ! Font size
.head 5 -  Set bUndef = ( p_nSize = MTBL_FONT_UNDEF_SIZE )
.head 5 -  Set cbUndefSize = bUndef
.head 5 -  Call SalSendMsg( cbUndefSize, SAM_Click, 0, 0 )
.head 5 +  If NOT bUndef
.head 6 -  Set cmbSize = SalNumberToStrX( p_nSize, 0 )
.head 5 -  ! Font enhancements
.head 5 -  Set bUndef = ( p_nEnh = MTBL_FONT_UNDEF_ENH )
.head 5 -  Set cbUndefEnh = bUndef
.head 5 -  Call SalSendMsg( cbUndefEnh, SAM_Click, 0, 0 )
.head 5 +  If NOT bUndef
.head 6 -  Set cbBold = p_nEnh & FONT_EnhBold
.head 6 -  Set cbItalic = p_nEnh & FONT_EnhItalic
.head 6 -  Set cbUnderline = p_nEnh & FONT_EnhUnderline
.head 6 -  Set cbStrikeOut = p_nEnh & FONT_EnhStrikeOut

.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  : hili
.head 8 -  Class: fcMTblHiLiDef
.head 7 -  : item
.head 8 -  Class: fcMTblItem
.head 7 -  : odi
.head 8 -  Class: fcMTblODI
.head 7 -  Number: nBackColor
.head 7 -  Number: nBrush
.head 7 -  Number: nClipLeft
.head 7 -  Number: nClipTop
.head 7 -  Number: nClipRight
.head 7 -  Number: nClipBottom
.head 7 -  Number: nColor
.head 7 -  Number: nFont
.head 7 -  Number: nFontEnh
.head 7 -  Number: nFontSize
.head 7 -  Number: nHt
.head 7 -  Number: nImage
.head 7 -  Number: nImageCopy
.head 7 -  Number: nImgHt
.head 7 -  Number: nImgLeft
.head 7 -  Number: nImgWid
.head 7 -  Number: nLeft
.head 7 -  Number: nOldBkMode
.head 7 -  Number: nOldBrush
.head 7 -  Number: nOldFont
.head 7 -  Number: nOldPen
.head 7 -  Number: nOldTextColor
.head 7 -  Number: nOldX
.head 7 -  Number: nOldY
.head 7 -  Number: nPen
.head 7 -  Number: nRectLeft
.head 7 -  Number: nSelBackColor
.head 7 -  Number: nSelTextColor
.head 7 -  Number: nSize
.head 7 -  Number: nWid
.head 7 -  String: sFontName

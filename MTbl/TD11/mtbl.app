.head 9 -  Call MTblSetColumnTitle( col4, "Employee ID" )
.head 9 -  Call MTblSetColumnTitle( col5, "Paid?" )
.head 9 -  !
.head 9 -  Set sSql = "SELECT company_name,
invoice_no,
invoice_date,
employee_id,
@decode( status, 'PAID', 'Yes', 'No' )
FROM invoice
ORDER BY company_name, invoice_no
INTO :col1,
:col2,
:col3,
:col4,
:col5"
.head 9 +  If npMode < POP_DB_SETRANGE
.head 10 +  If npMode = POP_DB_FILLALL

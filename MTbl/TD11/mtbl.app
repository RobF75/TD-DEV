.head 4 +  Actions
.head 5 -  ! Get selected flag
.head 5 -  Set nIdx = SalListQuerySelection( lbFlags )
.head 5 +  If nIdx >= 0
.head 6 -  Set nFlag = VisListGetValue( lbFlags, nIdx )
.head 6 -  !
.head 6 -  Set nFlags = MTSI_REDRAW
.head 6 +  If cbNoSelInv
.head 7 -  Set nFlags = nFlags | MTSI_NOSELINV
.head 6 -  ! Set image
.head 6 -  Set nImage = ccImg.GetImage( )
.head 6 -  Call SalGetWindowText( ccImg, sText, 255 )
.head 6 +  If sText = "<No default>"
.head 7 -  Set nImage = MTBL_HIMG_NODEFAULT
.head 6 +  If NOT MTblSetRowFlagImage( frmMain.tbl1, nFlag, nImage, nFlags )
.head 7 -  Set sMsg = "Error setting row flag image."
.head 7 -  Call SalMessageBox( sMsg, "Row flag images", MB_IconExclamation )

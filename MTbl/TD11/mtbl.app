.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nRet
.head 5 -  String: sText
.head 4 +  Actions
.head 5 -  Call SalWaitCursor( TRUE )
.head 5 -  Call wfSaveSettings( )
.head 5 -  Set nRet = MTblExportToOOCalc( frmMain.tbl1, frmMain.OOCalcExp.Language, frmMain.OOCalcExp.CalcStartCell, frmMain.OOCalcExp.CalcFlags, frmMain.OOCalcExp.ExpFlags, frmMain.OOCalcExp.RowFlagsOn, frmMain.OOCalcExp.RowFlagsOff, 
frmMain.OOCalcExp.ColFlagsOn, 
frmMain.OOCalcExp.ColFlagsOff )
.head 5 -  Call SalWaitCursor( FALSE )
.head 5 +  If nRet < 1
.head 6 +  Select Case nRet
.head 7 +  Case MTE_ERR_CANCELLED
.head 8 -  Set sText = "Export cancelled."
.head 8 -  Break
.head 7 +  Case MTE_ERR_RUNNING_INSTANCE
.head 8 -  Set sText = "Error getting running instance"
.head 8 -  Break
.head 7 +  Case MTE_ERR_NEW_INSTANCE
.head 8 -  Set sText = "Error creating new instance"
.head 8 -  Break
.head 7 +  Case MTE_ERR_OLE_EXCEPTION
.head 8 -  Set sText = "An OLE exception has occured"
.head 8 -  Break
.head 7 +  Case MTE_ERR_EXCEPTION
.head 8 -  Set sText = "An exception has occured"
.head 8 -  Break
.head 7 +  Case MTE_ERR_NOT_SUBCLASSED
.head 8 -  Set sText = "Table isn't subclassed"
.head 8 -  Break
.head 7 +  Case MTE_ERR_INVALID_LANG
.head 8 -  Set sText = "Invalid language"
.head 8 -  Break
.head 7 +  Default
.head 8 -  Set sText = "Export failed."
.head 8 -  Break
.head 6 -  Call SalMessageBox( sText, "Export error", MB_IconHand | MB_Ok )
.head 3 +  Function: wfReadSettings
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  ! Language
.head 5 -  Call cmbLanguage.Populate( )
.head 5 -  Call cmbLanguage.SelectValue( frmMain.OOCalcExp.Language )
.head 5 -  ! Excel start cell
.head 5 -  Set dfsStartCell = frmMain.OOCalcExp.CalcStartCell
.head 5 -  ! Excel flags
.head 5 -  Set cbNewWBook = frmMain.OOCalcExp.CalcFlags & MTE_OOCALC_NEW_WORKBOOK
.head 5 -  Set cbNewWSheet = frmMain.OOCalcExp.CalcFlags & MTE_OOCALC_NEW_WORKSHEET
.head 5 -  Set cbCurPos = frmMain.OOCalcExp.CalcFlags & MTE_OOCALC_CURRENT_POS
.head 5 -  Set cbStrColsAsText = frmMain.OOCalcExp.CalcFlags & MTE_OOCALC_STRING_COLS_AS_TEXT
.head 5 -  Set cbNullsAsSpace = frmMain.OOCalcExp.CalcFlags & MTE_OOCALC_NULLS_AS_SPACE
.head 5 -  ! Export flags
.head 5 -  Set cbColHdrs = frmMain.OOCalcExp.ExpFlags & MTE_COL_HEADERS
.head 5 -  Set cbColors = frmMain.OOCalcExp.ExpFlags & MTE_COLORS
.head 5 -  Set cbFonts = frmMain.OOCalcExp.ExpFlags & MTE_FONTS
.head 5 -  Set cbGrid = frmMain.OOCalcExp.ExpFlags & MTE_GRID
.head 5 -  Set cbShowStatus = frmMain.OOCalcExp.ExpFlags & MTE_SHOW_STATUS
.head 5 -  Set cbSplitRows = frmMain.OOCalcExp.ExpFlags & MTE_SPLIT_ROWS
.head 5 -  ! Rows to export
.head 5 +  If frmMain.OOCalcExp.RowFlagsOn & ROW_Selected
.head 6 -  Set rbSelectedRows = TRUE
.head 5 -  ! Columns to export
.head 5 +  If frmMain.OOCalcExp.ColFlagsOn & COL_Selected
.head 6 -  Set rbSelectedCols = TRUE
.head 3 +  Function: wfSaveSettings
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  : OOCalcExp
.head 6 -  Class: fcOOCalcExp
.head 4 +  Actions
.head 5 -  ! Language
.head 5 -  Set OOCalcExp.Language = cmbLanguage.GetSelectedValue( )
.head 5 -  ! Open Office Calc start cell
.head 5 -  Set OOCalcExp.CalcStartCell = dfsStartCell
.head 5 -  ! Open Office Calc flags
.head 5 +  If cbNewWBook
.head 6 -  Set OOCalcExp.CalcFlags = OOCalcExp.CalcFlags | MTE_OOCALC_NEW_WORKBOOK
.head 5 +  If cbNewWSheet
.head 6 -  Set OOCalcExp.CalcFlags = OOCalcExp.CalcFlags | MTE_OOCALC_NEW_WORKSHEET
.head 5 +  If cbCurPos
.head 6 -  Set OOCalcExp.CalcFlags = OOCalcExp.CalcFlags | MTE_OOCALC_CURRENT_POS
.head 5 +  If cbStrColsAsText
.head 6 -  Set OOCalcExp.CalcFlags = OOCalcExp.CalcFlags | MTE_OOCALC_STRING_COLS_AS_TEXT
.head 5 +  If cbNullsAsSpace
.head 6 -  Set OOCalcExp.CalcFlags = OOCalcExp.CalcFlags | MTE_OOCALC_NULLS_AS_SPACE
.head 5 -  ! Export flags
.head 5 +  If cbColHdrs
.head 6 -  Set OOCalcExp.ExpFlags = OOCalcExp.ExpFlags | MTE_COL_HEADERS
.head 5 +  If cbColors
.head 6 -  Set OOCalcExp.ExpFlags = OOCalcExp.ExpFlags | MTE_COLORS
.head 5 +  If cbFonts
.head 6 -  Set OOCalcExp.ExpFlags = OOCalcExp.ExpFlags | MTE_FONTS
.head 5 +  If cbGrid
.head 6 -  Set OOCalcExp.ExpFlags = OOCalcExp.ExpFlags | MTE_GRID
.head 5 +  If cbShowStatus
.head 6 -  Set OOCalcExp.ExpFlags = OOCalcExp.ExpFlags | MTE_SHOW_STATUS
.head 5 +  If cbSplitRows
.head 6 -  Set OOCalcExp.ExpFlags = OOCalcExp.ExpFlags | MTE_SPLIT_ROWS
.head 5 -  ! Rows to export
.head 5 -  Set OOCalcExp.RowFlagsOff = ROW_Hidden
.head 5 +  If rbSelectedRows
.head 6 -  Set OOCalcExp.RowFlagsOn = ROW_Selected
.head 5 -  ! Columns to export
.head 5 +  If rbSelectedCols
.head 6 -  Set OOCalcExp.ColFlagsOn = COL_Selected
.head 5 +  Else
.head 6 -  Set OOCalcExp.ColFlagsOn = COL_Visible
.head 5 -  ! Assign
.head 5 -  Call frmMain.OOCalcExp.Assign( OOCalcExp )

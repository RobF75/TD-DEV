.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Boolean: bInList
.head 5 -  Date/Time: dtRet
.head 5 -  Date/Time: dtStart
.head 5 -  Date/Time: dtStop
.head 5 -  Number: n
.head 5 -  Number: nError
.head 5 -  Number: nErrorPos
.head 5 -  Number: nMod
.head 5 -  Number: nType
.head 5 -  Number: nRet
.head 5 -  Number: nSec
.head 5 -  String: sRet
.head 5 -  String: sText
.head 5 -  Window Handle: hWndRet
.head 4 +  Actions
.head 5 -  Set dtStart = SalDateCurrent( )
.head 5 -  Set nType = SalCompileAndEvaluate( cmbExpr, nError, nErrorPos, nRet, sRet, dtRet, hWndRet, FALSE, wpsContext )
.head 5 -  Set dtStop = SalDateCurrent( )
.head 5 +  If NOT nError
.head 6 +  Select Case nType
.head 7 +  Case EVAL_Date
.head 8 -  Call SalDateToStr( dtRet, sRet )
.head 8 -  Set sRet = "Date/Time: " || sRet
.head 8 -  Break
.head 7 +  Case EVAL_Handle
.head 8 -  Set sRet = SalNumberToStrX( SalWindowHandleToNumber( hWndRet ), 0 )
.head 8 -  Set sRet = "Handle: " || sRet
.head 8 -  Break
.head 7 +  Case EVAL_If
.head 8 -  Set sRet = SalNumberToStrX( nRet, 0 )
.head 8 -  Set sRet = "If: " || sRet
.head 8 -  Break
.head 7 +  Case EVAL_Number
.head 8 +  If SalNumberMod( nRet, 1 )
.head 9 -  Set sRet = SalNumberToStrX( nRet, 2 )
.head 8 +  Else
.head 9 -  Set sRet = SalNumberToStrX( nRet, 0 )
.head 8 -  Set sRet = "Number: " || sRet
.head 8 -  Break
.head 7 +  Case EVAL_Set
.head 8 -  Set sRet = "Set!"
.head 8 -  Break
.head 7 +  Case EVAL_String
.head 8 -  Set sRet = "String: " || sRet
.head 8 -  Break
.head 7 +  Case EVAL_Template
.head 8 -  Set sRet = SalNumberToStrX( nRet, 2 )
.head 8 -  Set sRet = "Template: " || sRet
.head 8 -  Break
.head 7 +  Default
.head 8 -  Set sRet = "<Unknown EVAL type>"
.head 6 -  Set nSec = ( dtStop - dtStart ) * 86400
.head 6 -  Set sRet = sRet || CRLF || "Time: " || SalFmtFormatNumber( nSec, "#.##0,000" ) || " Sec."
.head 6 -  !
.head 6 +  While SalListQueryText( cmbExpr, n, sText ) > 0
.head 7 +  If sText = cmbExpr
.head 8 -  Set bInList = TRUE
.head 8 -  Break
.head 7 -  Set n = n + 1
.head 6 +  If NOT bInList
.head 7 -  Call SalListAdd( cmbExpr, cmbExpr )
.head 5 +  Else
.head 6 -  Set sRet = "Error: " || SalNumberToStrX( nError, 0 )
.head 5 -  !
.head 5 -  Set mlResult = sRet

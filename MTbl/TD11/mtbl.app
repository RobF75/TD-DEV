.head 4 +  Actions
.head 5 -  Set sMsgPrefix = SalStrLeftX( spTxt, 3 )
.head 5 +  If sMsgPrefix = "SAM" AND NOT cbSAM
.head 6 -  Return TRUE
.head 5 +  If sMsgPrefix = "MTM" AND NOT cbMTM
.head 6 -  Return TRUE
.head 5 -  !
.head 5 +  If dfMsgIncl
.head 6 -  Set bIncl = FALSE
.head 6 -  Set nToken = SalStrTokenize( dfMsgIncl, ",", ",", saToken )
.head 6 -  Set n = 0
.head 6 +  While n < nToken
.head 7 -  Set s = VisStrTrim( saToken[n] )
.head 7 -  Set nLen = SalStrLength( s )
.head 7 +  If SalStrLeftX( spTxt, nLen ) = s
.head 8 -  Set bIncl = TRUE
.head 8 -  Break
.head 7 -  Set n = n + 1
.head 6 +  If NOT bIncl
.head 7 -  Return TRUE
.head 5 +  If dfMsgExcl
.head 6 -  Set bIncl = TRUE
.head 6 -  Set nToken = SalStrTokenize( dfMsgExcl, ",", ",", saToken )
.head 6 -  Set n = 0
.head 6 +  While n < nToken
.head 7 -  Set s = VisStrTrim( saToken[n] )
.head 7 -  Set nLen = SalStrLength( s )
.head 7 +  If SalStrLeftX( spTxt, nLen ) = s
.head 8 -  Set bIncl = FALSE
.head 8 -  Break
.head 7 -  Set n = n + 1
.head 6 +  If NOT bIncl
.head 7 -  Return TRUE
.head 5 -  !
.head 5 -  Set nPos = SalStrScan( spTxt, "[" )

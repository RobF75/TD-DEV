.head 4 +  Actions
.head 5 -  Set n = -1
.head 5 +  While SalTblFindNextRow( tblLang, n, 0, 0 )
.head 6 -  Call SalTblSetContext( tblLang, n )
.head 6 -  !
.head 6 +  If SalIsNull( tblLang.colNr )
.head 7 -  Call SalTblSetFocusCell( tblLang, n, tblLang.colNr, 0, -1 )
.head 7 -  Call SalMessageBox( "Please enter a number", "Register Language", MB_IconAsterisk | MB_Ok )
.head 7 -  Break
.head 6 +  If SalIsNull( tblLang.colName )
.head 7 -  Call SalTblSetFocusCell( tblLang, n, tblLang.colName, 0, -1 )
.head 7 -  Call SalMessageBox( "Please enter a name", "Register Language", MB_IconAsterisk | MB_Ok )
.head 7 -  Break

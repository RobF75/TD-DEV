.head 3 +  Function: wfDelete
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: n
.head 5 -  Number: nRow
.head 5 -  Boolean: bError
.head 5 -  Window Handle: hWndCol
.head 4 +  Actions
.head 5 +  If NOT SalTblAnyRows( tblUD, ROW_Selected, 0  )
.head 6 -  Call SalMessageBox( "Please select the rows you want to delete", "Row User Data", MB_IconAsterisk | MB_Ok )
.head 6 -  Return FALSE
.head 5 -  Call SalTblQueryFocus( frmMain.tbl1, nRow, hWndCol )
.head 5 -  Set n = TBL_MaxRow
.head 5 +  While SalTblFindPrevRow( tblUD, n, ROW_Selected, 0 )
.head 6 -  Call SalTblSetContext( tblUD, n )
.head 6 +  If NOT SalTblQueryRowFlags( tblUD, n, ROW_New )
.head 7 +  If NOT MTblDeleteRowUserData( frmMain.tbl1, nRow, tblUD.colKey )
.head 8 -  Set bError = TRUE
.head 8 -  Break
.head 6 -  Call SalTblDeleteRow( tblUD, n, TBL_NoAdjust )
.head 5 +  If bError
.head 6 -  Call SalMessageBox( "Error deleting row data", "Row User Data Error", MB_IconStop | MB_Ok )
.head 3 +  Function: wfDo
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Boolean: bError
.head 5 -  Number: n
.head 5 -  Number: nRow
.head 5 -  Window Handle: hWndCol
.head 4 +  Actions
.head 5 -  ! Get focus
.head 5 -  Call SalTblQueryFocus( frmMain.tbl1, nRow, hWndCol )
.head 5 -  ! Set data
.head 5 -  Set n = -1
.head 5 +  While SalTblFindNextRow( tblUD, n, 0, 0 )
.head 6 -  Call SalTblSetContext( tblUD, n )
.head 6 +  If SalIsNull( tblUD.colKey )
.head 7 -  Call SalTblSetFocusCell( tblUD, n, tblUD.colKey, 0, -1 )
.head 7 -  Call SalMessageBox( "Please enter a key", "Row User Data", MB_IconAsterisk | MB_Ok )
.head 7 -  Break
.head 6 +  If NOT MTblSetRowUserData( frmMain.tbl1, nRow, tblUD.colKey, tblUD.colValue )
.head 7 -  Set bError = TRUE
.head 7 -  Break
.head 6 -  Call SalTblSetRowFlags( tblUD, n, ROW_New | ROW_Edited, FALSE )
.head 5 +  If bError
.head 6 -  Call SalMessageBox( "Error setting row data", "Row User Data Error", MB_IconStop | MB_Ok )
.head 3 +  Function: wfUpdate
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: n
.head 5 -  Number: nData
.head 5 -  Number: nNewRow
.head 5 -  Number: nRow
.head 5 -  String: saKeys[*]
.head 5 -  String: saValues[*]
.head 5 -  Window Handle: hWndCol
.head 4 +  Actions
.head 5 -  ! Get focus
.head 5 -  Call SalTblQueryFocus( frmMain.tbl1, nRow, hWndCol )
.head 5 -  ! Set title
.head 5 -  Call SalSetWindowText( hWndForm, "Row User Data for row " || SalNumberToStrX( nRow, 0 ) )
.head 5 -  ! Get data
.head 5 -  Call SalTblReset( tblUD )
.head 5 -  Set nData = MTblEnumRowUserData( frmMain.tbl1, nRow, saKeys, saValues )
.head 5 +  If nData > 0
.head 6 +  While n < nData
.head 7 -  Set nNewRow = SalTblInsertRow( tblUD, TBL_MaxRow )
.head 7 +  If nNewRow != TBL_Error
.head 8 -  Call SalTblSetRowFlags( tblUD, nNewRow, ROW_New, FALSE  )
.head 8 -  Set tblUD.colKey = saKeys[n]
.head 8 -  Set tblUD.colValue = saValues[n]
.head 8 -  Call MTblDisableCell( tblUD.colKey, nNewRow, TRUE )
.head 7 -  Set n = n + 1

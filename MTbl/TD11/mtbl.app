.head 4 +  Actions
.head 5 +  If p_hWndCol
.head 6 -  Call cmbCols.SelectHandle( p_hWndCol )
.head 5 +  If p_nRow != TBL_Error
.head 6 -  Set w_nRow = p_nRow
.head 5 -  Call wfUpdate( )
.head 3 +  Function: wfUpdate
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nFlags
.head 5 -  Number: nLines
.head 5 -  Number: nType
.head 5 -  String: sCheckedVal
.head 5 -  String: sUnCheckedVal
.head 5 -  Window Handle: hWndCol
.head 4 +  Actions
.head 5 -  ! Get selected column
.head 5 -  Set hWndCol = cmbCols.GetSelectedHandle( )
.head 5 -  ! Set title
.head 5 -  Call SalSetWindowText( hWndForm, "Cell type for row " || GetRowStr( w_nRow ) )
.head 5 -  ! Get definition
.head 5 +  If NOT MTblQueryCellType( hWndCol, w_nRow, nType, nFlags, nLines, sCheckedVal, sUnCheckedVal )
.head 6 -  Call SalMessageBox( "Getting cell type failed.", "Cell type", MB_IconHand | MB_Ok )
.head 6 -  Return FALSE
.head 5 -  ! Set controls
.head 5 -  Call SalListSetSelect( cmbType, nType )
.head 5 -  Call wfAdaptToType( nType )
.head 5 -  !
.head 5 +  If nType = COL_CellType_CheckBox
.head 6 -  Set cbCheckBoxIgnoreCase = ( nFlags & COL_CheckBox_IgnoreCase ) != 0
.head 5 +  Else
.head 6 -  Set cbCheckBoxIgnoreCase = FALSE
.head 5 -  !
.head 5 +  If nType = COL_CellType_DropDownList
.head 6 -  Set cbDropDownListSorted = ( nFlags & COL_DropDownList_Sorted ) != 0
.head 6 -  Set cbDropDownListVScroll = ( nFlags & COL_DropDownList_VScroll ) != 0
.head 6 -  Set cbDropDownListAuto = ( nFlags & COL_DropDownList_Auto ) != 0
.head 6 -  Set cbDropDownListEditable = ( nFlags & COL_DropDownList_Editable ) != 0
.head 5 +  Else
.head 6 -  Set cbDropDownListSorted = FALSE
.head 6 -  Set cbDropDownListVScroll = FALSE
.head 6 -  Set cbDropDownListAuto = FALSE
.head 6 -  Set cbDropDownListEditable = FALSE
.head 5 -  !
.head 5 -  Set dfnLines = nLines
.head 5 -  Set dfsCheckedVal = sCheckedVal
.head 5 -  Set dfsUnCheckedVal = sUnCheckedVal
.head 5 -  !
.head 5 -  Return TRUE

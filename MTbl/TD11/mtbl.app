.head 8 -  Set col4 = "Popup edit!"
.head 7 +  Else
.head 8 -  Set col4 = "Choose a value"
.head 7 -  ! Column 5
.head 7 +  If npRow = 3  AND NOT tbSetNoCellType
.head 8 +  If MTblDefineCellType( col5, npRow, COL_CellType_DropDownList, COL_DropDownList_VScroll | COL_DropDownList_Sorted | COL_DropDownList_Editable, 0, "", "" )
.head 9 +  If MTblSetDropDownListContext( col5, npRow )
.head 10 +  If MTblSetDropDownListContext( col4, TBL_Error )
.head 11 -  Set nCount = SalListQueryCount( col4 )
.head 11 -  Set n = 0
.head 11 +  While n < nCount
.head 12 -  Set sText = SalListQueryTextX( col4, n )
.head 12 -  ! Call SalListAdd( col5, sText )
.head 12 -  Call VisListAddValue( col5, sText, n )
.head 12 -  Set n = n + 1
.head 9 -  Set col5 = "DropDownList!"
.head 9 -  Call MTblSetCellFont( col5, npRow, MTBL_FONT_UNDEF_NAME, MTBL_FONT_UNDEF_SIZE, FONT_EnhBold, MTSF_REDRAW )
.head 8 +  Else
.head 9 -  Set col5 = "No"
.head 7 +  Else
.head 8 -  Set col5 = "No"

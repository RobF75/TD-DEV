.head 5 +  Function: tfOnMousemove
.head 6 -  Description:
.head 6 -  Returns
.head 6 +  Parameters
.head 7 -  Number: npwP
.head 7 -  Number: nplP
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  Number: nFlags
.head 7 -  Number: nMFlags
.head 7 -  Number: nRow
.head 7 -  Number: nRowHdrSep
.head 7 -  Number: nX
.head 7 -  Number: nY
.head 7 -  String: sCol
.head 7 -  String: sColSep
.head 7 -  String: sMFlags
.head 7 -  String: sRow
.head 7 -  String: sRowHdrSep
.head 7 -  String: sText
.head 7 -  String: sX
.head 7 -  String: sY
.head 7 -  Window Handle: hWndCol
.head 7 -  Window Handle: hWndColSep
.head 6 +  Actions
.head 7 -  Set nX = SalNumberLow( nplP )
.head 7 -  Set sX = SalNumberToStrX( nX, 0 )
.head 7 -  Set nY = SalNumberHigh( nplP )
.head 7 -  Set sY = SalNumberToStrX( nY, 0 )
.head 7 -  !
.head 7 +  Loop OFP
.head 8 +  If NOT MTblObjFromPoint( hWndForm, nX, nY, nRow, hWndCol, nFlags, nMFlags )
.head 9 +  If NOT SalTblObjectsFromPoint( hWndForm, nX, nY, nRow, hWndCol, nFlags )
.head 10 -  Set sText = "<Error>"
.head 10 -  Break OFP
.head 8 -  !
.head 8 +  If NOT SalGetItemName( hWndCol, sCol )
.head 9 -  Set sCol = "<no>"
.head 8 +  Else
.head 9 -  Set sCol = sCol || " (" || SalNumberToStrX( SalWindowHandleToNumber( hWndCol ), 0 ) || ")"
.head 8 +  If nRow = TBL_Error
.head 9 -  Set sRow = "<no>"
.head 8 +  Else
.head 9 -  Set sRow = SalNumberToStrX( nRow, 0 )
.head 8 -  !
.head 8 +  If nMFlags
.head 9 +  If nMFlags & MTOFP_OVERNODE
.head 10 -  Set sMFlags = "Over Node"
.head 9 +  ! If nMFlags & MTOFP_OVERCELLTEXT
.head 10 +  If sMFlags
.head 11 -  Set sMFlags = sMFlags || ", "
.head 10 -  Set sMFlags = sMFlags || "Over Cell Text"
.head 9 +  If nMFlags & MTOFP_OVERTEXT
.head 10 +  If sMFlags
.head 11 -  Set sMFlags = sMFlags || ", "
.head 10 -  Set sMFlags = sMFlags || "Over Text"
.head 9 +  ! If nMFlags & MTOFP_OVERCELLIMAGE
.head 10 +  If sMFlags
.head 11 -  Set sMFlags = sMFlags || ", "
.head 10 -  Set sMFlags = sMFlags || "Over Cell Image"
.head 9 +  If nMFlags & MTOFP_OVERIMAGE
.head 10 +  If sMFlags
.head 11 -  Set sMFlags = sMFlags || ", "
.head 10 -  Set sMFlags = sMFlags || "Over Image"
.head 9 +  If nMFlags & MTOFP_OVERCOLHDRGRP
.head 10 +  If sMFlags
.head 11 -  Set sMFlags = sMFlags || ", "
.head 10 -  Set sMFlags = sMFlags || "Over Column Header Group"
.head 9 +  If nMFlags & MTOFP_OVERMERGEDCELL
.head 10 +  If sMFlags
.head 11 -  Set sMFlags = sMFlags || ", "
.head 10 -  Set sMFlags = sMFlags || "Over Merged Cell"
.head 9 +  If nMFlags & MTOFP_OVERBTN
.head 10 +  If sMFlags
.head 11 -  Set sMFlags = sMFlags || ", "
.head 10 -  Set sMFlags = sMFlags || "Over Button"
.head 9 +  If nMFlags & MTOFP_OVERDDBTN
.head 10 +  If sMFlags
.head 11 -  Set sMFlags = sMFlags || ", "
.head 10 -  Set sMFlags = sMFlags || "Over Drop Down Button"
.head 9 +  If nMFlags & MTOFP_OVERCOLHDRSEP
.head 10 +  If sMFlags
.head 11 -  Set sMFlags = sMFlags || ", "
.head 10 -  Set sMFlags = sMFlags || "Over Column Header Separator"
.head 10 -  Set hWndColSep = MTblGetSepCol( hWndForm, nX, nY )
.head 10 +  If hWndColSep
.head 11 -  Call SalGetItemName( hWndColSep, sColSep )
.head 11 -  Set sMFlags = sMFlags || "(" || sColSep || ")"
.head 9 +  If nMFlags & MTOFP_OVERCORNERSEP
.head 10 +  If sMFlags
.head 11 -  Set sMFlags = sMFlags || ", "
.head 10 -  Set sMFlags = sMFlags || "Over Corner Separator"
.head 9 +  If nMFlags & MTOFP_OVERROWHDRSEP
.head 10 +  If sMFlags
.head 11 -  Set sMFlags = sMFlags || ", "

.head 2 +  Functions
.head 3 +  Function: wfOnCreate
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  ! Fill column list
.head 5 -  Call lbCols.Populate( 0, 0 )
.head 5 -  ! Read settings
.head 5 -  Call wfReadSettings( )
.head 3 -  !
.head 3 +  Function: wfAdd
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Number: npFlags
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nIdx
.head 5 -  Number: nRow
.head 5 -  String: sText
.head 4 +  Actions
.head 5 +  If SalListQueryCount( lbCols ) > 0
.head 6 -  Set nIdx = SalSendMsg( lbCols, LB_GETCARETINDEX, 0, 0 )
.head 6 -  Set nRow = SalTblInsertRow( tblSortCols, TBL_MaxRow )
.head 6 +  If nRow != TBL_Error
.head 7 -  Call SalTblSetRowFlags( tblSortCols, nRow, ROW_New, FALSE )
.head 7 -  Call SalTblClearSelection( tblSortCols )
.head 7 -  Call SalTblSetRowFlags( tblSortCols, nRow, ROW_Selected, TRUE )
.head 7 -  Call SalTblSetFocusRow( tblSortCols, nRow )
.head 7 -  !
.head 7 -  Set tblSortCols.colHandle = lbCols.GetValue( nIdx )
.head 7 -  Set tblSortCols.colName = SalListQueryTextX( lbCols, nIdx )
.head 7 -  !
.head 7 +  If npFlags & MTS_DESC
.head 8 -  Set tblSortCols.colSortOrder = "Descending"
.head 7 +  Else
.head 8 -  Set tblSortCols.colSortOrder = "Ascending"
.head 7 -  !
.head 7 +  If npFlags & MTS_IGNORECASE
.head 8 -  Set tblSortCols.colIgnoreCase = "Yes"
.head 7 +  Else
.head 8 -  Set tblSortCols.colIgnoreCase = "No"
.head 7 -  !
.head 7 +  If npFlags & MTS_STRINGSORT
.head 8 -  Set tblSortCols.colStringSort = "Yes"
.head 7 +  Else
.head 8 -  Set tblSortCols.colStringSort = "No"
.head 7 -  !
.head 7 +  If npFlags & MTS_DT_STRING
.head 8 -  Set tblSortCols.colSortDataType = "String"
.head 7 +  Else If npFlags & MTS_DT_NUMBER
.head 8 -  Set tblSortCols.colSortDataType = "Number"
.head 7 +  Else If npFlags & MTS_DT_DATETIME
.head 8 -  Set tblSortCols.colSortDataType = "Date/Time"
.head 7 +  Else If npFlags & MTS_DT_CUSTOM
.head 8 -  Set tblSortCols.colSortDataType = "Custom"
.head 7 +  Else If npFlags & MTS_DT_CUSTOM_STRING
.head 8 -  Set tblSortCols.colSortDataType = "Custom String"
.head 7 +  Else
.head 8 -  Set tblSortCols.colSortDataType = "Default"
.head 7 -  !
.head 7 -  Call SalListDelete( lbCols, nIdx )
.head 3 +  Function: wfDo
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Boolean: bOk
.head 5 -  Date/Time: dtStart
.head 5 -  Date/Time: dtStop
.head 5 -  Number: n
.head 5 -  Number: nFromLevel
.head 5 -  Number: nMinRow
.head 5 -  Number: nMaxRow
.head 5 -  Number: nParentRow
.head 5 -  Number: nUpper
.head 5 -  Number: nSortTreeFlags
.head 5 -  Number: nToLevel
.head 5 -  Number: naFlags[*]
.head 5 -  String: sText
.head 5 -  Window Handle: hWndaCols[*]
.head 4 +  Actions
.head 5 -  Call SalWaitCursor( TRUE )
.head 5 -  !
.head 5 -  Call wfSaveSettings( )
.head 5 +  If NOT SalArrayIsEmpty( frmMain.SortCols )
.head 6 -  Call SalArrayGetUpperBound( frmMain.SortCols, 1, nUpper )
.head 6 +  While n <= nUpper
.head 7 -  Set hWndaCols[n] = frmMain.SortCols[n].Handle
.head 7 -  Set naFlags[n] = frmMain.SortCols[n].Flags
.head 7 -  !
.head 7 -  Set n = n + 1
.head 6 -  !
.head 6 -  !
.head 6 -  Set nMinRow = dfMinRow
.head 6 +  If nMinRow = NUMBER_Null
.head 7 -  Set nMinRow = TBL_Error
.head 6 -  !
.head 6 -  Set nMaxRow = dfMaxRow
.head 6 +  If nMaxRow = NUMBER_Null
.head 7 -  Set nMaxRow = TBL_Error
.head 6 -  !
.head 6 -  Set nFromLevel = dfFromLevel
.head 6 +  If nFromLevel = NUMBER_Null
.head 7 -  Set nFromLevel = -1
.head 6 -  !
.head 6 -  Set nToLevel = dfToLevel
.head 6 +  If nToLevel = NUMBER_Null
.head 7 -  Set nToLevel = -1
.head 6 -  !
.head 6 -  Set nParentRow = dfParentRow
.head 6 +  If nParentRow = NUMBER_Null
.head 7 -  Set nParentRow = TBL_Error
.head 6 -  !
.head 6 -  Set dtStart = SalDateCurrent( )
.head 6 -  Set bOk = MTblSortEx( frmMain.tbl1, hWndaCols, naFlags, nMinRow, nMaxRow, nFromLevel, nToLevel, nParentRow )
.head 6 -  Set dtStop = SalDateCurrent( )
.head 6 -  !
.head 6 +  If bOk
.head 7 -  Set sText = SalFmtFormatNumber( ( dtStop - dtStart ) * 86400, "#.##0,00" )
.head 7 -  Set sText = "Sorted in " || sText || " seconds."
.head 7 +  If NOT MTblQueryFlags( frmMain.tbl1, MTBL_FLAG_SORT_RESTORE_TREE )
.head 8 -  Set sText = sText || CRLF || "Do you want to do a tree sort now?"
.head 8 +  If SalMessageBox( sText, "Sort time", MB_IconAsterisk | MB_YesNo ) = IDYES
.head 9 +  If MTblQueryTreeFlags( frmMain.tbl1, MTBL_TREE_FLAG_BOTTOM_UP )
.head 10 -  Set nSortTreeFlags = MTST_BOTTOMUP
.head 9 +  Else
.head 10 -  Set nSortTreeFlags = MTST_TOPDOWN
.head 9 -  Call SalWaitCursor( TRUE )
.head 9 -  Set bOk = MTblSortTree( frmMain.tbl1, nSortTreeFlags )
.head 9 -  Call SalWaitCursor( FALSE )
.head 9 +  If NOT bOk
.head 10 -  Call SalMessageBox( "Tree sort failed.", "Sort error", MB_IconHand | MB_Ok )
.head 7 +  Else
.head 8 -  Call SalMessageBox( sText, "Sort time", MB_IconAsterisk | MB_Ok )
.head 6 +  Else
.head 7 -  Call SalMessageBox( "Sorting failed.", "Sort error", MB_IconHand | MB_Ok )
.head 6 -  !
.head 6 -  Call frmMain.tbl1.tfUpdateDlgs( )
.head 5 -  !
.head 5 -  Call SalWaitCursor( FALSE )
.head 3 +  Function: wfDown
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nRow
.head 5 -  Number: nRow2
.head 5 -  Window Handle: hWndCol
.head 4 +  Actions
.head 5 +  If SalTblQueryFocus( tblSortCols, nRow, hWndCol )
.head 6 -  Set nRow2 = nRow
.head 6 +  If SalTblFindNextRow( tblSortCols, nRow2, 0, 0 )
.head 7 +  If MTblSwapRows( tblSortCols, nRow, nRow2, MTSR_REDRAW )
.head 8 -  Call SalTblSetFocusRow( tblSortCols, nRow2 )
.head 5 -  Call SalSetFocus( tblSortCols )
.head 3 +  Function: wfReadSettings
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: n
.head 5 -  Number: nItems
.head 5 -  Number: nIdx
.head 5 -  String: sText
.head 5 -  Window Handle: hWndCol
.head 4 +  Actions
.head 5 +  If NOT SalArrayIsEmpty( frmMain.SortCols )
.head 6 +  While n < frmMain.wnSortCols
.head 7 -  Set nItems = SalListQueryCount( lbCols )
.head 7 -  Set nIdx = 0
.head 7 +  While nIdx < nItems
.head 8 -  Set hWndCol =  lbCols.GetHandle( nIdx )
.head 8 +  If hWndCol = frmMain.SortCols[n].Handle
.head 9 -  Call SalListSetSelect( lbCols, nIdx )
.head 9 -  Call wfAdd( frmMain.SortCols[n].Flags )
.head 9 -  Break
.head 8 -  Set nIdx = nIdx + 1
.head 7 -  Set n = n + 1
.head 5 -  Set dfMinRow = frmMain.wnSortMinRow
.head 5 -  Set dfMaxRow = frmMain.wnSortMaxRow
.head 5 -  Set dfFromLevel = frmMain.wnSortFromLevel
.head 5 -  Set dfToLevel = frmMain.wnSortToLevel
.head 5 -  Set dfParentRow = frmMain.wnSortParentRow
.head 3 +  Function: wfRemove
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nRow
.head 5 -  Window Handle: hWndCol
.head 4 +  Actions
.head 5 +  If SalTblAnyRows( tblSortCols, 0, 0 )
.head 6 +  If SalTblQueryFocus( tblSortCols, nRow, hWndCol )
.head 7 -  Call SalTblSetContext( tblSortCols, nRow )
.head 7 -  Call lbCols.AddValue( tblSortCols.colName, tblSortCols.colHandle )
.head 7 -  Call SalTblDeleteRow( tblSortCols, nRow, TBL_NoAdjust )
.head 3 +  Function: wfSaveSettings
.head 4 -  Description:
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: n
.head 5 -  Number: nFlags
.head 5 -  Number: nRow
.head 5 -  String: sText
.head 4 +  Actions
.head 5 +  If NOT SalArrayIsEmpty( frmMain.SortCols ) 
.head 6 -  Call SalArraySetUpperBound( frmMain.SortCols, 1, -1 )
.head 5 -  Set frmMain.wnSortCols = 0
.head 5 +  If SalTblAnyRows( tblSortCols, 0, 0 )
.head 6 -  Set nRow = -1
.head 6 +  While SalTblFindNextRow( tblSortCols, nRow, 0, 0 )
.head 7 +  If SalTblSetContext( tblSortCols, nRow )
.head 8 -  Set frmMain.SortCols[n].Handle = SalNumberToWindowHandle( tblSortCols.colHandle )
.head 8 -  !
.head 8 -  Set nFlags = 0
.head 8 -  !
.head 8 +  If tblSortCols.colSortOrder = "Descending"
.head 9 -  Set nFlags = nFlags | MTS_DESC
.head 8 +  Else
.head 9 -  Set nFlags = nFlags | MTS_ASC
.head 8 -  !
.head 8 +  If tblSortCols.colIgnoreCase = "Yes"
.head 9 -  Set nFlags = nFlags | MTS_IGNORECASE
.head 8 +  If tblSortCols.colStringSort = "Yes"
.head 9 -  Set nFlags = nFlags | MTS_STRINGSORT
.head 8 -  !
.head 8 -  Set sText = tblSortCols.colSortDataType 
.head 8 +  If sText = "Default"
.head 9 -  Set nFlags = nFlags | MTS_DT_DEFAULT
.head 8 +  Else If sText = "String"
.head 9 -  Set nFlags = nFlags | MTS_DT_STRING
.head 8 +  Else If sText = "Number"
.head 9 -  Set nFlags = nFlags | MTS_DT_NUMBER
.head 8 +  Else If sText = "Date/Time"
.head 9 -  Set nFlags = nFlags | MTS_DT_DATETIME
.head 8 +  Else If sText = "Custom"
.head 9 -  Set nFlags = nFlags | MTS_DT_CUSTOM
.head 8 +  Else If sText = "Custom String"
.head 9 -  Set nFlags = nFlags | MTS_DT_CUSTOM_STRING
.head 8 -  !
.head 8 -  Set frmMain.SortCols[n].Flags = nFlags
.head 8 -  !
.head 8 -  Set n = n + 1
.head 6 -  Set frmMain.wnSortCols = n
.head 5 -  Set frmMain.wnSortMinRow = dfMinRow
.head 5 -  Set frmMain.wnSortMaxRow = dfMaxRow

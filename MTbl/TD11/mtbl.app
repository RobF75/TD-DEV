.head 5 -  Set nChildRow = MTblGetFirstChildRow( frmMain.tbl1, nRow )
.head 5 +  While nChildRow != TBL_Error
.head 6 -  Call SalListAdd( lbChildRows, SalNumberToStrX( nChildRow, 0 ) )
.head 6 -  Set nChildRow = MTblGetNextChildRow( frmMain.tbl1, nChildRow )

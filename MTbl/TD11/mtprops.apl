.head 11 -  Break VALIDATE
.head 9 -  !
.head 9 -  Set nMax = GetMaxDataLen( )
.head 9 +  If nMax > 0
.head 10 +  If SalStrLength( sVal ) > nMax
.head 11 -  Set bOk = FALSE
.head 11 -  Set r_sMsg = "Value's data length is above maximum"
.head 11 -  Break VALIDATE
.head 9 -  !
.head 9 -  Break VALIDATE
.head 7 -  !
.head 7 -  Return bOk

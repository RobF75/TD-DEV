.head 4 +  Actions
.head 5 +  If sTBCompany = 'Z'
.head 6 -  Set sCompName = 'Zee Sweet '
.head 5 +  Else
.head 6 -  Set sCompName = 'Flemings '
.head 5 +  If NOT GetRegistryValue('ACCOUNTS', 'TBCSVPath', sPath, 'C:\Temp' )
.head 6 -  Call SetRegistryValue( 'ACCOUNTS', 'TBCSVPath', 'c:\centura\csvs\trialbal' , 'C:\Temp' )
.head 5 -  ! Set sPath = OurGetIniFileParameter( 'ACCOUNTS', 'TBCSVPath', OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'c:\\temp' ) )
.head 5 -  Set sPath = sPath||'\\'||sCompName||'TB'|| SalStrRightX( SalNumberToStrX( SalDateYear( dtRolloverDate ), 0 ), 1 ) || SalNumberToStrX( 
SalDateConstruct( SalDateYear( dtRolloverDate ), 
SalDateMonth( dtRolloverDate ), SalDateDay( dtRolloverDate ), 0, 0, 0 ) - 
SalDateConstruct( SalDateYear( dtRolloverDate ), 1, 1, 0, 0, 0 ), 0 )||'.rtf'
.head 5 -  Return sPath
.head 5 -  ! Return 'c:\\temp\\tb'|| SalNumberToStrX( 
SalDateConstruct( SalDateYear( dtRolloverDate ), 
SalDateMonth( dtRolloverDate ), SalDateDay( dtRolloverDate ), 0, 0, 0 ) - 

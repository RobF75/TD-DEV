.head 8 -  Set bCustCSVFileOpen = FALSE
.head 7 -  !
.head 7 -  Set sCSVFile = OurGetIniFileParameter( 'ACCOUNTS', 'StatementsCSVPath', 'c:\\temp' ) || '\\' || MakeCustStatementCSVFileName( colAssCustNo, SalDateYear( colRolloverDate ), sReportFileName )
.head 7 +  If SalFileOpen( hCustInvCSVFile, sCSVFile, OF_Create | OF_Write | OF_Text )
.head 8 -  Set bCustCSVFileOpen = TRUE
.head 7 +  Else
.head 8 +  If CreateFileStructure('CSVFiles')
.head 9 +  If SalFileOpen( hCustInvCSVFile, sCSVFile, OF_Create | OF_Write | OF_Text )
.head 10 -  Set bCustCSVFileOpen = TRUE
.head 9 +  Else
.head 10 -  Set bOk = FALSE
.head 6 -  !

.head 3 -  String: sErrmsg
.head 3 -  String: sNum
.head 2 +  Named Menus
.head 2 +  Internal Functions
.head 3 -  !
.head 3 +  ! Function: StrCSVTokenize
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  Number: 
.head 4 +  Parameters 
.head 5 -  String: sCSVLine
.head 5 -  Receive String: sCSVFields[*]
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  Number: nFieldPos
.head 5 -  Number: nCharPos
.head 5 -  Number: nNumChars
.head 5 -  String: sField
.head 5 -  String: sPosChar
.head 5 -  Boolean: bQuoteOpen
.head 4 +  Actions 
.head 5 -  Set nNumChars = SalStrLength( sCSVLine )
.head 5 -  Set nFieldPos = 0
.head 5 -  Set sCSVFields[ nFieldPos ] = ''
.head 5 -  Set nCharPos = 0
.head 5 -  Set sField = ''
.head 5 +  While nCharPos < nNumChars
.head 6 -  Set sPosChar = SalStrMidX( sCSVLine, nCharPos, 1 )
.head 6 -  !
.head 6 +  If sPosChar = '"'
.head 7 +  If bQuoteOpen
.head 8 -  Set bQuoteOpen = FALSE
.head 7 +  Else 
.head 8 -  Set bQuoteOpen = TRUE
.head 6 +  Else If sPosChar = ',' AND NOT bQuoteOpen
.head 7 -  Set bQuoteOpen = FALSE
.head 7 -  Set sCSVFields[ nFieldPos ] = sField
.head 7 -  Set nFieldPos = nFieldPos + 1
.head 7 -  Set sCSVFields[ nFieldPos ] = ''
.head 7 -  Set sField = ''
.head 6 +  Else 
.head 7 -  Set sField = sField || sPosChar
.head 6 -  Set nCharPos = nCharPos + 1
.head 5 -  Set sCSVFields[ nFieldPos ] = sField
.head 5 -  Set nFieldPos = nFieldPos + 1
.head 5 -  Set sCSVFields[ nFieldPos ] = ''
.head 5 -  Return nFieldPos
.head 3 -  !
.head 3 +  Function: ValidRegion
.head 4 -  Description: Validate the region entered, if selected then this isnt called as this
is done from a sam-validate message
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Set sgSql = 'SELECT REGION_ID FROM REGION
 WHERE REGION_ID = :hWndForm.dfRegion'
.head 5 +  If NOT RowIdExists( sgSql )
.head 6 -  Call SalMessageBox( 'Region entered does not exist. Please select a region
from the list of valid regions', 'Customer Master', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  Else
.head 6 -  Return TRUE
.head 3 +  Function: ValidCustType
.head 4 -  Description: Validate the customer type entered, if selected then this isnt called as this
is done from a sam-validate message
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Set sgSql = 'SELECT CUST_TYPE FROM CUSTOMER_TYPE
 WHERE CUST_TYPE = :hWndForm.dfCusttype'
.head 5 +  If NOT RowIdExists( sgSql )
.head 6 -  Call SalMessageBox( 'Customer Type entered does not exist. Please select
 a Customer Type from the list of valid types', 'Customer Master', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  Else
.head 6 -  Return TRUE
.head 3 +  Function: GetCustomerNo
.head 4 -  Description: Dependent on the postcode the user entered for the new customer
use the first byte of the postcode to read the customer file for the last
customer no used for that prefix 
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nLoCustno
.head 5 -  Number: nHiCustno
.head 5 -  Number: nInd
.head 5 -  String: sLoCustno
.head 5 -  String: sHiCustno
.head 5 -  Boolean: bLocalSqlNext
.head 5 -  Sql Handle: hLocalSqlNext
.head 4 +  Actions
.head 5 -  ! LOCAL SQL HANDLE CONNECTION, DISCONNECT on exit pointS
.head 5 -  Set bLocalSqlNext = SqlConnect( hLocalSqlNext ) 
.head 5 +  If bLocalSqlNext
.head 6 -  Call SqlSetLockTimeout( hLocalSqlNext, SQLTIMEOUT )
.head 5 +  Else
.head 6 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -  Return FALSE
.head 5 -  !
.head 5 -  ! At this point we know that the state for this customer has been selected
.head 5 +  If frmCustTab.cmbState = 'NT'
.head 6 -  Set nLoCustno = 080000
.head 6 -  Set nHiCustno = 099999 
.head 5 +  Else If frmCustTab.cmbState = 'NSW'
.head 6 -  Set nLoCustno = 200000
.head 6 -  Set nHiCustno = 299999
.head 5 +  Else If frmCustTab.cmbState = 'ACT'
.head 6 -  Set nLoCustno = 200000
.head 6 -  Set nHiCustno = 299999
.head 5 +  Else If frmCustTab.cmbState = 'VIC'
.head 6 -  Set nLoCustno = 300000
.head 6 -  Set nHiCustno = 399999
.head 5 +  Else If frmCustTab.cmbState = 'QLD'
.head 6 -  Set nLoCustno = 400000
.head 6 -  Set nHiCustno = 499999
.head 5 +  Else If frmCustTab.cmbState = 'SA'
.head 6 -  Set nLoCustno = 500000
.head 6 -  Set nHiCustno = 599999
.head 5 +  Else If frmCustTab.cmbState = 'WA'
.head 6 -  Set nLoCustno = 600000
.head 6 -  Set nHiCustno = 699999
.head 5 +  Else If frmCustTab.cmbState = 'TAS'
.head 6 -  Set nLoCustno = 700000
.head 6 -  Set nHiCustno = 799999
.head 5 -  Call SalNumberToStr( nLoCustno, 0, sLoCustno )
.head 5 -  Call SalNumberToStr( nHiCustno, 0, sHiCustno )
.head 5 -  Set sgSql = 'SELECT MAX( CUST_NO ) + 1 FROM CUSTOMER_MASTER 
INTO :frmCustTab.dfCustno WHERE CUSTOMER_MASTER.CUST_NO  
BETWEEN '||sLoCustno||' AND '||sHiCustno
.head 5 +  If SqlPrepare( hLocalSqlNext, sgSql )
.head 6 +  If SqlExecute( hLocalSqlNext )
.head 7 -  Call SqlFetchNext( hLocalSqlNext, nInd )
.head 7 +  If SalIsNull( frmCustTab.dfCustno )
.head 8 -  Set frmCustTab.dfCustno = nLoCustno
.head 7 -  Call SalSetFieldEdit( frmCustTab.dfCustno, TRUE )
.head 7 +  If bLocalSqlNext
.head 8 -  Call SqlDisconnect( hLocalSqlNext )
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Unable to read Customer Master File for 
customer number.',
 'Stock Item', MB_Ok )
.head 7 +  If bLocalSqlNext
.head 8 -  Call SqlDisconnect( hLocalSqlNext )
.head 7 -  Return FALSE
.head 5 +  Else
.head 6 -  Call SalMessageBox( 'Unable to read Customer Master File for 
customer number.',
 'Stock Item', MB_Ok )
.head 6 +  If bLocalSqlNext
.head 7 -  Call SqlDisconnect( hLocalSqlNext )
.head 6 -  Return FALSE
.head 3 +  Function: GetCustomerState
.head 4 -  Description: Depending on the customer number the user entered for the new 
customer we preset the state that this number falls into.
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  ! At this point we know that a customer number been entered
.head 5 +  If frmCustTab.dfCustno >= 080000 AND frmCustTab.dfCustno <= 099999
.head 6 -  Set frmCustTab.cmbState = 'NT'
.head 5 +  Else If frmCustTab.dfCustno >= 200000 AND frmCustTab.dfCustno <= 299999
.head 6 -  Set frmCustTab.cmbState = 'NSW'
.head 5 +  Else If frmCustTab.dfCustno >= 300000 AND frmCustTab.dfCustno <= 399999
.head 6 -  Set frmCustTab.cmbState = 'VIC'
.head 5 +  Else If frmCustTab.dfCustno >= 400000 AND frmCustTab.dfCustno <= 499999
.head 6 -  Set frmCustTab.cmbState = 'QLD'
.head 5 +  Else If frmCustTab.dfCustno >= 500000 AND frmCustTab.dfCustno <= 599999
.head 6 -  Set frmCustTab.cmbState = 'SA'
.head 5 +  Else If frmCustTab.dfCustno >= 600000 AND frmCustTab.dfCustno <= 699999
.head 6 -  Set frmCustTab.cmbState = 'WA'
.head 5 +  Else If frmCustTab.dfCustno >= 700000 AND frmCustTab.dfCustno <= 799999
.head 6 -  Set frmCustTab.cmbState = 'TAS'
.head 5 -  Call SalSetFieldEdit( frmCustTab.cmbState, TRUE )
.head 5 -  Call SalSetFocus( frmCustTab.dfCustname)
.head 3 -  !
.head 3 -  ! FUNCTIONS TO APPLY AND UNAPPLY TRANSACTIONS
.head 3 +  Function: ApplyTransRow
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nColTransAmount
.head 5 -  Receive Number: nColAmtOuts
.head 5 -  Number: nColAmtApply
.head 5 -  Receive Number: ndfStillToApply
.head 5 -  Receive Date/Time: dtColAppDate
.head 5 -  Receive Date/Time: dtApplyDate
.head 5 -  Receive Number: nTotalUnApplied
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nTmpAmtOuts
.head 5 -  Number: nTmpStillToApply
.head 5 -  Number: nTmpTotalUnApplied
.head 4 +  Actions
.head 5 -  Set nTmpAmtOuts = nColAmtOuts
.head 5 -  Set nTmpStillToApply = ndfStillToApply
.head 5 -  Set nTmpTotalUnApplied = nTotalUnApplied
.head 5 +  If DoTransApply( nColTransAmount, nTmpAmtOuts, nColAmtApply, nTmpStillToApply, nTmpTotalUnApplied )
.head 6 -  Set nColAmtOuts = nTmpAmtOuts
.head 6 -  Set ndfStillToApply = nTmpStillToApply
.head 6 -  Set nTotalUnApplied = nTmpTotalUnApplied
.head 6 +  If dtColAppDate = DATETIME_Null
.head 7 -  Set dtColAppDate = dtApplyDate
.head 6 +  Else
.head 7 -  Set dtApplyDate = dtColAppDate
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 3 +  Function: ApplyTransRowToDeposit
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nColTransAmount
.head 5 -  Receive Number: nColAmtOuts
.head 5 -  Number: nColAmtApply
.head 5 -  Receive Number: nStillToApply
.head 5 -  Receive Date/Time: dtColAppDate
.head 5 -  Receive Date/Time: dtApplyDate
.head 5 -  Receive Number: nTotalUnAppliedDeposit
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nTmpAmtOuts
.head 5 -  Number: nTmpStillToApply
.head 5 -  Number: nTmpTotalUnApplied
.head 4 +  Actions
.head 5 -  Set nTmpAmtOuts = nColAmtOuts - nTmpTotalUnApplied
.head 5 -  Set nTmpStillToApply = nStillToApply
.head 5 -  Set nTmpTotalUnApplied = nTotalUnAppliedDeposit
.head 5 +  If nColAmtOuts > nTmpStillToApply
.head 6 -  Set nColAmtApply = nTmpTotalUnApplied
.head 5 +  If DoTransApply( nColTransAmount, nTmpAmtOuts, nColAmtApply, nTmpStillToApply, nTmpTotalUnApplied )
.head 6 -  Set nColAmtOuts = nTmpAmtOuts
.head 6 -  Set nStillToApply = nTmpStillToApply
.head 6 -  Set nTotalUnAppliedDeposit = nTmpTotalUnApplied
.head 6 +  If dtColAppDate = DATETIME_Null
.head 7 -  Set dtColAppDate = dtApplyDate
.head 6 +  Else
.head 7 -  Set dtApplyDate = dtColAppDate
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 3 +  Function: DoTransApply
.head 4 -  Description: Apply logic, returns true if we havent over applied
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nColTransAmount
.head 5 -  Receive Number: nColAmtOuts
.head 5 -  Number: nColAmtApply
.head 5 -  Receive Number: nStillToApply
.head 5 -  Receive Number: nTotalUnApplied
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If nColAmtApply > 0
.head 6 -  Set nStillToApply = nStillToApply - nColAmtApply
.head 6 -  Set nTotalUnApplied = nTotalUnApplied - nColAmtApply
.head 6 +  If nColAmtOuts > 0
.head 7 -  Set nColAmtOuts = nColAmtOuts - nColAmtApply
.head 6 +  Else
.head 7 -  Set nColAmtOuts = nColTransAmount - nColAmtApply
.head 5 +  Else
.head 6 +  If nColAmtOuts > 0
.head 7 -  Set nStillToApply = nStillToApply - nColAmtOuts
.head 7 -  Set nTotalUnApplied = nTotalUnApplied - nColAmtOuts
.head 6 +  Else
.head 7 -  Set nStillToApply = nStillToApply - nColTransAmount
.head 7 -  Set nTotalUnApplied = nTotalUnApplied - nColTransAmount
.head 6 -  Set nColAmtOuts = 0
.head 5 +  If nStillToApply >= 0
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 3 +  Function: UnApplyTransRow
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nColTransAmount
.head 5 -  Receive Number: nColAmtOuts
.head 5 -  Number: nColOrgAmtOuts
.head 5 -  Receive Number: nColAmtApply
.head 5 -  Receive Number: ndfStillToApply
.head 5 -  Receive Date/Time: dtColAppDate
.head 5 -  Number: nAmtReceipt
.head 5 -  Receive Number: nTotalUnApplied
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nTmpAmtOuts
.head 5 -  Number: nTmpStillToApply
.head 5 -  Number: nTmpAmtApply
.head 5 -  Number: nTmpTotalUnApplied
.head 4 +  Actions
.head 5 -  Set nTmpAmtOuts = nColAmtOuts
.head 5 -  Set nTmpStillToApply = ndfStillToApply
.head 5 -  Set nTmpAmtApply = nColAmtApply
.head 5 -  Set nTmpTotalUnApplied = nTotalUnApplied
.head 5 +  If DoTransUnApply( nColTransAmount, nTmpAmtOuts, nColOrgAmtOuts, nTmpAmtApply, nTmpStillToApply, nAmtReceipt, nTmpTotalUnApplied )
.head 6 -  Set nColAmtOuts = nTmpAmtOuts
.head 6 -  Set ndfStillToApply = nTmpStillToApply
.head 6 -  Set nTotalUnApplied = nTmpTotalUnApplied
.head 6 -  Set nColAmtApply = nTmpAmtApply
.head 6 -  Set dtColAppDate = DATETIME_Null
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 3 +  Function: DoTransUnApply
.head 4 -  Description: Apply logic, returns true if we havent over applied
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nColTransAmount
.head 5 -  Receive Number: nColAmtOuts
.head 5 -  Number: nColOrgAmtOuts
.head 5 -  Receive Number: nColAmtApply
.head 5 -  Receive Number: ndfStillToApply
.head 5 -  Number: nAmtReceipt
.head 5 -  Receive Number: nTotalUnApplied
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If nColAmtApply > 0
.head 6 -  Set ndfStillToApply = ndfStillToApply + nColAmtApply
.head 6 -  Set nTotalUnApplied = nTotalUnApplied + nColAmtApply
.head 6 -  Set nColAmtOuts = nColAmtOuts + nColAmtApply
.head 6 -  Set nColAmtApply = NUMBER_Null
.head 5 +  Else
.head 6 +  If nColOrgAmtOuts > 0
.head 7 -  Set ndfStillToApply = ndfStillToApply + nColOrgAmtOuts
.head 7 -  Set nTotalUnApplied = nTotalUnApplied + nColOrgAmtOuts
.head 7 -  Set nColAmtOuts = nColOrgAmtOuts
.head 6 +  Else
.head 7 -  Set ndfStillToApply = ndfStillToApply + nColTransAmount
.head 7 -  Set nTotalUnApplied = nTotalUnApplied + nColTransAmount
.head 7 -  Set nColAmtOuts = nColTransAmount
.head 5 +  If ndfStillToApply <= nAmtReceipt
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 3 -  !
.head 3 +  Function: GetTrialBalanceCSVFileName
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  String:
.head 4 +  Parameters
.head 5 -  Date/Time: dtRolloverDate
.head 5 -  String: sTBCompany
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sPath
.head 5 -  String: sCompName
.head 4 +  Actions
.head 5 +  If sTBCompany = 'Z'
.head 6 -  Set sCompName = 'Zee Sweet '
.head 5 +  Else
.head 6 -  Set sCompName = 'Flemings '
.head 5 +  If NOT GetRegistryValue('ACCOUNTS', 'TBCSVPath', sPath, 'C:\Temp' )
.head 6 -  Call SetRegistryValue( 'ACCOUNTS', 'TBCSVPath', 'c:\centura\csvs\trialbal' , 'C:\Temp' )
.head 5 -  ! Set sPath = OurGetIniFileParameter( 'ACCOUNTS', 'TBCSVPath', OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'c:\\temp' ) )
.head 5 -  Set sPath = sPath||'\\'||sCompName||'TB'|| SalStrRightX( SalNumberToStrX( SalDateYear( dtRolloverDate ), 0 ), 1 ) || SalNumberToStrX( 
SalDateConstruct( SalDateYear( dtRolloverDate ), 
SalDateMonth( dtRolloverDate ), SalDateDay( dtRolloverDate ), 0, 0, 0 ) - 
SalDateConstruct( SalDateYear( dtRolloverDate ), 1, 1, 0, 0, 0 ), 0 )||'.csv'
.head 5 -  Return sPath
.head 5 -  ! Return 'c:\\temp\\tb'|| SalNumberToStrX( 
SalDateConstruct( SalDateYear( dtRolloverDate ), 
SalDateMonth( dtRolloverDate ), SalDateDay( dtRolloverDate ), 0, 0, 0 ) - 
SalDateConstruct( SalDateYear( dtRolloverDate ), 1, 1, 0, 0, 0 ), 0 )||'.csv'

.head 6 +  Actions
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  !
.head 9 -  Set nDepAmtPaid = NUMBER_Null
.head 9 -  Set nGotDepAmtPaid = NUMBER_Null
.head 9 -  !
.head 9 +  If sTransTable = 'TRANS_HISTORY'
.head 10 -  Set sSql = " SELECT DepHist_Amt_Paid 
FROM Deposit_History 
WHERE Cust_No = :1 AND 
Trans_Hist_User_Id = :2 AND 
Trans_Hist_SysDT = :3 "
.head 10 -  Set sName = 'INVHISTDEPHIST'
.head 10 -  Set sBind = ':nCustNo, :sTransUserId, :dtTransSysDT'
.head 10 -  Set sInto = ':nGotDepAmtPaid'
.head 10 -  Call fcTransHistHdl.Setup( sSql, sName, sBind, sInto )
.head 10 -  Call SqlVarSetup( fcTransHistHdl.hSqlHandle )
.head 10 -  !
.head 10 +  If fcTransHistHdl.Execute( )
.head 11 +  While fcTransHistHdl.FetchNext( nInd )
.head 12 -  Set nDepAmtPaid = nDepAmtPaid + nGotDepAmtPaid
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 -  Return FALSE
.head 9 +  Else
.head 10 -  Set sSql = " SELECT DepHist_Amt_Paid 
FROM Deposit_History 
WHERE Cust_No = :1 AND 
Trans_User_Id = :2 AND 
Trans_Sysdatetime = :3 "
.head 10 -  Set sName = 'INVDEPHIST'
.head 10 -  Set sBind = ':nCustNo, :sTransUserId, :dtTransSysDT'
.head 10 -  Set sInto = ':nGotDepAmtPaid'
.head 10 -  Call fcTransHdl.Setup( sSql, sName, sBind, sInto )
.head 10 -  Call SqlVarSetup( fcTransHdl.hSqlHandle )
.head 10 -  !
.head 10 +  If fcTransHdl.Execute( )
.head 11 +  While fcTransHdl.FetchNext( nInd )
.head 12 -  Set nDepAmtPaid = nDepAmtPaid + nGotDepAmtPaid
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Call fcTransHdl.Disconnect( )
.head 9 -  Call fcTransHistHdl.Disconnect( )
.head 9 -  Return TRUE
.head 5 +  Function: GetTransNotes
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  String: sTransUserId
.head 7 -  Date/Time: dtTransSysDT

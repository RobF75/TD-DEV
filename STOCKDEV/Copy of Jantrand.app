.head 4 +  Message Actions
.head 5 +  On PAM_UPDATECUST
.head 6 -  Call SalSetFieldEdit( hWndItem, TRUE )
.head 6 -  Call BuildSQL( wParam,hWndItem,'CUSTOMER_MASTER.CUST_AR_BALANCE' )
.head 5 -  ! Adjustarbalance is sent to this field on a row new in tbltransaction so colTransAmount
does apply whereas in all other instances we should be checking if something 
exists in colAmtOuts
.head 5 +  On PAM_ADJUSTARBALANCE
.head 6 +  If wParam = nDR
.head 7 -  Set dfCustARBalance = dfCustARBalance + hWndForm.nTransAmount
.head 7 -  Call AdjustCustARBalance( dfCustNo, hWndForm.nTransAmount, nIncrement, tblTransaction.colTransCompany, SH_cls_Execute )
.head 6 +  Else If wParam = nCR
.head 7 -  Set dfCustARBalance = dfCustARBalance - hWndForm.nTransAmount
.head 7 -  Call AdjustCustARBalance( dfCustNo, hWndForm.nTransAmount, nDecrement, tblTransaction.colTransCompany, SH_cls_Execute )
.head 6 -  Return TRUE
.head 6 -  ! If GetCustARBalance( dfCustNo, dfCustARBalance, SH_cls_Execute )
.head 6 +  ! Else
.head 7 -  Return FALSE
.head 5 +  On PAM_ADJUSTARBALANCEWROFF
.head 6 +  ! If wParam = nDR
.head 7 -                                                                 Set dfCustARBalance = dfCustARBalance + hWndForm.nTransAmount
.head 6 +  If GetCustARBalance( dfCustNo, dfCustARBalance, SH_cls_Execute )
.head 7 +  If wParam = nCR
.head 8 +  If frmTransaction.tblTransaction.colAmtOuts > 0
.head 9 -  ! Set dfCustARBalance = dfCustARBalance - frmTransaction.tblTransaction.colAmtOuts
.head 9 -  Call AdjustCustARBalance( dfCustNo, frmTransaction.tblTransaction.colAmtOuts, nDecrement, tblTransaction.colTransCompany, SH_cls_Execute )
.head 8 +  Else
.head 9 -  Set dfCustARBalance = dfCustARBalance - frmTransaction.tblTransaction.colTransAmount
.head 9 -  Call AdjustCustARBalance( dfCustNo, hWndForm.colTransAmount, nDecrement, tblTransaction.colTransCompany, SH_cls_Execute )
.head 7 -  Return TRUE

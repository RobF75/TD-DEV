.head 3 +  Function: AdjustCustTotal
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Receive Number: nCustTotal
.head 5 -  Receive Number: nTransAmount
.head 5 -  Receive Number: nTransGSTAmount
.head 5 -  String: sTransCode
.head 5 -  String: sTransType
.head 5 -  Long String: sTransNotes
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If sTransCode = 'DR'
.head 6 -  Set nCustTotal = nCustTotal + nTransAmount
.head 5 +  Else If sTransCode = 'CR'
.head 6 +  ! If sTransType = 'INVOICE'
.head 7 +  If sTransNotes = 'Uninvoiced' OR sTransNotes = 'CANCELLED'
.head 8 -  Set nTransAmount = nTransAmount * -1
.head 8 -  Set nTransGSTAmount = nTransGSTAmount * -1
.head 7 +  ! If sTransNotes = 'Uninvoiced'
.head 8 -                                                                 Set nTransAmount = nTransAmount * -1
.head 7 -  Set nCustTotal = nCustTotal + nTransAmount
.head 6 -  ! Else
.head 6 -  Set nCustTotal = nCustTotal - nTransAmount
.head 6 -  Set nTransAmount = nTransAmount * -1
.head 6 -  Set nTransGSTAmount = nTransGSTAmount * -1
.head 5 -  Return TRUE

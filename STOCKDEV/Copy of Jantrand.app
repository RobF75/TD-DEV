.head 4 +  Message Actions
.head 5 +  On PAM_POPULATE
.head 6 -  Call SalSendMsg( frmTransaction.dfTotalUnapplied, PAM_RESET, 0, 0 )
.head 6 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillAll, PAM_SQL )
.head 6 -  Set bTablePopulated = TRUE
.head 5 +  ! On PAM_NOROWS
.head 6 -                                                                 Call SalMessageBox( 'No Cash Receipts were found for this customer!', 'Customer Outstanding Transactions', MB_Ok )
.head 5 +  On PAM_SETROWEDITFLAG
.head 6 +  If NOT wParam
.head 7 -  Call SalTblFetchRow( hWndForm, lParam )
.head 7 +  If NOT colAmtUnApplied = colOrgAmtUnApplied
.head 8 -  Return FALSE
.head 6 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_HideMarks, TRUE )
.head 6 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, wParam )
.head 6 -  Call SalSendMsg( colApplied, PAM_ROWAPPLIED, wParam, 0 )
.head 5 +  On PAM_CLEARAPPLIEDROW
.head 6 -  Call SalTblDeleteRow( hWndForm, lParam, TBL_NoAdjust )
.head 5 +  On SAM_FetchRowDone
.head 6 +  If SqlFetchRow( hLocalSqlPopTbl, lParam, nInd )
.head 7 -  Set colOrgAmtUnApplied = colAmtUnApplied
.head 7 -  Set frmTransaction.dfTotalUnapplied = frmTransaction.dfTotalUnapplied + colAmtUnApplied
.head 5 +  On SAM_Create
.head 6 -  Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 -  Set bTablePopulated = FALSE
.head 6 -  Set nAppliedColour = COLOR_Red
.head 6 -  Set sSQLPOPTABLENAME = ' CASH_RECEIPT '
.head 6 -  Set sORDERBY = ' ORDER BY RCPT_SYSDATETIME '
.head 6 -  Set sWHEREUpdtCshRcpt = ' WHERE Receipt_User_Id = :frmTransaction.tblUnAppCash.colRcptUserId AND Rcpt_Sysdatetime = :frmTransaction.tblUnAppCash.colRcptSysDateTime '
.head 6 -  Set bUpdtCshRcptHdlConnected = FALSE
.head 6 -  Set bUpdtCshRcptHdlPrepared = FALSE
.head 5 +  On SAM_Destroy
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlDisconnect( hLocalSqlPopTbl )
.head 6 +  If bUpdtCshRcptHdlConnected
.head 7 -  Call SqlDisconnect( hSqlUpdtCshRcptHdl )

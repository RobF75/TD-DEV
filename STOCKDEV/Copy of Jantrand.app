.head 4 +  Functions
.head 5 +  Function: GetInvoiceDeposit
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  Number: nCustNo
.head 7 -  String: sTransUserId
.head 7 -  Date/Time: dtTransSysDT
.head 7 -  ! sTransTable = 'TRANSACTION' or 'TRANS_HISTORY'
.head 7 -  String: sTransTable
.head 7 -  Receive Number: nDepAmtPaid
.head 7 -  Number: nActionType
.head 6 +  Static Variables
.head 7 -  FunctionalVar: fcTransHdl
.head 8 -  Class: hcSqlHandle
.head 7 -  FunctionalVar: fcTransHistHdl
.head 8 -  Class: hcSqlHandle
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  String: sBind
.head 7 -  String: sInto
.head 7 -  String: sName
.head 7 -  !
.head 7 -  Number: nGotDepAmtPaid
.head 7 -  Number: nInd
.head 6 +  Actions
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  !
.head 9 -  Set nDepAmtPaid = NUMBER_Null
.head 9 -  Set nGotDepAmtPaid = NUMBER_Null
.head 9 -  !
.head 9 +  If sTransTable = 'TRANS_HISTORY'
.head 10 -  Set sSql = " SELECT DepHist_Amt_Paid 
FROM Deposit_History 
WHERE Cust_No = :1 AND 
Trans_Hist_User_Id = :2 AND 
Trans_Hist_SysDT = :3 "
.head 10 -  Set sName = 'INVHISTDEPHIST'
.head 10 -  Set sBind = ':nCustNo, :sTransUserId, :dtTransSysDT'
.head 10 -  Set sInto = ':nGotDepAmtPaid'
.head 10 -  Call fcTransHistHdl.Setup( sSql, sName, sBind, sInto )
.head 10 -  Call SqlVarSetup( fcTransHistHdl.hSqlHandle )
.head 10 -  !
.head 10 +  If fcTransHistHdl.Execute( )
.head 11 +  While fcTransHistHdl.FetchNext( nInd )
.head 12 -  Set nDepAmtPaid = nDepAmtPaid + nGotDepAmtPaid
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 -  Return FALSE
.head 9 +  Else
.head 10 -  Set sSql = " SELECT DepHist_Amt_Paid 
FROM Deposit_History 
WHERE Cust_No = :1 AND 
Trans_User_Id = :2 AND 
Trans_Sysdatetime = :3 "
.head 10 -  Set sName = 'INVDEPHIST'
.head 10 -  Set sBind = ':nCustNo, :sTransUserId, :dtTransSysDT'
.head 10 -  Set sInto = ':nGotDepAmtPaid'
.head 10 -  Call fcTransHdl.Setup( sSql, sName, sBind, sInto )
.head 10 -  Call SqlVarSetup( fcTransHdl.hSqlHandle )
.head 10 -  !
.head 10 +  If fcTransHdl.Execute( )
.head 11 +  While fcTransHdl.FetchNext( nInd )
.head 12 -  Set nDepAmtPaid = nDepAmtPaid + nGotDepAmtPaid
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Call fcTransHdl.Disconnect( )
.head 9 -  Call fcTransHistHdl.Disconnect( )
.head 9 -  Return TRUE
.head 5 +  Function: GetTransNotes
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  String: sTransUserId
.head 7 -  Date/Time: dtTransSysDT
.head 7 -  String: sTableType
.head 7 -  Receive String: lsTransNotes
.head 7 -  Number: nActionType
.head 6 +  Static Variables
.head 7 -  FunctionalVar: fcOurHandle
.head 8 -  Class: hcSqlHandle
.head 7 -  FunctionalVar: fcOurHistHandle
.head 8 -  Class: hcSqlHandle
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  String: sBind
.head 7 -  String: sInto
.head 7 -  String: sName
.head 7 -  Number: nInd
.head 7 -  !
.head 7 -  String: lsGotTransNotes
.head 6 +  Actions
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  !
.head 9 -  Set lsTransNotes = ''
.head 9 -  Set lsGotTransNotes = ''
.head 9 -  !
.head 9 +  If sTableType = 'TRANSACTION'
.head 10 -  Set sSql = " SELECT 
  Transaction_Notes
FROM 
  Transaction
WHERE 
  Trans_User_Id = :1 AND 
  Trans_Sysdatetime = :2 "
.head 10 -  Set sName = 'INVSUMTRNOTES'
.head 10 -  Set sBind = ':sTransUserId, :dtTransSysDT'
.head 10 -  Set sInto = ':lsGotTransNotes'
.head 10 -  Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
.head 10 -  Call SqlVarSetup( fcOurHandle.hSqlHandle )
.head 10 -  !
.head 10 +  If fcOurHandle.Execute( )
.head 11 +  If fcOurHandle.FetchNext( nInd )
.head 12 -  Set lsTransNotes = lsGotTransNotes
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 -  Return FALSE
.head 9 +  Else
.head 10 -  Set sSql = " SELECT 
  Hist_Trans_Notes
FROM 
  Trans_History
WHERE 
  Trans_Hist_User_Id = :1 AND 
  TrHist_Sysdatetime = :2 "
.head 10 -  Set sName = 'INVSUMTRNOTEHS'
.head 10 -  Set sBind = ':sTransUserId, :dtTransSysDT'
.head 10 -  Set sInto = ':lsGotTransNotes'
.head 10 -  Call fcOurHistHandle.Setup( sSql, sName, sBind, sInto )
.head 10 -  Call SqlVarSetup( fcOurHistHandle.hSqlHandle )
.head 10 -  !
.head 10 +  If fcOurHistHandle.Execute( )
.head 11 +  If fcOurHistHandle.FetchNext( nInd )
.head 12 -  Set lsTransNotes = lsGotTransNotes
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Set bOk = TRUE
.head 9 +  If NOT fcOurHandle.Disconnect( )
.head 10 -  Set bOk = FALSE
.head 9 +  If NOT fcOurHistHandle.Disconnect( )
.head 10 -  Set bOk = FALSE
.head 9 -  Return bOk

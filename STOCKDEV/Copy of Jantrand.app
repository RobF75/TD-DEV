.head 6 +  Menu Actions
.head 7 -  Call SalWaitCursor( TRUE )
.head 7 -  Set bSummaryTB = FALSE
.head 7 -  Set sCompany = 'F'
.head 7 -  Set nTBType = nSelectedCustomers
.head 7 -  Set nNumCust = 0
.head 7 -  Set nRow = TBL_MinRow
.head 7 +  Select Case nWhichTableActive
.head 8 +  Case nCustomerTbl
.head 9 +  If NOT SalTblAnyRows( tblQCustomer, ROW_Selected, 0 )
.head 10 -  Set nTBType = nAllCustomers
.head 9 +  Else
.head 10 +  While SalTblFindNextRow( tblQCustomer, nRow, ROW_Selected, 0 )
.head 11 -  Call SalTblFetchRow( tblQCustomer, nRow )
.head 11 -  Set nNumCust = nNumCust + 1
.head 11 -  Set nCustNos[nNumCust-1] = tblQCustomer.colCustNo
.head 10 -  Set nCustNos[nNumCust] = NUMBER_Null
.head 9 -  Break
.head 8 +  Case nCustAddrTbl
.head 9 +  If NOT SalTblAnyRows( tblQCustAddr, ROW_Selected, 0 )
.head 10 -  Set nTBType = nAllCustomers
.head 9 +  Else
.head 10 +  While SalTblFindNextRow( tblQCustAddr, nRow, ROW_Selected, 0 )
.head 11 -  Call SalTblFetchRow( tblQCustAddr, nRow )
.head 11 -  Set nNumCust = nNumCust + 1
.head 11 -  Set nCustNos[nNumCust-1] = tblQCustAddr.colCustNo
.head 10 -  Set nCustNos[nNumCust] = NUMBER_Null
.head 9 -  Break
.head 8 +  Case nCustContTbl
.head 9 +  If NOT SalTblAnyRows( tblQCustCont, ROW_Selected, 0 )
.head 10 -  Set nTBType = nAllCustomers
.head 9 +  Else
.head 10 +  While SalTblFindNextRow( tblQCustCont, nRow, ROW_Selected, 0 )
.head 11 -  Call SalTblFetchRow( tblQCustCont, nRow )
.head 11 -  Set nNumCust = nNumCust + 1
.head 11 -  Set nCustNos[nNumCust-1] = tblQCustCont.colCustNo
.head 10 -  Set nCustNos[nNumCust] = NUMBER_Null
.head 7 +  If SalModalDialog( dlgNewGetDateSelect, hWndForm, nTBType )
.head 8 +  If nTBType = nSelectedCustomers
.head 9 +  If IDNO =  SalMessageBox( 'You will be unable to update the monthly AR table for the selected customers option.  
 Do you wish to continue?', 'Month End', MB_YesNo )
.head 10 -  Call SalWaitCursor( FALSE )
.head 9 +  Else
.head 10 -  Call PopDateTime( dtRolloverDate, TRUE )
.head 10 -  Call SalCreateWindow( frmPrintTrialBalance, hWndForm, nCustNos, nNumCust, dtRolloverDate, nPrintTrialBalSt, nTBType, bSummaryTB, sCompany )

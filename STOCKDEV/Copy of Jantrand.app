.head 4 +  Message Actions
.head 5 +  On SAM_Click
.head 6 +  If IDOK = SalMessageBox( 'Are you sure you wish to recalculate the AR Balance for 
the selected customers??  ',
 'Recalc AR', MB_OkCancel )
.head 7 +  Select Case nWhichTableActive
.head 8 +  Case nCustomerTbl
.head 9 +  If NOT SalTblAnyRows( tblQCustomer, ROW_Selected, 0 )
.head 10 +  If IDYES = SalMessageBox( 'No Customer selected, do you wish to recalculate all customers', 'Query Customer', MB_YesNo )
.head 11 -  Call GetAllCustNos( naCustNos, nCount, SH_cls_Execute )
.head 11 -  Call SalCreateWindow( dlgMeterProgress, hWndForm, 'Resetting All Cust AR Balance', nCount )
.head 11 -  Set nCount = 0
.head 11 +  While naCustNos[nCount] != NUMBER_Null
.head 12 +  If NOT RecalcAR( naCustNos[nCount], SH_cls_Execute )
.head 13 -  Call SalMessageBox( 'Error in recalculating customers AR Balance',

.head 6 -                                                                 Call MyTableLoop( hWndForm, hWndForm,  PAM_CHECKMISSINVNOS, 0, 0, 'Checking for Missing Invoice Numbers.', nLowToHi )
.head 5 +                                                                 On PAM_SETSGSQL
.head 6 -                                                                 Set sgSql = " SELECT  
  Transaction.Cust_No,
  Customer_Master.Cust_Name, 
  @VALUE( Transaction.Reference_Id ), 
  Transaction.Reference_Id, 
  Transaction.Transaction_Date,
  Transaction.Transaction_Amount,
  Transaction.Label_Charges,
  Transaction.Postal_Charges,
  Transaction.Freight_Charges,
  Transaction.Rail_Charges,
  Transaction.Royalties,
  Transaction.Trans_User_Id,
  Transaction.Trans_SysDateTime, 
  'TRANSACTION'
FROM  
  Transaction,
  Customer_Master
WHERE 
  Customer_Master.Cust_No = Transaction.Cust_No AND 
  Transaction.Transaction_Date >= :frmPrintInvSummary.dfReportFromDate AND 
  Transaction.Transaction_Date <= :frmPrintInvSummary.dfReportToDate AND
  Transaction.Transaction_Type = 'INVOICE'
UNION ALL
SELECT  
 Trans_History.Cust_No,
 Customer_Master.Cust_Name,
 @VALUE( Trans_History.Hist_Reference_Id ), 
 Trans_History.Hist_Reference_Id,
 Trans_History.Hist_Trans_Date,
 Trans_History.Hist_Trans_Amount,
 Trans_History.Hist_Label_Charges,
 Trans_History.Hist_Postal_Charge,
 Trans_History.Hist_Freight_Charg,
 Trans_History.Hist_Rail_Charges,
 Trans_History.Royalties,
 Trans_History.Trans_Hist_User_Id,
 Trans_History.TrHist_SysDateTime, 
 'TRANS_HISTORY'
FROM  
  Trans_History, 
  Customer_Master  
WHERE 
  Customer_Master.Cust_No = Trans_History.Cust_No AND 
  Trans_History.Hist_Trans_Date >= :frmPrintInvSummary.dfReportFromDate AND 
  Trans_History.Hist_Trans_Date <= :frmPrintInvSummary.dfReportToDate AND
  Trans_History.Hist_Trans_Type = 'INVOICE' 
INTO 
  :frmPrintInvSummary.tblInvSummary.colTransCustNo, 
  :frmPrintInvSummary.tblInvSummary.colCustName, 
  :frmPrintInvSummary.tblInvSummary.colNumericTransRefId, 
  :frmPrintInvSummary.tblInvSummary.colTransRefId, 
  :frmPrintInvSummary.tblInvSummary.colTransDate, 
  :frmPrintInvSummary.tblInvSummary.colTransAmount, 
  :frmPrintInvSummary.tblInvSummary.colTransLabelChrg, 
  :frmPrintInvSummary.tblInvSummary.colTransPostalChrg, 
  :frmPrintInvSummary.tblInvSummary.colTransFreightChrg, 
  :frmPrintInvSummary.tblInvSummary.colTransRailChrg, 
  :frmPrintInvSummary.tblInvSummary.colTransRoyalties, 
  :frmPrintInvSummary.tblInvSummary.colTransUserId, 
  :frmPrintInvSummary.tblInvSummary.colTransSysDT, 
  :frmPrintInvSummary.tblInvSummary.colTransTable 
ORDER BY 3 "
.head 6 -                                                                 Return TRUE
.head 5 +                                                                 On SAM_FetchRowDone
.head 6 -  Call GetInvoiceDeposit( colTransCustNo, colTransUserId, colTransSysDT, colTransTable, colDepAmtPaid, SH_cls_Execute )
.head 6 -                                                                 Set colDepAmtPaid = colDepAmtPaid * -1
.head 5 +                                                                 On PAM_ROWACTION
.head 6 -                                                                 Set dfTotRail = dfTotRail + colTransRailChrg
.head 6 -                                                                 Set dfTotPostal = dfTotPostal + colTransPostalChrg
.head 6 -                                                                 Set dfTotFreight = dfTotFreight + colTransFreightChrg
.head 6 -                                                                 Set dfTotLabels = dfTotLabels + colTransLabelChrg
.head 6 -                                                                 Set dfTotDeposits = dfTotDeposits + colDepAmtPaid
.head 6 -                                                                 Set dfTotRoyalties = dfTotRoyalties + colTransRoyalties
.head 6 -                                                                 Set dfTotInvoices = dfTotInvoices + colTransAmount
.head 6 -                                                                 Set dfNoInv = dfNoInv + 1
.head 6 -                                                                 Return TRUE
.head 5 +                                                                 On PAM_CHECKMISSINVNOS
.head 6 +                                                                 If NOT nLastInvoiceNo + 1 = colNumericTransRefId
.head 7 -  Call GetInvoiceNoRegisterDetails( nLastInvoiceNo + 1, dtInvoiceDate, sStatus, 
sRunType, nYearOfSale, sLoadId, nCustNo, sUserId, SH_cls_Execute )
.head 7 +                                                                 If sStatus = 'ONSCREEN'
.head 8 -                                                                 Set nNewRow = SalTblInsertRow( hWndForm, lParam )
.head 8 -                                                                 Call SalTblSetContext( hWndForm, nNewRow )
.head 8 -                                                                 Call SalTblSetRowFlags( hWndForm, nNewRow, ROW_HideMarks, TRUE )
.head 8 +                                                                 If nCustNo > 0
.head 9 -                                                                 Set colTransCustNo = nCustNo
.head 8 -                                                                 Set colCustName = 'Canceled from Screen'
.head 8 -                                                                 Set colTransRefId = SalNumberToStrX( nLastInvoiceNo + 1, 0 )
.head 8 -                                                                 Set colTransDate = dtInvoiceDate
.head 8 -                                                                 Set colTransUserId = sUserId
.head 8 -                                                                 Set nLastInvoiceNo = nLastInvoiceNo + 1
.head 8 -  ! Set dfNoInv = dfNoInv - 1
.head 8 -                                                                 Return TRUE
.head 6 -                                                                 Set nLastInvoiceNo = colNumericTransRefId
.head 6 -                                                                 Return TRUE
.head 5 +                                                                 On PAM_RESET
.head 6 -                                                                 Call PushWndHdl( hWndNULL )
.head 6 -                                                                 Call SalSendClassMessage( PAM_RESET, wParam, lParam )
.head 5 +                                                                 On PAM_NOROWS
.head 6 -                                                                 Return TRUE

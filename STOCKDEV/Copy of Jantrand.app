.head 5 -  Number: nLastCustNo
.head 5 -  !
.head 5 -  Number: nTransMonth
.head 5 -  Number: nRolloverMonth
.head 5 -  Number: nMonthsTerm
.head 5 -  Date/Time: dtTransDate
.head 5 -  !
.head 5 -  Window Handle: hWndMeter
.head 5 -  Number: nRowCount
.head 5 -  Number: nTotalRows
.head 5 -  String: sSql
.head 5 -  String: sName
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  Number: nSqlHandleNo
.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CALCSVCCHGC' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql =  " SELECT Cust_No,
 Reference_Id,
 Transaction_Date,
 Trans_Amount_Outst
  FROM Transaction 
   WHERE Transaction_Date <= :1 AND 
  ( Transaction_Type = 'INVOICE'  OR Transaction_Type = 'DEBIT' ) AND 
    Trans_Amount_Outst > 0 and
  Company = :2
     ORDER BY CUST_NO"
.head 7 -  Set sName = 'CALCSVCCHGC'
.head 7 -  Set sBind = ':dtRolloverDate, :sTransCompany'
.head 7 -  Set sInto = ':nCustNo, :sReferenceId, :dtTransDate, :nTransAmountOutst '
.head 7 -  !
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 +  If haSqlHandles[nSqlHandleNo].Execute( )
.head 8 -  Call haSqlHandles[nSqlHandleNo].ResultSetCount( nTotalRows )
.head 8 -  Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Calculating Service Charges', nTotalRows )
.head 8 -  Set nRowCount = 0
.head 8 -  !
.head 8 -  Set nLastCustNo = NUMBER_Null
.head 8 -  Set bFirstCustNo = TRUE
.head 8 -  Set nSvcChgAmount = 0
.head 8 +  While haSqlHandles[nSqlHandleNo].FetchNext( nInd )
.head 9 -  !
.head 9 -  !
.head 9 -  ! While debugging stop at a customer that you want 
.head 9 +  ! If nCustNo = 310495
.head 10 -  Call SalMessageBox('At cust no for debug','Stop now',MB_Ok)
.head 9 -  !
.head 9 -  !
.head 9 -  Set nRowCount = nRowCount + 1
.head 9 -  Call SalSendMsg( hWndMeter, PAM_clsMTR_SETPROGRESS, 0, nRowCount )
.head 9 -  ! Get next record, check if current cust has another entry, then go
back to the record we had.
.head 9 -  Set nPreviousCustNo = nCustNo
.head 9 +  If haSqlHandles[nSqlHandleNo].FetchNext( nInd )
.head 10 +  If nCustNo = nPreviousCustNo
.head 11 -  Set bChangeOfCustNo = FALSE
.head 10 +  Else
.head 11 -  Set bChangeOfCustNo = TRUE
.head 10 -  Call haSqlHandles[nSqlHandleNo].FetchPrevious( nInd )
.head 9 +  Else
.head 10 -  Set bChangeOfCustNo = TRUE
.head 9 -  ! If this is the first time we get this cust then we need to get their details
.head 9 +  If nLastCustNo != nCustNo
.head 10 -  Call GetCustSvcChgDetails( nCustNo, nCustARBalance, nInitCreditTerm, dtSvcChgFromDate, nSvcChg, SH_cls_Execute )
.head 10 -  Call GetCustTotalUnAppliedCash( nCustNo, nUnAppliedCash, sTransCompany, SH_cls_Execute )
.head 10 -  Call GetCustTotalUnAppliedCredits( nCustNo, nUnAppliedCredits, sTransCompany, SH_cls_Execute )
.head 10 -  Set nUnAppliedCash = nUnAppliedCash + nUnAppliedCredits
.head 10 -  Set nLastCustNo = nCustNo
.head 9 -  ! GF This next line is the problem , I believe the dtSvcChgFromDate changes when a
transaction is entered so the date is reset. If this is the case then service charges do
not get applied from earlier invoices.
I am going to comment out this next if, And promote the code underneath.
.head 9 -  ! If NOT dtSvcChgFromDate > dtRolloverDate
.head 9 -  ! See how much money they owe, if they have over paid then they
no longer owe us anything
.head 9 +  If nTransAmountOutst >= nUnAppliedCash
.head 10 -  Set nTransAmountOutst = nTransAmountOutst - nUnAppliedCash
.head 10 -  Set nUnAppliedCash = 0
.head 10 -  Set nUnAppliedCredits = 0
.head 9 +  Else
.head 10 -  Set nTransAmountOutst = 0
.head 10 -  Set nUnAppliedCash = nUnAppliedCash - nTransAmountOutst
.head 9 -  ! We don't apply service charges on balances less than $5? 
.head 9 +  If nTransAmountOutst > nMinARBal
.head 10 -  Set nTransMonth = SalDateMonth( dtTransDate )
.head 10 -  Set nRolloverMonth = SalDateMonth( dtRolloverDate )
.head 10 -  Set nMonthsTerm = nInitCreditTerm / 30
.head 10 +  If MonthDifference( dtTransDate, dtRolloverDate ) > nMonthsTerm
.head 11 -  Set nSvcChgAmount = nSvcChgAmount + nTransAmountOutst * ( nSvcChg / 100 )
.head 9 -  ! This is the end of the code that was promoted
.head 9 +  If bChangeOfCustNo
.head 10 +  If nSvcChgAmount > 0
.head 11 +  If InsertCalcSvcChg( nCustNo, '', nSvcChgAmount, dtRolloverDate, sTransCompany, SH_cls_Execute )

.head 4 +  Message Actions
.head 5 +  On PAM_POPULATE
.head 6 -  Call SalSendMsg( frmTransHistory.dfTransTotAmtTrans, PAM_RESET, 0, 0 )
.head 6 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillAll, PAM_SQL )
.head 6 -  Set bTablePopulated = TRUE
.head 5 +  On SAM_FetchRowDone
.head 6 +  If SqlFetchRow( hLocalSqlPopTbl, lParam, nInd )
.head 7 +  If colTransCode = 'DR'
.head 8 -  Set colDebit = colTransAmount
.head 8 -  Set colCredit = NUMBER_Null
.head 8 -  Set frmTransHistory.dfTransTotAmtTrans = frmTransHistory.dfTransTotAmtTrans + colAmtOuts
.head 7 +  Else
.head 8 -  Set colDebit = NUMBER_Null
.head 8 -  Set colCredit = colTransAmount
.head 8 -  Set frmTransHistory.dfTransTotAmtTrans = frmTransHistory.dfTransTotAmtTrans - colAmtOuts
.head 5 +  On PAM_NOROWS
.head 6 -  Call SalMessageBox( 'No transactions were found for this customer!', 'Customer Transactions History', MB_Ok )
.head 5 +  On PAM_RESET
.head 6 -  Call SalTblReset( hWndForm )
.head 6 -  Set bTablePopulated = FALSE
.head 5 +  On SAM_Create
.head 6 -  Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 -  Set bTablePopulated = FALSE
.head 6 -  Set sSQLPOPTABLENAME = ' TRANSACTION '
.head 6 -  Set sORDERBY = ' ORDER BY TRANSACTION_DATE DESC '
.head 5 +  On SAM_Destroy
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlDisconnect( hLocalSqlPopTbl )

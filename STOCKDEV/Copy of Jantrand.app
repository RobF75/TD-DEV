.head 3 +  Function: CalcSvcChg
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Date/Time: dtRolloverDate
.head 5 -  String: sTransCompany
.head 5 -  Number: nActionType
.head 4 -  Static Variables

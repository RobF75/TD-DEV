.head 6 +  If bCustCSVFileOpen
.head 7 +  If NOT SalFilePutStr( hCustInvCSVFile, sTmp )
.head 8 -  Call SalFileClose( hCustInvCSVFile )
.head 8 -  Set bCustCSVFileOpen = FALSE
.head 6 -  !
.head 6 -  Return TRUE
.head 5 -  !
.head 5 -  ! ^^
.head 5 +  On PAM_POPULATE
.head 6 +  If nFromCustNo > 0
.head 7 -  Set bPrint = FALSE
.head 6 +  Else
.head 7 -  Set bPrint = TRUE
.head 6 -  !
.head 6 -  Call fcTrialBalanceCSVFile.Setup( GetTrialBalanceCSVFileName( frmPrintTrialBalance.dtRolloverDate, sCompany ), OF_ReadWrite | OF_Text, NUMBER_Null )
.head 6 +  If fcTrialBalanceCSVFile.Open( )
.head 7 -  Call SalTblReset( hWndForm )
.head 7 -  Call fcTrialBalanceCSVFile.Seek (0, FILE_SeekEnd )
.head 7 -  Set nNoRows = fcTrialBalanceCSVFile.Tell( )
.head 7 -  Call fcTrialBalanceCSVFile.Seek (0, FILE_SeekBegin )
.head 7 -  Set nFileCurrRow = 0
.head 7 +  If nNoRows >= nNumRowsToMeter
.head 8 -  Set hWndMeter = SalCreateWindow( dlgMeterProgress, frmPrintTrialBalance, 'Populating Table', nNoRows )
.head 7 +  Else
.head 8 -  Set hWndMeter = hWndNULL
.head 7 +  While fcTrialBalanceCSVFile.Read( sTemp ) AND NOT bCancel
.head 8 -  !
.head 8 -  Set nCSVCounter = 0
.head 8 +  While nCSVCounter <= 31
.head 9 -  Set sCSVFields[nCSVCounter] = ''
.head 9 -  Set nCSVCounter = nCSVCounter + 1
.head 9 -  ! Set sCSVFields[1] = ''
.head 9 -  ! Set sCSVFields[2] = ''
.head 9 -  ! Set sCSVFields[3] = ''
.head 9 -  ! Set sCSVFields[4] = ''
.head 9 -  ! Set sCSVFields[5] = ''
.head 9 -  ! Set sCSVFields[6] = ''
.head 9 -  ! Set sCSVFields[7] = ''
.head 9 -  ! Set sCSVFields[8] = ''
.head 9 -  ! Set sCSVFields[9] = ''

.head 6 +  Actions
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  !
.head 9 -  Set lsTransNotes = ''
.head 9 -  Set lsGotTransNotes = ''
.head 9 -  !
.head 9 +  If sTableType = 'TRANSACTION'
.head 10 -  Set sSql = " SELECT 
  Transaction_Notes
FROM 
  Transaction
WHERE 
  Trans_User_Id = :1 AND 
  Trans_Sysdatetime = :2 "
.head 10 -  Set sName = 'INVSUMTRNOTES'
.head 10 -  Set sBind = ':sTransUserId, :dtTransSysDT'
.head 10 -  Set sInto = ':lsGotTransNotes'
.head 10 -  Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
.head 10 -  Call SqlVarSetup( fcOurHandle.hSqlHandle )
.head 10 -  !
.head 10 +  If fcOurHandle.Execute( )
.head 11 +  If fcOurHandle.FetchNext( nInd )
.head 12 -  Set lsTransNotes = lsGotTransNotes
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 -  Return FALSE
.head 9 +  Else
.head 10 -  Set sSql = " SELECT 
  Hist_Trans_Notes
FROM 
  Trans_History
WHERE 
  Trans_Hist_User_Id = :1 AND 
  TrHist_Sysdatetime = :2 "
.head 10 -  Set sName = 'INVSUMTRNOTEHS'
.head 10 -  Set sBind = ':sTransUserId, :dtTransSysDT'
.head 10 -  Set sInto = ':lsGotTransNotes'
.head 10 -  Call fcOurHistHandle.Setup( sSql, sName, sBind, sInto )
.head 10 -  Call SqlVarSetup( fcOurHistHandle.hSqlHandle )
.head 10 -  !
.head 10 +  If fcOurHistHandle.Execute( )
.head 11 +  If fcOurHistHandle.FetchNext( nInd )
.head 12 -  Set lsTransNotes = lsGotTransNotes
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Set bOk = TRUE
.head 9 +  If NOT fcOurHandle.Disconnect( )
.head 10 -  Set bOk = FALSE
.head 9 +  If NOT fcOurHistHandle.Disconnect( )
.head 10 -  Set bOk = FALSE
.head 9 -  Return bOk
.head 4 +  Window Variables
.head 5 -  !
.head 5 -  Number: nInvoiceNo
.head 5 -  Date/Time: dtInvoiceDate
.head 5 -  String: sStatus
.head 5 -  String: sRunType
.head 5 -  Number: nYearOfSale
.head 5 -  String: sLoadId
.head 5 -  Number: nCustNo
.head 5 -  String: sUserId
.head 5 -  !
.head 5 -  !
.head 5 -  String: sSql
.head 5 -  Number: nInd
.head 5 -  FunctionalVar: fcOurInvNoRegRangeHdl
.head 6 -  Class: hcSqlHandle
.head 5 -  Number: nNewRow
.head 5 -  Boolean: bLoop
.head 5 -  Boolean: bAnotherRegInvNo
.head 5 -  !
.head 4 +  Message Actions
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLTABLENAME = ''
.head 6 -  Set sSQLPOPTABLENAME = ''
.head 6 -  Set sROWID = ''
.head 6 -  Set sSQLWHERE = ''
.head 6 -  Set sORDERBY = ''
.head 6 -  Set bSelectFirstRow = FALSE
.head 6 -  Set nTableFillType = TBL_FillAll
.head 5 +  On PAM_POPULATE
.head 6 -  Call SalSendClassMessage( PAM_POPULATE, wParam, lParam )
.head 6 -  !
.head 6 -  Call MyTableLoop( hWndForm, hWndForm,  PAM_ROWACTION, 0, 0, 'Calculating the totals', nLowToHi )
.head 6 -  !
.head 6 -  Set sSql = " SELECT 
  Invoice_No, 
  Invoice_Date, 
  Status, 
  Run_Type, 
  Year_Of_Sale, 
  Load_Id, 
  Cust_No, 
  User_Id 
FROM Inv_No_Register 
INTO 
  :frmPrintCredNoteSummary.tblInvSummary.nInvoiceNo, 
  :frmPrintCredNoteSummary.tblInvSummary.dtInvoiceDate, 
  :frmPrintCredNoteSummary.tblInvSummary.sStatus, 
  :frmPrintCredNoteSummary.tblInvSummary.sRunType, 
  :frmPrintCredNoteSummary.tblInvSummary.nYearOfSale, 
  :frmPrintCredNoteSummary.tblInvSummary.sLoadId, 
  :frmPrintCredNoteSummary.tblInvSummary.nCustNo, 
  :frmPrintCredNoteSummary.tblInvSummary.sUserId
WHERE  
Invoice_Date BETWEEN :frmPrintCredNoteSummary.dfReportFromDate AND :frmPrintCredNoteSummary.dfReportToDate 
	
ORDER BY Invoice_No "
.head 6 -  Call fcOurInvNoRegRangeHdl.PrepareSetup( sSql )
.head 6 -  Call SqlVarSetup( fcOurInvNoRegRangeHdl.hSqlHandle )
.head 6 -  Call fcOurInvNoRegRangeHdl.PrepareAndExecute( )
.head 6 -  !
.head 6 +  If fcOurInvNoRegRangeHdl.FetchNext( nInd )
.head 7 -  Set bAnotherRegInvNo = TRUE
.head 6 +  Else
.head 7 -  Set bAnotherRegInvNo = FALSE
.head 6 -  Call MyTableLoop( hWndForm, hWndForm,  PAM_CHECKMISSINVNOS, 0, 0, 'Checking for Missing Invoice Numbers.', nLowToHi )
.head 6 -  Return TRUE
.head 5 +  On PAM_SETSGSQL
.head 6 -  Set sgSql = " SELECT  
  Transaction.Cust_No,
  Customer_Master.Cust_Name, 
  @VALUE( Transaction.Reference_Id ), 
  Transaction.Reference_Id, 
  Transaction.Transaction_Date,
  Transaction.Transaction_Amount,
  Transaction.Trans_GST,
  Transaction.Label_Charges,
  Transaction.Postal_Charges,
  Transaction.Freight_Charges,
  Transaction.Rail_Charges,
  Transaction.Royalties,
  Transaction.Trans_User_Id,
  Transaction.Trans_SysDateTime, 
  Transaction.Transaction_Code,
Transaction.Company,
  'TRANSACTION' 
FROM  
  Transaction,
  Customer_Master
WHERE 
  Customer_Master.Cust_No = Transaction.Cust_No AND 
  Transaction.Transaction_Date >= :frmPrintCredNoteSummary.dfReportFromDate AND 
  Transaction.Transaction_Date <= :frmPrintCredNoteSummary.dfReportToDate AND
  Transaction.Transaction_Type = 'CREDNOTE' 
UNION ALL
SELECT  
 Trans_History.Cust_No,
 Customer_Master.Cust_Name,
 @VALUE( Trans_History.Hist_Reference_Id ), 
 Trans_History.Hist_Reference_Id,
 Trans_History.Hist_Trans_Date,
 Trans_History.Hist_Trans_Amount,
 Trans_History.Hist_GST,
 Trans_History.Hist_Label_Charges,
 Trans_History.Hist_Postal_Charge,
 Trans_History.Hist_Freight_Charg,
 Trans_History.Hist_Rail_Charges,
 Trans_History.Royalties,
 Trans_History.Trans_Hist_User_Id,
 Trans_History.TrHist_SysDateTime, 
 Trans_History.Hist_Trans_Code, 
Trans_History.Hist_Company,
 'TRANS_HISTORY'
FROM  
  Trans_History, 
  Customer_Master  
WHERE 
  Customer_Master.Cust_No = Trans_History.Cust_No AND 
  Trans_History.Hist_Trans_Date >= :frmPrintCredNoteSummary.dfReportFromDate AND 
  Trans_History.Hist_Trans_Date <= :frmPrintCredNoteSummary.dfReportToDate AND
  Trans_History.Hist_Trans_Type = 'CREDNOTE'
INTO 
  :frmPrintCredNoteSummary.tblInvSummary.colTransCustNo, 
  :frmPrintCredNoteSummary.tblInvSummary.colCustName, 
  :frmPrintCredNoteSummary.tblInvSummary.colNumericTransRefId, 
  :frmPrintCredNoteSummary.tblInvSummary.colTransRefId, 
  :frmPrintCredNoteSummary.tblInvSummary.colTransDate, 
  :frmPrintCredNoteSummary.tblInvSummary.colTransAmount, 
  :frmPrintCredNoteSummary.tblInvSummary.colTransGST, 
  :frmPrintCredNoteSummary.tblInvSummary.colTransLabelChrg, 
  :frmPrintCredNoteSummary.tblInvSummary.colTransPostalChrg, 
  :frmPrintCredNoteSummary.tblInvSummary.colTransFreightChrg, 
  :frmPrintCredNoteSummary.tblInvSummary.colTransRailChrg, 
  :frmPrintCredNoteSummary.tblInvSummary.colTransRoyalties, 
  :frmPrintCredNoteSummary.tblInvSummary.colTransUserId, 
  :frmPrintCredNoteSummary.tblInvSummary.colTransSysDT, 
  :frmPrintCredNoteSummary.tblInvSummary.colTransCode, 
:frmPrintCredNoteSummary.tblInvSummary.colTransCompany,
  :frmPrintCredNoteSummary.tblInvSummary.colTransTable
ORDER BY 3 "
.head 6 -  Return TRUE
.head 5 +  On SAM_FetchRowDone
.head 6 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_HideMarks, TRUE )
.head 6 -  Call GetTransNotes( colTransUserId, colTransSysDT, colTransTable, colTransNotes, SH_cls_Execute )
.head 6 +  If colTransNotes = 'Uninvoiced'
.head 7 +  If colTransCompany = 'Z'

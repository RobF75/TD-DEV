.head 8 +  If IDCANCEL = SalMessageBox( 'You have clicked the QUERY ADDRESS button, any other details other than Customer No or Customer Name and Address details are not applicable!  Do you still want to continue! ', 'NOTE', MB_OkCancel | MB_IconQuestion )
.head 9 -  Return FALSE

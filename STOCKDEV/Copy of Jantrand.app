.head 5 +  On PAM_DELETEROWS
.head 6 -  ! The next while make all the colCustARBalance columns that are not the last
  entry for a customer NULL.  So that a customers AR balance appears in this
  table only once for each cust_No and on his last details line
.head 6 -  Set nRow = TBL_MinRow
.head 6 +  While SalTblFindNextRow( hWndForm, nRow, 0, 0 )
.head 7 -  Call SalTblSetContext( hWndForm, nRow )
.head 7 -  Set nRowCustNo = colAssCustNo
.head 7 +  If SalTblSetContext( hWndForm, nRow + 1 )
.head 8 -  Set nRowP1CustNo = colAssCustNo
.head 8 +  If nRowCustNo = nRowP1CustNo
.head 9 -  Call SalTblSetContext( hWndForm, nRow )
.head 9 -  Set colCustARBalance = NUMBER_Null
.head 6 -  ! The next while goes through and checks the colCustARBalance and if = 0
  It works up the table and deletes this customers detail lines from the table!
.head 6 -  ! GF 27/11/98 Commented this next routine because it appears that the previous 
routine set all the ARBalances to zero, and this one checks if it's zero, then deletes
it. Very strange, it appears that it should start at the bottom of the table like the 
comment above says that it does.
.head 6 -  Set nRow = TBL_MinRow
.head 6 +  While SalTblFindNextRow( hWndForm, nRow, 0, 0 )
.head 7 -  Call SalTblSetContext( hWndForm, nRow )
.head 7 +  If colCustARBalance = 0
.head 8 -  Set nRemoveCustNo = colCustNo
.head 8 +  While nRemoveCustNo = colCustNo
.head 9 -  Call SalTblDeleteRow( hWndForm, nRow, TBL_NoAdjust )
.head 9 -  Set nRow = nRow - 1
.head 9 -  Call SalTblSetContext( hWndForm, nRow )

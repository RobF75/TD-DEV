.head 2 +  Functions
.head 3 +  Function: fGetUnusedInvoiceNos
.head 4 -  Description: finds any unused invoice numbers from prior manual allocations
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  Number: nInd
.head 5 -  Boolean: bOk
.head 5 -  Sql Handle: hSqlHandle
.head 4 +  Actions
.head 5 -  Set bOk = TRUE
.head 5 -  Call SalWaitCursor( TRUE )
.head 5 -  Set sSql = "
SELECT
	Invoice_No,
	Company
FROM
  	Inv_No_Register
WHERE
	Invoice_No IS NOT NULL
AND	Status  = 'MANUAL'
AND  	Company = :sCompany
INTO
	:tblUnusedNumbers.colManualNos,
	:tblUnusedNumbers.colCompany
ORDER BY
	Invoice_No"
.head 5 +  If SqlConnect( hSqlHandle )
.head 6 -  Call SalTblPopulate ( tblUnusedNumbers, hSqlHandle, sSql, TBL_FillAll )
.head 6 -  Call SqlDisconnect( hSqlHandle )
.head 5 +  Else
.head 6 -  Set bOk = FALSE
.head 5 -  Call SalWaitCursor( FALSE )
.head 5 -  Return bOk
.head 2 -  Window Parameters
.head 2 +  Window Variables
.head 3 -  String: sCompany
.head 2 +  Message Actions
.head 3 +  On PAM_SETINSTANCEVARS
.head 4 -  Set sDatabase = SqlDatabase

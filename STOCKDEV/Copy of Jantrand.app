.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = " SELECT
  SUM(@IF(@ISNA(Contract_Price),Base_Price,Contract_Price)*(@IF(@ISNA(Conf_Amt),
    @IF(@EXACT(Sale_Cat,'FC'),0,@IF(@EXACT(Sale_Cat,'RP'),0,Ordered_Amount)), 
    @IF(@EXACT(Sale_Cat,'FC'),0,@IF(@EXACT(Sale_Cat,'RP'),0,Conf_Amt)))))
FROM 
  Customer_Order,
  Stock_Item 
WHERE 
  Customer_Order.Cust_No = :1 AND 
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
  Customer_Order.Year_Of_Sale = :2 AND 
  ( Customer_Order.Invoiced_Flag = 'N' OR 
    Customer_Order.Invoiced_Flag IS NULL ) "
.head 9 -  Set sName = 'CSTYEARORDVAL'
.head 9 -  Set sBind = ':nCustNo, :nYear'
.head 9 -  Set sInto = ':nGotOrdValue'
.head 9 -  !
.head 9 -  Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
.head 9 -  Call SqlVarSetup( fcOurHandle.hSqlHandle )
.head 9 -  !
.head 9 -  Set nOrdValue = NUMBER_Null
.head 9 -  Set nGotOrdValue = NUMBER_Null
.head 9 -  !
.head 9 +  If fcOurHandle.Execute( )
.head 10 +  If fcOurHandle.FetchNext( nInd )
.head 11 -  Set nOrdValue = nGotOrdValue
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Return fcOurHandle.Disconnect( )

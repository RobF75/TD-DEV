.head 5 +  On PAM_POPULATE
.head 6 -  Call PopString( sPreBuildWhere, TRUE )
.head 6 -  ! order by customer.master.customer_name is by column number position becuase
  the name can be upper and lower case.  The colCustName must stay at its current position
  otherwise the order by will need to be adjusted.
.head 6 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillAll, PAM_SQL )
.head 6 -  Call SalTblSetLockedColumns( hWndForm, 2 )
.head 5 +  On PAM_REPOPULATE
.head 6 -  Call TableRePopulate( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, sCurrentBuildWhere, TRUE, TBL_FillAll, PAM_SQL )
.head 5 +  On PAM_SEARCH
.head 6 -  Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillAll, PAM_SQL )
.head 6 -  Call SalTblSetLockedColumns( hWndForm, 2 )
.head 5 +  On PAM_RESET
.head 6 -  Call TableReset( hWndForm, colCustNo )
.head 5 +  On PAM_NOROWS
.head 6 -  Call SalMessageBox( 'No rows match the search criteria', 'Customer & Contact Query', MB_Ok )
.head 5 +  On PAM_ENABLE
.head 6 +  If wParam
.head 7 -  Call SalShowWindow( hWndForm )
.head 6 +  Else
.head 7 -  Call SalHideWindow( hWndForm )
.head 5 +  On SAM_Create
.head 6 -  Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 -  Set sSQLPOPTABLENAME = ' CUSTOMER_MASTER, CUSTOMER_CONTACTS '
.head 6 -  Set sORDERBY = ' ORDER BY 2,1 '
.head 5 +  On SAM_Destroy
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlDisconnect( hLocalSqlPopTbl )

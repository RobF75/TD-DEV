.head 6 -  Call GetInvoiceDeposit( 0, '', DATETIME_Null, '', colDepAmtPaid, SH_cls_Disconnect )
.head 6 -  Call GetInvoiceNoRegisterDetails( 0, dtInvoiceDate, sStatus, 
sRunType, nYearOfSale, sLoadId, nCustNo, sUserId, SH_cls_Disconnect )
.head 6 -                                                                 Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

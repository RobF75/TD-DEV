.head 6 -  ! If frmPrintTrialBalance.sCompany = 'Z'
.head 6 -  Set sReportFileName = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\Cststat10.qrp'
.head 6 -  Set sObjVariable = 'objLogo'
.head 6 +  ! Else
.head 7 -                  Set sReportFileName = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\Cststat5.qrp'
.head 5 +  On PAM_ADDROW
.head 6 -  Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
.head 6 -  Call SalSendMsg( hWndForm, PAM_POPFIELDS, 0, 0 )
.head 6 -  ! For cash colTransAmount is -ve already
.head 6 +  If colTransType = 'DEPOSIT'
.head 7 -  Set nTotalAR = nTotalAR + colDeposit
.head 6 +  Else
.head 7 -  Set nTotalAR = nTotalAR + colTransAmount
.head 6 +  ! Else If colTransCode = 'DR'
.head 7 -                                                                 Set nTotalAR = nTotalAR + colTransAmount
.head 6 +  ! Else
.head 7 -                                                                 Set nTotalAR = nTotalAR - colTransAmount
.head 6 +  If colTransType != 'OUTSTAND DEPOSIT'
.head 7 -  Set nCurrentAR = nCurrentAR + col0to30
.head 7 -  Set n30dayAR = n30dayAR + col31to60
.head 7 -  Set n60dayAR = n60dayAR + col61to90
.head 7 -  Set n90dayAR = n90dayAR + col91plus
.head 6 +  If colTransType = 'INVOICE'
.head 7 +  If NOT colTransCancelled = 'CANCELLED'
.head 8 -  Set nTotalInv = nTotalInv + col0to30
.head 6 +  If colTransType = 'CASH' or colTransType = 'CHEQUE' or colTransType = 'CREDIT_CARD' or 
colTransType = 'MONEYORD'
.head 7 +  If colTransDate >= SalDateMonthBegin( colRolloverDate ) AND colTransDate <= colRolloverDate
.head 8 -  Set nTotalCash = nTotalCash - colTransAmount
.head 8 -  ! to get the cash to accumulate subtract the negative
.head 8 -  ! Set nTotalCash = nTotalCash + colTransAmount
.head 6 +  If colTransType = 'CREDNOTE'
.head 7 -  Set nTotalCredit = nTotalCredit - col0to30
.head 6 +  If colTransType = 'DEPOSIT'
.head 7 -  Set nDepositUsed = nDepositUsed - col0to30
.head 6 +  If colTransType = 'SVC CHG'
.head 7 -  Set nTotSvcChg = nTotSvcChg + col0to30
.head 6 +  If colTransType = 'DR.JNL' OR colTransType = 'DEBIT'
.head 7 +  If NOT colTransCancelled = 'CANCELLED'
.head 8 -  Set nTotDRJournal = nTotDRJournal + col0to30
.head 6 +  If colTransType = 'REFUND'
.head 7 -  Set nTotRefund = nTotRefund + col0to30
.head 6 +  If colTransType = 'BANKCHG' OR colTransType = 'BNKCHG'
.head 7 -  Set nTotBankCharge = nTotBankCharge + col0to30
.head 6 -  Set sTemp = SalStrLeftX( colTransType, 2 )
.head 6 +  If sTemp = 'GL' AND colTransCode = 'DR'
.head 7 -  Set nMiscGLDebit = nMiscGLDebit + col0to30
.head 6 +  If colTransType = 'SVCWROFF'
.head 7 -  Set nSvcChgWroff = nSvcChgWroff - col0to30
.head 6 +  If colTransType = 'CR.JNL'
.head 7 -  Set nCRJournal = nCRJournal  - col0to30
.head 6 +  If colTransType = 'WRITEOFF'
.head 7 -  Set nWroffs = nWroffs - col0to30
.head 6 +  If colTransType = 'CREDIT'
.head 7 +  If NOT colTransCancelled = 'CANCELLED'
.head 8 -  Set nCRTypes = nCRTypes - col0to30
.head 6 +  If colTransType = 'GLDISCNT'
.head 7 -  Set nDiscounts = nDiscounts - col0to30
.head 6 +  If colTransType = 'GLCOPADV'
.head 7 -  Set nCoopAdv = nCoopAdv - col0to30
.head 6 +  If sTemp = 'GL' AND colTransCode = 'CR'
.head 7 -  Set nMiscGLCredits = nMiscGLCredits - col0to30
.head 6 +  If colTransType = 'OUTSTAND DEPOSIT'
.head 7 -  Set nDepRequest = nDepRequest + colOutstandDeposit

.head 6 -  Set sTableHeading = 'Transactions Cash Receipt Applied against'
.head 5 +  On PAM_SETSGSQL
.head 6 -  ! GF 22/10/2008 changed below UNION to be a UNION ALL to show all transaction. There was a bug showing only single applications for a depoit that was ezually apid twice from the one receipt.
.head 6 -  Set sgSql = " SELECT
  Cash_Application.Cust_No, 
  Cash_Application.Date_Applied, 
  Cash_Application.Applied_Amount, 
  Transaction.Reference_Id, 
  Transaction.Transaction_Type, 
  Transaction.Transaction_Date, 
  Transaction.Transaction_Amount, 
  Transaction.Trans_GST,
  Transaction.Trans_Amount_Outst ,
   Transaction.Company
FROM 
  Cash_Application, 
  Transaction 
WHERE
  Cash_Application.Receipt_User_Id = :dlgReceiptAppliedOnTrans.sReceiptUserId AND 
  Cash_Application.Receipt_Sysdatetim = :dlgReceiptAppliedOnTrans.dtReceiptSysDT AND 
  Cash_Application.Trans_User_Id = Transaction.Trans_User_Id AND 
  Cash_Application.Trans_Sysdatetime = Transaction.Trans_Sysdatetime
UNION ALL
SELECT
  Cash_Application.Cust_No, 
  Cash_Application.Date_Applied, 
  Cash_Application.Applied_Amount, 
  Trans_History.Hist_Reference_Id, 
  Trans_History.Hist_Trans_Type, 
  Trans_History.Hist_Trans_Date, 
  Trans_History.Hist_Trans_Amount, 
  Trans_History.Hist_GST,
  Trans_History.Hist_Amt_Outstand ,
Trans_History.Hist_Company
FROM 
  Cash_Application, 
  Trans_History 
WHERE
  Cash_Application.Receipt_User_Id = :dlgReceiptAppliedOnTrans.sReceiptUserId AND 
  Cash_Application.Receipt_Sysdatetim = :dlgReceiptAppliedOnTrans.dtReceiptSysDT AND 
  Cash_Application.Trans_Hist_User_Id = Trans_History.Trans_Hist_User_Id AND 
  Cash_Application.Trans_Hist_Sysdate = Trans_History.TrHist_Sysdatetime
UNION ALL
SELECT
  Cash_Application.Cust_No, 
  Cash_Application.Date_Applied, 
  Cash_Application.Applied_Amount, 
  Transaction.Reference_Id, 
  Transaction.Transaction_Type, 
  Transaction.Transaction_Date, 
  Transaction.Transaction_Amount, 
  Transaction.Trans_GST,
  Transaction.Trans_Amount_Outst ,
Transaction.Company
FROM 
  Cash_Application, 
  Transaction
WHERE
  Cash_Application.Receipt_User_Id = :dlgReceiptAppliedOnTrans.sReceiptUserId AND 
  Cash_Application.Receipt_Sysdatetim = :dlgReceiptAppliedOnTrans.dtReceiptSysDT AND 
  Cash_Application.Trans_User_Id_Cred = Transaction.Trans_User_Id AND 
  Cash_Application.Trans_Sysdate_Cred = Transaction.Trans_Sysdatetime
UNION ALL
SELECT
  Cash_Application.Cust_No, 
  Cash_Application.Date_Applied, 
  Cash_Application.Applied_Amount, 
  Trans_History.Hist_Reference_Id, 
  Trans_History.Hist_Trans_Type, 
  Trans_History.Hist_Trans_Date, 
  Trans_History.Hist_Trans_Amount, 
  Trans_History.Hist_GST,
  Trans_History.Hist_Amt_Outstand,
Trans_History.Hist_Company 
FROM 
  Cash_Application, 
  Trans_History 
WHERE
  Cash_Application.Receipt_User_Id = :dlgReceiptAppliedOnTrans.sReceiptUserId AND 
  Cash_Application.Receipt_Sysdatetim = :dlgReceiptAppliedOnTrans.dtReceiptSysDT AND 
  Cash_Application.Trans_H_UserCred = Trans_History.Trans_Hist_User_Id AND 
  Cash_Application.Trans_H_dateCred = Trans_History.TrHist_Sysdatetime 
INTO 
  :dlgReceiptAppliedOnTrans.tblReceiptAppliedOnTrans.colCustNo, 
  :dlgReceiptAppliedOnTrans.tblReceiptAppliedOnTrans.colDateApplied, 
  :dlgReceiptAppliedOnTrans.tblReceiptAppliedOnTrans.colAppliedAmount, 
  :dlgReceiptAppliedOnTrans.tblReceiptAppliedOnTrans.colReferenceId, 
  :dlgReceiptAppliedOnTrans.tblReceiptAppliedOnTrans.colTransType, 
  :dlgReceiptAppliedOnTrans.tblReceiptAppliedOnTrans.colTransDate, 
  :dlgReceiptAppliedOnTrans.tblReceiptAppliedOnTrans.colTransAmount, 
  :dlgReceiptAppliedOnTrans.tblReceiptAppliedOnTrans.colTransGST, 
  :dlgReceiptAppliedOnTrans.tblReceiptAppliedOnTrans.colTransAmtOutstand,
:dlgReceiptAppliedOnTrans.tblReceiptAppliedOnTrans.colTransCompany"
.head 6 -  Return TRUE

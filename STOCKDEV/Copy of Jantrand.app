.head 6 -                                                                 List Values 
.head 6 +                                                                 Message Actions 
.head 7 +                                                                 On PAM_DATAVAL
.head 8 -                                                                 Return TRUE
.head 7 +                                                                 On PAM_SETCRTRANSVALUES
.head 8 +                                                                 If colType = 'INVOICE'
.head 9 -                                                                 Set colWrOffType = 'WRITEOFF'
.head 8 +                                                                 Else If colType = 'SVC CHG'
.head 9 -                                                                 Set colWrOffType = 'SVCWROFF'
.head 8 +                                                                 Else If colType = 'BANK FEE'
.head 9 -                                                                 Set colWrOffType = 'BNKWROFF'
.head 8 +                                                                 Else 
.head 9 -                                                                 Set colWrOffType = 'WRITEOFF'
.head 7 +                                                                 On PAM_INSERTCRTRANS
.head 8 -                                                                 Call SalSetFieldEdit( hWndItem, TRUE )
.head 8 -                                                                 Call BuildSQL( wParam, hWndItem, 'TRANSACTION_TYPE' )

.head 8 -  Set colContactAHPh = sContactAHPh
.head 8 -  !
.head 8 -  ! For cash colTransAmount is -ve already
.head 8 +  If colTransType = 'DEPOSIT'
.head 9 -  Set nTotalAR = nTotalAR + colDeposit
.head 8 +  Else
.head 9 -  Set nTotalAR = nTotalAR + colTransAmount
.head 8 +  If colTransType != 'OUTSTAND DEPOSIT'
.head 9 -  Set nCurrentAR = nCurrentAR + col0to30
.head 9 -  Set n30dayAR = n30dayAR + col31to60
.head 9 -  Set n60dayAR = n60dayAR + col61to90
.head 9 -  Set n90dayAR = n90dayAR + col91plus
.head 8 +  If colTransType = 'INVOICE'
.head 9 -  Set nTotalInv = nTotalInv + col0to30
.head 8 +  If colTransType = 'CASH' or colTransType = 'CHEQUE' or colTransType = 'MONEYORD' or colTransType = 'CREDIT_CARD'
.head 9 +  If colTransDate >= SalDateMonthBegin( colRolloverDate ) AND colTransDate <= colRolloverDate
.head 10 -  Set nTotalCash = nTotalCash - colTransAmount
.head 10 -  ! to get the cash to accumulate subtract the negative
.head 10 -  ! Set nTotalCash = nTotalCash + colTransAmount
.head 8 +  If colTransType = 'CREDNOTE'
.head 9 -  Set nTotalCredit = nTotalCredit - col0to30
.head 8 +  If colTransType = 'DEPOSIT'
.head 9 -  Set nDepositUsed = nDepositUsed - col0to30
.head 8 +  If colTransType = 'SVC CHG'
.head 9 -  Set nTotSvcChg = nTotSvcChg + col0to30
.head 8 +  If colTransType = 'DR.JNL' OR colTransType = 'DEBIT'
.head 9 -  Set nTotDRJournal = nTotDRJournal + col0to30
.head 8 +  If colTransType = 'REFUND'
.head 9 -  Set nTotRefund = nTotRefund + col0to30
.head 8 +  If colTransType = 'BANKCHG'
.head 9 -  Set nTotBankCharge = nTotBankCharge + col0to30
.head 8 -  Set sTemp = SalStrLeftX( colTransType, 2 )
.head 8 +  If sTemp = 'GL' AND colTransCode = 'DR'
.head 9 -  Set nMiscGLDebit = nMiscGLDebit + col0to30
.head 8 +  If colTransType = 'SVCWROFF'
.head 9 -  Set nSvcChgWroff = nSvcChgWroff - col0to30
.head 8 +  If colTransType = 'CR.JNL'
.head 9 -  Set nCRJournal = nCRJournal  - col0to30
.head 8 +  If colTransType = 'WRITEOFF'
.head 9 -  Set nWroffs = nWroffs - col0to30
.head 8 +  If colTransType = 'CREDIT'
.head 9 -  Set nCRTypes = nCRTypes - col0to30
.head 8 +  If colTransType = 'GLDISCNT'
.head 9 -  Set nDiscounts = nDiscounts - col0to30
.head 8 +  If colTransType = 'GLCOPADV'
.head 9 -  Set nCoopAdv = nCoopAdv - col0to30
.head 8 +  If sTemp = 'GL' AND colTransCode = 'CR'
.head 9 -  Set nMiscGLCredits = nMiscGLCredits - col0to30
.head 8 +  If colTransType = 'OUTSTAND DEPOSIT'
.head 9 -  Set nDepRequest = nDepRequest + colOutstandDeposit

.head 4 -  Functions
.head 4 -  Window Variables
.head 4 +  Message Actions
.head 5 +  ! On PAM_SETINSTANCEVARS
.head 6 -                                                                 Set sSQLTABLENAME = ' DEPOSIT_HISTORY '
.head 6 -                                                                 Set sSQLPOPTABLENAME = ' DEPOSIT_HISTORY, TRANSACTION '
.head 6 -                                                                 Set sROWID = ' DEPOSIT_HISTORY.ROWID '
.head 6 -                                                                 Set sSQLWHERE = ' WHERE Deposit_History.Cust_No = :frmDepositHistory.dfCustNo AND 
  Deposit_History.Cust_No = Transaction.Cust_No AND 
  Deposit_History.Trans_User_Id = Transaction.Trans_User_Id AND 
  Deposit_History.Trans_Sysdatetime = Transaction.Trans_Sysdatetime '
.head 6 -                                                                 Set sORDERBY = ' ORDER BY Deposit_History.Dep_Hist_Sysdtetim '
.head 6 -                                                                 Set sTableHeading = ' Deposit History '
.head 5 +  ! On PAM_POPULATE
.head 6 -                                                                 Return SalSendClassMessage( PAM_POPULATE, wParam, lParam )
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLTABLENAME = ''
.head 6 -  Set sSQLPOPTABLENAME = ''
.head 6 -  Set sROWID = ''
.head 6 -  Set sSQLWHERE = ''
.head 6 -  Set sORDERBY = ''
.head 6 -  Set bSelectFirstRow = FALSE
.head 6 -  Set nTableFillType = TBL_FillAll
.head 5 +  On PAM_SETSGSQL
.head 6 -  Set sgSql = " SELECT  
  'ROWID', 
  TRANSACTION.REFERENCE_ID ,  
  DEPOSIT_HISTORY.DEP_HIST_SYSDTETIM ,  
  DEPOSIT_HISTORY.DEPHIST_REQD_DATE ,  
  DEPOSIT_HISTORY.DEPHIST_AMT_REQD ,  
  DEPOSIT_HISTORY.DEPHIST_AMT_PAID ,  
  DEPOSIT_HISTORY.DEP_HIST_PAID_DATE ,  
  DEPOSIT_HISTORY.DEPHIST_YR_OF_SALE,
DEPOSIT_HISTORY.COMPANY   
FROM  
  DEPOSIT_HISTORY, 
  TRANSACTION  
WHERE 
  Deposit_History.Cust_No = :frmDepositHistory.dfCustNo AND 
  Deposit_History.Cust_No = Transaction.Cust_No AND 
  Deposit_History.Trans_User_Id = Transaction.Trans_User_Id AND 
  Deposit_History.Trans_Sysdatetime = Transaction.Trans_Sysdatetime  
UNION ALL
SELECT  
  'ROWID',
  TRANS_HISTORY.HIST_REFERENCE_ID ,  
  DEPOSIT_HISTORY.DEP_HIST_SYSDTETIM ,  
  DEPOSIT_HISTORY.DEPHIST_REQD_DATE ,  
  DEPOSIT_HISTORY.DEPHIST_AMT_REQD ,  
  DEPOSIT_HISTORY.DEPHIST_AMT_PAID ,  
  DEPOSIT_HISTORY.DEP_HIST_PAID_DATE ,  
  DEPOSIT_HISTORY.DEPHIST_YR_OF_SALE ,
DEPOSIT_HISTORY.COMPANY    
FROM  
  DEPOSIT_HISTORY, 
  TRANS_HISTORY  
INTO 
  :frmDepositHistory.tblDepositsTable.colRowId, 
  :frmDepositHistory.tblDepositsTable.colReferenceId, 
  :frmDepositHistory.tblDepositsTable.colDepHistSysDT, 
  :frmDepositHistory.tblDepositsTable.colDepHistReqdDate, 
  :frmDepositHistory.tblDepositsTable.colDepHistAmtReqd, 
  :frmDepositHistory.tblDepositsTable.colDepHistAmtPaid, 
  :frmDepositHistory.tblDepositsTable.colDepHistPaidDate, 
  :frmDepositHistory.tblDepositsTable.colDepHistYearOfSale ,
:frmDepositHistory.tblDepositsTable.colDepHistCompany
WHERE 
  Deposit_History.Cust_No = :frmDepositHistory.dfCustNo AND 
  Deposit_History.Cust_No = Trans_History.Cust_No AND 
  Deposit_History.Trans_Hist_User_Id = Trans_History.Trans_Hist_User_Id AND 
  Deposit_History.Trans_Hist_SysDT = Trans_History.TrHist_Sysdatetime  
ORDER BY 3 "
.head 6 -  Return TRUE

.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Receive Sql Handle: hSqlHandle
.head 5 -  Receive Boolean: bHandleConnected
.head 5 -  Receive Boolean: bHandlePrepared
.head 5 -  String: sUserId
.head 5 -  String: dDateTime
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 4 +  Actions
.head 5 +  If NOT bHandleConnected
.head 6 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 6 +  If bHandleConnected
.head 7 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 5 +  If NOT bHandlePrepared
.head 6 -  Set sSql = 'DELETE FROM TRANSACTION WHERE TRANS_USER_ID = :'||sUserId
||' AND TRANS_SYSDATETIME = :'||dDateTime
.head 6 +  If SqlPrepare( hSqlHandle, sSql )
.head 7 -  Set bHandlePrepared = TRUE
.head 6 +  Else
.head 7 -  Set bHandlePrepared = FALSE
.head 5 +  If SqlExecute( hSqlHandle )
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Set bHandlePrepared = FALSE
.head 6 -  Return FALSE

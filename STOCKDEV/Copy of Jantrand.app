.head 7 +  ! On PAM_COPYROWINFOFROM
.head 8 -                                                                 Call SalTblFetchRow( hWndForm, lParam )
.head 8 +                                                                 Select Case wParam
.head 9 +                                                                 Case DT_DateTime
.head 10 -                                                                 Set dtTemp = colWhere
.head 10 -                                                                 Break 
.head 9 +                                                                 Case DT_Number
.head 10 -                                                                 Set nTemp = colWhere
.head 10 -                                                                 Break 
.head 9 +                                                                 Case DT_String
.head 10 -                                                                 Set sTemp = colWhere
.head 10 -                                                                 Break 
.head 9 +                                                                 Case DT_LongString
.head 10 -                                                                 Set lsTemp = colWhere
.head 10 -                                                                 Break 
.head 7 +  ! On PAM_COPYROWINFOTO
.head 8 -                                                                 Call SalTblFetchRow( hWndForm, lParam )
.head 8 +                                                                 Select Case wParam
.head 9 +                                                                 Case DT_DateTime
.head 10 -                                                                 Set colWhere = dtTemp
.head 10 -                                                                 Break 

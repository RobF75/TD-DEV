.head 4 +  Message Actions 
.head 5 +  On SAM_Click
.head 6 -  ! Send message pam_qcustcheck to hWndForm children and if some return false
then confirm with user if they have clicked the right button.
.head 6 -  Set hWndChild = SalGetFirstChild( hWndForm, TYPE_DataField )
.head 6 +  While NOT hWndChild = hWndNULL
.head 7 +  If NOT SalSendMsg( hWndChild, PAM_QCUSTCHECK, 0, 0 )
.head 8 +  If IDCANCEL = SalMessageBox( 'You have clicked the QUERY CUSTOMER button, any other details other than Customer No or Customer Name are not applicable!  Do you still want to continue! ', 'NOTE', MB_OkCancel | MB_IconQuestion )
.head 9 -  Return FALSE
.head 8 +  Else 
.head 9 -  Break 
.head 7 -  Set hWndChild = SalGetNextChild( hWndChild, TYPE_DataField )
.head 6 -  Call SalWaitCursor( TRUE )
.head 6 -  Call PushWndHdl( hWndForm )
.head 6 -  Call PushNumber( PAM_QBECUST )
.head 6 -  Call BuildWhereQBE(  )
.head 6 -  Set sBuildWhere = StripWhereFromSQL( sBuildWhere )
.head 6 -  Call SalEndDialog( hWndForm, nCustomerTbl )

.head 5 +  On PAM_PRINTFULLTABLEREPORT
.head 6 -  Set nLastCustNo = NUMBER_Null
.head 6 -  Set nLastCustNoARBalance = NUMBER_Null
.head 6 -  Set bMarkCust = FALSE
.head 6 -  Set sPrinter = 'ConditionsOfSale'
.head 6 -  Call MyTableLoop( hWndForm, hWndForm, PAM_CHECKEDIT, 0, 0, 'Checking to print balances greater than $5', nHiToLow )
.head 6 -  Set nLastCustNo = NUMBER_Null
.head 6 -  Call MyTableLoop( hWndForm, hWndForm, PAM_ROWACTION, 0, ROW_Selected, 'Removing Statements below $5 OR with Debt Collectors', nLowToHi )
.head 6 -  Set nLastCustNo = NUMBER_Null
.head 6 -  Return SalSendClassMessage( PAM_PRINTFULLTABLEREPORT, wParam, lParam )
.head 5 +  On PAM_CHECKEDIT
.head 6 +  If nLastCustNo != colAssCustNo
.head 7 -  Set nLastCustNo = colAssCustNo
.head 7 -  ! Add a bit to print -ve statements
.head 7 +  If colCustARBalance >= 5 OR colOutstandDeposit > 0 or colCustARBalance <= -5
.head 8 -  Set bMarkCust = TRUE
.head 7 +  Else
.head 8 -  Set bMarkCust = FALSE
.head 7 -  ! Want to check if the debt collection flag is on - cos if it is we dont want to print a statement for them
.head 7 -  ! 10-1-2006 GF Asked by Brendan to now print statements for Custs with Debt Collectors. He wants to photocopy onto Red paper and send it to cust.
.head 7 +  ! If bMarkCust
.head 8 +  If colDebtCollect = 'Y'
.head 9 -  Set bMarkCust = FALSE
.head 6 +  If Not SalTblSetRowFlags( hWndForm, lParam, ROW_Selected, bMarkCust )
.head 7 -  Call SalMessageBox('Error','Error',MB_Ok)
.head 6 -  Return TRUE
.head 5 +  On PAM_ROWACTION
.head 6 -  Call SalTblDeleteRow( hWndForm, lParam, TBL_NoAdjust )
.head 6 -  Return nRowDeleted

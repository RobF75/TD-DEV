.head 2 +  Functions
.head 3 +  Function: fSetInvoiceNoRange
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Sql Handle: hSqlHandle
.head 5 -  Date/Time: dtAllocationDate
.head 5 -  Number: nTotalInvoices
.head 5 -  Receive Number: nFirstInvoiceNo
.head 5 -  Receive Number: nLastInvoiceNo
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sJulianDate
.head 5 -  String: sSql
.head 5 -  Number: nInd
.head 5 -  Number: nMaxUsedInvNo
.head 5 -  Boolean: bOk
.head 4 +  Actions
.head 5 -  Set bOk = TRUE
.head 5 -  Set sJulianDate = GetStrJulianDate( dtAllocationDate )
.head 5 -  Set nFirstInvoiceNo = SalStrToNumber( sJulianDate || '0000' )
.head 5 -  Set nLastInvoiceNo = SalStrToNumber( sJulianDate || '9999' )
.head 5 -  Set nMaxUsedInvNo = NUMBER_Null
.head 5 -  Set sSql = " SELECT
  MAX( Invoice_No )
FROM
  Inv_No_Register
WHERE
  Invoice_No BETWEEN :nFirstInvoiceNo AND :nLastInvoiceNo
INTO 
  :nMaxUsedInvNo "
.head 5 +  If SqlPrepareAndExecute( hSqlHandle, sSql )
.head 6 -  Call SqlFetchNext( hSqlHandle, nInd )
.head 6 +  If NOT nMaxUsedInvNo = NUMBER_Null
.head 7 -  Set nFirstInvoiceNo = nMaxUsedInvNo + 1
.head 6 -  Set nLastInvoiceNo = nFirstInvoiceNo + nTotalInvoices - 1
.head 5 +  Else
.head 6 -  Set bOk = FALSE
.head 6 -  Set nFirstInvoiceNo = NUMBER_Null
.head 6 -  Set nLastInvoiceNo = NUMBER_Null
.head 5 -  Return bOk
.head 3 +  Function: fAllocateInvBookInvNos
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Sql Handle: hSqlHandle
.head 5 -  Number: nFirstInvoiceNo
.head 5 -  Number: nLastInvoiceNo
.head 5 -  String: sCompany
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  Boolean: bOk
.head 5 -  Number: nInvoiceNo
.head 5 -  Number: nInd
.head 4 +  Actions
.head 5 -  Set bOk = TRUE
.head 5 -  Set sSql = " SELECT 
  1 
FROM 
  Inv_No_Register
WHERE 
  Invoice_No BETWEEN :nFirstInvoiceNo AND :nLastInvoiceNo "
.head 5 +  If SqlPrepareAndExecute( hSqlHandle, sSql ) AND SqlFetchNext( hSqlHandle, nInd )
.head 6 -  Set bOk = FALSE
.head 5 +  Else
.head 6 -  Set sSql = " INSERT INTO Inv_No_Register
  ( Invoice_No, Status, Company )
VALUES 
  ( :nInvoiceNo, 'MANUAL', :sCompany ) "
.head 6 +  If SqlPrepare( hSqlHandle, sSql )
.head 7 -  Set nInvoiceNo = nLastInvoiceNo
.head 7 +  While nInvoiceNo >= nFirstInvoiceNo AND bOk
.head 8 +  If SqlExecute( hSqlHandle )
.head 9 -  Set nInvoiceNo = nInvoiceNo - 1
.head 8 +  Else
.head 9 -  Set bOk = FALSE
.head 7 +  If bOk
.head 8 -  Call SqlCommit( hSqlHandle )
.head 7 +  Else
.head 8 -  Call SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
.head 6 +  Else
.head 7 -  Set bOk = FALSE
.head 5 -  Return bOk
.head 2 -  Window Parameters
.head 2 +  Window Variables
.head 3 -  String: sCompany
.head 2 +  Message Actions
.head 3 +  On PAM_SETINSTANCEVARS
.head 4 -  Set sDatabase = SqlDatabase
.head 3 +  On SAM_CreateComplete
.head 4 -  ! set default to week begining ie Monday - 1 = Sunday
.head 4 -  ! most likely no invoices were done on Sunday and the full 9999
.head 4 -  ! range would be available.
.head 4 -  Set dfdtInvoiceDate = SalDateWeekBegin( SalDateCurrent(  ) ) - 1
.head 4 -  Set dfnTotalInvoices = 100
.head 4 -  Set rbCompanyFleming = TRUE
.head 4 -  Set sCompany = 'F'
.head 4 -  Call fSetInvoiceNoRange( hSqlDetail, dfdtInvoiceDate, dfnTotalInvoices, dfnFirstInvoiceNo, dfnLastInvoiceNo )
.head 4 -  Call SalWaitCursor( FALSE )

    FROM 
      cash_application ca1,
      cash_receipt cr
    WHERE 
      ca1.trans_user_id = :1 and
      ca1.trans_sysdatetime = :2 and
      ca1.receipt_user_id = cr.Receipt_User_Id AND 
      ca1.receipt_sysdatetim = cr.Rcpt_Sysdatetime AND  
      ca1.Date_Applied <= :3 and
      cr.Company = :4 AND 
      ca1.receipt_sysdatetim not in
      ( 
        SELECT 
          dh.Rcpt_Sysdatetime 
        FROM 
          Deposit_History dh,
          Cash_Application ca
        WHERE 
          dh.Receipt_User_Id = ca.Receipt_User_Id and
          dh.Rcpt_sysdatetime = ca.Receipt_Sysdatetim  and
  	dh.trans_user_id = :1 and
  	dh.trans_sysdatetime = :2
     )
    ORDER BY 
       ca1.date_applied "

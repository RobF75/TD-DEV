.head 7 +  Message Actions
.head 8 +  On PAM_CLICK
.head 9 -  Set nYear = SalStrToNumber( ccYear.GetNumber( ) )
.head 9 -  Call lbMonth.GetSelectMonthBegEndDays( nMonth, nBegDay, nEndDay, nYear )
.head 9 -  Set dtRolloverDate = SalDateConstruct( nYear, nMonth, nEndDay, 0, 0, 0 )
.head 9 -  Call SalDateToStr( dtRolloverDate, sRolloverDate )
.head 9 -  Set sRolloverDate = SalNumberToStrX( SalDateDay( dtRolloverDate ), 0 ) || '/' || 
SalNumberToStrX( SalDateMonth( dtRolloverDate ), 0 ) || '/' || 
SalNumberToStrX( SalDateYear( dtRolloverDate ), 0 )
.head 9 -  Set nCurrentMonth = SalDateMonth( SalDateCurrent() )
.head 9 -  Set nCurrentYear = SalDateYear( SalDateCurrent() )
.head 9 +  ! If nCurrentMonth > 2
.head 10 +  If nCurrentMonth - SalDateMonth( dtRolloverDate ) < 2
.head 11 -  Call SalMessageBox('Rollover Date is too current, please check','Rollover Error',MB_Ok)
.head 11 -  Return FALSE
.head 9 +  ! Else If nCurrentMonth = 2
.head 10 -  If SalDateMonth( dtRolloverDate ) = 1
.head 10 -  Call SalMessageBox('Rollover Date is too current, please check','Rollover Error',MB_Ok)
.head 10 -  Return FALSE
.head 9 +  ! Else If nCurrentMonth = 1
.head 10 -  If SalDateMonth( dtRolloverDate ) = 12
.head 10 -  Call SalMessageBox('Rollover Date is too current, please check','Rollover Error',MB_Ok)
.head 10 -  Return FALSE
.head 9 +  If IDOK = SalMessageBox( 'Is the '||sRolloverDate||' the date you wish to use?', 'Verify', MB_OkCancel )
.head 10 +  If SalSendMsg( hWndItem, PAM_PUSHFIELDS, 0, 0 )
.head 11 -  Return SalSendMsg( pbCancel, SAM_Click, 0, TRUE )
.head 8 +  On PAM_PUSHFIELDS
.head 9 -  Call PushDateTime( dtRolloverDate )
.head 9 -  Return TRUE

.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 +  If sCompany = 'F'
.head 7 +  If NOT SalPicSetFile( picLogo, 'j:\\data\\logos\\flemings.bmp' )
.head 8 -  Call SalMessageBox('Unable to get Flemings.bmp logo file. Contact Programmer', 'Error', MB_Ok)
.head 8 -  Return FALSE
.head 6 +  Else If sCompany = 'Z'
.head 7 +  If NOT SalPicSetFile( picLogo, 'j:\\data\\logos\\zeesweet.bmp' )
.head 8 -  Call SalMessageBox('Unable to get Zee Sweet.bmp logo file. Contact Programmer', 'Error', MB_Ok)
.head 8 -  Return FALSE
.head 6 +  If NOT SalPicGetString( picLogo, PIC_FormatBitmap, sLogo )

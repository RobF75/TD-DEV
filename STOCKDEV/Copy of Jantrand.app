	:frmPrintCashApp.tblCashApp.colRefId 
WHERE
	Transaction.Trans_User_Id = :frmPrintCashApp.tblCashApp.colTransUser AND
	Transaction.Trans_Sysdatetime = :frmPrintCashApp.tblCashApp.colTransSysDate and
	Transaction.Company = :sCompany
"

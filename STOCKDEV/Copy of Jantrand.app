.head 5 +  Message Actions
.head 6 +  On PAM_CLICK
.head 7 -  Set nYear = SalStrToNumber( ccYear.GetNumber( ) )
.head 7 -  Call lbMonth.GetSelectMonthBegEndDays( nMonth, nBegDay, nEndDay, nYear )
.head 7 -  Set dtRolloverDate = SalDateConstruct( nYear, nMonth, nEndDay, 0, 0, 0 )
.head 7 -  Call SalDateToStr( dtRolloverDate, sRolloverDate )
.head 7 -  Set sRolloverDate = SalNumberToStrX( SalDateDay( dtRolloverDate ), 0 ) || '/' || 
SalNumberToStrX( SalDateMonth( dtRolloverDate ), 0 ) || '/' || 
SalNumberToStrX( SalDateYear( dtRolloverDate ), 0 )
.head 7 -  Set nCurrentMonth = SalDateMonth( SalDateCurrent() )
.head 7 -  Set nCurrentYear = SalDateYear( SalDateCurrent() )
.head 7 +  If nCurrentMonth > 2
.head 8 +  If (nCurrentMonth - SalDateMonth( dtRolloverDate ) < 2) and (SalDateYear( SalDateCurrent() ) - SalDateYear( dtRolloverDate ) <= 0 )
.head 9 -  Call SalMessageBox('Rollover Date is too current, please check','Rollover Error',MB_Ok)
.head 9 -  Return FALSE
.head 7 +  Else If (nCurrentMonth = 2) 
.head 8 +  If (SalDateMonth( dtRolloverDate ) = 1) or (SalDateYear( SalDateCurrent() ) - SalDateYear( dtRolloverDate ) <= 0 )
.head 9 -  Call SalMessageBox('Rollover Date is too current, please check','Rollover Error',MB_Ok)
.head 9 -  Return FALSE
.head 7 +  Else If (nCurrentMonth = 1) 
.head 8 +  If (SalDateMonth( dtRolloverDate ) = 12) or (SalDateYear( SalDateCurrent() ) - SalDateYear( dtRolloverDate ) <= 0 )
.head 9 -  Call SalMessageBox('Rollover Date is too current, please check','Rollover Error',MB_Ok)
.head 9 -  Return FALSE
.head 7 +  If IDOK = SalMessageBox( 'Is the '||sRolloverDate||' the date you wish to use?', 'Verify', MB_OkCancel )
.head 8 +  If SalSendMsg( hWndItem, PAM_PUSHFIELDS, 0, 0 )
.head 9 -  Return SalSendMsg( pbCancel, SAM_Click, 0, TRUE )

.head 3 -  On SAM_Create
.head 3 +  On SAM_ReportStart
.head 4 +  ! If NOT bCustHdlConnected
.head 5 -                          Set bAllCustHdlConnected = SqlConnect( hSqlCustHandle )
.head 5 +                          If bAllCustHdlConnected
.head 6 -                          Call SqlSetLockTimeout( hSqlCustHandle, SQLTIMEOUT )
.head 6 -                          Call SqlSetParameter( hSqlCustHandle, DBP_PRESERVE, TRUE, ''  )
.head 5 +                          Else 
.head 6 -                          Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -                          Return FALSE
.head 4 +  ! If NOT bCustHdlPrepared
.head 5 +                          If TRUE
.head 6 -                          Set sSql = " SELECT 
	
FROM
  Customer_Master,
  Customer_Type,
  Customer_Order,
  Stock_Item
INTO :frmPrintCustomerTAs.dfCustno
WHERE
  Customer_Master.Cust_No = Customer_Order.Cust_No AND
  Customer_Order.Year_Of_Sale = :frmPrintCustomerTAs.dfYr AND
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND
  Customer_Master.Customer_Type = Customer_Type.Cust_Type AND
  Customer_Master.Customer_Type LIKE '%OR%' AND
  Customer_Type.NPA_Required = 'Y' AND
  ( NOT Customer_Master.FNA_Flag = 'Y' OR
    Customer_Master.FNA_Flag IS NULL ) AND
 Customer_Order.Conf_Amt > 0 AND
  ( NOT Customer_Order.TA_Recd_Flag = 'Y' OR
    Customer_Order.TA_Recd_Flag IS NULL ) AND
   (Stock_Item.cv_on_trial_flag = 'Y'  or Stock_Item.rt_on_trial_flag = 'Y' or
  customer_order.sale_cat in ('FC', 'TT')) AND
  NOT Customer_Order.Sale_Cat != 'RP' "
.head 5 +                          If SqlPrepare( hSqlCustHandle, sSql )
.head 6 -                          Set bCustHdlPrepared = TRUE
.head 5 +                          Else 
.head 6 -                          Set bCustHdlPrepared = FALSE
.head 4 +  If NOT SalFileOpen( fhBarcode, 'c:\\centura\\graham\\barcode.txt', OF_ReadWrite | OF_Create )
.head 5 -  Call SalMessageBox('File Open Error', 'Error', MB_Ok)
.head 5 -  Return FALSE
.head 3 +  On SAM_ReportFetchInit
.head 4 -  Set nCount = 0
.head 4 -  Set nCustCount = 0
.head 4 -  Set nQuantityCount = 0
.head 4 -  Set nQuantity = 0
.head 4 +  If TRUE
.head 5 -  Set sSelect = 
"Select
	customer_master.cust_no,
	cust_name,
	stock_item_no,
	cult_desc,
	conf_amt,
	bitmap
into
	:nCustNo,
	:sCustName,
	:nItemNo,
	:sCultDesc,
	:nConfAmt,
	:sCustLogoFile
from
	customer_master,
	customer_order,
	stock_item,
	load_customers
where
	customer_order.stock_item_no = stock_item.item_no and
	load_customers.cust_no = customer_order.cust_no and
	customer_master.cust_no = customer_order.cust_no and
	load_customers.load_id = :sLoadId and
	customer_order.conf_amt > 0 and
	year_of_sale = :nYear
order by 
	load_customers.sequence_no,
	customer_master.cust_no
"
.head 4 -  ! Set nCopies = 0
.head 4 -  ! Set nOptions = RPT_PrintAll

.head 3 +  Function: PrintFCLabelFarmStock
.head 4 -  Description: Prints Field Count label for the farms growing stock selected by the 
user.
Prints a label for the stock growing on this farm that the user
selected.
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Window Handle: hWndPushbutton
.head 5 -  Window Handle: hWndFarmTable
.head 5 -  Number: nYear
.head 5 -  String: sFarmId
.head 5 -  String: sFarmDesc
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  Sql Handle: hSqlHandle
.head 5 -  Boolean: bSqlHandle
.head 5 -  Number: nRow
.head 5 -  Number: nInd
.head 5 -  Number: nStockItemNo
.head 5 -  String: sLabelId
.head 5 -  !
.head 5 -  String: sPrevCultId
.head 5 -  String: sPrevRootId
.head 5 -  Number: nPrevRow
.head 4 +  Actions
.head 5 -  Call SalWaitCursor( TRUE )
.head 5 -  Call SalDisableWindow( hWndPushbutton )
.head 5 -  Set bSqlHandle = SqlConnect( hSqlHandle ) 
.head 5 +  If bSqlHandle
.head 6 -  Call SqlSetLockTimeout( hSqlHandle, 10 )
.head 6 -  ! Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 5 +  Else
.head 6 -  Call SalWaitCursor( FALSE )
.head 6 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -  Call SalEnableWindow( hWndPushbutton )
.head 6 -  Return FALSE
.head 5 -  !
.head 5 -  Set nRow = TBL_MinRow
.head 5 -  Set sPrevCultId = ''
.head 5 -  Set sPrevRootId = ''
.head 5 -  Set nPrevRow = 0
.head 5 +  While SalTblFindNextRow( hWndFarmTable, nRow, ROW_Selected, 0 )
.head 6 -  Call SalTblFetchRow( hWndFarmTable, nRow )
.head 6 +  If NOT ( hWndFarmTable.colCultId = sPrevCultId AND 
   hWndFarmTable.colRootId = sPrevRootId AND 
   hWndFarmTable.colRow = nPrevRow )
.head 7 -  Set sSql = ' 
SELECT  
  Stock_Labels.Label_Id
FROM
  Stock_Labels 
INTO  
  :sLabelId
WHERE
  Stock_Labels.Stock_Item_No = :hWndFarmTable.colItemNo AND 
  Stock_Labels.Stock_Label_Use = \'FC\' '
.head 7 +  If SqlPrepare( hSqlHandle, sSql )
.head 8 +  If SqlExecute( hSqlHandle )
.head 9 +  If NOT SqlFetchNext( hSqlHandle, nInd )
.head 10 -  Call GetLabelIdFromUse( 'FC', sLabelId, SH_cls_Execute )
.head 10 +  If sLabelId = ''
.head 11 -  Call SalMessageBox( 'SqlFetchNext failed in printing Field Count Label.  No Label where Printed!', 'Error', MB_Ok )
.head 11 -  Call SalEnableWindow( hWndPushbutton )
.head 11 -  Call SalWaitCursor( FALSE )
.head 11 -  Return FALSE
.head 10 +  Else
.head 11 +  If InsertStockLabelsUse( hWndFarmTable.colItemNo, sLabelId, 'FC', SH_cls_Execute )
.head 12 -  Call InsertStockLabelsUse( 0, '', '', SH_cls_Commit )
.head 8 +  Else
.head 9 -  Call SalMessageBox( 'SqlExecute failed in printing Field Count Label.  No Label where Printed!', 'Error', MB_Ok )
.head 9 -  Call SalEnableWindow( hWndPushbutton )
.head 9 -  Call SalWaitCursor( FALSE )
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Call SalMessageBox( 'SqlPrepare failed in printing Field Count Label.  No Label where Printed!', 'Error', MB_Ok )
.head 8 -  Call SalEnableWindow( hWndPushbutton )
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 -  Return FALSE
.head 7 -  Call PrintLabels( hWndFarmTable.colItemNo, sLabelId, 1, hWndFarmTable.colLocId, hWndFarmTable, SH_cls_Execute  )
.head 7 -  ! Call PrintLabelsFarmStock( sLabelId, hWndFarmTable, sFarmId, sFarmDesc )
.head 6 -  Set sPrevCultId = hWndFarmTable.colCultId
.head 6 -  Set sPrevRootId = hWndFarmTable.colRootId
.head 6 -  Set nPrevRow = hWndFarmTable.colRow
.head 5 +  If bSqlHandle
.head 6 -  Call SqlDisconnect( hSqlHandle )
.head 5 -  Call GetLabelIdFromUse( '', sLabelId, SH_cls_Disconnect )
.head 5 -  Call InsertStockLabelsUse( 0, '', '', SH_cls_Disconnect )
.head 5 -  Call PrintLabels( 0, '', 0, 0, hWndNULL, SH_cls_Disconnect  )
.head 5 -  Call SalEnableWindow( hWndPushbutton )
.head 5 -  Call SalWaitCursor( FALSE )
.head 3 +  Function: GetLabelIdFromUse
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: sLabelUse
.head 5 -  Receive String: sLabelId
.head 5 -  Number: nActionType
.head 4 +  Static Variables

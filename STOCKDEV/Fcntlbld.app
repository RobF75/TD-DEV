MB_Ok|MB_IconAsterisk )
.head 5 +  ! On SAM_FetchRow
.head 6 +  If SqlFetchRow( hLocalSqlPopTbl, lParam, nInd )
.head 7 +  If NOT SalIsNull( colRootId )
.head 8 +  If NOT MySqlPrepExecFetch( hLocalSqlExtra, sSqlExtra, nInd )
.head 9 -  Call SalMessageBox( 'MySqlPrepExecFetch failed on FetchRow of Root Description, Contact Jan about this error.', 'Error', MB_Ok )
.head 7 -  Return TRUE
.head 5 +  On SAM_Create
.head 6 -  Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlPopTbl, 10 )
.head 7 -  Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 -  Set bLocalSqlDoTbl = SqlConnect( hLocalSqlDoTbl ) 
.head 6 +  If bLocalSqlDoTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlDoTbl, 10 )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 -  Set bLocalSqlExtra = SqlConnect( hLocalSqlExtra ) 
.head 6 +  If bLocalSqlExtra
.head 7 -  Call SqlSetLockTimeout( hLocalSqlExtra, 10 )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 -  Set sSQLPOPTABLENAME = ' GROWING_SALE, LOCATION, STOCK_ITEM '
.head 6 -  ! Set sSQLPOPTABLENAME = ' GROWING_SALE, LOCATION, STOCK_ITEM, CULTIVAR '
.head 6 -  Set sORDERBY = ' ORDER BY LOCATION.ROW#, LOCATION.SEQ# '
.head 6 -  Set sSqlExtra = ' SELECT Root_Desc FROM Rootstock
  INTO :hWndForm.colRootDesc WHERE 
  Root_Id = :hWndForm.colRootId'
.head 5 +  On SAM_Destroy
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlDisconnect( hLocalSqlPopTbl )
.head 6 +  If bLocalSqlDoTbl
.head 7 -  Call SqlDisconnect( hLocalSqlDoTbl )
.head 6 +  If bLocalSqlExtra
.head 7 -  Call SqlDisconnect( hLocalSqlExtra )
.head 5 +  On PAM_GETFIELDDATA
.head 6 -  Set sDataDesc = SalNumberToHString( lParam )
.head 6 -  !
.head 6 +  If sDataDesc = 'CULTIVAR.CULT_DESC'
.head 7 -  Set sFormat =  tblGrowingStock.colCultDesc
.head 6 +  Else If sDataDesc = 'CULTIVAR.VARIETY'
.head 7 -  Set sFormat =  tblGrowingStock.colVariety
.head 6 +  Else If sDataDesc = 'ROOTSTOCK.ROOT_ID'
.head 7 -  Set sFormat =  tblGrowingStock.colRootId
.head 6 +  Else If sDataDesc = 'ROOTSTOCK.ROOT_DESC'
.head 7 -  Set sFormat =  tblGrowingStock.colRootDesc
.head 6 +  Else If sDataDesc = 'FARM_MASTER.FARM_NAME'
.head 7 -  Set sFormat = frmFarmStock.dfFarmId
.head 6 +  Else If sDataDesc = 'FARM_MASTER.FARM_DESCRIPTION'
.head 7 -  Set sFormat = frmFarmStock.dfFarmDesc
.head 6 +  Else If sDataDesc = 'LOCATION.ROW#'
.head 7 -  Call SalNumberToStr(  tblGrowingStock.colRow, 0, sFormat )
.head 6 +  Else If sDataDesc = 'LOCATION.SEQ#'
.head 7 -  Call SalNumberToStr( tblGrowingStock.colSeq, 0, sFormat )
.head 6 +  Else If sDataDesc = 'STOCK_ITEM.ITEM_NO'
.head 7 -  Call SalNumberToStr(  tblGrowingStock.colItemNo, 0, sFormat )
.head 6 +  Else
.head 7 -  Return FALSE
.head 6 -  Call PushString( sFormat )
.head 6 -  Return TRUE

.head 6 -  Call SalNumberToStr(  hWndFarmTable.colRow, 0, sFormat )
.head 5 +  Else If sDataDesc = 'LOCATION.SEQ#'
.head 6 -  Call SalNumberToStr( hWndFarmTable.colSeq, 0, sFormat )
.head 5 +  Else If sDataDesc = 'STOCK_ITEM.ITEM_NO'
.head 6 -  Call SalNumberToStr(  hWndFarmTable.colItemNo, 0, sFormat )
.head 5 +  Else 
.head 6 -  Call SalMessageBox( 'Error unknown Data', 'Labels', MB_Ok )
.head 6 -  Return FALSE
.head 5 -  Return TRUE

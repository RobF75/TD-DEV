.head 4 +  Actions 
.head 5 -  Set nString = SalStrScan( sDataDesc, '.' )
.head 5 -  Call SalStrLeft( sDataDesc, nString, sTable )
.head 5 +  If sDataDesc = 'CULTIVAR.CULT_DESC'
.head 6 -  Set sFormat = hWndFarmTable.colCultDesc
.head 5 +  Else If sDataDesc = 'CULTIVAR.VARIETY'
.head 6 -  Set sFormat =  hWndFarmTable.colVariety
.head 5 +  Else If sDataDesc = 'TREE_TYPE.TREE_TYPE'
.head 6 -  Set sFormat =  hWndFarmTable.colTreeType
.head 5 +  Else If sDataDesc = 'TREE_TYPE.TREE_TYPE_DESC'
.head 6 -  Set sFormat =  hWndFarmTable.colTreeTypeDesc
.head 5 +  Else If sDataDesc = 'ROOTSTOCK.ROOT_ID'
.head 6 -  Set sFormat =  hWndFarmTable.colRootId
.head 5 +  Else If sDataDesc = 'ROOTSTOCK.ROOT_DESC'
.head 6 -  Set sFormat =  hWndFarmTable.colRootDesc
.head 5 +  Else If sDataDesc = 'FARM_MASTER.FARM_NAME'
.head 6 -  Set sFormat = sFarmId
.head 5 +  Else If sDataDesc = 'FARM_MASTER.FARM_DESCRIPTION'
.head 6 -  Set sFormat = sFarmDesc
.head 5 +  Else If sDataDesc = 'LOCATION.ROW#'
.head 6 -  Call SalNumberToStr( hWndFarmTable.colRow, 0, sFormat )
.head 5 +  Else If sDataDesc = 'LOCATION.SEQ#'
.head 6 -  Call SalNumberToStr(  hWndFarmTable.colSeq, 0, sFormat )
.head 5 +  Else If sDataDesc = 'STOCK_ITEM.ITEM_NO'
.head 6 -  Call SalNumberToStr(  hWndFarmTable.colItemNo, 0, sFormat )
.head 5 +  Else 
.head 6 -  Call SalMessageBox( 'Error unknown Data', 'Labels', MB_Ok )
.head 6 -  Return FALSE
.head 5 -  Return TRUE

.head 5 +  On PAM_GETFIELDDATA
.head 6 -  Set sDataDesc = SalNumberToHString( lParam )
.head 6 -  !
.head 6 +  If sDataDesc = 'CULTIVAR.CULT_DESC'
.head 7 -  Set sFormat =  tblGrowingOnFarm.colCultDesc
.head 6 +  Else If sDataDesc = 'CULTIVAR.VARIETY'
.head 7 -  Set sFormat =  tblGrowingOnFarm.colVariety
.head 6 +  Else If sDataDesc = 'ROOTSTOCK.ROOT_ID'
.head 7 -  Set sFormat =  tblGrowingOnFarm.colRootId
.head 6 +  Else If sDataDesc = 'ROOTSTOCK.ROOT_DESC'
.head 7 -  Set sFormat =  tblGrowingOnFarm.colRootDesc
.head 6 +  Else If sDataDesc = 'FARM_MASTER.FARM_NAME'
.head 7 -  Set sFormat = tblFarm.colFarm
.head 6 +  Else If sDataDesc = 'FARM_MASTER.FARM_DESCRIPTION'
.head 7 -  Set sFormat = tblFarm.colDesc
.head 6 +  Else If sDataDesc = 'LOCATION.ROW#'
.head 7 -  Call SalNumberToStr(  tblGrowingOnFarm.colRow, 0, sFormat )
.head 6 +  Else If sDataDesc = 'LOCATION.SEQ#'
.head 7 -  Call SalNumberToStr( tblGrowingOnFarm.colSeq, 0, sFormat )

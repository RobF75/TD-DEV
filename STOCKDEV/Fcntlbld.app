.head 2 +  Application Actions
.head 3 +  On SAM_AppStartup
.head 4 +  If strArgArray[0] = ''
.head 5 -  Set SqlDatabase = 'STklocal'
.head 5 -  Set SqlUser = 'GRAHAM'
.head 5 -  Set SqlPassword = 'GRAHAM'
.head 4 +  Else
.head 5 -  Set SqlDatabase = strArgArray[1]
.head 5 -  Set SqlUser = strArgArray[2]
.head 5 -  Set SqlPassword = strArgArray[3]
.head 4 -  !
.head 4 -  ! WHEN MAKING THEN EXECUTABLE INTO STOCK CHANGE THE NAME TO FCNTLBL.EXE
.head 4 -  !
.head 4 -  Set bShowSql = FALSE
.head 4 -  Set bghSqlDetail = SqlConnect( hSqlDetail )
.head 4 +  If bghSqlDetail
.head 5 -  Call SqlSetIsolationLevel( hSqlDetail,'RL')
.head 5 -  Call SqlSetLockTimeout( hSqlDetail,10 )
.head 3 +  On SAM_AppExit
.head 4 +  If bghSqlDetail
.head 5 -  Call SqlDisconnect( hSqlDetail )
.head 3 +  On SAM_SqlError
.head 4 -  Call SqlExtractArgs( wParam, lParam, hSqlError, nSqlError, nErrorPos )
.head 4 -  ! Going to comments the return false line and put in others to do error processing
.head 4 -  ! Return FALSE
.head 4 -  Call SqlGetErrorText( nSqlError, sErrmsg )
.head 4 -  Call SalNumberToStr( nSqlError, 0, sNum )
.head 4 -  Call SalMessageBox( sNum || '-' || sErrmsg || '.
Choose OK to quit.', 'Royalty', MB_Ok | MB_IconStop )
.head 4 -  ! Call SalQuit(  )
.head 4 -  Return FALSE

.head 5 -  String: sName
.head 5 -  Number: nInd
.head 5 -  Number: nSqlHandleNo
.head 5 -  !
.head 5 -  String: sGotLabelId
.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetLabelIdFromUse' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT Label_Id FROM Stock_Labels WHERE Stock_Label_Use = :1 "
.head 7 -  Set sName = 'LBLIDFRMUSE'
.head 7 -  Set sBind = ':sLabelUse'
.head 7 -  Set sInto = ':sGotLabelId'
.head 7 -  !
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set sLabelId = ''
.head 7 -  Set sGotLabelId = ''
.head 7 -  !
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 -  Set sLabelId = sGotLabelId
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 3 +  Function: InsertStockLabelsUse
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nItemNo
.head 5 -  String: sLabelId
.head 5 -  String: sLabelUse
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  ! hcSqlHandle: fcOurHandle
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nSqlHandleNo
.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'InsertStockLabelsUse' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " INSERT INTO Stock_Labels 
( 
  Stock_Item_No,  
  Label_Id, 
  Stock_Label_Use 
) VALUES ( :1, :2, :3 ) "
.head 7 -  Set sName = 'InsStkLblUse'
.head 7 -  Set sBind = ':nItemNo, :sLabelId, :sLabelUse'
.head 7 -  Set sInto = ''
.head 7 -  !
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Execute( )
.head 6 +  Case SH_cls_Commit
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Commit( )
.head 6 +  Case SH_cls_Rollback
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )

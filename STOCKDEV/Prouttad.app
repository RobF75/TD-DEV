.head 7 -    : fcOurHandle
.head 6 +    Local variables 
.head 7 -    String: sSql
.head 7 -    String: sBind
.head 7 -    String: sInto
.head 7 -    String: sName
.head 7 -  !
.head 7 -    String: sGotRegionDesc
.head 7 -  !
.head 7 -    Number: nInd
.head 6 +    Actions 
.head 7 +    Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -    Set sSql = " SELECT Region_Desc 
FROM Region 
WHERE Region_Id = :1 "
.head 9 -    Set sName = 'GETREGDESC'
.head 9 -    Set sBind = ':sRegionId'
.head 9 -    Set sInto = ':sGotRegionDesc'
.head 9 -  !
.head 9 -    Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
.head 9 -    Call SqlVarSetup( fcOurHandle.hSqlHandle )
.head 9 -  !
.head 9 -    Set sRegionDesc = ''
.head 9 -    Set sGotRegionDesc = ''
.head 9 -  !
.head 9 +    If fcOurHandle.Execute( )
.head 10 -    Call fcOurHandle.FetchNext( nInd )
.head 10 -  !
.head 10 -    Set sRegionDesc = sGotRegionDesc
.head 10 -    Return TRUE
.head 9 +    Else 
.head 10 -    Return FALSE
.head 8 +  ! Case nCommit
.head 9 -    Return fcOurHandle.Commit( )
.head 8 +  ! Case nRollback
.head 9 -    Return fcOurHandle.Rollback( )
.head 8 +  Case SH_cls_Disconnect
.head 9 -    Return fcOurHandle.Disconnect( )

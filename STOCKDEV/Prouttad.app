.head 5 +    Function: GetRegionDesc
.head 6 -    Description: 
.head 6 +    Returns 
.head 7 -    Boolean: 
.head 6 +    Parameters 
.head 7 -    String: sRegionId
.head 7 -    Receive String: sRegionDesc
.head 7 -    Number: nActionType

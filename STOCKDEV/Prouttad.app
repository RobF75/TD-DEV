.head 2 +  Application Actions
.head 3 +  On SAM_AppStartup
.head 4 -  ! ASSUMPTION FOR Command Line arguments
Argument 1 - SqlDatabase
Argument 2 - SqlUser
Argument 3 - SqlPassword
Argument 4 - File Name for list of selected load Ids
Argument 5 - Year ( number )
Argument 6 - Action Type ( string ) = ( 'SELECTED_LOADS' OR 'ALL_CUST' )
.head 4 -  !
.head 4 -  ! Set strArgArray[1] = 'STOCKDEV'
.head 4 -  ! Set strArgArray[2] = 'JAN'
.head 4 -  ! Set strArgArray[3] = 'JAN'
.head 4 -  ! Set strArgArray[4] = 'c:\\temp\\loadids.tmp'
.head 4 -  ! Set strArgArray[5] = '96'
.head 4 -  ! Set strArgArray[6] = 'ALL_CUST'
.head 4 -  !
.head 4 -  Set SqlDatabase = strArgArray[ 1 ]
.head 4 -  Set SqlUser = strArgArray[ 2 ]
.head 4 -  Set SqlPassword = strArgArray[ 3 ]
.head 4 -  !
.head 4 -  Set bghSqlDetail = SqlConnect( hSqlDetail )
.head 4 +  If bghSqlDetail
.head 5 -  Call SqlSetIsolationLevel( hSqlDetail,'RL')
.head 5 -  Call SqlSetLockTimeout( hSqlDetail, SQLTIMEOUT )
.head 3 +  On SAM_AppExit
.head 4 +  If bghSqlDetail
.head 5 -  Call SqlDisconnect( hSqlDetail )

.head 4 +  Functions
.head 5 +  Function: GetRegionDesc
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  String: sRegionId
.head 7 -  Receive String: sRegionDesc
.head 7 -  Number: nActionType
.head 6 +  Static Variables
.head 7 -  FunctionalVar: fcOurHandle
.head 8 -  Class: hcSqlHandle
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  String: sBind
.head 7 -  String: sInto
.head 7 -  String: sName
.head 7 -  !
.head 7 -  String: sGotRegionDesc
.head 7 -  !
.head 7 -  Number: nInd
.head 6 +  Actions
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = " SELECT Region_Desc 
FROM Region 
WHERE Region_Id = :1 "
.head 9 -  Set sName = 'GETREGDESC'
.head 9 -  Set sBind = ':sRegionId'
.head 9 -  Set sInto = ':sGotRegionDesc'
.head 9 -  !
.head 9 -  Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
.head 9 -  Call SqlVarSetup( fcOurHandle.hSqlHandle )
.head 9 -  !
.head 9 -  Set sRegionDesc = ''
.head 9 -  Set sGotRegionDesc = ''
.head 9 -  !
.head 9 +  If fcOurHandle.Execute( )
.head 10 -  Call fcOurHandle.FetchNext( nInd )
.head 10 -  !
.head 10 -  Set sRegionDesc = sGotRegionDesc
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  ! Case nCommit
.head 9 -    Return fcOurHandle.Commit( )
.head 8 +  ! Case nRollback
.head 9 -    Return fcOurHandle.Rollback( )
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Return fcOurHandle.Disconnect( )
.head 4 -  Window Variables
.head 4 +  Message Actions
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 +  If frmPrintOutstandingTAs.sActionType = 'ALL_CUST'
.head 7 +  If frmPrintOutstandingTAs.nYear < OurDateYear( SalDateCurrent(  ) )
.head 8 -  Set sSQLTABLENAME = ''
.head 8 -  Set sSQLPOPTABLENAME = 'Customer_Master, Customer_Address, Customer_Contacts, 
Cust_Order_History, Stock_Item, Customer_Type '
.head 8 -  Set sROWID = ''
.head 8 -  Set sSQLWHERE = " WHERE Customer_Master.Customer_Type LIKE '%OR%' AND 
Customer_Master.Customer_Type = Customer_Type.Cust_Type AND 
Customer_Type.NPA_Required = 'Y' AND 
Customer_Master.Cust_No = Customer_Address.Cust_No AND
Customer_Address.Main_Address_Flag = 'Y' AND 
Customer_Master.Cust_No = Customer_Contacts.Cust_No AND 
Customer_Contacts.Main_Contact_Flag = 'Y' AND 
Customer_Master.Cust_No = Cust_Order_History.Cust_No AND 
Cust_Order_History.Year_Of_Sale = :frmPrintOutstandingTAs.nYear AND 
Cust_Order_History.CONF_AMT > 0 AND 
Cust_Order_History.TA_Recd_Flag != 'Y' AND 
Cust_Order_History.SALE_CAT != 'RP' AND
Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
( Stock_Item.CV_on_trial_Flag = 'Y' OR Stock_Item.RT_on_trial_Flag = 'Y' ) "
.head 8 -  Set sORDERBY = 'ORDER BY Customer_Master.Region_Id, Customer_Master.Cust_Name, Customer_Master.Cust_No'
.head 7 +  Else
.head 8 -  Set sSQLTABLENAME = ''
.head 8 -  Set sSQLPOPTABLENAME = 'Customer_Master, Customer_Address, Customer_Contacts, 
Customer_Order, Stock_Item, Customer_Type'
.head 8 -  Set sROWID = ''
.head 8 -  Set sSQLWHERE = " WHERE Customer_Master.Customer_Type LIKE '%OR%' AND 
Customer_Master.Cust_No = Customer_Address.Cust_No AND
Customer_Address.Main_Address_Flag = 'Y' AND 
Customer_Master.Customer_Type = Customer_Type.Cust_Type AND 
Customer_Type.NPA_Required = 'Y' AND 
Customer_Master.Cust_No = Customer_Contacts.Cust_No AND 
Customer_Contacts.Main_Contact_Flag = 'Y' AND 
Customer_Master.Cust_No = Customer_Order.Cust_No AND 
Customer_Order.Year_Of_Sale = :frmPrintOutstandingTAs.nYear AND 
CUSTOMER_ORDER.CONF_AMT > 0 AND 
Customer_Order.TA_Recd_Flag != 'Y' AND 
CUSTOMER_ORDER.SALE_CAT != 'RP' AND
Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
( Stock_Item.CV_on_trial_Flag = 'Y' OR Stock_Item.RT_on_trial_Flag = 'Y' ) "
.head 8 -  Set sORDERBY = 'ORDER BY Customer_Master.Region_Id, Customer_Master.Cust_Name, Customer_Master.Cust_No'
.head 6 +  Else
.head 7 -  Set sSQLTABLENAME = ''
.head 7 -  Set sSQLPOPTABLENAME = 'Load_Customers, Customer_Master, Customer_Address, 
Customer_Contacts, Customer_Order, Stock_Item, Customer_Type '
.head 7 -  Set sROWID = ''
.head 7 -  Set sSQLWHERE = " WHERE Load_Customers.Load_Id = :frmPrintOutstandingTAs.sLoadId AND 
Load_Customers.Cust_No = Customer_Master.Cust_No AND 
Customer_Master.Customer_Type = Customer_Type.Cust_Type AND 
Customer_Type.NPA_Required = 'Y' AND 
Customer_Master.Customer_Type LIKE '%OR%' AND 
Customer_Master.Cust_No = Customer_Address.Cust_No AND 
Customer_Address.Main_Address_Flag = 'Y' AND 
Customer_Master.Cust_No = Customer_Contacts.Cust_No AND 
Customer_Contacts.Main_Contact_Flag = 'Y' AND 
Customer_Master.Cust_No = Customer_Order.Cust_No AND 
Customer_Order.Year_Of_Sale = :frmPrintOutstandingTAs.nYear AND 
CUSTOMER_ORDER.CONF_AMT > 0 AND 
Customer_Order.TA_Recd_Flag != 'Y' AND 
CUSTOMER_ORDER.SALE_CAT != 'RP' AND
Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
( Stock_Item.CV_Non_Prop_Flag = 'Y' OR Stock_Item.RT_Non_Prop_Flag = 'Y' ) "
.head 7 -  Set sORDERBY = ' ORDER BY Load_Customers.Sequence_No'
.head 5 +  On SAM_FetchRowDone
.head 6 +  If NOT SalIsNull( colRegionId )
.head 7 -  Call GetRegionDesc( colRegionId, colRegionDesc, SH_cls_Execute )
.head 5 +  On PAM_NOROWS
.head 6 -  Return TRUE
.head 5 +  On SAM_Destroy
.head 6 -  Call GetRegionDesc( '', colRegionDesc, SH_cls_Disconnect )
.head 6 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

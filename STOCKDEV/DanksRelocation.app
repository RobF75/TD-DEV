.head 11 -  Set bCopied = FALSE							! Set the copy failue flag (reason supplied in function call)
.head 10 -  !
.head 9 +  Else
.head 10 -  Set bCopied = FALSE							! Set the copy failue flag
.head 10 -  Set sReason = 'Unable to resolve State'						! Set the failure reason
.head 9 -  !
.head 8 +  Else
.head 9 -  Set bCopied = FALSE							! Set the copy failue flag
.head 9 -  Set sReason = 'Unable to resolve Cust #'					! Set the failure reason
.head 8 -  !
.head 8 +  ! If bCopied = TRUE								! If Customer # found ok
.head 9 -  !

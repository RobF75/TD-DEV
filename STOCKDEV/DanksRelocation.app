.head 3 +  ! Function: fnSendEmail	! 15/04/05 (PXD) Replaced mail client with direct SMTP 
.head 4 -  Description: Send an email to notify the requested user of the copying results
.head 4 -  Returns 
.head 4 -  Parameters 
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  String: sUser							! Email User name
.head 5 -  String: sPassword							! Email password
.head 5 -  String: sPOP							! Email server name
.head 5 -  Boolean: bAllowUI							! Open user interface on send?
.head 5 -  Number: nSession							! Session ID number
.head 5 -  String: sMessageType						! Email Client type ??
.head 5 -  String: sSubject							! Email header
.head 5 -  String: sNoteText							! Text of Email
.head 5 -  String: sTORecips							! Deliver TO
.head 5 -  String: sCCRecips							! Deliver COPY TO
.head 5 -  String: sBCCRecips						! Deliver BLIND COPY TO
.head 5 -  String: sAttachments						! Attachment location
.head 5 -  Boolean: bRetReceipt						! Return receipt requested
.head 5 -  Number: nPriority							! Priority of Message
.head 5 -  Number: nNumber							! Unsure of this parameter's usage
.head 4 +  Actions 
.head 5 -  ! Set sUser = ''							! Email User account
.head 5 -  ! Set sPassword = ''						! Account password
.head 5 -  ! Set sPOP = 'corellinux'						! Email server name
.head 5 -  Set bAllowUI = FALSE						! Disable user interface
.head 5 -  Set nSession = 1							! Set session ID
.head 5 -  Call MailConnect( sUser, sPassword, sPOP, bAllowUI, nSession )		! Connect to Email client
.head 5 -  !
.head 5 -  Set sMessageType = ''						! Default client type
.head 5 -  Set sSubject = 'Danks File Copy Process'				! Email title
.head 5 -  Set sNoteText = sFileCount||' matching items. The copy process has completed with the following results:'	! Body text
.head 5 -  Set sNoteText = sNoteText || sEmailText				! Add in the result text lines
.head 5 -  Set sTORecips = 'pdunlop@flemings.com.au'				! Send to assigned user
.head 5 -  Set sCCRecips = ''							! No copy required
.head 5 -  Set sBCCRecips = ''						! No blind copy either
.head 5 -  Set sAttachments = ''						! No attachments to send
.head 5 -  Set bRetReceipt = FALSE						! Don't need a receipt
.head 5 -  Set nPriority = 1							! Email Priority 
.head 5 -  Set nNumber = 1							! Anything above 1 sends a request rcpt
.head 5 -  Call MailSend( nSession, sMessageType, sSubject, sNoteText, sTORecips,
sCCRecips, sBCCRecips, sAttachments, bRetReceipt, nPriority, nNumber )		! Send the message
.head 5 -  !
.head 5 -  Call MailDisconnect( nSession )					! Finished with email client
.head 3 +  Function: fnSendEmail	
.head 4 -  Description: Send an email to notify the requested user of the copying results 
15/04/05 (PXD) Replaced previous mail client usage with direct SMTP sending
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: sEmailText				! Prebuilt text of the email
.head 5 -  String: sFileCount				! Count of files processed
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sRecipient				! Email recipient(s)
.head 5 -  String: sCopy				! CC addresses
.head 5 -  String: sBlindCopy				! BCC addresses
.head 5 -  String: sOriginator				! Sender address
.head 5 -  String: sNickname				! Sender friendly name
.head 5 -  String: sTitle				! Email title
.head 5 -  String: sBody				! Email body text
.head 5 -  String: sAttachment				! Email attachment(s)
.head 5 -  String: sServer				! Mail server to use
.head 5 -  String: sEmailPort				! Mail server connection port (char)
.head 5 -  Number: nPort				! Mail server connection port (numeric)
.head 4 +  Actions
.head 5 -  !
.head 5 -  Set sRecipient = 'pdunlop@flemings.com.au'	! Send to assigned user
.head 5 -  Set sCopy = STRING_Null			! CC to no-one
.head 5 -  Set sBlindCopy = STRING_Null		! BCC to no-one
.head 5 -  Set sNickname = 'Automated'			! Friendly name of sender
.head 5 -  Set sOriginator = 'Automated@flemings.com.au'	! Address of sender
.head 5 -  !
.head 5 -  Set sTitle =  'Danks File Copy Process'		! Email title
.head 5 -  Set sBody = sFileCount || ' matching items. The copy process has completed with the following results:'		! Body text
.head 5 -  Set sBody = sBody || sEmailText		! Add in the result text lines
.head 5 -  Set sAttachment = STRING_Null		! No attachments to send
.head 5 -  !
.head 5 -  Set sServer = 'dualxeon'			! Local mail server
.head 5 -  Set nPort = 25				! SMTP port
.head 5 -  !
.head 5 -  Call SMTPSend( sRecipient, sCopy, sBlindCopy, sNickname, sOriginator, sTitle, sBody, sAttachment, sServer, nPort )	! Send email via SMTP
.head 5 -  !
.head 5 -  Return TRUE

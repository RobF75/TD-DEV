.head 2 +  Message Actions 
.head 3 +  On SAM_Create
.head 4 -  !
.head 4 -  Set sLocation = 'X:\\Filing\\Customer\\B2BE\\HostIn'				! Set Danks file location path	
.head 4 -  Set sSuffix = '\\*.B2BE_AUTOACK'						! Set file type to find
.head 4 -  Set nFileCount = VisDosEnumFiles (sLocation||sSuffix, FA_Standard, sFiles )		! Get matching item names and count
.head 4 -  !
.head 4 +  If nFileCount < 0								! If no files match (i.e. error cond.)
.head 5 -  Set sFileCount = '0'								! set matching count string to zero
.head 4 +  Else 
.head 5 -  Set sFileCount = SalNumberToStrX( nFileCount, 0 )					! Otherwise get true string value of count
.head 4 -  !
.head 4 -  Set nCounter = 0								! Initialise loop counter / array pointer
.head 4 -  !
.head 4 +  While nCounter < nFileCount							! Do while counter value less than matching item count
.head 5 -  !
.head 5 -  Set sFileName = sFiles[ nCounter ]						! Save file name
.head 5 -  Set sSourcePath = sLocation||'\\'||sFileName					! Save path to file for this item
.head 5 -  Set bCopied = TRUE							! Initialise the item copied flag
.head 5 -  Set sReason = STRING_Null							! Initialise error reason
.head 5 -  !
.head 5 -  Set bOk = SalTblPopulateFromXML (hWndForm, sFileName, sRootNode, bTableNode, bUseSchema)
.head 5 -  !
.head 5 -  !
.head 5 -  !
.head 5 -  !
.head 5 +  If SalFileOpen( hFileRead, sSourcePath, OF_Read | OF_Text )			! Open this file for reading
.head 6 -  Set nMaxLineSize = 999							! Max length of string to read
.head 6 +  If SalFileGetStr( hFileRead,sInputLine,nMaxLineSize )				! Get first text line from file
.head 7 -  Set nFieldCount = SalStrTokenize( sInputLine, '', '|', sInputField )			! Break it down into input fields
.head 7 -  Set sInvoiceNo = sInputField[4]						! Invoice number is 5th field
.head 7 +  If sInvoiceNo = STRING_Null							! If no invoice number given
.head 8 -  Set bCopied = FALSE							! Set item copy failure flag
.head 8 -  Set sReason = 'Invalid Invoice #'						! Set the failure reason
.head 6 +  Else 
.head 7 -  Set bCopied = FALSE							! Can't get text line
.head 7 -  Set sReason = 'Unable to read file text'						! Set the failure reason
.head 6 -  !
.head 6 -  Call SalFileClose( hFileRead )							! Close this file
.head 6 -  !
.head 6 +  If bCopied = TRUE								! If Invoice # found ok
.head 7 -  Set nInvoiceNo = SalStrToNumber( sInvoiceNo )					! Convert Invoice # to numeric value
.head 7 -  !
.head 7 +  If fnFindCustNo( nInvoiceNo, nCustNo )						! Get Customer # for this invoice
.head 8 -  !
.head 8 +  If fnFindCustDetails( nCustNo, sState )						! Get the Customer State Details
.head 9 -  !
.head 9 +  If NOT fnCopyDanksFile( nCustNo, nInvoiceNo, sSourcePath, sDanksFileName, sReason )		! Copy the file to new location
.head 10 -  Set bCopied = FALSE							! Set the copy failue flag (reason supplied in function call)
.head 9 -  !
.head 8 +  Else 
.head 9 -  Set bCopied = FALSE							! Set the copy failue flag
.head 9 -  Set sReason = 'Unable to resolve State'						! Set the failure reason
.head 8 -  !
.head 7 +  Else 
.head 8 -  Set bCopied = FALSE							! Set the copy failue flag
.head 8 -  Set sReason = 'Unable to resolve Cust #'					! Set the failure reason
.head 7 -  !
.head 7 +  ! If bCopied = TRUE								! If Customer # found ok
.head 8 -  !
.head 8 -  Call fnFindCustDetails( nCustNo, sState )						! Get the Customer State Details
.head 8 -  !
.head 8 +  If bCopied = TRUE								! If Customer Details found ok
.head 9 -  !
.head 9 -  Call fnCopyDanksFile( )							! Copy the file to new location
.head 8 -  !
.head 7 -  !
.head 6 -  !
.head 5 +  Else 
.head 6 -  Set bCopied = FALSE							! Set item copy failure flag						
.head 6 -  Set sReason = 'Unable to open Danks file'					! Set the failure reason
.head 5 -  !
.head 5 -  Set sNewLine = '
Danks file name '||sFiles[ nCounter ]						! Set up the email text line for item
.head 5 +  If bCopied = TRUE								! If this file copied ok
.head 6 -  Set sNewLine = sNewLine||' for invoice '||sInvoiceNo||' copied successfully'		! Adjust text to show success
.head 5 +  Else 
.head 6 -  Set sNewLine = sNewLine||' FAILED to copy. '||sReason				! Otherwise reflect the failure
.head 5 -  Set sEmailText = sEmailText||sNewLine						! Add the line to the email message
.head 5 -  Set nCounter = nCounter + 1							! Increment counter / array pointer
.head 4 -  !
.head 4 -  Set sEmailText = sEmailText||'
End of Report.'								! Add EOM to the email message
.head 4 -  !
.head 4 -  Call fnSendEmail( sEmailText, sFileCount )					! Create an email notification
.head 4 -  !
.head 4 -  Return TRUE								! Finished Copying 
.head 4 -  !
.head 4 -  !
.head 4 -  Set sFile = ""
.head 4 -  Set sRootNode = "B2BEAutoAck"
.head 4 -  Set bTableNode = TRUE
.head 4 -  Set bUseSchema = FALSE
.head 4 -  !
.head 4 -  Set bOk = SalTblPopulateFromXML (hWndForm, sFile, sRootNode, bTableNode, bUseSchema)
.head 4 -  !

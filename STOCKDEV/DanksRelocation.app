.head 2 +  Internal Functions
.head 3 +  ! Function: fnFindCustNo
.head 4 -  Description: Get the matching customer number for the invoice number found in the Danks file
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 +  Parameters 
.head 5 -  Number: nInvoiceNo							! Invoice number to process
.head 5 -  Receive Number: nCustNo							! Customer number of invoice owner
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  String: sSql								! SQL string
.head 5 -  Sql Handle: hSql								! SQL handle
.head 5 -  Number: nRetVal								! Return value
.head 5 -  String: sStatus								! Invoice status 
.head 4 +  Actions 
.head 5 -  Set sStatus = 'FINAL'							! Status of invoice required
.head 5 -  Set sSql = '
SELECT 
	CUST_NO
FROM 
	INV_NO_REGISTER
INTO
	:nCustNo
WHERE 
	INVOICE_NO = :nInvoiceNo
AND	STATUS = :sStatus
AND	CUST_NO > 0'							! Get customer number for invoice
.head 5 -  Call SqlConnect( hSql )							! Connect to database
.head 5 -  Call SqlPrepareAndExecute( hSql, sSql )						! Execute the SQL statement
.head 5 -  Call SqlFetchNext( hSql, nRetVal )						! Get the results	
.head 5 +  If nRetVal = FETCH_EOF							! If the results don't exist
.head 6 -  Set bCopied = FALSE							! Set the copy failue flag
.head 6 -  Set sReason = 'Unable to resolve Cust #'					! Set the failure reason
.head 5 -  Call SqlDisconnect( hSql )							! Disconnect from DB
.head 5 -  Return TRUE								! Back to caller
.head 3 +  Function: fnFindCustNo
.head 4 -  Description: Get the matching customer number for the invoice number found in the Danks file
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nInvoiceNo							! Invoice number to process
.head 5 -  Receive Number: nCustNo							! Customer number of invoice owner
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Sql Handle: hSql								! Connection handle
.head 5 -  String: sSql								! SQL statement
.head 5 -  Number: nRetCode								! SQL processing return code
.head 5 -  Boolean: bFetched								! Function status return flag
.head 4 +  Actions
.head 5 -  Set bFetched = FALSE							! Initialise return rlag
.head 5 -  !
.head 5 -  Set sSql = "
SELECT 
	CUST_NO
FROM 
	INV_NO_REGISTER
INTO
	:nCustNo
WHERE 
	INVOICE_NO = :nInvoiceNo
AND	STATUS = 'FINAL'
AND	CUST_NO > 0"							! Get customer number for invoice
.head 5 -  !
.head 5 +  If SqlConnect( hSql )							! If handle connected Ok
.head 6 +  If SqlPrepareAndExecute( hSql, sSql )						! And executed Ok
.head 7 -  Set bFetched = SqlFetchRow( hSql, 0, nRetCode )					! Fetch the data
.head 6 -  Call SqlDisconnect (hSql)							! Disconnnect handle
.head 5 -  !
.head 5 -  Return bFetched								! Function status return flag
.head 3 +  ! Function: fnFindCustDetails
.head 4 -  Description: Get the required details of the matching customer from the address table
.head 4 -  Returns 
.head 4 +  Parameters 
.head 5 -  Number: nCustNo							! Customer number to process
.head 5 -  Receive String: sState						! Home State of customer
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  String: sSql								! SQL string
.head 5 -  Sql Handle: hSql								! SQL handle
.head 5 -  Number: nRetVal								! Return value
.head 4 +  Actions 
.head 5 -  Set sSql = "
SELECT 
	STATE
FROM 
	CUSTOMER_ADDRESS
INTO
	:sState
WHERE 
	CUST_NO = :nCustNo
AND 	MAIN_ADDRESS_FLAG = 'Y'"					! Get the customer details
.head 5 -  Call SqlConnect( hSql )							! Connect to database
.head 5 -  Call SqlPrepareAndExecute( hSql, sSql )					! Execute the SQL statement
.head 5 -  Call SqlFetchNext( hSql, nRetVal )						! Get the results		
.head 5 +  If nRetVal = FETCH_EOF							! If the results don't exist
.head 6 -  Set bCopied = FALSE							! Set the copy failue flag
.head 6 -  Set sReason = 'Unable to resolve State'					! Set the failure reason
.head 5 -  Call SqlDisconnect( hSql )							! Disconnect from DB
.head 5 -  Return TRUE								! Back to caller
.head 3 +  Function: fnFindCustDetails
.head 4 -  Description: Get the required details of the matching customer from the address table
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo							! Customer number to process
.head 5 -  Receive String: sState						! Home State of customer
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Sql Handle: hSql								! Connection handle
.head 5 -  String: sSql								! SQL statement
.head 5 -  Number: nRetCode								! SQL processing return code
.head 5 -  Boolean: bFetched								! Function status return flag
.head 4 +  Actions
.head 5 -  Set bFetched = FALSE							! Initialise return rlag
.head 5 -  !
.head 5 -  Set sSql = "
SELECT 
	STATE
FROM 
	CUSTOMER_ADDRESS
INTO
	:sState
WHERE 
	CUST_NO = :nCustNo
AND 	MAIN_ADDRESS_FLAG = 'Y'"					! Get the customer details
.head 5 -  !
.head 5 +  If SqlConnect( hSql )							! If handle connected Ok
.head 6 +  If SqlPrepareAndExecute( hSql, sSql )						! And executed Ok
.head 7 -  Set bFetched = SqlFetchRow( hSql, 0, nRetCode )					! Fetch the data
.head 6 -  Call SqlDisconnect (hSql)							! Disconnnect handle
.head 5 -  !
.head 5 -  Return bFetched								! Function status return flag
.head 3 +  Function: fnCopyDanksFile
.head 4 -  Description: Copies the Danks file to the new customer based location and deletes the original
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Number: nCustNo								! Customer to process
.head 5 -  Number: nInvoiceNo							! Invoice to process
.head 5 -  String: sSourcePath								! Location of the file to process
.head 5 -  String: sDanksFileName							! Name of file to process
.head 5 -  Receive String: sReason							! Failure msg (if applicable)
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sDestPath								! Where to copy file to
.head 5 -  String: sCustNo								! Directory structure Cust #
.head 5 -  String: sFileType								! Directory structure file type
.head 5 -  Number: nCopyResult							! Result of copy process
.head 5 -  Boolean: bDirCreated							! Directory creation flag
.head 5 -  Boolean: bProcessed							! Function priocessing status flag
.head 4 +  Actions
.head 5 -  Set bProcessed = FALSE							! Initialise process status flag
.head 5 -  !
.head 5 -  Set sFileType = 'Invoices'							! Playing with invoice area
.head 5 -  Set sCustNo = SalNumberToStrX( nCustNo, 0 )					! Get string value of Cust #
.head 5 -  Set sInvoiceNo = SalNumberToStrX( nInvoiceNo, 0 )				! Get string value of Invoice #
.head 5 -  !
.head 5 +  If bDebugMode = TRUE							! Running in DEBUG mode - don't delete the file
.head 6 -  Call SalMessageBox( 'Copying file to C:\Temp\Test', 'DEBUG Mode', MB_Ok )
.head 6 -  Set sDestPath = 'C:\\Temp\\Test'						! Test location
.head 5 +  Else
.head 6 -  Set sDestPath = 'X:\\Filing\\Customer'						! Basic filing location path
.head 5 -  !
.head 5 -  Set sDestPath = sDestPath||'\\'||sState||'\\'||sCustNo||'\\'||sFileType||'\\'||sInvoiceNo	! Fully qualified destination path
.head 5 -  !
.head 5 -  Set bDirCreated = SalFileCreateDirectory( sDestPath )				! Create destination path
.head 5 -  Set sDestPath = sDestPath||'\\'||sDanksFileName				! Fully qualified file name
.head 5 -  !
.head 5 -  Set nCopyResult = SalFileCopy( sSourcePath, sDestPath, TRUE )			! Copy file
.head 5 +  Select Case nCopyResult							! Select process result
.head 6 +  Case FILE_CopyOK					
.head 7 -  !
.head 7 +  If bDebugMode = TRUE							! Running in DEBUG mode - don't delete the file
.head 8 -  Call SalMessageBox( 'Delete function currently disabled', 'FILE_CopyOK', MB_Ok )
.head 7 +  Else
.head 8 -  Call VisFileDelete( sSourcePath )						! Delete original file
.head 7 -  !
.head 7 -  Set sReason =  STRING_Null
.head 7 -  Set bProcessed = TRUE							! Reset copy flag if successful
.head 7 -  Break
.head 6 +  Case FILE_CopySrc
.head 7 -  Set sReason =  'Unable to open source file'
.head 7 -  Break
.head 6 +  Case FILE_CopyDest
.head 7 -  Set sReason = 'Unable to open destination file'
.head 7 -  Break
.head 6 +  Case FILE_CopyExist
.head 7 -  Set sReason = 'This file already exists'
.head 7 -  Break
.head 6 +  Case FILE_CopyRead
.head 7 -  Set sReason = 'Read failed during copy'
.head 7 -  Break
.head 6 +  Case FILE_CopyWrite
.head 7 -  Set sReason = 'Write failed during copy'
.head 7 -  Break
.head 6 +  Default
.head 7 -  Set sReason = 'Unknown Error'
.head 7 -  Break
.head 5 -  !
.head 5 -  Return bProcessed
.head 3 +  Function: fnProcessDanksFiles
.head 4 -  Description: Opens the confirmation data file supplied to us by Danks and extracts the invoice number
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sLocation								! Downloaded Danks file location
.head 5 -  File Handle: hFileRead							! Handle for read process
.head 5 -  Number: nFileCount								! Count of matching files found
.head 5 -  String: sSuffix								! File type to look for
.head 5 -  String: sFiles[*]								! Array of matching file names
.head 5 -  Number: nCounter								! Loop control counter
.head 5 -  String: sNewLine								! Email text line
.head 5 -  String: sInputLine								! Input string from file
.head 5 -  Number: nMaxLineSize							! Maximum input string length
.head 5 -  String: sInputField[*]								! Breakdown of input string fields
.head 5 -  Number: nFieldCount							! Count of input fields tokenised
.head 4 +  Actions
.head 5 -  Set sLocation = 'X:\\Filing\\Customer\\B2BE\\HostIn'				! Set Danks file location path	
.head 5 -  Set sSuffix = '\\*.B2BE_AUTOACK'						! Set file type to find
.head 5 -  Set nFileCount = VisDosEnumFiles (sLocation||sSuffix, FA_Standard, sFiles )		! Get matching item names and count
.head 5 -  !
.head 5 +  If nFileCount < 0								! If no files match (i.e. error cond.)
.head 6 -  Set sFileCount = '0'								! set matching count string to zero
.head 5 +  Else
.head 6 -  Set sFileCount = SalNumberToStrX( nFileCount, 0 )					! Otherwise get true string value of count
.head 5 -  !
.head 5 -  Set nCounter = 0								! Initialise loop counter / array pointer
.head 5 -  !
.head 5 +  While nCounter < nFileCount							! Do while counter value less than matching item count
.head 6 -  !
.head 6 -  Set sDanksFileName = sFiles[ nCounter ]					! Save file name
.head 6 -  Set sSourcePath = sLocation||'\\'||sDanksFileName				! Save path to file for this item
.head 6 -  Set bCopied = TRUE							! Initialise the item copied flag
.head 6 -  Set sReason = STRING_Null							! Initialise error reason
.head 6 -  !
.head 6 +  If SalFileOpen( hFileRead, sSourcePath, OF_Read | OF_Text )			! Open this file for reading
.head 7 -  Set nMaxLineSize = 999							! Max length of string to read
.head 7 +  If SalFileGetStr( hFileRead,sInputLine,nMaxLineSize )				! Get first text line from file
.head 8 -  !
.head 8 -  ! 31/05/05 (PXD) B2BE software now uses XML headers. Changed InvoiceNo location code to reflect this..
.head 8 -  ! Set nFieldCount = SalStrTokenize( sInputLine, '', '|', sInputField )			! Break it down into input fields
.head 8 -  ! Set sInvoiceNo = sInputField[4]						! Invoice number is 5th field
.head 8 -  !
.head 8 -  Set nFieldCount = SalStrTokenize( sInputLine, '', '>', sInputField )			! Break it down into input fields
.head 8 -  Set sInvoiceNo = sInputField[8]						! Invoice number is 9th XML header field
.head 8 -  Set sInvoiceNo = SalStrLeftX( sInvoiceNo, SalStrScan( sInvoiceNo, "<" ))		! Trim off XML trailer info	
.head 8 -  !
.head 8 +  If sInvoiceNo = STRING_Null							! If no invoice number given
.head 9 -  Set bCopied = FALSE							! Set item copy failure flag
.head 9 -  Set sReason = 'Invalid Invoice #'						! Set the failure reason
.head 7 +  Else
.head 8 -  Set bCopied = FALSE							! Can't get text line
.head 8 -  Set sReason = 'Unable to read file text'						! Set the failure reason
.head 7 -  !

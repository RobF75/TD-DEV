.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLTABLENAME = ' STOCK_ITEM '
.head 6 -  Set sSQLPOPTABLENAME= ' STOCK_ITEM '
.head 6 -  ! Set sSQLWHERE= ""
.head 6 -  Set sORDERBY = ' ORDER BY 1,2,3,4,6 '
.head 6 -  Set sTableHeading = 'Stock Items For Sale'
.head 6 -  Set hWndRowNewColumn = colYear
.head 6 -  Set sQueryDialogName = 'dlgQueryTblItems'
.head 6 -  Set nTableFillType = TBL_FillAll
.head 6 -  !
.head 6 -  Set nDontSellColor = COLOR_Red
.head 5 +  On PAM_POPULATE
.head 6 -  Set nTotalRows = 0
.head 6 -  Return SalSendClassMessage( PAM_POPULATE, wParam, lParam )
.head 5 +  On PAM_SEARCH
.head 6 -  Set nTotalRows = 0
.head 6 -  Return SalSendClassMessage( PAM_SEARCH, wParam, lParam )
.head 5 +  On SAM_FetchRowDone
.head 6 -  Set colYear = frmAvailability.dfYear
.head 6 -  Call CheckYearExists( colItemNo, colYear, bYearExists, colSoldOutFlag, SH_cls_Execute )
.head 6 +  If bYearExists
.head 7 -  Set nTotalRows = nTotalRows + 1
.head 7 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_Selected, TRUE )
.head 7 -  Call CalcItemTotAvailForQueries( colItemNo, colYear, colAvail, SH_cls_Execute )
.head 5 +  On PAM_QUERY
.head 6 +  If SalSendClassMessage( PAM_QUERY, wParam, lParam )
.head 7 -  Call SalWaitCursor( TRUE )
.head 7 -  !
.head 7 -  Call SalSendMsg( tblTreeTypeColumns, PAM_RESET, 0, 0 )
.head 7 -  Call SalSendMsg( tblAvailability, PAM_RESET, 0, 0 )
.head 7 -  !
.head 7 -  Set sTreeType = ''
.head 7 -  Set sLastCultId = 'START'
.head 7 -  Set sLastRootId = 'START'
.head 7 -  Set sLastGenFlag = 'START'
.head 7 -  Call MyTableLoop( hWndForm, hWndForm, PAM_ROWGETTREETYPES, ROW_Selected, 0, 'Collecting Tree Types', nLowToHi )
.head 7 -  !
.head 7 -  Set sTreeType = ''
.head 7 -  Set sLastCultId = 'START'
.head 7 -  Set sLastRootId = 'START'
.head 7 -  Set sLastGenFlag = 'START'
.head 7 -  Call MyTableLoop( hWndForm, hWndForm, PAM_ROWFORMATTREETYPES, ROW_Selected, 0, 'Formatting', nLowToHi )
.head 7 -  !
.head 7 -  Call SalWaitCursor( FALSE )
.head 5 +  On PAM_SETTABLELOOPTOTALROWS
.head 6 -  Call PushNumber( nTotalRows )
.head 6 -  Return TRUE
.head 5 +  ! On PAM_PUSHFIELDS
.head 6 -  Call PushNumber( frmAvailability.dfYear )
.head 6 -  Return TRUE
.head 5 +  ! On PAM_POPFIELDS
.head 6 -  Call PopNumber( frmAvailability.dfYear, TRUE )
.head 6 -  Return TRUE
.head 5 +  On PAM_REPOPULATE
.head 6 -  Set nTotalRows = 0
.head 6 -  Return SalSendMsg( hWndForm, PAM_QUERY, 0, 0 )
.head 5 +  On PAM_ROWGETTREETYPES
.head 6 +  If sLastCultId = colCultId AND sLastRootId = colRootId AND sLastGenFlag = colGenFlag
.head 7 -  Call PushString( colTreeType )
.head 7 +  If SalSendMsg( tblTreeTypeColumns, PAM_LOOKUP, 0, 0 )
.head 8 -  Call PopNumber( nNewColId, TRUE )
.head 7 +  Else
.head 8 -  Call CreateNewColumn( tblAvailability, colTreeType, nNewColId )
.head 8 -  Call StoreTreeTypeColId( tblTreeTypeColumns, colTreeType, nNewColId )
.head 7 -  !
.head 6 +  Else
.head 7 -  Set sLastCultId = colCultId
.head 7 -  Set sLastRootId = colRootId
.head 7 -  Set sLastGenFlag = colGenFlag
.head 7 -  !
.head 7 -  Call PushString( colTreeType )
.head 7 +  If SalSendMsg( tblTreeTypeColumns, PAM_LOOKUP, 0, 0 )
.head 8 -  Call PopNumber( nNewColId, TRUE )
.head 7 +  Else
.head 8 -  Call CreateNewColumn( tblAvailability, colTreeType, nNewColId )
.head 8 -  Call StoreTreeTypeColId( tblTreeTypeColumns, colTreeType, nNewColId )
.head 7 -  !
.head 6 -  !
.head 6 -  Return TRUE
.head 5 +  On PAM_ROWFORMATTREETYPES
.head 6 +  If colAvail != 0
.head 7 +  If sLastCultId = colCultId AND sLastRootId = colRootId AND sLastGenFlag = colGenFlag
.head 8 -  Call PushString( colTreeType )
.head 8 +  If SalSendMsg( tblTreeTypeColumns, PAM_LOOKUP, 0, 0 )
.head 9 -  Call PopNumber( nNewColId, TRUE )
.head 8 -  !
.head 8 -  Call MoveDataSameRow( tblAvailability, nNewColId, colAvail )
.head 7 +  Else
.head 8 -  Set sLastCultId = colCultId
.head 8 -  Set sLastRootId = colRootId
.head 8 -  Set sLastGenFlag = colGenFlag
.head 8 -  !
.head 8 -  Call PushString( colTreeType )
.head 8 +  If SalSendMsg( tblTreeTypeColumns, PAM_LOOKUP, 0, 0 )
.head 9 -  Call PopNumber( nNewColId, TRUE )
.head 8 -  !
.head 8 -  Call MoveDataNewRow( tblAvailability, colCultDesc, colRootDesc, nNewColId, colAvail )
.head 7 -  !
.head 7 +  If colGenFlag = 'Y'
.head 8 -  Call SalSendMsg( tblAvailability, PAM_GENERICROW, 0, lParam )
.head 7 -  !
.head 7 +  If colSoldOutFlag = 'Y' OR colCVNotSaleFlag = 'Y' OR colRTNotSaleFlag = 'Y'
.head 8 -  Set hWndCol = SalTblGetColumnWindow( tblAvailability, nNewColId, COL_GetID )
.head 8 -  Call SalColorSet( hWndCol, COLOR_IndexCellText, nDontSellColor )
.head 6 -  Return TRUE
.head 5 +  On SAM_Destroy
.head 6 -  Call CheckYearExists( 0, 0, bYearExists, colSoldOutFlag, SH_cls_Disconnect )
.head 6 -  Call CalcItemTotAvailForQueries( 0, 0, colAvail, SH_cls_Disconnect )
.head 6 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

.head 2 +  Application Actions
.head 3 +  On SAM_AppStartup
.head 4 -  ! 22/2/95  This app CANNOT be put into live until the denormalised stock item table
is adjusted
.head 4 -  ! 22/5/95 Sold Out, cultivar not for sale, and rootstock not for sale check is implemented
.head 4 -  !
.head 4 +  If strArgArray[0]
.head 5 -  Set SqlDatabase = 'STOCKDEV'
.head 5 -  Set SqlUser = 'REBECCA'
.head 5 -  Set SqlPassword = 'REBECCA'
.head 4 +  Else
.head 5 -  Set SqlDatabase = strArgArray[1]
.head 5 -  Set SqlUser = strArgArray[2]
.head 5 -  Set SqlPassword = strArgArray[3]
.head 4 -  !
.head 4 -  ! Set hWndCheckExists = FindWindowA(0,"Availability")
.head 4 -  ! Set bCheckExistsWindowHidden = FALSE
.head 4 +  ! If hWndCheckExists
.head 5 +  If NOT SalIsWindowVisible( hWndCheckExists )
.head 6 -  Set bCheckExistsWindowHidden = TRUE
.head 5 -  Call SalBringWindowToTop( hWndCheckExists )
.head 5 -  ! Maximize the window
.head 5 -  Call ShowWindow(hWndCheckExists,3)
.head 5 +  ! TS 4/5/95 Doesn't work correctly - If bCheckExistsWindowHidden
.head 6 -  Call SalHideWindow( hWndCheckExists )
.head 5 -  Call SalMessageBeep( 1 )
.head 5 -  Call SalQuit(  )
.head 4 -  !
.head 4 -  Set bShowSql = FALSE
.head 4 -  Set bghSqlDetail = SqlConnect( hSqlDetail )
.head 4 +  If bghSqlDetail
.head 5 -  Call SqlSetIsolationLevel( hSqlDetail, 'RL')
.head 5 -  Call SqlSetLockTimeout( hSqlDetail, SQLTIMEOUT )
.head 3 +  On SAM_SqlError
.head 4 -  Call SqlExtractArgs( wParam, lParam, hSqlError, nSqlError, nErrorPos )
.head 4 -  ! Going to comments the return false line and put in others to do error processing
.head 4 -  ! Return FALSE
.head 4 -  Call SqlGetErrorText( nSqlError, sErrmsg )
.head 4 -  Call SalNumberToStr( nSqlError, 0, sNum )
.head 4 -  Call SalMessageBox( sNum || '-' || sErrmsg || '.
Choose OK to quit.', 'Customer', MB_Ok | MB_IconStop )
.head 4 -  ! Call SalQuit(  )
.head 4 -  Return FALSE
.head 3 +  On SAM_AppExit
.head 4 +  If bghSqlDetail
.head 5 -  Call SqlDisconnect( hSqlDetail )

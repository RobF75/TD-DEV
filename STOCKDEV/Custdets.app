.head 8 -  ! replace the column name with the following to make the surname interchange
  with the first name if we have them separated by a comma.
  "@RIGHT( CUST_NAME,@LENGTH( CUST_NAME ) -@SCAN( CUST_NAME , ',') - @IF( @SCAN( CUST_NAME , ',' )+1, 2, 0 )) || ' ' || @LEFT( CUST_NAME ,@SCAN( CUST_NAME , ',' ) )"
.head 8 -  Call BuildSQL( wParam,hWndItem,' CUSTOMER_MASTER.CUST_NAME ' )

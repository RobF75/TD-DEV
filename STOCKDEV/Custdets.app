  otherwise the order by will need to be adjusted.
.head 6 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
.head 6 -  Call SalTblSetLockedColumns( hWndForm, 2 )
.head 5 +  On PAM_REPOPULATE

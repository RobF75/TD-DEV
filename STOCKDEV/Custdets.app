.head 4 +  Message Actions
.head 5 +  On PAM_POPULATE
.head 6 -  Set nWhichPopulate = 1
.head 6 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere1, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
.head 5 +  On PAM_POPULATE2
.head 6 -  ! for NPAs
.head 6 -  Set nWhichPopulate = 2
.head 6 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere2, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
.head 5 +  On PAM_POPULATE3
.head 6 -  ! for Hail Damaged Letters
.head 6 -  Set nWhichPopulate = 3
.head 6 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere3, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
.head 5 +  On PAM_POPULATE4
.head 6 -  ! for Customer Details listing
.head 6 -  Set nWhichPopulate = 4
.head 6 +  If bgOrderByName
.head 7 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere4, nSELECT, sSQLPOPTABLENAME, sOrderByName, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
.head 6 +  Else
.head 7 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere4, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
.head 5 +  On PAM_POPULATE5
.head 6 -  ! for Order Form master listing for customers who arent orchardists and have
their mailist flag = Y 
.head 6 -  Set nWhichPopulate = 5
.head 6 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere5, nSELECT, sSQLPOPTABLENAME, sOrderByName, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
.head 5 +  On PAM_POPULATE6
.head 6 -  ! for ORCHARDISTS listing for customers AND Have
their mailist flag = Y 
.head 6 -  Set nWhichPopulate = 6
.head 6 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere6, nSELECT, sSQLORCHTABLENAME, sOrderByName, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
.head 5 +  On SAM_FetchRowDone
.head 6 +  If bPrintCustDets
.head 7 +  If NOT bSqlCurrSalesPrep
.head 8 +  If SqlPrepare( hSqlCurrSales, 'SELECT SUM(ORDERED_AMOUNT), SUM(CONF_AMT) FROM
CUSTOMER_ORDER INTO :frmQCustomer.tblMaster.nSumOrdAmt, 
:frmQCustomer.tblMaster.nSumConfAmt 
 WHERE CUST_NO = :frmQCustomer.tblMaster.colCustNo
AND YEAR_OF_SALE = :frmQCustomer.tblMaster.colYrForOrder'  )
.head 9 -  Set bSqlCurrSalesPrep = TRUE
.head 7 +  If NOT bSqlHistSalesPrep
.head 8 +  If SqlPrepare( hSqlHistSales, 'SELECT SUM(ORDERED_AMOUNT), SUM(CONF_AMT) FROM
CUST_ORDER_HISTORY INTO :frmQCustomer.tblMaster.nSumOrdAmt, 
:frmQCustomer.tblMaster.nSumConfAmt 
 WHERE CUST_NO = :frmQCustomer.tblMaster.colCustNo
AND YEAR_OF_SALE = :frmQCustomer.tblMaster.colYrForOrder'  )
.head 9 -  Set bSqlHistSalesPrep = TRUE
.head 7 -  !
.head 7 -  Set nSumOrdAmt = 0
.head 7 -  Set nSumConfAmt = 0
.head 7 -  Set frmQCustomer.tblMaster.colYrForOrder = ccYear.GetSeasonYear() - 3
.head 7 +  If SqlExecute( hSqlHistSales )
.head 8 -  Call SqlFetchNext( hSqlHistSales, nInd )
.head 8 +  If nSumConfAmt > 0
.head 9 -  Set colPrev94 = nSumConfAmt 
.head 8 +  Else
.head 9 -  Set colPrev94 = nSumOrdAmt 
.head 7 -  !
.head 7 -  Set nSumOrdAmt = 0
.head 7 -  Set nSumConfAmt = 0
.head 7 -  Set frmQCustomer.tblMaster.colYrForOrder = ccYear.GetSeasonYear() - 2
.head 7 +  If SqlExecute( hSqlHistSales )
.head 8 -  Call SqlFetchNext( hSqlHistSales, nInd )
.head 8 +  If nSumConfAmt > 0
.head 9 -  Set colPrev95 = nSumConfAmt 
.head 8 +  Else
.head 9 -  Set colPrev95 = nSumOrdAmt 
.head 7 -  !
.head 7 -  Set nSumOrdAmt = 0
.head 7 -  Set nSumConfAmt = 0
.head 7 -  Set frmQCustomer.tblMaster.colYrForOrder = ccYear.GetSeasonYear() - 1
.head 7 +  If SqlExecute( hSqlHistSales )
.head 8 -  Call SqlFetchNext( hSqlHistSales, nInd )
.head 8 +  If nSumConfAmt > 0
.head 9 -  Set colPrev96 = nSumConfAmt 
.head 8 +  Else
.head 9 -  Set colPrev96 = nSumOrdAmt 
.head 7 -  !
.head 7 -  Set nSumOrdAmt = 0
.head 7 -  Set nSumConfAmt = 0
.head 7 -  Set frmQCustomer.tblMaster.colYrForOrder = ccYear.GetSeasonYear()
.head 7 +  If SqlExecute( hSqlCurrSales )
.head 8 -  Call SqlFetchNext( hSqlCurrSales, nInd )
.head 8 +  If nSumConfAmt > 0
.head 9 -  Set colCurrSales = nSumConfAmt 
.head 8 +  Else
.head 9 -  Set colCurrSales = nSumOrdAmt 
.head 5 +  On SAM_Create
.head 6 -  Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 -  !
.head 6 -  Set bSqlCurrSales = SqlConnect( hSqlCurrSales ) 
.head 6 +  If bSqlCurrSales
.head 7 -  Call SqlSetLockTimeout( hSqlCurrSales, SQLTIMEOUT )

.head 4 +  Message Actions
.head 5 +  On SAM_Click
.head 6 +  ! If rbCustNoRange OR rbAlphaRange
.head 7 +          If SalQueryFieldEdit( dfAlphaFrom )
.head 8 +          If NOT SalQueryFieldEdit( dfAlphaTo )
.head 9 -          Set dfAlphaTo = 'ZZZZZZZZ'
.head 8 -          Set bgOrderByName = TRUE
.head 7 +          Else If SalQueryFieldEdit( dfAlphaTo )
.head 8 -          Set bgOrderByName = TRUE
.head 8 -          Set dfAlphaFrom = 'AAAAAAAAA'
.head 7 +          Else If SalQueryFieldEdit( dfCustnoFrom )
.head 8 +          If SalQueryFieldEdit( dfCustnoTo )
.head 9 -          Call SalNumberToStr( dfCustnoFrom, 0, sCustnoFrom )
.head 9 -          Call SalNumberToStr( dfCustnoTo, 0, sCustnoTo )
.head 8 +          Else 
.head 9 -          Call SalNumberToStr( dfCustnoFrom, 0, sCustnoFrom )
.head 9 -          Call SalNumberToStr( 999999, 0, sCustnoTo )
.head 7 +          Else If SalQueryFieldEdit( dfCustnoTo )
.head 8 -          Call SalNumberToStr( 1, 0, sCustnoFrom )
.head 8 -          Call SalNumberToStr( dfCustnoTo, 0, sCustnoTo )
.head 7 +          Else 
.head 8 -          Call SalNumberToStr( 1, 0, sCustnoFrom )
.head 8 -          Call SalNumberToStr( 999999, 0, sCustnoTo )
.head 7 +          If bgOrderByName
.head 8 -          Call PushString( " WHERE @UPPER(CUSTOMER_MASTER.CUST_NAME)  
BETWEEN '"||dfAlphaFrom||"' AND '"||dfAlphaTo||"'" )
.head 7 +          Else 
.head 8 -          Call PushString( ' WHERE CUSTOMER_MASTER.CUST_NO 
BETWEEN '||sCustnoFrom||' AND '||sCustnoTo )
.head 6 +  ! Else
.head 7 -          Set bgOrderByName = TRUE
.head 7 -          Call PushString( " WHERE CUSTOMER_MASTER.CUSTOMER_TYPE LIKE '%"||dfCustType||"%' " )
.head 6 -  !
.head 6 -  Set sSql = ' WHERE '
.head 6 -  Set bFirst = TRUE
.head 6 +  If NOT SalIsNull( dfAlphaFrom ) OR NOT SalIsNull( dfAlphaTo )
.head 7 +  If SalIsNull( dfAlphaTo )
.head 8 -  Set dfAlphaTo = 'ZZZZZZZZ'
.head 7 +  If SalIsNull( dfAlphaFrom )
.head 8 -  Set dfAlphaFrom = 'AAAAAAAAA'
.head 7 -  Set sSql = sSql || " @UPPER(CUSTOMER_MASTER.CUST_NAME)  
BETWEEN '"||dfAlphaFrom||"' AND '"||dfAlphaTo||"'"
.head 7 -  Set bFirst = FALSE
.head 6 -  !
.head 6 +  If NOT SalIsNull( dfCustnoFrom ) OR NOT SalIsNull( dfCustnoTo )
.head 7 +  If SalIsNull( dfCustnoTo )
.head 8 -  Set dfCustnoTo = 999999
.head 7 +  If SalIsNull( dfCustnoFrom )
.head 8 -  Set dfCustnoFrom = 1
.head 7 -  Call SalNumberToStr( dfCustnoFrom, 0, sCustnoFrom )
.head 7 -  Call SalNumberToStr( dfCustnoTo, 0, sCustnoTo )
.head 7 -  !
.head 7 +  If NOT bFirst
.head 8 -  Set sSql = sSql || ' AND '
.head 7 -  Set sSql = sSql || ' CUSTOMER_MASTER.CUST_NO 
BETWEEN '||sCustnoFrom||' AND '||sCustnoTo
.head 7 -  Set bFirst = FALSE
.head 6 +  Else
.head 7 -  Set dfCustnoFrom = 1
.head 7 -  Set dfCustnoTo = 999999
.head 6 -  !
.head 6 +  If NOT SalIsNull( dfCustType )
.head 7 +  If NOT bFirst
.head 8 -  Set sSql = sSql || ' AND '
.head 7 -  Set sSql = sSql || " CUSTOMER_MASTER.CUSTOMER_TYPE LIKE '%"||dfCustType||"%' "
.head 7 -  Set bFirst = FALSE
.head 6 -  !
.head 6 +  If SalSendMsg( tblQRegions, PAM_GetSelectedRegions, 0, 0 )
.head 7 -  Call PopString( sSelectedRegionIds, TRUE )
.head 6 +  Else
.head 7 -  Set sSelectedRegionIds = ''
.head 6 -  !
.head 6 +  If rbSortByCustNo
.head 7 -  Set bgOrderByName = FALSE
.head 6 +  Else
.head 7 -  Set bgOrderByName = TRUE
.head 6 +  If not sSql = ' WHERE '
.head 7 -  Set sSql = sSql || ' AND '
.head 6 -  Call PushString( sSql )
.head 6 -  Call PushString( sSelectedRegionIds )
.head 6 -  Call SalEndDialog( hWndForm, TRUE )

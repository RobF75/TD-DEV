.head 6 -  Set sSqlQCustomerSelect = '
SELECT 
  CUSTOMER_MASTER.CUST_NO,  CUSTOMER_MASTER.CUST_NAME , 
  CUSTOMER_MASTER.BUS_NAME, CUSTOMER_MASTER.CUSTOMER_TYPE, 
  CUSTOMER_MASTER.REGION_ID 
FROM  
  CUSTOMER_MASTER  
INTO 
  :frmQCustomer.tblQCustomer.colCustNo, 
  :frmQCustomer.tblQCustomer.colCustName, 
  :frmQCustomer.tblQCustomer.colBusName, 
  :frmQCustomer.tblQCustomer.colCustType, 
  :frmQCustomer.tblQCustomer.colCustRegion' || sBuildWhere || sORDERBY

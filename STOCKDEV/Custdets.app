.head 9 -  Call MyStrReplace( sQueryTmpStr, '\'', '_' )
.head 9 -  Set sQueryTmpStr = '%'||sQueryTmpStr||'%'
.head 9 -  Call PushString( sQueryTmpStr )
.head 9 -  Call PushString( LIKEOPERAND )
.head 9 -  Call PushString( STRINGFOLLOWING )
.head 9 -  Call PushString( '@UPPER(CUSTOMER_MASTER.CUST_NAME)' )
.head 9 -  Return TRUE

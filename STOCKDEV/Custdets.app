.head 4 +  Message Actions
.head 5 +  On PAM_POPULATE
.head 6 +  If bgPrintConfirmats
.head 7 -  Set ngAckYear = ngConfYear
.head 6 -  Set frmQCustomer.nNoNPAs = 0
.head 6 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillAll, PAM_SQL )
.head 5 +  On SAM_FetchRowDone
.head 6 +  ! If NOT SalIsNull( colRootId )
.head 7 -           Call MyGetRootDesc( hSqlHdlRootDesc, bHdlRootDescConnected,
 bHdlRootDescPrepared, 'frmQCustomer.tblOrd.colRootDesc',
 'frmQCustomer.tblOrd.colRootNPAflag', 'frmQCustomer.tblOrd.colRootId' )
.head 6 +  If frmQCustomer.tblOrd.colRootNPAflag = 'Y' OR frmQCustomer.tblOrd.colCultNPAflag = 'Y'
.head 7 +  If frmQCustomer.tblOrd.colNPARcd = 'N'
.head 8 +  If frmQCustomer.tblOrd.colConfAmt > 0
.head 9 +  If frmQCustomer.tblOrd.colSaleCat != 'RP'
.head 10 -  Set frmQCustomer.tblOrd.colNPANeeded = 'Y'
.head 10 -  Set frmQCustomer.nNoNPAs = frmQCustomer.nNoNPAs + 1
.head 5 +  On SAM_Create
.head 6 -  Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 -  Set bLocalSqlExtraTbl = SqlConnect( hLocalSqlExtraTbl ) 
.head 6 +  If bLocalSqlExtraTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlExtraTbl, SQLTIMEOUT )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 -  Set bHdlRootDescConnected = FALSE
.head 6 -  Set bHdlRootDescPrepared = FALSE
.head 6 -  Set sSQLPOPTABLENAME = 'CUSTOMER_ORDER, STOCK_ITEM, CUSTOMER_TYPE, TREE_TYPE, CUSTOMER_MASTER '
.head 6 -  ! Set sSQLPOPTABLENAME = 'CUSTOMER_ORDER, STOCK_ITEM, CULTIVAR, CUSTOMER_TYPE, TREE_TYPE, CUSTOMER_MASTER '
.head 6 -  Set sORDERBY = ' ORDER BY 1,2,6 '
.head 5 +  On SAM_Destroy
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlDisconnect( hLocalSqlPopTbl )
.head 6 +  If bLocalSqlExtraTbl
.head 7 -  Call SqlDisconnect( hLocalSqlExtraTbl )
.head 6 +  If bHdlRootDescConnected
.head 7 -  Call SqlDisconnect( hSqlHdlRootDesc )

.head 4 -  String: WHORDPOSPRINTINV = ' WHERE CUST_PROMO.CUST_NO = 
:frmOrders.dfCustNo AND CUST_PROMO.PROMO_SENT_FLAG != \'Y\' 
 AND CUST_PROMO.YEAR_OF_ORDER = :frmOrders.dfYr AND
PROMO.PROMO_ID = CUST_PROMO.PROMO_ID'
.head 4 -  String: CM = ' CUSTOMER_MASTER '
.head 4 -  ! String: WHERECMTML = ' WHERE  CUSTOMER_MASTER.CUST_NO  = :frmOrders.dfCustNo 
AND LOAD.LOAD_ID IN (SELECT DISTINCT LOAD_ID FROM LOAD_CUSTOMERS
WHERE CUST_NO = :frmOrders.dfCustNo) AND
LOAD.TRANSPORT_ID = TRANSPORT_METHOD.TRANSPORT_ID
ORDER BY LOAD.SHIPPING_DATE '

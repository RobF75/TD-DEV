.head 4 +  Message Actions
.head 5 +  On PAM_POPULATE
.head 6 -  Call PopString( sPreBuildWhere, TRUE )
.head 6 -  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, 
sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
.head 6 -  Call SalTblSetLockedColumns( hWndForm, 2 )
.head 5 +  On PAM_REPOPULATE
.head 6 -  Call TableRePopulate( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, 
sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
.head 5 +  On PAM_SEARCH
.head 6 -  Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, 
sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )

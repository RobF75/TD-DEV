.head 5 -  String: sRegionIds
.head 4 +  Message Actions
.head 5 +  On PAM_POPULATE
.head 6 -  Set sSql = ' SELECT 
  REGION_ID, 
  REGION_DESC 
FROM  
  REGION   
INTO 
  :dlgCustDets.tblQRegions.colRegionId, 
  :dlgCustDets.tblQRegions.colRegionDesc 
ORDER BY 
  REGION_DESC, REGION_ID '
.head 6 -  Call SalTblPopulate( hWndForm, hLocalSqlPopTbl, sSql, TBL_FillNormal )
.head 5 +  On SAM_Create
.head 6 -  Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 5 +  On PAM_GetSelectedRegions
.head 6 -  Set sRegionIds = ''
.head 6 -  Call MyTableLoop( hWndForm, hWndForm, PAM_ROWACTION, ROW_Selected, 0, 'Extracting selected regions.', nLowToHi )
.head 6 +  If sRegionIds = ''
.head 7 -  Return FALSE
.head 6 +  Else
.head 7 -  Call PushString( sRegionIds )
.head 7 -  Return TRUE
.head 5 +  On PAM_ROWACTION
.head 6 +  If sRegionIds = ''
.head 7 -  Set sRegionIds = "'" || colRegionId || "'"
.head 6 +  Else
.head 7 -  Set sRegionIds = sRegionIds || ', ' || "'" || colRegionId || "'"
.head 6 -  Return TRUE
.head 5 +  On SAM_Destroy
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlDisconnect( hLocalSqlPopTbl )

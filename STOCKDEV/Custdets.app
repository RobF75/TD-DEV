.head 7 +  On PAM_WHEREPOPULATE
.head 8 -  ! tHIS ONE SEEMS TO USE THE WRONG TABLE FOR THE SELECT OF CUSTOMER TYPE
.head 8 -  ! Set sBuildWhere = ' WHERE CUSTOMER_MASTER.CUSTOMER_TYPE = CUSTOMER_TYPE.CUST_TYPE
 AND ( CUSTOMER_TYPE.CUST_TYPE NOT LIKE \'OR_\' 
 OR CUSTOMER_TYPE.CUST_TYPE != \'NOR\' )  AND CUSTOMER_MASTER.MAILING_LIST_FLAG = \'Y\' '
.head 8 -  Set sBuildWhere = " WHERE 
 CUSTOMER_MASTER.CUSTOMER_TYPE NOT LIKE 'OR_'
 AND CUSTOMER_MASTER.CUSTOMER_TYPE != 'BOR' 
  AND CUSTOMER_MASTER.CUSTOMER_TYPE != 'BAD'
 AND CUSTOMER_MASTER.CUSTOMER_TYPE != 'CAS'
 AND CUSTOMER_MASTER.CUSTOMER_TYPE != 'OPP' 
 AND CUSTOMER_MASTER.CUSTOMER_TYPE != 'NOR'   AND 
CUSTOMER_MASTER.MAILING_LIST_FLAG = 'Y' AND
CUSTOMER_MASTER.CUSTOMER_TYPE = CUSTOMER_TYPE.CUST_TYPE "

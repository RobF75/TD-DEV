.head 9 -  Set sSql = " SELECT 
  Customer_Master.Cust_No, 
  Customer_Master.Cust_Name, 
  Customer_Master.Bus_Name, 
  Customer_Address.Address_1, 
  Customer_Address.Address_2, 
  Customer_Address.Suburb, 
  Customer_Address.State, 
  Customer_Address.Postcode,
  Customer_Address.Email 
FROM 
  Customer_Master, 
  Customer_Address 
INTO 
  :dlgMailMerge.nCustNo, 
  :dlgMailMerge.sCustName, 
  :dlgMailMerge.sBusName, 
  :dlgMailMerge.sAddLine1, 
  :dlgMailMerge.sAddLine2, 
  :dlgMailMerge.sSuburb, 
  :dlgMailMerge.sState, 
  :dlgMailMerge.sPostCode,
  :dlgMailMerge.sEmailAddress 
WHERE 
  Customer_Master.Cust_No = :dlgMailMerge.hWndTable.colCustNo AND 
  Customer_Master.Cust_No = Customer_Address.Cust_No AND 
  Customer_Address.Main_Address_Flag = 'Y' "
.head 9 +  If NOT fcMailMergeHdl.PrepareSetup( sSql )
.head 10 -  Return FALSE
.head 7 +  Else
.head 8 +  If rbOrchadists
.head 9 +  If cbMainAddress
.head 10 +  If cbCurrentYearOrders
.head 11 -  Set sSql = " SELECT DISTINCT 
  Customer_Master.Cust_No, 
  Customer_Master.Cust_Name, 
  Customer_Master.Bus_Name, 
  Customer_Address.Address_1, 
  Customer_Address.Address_2, 
  Customer_Address.Suburb, 
  Customer_Address.State, 
  Customer_Address.Postcode,
  Customer_Address.Email 
FROM 
  Customer_Master, 
  Customer_Address
INTO 
  :dlgMailMerge.nCustNo, 
  :dlgMailMerge.sCustName, 
  :dlgMailMerge.sBusName, 
  :dlgMailMerge.sAddLine1, 
  :dlgMailMerge.sAddLine2, 
  :dlgMailMerge.sSuburb, 
  :dlgMailMerge.sState, 
  :dlgMailMerge.sPostCode,
  :dlgMailMerge.sEmailAddress 
WHERE 
  Customer_Master.Cust_No = Customer_Address.Cust_No AND 
  Customer_Address.Main_Address_Flag = 'Y' AND 
  Customer_Master.Customer_Type LIKE '%OR%' AND 
  Customer_Master.Mailing_List_Flag = 'Y' AND 
  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
  ( Customer_Master.Bad_Debt_Flag = 'N' OR
    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
  ( Customer_Master.Closed_Account = 'N' OR 
    Customer_Master.Closed_Account IS NULL ) AND 
  EXISTS ( SELECT 
                    Customer_Order.Cust_No 
                 FROM 
                   Customer_Order 
                 WHERE 
                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
                   Customer_Order.Year_Of_Sale = :dlgMailMerge.nYear AND 
                  Customer_Order.Ordered_Amount > 0 ) 
ORDER BY Customer_Master.Cust_Name "

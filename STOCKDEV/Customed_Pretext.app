.head 4 +  Actions
.head 5 -  ! LOCAL SQL HANDLE CONNECTION, DISCONNECT are on exit pointS
.head 5 -  Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
.head 5 +  If bLocalSqlA
.head 6 -  Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
.head 5 +  Else
.head 6 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -  Return FALSE
.head 5 -  !
.head 5 -  Call SalSendMsgToChildren( dlgDeposit, PAM_SETEDIT, 0, 0 )
.head 5 -  Call CallBuildSql( dlgDeposit, nINSERT, PAM_SQL, OUTSTAND_DEPOSIT, '' )
.head 5 +  If MySqlPrepExec( hLocalSqlA, sgSql )
.head 6 -  Call SqlCommit( hLocalSqlA )
.head 5 +  ! If NOT SqlOK( hLocalSqlA, sgSql )
.head 6 -  ! Can only be because it is trying to add one for the same date/time so try again
.head 6 -                                                                                                                                                                        Call SqlImmediate( sgSql )
.head 6 -                                                                                                                                                                        Call SqlClearImmediate(  )
.head 5 +  If bLocalSqlA
.head 6 -  Call SqlDisconnect( hLocalSqlA )
.head 5 -  Call SalEndDialog( dlgDeposit, TRUE )

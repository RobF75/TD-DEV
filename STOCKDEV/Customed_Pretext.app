.head 5 -                                                                                                                                                                        Call OurSendMsgToChildren(  frmOrders.tblOrder, PAM_EXTENDPRICES, 0, 0 )
.head 5 +                                                                                                                                                                        If nMySendMsgError
.head 6 -                                                                                                                                                                        Set bOk = FALSE
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 +                                                                                                                                                                        If bgUpdateFiles = TRUE

.head 5 +                                                                                                                                                                        If bLocalSqlA
.head 6 -                                                                                                                                                                        Call SqlDisconnect( hLocalSqlA )
.head 3 +  ! Function: ClearCust 
.head 4 -                                                                                                                                                                        Description: Clear the screen and reset field defaults
.head 4 -                                                                                                                                                                        Returns 

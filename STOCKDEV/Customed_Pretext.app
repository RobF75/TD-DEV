.head 6 +  If SalIsWindowVisible( hWndForm )
.head 7 -  ! Call SalModalDialog( dlgFinelineMaintenance, hWndForm, hWndForm.colCustNo, hWndForm.colAssCustNo, hWndForm.colCustName, cSeasonYear.GetSeasonYear () , hWndForm.colSupplierId)
.head 7 -  Call SalCreateWindow( frmFinelineMaintenance, hWndForm, hWndForm.colCustNo, hWndForm.colAssCustNo, hWndForm.colCustName, cSeasonYear.GetSeasonYear () , hWndForm.colSupplierId, hWndForm.colCustType)
.head 5 +  On PAM_CheckFinelineCustomer
.head 6 -  Set nRow = TBL_MinRow
.head 6 -  Call SalTblFindNextRow( hWndItem, nRow, ROW_Selected, 0 )
.head 6 -  Call SalTblFetchRow( hWndItem, nRow )
.head 6 +  If NOT fnIsCustomerFineline ( colCustNo )
.head 7 -  Return FALSE
.head 6 +  Else
.head 7 -  Return TRUE
.head 5 +  ! On SAM_Click
.head 6 +  If NOT fnIsCustomerFineline ( colCustNo )

  Cust_No = :nCustNo'
.head 5 +  If SqlImmediate( sgSql )
.head 6 -  Call SqlClearImmediate(  )
.head 6 +  If sTmpDepReqd != 'Y'
.head 7 -  Return FALSE
.head 5 +  Else
.head 6 -  Call SqlClearImmediate(  )
.head 6 -  Return FALSE

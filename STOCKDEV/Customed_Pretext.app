.head 3 -  !
.head 3 -  ! The next 3 functions are for keeping selected rows on frmOrders.tblOrder
.head 3 +  Function: InitialiseSelectedRowsArray
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Receive Date/Time: dtSelectedRowOrdDTArray[*]
.head 5 -  Receive Number: nLastSelectedRowOrdDT
.head 5 -  Window Handle: hWndTable
.head 5 -  Receive Boolean: bTurnOffCheckToSelectRow
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nRow
.head 5 -  Number: nCount
.head 5 -  Boolean: bFinish
.head 4 +  Actions
.head 5 +  If nLastSelectedRowOrdDT > -1
.head 6 -  Set bTurnOffCheckToSelectRow = TRUE
.head 6 -  Set bFinish = FALSE
.head 6 -  Set nCount = -1
.head 6 -  Set nRow = TBL_MinRow
.head 6 +  While SalTblFindNextRow( hWndTable, nRow, 0, 0 ) AND NOT bFinish
.head 7 -  Call SalTblFetchRow( hWndTable, nRow )
.head 7 +  If CheckToSelectRow( dtSelectedRowOrdDTArray, nLastSelectedRowOrdDT, hWndTable.colOrderDateTime, hWndTable, nRow )
.head 8 -  Set nCount = nCount + 1
.head 7 +  If nCount >= nLastSelectedRowOrdDT
.head 8 -  Set bFinish = TRUE
.head 5 -  !
.head 5 -  Set nLastSelectedRowOrdDT = -1
.head 5 -  Set nRow = TBL_MinRow
.head 5 +  While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
.head 6 -  Call SalTblFetchRow( hWndTable, nRow )
.head 6 -  Set nLastSelectedRowOrdDT = nLastSelectedRowOrdDT + 1
.head 6 -  Set dtSelectedRowOrdDTArray[ nLastSelectedRowOrdDT ] = hWndTable.colOrderDateTime
.head 5 -  Set bTurnOffCheckToSelectRow = FALSE
.head 3 +  Function: CheckToSelectRow
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Date/Time: dtSelectedRowOrdDTArray[*]
.head 5 -  Number: nLastSelectedRowOrdDT
.head 5 -  Date/Time: dtColDateTime
.head 5 -  Window Handle: hWndTable
.head 5 -  Number: nRow
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nCount
.head 5 -  Boolean: bFound
.head 4 +  Actions
.head 5 -  Set bFound = FALSE
.head 5 -  Set nCount = 0
.head 5 +  While nCount <= nLastSelectedRowOrdDT AND NOT bFound
.head 6 +  If dtSelectedRowOrdDTArray[ nCount ] = dtColDateTime
.head 7 -  Set bFound = TRUE
.head 7 +  If NOT SalTblQueryRowFlags( hWndTable, nRow, ROW_Selected )
.head 8 -  Call SalTblSetFocusRow( hWndTable, nRow )
.head 8 -  Call SalTblSetContext( hWndTable, nRow )
.head 8 -  Call SalTblSetRowFlags( hWndTable, nRow, ROW_Selected, TRUE )
.head 6 -  Set nCount = nCount + 1
.head 5 +  If bFound
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 3 +  Function: ForceBackEndToSelectToReset
.head 4 -  Description: Because the rows are selected on SAM_FetchRow if on table 
click the user select new rows or modifies,  This functions brings
back the backend result set rows so that they can be selected
before reseting the nLastSelectedRowOrdDT counter of the 
rows that are being remembered.  So that next time pulling,
invoicing etc. is run we have the rows selected in the table and
we can correctly reset the remembered rows.
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Window Handle: hWndTable
.head 5 -  Receive Number: nLastSelectedRowOrdDT
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nRow
.head 5 -  Number: nOriginalRowContext
.head 4 +  Actions
.head 5 +  If nLastSelectedRowOrdDT > -1
.head 6 -  Call SalWaitCursor( TRUE )
.head 6 -  Set nOriginalRowContext = SalTblQueryContext( hWndTable )
.head 6 -  Set nRow = TBL_MinRow
.head 6 +  While SalTblFindNextRow( hWndTable, nRow, 0, 0 )
.head 7 -  Call SalTblFetchRow( hWndTable, nRow )
.head 6 -  Call SalTblFetchRow( hWndTable, nOriginalRowContext )
.head 6 -  Set nLastSelectedRowOrdDT = -1
.head 6 -  Call SalWaitCursor( FALSE )
.head 3 -  !
.head 3 +  Function: AssignOrdersToHardCodeLoads
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Window Handle: hWndTable
.head 5 -  Number: nLoadType
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  !
.head 5 -  String: sLoadId
.head 5 -  String: sSqlUpdate
.head 5 -  Number: nRow
.head 5 -  Number: nModuleRow
.head 5 -  Boolean: bPulled
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Call SalWaitCursor( TRUE )
.head 7 -  Call SalSendMsg( hWndTable, PAM_REMEMBERSELECTEDROWS, 0, 0 )
.head 7 -  Set sLoadId = ''
.head 7 -  !
.head 7 +  Select Case nLoadType
.head 8 +  Case nCustInvLoad
.head 9 -  Set sLoadId = 'CUSTINV'
.head 9 -  Break
.head 8 +  Case nPickupLoad
.head 9 -  Set sLoadId = 'PICKUPS'
.head 9 -  Break
.head 8 +  Case nMarketLoad
.head 9 -  Set sLoadId = 'MARKET'
.head 9 -  Break
.head 8 +  Case nRailLoad
.head 9 -  Set sLoadId = GetCustRailMailLoadId( nCustNo, nLoadType, SH_cls_Execute )
.head 9 -  Break
.head 8 +  Case nMailLoad
.head 9 -  Set sLoadId = GetCustRailMailLoadId( nCustNo, nLoadType, SH_cls_Execute  )
.head 7 +  If sLoadId != ''
.head 8 -  Call UpdateLoadCustomers( sLoadId, nCustNo, SH_cls_Execute )
.head 8 -  Set bPulled = FALSE
.head 8 -  Set nRow = TBL_MinRow
.head 8 +  While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
.head 9 -  Call SalTblFetchRow( hWndTable, nRow )
.head 9 +  If hWndTable.colPullFlag != 'Y'
.head 10 -  Call UpdtCustOrdLoadId( sLoadId, nCustNo, hWndTable.colOrderDateTime, SH_cls_Execute )
.head 10 +  If hWndTable.colModuleParent = 'Y'
.head 11 +  ! While SalTblFindNextRow( hWndTable, nModuleRow, 0, 0 )
.head 12 -  Call SalTblFetchRow( hWndTable, nModuleRow )
.head 12 -  If hWndTable.colModuleItem = 'Y'  
.head 11 -  Call UpdCustOrdChildrenLoadId ( sLoadId, nCustNo, hWndTable.colOrderDateTime, SH_cls_Execute )
.head 9 +  Else
.head 10 -  Set bPulled = TRUE
.head 8 -  Call SalSendMsg( hWndTable, PAM_REPOPULATE, 0, 0 )
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 +  If bPulled
.head 9 -  Call SalMessageBox( 'One or more selected orders could not be assigned because they were pulled!', 'NOTE', MB_Ok )
.head 7 +  Else
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 -  Call SalMessageBox( 'Error Occured in Obtaining the correct Load_Id to Use! Order Have not been Assigned!', 'Error', MB_Ok )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call UpdtCustOrdLoadId( '', 0, DATETIME_Null, SH_cls_Disconnect )
.head 7 -  Call UpdateLoadCustomers( '', 0, SH_cls_Disconnect )
.head 7 -  Call UpdCustOrdChildrenLoadId ( '', 0, DATETIME_Null, SH_cls_Disconnect )

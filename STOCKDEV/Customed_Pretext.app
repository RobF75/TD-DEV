.head 3 +  ! Function: IfCustTypeUsed 
.head 4 -                                                                                                                                                                        Description: Dont allow the deletion of a customer type if customers exist that use that
type, TRUE returned if it is used, FALSE if it is not
.head 4 +                                                                                                                                                                        Returns 
.head 5 -                                                                                                                                                                        Boolean: 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Number: nCustno
.head 4 +                                                                                                                                                                        Actions 
.head 5 -                                                                                                                                                                        Set ngRow = TBL_MinRow
.head 5 +                                                                                                                                                                        While SalTblFindNextRow( dlgCusttype.tblCusttype, ngRow, ROW_MarkDeleted, 0 )
.head 6 -                                                                                                                                                                        Call SalTblFetchRow( dlgCusttype.tblCusttype, ngRow )
.head 6 -                                                                                                                                                                        Set nCustno = 0
.head 6 -                                                                                                                                                                        Set sgSql = 'SELECT CUSTOMER_MASTER.CUST_NO FROM
 CUSTOMER_MASTER INTO :nCustno
 WHERE CUSTOMER_MASTER.CUSTOMER_TYPE = :dlgCusttype.tblCusttype.colCusttype'
.head 6 -                                                                                                                                                                        Call SqlImmediate( sgSql )
.head 6 -                                                                                                                                                                        Call SqlClearImmediate(  )
.head 6 +                                                                                                                                                                        If nCustno != 0
.head 7 -                                                                                                                                                                        Call ErrorMessage( ' Sorry, this customer type is in user by a customer.  You cannot delete it until the customer is amended with another customer type.  ', dlgCusttype.tblCusttype, ngRow )
.head 7 -  ! Call SalMessageBox( 'Sorry, this customer type is in use by a customer.  You cannot
delete it until the customer is amended with another customer type', 'Customer Type',
 MB_Ok )
.head 7 -                                                                                                                                                                        Return TRUE
.head 7 -                                                                                                                                                                        Break 
.head 5 -                                                                                                                                                                        Return FALSE
.head 3 +  ! Function: SetTableValues
.head 4 -                                                                                                                                                                        Description: To send a message to all children in a table to set their values 
.head 4 -                                                                                                                                                                        Returns 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Number: nConfAmt
.head 5 -                                                                                                                                                                        Number: nOrdAmt
.head 4 +                                                                                                                                                                        Actions 
.head 5 -  ! Send message to columns to calculate and display summaries or set values
.head 5 -                                                                                                                                                                        Set ngConfTotal = 0
.head 5 -                                                                                                                                                                        Set ngOrdTotal = 0
.head 5 -                                                                                                                                                                        Set nConfAmt = 0
.head 5 -                                                                                                                                                                        Set nOrdAmt = 0
.head 5 -                                                                                                                                                                        Call SalTblQueryScroll( hWndForm, ngPos, ngMinRange, ngMaxRange )
.head 5 -                                                                                                                                                                        Set ngRow = ngMinRange
.head 5 +                                                                                                                                                                        While ngRow <= ngMaxRange 
.head 6 -                                                                                                                                                                        Call SalTblFetchRow( hWndForm, ngRow )
.head 6 -                                                                                                                                                                        Call SalSendMsgToChildren( hWndForm, PAM_SETVALUES, 0, 0 )
.head 6 +                                                                                                                                                                        Loop 
.head 7 +                                                                                                                                                                        If PopNumber( nConfAmt, FALSE )
.head 8 -                                                                                                                                                                        Set ngConfTotal = ngConfTotal + nConfAmt
.head 8 -                                                                                                                                                                        Call PopNumber( nOrdAmt, FALSE )
.head 8 -                                                                                                                                                                        Set ngOrdTotal = ngOrdTotal + nOrdAmt
.head 7 +                                                                                                                                                                        Else 
.head 8 -                                                                                                                                                                        Break 
.head 6 -                                                                                                                                                                        Set ngRow = ngRow + 1
.head 5 -                                                                                                                                                                        Call SalTblFetchRow( hWndForm, TBL_MinSplitRow )
.head 5 -                                                                                                                                                                        Call SalSendMsgToChildren( hWndForm, PAM_SUMTOTALS, 0, 0 )
.head 5 -                                                                                                                                                                        Call SalTblSetRowFlags( hWndForm, TBL_MinSplitRow, ROW_New|
ROW_Edited, FALSE )
.head 3 +  ! Function: UpdatePulledFlag
.head 4 -                                                                                                                                                                        Description: To update the pulled flag for a customer once his pull sheet has been 
printed
.head 4 -                                                                                                                                                                        Returns 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Boolean: bLocalSqlA
.head 5 -                                                                                                                                                                        Sql Handle: hLocalSqlA
.head 4 +                                                                                                                                                                        Actions 
.head 5 -  ! LOCAL SQL HANDLE CONNECTION, DISCONNECT are on exit pointS
.head 5 -                                                                                                                                                                        Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
.head 5 +                                                                                                                                                                        If bLocalSqlA
.head 6 -                                                                                                                                                                        Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
.head 5 +                                                                                                                                                                        Else 
.head 6 -                                                                                                                                                                        Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 -  !
.head 5 -                                                                                                                                                                        Set sgSql = 'UPDATE CUSTOMER_ORDER SET PULL_SHEET_ISSUED = \'Y\',
PULL_SHEET_DATE = SYSDATETIME, PULL_SHEET_BY = USER WHERE
CUSTOMER_ORDER.ROWID = :frmOrders.tblOrder.colRowId'
.head 5 +                                                                                                                                                                        If NOT SqlOK( hLocalSqlA, sgSql )
.head 6 -                                                                                                                                                                        Call SalMessageBox( 'Am unable to update the pulled flag for this order.
   Please do so manually', 'Pull Order for Customer', MB_Ok )
.head 5 -                                                                                                                                                                        Call SqlCommit( hLocalSqlA )
.head 5 +                                                                                                                                                                        If bLocalSqlA
.head 6 -                                                                                                                                                                        Call SqlDisconnect( hLocalSqlA )
.head 3 +  ! Function: UnpullSelected
.head 4 -                                                                                                                                                                        Description: For every row that is selected that has been pulled, unpull the flags
.head 4 +                                                                                                                                                                        Returns 
.head 5 -                                                                                                                                                                        Boolean: 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Boolean: bLocalSqlA
.head 5 -                                                                                                                                                                        Sql Handle: hLocalSqlA
.head 4 +                                                                                                                                                                        Actions 
.head 5 -  !
.head 5 -                                                                                                                                                                        Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
.head 5 +                                                                                                                                                                        If bLocalSqlA
.head 6 -                                                                                                                                                                        Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
.head 6 -                                                                                                                                                                        Call SqlSetParameter( hLocalSqlA, DBP_PRESERVE, TRUE, ''  )
.head 5 +                                                                                                                                                                        Else 
.head 6 -                                                                                                                                                                        Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 -                                                                                                                                                                        Set ngRow = -1
.head 5 -                                                                                                                                                                        Set sgSql = 'UPDATE CUSTOMER_ORDER SET PULL_SHEET_ISSUED = \'N\',
PULL_SHEET_DATE = :frmOrders.tblOrder.colPullDate, PULL_SHEET_BY = \' \' WHERE
CUSTOMER_ORDER.ROWID = :frmOrders.tblOrder.colRowId'
.head 5 -                                                                                                                                                                        Call SqlPrepare( hLocalSqlA, sgSql )
.head 5 +                                                                                                                                                                        While SalTblFindNextRow( frmOrders.tblOrder, ngRow, ROW_Selected, 0 )
.head 6 -                                                                                                                                                                        Call SalTblFetchRow( frmOrders.tblOrder, ngRow )
.head 6 +                                                                                                                                                                        If frmOrders.tblOrder.colPullFlag != 'Y'
.head 7 +                                                                                                                                                                        If bLocalSqlA
.head 8 -                                                                                                                                                                        Call SqlDisconnect( hLocalSqlA )
.head 7 -                                                                                                                                                                        Call SalMessageBox( 'One of the selected rows for unpulling has
not been pulled yet', 'Unpull Selected Order', MB_Ok )
.head 7 -                                                                                                                                                                        Return FALSE
.head 6 +                                                                                                                                                                        Else If frmOrders.tblOrder.colInvFlag = 'Y'
.head 7 +                                                                                                                                                                        If bLocalSqlA
.head 8 -                                                                                                                                                                        Call SqlDisconnect( hLocalSqlA )
.head 7 -                                                                                                                                                                        Call ErrorMessage( 'One of the selected rows for unpulling has been invoiced! This row cannot be unpulled!', frmOrders.tblOrder, ngRow )
.head 7 -                                                                                                                                                                        Return FALSE
.head 6 -                                                                                                                                                                        Set frmOrders.tblOrder.colPullDate = DATETIME_Null
.head 6 +                                                                                                                                                                        If SqlExecute( hLocalSqlA )
.head 7 -                                                                                                                                                                        Call SqlCommit( hLocalSqlA )
.head 6 +                                                                                                                                                                        Else 
.head 7 -                                                                                                                                                                        Call SqlPrepareAndExecute( hLocalSqlA, 'ROLLBACK' )
.head 7 -                                                                                                                                                                        Call SalMessageBox( 'Am unable to update the pulled flag for this order.
   Please contact programmers', 'Unpull Order for Customer', MB_Ok )
.head 5 +                                                                                                                                                                        If bLocalSqlA
.head 6 -                                                                                                                                                                        Call SqlDisconnect( hLocalSqlA )
.head 3 +  ! Function: StoreSelectedRowNumbers
.head 4 -                                                                                                                                                                        Description: Because the user is selecting rows to invoice and part of the processing
when finished with those is to repopulate the table with POS items, when the 
user wishes to print we need to repopulate for the stock item orders
and reset the rows selected
.head 4 -                                                                                                                                                                        Returns 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 -                                                                                                                                                                        Local variables 
.head 4 +                                                                                                                                                                        Actions 
.head 5 -                                                                                                                                                                        Set ngRowSelected[ngArrayInc] = ngRow + 1
.head 5 -                                                                                                                                                                        Set ngArrayInc = ngArrayInc + 1
.head 3 +  ! Function: ResetSelectedRowNumbers
.head 4 -                                                                                                                                                                        Description: To reset which rows were selected in the invoicing process
.head 4 -                                                                                                                                                                        Returns 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Number: nArrayCount
.head 4 +                                                                                                                                                                        Actions 
.head 5 -                                                                                                                                                                        Set nArrayCount = SalQueryArrayBounds( ngRowSelected, ngMinRange, ngMaxRange )
.head 5 -                                                                                                                                                                        Set ngArrayInc = ngMinRange
.head 5 +                                                                                                                                                                        While ngArrayInc <= ngMaxRange
.head 6 -  ! To take care of the instance where there are no entries and ngMax and ngMin
are = 0
.head 6 +  ! If nArrayCount != 0
.head 7 -                                                                                                                                                                        Call SalTblSetRowFlags( frmOrders.tblOrder, ngRowSelected[ngArrayInc], ROW_Selected, TRUE )
.head 6 +                                                                                                                                                                        If ngRowSelected[ngArrayInc] != 0
.head 7 -                                                                                                                                                                        Call SalTblSetRowFlags( frmOrders.tblOrder, (ngRowSelected[ngArrayInc] - 1), ROW_Selected, TRUE )
.head 6 -                                                                                                                                                                        Set ngArrayInc = ngArrayInc + 1
.head 3 +  ! Function: ClearSelectedArray
.head 4 -                                                                                                                                                                        Description: To clear the given array 
.head 4 -                                                                                                                                                                        Returns 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Number: nClearArrayInc
.head 5 -                                                                                                                                                                        Number: nArrayCount
.head 4 +                                                                                                                                                                        Actions 
.head 5 -                                                                                                                                                                        Set nArrayCount = SalQueryArrayBounds( ngRowSelected, ngMinRange, ngMaxRange )
.head 5 -                                                                                                                                                                        Set nClearArrayInc = ngMinRange
.head 5 +                                                                                                                                                                        While nClearArrayInc <= ngMaxRange
.head 6 -                                                                                                                                                                        Set ngRowSelected[nClearArrayInc] = NUMBER_Null
.head 6 -                                                                                                                                                                        Set nClearArrayInc = nClearArrayInc + 1
.head 5 -                                                                                                                                                                        Set ngArrayInc = 0
.head 5 -  ! Call SalSetArrayBounds( ngRowSelected, AC_Dynamic, AC_Dynamic )
.head 3 +  ! Function: POSFreightCharge
.head 4 -                                                                                                                                                                        Description: If no stock items have been purchased then need to calculate the
applicable freight charge for the POS and add it to the customers
freight charge
.head 4 -                                                                                                                                                                        Returns 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Boolean: bLocalSqlA
.head 5 -                                                                                                                                                                        Sql Handle: hLocalSqlA
.head 4 +                                                                                                                                                                        Actions 
.head 5 -  ! LOCAL SQL HANDLE CONNECTION, DISCONNECT ARE on exit pointS
.head 5 -                                                                                                                                                                        Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
.head 5 +                                                                                                                                                                        If bLocalSqlA
.head 6 -                                                                                                                                                                        Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
.head 5 +                                                                                                                                                                        Else 
.head 6 -                                                                                                                                                                        Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 -  !
.head 5 -                                                                                                                                                                        Set sgSql = 'SELECT PRICE_BREAK.AMOUNT, PRICE_BREAK.NO_TREES FROM
FREIGHT_CHARGE,PRICE_BREAK INTO :ngPercAmt, :ngNoTrees WHERE
FREIGHT_CODE = :frmOrders.tblOrder.colPOSFrCode AND PRICE_BREAK.PRICE_BREAK_ID
= FREIGHT_CHARGE.PRICE_BREAK_ID ORDER BY FREIGHT_BRK_LEVEL'
.head 5 +                                                                                                                                                                        If NOT SqlOK( hLocalSqlA, sgSql )
.head 6 +                                                                                                                                                                        If bLocalSqlA
.head 7 -                                                                                                                                                                        Call SqlDisconnect( hLocalSqlA )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 +                                                                                                                                                                        While SqlFetchNext( hLocalSqlA, ngFetch )
.head 6 +                                                                                                                                                                        If ngFetch = FETCH_EOF
.head 7 +                                                                                                                                                                        If bLocalSqlA
.head 8 -                                                                                                                                                                        Call SqlDisconnect( hLocalSqlA )
.head 7 -                                                                                                                                                                        Return FALSE
.head 6 +                                                                                                                                                                        If frmOrders.tblOrder.colConfAmt <= ngNoTrees
.head 7 -                                                                                                                                                                        Set frmOrders.dfDelCharge = frmOrders.dfDelCharge + ngPercAmt
.head 7 +                                                                                                                                                                        If bLocalSqlA
.head 8 -                                                                                                                                                                        Call SqlDisconnect( hLocalSqlA )
.head 7 -                                                                                                                                                                        Return TRUE
.head 5 +                                                                                                                                                                        If bLocalSqlA
.head 6 -                                                                                                                                                                        Call SqlDisconnect( hLocalSqlA )
.head 3 +  Function: OrderGoAhead
.head 4 -  Description: If the customer has stops for any reason of orders being placed then we
want error messages to appear
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If frmOrders.dfDontSell = 'Y'
.head 6 -  Call SalMessageBox( 'This Customer is flagged as DONT SELL TO!,
You need authorisation from the office manager before continuing to add the order?
Please note any comments from customer details before requesting
the authorisation.', 'Warning', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  If frmOrders.dfCredStop = 'Y'
.head 6 +  If frmOrders.dfCusttype = 'GCP'
.head 7 -  Call SalMessageBox( 'This Customer is to be REFERED to John Danks!,
Please advise Accounts Payable. Orders to be punched with a hold date', 'Warning', MB_Ok )
.head 7 -  Call SalMessageBox( 'Advise Accounts     NOW!!!!', 'Warning', MB_Ok )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'This Customer is flagged as CREDIT STOP!,
You need to refer to Accounts Payable re releasing this customer from Credit Stop status.', 'Warning', MB_Ok )
.head 7 -  Return FALSE
.head 5 +  If frmOrders.dfClAcc = 'Y'
.head 6 -  Call SalMessageBox( 'This Customer is flagged as a CLOSED ACCOUNT!,
You need to refer to Accounts Payable re this customer.', 'Warning', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  If frmOrders.dfCusttype = 'OPP'
.head 6 +  If IDCANCEL = SalMessageBox( 'This customer is an OPPOSITION customer, do you still want to accept this order?', 'Warning', MB_OkCancel )
.head 7 -  Return FALSE
.head 5 +  Else If frmOrders.dfCusttype = 'BAD'
.head 6 -  Call SalMessageBox( 'This customer is a BAD DEBT customer, please contact accounts', 'Warning', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  Else If frmOrders.dfCusttype = 'BOR'
.head 6 -  Call SalMessageBox( 'This customer is a BAD DEBT customer, please contact Accounts', 'Warning', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  If frmOrders.dfBadDebt = 'Y'
.head 6 -  Call SalMessageBox( 'This customer is a BAD DEBT customer, please contact accounts', 'Warning', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  If frmOrders.dfCredLimit > 0
.head 6 +  If frmOrders.dfAR > frmOrders.dfCredLimit
.head 7 -  Call SalMessageBox( 'This customer has exceeded his credit limit.   Please contact accounts
to OK any further orders and increasing his Credit Limit' , 'Warning', MB_Ok )
.head 7 -  Return FALSE
.head 5 -  Return TRUE

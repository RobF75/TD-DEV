.head 7 -  !
.head 7 -                                                                                                   Set bNeedPRC = FALSE
.head 7 -  !
.head 7 +                                                                                                   If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 +                                                                                                   If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 -                                                                                                   Set bNeedPRC = TRUE
.head 8 -  ! Return TRUE
.head 7 +                                                                                                   Else 
.head 8 -                                                                                                   Set bNeedPRC = FALSE
.head 7 -                                                                                                   Return bNeedPRC
.head 6 +  Case SH_cls_Disconnect
.head 7 -                                                                                                   Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 3 +  ! Function: MySumOrdConfHistory
.head 4 -                                                                                                                                                                        Description: To sum the ordered and confirmed values as label charges require these
and freight charges is now done on an order basis not a customer basis
.head 4 +                                                                                                                                                                        Returns 
.head 5 -                                                                                                                                                                        Boolean: 
.head 4 +                                                                                                                                                                        Parameters 
.head 5 -                                                                                                                                                                        Number: nCustNo
.head 5 -                                                                                                                                                                        Number: nYear
.head 5 -                                                                                                                                                                        Receive Number: nTotalConfAmt
.head 5 -                                                                                                                                                                        Receive Number: nTotalOrdAmt
.head 5 -                                                                                                                                                                        Number: nActionType
.head 4 +                                                                                                                                                                        Static Variables 
.head 5 -                                                                                                                                                                        : fcOurHandle
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        String: sSql
.head 5 -                                                                                                                                                                        String: sBind
.head 5 -                                                                                                                                                                        String: sInto
.head 5 -                                                                                                                                                                        String: sName
.head 5 -  !
.head 5 -                                                                                                                                                                        Number: nGotTotalConfAmt
.head 5 -                                                                                                                                                                        Number: nGotTotalOrdAmt
.head 5 -                                                                                                                                                                        Number: nInd
.head 4 +                                                                                                                                                                        Actions 
.head 5 +                                                                                                                                                                        Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -                                                                                                                                                                        Set sSql = " SELECT Sum( Conf_Amt ), Sum( Ordered_Amount ) 
FROM Cust_Order_History
WHERE Cust_No = :1 AND Year_Of_Sale = :2 "
.head 7 -                                                                                                                                                                        Set sName = 'SMCNFORDAMTHIST'
.head 7 -                                                                                                                                                                        Set sBind = ':nCustNo, :nYear'
.head 7 -                                                                                                                                                                        Set sInto = ':nGotTotalConfAmt, :nGotTotalOrdAmt'
.head 7 -  !
.head 7 -                                                                                                                                                                        Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
.head 7 -                                                                                                                                                                        Call SqlVarSetup( fcOurHandle.hSqlHandle )
.head 7 -  !
.head 7 -                                                                                                                                                                        Set nTotalConfAmt = 0
.head 7 -                                                                                                                                                                        Set nTotalOrdAmt = 0
.head 7 -  !
.head 7 -                                                                                                                                                                        Set nGotTotalConfAmt = 0
.head 7 -                                                                                                                                                                        Set nGotTotalOrdAmt = 0
.head 7 -  !
.head 7 +                                                                                                                                                                        If fcOurHandle.Execute( )
.head 8 -                                                                                                                                                                        Call fcOurHandle.FetchNext( nInd )
.head 8 -                                                                                                                                                                        Set nTotalConfAmt = nGotTotalConfAmt
.head 8 -                                                                                                                                                                        Set nTotalOrdAmt = nGotTotalOrdAmt
.head 8 -                                                                                                                                                                        Return TRUE
.head 7 +                                                                                                                                                                        Else 
.head 8 -                                                                                                                                                                        Return FALSE
.head 6 +  ! Case SH_cls_Commit
.head 7 -                                                                                                                                                                        Return fcOurHandle.Commit( )
.head 6 +  ! Case nRollback
.head 7 -                                                                                                                                                                        Return fcOurHandle.Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -                                                                                                                                                                        Return fcOurHandle.Disconnect( )

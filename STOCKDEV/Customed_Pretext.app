.head 5 -                                                                                                                                                                        Sql Handle: hLocalSqlA
.head 4 +                                                                                                                                                                        Actions 
.head 5 -  ! LOCAL SQL HANDLE CONNECTION, DISCONNECTS are on exit pointS
.head 5 -                                                                                                                                                                        Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
.head 5 +                                                                                                                                                                        If bLocalSqlA
.head 6 -                                                                                                                                                                        Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
.head 5 +                                                                                                                                                                        Else 
.head 6 -                                                                                                                                                                        Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 -  !
.head 5 -                                                                                                                                                                        Set sgSql = 'SELECT CUST_NO  FROM CUSTOMER_MASTER
 INTO :hWndForm.dfAsscustno
WHERE ASS_CUST_NO = :hWndForm.dfCustno'
.head 5 +                                                                                                                                                                        If SqlOK( hLocalSqlA,sgSql )
.head 6 +                                                                                                                                                                        If SqlFetchNext( hLocalSqlA,ngFetch )

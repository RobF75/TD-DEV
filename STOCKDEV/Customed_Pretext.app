	Cust_no = :1 and
	Inv_No = :2"
.head 7 -  Set sName = '0612SelTranRoy2'
.head 7 -  Set sBind = ' :nCustNoFrom, :nInvNo, '
.head 7 -  Set sInto = ' :sCultRootType, :sCultRootId, :sCultRootDesc, :sCustName, :dtPaidDT, :sOwnerId'
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  !
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 +  While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 -  Call UpdtTransferRoyalty( nCustNoFrom, nCustNoTo, nInvNo, sToCustName, sCultRootType, sCultRootId, sCultRootDesc, sCustName, dtPaidDT, sOwnerId, SH_cls_Execute)
.head 8 -  Return TRUE
.head 7 +  Else

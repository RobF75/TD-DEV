.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = "
SELECT
	Cult_Root_Type,
	Cult_Root_Id,
	Cult_Root_Desc,
	Cust_Name,
	Paid_Date_Time,
	Royalty_Owner_Id
FROM
	Royalties_Paid

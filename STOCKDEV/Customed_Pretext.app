.head 5 +  On PAM_REPOPULATE
.head 6 -  Set sSqlQCustomerContactSelect = '
SELECT 
  CUSTOMER_MASTER.CUST_NO, CUSTOMER_MASTER.ASS_CUST_NO, CUSTOMER_MASTER.CUST_NAME, CUSTOMER_MASTER.BUS_NAME, 
  CUSTOMER_CONTACTS.WRK_PHONE_CODE, CUSTOMER_CONTACTS.CONTACT_WORK_PHONE, 
  CUSTOMER_CONTACTS.CONTACT_SURNAME, CUSTOMER_MASTER.CUSTOMER_TYPE , customer_master.Supplier_id 
FROM  
  CUSTOMER_MASTER, CUSTOMER_CONTACTS
INTO 
  :frmQCustomer.tblQCustCont.colCustNo, :frmQCustomer.tblQCustCont.colAssCustNo, :frmQCustomer.tblQCustCont.colCustName, 
  :frmQCustomer.tblQCustCont.colBusName, :frmQCustomer.tblQCustCont.colACode, 
  :frmQCustomer.tblQCustCont.colPhNo, :frmQCustomer.tblQCustCont.colSurname, 
  :frmQCustomer.tblQCustCont.colCustType , 
  :frmQCustomer.tblQCustCont.colSupplierId
 WHERE 
  CUSTOMER_MASTER.CUST_NO = CUSTOMER_CONTACTS.CUST_NO 
' || sLocalBuildWhere || sORDERBY
.head 6 -  Call SalTblReset( hWndForm )
.head 6 -  Call SalTblPopulate( hWndForm, hLocalSqlPopTbl, sSqlQCustomerContactSelect, TBL_FillNormal )
.head 6 -  Call SalTblFetchRow( hWndForm, 0 )
.head 6 -  Call SalTblSetRowFlags( hWndForm, 0, ROW_Selected, TRUE )
.head 5 +  On PAM_RESET
.head 6 -  Call TableReset( hWndForm, colCustNo )
.head 5 +  On PAM_ENABLE
.head 6 +  If wParam
.head 7 -  Call SalShowWindow( hWndForm )
.head 6 +  Else
.head 7 -  Call SalHideWindow( hWndForm )
.head 5 +  On SAM_Create
.head 6 -  Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )

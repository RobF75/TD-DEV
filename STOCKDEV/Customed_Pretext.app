.head 3 +  ! Function: CheckCustNeedPRC
.head 4 -                                                                                                   Description: 
.head 4 +                                                                                                   Returns 
.head 5 -                                                                                                   Boolean: 
.head 4 +                                                                                                   Parameters 
.head 5 -                                                                                                   Number: nCustNo
.head 5 -                                                                                                   Number: nYear
.head 5 -                                                                                                   Receive Boolean: bNeedPRC
.head 5 -                                                                                                   Number: nActionType
.head 4 -                                                                                                   Static Variables 
.head 4 +                                                                                                   Local variables 
.head 5 -                                                                                                   String: sSql
.head 5 -                                                                                                   String: sBind
.head 5 -                                                                                                   String: sInto
.head 5 -                                                                                                   String: sName
.head 5 -                                                                                                   Number: nInd
.head 5 -                                                                                                   Number: nSqlHandleNo
.head 4 +                                                                                                   Actions 
.head 5 -                                                                                                   Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CheckCustNeedPRC' )
.head 5 +                                                                                                   Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -                                                                                                   Set sSql = " SELECT 
  Customer_Order.Cust_No 
FROM 
  Customer_Order, 
  Stock_Item, 
  Customer_Master
WHERE 
  Customer_Order.Cust_No = :1 AND 
  Customer_Order.Year_Of_Sale = :2 AND 
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
   Customer_Order.Conf_Amt > 0 AND
   Stock_Item.Prod_Royalty = 'Y' AND 
  ( NOT Customer_Order.PRC_Recd_Flag = 'Y' OR 
    Customer_Order.PRC_Recd_Flag IS NULL ) AND
  NOT Customer_Order.Sale_Cat = 'RP' "
.head 7 -                                                                                                   Set sName = 'IVCSTCHKNDPRC'
.head 7 -                                                                                                   Set sBind = ':nCustNo, :nYear'
.head 7 -                                                                                                   Set sInto = ''
.head 7 -                                                                                                   Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )

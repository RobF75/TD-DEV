.head 5 +  On PAM_REPOPULATE
.head 6 -  Set sSqlQCustomerAddressSelect = '
SELECT 
  CUSTOMER_MASTER.CUST_NO, CUSTOMER_MASTER.ASS_CUST_NO, CUSTOMER_MASTER.CUST_NAME, CUSTOMER_MASTER.BUS_NAME, 
  CUSTOMER_ADDRESS.AREA_CODE, CUSTOMER_ADDRESS.PHONE_NO, CUSTOMER_ADDRESS.ADDRESS_TYPE, 
  CUSTOMER_ADDRESS.SUBURB, CUSTOMER_ADDRESS.POSTCODE, CUSTOMER_MASTER.CUSTOMER_TYPE , customer_master.Supplier_id 
FROM  
  CUSTOMER_MASTER, CUSTOMER_ADDRESS
INTO 
  :frmQCustomer.tblQCustAddr.colCustNo, :frmQCustomer.tblQCustAddr.colAssCustNo, :frmQCustomer.tblQCustAddr.colCustName, 
  :frmQCustomer.tblQCustAddr.colBusName, :frmQCustomer.tblQCustAddr.colACode, 
  :frmQCustomer.tblQCustAddr.colPhNo, :frmQCustomer.tblQCustAddr.colAddType, 

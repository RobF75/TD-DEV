.head 5 +  If NOT bHandleConnected
.head 6 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 6 +  If bHandleConnected
.head 7 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else 
.head 7 -  Call SalWaitCursor( FALSE )
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Call SalWaitCursor( TRUE )
.head 7 -  Return FALSE
.head 5 +  If NOT bHandlePrepared
.head 6 +  If sOrderType = 'POS'
.head 7 -  Call CallBuildSql( hWndTable, nSELECT, PAM_SQLPOS, sSQLTABLENAME, sSqlWhere )
.head 6 +  Else 
.head 7 -  Call CallBuildSql( hWndTable, nSELECT, PAM_SQL, sSQLTABLENAME, sSqlWhere )
.head 6 +  If SqlPrepare( hSqlHandle, sgSql )
.head 7 -  Set bHandlePrepared = TRUE
.head 7 +  If NOT SqlExecute( hSqlHandle )
.head 8 -  Set bHandlePrepared = FALSE
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 -  Call SalMessageBox( 'Error occured in retrieving all order lines! ', 'Error', MB_Ok )
.head 8 -  Call SalWaitCursor( TRUE )
.head 8 -  Return FALSE
.head 6 +  Else 
.head 7 -  Set bHandlePrepared = FALSE
.head 5 -  Call SqlFetchNext( hSqlHandle, nInd )
.head 5 +  If nInd = FETCH_Ok
.head 6 -  Return TRUE
.head 5 +  Else If nInd = FETCH_EOF
.head 6 -  Return FALSE
.head 5 +  Else 
.head 6 -  Set bHandlePrepared = FALSE
.head 6 -  Call SalWaitCursor( FALSE )
.head 6 -  Call SalMessageBox( 'Error occured in retrieving a order line! ', 'Error', MB_Ok )
.head 6 -  Call SalWaitCursor( TRUE )

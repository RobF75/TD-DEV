.head 6 +  ! Case nRollback
.head 7 -                                                                                                                                                                        Return fcOurHandle.Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect()
.head 7 -  Call haSqlHandles[ nSqlBareHandleNo ].Disconnect()
.head 7 -  Return haSqlHandles[ nSqlContHandleNo ].Disconnect()

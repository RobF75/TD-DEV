.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 +  If sDisplayOrderType = 'CONTAINERISED'
.head 8 -  Set sSql = " 
SELECT 
	Sum( Conf_Amt ), 
	Sum( Ordered_Amount ) 
FROM 
	Customer_Order, Stock_Item
WHERE 
	Cust_No = :1 AND 
	Year_Of_Sale = :2 AND 
	Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
	Stock_Item.Tree_Type LIKE 'C%' "
.head 8 -  Set sName = '1303SumOrdCont'
.head 8 -  Set sBind = ':nCustNo, :nYear'
.head 8 -  Set sInto = ':nGotTotalConfAmt, :nGotTotalOrdAmt'
.head 8 -  Call haSqlHandles[ nSqlContHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 8 -  Call SqlVarSetup( haSqlHandles[ nSqlContHandleNo ].hSqlHandle )
.head 8 -  !
.head 8 -  Set nTotalConfAmt = 0
.head 8 -  Set nTotalOrdAmt = 0
.head 8 -  !
.head 8 -  Set nGotTotalConfAmt = 0
.head 8 -  Set nGotTotalOrdAmt = 0
.head 8 -  !
.head 8 +  If haSqlHandles[ nSqlContHandleNo ].Execute()
.head 9 -  Call haSqlHandles[ nSqlContHandleNo ].FetchNext( nInd )
.head 9 -  Set nTotalConfAmt = nGotTotalConfAmt
.head 9 -  Set nTotalOrdAmt = nGotTotalOrdAmt
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Return FALSE
.head 7 +  Else If sDisplayOrderType = 'BARE_ROOTED' 
.head 8 -  Set sSql = " 
SELECT 
	Sum( Conf_Amt ), 
	Sum( Ordered_Amount ) 
FROM 
	Customer_Order, Stock_Item  
WHERE 
	Cust_No = :1 AND 
	Year_Of_Sale = :2 AND 
	Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
	NOT Stock_Item.Tree_Type LIKE 'C%' "
.head 8 -  Set sName = '1303SumOrdBare'
.head 8 -  Set sBind = ':nCustNo, :nYear'
.head 8 -  Set sInto = ':nGotTotalConfAmt, :nGotTotalOrdAmt'
.head 8 -  Call haSqlHandles[ nSqlBareHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 8 -  Call SqlVarSetup( haSqlHandles[ nSqlBareHandleNo ].hSqlHandle )
.head 8 -  !
.head 8 -  Set nTotalConfAmt = 0
.head 8 -  Set nTotalOrdAmt = 0
.head 8 -  !
.head 8 -  Set nGotTotalConfAmt = 0
.head 8 -  Set nGotTotalOrdAmt = 0
.head 8 -  !
.head 8 +  If haSqlHandles[ nSqlBareHandleNo ].Execute()
.head 9 -  Call haSqlHandles[ nSqlBareHandleNo ].FetchNext( nInd )
.head 9 -  Set nTotalConfAmt = nGotTotalConfAmt
.head 9 -  Set nTotalOrdAmt = nGotTotalOrdAmt
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Set sSql = " 
SELECT 
	Sum( Conf_Amt ), 
	Sum( Ordered_Amount ) 
FROM 
	Customer_Order 
WHERE 
	Cust_No = :1 AND 
	Year_Of_Sale = :2 "
.head 8 -  Set sName = 'SUMCONFORDAMT'
.head 8 -  Set sBind = ':nCustNo, :nYear'
.head 8 -  Set sInto = ':nGotTotalConfAmt, :nGotTotalOrdAmt'
.head 8 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 8 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 8 -  !
.head 8 -  Set nTotalConfAmt = 0

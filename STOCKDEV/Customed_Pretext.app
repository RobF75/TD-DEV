.head 3 -  !
.head 3 +  Function: TableInsert
.head 4 -  Description: To insert all new rows in one hit - saltbldoinserts should
 do it but doesnt when key is date/time as well
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Long String: sTableDecl
.head 4 +  Actions
.head 5 -  Call PopWndHdl( hWndTbl, TRUE )
.head 5 -  Call PopString( sTableDecl, TRUE )
.head 5 -  Set ngRow = TBL_MinRow
.head 5 +  While SalTblFindNextRow( hWndTbl, ngRow, ROW_New, 0 )
.head 6 -  Call SalTblFetchRow( hWndTbl, ngRow )
.head 6 -  Call SalSendMsgToChildren( hWndTbl, PAM_SETEDIT, 0, 0 )
.head 6 -  Call CallBuildSql( hWndTbl,nINSERT, PAM_SQL, sTableDecl, '' )
.head 6 -  Set bOk = SqlImmediate( sgSql )
.head 6 +  If bOk
.head 7 -  Call SqlClearImmediate(  )
.head 7 -  Call SalTblSetRowFlags( hWndTbl, ngRow, ROW_New, FALSE )
.head 7 -  Call SalTblSetRowFlags( hWndTbl, ngRow, ROW_Edited, FALSE )
.head 6 +  Else
.head 7 -  Call SqlClearImmediate(  )
.head 7 -  Return FALSE
.head 3 +  ! Function: NumLoadToRegionLeft
.head 4 -                                                                                                                                                                        Description: To check if a customer order has been added and has not been 
assigned a load yet, if there is only one more load to their region
left to display a warning if it has already been pulled 
.head 4 -                                                                                                                                                                        Returns 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Boolean: bLocalSqlA
.head 5 -                                                                                                                                                                        Sql Handle: hLocalSqlA
.head 4 +                                                                                                                                                                        Actions 
.head 5 -  ! LOCAL SQL HANDLE CONNECTION, DISCONNECT ARE on exit pointS
.head 5 -                                                                                                                                                                        Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
.head 5 +                                                                                                                                                                        If bLocalSqlA
.head 6 -                                                                                                                                                                        Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
.head 5 +                                                                                                                                                                        Else 
.head 6 -                                                                                                                                                                        Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 -  !
.head 5 -                                                                                                                                                                        Set ngArray = 0
.head 5 -                                                                                                                                                                        Call SalQueryArrayBounds( sgLoadId, ngMin, ngMax )
.head 5 +                                                                                                                                                                        While ngArray <= ngMax
.head 6 -                                                                                                                                                                        Set sgLoadId[ngArray] = ' '
.head 6 -                                                                                                                                                                        Set sgPulled[ngArray] = ' '
.head 6 -                                                                                                                                                                        Set ngArray = ngArray + 1
.head 5 -                                                                                                                                                                        Call SalSetArrayBounds( sgLoadId, AC_Dynamic, AC_Dynamic )
.head 5 -                                                                                                                                                                        Set ngArray = 0
.head 5 -  ! I think this should have the shipping date as part of the where clause also
.head 5 -                                                                                                                                                                        Set sgSql = 'SELECT LOAD.LOAD_ID,LOAD_PULLED_FLAG FROM 
CUSTOMER_MASTER,REGION_LOAD,LOAD INTO
 :sgLoadId[ngArray], :sgPulled[ngArray] WHERE
 CUSTOMER_MASTER.CUST_NO = :frmOrderDets.dfCustNo AND
REGION_LOAD.REGION_ID = CUSTOMER_MASTER.REGION_ID AND 
LOAD.LOAD_ID = REGION_LOAD.LOAD_ID'
.head 5 +                                                                                                                                                                        If NOT SqlOK( hLocalSqlA, sgSql )
.head 6 +                                                                                                                                                                        If bLocalSqlA
.head 7 -                                                                                                                                                                        Call SqlDisconnect( hLocalSqlA )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 +                                                                                                                                                                        While SqlFetchNext( hLocalSqlA, ngFetch )
.head 6 -                                                                                                                                                                        Set ngArray = ngArray + 1
.head 5 -                                                                                                                                                                        Set ngArray = 0
.head 5 -                                                                                                                                                                        Call SalQueryArrayBounds( sgLoadId, ngMin, ngMax )
.head 5 +                                                                                                                                                                        If ngMax = ngMin
.head 6 +                                                                                                                                                                        If sgPulled[ngMin] = 'Y'
.head 7 -                                                                                                                                                                        Call SalMessageBox( 'The last load for this region has been
pulled.   Please notify despatch to see if it can be included on this load still',
 'Loads for this Order', MB_Ok )
.head 5 +                                                                                                                                                                        If bLocalSqlA
.head 6 -                                                                                                                                                                        Call SqlDisconnect( hLocalSqlA )
.head 3 +  ! Function: AddDeposit
.head 4 -                                                                                                                                                                        Description: Add the deposit required record to the outstanding deposit table 
.head 4 -                                                                                                                                                                        Returns 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Boolean: bLocalSqlA
.head 5 -                                                                                                                                                                        Sql Handle: hLocalSqlA
.head 4 +                                                                                                                                                                        Actions 
.head 5 -  ! LOCAL SQL HANDLE CONNECTION, DISCONNECT are on exit pointS
.head 5 -                                                                                                                                                                        Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
.head 5 +                                                                                                                                                                        If bLocalSqlA
.head 6 -                                                                                                                                                                        Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
.head 5 +                                                                                                                                                                        Else 
.head 6 -                                                                                                                                                                        Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 -  !
.head 5 -                                                                                                                                                                        Call SalSendMsgToChildren( dlgDeposit, PAM_SETEDIT, 0, 0 )
.head 5 -                                                                                                                                                                        Call CallBuildSql( dlgDeposit, nINSERT, PAM_SQL, OUTSTAND_DEPOSIT, '' )
.head 5 +                                                                                                                                                                        If MySqlPrepExec( hLocalSqlA, sgSql )

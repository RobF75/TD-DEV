.head 3 +  Actions
.head 4 -  Set sSqlFinelineCustomer =
"
Select
	*
From
	Customer_Master
Where
	Cust_No 	= :npCustNo
And	Fineline 	= 'Y'
"
.head 4 -  Call SqlExists( sSqlFinelineCustomer, bExists )
.head 4 -  Return bExists

  CUSTOMER_MASTER.CUST_NO,  CUSTOMER_MASTER.ASS_CUST_NO, CUSTOMER_MASTER.CUST_NAME , 
  CUSTOMER_MASTER.BUS_NAME, CUSTOMER_MASTER.CUSTOMER_TYPE, 
  CUSTOMER_MASTER.REGION_ID, customer_master.Supplier_id 
FROM  
  CUSTOMER_MASTER  
INTO 
  :frmQCustomer.tblQCustomer.colCustNo, 
  :frmQCustomer.tblQCustomer.colAssCustNo, 
  :frmQCustomer.tblQCustomer.colCustName, 
  :frmQCustomer.tblQCustomer.colBusName, 
  :frmQCustomer.tblQCustomer.colCustType, 
  :frmQCustomer.tblQCustomer.colCustRegion, 
  :frmQCustomer.tblQCustomer.colSupplierId
' || sLocalBuildWhere || sORDERBY
.head 6 -  Call SalTblReset( hWndForm )
.head 6 -  Call SalTblPopulate( hWndForm, hLocalSqlPopTbl, sSqlQCustomerSelect, TBL_FillNormal )
.head 6 -  Call SalTblFetchRow( hWndForm, 0 )
.head 6 -  Call SalTblSetRowFlags( hWndForm, 0, ROW_Selected, TRUE )
.head 6 -  Call SalSendMsg ( hWndForm, SAM_Click, 0, 0 ) 
.head 5 +  On PAM_RESET
.head 6 -  Call TableReset( hWndForm, colCustNo )
.head 5 +  On PAM_NOROWS
.head 6 -  Call SalMessageBox( 'No rows match the search criteria', 'Customer Query', MB_Ok )
.head 5 +  On PAM_ENABLE
.head 6 +  If wParam
.head 7 -  Call SalShowWindow( hWndForm )
.head 6 +  Else
.head 7 -  Call SalHideWindow( hWndForm )
.head 5 +  On SAM_Create
.head 6 -  Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 -  Set sORDERBY = ' ORDER BY 3,1 '
.head 5 +  On SAM_Destroy
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlDisconnect( hLocalSqlPopTbl )

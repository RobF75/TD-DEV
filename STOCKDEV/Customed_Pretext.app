.head 6 -  Call SalFilePutStr( fhOutputFile, 'Supplier Id, Item Description, Type, Buy Price (GST INC), Sell Price, Fineline / Keycode, Barcode Number' )
.head 6 +  While SalTblFindNextRow( hWndItem, nRow, 0, 0 )
.head 7 -  Call SalTblFetchRow( hWndItem, nRow )
.head 7 -  Set sOutputString = STRING_Null
.head 7 +  If colnWholesalePrice != NUMBER_Null
.head 8 -  Set nWholesalePrice = colnWholesalePrice + (colnWholesalePrice * nGSTPercent)
.head 7 +  Else 
.head 8 -  Call CalcItemPriceForQueries( colnStockItemNo, nDefaultYear, nWholesalePrice, nTmp, nTmp, SH_cls_Execute )
.head 7 +  If wParam = nOurBarcode
.head 8 -  Set sOutputString = fnCalculateBarCode( colnStockItemNo )
.head 8 -  Set sOutputString = sSupplierId || ',' || colsItemDescription || ',' || colsTreeType || ',' || SalNumberToStrX( nWholesalePrice, 2 ) || ',' || SalNumberToStrX( colnRetailPrice, 2 ) || ',' || SalNumberToStrX( colnFinelineNo, 0 ) || ',' || sOutputString
.head 7 +  Else If wParam = nTheirBarcode
.head 8 +  If colsBarCode = STRING_Null
.head 9 -  Set sOutputString = STRING_Null
.head 9 -  Set sOutputString = sSupplierId || ',' || colsItemDescription || ',' || colsTreeType || ',' || SalNumberToStrX( colnFinelineNo, 0 ) || ',' || SalNumberToStrX( nWholesalePrice, 2 ) || ',' || SalNumberToStrX( colnRetailPrice, 2 ) || ',' || sOutputString
.head 8 +  Else 
.head 9 -  Set nStepOneResult = 0
.head 9 -  Set nStepThreeResult = 0
.head 9 -  Set nStepTwoResult = 0
.head 9 -  Set sPreliminaryValue = colsBarCode
.head 9 -  Set nCount = 0
.head 9 -  ! The following while loop goes through the preliminary string extracting all characters
one by one as numbers into an array. Eg if string was 123456789012 then the characters would be extracted
as follows:   nBarCodeNumbers[0] = 1,nBarCodeNumbers[1] = 2,nBarCodeNumbers[2] = 3
.head 9 +  While nCount <= 11
.head 10 -  Set nBarCodeNumbers[nCount] = SalStrToNumber( SalStrMidX( sPreliminaryValue, nCount, 1 ) )
.head 10 -  Set nCount = nCount + 1
.head 9 -  ! First step in check digit calculation requires all alternate number starting from the right be
added together and then multiplied by three.
.head 9 -  Call SalArrayGetUpperBound( nBarCodeNumbers, 1, nArrayUpper )
.head 9 -  ! Step 1. Starting with the first number on the right, add all the alternate numbers.
Multiply the result by three.
.head 9 -  Set nCount = nArrayUpper
.head 9 +  While nCount >= 0
.head 10 -  Set nStepOneResult = nStepOneResult + nBarCodeNumbers[nCount]
.head 10 -  Set nCount = nCount - 2
.head 9 -  Set nStepOneResult = nStepOneResult * 3
.head 9 -  ! Step 2. Starting with the second number on the right add all the alternate numbers
.head 9 -  Set nCount = nArrayUpper - 1
.head 9 +  While nCount >= 0
.head 10 -  Set nStepTwoResult = nStepTwoResult + nBarCodeNumbers[nCount]
.head 10 -  Set nCount = nCount - 2
.head 9 -  ! Step 3. Add the results of step one and step two together
.head 9 -  Set nStepThreeResult = nStepOneResult + nStepTwoResult
.head 9 -  ! Step 4. The number needed to bring nStepThreeResult to the next multiple of 10 becomes the check digit
.head 9 -  ! In the following code the call to SalNumberMod will return the number left over after dividing by ten.
! To workout the check digit simply take that value from 10.
.head 9 -  Set nCheckDigit = 10 - SalNumberMod( nStepThreeResult, 10 )
.head 9 +  If nCheckDigit = 10
.head 10 -  Set nCheckDigit = 0
.head 9 -  Set sOutputString = sPreliminaryValue || SalNumberToStrX( nCheckDigit, 0 )
.head 9 -  Set sOutputString = sSupplierId || ',' || colsItemDescription || ',' || colsTreeType || ',' || SalNumberToStrX( colnFinelineNo, 0 ) || ',' || SalNumberToStrX( nWholesalePrice, 2 ) || ',' || SalNumberToStrX( colnRetailPrice, 2 ) || ',' || sOutputString
.head 7 +  Else If wParam = nFinelineException
.head 8 +  If colnFinelineNo = NUMBER_Null
.head 9 -  Set sOutputString = fnCalculateBarCode( colnStockItemNo )
.head 9 -  Set sOutputString = sSupplierId || ',' || colsItemDescription || ',' || colsTreeType || ',' || SalNumberToStrX( colnRetailPrice, 2 ) || ',' || SalNumberToStrX( nWholesalePrice, 2 ) || ',' || SalNumberToStrX( colnFinelineNo, 0 ) || ',' || sOutputString
.head 7 +  Else 
.head 8 -  Call SalMessageBox( 'Not a Valid selection' , 'Error' , MB_Ok )
.head 8 -  Break 
.head 7 +  If sOutputString != STRING_Null
.head 8 -  Call SalFilePutStr( fhOutputFile, sOutputString )
.head 6 -  Call SalFileClose( fhOutputFile )
.head 6 -  Call SalLoadAppAndWait( 'c:\\centura\\localexe\\csv2xls.exe csv2xls ' || sFilePath || ' ' || SalStrLeftX( sFilePath, SalStrLength( sFilePath ) - 3 ) || 'xls' , Window_NotVisible, nReturn )
.head 6 -  Call VisFileDelete( SalStrLeftX( sFilePath, SalStrLength( sFilePath ) - 3 ) || 'csv' )

.head 3 +  ! Function: GetNoCustOrderLines
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  Number: 
.head 4 +  Parameters 
.head 5 -  Receive Sql Handle: hSqlHandle
.head 5 -  Receive Boolean: bHandleConnected
.head 5 -  Number: nCustNo
.head 5 -  String: sSQLTABLENAME
.head 5 -  Window Handle: hWndTable
.head 5 -  String: sTransferType
.head 5 -  String: sPOSOrders
.head 5 -  Number: nYear
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  String: sSql
.head 5 -  Number: nNoOrders
.head 5 -  Number: nRow
.head 5 -  Number: nInd
.head 4 +  Actions 
.head 5 -  Set nNoOrders = NUMBER_Null
.head 5 +  If sTransferType = 'SELECTED' AND sPOSOrders != 'POS'
.head 6 -  Set nRow = TBL_MinRow
.head 6 +  While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
.head 7 -  Set nNoOrders = nNoOrders + 1
.head 6 -  Return nNoOrders
.head 5 +  Else 
.head 6 +  If NOT bHandleConnected
.head 7 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 7 +  If bHandleConnected
.head 8 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 8 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 7 +  Else 
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 8 -  Call SalWaitCursor( TRUE )
.head 8 -  Return -1
.head 6 +  If sPOSOrders = 'POS' AND sTransferType = 'SELECTED'
.head 7 -  Set sSql = 'SELECT Count(*) FROM ' || sSQLTABLENAME || ' INTO :nNoOrders WHERE Cust_No = :nCustNo AND Year_Of_Order = :nYear '
.head 6 +  Else 
.head 7 -  Set sSql = 'SELECT Count(*) FROM ' || sSQLTABLENAME || ' INTO :nNoOrders WHERE Cust_No = :nCustNo '
.head 6 +  If SqlPrepare( hSqlHandle, sSql )
.head 7 +  If SqlExecute( hSqlHandle )
.head 8 -  Call SqlFetchNext( hSqlHandle, nInd )
.head 8 +  If nInd = FETCH_Ok
.head 9 -  Return nNoOrders
.head 8 +  Else If nInd = FETCH_EOF
.head 9 -  Return 0
.head 8 +  Else 
.head 9 -  Return -1
.head 7 +  Else 
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 -  Call SalMessageBox( 'Error occured in retrieving a count of order lines! ', 'Error', MB_Ok )
.head 8 -  Call SalWaitCursor( TRUE )
.head 8 -  Return -1
.head 6 +  Else 
.head 7 -  Call SalWaitCursor( FALSE )
.head 7 -  Call SalMessageBox( 'Error occured in Preparing count order order lines statement! ', 'Error', MB_Ok )
.head 7 -  Call SalWaitCursor( TRUE )
.head 7 -  Return -1

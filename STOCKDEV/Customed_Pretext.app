.head 3 +  Function: UpdtCustOrderContractPrice
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Number: nItemNo
.head 5 -  String: sSupplierId
.head 5 -  Number: nContractPrice
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nSqlHandleNo
.head 5 -  Number: nInd
.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( '0411UpCstOrdCP' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = "
UPDATE
	Customer_Order
SET
	Contract_Price = :1
WHERE
	Stock_Item_no = :2 and
	(Invoiced_Flag = 'N' or Invoiced_flag is null ) and
	cust_no in (
	select
		Cust_no
	from
		Customer_master
	where
		(Cust_No = :3 and
		supplier_id = :4) or
		(ass_cust_no = :3 and
		supplier_id = :4))
	"
.head 7 -  Set sName = '0411UpCstOrdCP4'
.head 7 -  Set sBind = ':nContractPrice , :nItemNo, :nCustNo, :sSupplierId '
.head 7 -  Set sInto = ''
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  !
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 -  Call haSqlHandles[ nSqlHandleNo ].Commit(  )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )

.head 4 +  Message Actions 
.head 5 +  ! On PAM_SETSGSQL
.head 6 -  Set sgSql = "
SELECT
	CUST.RowId,
	ST.Item_No,
	ST.Cult_Desc,
	T.Tree_Type_Desc,
	CUST.Fine_Line,
	CUST.RETAIL_PRICE,
	CUST.BARCODE
FROM
	Customer_Item CUST,
	Stock_Item ST,
	Tree_Type T
INTO
	:dlgFinelineMaintenance.tblCustomerItems.colRowId,
	:dlgFinelineMaintenance.tblCustomerItems.colnStockItemNo,
	:dlgFinelineMaintenance.tblCustomerItems.colsItemDescription,
	:dlgFinelineMaintenance.tblCustomerItems.colsTreeType,
	:dlgFinelineMaintenance.tblCustomerItems.colnFinelineNo,
	:dlgFinelineMaintenance.tblCustomerItems.colnRetailPrice,
	:dlgFinelineMaintenance.tblCustomerItems.colsBarCode	
WHERE 
	CUST.Cust_No 		= :dlgFinelineMaintenance.npCustomerNo
	AND	CUST.Stock_Item_No 	= ST.Item_No
	AND	ST.Tree_Type		= T.Tree_Type 
	AND	CUST.Supplier_Id 		= :dlgFinelineMaintenance.sSupplierId
ORDER BY 
	ST.Variety_Type,
	ST.Variety,
	ST.Cult_Desc,
	ST.Tree_Type
"
.head 6 -  Return TRUE
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 +  If TRUE
.head 7 -  Set sSQLPOPTABLENAME = 
"
Customer_Item CUST,
Stock_Item ST,
Tree_Type T
"
.head 7 -  Set sSQLTABLENAME = 
"
Customer_Item CUST,
Stock_Item ST,
Tree_Type T
"
.head 7 +  If dlgFinelineMaintenance.sSupplierId = STRING_Null
.head 8 -  Set sSQLWHERE = 
"
WHERE 
	CUST.Cust_No 		= :dlgFinelineMaintenance.npCustomerNo
AND	CUST.Stock_Item_No 	= ST.Item_No
AND	ST.Tree_Type		= T.Tree_Type 
" 	
.head 7 +  Else 
.head 8 -  Set sSQLWHERE = 
"
WHERE 
	CUST.Cust_No 		= :dlgFinelineMaintenance.npCustomerNo
AND	CUST.Stock_Item_No 	= ST.Item_No
AND	ST.Tree_Type		= T.Tree_Type 
AND	CUST.Supplier_Id 		= :dlgFinelineMaintenance.sSupplierId
" 	
.head 7 -  Set sORDERBY = 
"
ORDER BY 
	ST.Variety_Type,
	ST.Variety,
	ST.Cult_Desc,
	ST.Tree_Type
"

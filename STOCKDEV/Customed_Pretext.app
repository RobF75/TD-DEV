.head 7 -  Set sBind = ':nCustNoTo, :sToCustName, :nCustNoFrom, :nInvNo, :sCustName, :sCultRootType, :sCultRootId, :sCultRootDesc, :dtPaidDT, :sOwnerId '
.head 7 -  Set sInto = ''
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  !

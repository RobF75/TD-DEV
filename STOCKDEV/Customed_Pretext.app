.head 9 -  Call haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 -  Set nTotalConfAmt = nGotTotalConfAmt
.head 9 -  Set nTotalOrdAmt = nGotTotalOrdAmt
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Return FALSE

into :sTmpConf
where cust_no = :nCustNo and conf_flag = \'N\' and
year_of_sale = :nYear'
.head 5 +                                                                                                                                                                        If SqlPrepare( hSqlHandle, sSql )
.head 6 +                                                                                                                                                                        If SqlExecute( hSqlHandle )
.head 7 -                                                                                                                                                                        Call SqlFetchNext( hSqlHandle, nInd )
.head 6 +                                                                                                                                                                        Else 
.head 7 -                                                                                                                                                                        Call SalMessageBox( 'SqlExecute had a error in function HasCustAnyUnConfirms.  Please contact programmers.', 'Error', MB_Ok )
.head 7 +                                                                                                                                                                        If bSqlHandle
.head 8 -                                                                                                                                                                        Call SqlDisconnect( hSqlHandle )
.head 7 -                                                                                                                                                                        Return FALSE
.head 5 +                                                                                                                                                                        Else 
.head 6 -                                                                                                                                                                        Call SalMessageBox( 'SqlPrepare had a error in function HasCustAnyUnConfirms.  Please contact programmers.', 'Error', MB_Ok )
.head 6 +                                                                                                                                                                        If bSqlHandle
.head 7 -                                                                                                                                                                        Call SqlDisconnect( hSqlHandle )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 +                                                                                                                                                                        If sTmpConf != ''
.head 6 +                                                                                                                                                                        If bSqlHandle
.head 7 -                                                                                                                                                                        Call SqlDisconnect( hSqlHandle )
.head 6 -                                                                                                                                                                        Return TRUE
.head 5 +                                                                                                                                                                        If bSqlHandle
.head 6 -                                                                                                                                                                        Call SqlDisconnect( hSqlHandle )
.head 5 -                                                                                                                                                                        Return FALSE
.head 3 +  ! Function: GetItemisedAckForCust
.head 4 -                                                                                                                                                                        Description: 
.head 4 +                                                                                                                                                                        Returns 
.head 5 -                                                                                                                                                                        Boolean: 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        String: sTmpItemisedAck
.head 4 +                                                                                                                                                                        Actions 
.head 5 -                                                                                                                                                                        Set sTmpItemisedAck = ''
.head 5 -                                                                                                                                                                        Set sgSql = 'SELECT Customer_Type.Itemised_Ack 
FROM Customer_Type, Customer_Master
INTO :sTmpItemisedAck 
WHERE Customer_Master.Cust_No = :frmOrders.dfCustNo AND
Customer_Master.Customer_Type = Customer_Type.Cust_Type'
.head 5 +                                                                                                                                                                        If SqlImmediate( sgSql )
.head 6 -                                                                                                                                                                        Call SqlClearImmediate(  )
.head 6 +                                                                                                                                                                        If sTmpItemisedAck = 'Y'
.head 7 -                                                                                                                                                                        Return TRUE
.head 6 +                                                                                                                                                                        Else 
.head 7 -                                                                                                                                                                        Return FALSE
.head 5 +                                                                                                                                                                        Else 
.head 6 -                                                                                                                                                                        Call SqlClearImmediate(  )
.head 6 -                                                                                                                                                                        Return FALSE
.head 3 -  !
.head 3 +  ! Function: CalculateMessageLegend
.head 4 -                                                                                                                                                                        Description: 
.head 4 -                                                                                                                                                                        Returns 
.head 4 +                                                                                                                                                                        Parameters 
.head 5 -                                                                                                                                                                        Boolean: bUseStockItemCount
.head 5 -                                                                                                                                                                        Window Handle: hWndTable
.head 5 -                                                                                                                                                                        Number: nYear
.head 5 -                                                                                                                                                                        Receive String: sMessageLegend[1:*]
.head 5 -                                                                                                                                                                        Receive Number: nLastArrayEntry
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Sql Handle: hSqlHandle
.head 5 -                                                                                                                                                                        Boolean: bSqlHandle
.head 5 -                                                                                                                                                                        String: sSql
.head 5 -                                                                                                                                                                        Number: nInd
.head 5 -                                                                                                                                                                        String: sTreeTypeMessage
.head 5 -                                                                                                                                                                        Number: nLegendNo
.head 5 -                                                                                                                                                                        Number: nAmount
.head 5 -                                                                                                                                                                        Boolean: bStockCountMessageTaken
.head 5 -                                                                                                                                                                        Boolean: bCalculateLegend
.head 4 +                                                                                                                                                                        Actions 
.head 5 -                                                                                                                                                                        Set bSqlHandle = SqlConnect( hSqlHandle ) 
.head 5 +                                                                                                                                                                        If bSqlHandle
.head 6 -                                                                                                                                                                        Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 5 +                                                                                                                                                                        Else 
.head 6 -                                                                                                                                                                        Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 -                                                                                                                                                                        Set bStockCountMessageTaken = FALSE
.head 5 +                                                                                                                                                                        If bUseStockItemCount
.head 6 -                                                                                                                                                                        Set bCalculateLegend = FALSE
.head 6 -  ! Get amount of trees ordered by customer, if we have a confirmed amount
use it ever ordered amount
.head 6 +                                                                                                                                                                        If NOT SalIsNull( hWndTable.colConfAmt )
.head 7 -                                                                                                                                                                        Set nAmount = hWndTable.colConfAmt
.head 6 +                                                                                                                                                                        Else 
.head 7 -                                                                                                                                                                        Set nAmount = hWndTable.colOrdAmt
.head 6 -  ! If the order was substituted then check the availability of the substitute only
else availability of the ordered stock item.
.head 6 +                                                                                                                                                                        If hWndTable.colSubsItemNo != NUMBER_Null 
.head 7 +                                                                                                                                                                        If NOT AvailabilityOk(  hWndTable.colSubsItemNo, nYear, nAmount )
.head 8 -                                                                                                                                                                        Set sSql = 'SELECT Ack_Count_message FROM Tree_Type
INTO :sTreeTypeMessage
WHERE Tree_Type = :hWndTable.colType'
.head 8 -                                                                                                                                                                        Call SqlPrepare( hSqlHandle, sSql )
.head 8 -                                                                                                                                                                        Call SqlExecute( hSqlHandle )
.head 8 -                                                                                                                                                                        Call SqlFetchNext( hSqlHandle, nInd )
.head 8 +                                                                                                                                                                        If NOT sTreeTypeMessage = ''
.head 9 -                                                                                                                                                                        Set bStockCountMessageTaken = TRUE
.head 9 -                                                                                                                                                                        Set bCalculateLegend = TRUE
.head 6 +                                                                                                                                                                        Else 
.head 7 +                                                                                                                                                                        If NOT AvailabilityOk(  hWndTable.colItemNo, nYear, nAmount )
.head 8 -                                                                                                                                                                        Set sSql = 'SELECT Ack_Count_message FROM Tree_Type
INTO :sTreeTypeMessage
WHERE Tree_Type = :hWndTable.colType'
.head 8 -                                                                                                                                                                        Call SqlPrepare( hSqlHandle, sSql )
.head 8 -                                                                                                                                                                        Call SqlExecute( hSqlHandle )
.head 8 -                                                                                                                                                                        Call SqlFetchNext( hSqlHandle, nInd )
.head 8 +                                                                                                                                                                        If NOT sTreeTypeMessage = ''
.head 9 -                                                                                                                                                                        Set bStockCountMessageTaken = TRUE
.head 9 -                                                                                                                                                                        Set bCalculateLegend = TRUE
.head 5 -  ! Always print the general message IF we have one
.head 5 +                                                                                                                                                                        If NOT bStockCountMessageTaken
.head 6 -                                                                                                                                                                        Set sSql = 'SELECT Ack_Gen_message FROM Tree_Type
INTO :sTreeTypeMessage
WHERE Tree_Type = :hWndTable.colType'
.head 6 -                                                                                                                                                                        Call SqlPrepare( hSqlHandle, sSql )
.head 6 -                                                                                                                                                                        Call SqlExecute( hSqlHandle )
.head 6 -                                                                                                                                                                        Call SqlFetchNext( hSqlHandle, nInd )
.head 6 +                                                                                                                                                                        If NOT sTreeTypeMessage = ''
.head 7 -                                                                                                                                                                        Set bCalculateLegend = TRUE
.head 5 +                                                                                                                                                                        If bCalculateLegend
.head 6 -                                                                                                                                                                        Set nLegendNo = GetMessageLegendNo ( sTreeTypeMessage, sMessageLegend, nLastArrayEntry )
.head 6 +                                                                                                                                                                        If nLegendNo > 0
.head 7 -                                                                                                                                                                        Set hWndTable.colAvailability = nLegendNo
.head 6 +                                                                                                                                                                        Else 
.head 7 -                                                                                                                                                                        Call AddMessageToLegend( sTreeTypeMessage, hWndTable, sMessageLegend, nLastArrayEntry )
.head 5 +                                                                                                                                                                        If bSqlHandle
.head 6 -                                                                                                                                                                        Call SqlDisconnect( hSqlHandle )
.head 3 +  ! Function: AvailabilityOk
.head 4 -                                                                                                                                                                        Description: To compare the passed in ordered amount of the passed in stock Item
against the total availability of the stock item in the stock_item_Sale
file.  If availability Ok, ie: total availability - ordered amount isnt less 
than the threshold (20 or so) then it returns true else false
.head 4 +                                                                                                                                                                        Returns 
.head 5 -                                                                                                                                                                        Boolean: 
.head 4 +                                                                                                                                                                        Parameters 
.head 5 -                                                                                                                                                                        Number: nItemNo
.head 5 -                                                                                                                                                                        Number: nYear
.head 5 -                                                                                                                                                                        Number: nOrderedAmount
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Sql Handle: hSqlHandle
.head 5 -                                                                                                                                                                        Boolean: bSqlHandle
.head 5 -                                                                                                                                                                        String: sSql
.head 5 -                                                                                                                                                                        Number: nInd
.head 5 -                                                                                                                                                                        Number: nAvailThreshold
.head 5 -                                                                                                                                                                        Number: nTotalAvail
.head 4 +                                                                                                                                                                        Actions 
.head 5 -                                                                                                                                                                        Set bSqlHandle = SqlConnect( hSqlHandle ) 
.head 5 +                                                                                                                                                                        If bSqlHandle
.head 6 -                                                                                                                                                                        Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 5 +                                                                                                                                                                        Else 
.head 6 -                                                                                                                                                                        Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 -  ! INSTEAD OF CHECKING THE MIMINUM OF 20 - WE NOW NEED TO DO SOME
SPECIAL PROCESSING IF THE TOTAL AVAILABLE IS LESS THAN 0.
INSTEAD OF JUST PRINTING THE MESSAGE OF SUBJECT TO LIFTING EG THE 
STOCK COUNT MESSAGE(I THINK), WE NEED TO FETCH ALL CUSTOMERS WHO
HAVE ORDERED THIS STOCK ITEM BY ORDER DATE AND THEN WORK DOWN
FROM THE GROWING COUNT MINUS EACH PERSONS ORDER AMT UNTIL WE 
HIT THE CUSTOMER THAT WE ARE CURRENTLY DOING AN ACKNOWLEDGEMENT
FOR - IF HIS ORDER HASNT SENT THE TOTAL AVAIL(DYNAMICALLY BEING CALCULATED
DOWN BELOW ZERO THEN HE GETS THE OK MESSAGE - IF IT IS NEGATIVE EG WHEN
HE ORDERED THAT STOCK ITEM WAS ALREADY AT  -100 THEN HE HAS TO
GET THE MESSAGE THAT ITS SUBJECT TO LIFTING   
.head 5 -  ! Change this figure if we need to change the minimum availability before 
printing the Ack_Count_message.
.head 5 -                                                                                                                                                                        Set nAvailThreshold = 20
.head 5 -                                                                                                                                                                        Set nTotalAvail = 0
.head 5 -                                                                                                                                                                        Set sSql = 'SELECT Tot_Avail FROM Stock_Item_Sale INTO :nTotalAvail
WHERE Stock_Item_No = :nItemNo AND Year_Of_Sale = :nYear'
.head 5 +                                                                                                                                                                        If SqlPrepare( hSqlHandle, sSql )
.head 6 +                                                                                                                                                                        If SqlExecute( hSqlHandle )
.head 7 -                                                                                                                                                                        Call SqlFetchNext( hSqlHandle, nInd )
.head 6 +                                                                                                                                                                        Else 
.head 7 -                                                                                                                                                                        Call SalMessageBox( 'SqlExecute had a error in function AvailabilityOk.  Please contact programmers.', 'Error', MB_Ok )
.head 7 +                                                                                                                                                                        If bSqlHandle
.head 8 -                                                                                                                                                                        Call SqlDisconnect( hSqlHandle )
.head 7 -                                                                                                                                                                        Return FALSE
.head 5 +                                                                                                                                                                        Else 
.head 6 -                                                                                                                                                                        Call SalMessageBox( 'SqlPrepare had a error in function AvailabilityOk.  Please contact programmers.', 'Error', MB_Ok )
.head 6 +                                                                                                                                                                        If bSqlHandle
.head 7 -                                                                                                                                                                        Call SqlDisconnect( hSqlHandle )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 -  ! THE FOLLOWING CHECK IS WRONG ANYWAY - THE TOTAL AVAILABLE FOR
A STOCK ITEM ALREADY HAS THE ORDERED AMOUNT TAKEN OFF IT FOR THE
CUSTOMER - WHAT YOU ARE DOING HERE IS CHECKING AGAIN BY TAKING
THE AMOUNT OFF AGAIN - YOU ONLY NEED TO CHECK IF THE TOTAL AVAILABLE
IS GREATER THAN ZERO - IF IT IS - WE HAVE THE STOCK AVAILABLE FOR THE
CUSTOMER
.head 5 +                                                                                                                                                                        If nTotalAvail - nOrderedAmount < nAvailThreshold
.head 6 +                                                                                                                                                                        If bSqlHandle
.head 7 -                                                                                                                                                                        Call SqlDisconnect( hSqlHandle )
.head 6 -                                                                                                                                                                        Return FALSE
.head 5 +                                                                                                                                                                        Else 
.head 6 +                                                                                                                                                                        If bSqlHandle
.head 7 -                                                                                                                                                                        Call SqlDisconnect( hSqlHandle )
.head 6 -                                                                                                                                                                        Return TRUE
.head 3 +  ! Function: GetMessageLegendNo
.head 4 -                                                                                                                                                                        Description: 
.head 4 +                                                                                                                                                                        Returns 
.head 5 -                                                                                                                                                                        Number: 
.head 4 +                                                                                                                                                                        Parameters 
.head 5 -                                                                                                                                                                        String: sTreeTypeMessage
.head 5 -                                                                                                                                                                        String: sMessageLegend[1:*]
.head 5 -                                                                                                                                                                        Number: nLastArrayEntry
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Number: nCurrentPos
.head 4 +                                                                                                                                                                        Actions 
.head 5 -                                                                                                                                                                        Set nCurrentPos = 1
.head 5 +                                                                                                                                                                        While nCurrentPos < nLastArrayEntry
.head 6 +                                                                                                                                                                        If sMessageLegend[ nCurrentPos ] = sTreeTypeMessage
.head 7 -                                                                                                                                                                        Return nCurrentPos 
.head 6 -                                                                                                                                                                        Set nCurrentPos = nCurrentPos + 1
.head 5 -                                                                                                                                                                        Return 0
.head 3 +  ! Function: AddMessageToLegend
.head 4 -                                                                                                                                                                        Description: 
.head 4 -                                                                                                                                                                        Returns 
.head 4 +                                                                                                                                                                        Parameters 
.head 5 -                                                                                                                                                                        String: sTreeTypeMessage
.head 5 -                                                                                                                                                                        Window Handle: hWndTable
.head 5 -                                                                                                                                                                        Receive String: sMessageLegend[1:*]
.head 5 -                                                                                                                                                                        Receive Number: nLastArrayEntry
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 -                                                                                                                                                                        Local variables 
.head 4 +                                                                                                                                                                        Actions 
.head 5 -  ! because sMessageLegend start from 1:*
.head 5 -                                                                                                                                                                        Set sMessageLegend[ nLastArrayEntry ] = sTreeTypeMessage
.head 5 -                                                                                                                                                                        Set hWndTable.colAvailability = nLastArrayEntry
.head 5 -                                                                                                                                                                        Set nLastArrayEntry = nLastArrayEntry + 1
.head 3 +  ! Function: SendMessages
.head 4 -                                                                                                                                                                        Description: Sends messages one by one to the reportwindows
.head 4 -                                                                                                                                                                        Returns 
.head 4 +                                                                                                                                                                        Parameters 
.head 5 -                                                                                                                                                                        Window Handle: hWndFrmTbl
.head 5 -                                                                                                                                                                        Window Handle: hWndTable
.head 5 -                                                                                                                                                                        String: sMessageLegend[1:*]
.head 5 -                                                                                                                                                                        Number: nLastArrayEntry
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 
.head 5 -                                                                                                                                                                        Number: nInc
.head 4 +                                                                                                                                                                        Actions 
.head 5 -                                                                                                                                                                        Call SalTblSetFlagsAnyRows( hWndFrmTbl, ROW_Selected, FALSE, 0, 0 )
.head 5 -                                                                                                                                                                        Call SalTblFetchRow( hWndFrmTbl, 0 )
.head 5 -                                                                                                                                                                        Call SalSendMsgToChildren( hWndFrmTbl, PAM_INITIALIZE, 0, 0 )
.head 5 -                                                                                                                                                                        Call SalTblSetRowFlags( hWndFrmTbl, 0, ROW_Selected, TRUE )
.head 5 -                                                                                                                                                                        Set hWndTable.colTTMessage = '       '
.head 5 -                                                                                                                                                                        Set nInc = 1
.head 5 +                                                                                                                                                                        While nInc < nLastArrayEntry
.head 6 -                                                                                                                                                                        Call SalTblFetchRow( hWndFrmTbl, nInc )
.head 6 +                                                                                                                                                                        If NOT SalTblSetContext( hWndFrmTbl, nInc )
.head 7 -                                                                                                                                                                        Call SalTblInsertRow( hWndFrmTbl, nInc )
.head 6 -                                                                                                                                                                        Call SalSendMsgToChildren( hWndFrmTbl, PAM_INITIALIZE, 0, 0 )
.head 6 -                                                                                                                                                                        Call SalTblSetRowFlags( hWndFrmTbl, nInc, ROW_Selected, TRUE )
.head 6 -                                                                                                                                                                        Set hWndTable.colTTMessage = sMessageLegend[nInc]
.head 6 -                                                                                                                                                                        Set hWndTable.colAvailability = nInc
.head 6 -                                                                                                                                                                        Set nInc = nInc + 1
.head 3 -  !
.head 3 +  ! Function: GetTreeType
.head 4 -                                                                                                                                                                        Description: Due to the time difference when doing a query with tree type desc as
part of the select statement will get the tree type for each individual
record as we go
.head 4 -                                                                                                                                                                        Returns 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 -                                                                                                                                                                        Local variables 
.head 4 +                                                                                                                                                                        Actions 
.head 5 -                                                                                                                                                                        Set sgSql = 'SELECT TREE_TYPE_DESC FROM TREE_TYPE
 INTO :frmOrders.tblOrder.colTypeDesc WHERE TREE_TYPE = :frmOrders.tblOrder.colType'
.head 5 -                                                                                                                                                                        Call SqlImmediate( sgSql )
.head 5 -                                                                                                                                                                        Call SqlClearImmediate(  )
.head 3 +  ! Function: SetMessage
.head 4 -                                                                                                                                                                        Description: To set the Message field on frmCustomer if an associated 
company exists in Customer master 
.head 4 -                                                                                                                                                                        Returns 
.head 4 -                                                                                                                                                                        Parameters 
.head 4 -                                                                                                                                                                        Static Variables 
.head 4 +                                                                                                                                                                        Local variables 

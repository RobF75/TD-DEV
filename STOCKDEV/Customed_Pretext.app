.head 7 -                                                                                                                                                                        Set frmOrders.bFilesUpdated = FALSE
.head 7 -                                                                                                                                                                        Return FALSE
.head 6 +  If NOT MyUpdateOrderForInvoice( frmOrders.tblOrder, frmOrders.tblOrder.colItemNo,
 frmOrders.tblOrder.colSubsItemNo, frmOrders.tblOrder.colYr, frmOrders.tblOrder.colConfAmt, SH_cls_Execute )
.head 7 -                                                                                                                                                                        Set frmOrders.bFilesUpdated = FALSE
.head 7 -                                                                                                                                                                        Return FALSE
.head 5 +                                                                                                                                                                        If ngTRow = ngCount2 - 1
.head 6 -  !
.head 6 +                                                                                                                                                                        If SalSendMsg( tblInvoiceTotals, PAM_LOOKUPCUST, 0, frmOrders.dfCustNo )
.head 7 -                                                                                                                                                                        Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, nUseStoredTotals, 0 )

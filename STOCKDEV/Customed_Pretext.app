.head 4 -  Call SalSendMsgToChildren( hWndForm, PAM_DELETEROWS, wParam, lParam)
.head 3 +  On PAM_WRITEINSERTSUPDATES
.head 4 -  Call SalSendMsgToChildren( hWndForm, PAM_WRITEINSERTSUPDATES, wParam, lParam )
.head 3 +  On SAM_CreateComplete
.head 4 -  ! ! 12/6/02 (PXD) Now using registry details for barcode report selection
.head 4 -  ! Set sReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', 'k:\Centura\Reports' ) || '\\Barcode1.qrp'
.head 4 -  Call GetRegistryValue( 'REPORTS', 'Barcodes', sReportFile, '' )
.head 4 -  Set sReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' ) || '\\' || sReportFile
.head 4 -  Set sReportVars = 'dfnCustomerNo, dfsCustomerName, nItemNo, tblCustomerItems.colsTreeType, tblCustomerItems.colsItemDescription, sFineline, tblCustomerItems.colnRetailPrice, sSupplierId, nQuantityCount'
.head 4 -  Set sReportInto = 'CustNo, CustName, ItemNo, Type, CultDesc, Fineline, Price, Supplier, Count'
.head 4 -  Call Getmarkup( dfnCustomerNo, dfMarkup, SH_cls_Execute )
.head 4 +  If dfMarkup != NUMBER_Null 
.head 5 -  Call SalSendMsgToChildren( hWndForm, PAM_FinelineShowMarkup, 1, 0 )
.head 4 +  Else 
.head 5 -  Call SalSendMsgToChildren( hWndForm, PAM_FinelineShowMarkup, 0, 0 )
.head 4 -  ! ! 12/9/02 (PXD) Moved printer setup to the PAM_PRINTBARCODES, so that each print re-initialises it.
If other forms were being used, the current printer was being changed between prints.
.head 4 -  ! Call SetPrinter( 'Barcode' )
.head 3 +  On PAM_PRINTBARCODES
.head 4 -  ! Call SalSendMsgToChildren( hWndForm, PAM_PRINTBARCODES, wParam, lParam )
.head 4 -  Call SetPrinter( 'Barcode' )
.head 4 +  If NOT SalReportPrint( hWndForm,  sReportFile, sReportVars, sReportInto, 1, RPT_PrintAll, 0, 0, nErr )
.head 5 -  Call SalMessageBox(SalNumberToStrX( nErr, 0 ), 'Error', MB_Ok)
.head 3 +  On PAM_COPYSELECTEDROWS
.head 4 -  Call SalSendMsgToChildren( hWndForm, PAM_COPYSELECTEDROWS, wParam, lParam )
.head 3 +  On SAM_ReportStart
.head 4 -  ! Set sReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', 'k:\Centura\Reports' ) || '\\Barcode1.qrp'
.head 4 -  ! gf 24/10/02 Commenting out the select of the supplier id as this is now one oof the window parameters.
.head 4 -  ! Set sSqlCustDetails =
"SELECT
	Supplier_ID,
	Bitmap
FROM
	Customer_Master
INTO
	:sSupplier,
	:sCustBitmap
WHERE
	Cust_No = :dfnCustomerNo
"
.head 4 -  Set sSqlCustDetails =
"SELECT
	Bitmap
FROM
	Customer_Master
INTO
	:sCustBitmap
WHERE
	Cust_No = :dfnCustomerNo
"
.head 4 -  Call SqlConnect( hSqlCustDetails )					
.head 4 -  Call SqlPrepare( hSqlCustDetails, sSqlCustDetails )				
.head 4 -  Call SqlExecute (hSqlCustDetails)
.head 4 -  Call SqlFetchRow( hSqlCustDetails, 0, nReturnCode )			
.head 4 -  Call SqlDisconnect (hSqlCustDetails)				
.head 4 -  ! Set sReportInto = 'CustNo, CustName, ItemNo'
.head 4 -  ! Set sReportVars = 'nCustNo, sCustName, nItemNo'
.head 4 -  ! Set sReportVars = 'dfnCustomerNo, dfsCustomerName, nItemNo, colsTreeType, colsItemDescription, sFineline, colnRetailPrice, sSupplier, nQuantityCount'
.head 4 -  ! Set sReportInto = 'CustNo, CustName, ItemNo, Type, CultDesc, Fineline, Price, Supplier, Count'
.head 4 -  ! Call SetPrinter( 'Barcode' )
.head 3 +  On SAM_ReportFinish
.head 4 -  Call SetDefaultPrinter(  )
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchInit
.head 4 -  ! Set nCount = 0
.head 4 -  Set nQuantityCount = 0
.head 4 -  Set nRow = TBL_MinRow
.head 4 +  If sCustBitmap = STRING_Null
.head 5 +  If NOT SalPicSetFile( picCustLogo, OurGetIniFileParameter( 'GENERAL', 'CustLogos', 'J:\\DATA\\LOGOS' ) || '\\' || 'fleming.pcx' )
.head 6 -  Call SalMessageBox('Unable to set Bitmap 1','Error', MB_Ok)
.head 6 -  Return FALSE
.head 4 +  Else 
.head 5 +  If NOT SalPicSetFile( picCustLogo, OurGetIniFileParameter( 'GENERAL', 'CustLogos', 'J:\\DATA\\LOGOS' ) || '\\' || sCustBitmap )
.head 6 -  Call SalMessageBox('Unable to set Bitmap 2','Error', MB_Ok)
.head 6 -  Return FALSE
.head 4 +  If Not SalPicGetString( picCustLogo, PIC_FormatBitmap,  sBitmap )
.head 5 -  Call SalMessageBox('Unable to get Bitmap 3','Error',MB_Ok)
.head 5 -  Return FALSE
.head 4 -  !
.head 4 +  If tblCustomerItems.colsBarCode = STRING_Null
.head 5 -  Set sItemNo = SalFmtFormatNumber( tblCustomerItems.colnStockItemNo, '00000' )
.head 5 -  Set sItemNo = '9317036' || sItemNo
.head 5 -  Set nItemNo = SalStrToNumber( sItemNo )
.head 4 +  Else 
.head 5 -  Set nItemNo = SalStrToNumber( tblCustomerItems.colsBarCode )
.head 3 +  On SAM_ReportFetchNext
.head 4 +  If nQuantityCount = 0 or nQuantityCount >= dfnBarcodes
.head 5 +  While SalTblFindNextRow( tblCustomerItems, nRow, ROW_Selected, 0 )
.head 6 -  Call SalTblFetchRow( tblCustomerItems, nRow )
.head 6 -  Set sFineline = SalNumberToStrX( tblCustomerItems.colnFinelineNo, 0 )
.head 6 -  Set nQuantityCount = 1
.head 6 -  Return TRUE
.head 5 -  Return FALSE
.head 4 +  Else 
.head 5 -  Set nQuantityCount = nQuantityCount + 1
.head 5 -  Return TRUE
.head 4 +  ! If nQuantityCount >= dfnBarcodes
.head 5 -  Return FALSE
.head 4 +  ! Else
.head 5 -  Set nQuantityCount = nQuantityCount + 1
.head 5 -  Return TRUE
.head 3 +  On SAM_ReportNotify
.head 4 +  If lParam = RPT_BeforeBreakHeader1
.head 5 +  If not SalReportSetObjectVar( SalNumberToWindowHandle( wParam ), 'Bitmap', sBitmap )
.head 6 -  Call SalMessageBox('Error setting bitmap.','Error', MB_Ok)
.head 3 +  On PAM_OUTPUTFINELINEDATA
.head 4 -  Call SalSendMsgToChildren( hWndForm, PAM_OUTPUTFINELINEDATA, wParam, lParam )

.head 5 +  ! On PAM_SETSGSQL
.head 6 -  Set sgSql = "
SELECT
	CUST.RowId,
	ST.Item_No,
	ST.Cult_Desc,
	T.Tree_Type_Desc,
	CUST.Fine_Line,
	CUST.RETAIL_PRICE,
	CUST.BARCODE
FROM
	Customer_Item CUST,
	Stock_Item ST,
	Tree_Type T
INTO
	:frmFinelineMaintenance.tblCustomerItems.colRowId,
	:frmFinelineMaintenance.tblCustomerItems.colnStockItemNo,
	:frmFinelineMaintenance.tblCustomerItems.colsItemDescription,
	:frmFinelineMaintenance.tblCustomerItems.colsTreeType,
	:frmFinelineMaintenance.tblCustomerItems.colnFinelineNo,
	:frmFinelineMaintenance.tblCustomerItems.colnRetailPrice,
	:frmFinelineMaintenance.tblCustomerItems.colsBarCode	
WHERE 
	CUST.Cust_No 		= :frmFinelineMaintenance.npCustomerNo
	AND	CUST.Stock_Item_No 	= ST.Item_No
	AND	ST.Tree_Type		= T.Tree_Type 
	AND	CUST.Supplier_Id 		= :frmFinelineMaintenance.sSupplierId
ORDER BY 
	ST.Variety_Type,
	ST.Variety,
	ST.Cult_Desc,
	ST.Tree_Type
"
.head 6 -  Return TRUE

.head 3 +  On PAM_SETINSTANCEVARS
.head 4 -  Set dfnCustomerNo = npCustomerNo
.head 4 +  If npAssCustomerNo > 0
.head 5 -  Set npCustomerNo = npAssCustomerNo
.head 4 -  Set dfsCustomerName = spCustomerName

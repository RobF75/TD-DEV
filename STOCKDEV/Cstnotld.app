.head 2 +  Application Actions
.head 3 +  On SAM_AppStartup
.head 4 -  ! ASSUMPTION FOR Command Line arguments
Argument 1 - SqlDatabase
Argument 2 - SqlUser
Argument 3 - SqlPassword
Argument 4 - File Name for list of selected item numbers
Argument 5 - Year ( number )
Argument 6 - Stock Type ( 'CONT' = Containers, 'BARE' = Bare root, 'BOTH' = Bare root and Containers )
Argument 7 - Action Type ( number ) = ( nAllRegions, nSelectionRegions )
.head 4 -  !
.head 4 +  If strArgArray[1] = STRING_Null
.head 5 -  Set SqlDatabase = 'STOCKDEV'
.head 5 -  Set SqlUser = 'GRAHAM'
.head 5 -  Set SqlPassword = 'GRAHAM'
.head 5 -  Set strArgArray[4] = 'c:\\temp\\regions.tmp'
.head 5 -  Set strArgArray[5] = '2003'
.head 5 -  Set strArgArray[6] = 'POTS'
.head 5 -  Set strArgArray[7] = '66'
.head 4 +  Else
.head 5 -  Set SqlDatabase = strArgArray[ 1 ]
.head 5 -  Set SqlUser = strArgArray[ 2 ]
.head 5 -  Set SqlPassword = strArgArray[ 3 ]
.head 4 -  !
.head 4 -  !
.head 4 -  Set bghSqlDetail = SqlConnect( hSqlDetail )
.head 4 +  If bghSqlDetail
.head 5 -  Call SqlSetIsolationLevel( hSqlDetail,'RL')
.head 5 -  Call SqlSetLockTimeout( hSqlDetail, SQLTIMEOUT )
.head 3 +  On SAM_AppExit
.head 4 +  If bghSqlDetail
.head 5 -  Call SqlDisconnect( hSqlDetail )

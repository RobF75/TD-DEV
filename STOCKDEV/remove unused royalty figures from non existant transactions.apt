.head 4 +  Actions
.head 5 -  Set sSqlGet = "Select 
		distinct inv_no
	into
		:sInvNo
	from
		royalties_paid"
	
.head 5 -  Call SqlConnect( hSqlGet )
.head 5 -  Set nCount = 0
.head 5 +  If SqlPrepareAndExecute( hSqlGet, sSqlGet  )
.head 6 +  While SqlFetchNext( hSqlGet, nInd )
.head 7 -  Set saInvNo[nCount] = sInvNo
.head 7 -  Set nCount = nCount + 1
.head 7 -  Set saInvNo[nCount] = STRING_Null
.head 6 +  If nInd = FETCH_EOF
.head 7 -  Call SqlDisconnect( hSqlGet )
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  Else

.head 3 +  Function: DeleteRoyalties
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Receive String: saInvNo[*]
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Sql Handle: hSqlGet
.head 5 -  String: sSqlGet
.head 5 -  String: sInvNo
.head 5 -  Number: nInd
.head 5 -  Number: nCount
.head 4 +  Actions
.head 5 -  Set sSqlGet = "
	Delete from
		royalties_paid
	Where
		Inv_no = :saInvNo[nCount]"
	
.head 5 -  Call SqlConnect( hSqlGet )
.head 5 -  Set nCount = 0
.head 5 +  While saInvNo[nCount] != STRING_Null
.head 6 +  If NOT SqlPrepareAndExecute( hSqlGet, sSqlGet  )
.head 7 -  Return FALSE
.head 6 +  Else
.head 7 -  Set nCount = nCount + 1
.head 5 -  Call SqlCommit( hSqlGet )
.head 5 -  Call SqlDisconnect( hSqlGet )
.head 5 -  Return TRUE
.head 3 +  Function: CheckForInvoices
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: saInvNo[*]
.head 5 -  Receive String: saBadInvNo[*]
.head 4 -  Static Variables

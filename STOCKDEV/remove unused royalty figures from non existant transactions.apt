.head 5 -  Number: nBadCount
.head 5 -  Number: nTotalCount
.head 5 -  File Handle: fhInvoice
.head 4 +  Actions
.head 5 -  Set sSqlTrans = "Select 
		Reference_Id
	into
		:sTransInvNo
	from
		Transaction
	where
		reference_id = :saInvNo[nCount]"
	
.head 5 -  Set sSqlHist = "Select 
		Hist_Reference_Id
	into
		:sHistInvNo
	from
		Trans_History
	where
		hist_reference_id = :saInvNo[nCount]"
	
.head 5 -  Call SqlConnect( hSqlTrans )
.head 5 -  Call SqlConnect( hSqlHist )
.head 5 -  Set nCount = 0
.head 5 -  Set nBadCount = 0
.head 5 -  Call SalFileOpen( fhInvoice, 'd:\\temp\\invoice.txt', OF_Create | OF_ReadWrite )
.head 5 +  While saInvNo[nCount] != STRING_Null
.head 6 +  If SqlPrepareAndExecute( hSqlHist, sSqlHist  )
.head 7 +  If NOT SqlFetchNext( hSqlHist, nInd )
.head 8 +  If SqlPrepareAndExecute( hSqlTrans, sSqlTrans  )
.head 9 +  If Not SqlFetchNext( hSqlTrans, nInd )
.head 10 -  Set saBadInvNo[nBadCount] = saInvNo[nCount]
.head 10 -  Call SalFilePutStr( fhInvoice, saInvNo[nCount] )
.head 10 -  Set nBadCount = nBadCount + 1
.head 10 -  Set saBadInvNo[nBadCount] = STRING_Null
.head 6 -  Set nCount = nCount + 1
.head 5 -  Call SalFileClose( fhInvoice )
.head 5 -  Call SqlDisconnect( hSqlHist )
.head 5 -  Call SqlDisconnect( hSqlTrans )
.head 5 -  Return TRUE

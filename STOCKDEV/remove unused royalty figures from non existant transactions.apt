.head 3 +  On SAM_Create
.head 4 +  If GetInvoiceNo(saInvoiceNo)
.head 5 +  If CheckForInvoices(saInvoiceNo, saInvalidInvoices)
.head 6 -  Call DeleteRoyalties(saInvalidInvoices)
.head 4 +  Else
.head 5 -  Call SalMessageBox('Error1','Msg', MB_Ok)

Cust_Order_History, Stock_Item '
.head 8 -  Set sROWID = ''
.head 8 -  Set sSQLWHERE = " WHERE Customer_Master.Customer_Type LIKE '%OR%' AND 
Customer_Master.Cust_No = Customer_Address.Cust_No AND
Customer_Address.Main_Address_Flag = 'Y' AND 
Customer_Master.Cust_No = Customer_Contacts.Cust_No AND 
Customer_Contacts.Main_Contact_Flag = 'Y' AND 
Customer_Master.Cust_No = Cust_Order_History.Cust_No AND 
Cust_Order_History.Year_Of_Sale = :frmPrintOutstandingPRCs.nYear AND 
Cust_Order_History.CONF_AMT > 0 AND 
(Cust_Order_History.PRC_Recd_Flag = 'N' or
 Cust_Order_History.PRC_Recd_Flag is NULL) AND 
Cust_Order_History.SALE_CAT NOT in ('RP', 'TT', 'FC', 'FR') AND
Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
Stock_Item.Prod_Royalty != 'A'  "
.head 8 -  Set sORDERBY = 'ORDER BY Customer_Master.Region_Id, Customer_Master.Cust_Name, Customer_Master.Cust_No'
.head 7 +  Else

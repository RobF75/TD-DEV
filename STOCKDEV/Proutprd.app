.head 2 +  Message Actions
.head 3 +  On PAM_SETINSTANCEVARS
.head 4 -  Set sDatabase = SqlDatabase
.head 3 +  On SAM_Create
.head 4 -  Set nYear = SalStrToNumber( strArgArray[ 5 ] )
.head 4 -  Set sActionType = strArgArray[ 6 ]
.head 4 -  Return SalSendClassMessage( SAM_Create, wParam, lParam )
.head 3 +  On SAM_CreateComplete
.head 4 -  Call SalHideWindow( hWndForm )
.head 4 -  !
.head 4 +  If sActionType = 'SELECTED_LOADS'
.head 5 +  If NOT ReadStrArrayListFromFile( strArgArray[ 4 ], saLoadIds )
.head 6 -  Call SalMessageBox( 'An error occurred! Cannot do this report now! Contact Programmers.', 'Error', MB_Ok )
.head 6 -  Call SalDestroyWindow( hWndForm )
.head 4 -  !
.head 4 -  Call SalSendMsg( hWndForm, PAM_PRINTPRCS, 0, 0 )
.head 4 -  Call SalWaitCursor( FALSE )
.head 3 +  On PAM_PRINTPRCS
.head 4 -  Call SalWaitCursor( TRUE )
.head 4 -  !
.head 4 -  Set sRepInto = 'Cust_No, Cust_Name, BusName, Region_Desc, Ship_Address_Line1, Ship_Address_Line2,
Suburb, State, Postcode, Contact_Wrk_Ph_Code, Contact_Wrk_Ph, Tree_Type_Desc, CultivarDesc, 
PRCSent, PRCSentDate, ConfAmt, Load_Description'
.head 4 -  !
.head 4 -  Set sRepBind = 'frmPrintOutstandingPRCs.tblCust.colCustNo, frmPrintOutstandingPRCs.tblCust.colCustName,
frmPrintOutstandingPRCs.tblCust.colBusName, frmPrintOutstandingPRCs.tblCust.colRegionDesc, 
frmPrintOutstandingPRCs.tblCust.colBusAddrL1, frmPrintOutstandingPRCs.tblCust.colBusAddrL2, 
frmPrintOutstandingPRCs.tblCust.colBusSuburb, frmPrintOutstandingPRCs.tblCust.colBusState, 
frmPrintOutstandingPRCs.tblCust.colBusPostcode, frmPrintOutstandingPRCs.tblCust.colContactWrkAreaCode,
frmPrintOutstandingPRCs.tblCust.colContactWrkPhone, frmPrintOutstandingPRCs.tblCust.colTreeTypeDesc, 
frmPrintOutstandingPRCs.tblCust.colCultDesc, 
frmPrintOutstandingPRCs.tblCust.colPRCSentFlag, frmPrintOutstandingPRCs.tblCust.colPRCSentDate, 
frmPrintOutstandingPRCs.tblCust.colConfAmt, frmPrintOutstandingPRCs.sLoadDescription'
.head 4 -  !
.head 4 -  Set sReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\PRCouts2.qrp'
.head 4 -  Set nError = 1
.head 4 -  Call SetPrinter( 'SmallFanFold' )
.head 4 -  Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, RPT_PrintAll,0,0, nError )
.head 3 +  On SAM_ReportStart
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchInit
.head 4 -  Set bProcessLoads = TRUE
.head 4 -  Set bProcessCust = FALSE
.head 4 -  !
.head 4 -  Set bPopulateTblCust = FALSE
.head 4 -  !
.head 4 -  Set nLoadIdsPos = 0
.head 4 -  Set nCustRow = TBL_MinRow
.head 4 -  !
.head 4 -  Set bFinishedWithCust = FALSE
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchNext
.head 4 +  Loop
.head 5 +  If bProcessLoads
.head 6 +  If sActionType = 'SELECTED_LOADS'
.head 7 -  Set sLoadId = saLoadIds[ nLoadIdsPos ]
.head 7 +  If sLoadId = ''
.head 8 -  Return FALSE
.head 7 +  Else
.head 8 -  Set bProcessLoads = FALSE
.head 8 -  Set bProcessCust = TRUE
.head 8 -  Set bPopulateTblCust = TRUE
.head 8 -  Set nLoadIdsPos = nLoadIdsPos + 1
.head 8 -  !
.head 8 -  Call GetLoadDesc( sLoadId, sLoadDescription, SH_cls_Execute )
.head 6 +  Else
.head 7 -  ! else assumes nAllCustomers
.head 7 +  If bFinishedWithCust
.head 8 -  Return FALSE
.head 7 +  Else
.head 8 -  Set bProcessLoads = FALSE
.head 8 -  Set bProcessCust = TRUE
.head 8 -  Set bPopulateTblCust = TRUE
.head 5 +  If bProcessCust
.head 6 +  If bPopulateTblCust
.head 7 -  Call SalSendMsg( tblCust, PAM_POPULATE, 0, 0 )
.head 7 -  Set bPopulateTblCust = FALSE
.head 6 -  !
.head 6 +  If SalTblFindNextRow( tblCust, nCustRow, 0, 0 )
.head 7 -  Call SalTblFetchRow( tblCust, nCustRow )
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Set bProcessCust = FALSE
.head 7 -  Set bProcessLoads = TRUE
.head 7 -  Set bFinishedWithCust = TRUE
.head 3 +  On SAM_ReportFinish
.head 4 -  Call SetDefaultPrinter(  )
.head 4 -  Call GetLoadDesc( '', sLoadDescription, SH_cls_Disconnect )
.head 4 -  Call SalDestroyWindow( hWndForm )
.head 4 -  Call SalWaitCursor( FALSE )
.head 4 -  Return TRUE

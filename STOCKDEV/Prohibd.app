ROW_MarkDeleted )
.head 6 -  Call SalSendMsg( hWndForm.colYearProhib, PAM_ALLOWENTRY, FALSE, 0 )
.head 6 +  If bOk 
.head 7 -  Call SqlImmediate( 'commit' )
.head 7 -  Call SqlClearImmediate(  )
.head 7 -  Call SalSendMsg( hWndForm, PAM_POPULATE, 0, 0 ) 
.head 7 -  Call SalMessageBox( 'Row(s) deleted.', 'Cultivar / Rootstock Prohibitions',
MB_Ok|MB_IconAsterisk )
.head 7 -  Return TRUE
.head 5 +  On PAM_NOROWS

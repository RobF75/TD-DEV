.head 2 +  Named Menus
.head 2 +  Internal Functions
.head 3 +  Function: LoseProhibEdit
.head 4 -  Description: Ask the user if they want their changes saved prior to doing other
functions
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If IDYES = SalMessageBox( 'Your current changes have not been saved.
Would you like them saved to the database?', 'Cultivar / Rootstock Prohibitions',
MB_IconAsterisk|MB_YesNo  )
.head 6 +  If bgNew
.head 7 -  Call AddProhib(  )
.head 6 +  Else
.head 7 -  Call SaveProhib(  )
.head 3 +  Function: DetProhib
.head 4 -  Description: Fetch the selected prohibition and display
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Set bgNew = FALSE
.head 5 -  ! set an sqlStatement
.head 5 -  Call CallBuildSql( hWndForm,nSELECT, PAM_SQL, PROHIBCULT, PROHIBDATETIMECULT )
.head 5 +  If SqlOK( frmProhibDet.hLocalSqlA,sgSql )
.head 6 +  If SqlFetchNext( frmProhibDet.hLocalSqlA,ngFetch )
.head 7 -  Set bgNew = FALSE
.head 7 -  Set bgEdit = FALSE
.head 7 -  Call SalSendMsgToChildren( hWndForm,PAM_DISPREC,0,0 )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Record Not Found','No Record', MB_Ok )
.head 7 -  Return FALSE
.head 3 +  Function: ClearProhib
.head 4 -  Description: Clear the screen and reset field defaults
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Call InitTopLevelWindow( hWndForm )
.head 5 -  Call SalSetFocus( hWndForm.dfYear )
.head 5 -  Set bgNew = TRUE
.head 5 -  Call SalSendMsgToChildren( hWndForm,PAM_NEWREC,0,0 )
.head 5 -  Set bgEdit = FALSE
.head 5 -  Call SalSendMsgToChildren( hWndForm, PAM_INITIALIZE, 0, 0 )
.head 3 +  Function: PrevProhib
.head 4 -  Description: To get the previous prohibition to display from the table selections
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Set ngRow = SalTblQueryContext( frmProhib.tblProhib )
.head 5 +  If SalTblFindPrevRow( frmProhib.tblProhib, ngRow, ROW_Selected, 0 )
.head 6 -  Call SalTblFetchRow( frmProhib.tblProhib, ngRow )
.head 6 -  Call PushDateTime( frmProhib.tblProhib.colDateTime )
.head 6 -  Call PushNumber( PAM_DETREC )
.head 6 -  Call SalSendMsg( frmProhibDet, PAM_CREATECOMPLETE,0,0 )
.head 5 +  Else
.head 6 -  Call SalMessageBox( 'No previous selected records to display', 'Cultivar / Rootstock Prohibitions', MB_Ok )
.head 3 +  Function: NextProhib
.head 4 -  Description: To get the next prohibition to display from the table selections
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Set ngRow = SalTblQueryContext( frmProhib.tblProhib )
.head 5 +  If SalTblFindNextRow( frmProhib.tblProhib, ngRow, ROW_Selected, 0 )
.head 6 -  Call SalTblFetchRow( frmProhib.tblProhib, ngRow )
.head 6 -  Call PushDateTime( frmProhib.tblProhib.colDateTime )
.head 6 -  Call PushNumber( PAM_DETREC )
.head 6 -  Call SalSendMsg( frmProhibDet, PAM_CREATECOMPLETE,0,0 )
.head 5 +  Else
.head 6 -  Call SalMessageBox( 'No next selected records to display', 'Cultivar / Rootstock Prohibitions', MB_Ok )
.head 3 +  Function: DisplayProhib
.head 4 -  Description: To display a form window to the users of the prohibition selected
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Call PushDateTime( frmProhib.tblProhib.colDateTime )
.head 5 -  Call PushWndHdl( frmProhib.pbDetails )
.head 5 -  Call PushWndHdl( frmProhib.tblProhib )
.head 5 -  Call PushNumber( PAM_DETREC )
.head 5 -  Set hWndProhibDet = SalCreateWindow( frmProhibDet, hWndForm )

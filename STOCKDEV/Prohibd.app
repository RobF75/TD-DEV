.head 3 +  Function: DelProhib
.head 4 -  Description: Delete the selected record from Prohibition
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If SalMessageBox( 'Are you sure?','Delete',MB_YesNo ) = IDYES
.head 6 -  Set sgSql = 'DELETE FROM PROHIBITION
 WHERE PROHIB_DATE_TIME =:hWndForm.dfDateTime'
.head 6 +  If SqlOK( frmProhibDet.hLocalSqlA,sgSql )
.head 7 -  Call SqlCommit( frmProhibDet.hLocalSqlA )
.head 7 -  Call ClearProhib ( )
.head 7 -  Call SalMessageBox( 'Record Deleted Successfully','Delete OK', MB_Ok )
.head 6 +  Else
.head 7 -  Call SalMessageBox ('Record Deletion Unsuccessful','Deletion Error', MB_RetryCancel )
.head 3 +  Function: SaveProhib
.head 4 -  Description: Save the changes done to a royalty owner
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If NOT bgEdit
.head 6 -  Call SalMessageBox( 'Nothing has been modified','Cultivar / Rootstock Prohibitions Details',MB_Ok )
.head 6 -  Return TRUE
.head 5 -  Set bgEdit = FALSE
.head 5 -  Set hWndChild = SalGetFirstChild( hWndForm, TYPE_DataField )
.head 5 +  While NOT hWndChild = hWndNULL 
.head 6 +  If NOT SalSendMsg( hWndChild, PAM_DATAVAL, 0, 0 )
.head 7 -  Return FALSE
.head 6 -  Set hWndChild = SalGetNextChild( hWndChild, TYPE_DataField )
.head 5 -  Call CallBuildSql( hWndForm,nUPDATE, PAM_INSERTUPDATE, PROHIB, PROHIBDATETIME )
.head 5 +  If SqlOK( frmProhibDet.hLocalSqlB,sgSql )
.head 6 -  Call SqlCommit( frmProhibDet.hLocalSqlB )
.head 6 -  ! On modification of an order we wish to redisplay it
.head 6 -  ! Call SalMessageBox( 'Record Modified Successfully','Save OK', MB_Ok )
.head 6 -  Call DetProhib (  )
.head 5 +  Else
.head 6 -  Call SalMessageBox ('Record Modification Unsuccessful','Save Error',
 MB_RetryCancel )
.head 6 -  ! Need to reset fields and allow
.head 6 -  Return FALSE
.head 3 +  Function: AddProhib
.head 4 -  Description: To add a record into table Prohibition
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Set hWndChild = SalGetFirstChild( hWndForm, TYPE_DataField )
.head 5 +  While NOT hWndChild = hWndNULL 
.head 6 +  If NOT SalSendMsg( hWndChild, PAM_DATAVAL, 0, 0 )
.head 7 -  Return FALSE
.head 6 -  Set hWndChild = SalGetNextChild( hWndChild, TYPE_DataField )
.head 5 -  Set bgEdit = FALSE
.head 5 -  Set sgSql = 'SELECT PROHIB_DATE_TIME FROM PROHIBITION
 WHERE PROHIB_DATE_TIME = :hWndForm.dfDateTime'
.head 5 +  If NOT RowIdExists( sgSql )
.head 6 -  Call CallBuildSql( hWndForm,nINSERT, PAM_INSERTUPDATE, PROHIB, '' )
.head 6 +  If SqlOK( frmProhibDet.hLocalSqlA,sgSql )
.head 7 -  Call SqlCommit( frmProhibDet.hLocalSqlA )
.head 7 -  ! On addition of a customer we wish to clear the screen and reset it 
.head 7 -  ! Call SalMessageBox( 'Record Added Successfully','Add OK', MB_Ok )
.head 7 -  Call ClearProhib (  )
.head 6 +  Else
.head 7 -  Call SalMessageBox ('Record Addition Unsuccessful','Add Error', MB_RetryCancel )
.head 7 -  ! Need to reset fields and allow
.head 7 -  Return FALSE
.head 5 +  Else
.head 6 -  Call SalMessageBox( 'Record Already Exists','Duplicate',MB_Ok )
.head 6 -  Call SalSetFocus( hWndForm.dfYear )
.head 6 -  Return FALSE

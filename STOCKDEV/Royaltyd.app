 WHERE ROYALTY_OWNER_ID = :dfOwnerId'
.head 7 +  If SqlExists( sSql, bExists )
.head 8 +  If bExists
.head 9 -  Call SalMessageBox( 'Owner Id Already Exists.','Record Exists',MB_Ok )
.head 9 -  Call SalSetFocus( hWndForm.dfOwnerId )
.head 9 -  Return FALSE
.head 6 -  Return TRUE

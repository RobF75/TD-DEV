.head 2 +  Application Actions
.head 3 +  On SAM_AppStartup
.head 4 -  ! 27/2/95 myfunc.apl has had its report print windows and some other windows
  removed into seperate APLs
.head 4 -  ! DO NOT PUT INTO LIVE UNTIL DENORMALIZATION.
.head 4 +  If SalStrRightX(strArgArray[0], 3) = 'EXE'
.head 5 -  Set SqlDatabase = strArgArray[1]
.head 5 -  Set SqlUser = strArgArray[2]
.head 5 -  Set SqlPassword = strArgArray[3]
.head 4 +  Else
.head 5 -  Set SqlDatabase = 'STOCKDEV'
.head 5 -  Set SqlUser = 'GRAHAM'
.head 5 -  Set SqlPassword = 'GRAHAM'
.head 4 -  !
.head 4 -  ! WHEN MAKING THEN EXECUTABLE INTO STOCK CHANGE THE NAME TO ROYALTY.EXE
.head 4 -  !

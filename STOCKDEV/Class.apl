.head 4 +  Message Actions 
.head 5 +  On SAM_Create
.head 6 +  If SalIsWindowEnabled( hWndItem )
.head 7 -  Set bAllowEntry = TRUE
.head 6 +  Else 
.head 7 -  Set bAllowEntry = FALSE
.head 6 -  Call SalSendMsg( hWndItem, PAM_SETINSTANCEVARS, 0, 0 )
.head 5 +  On PAM_DATAVAL
.head 6 -  Return TRUE
.head 5 +  On PAM_NEWREC
.head 6 +  If nAppearanceOnNewRec = nHide
.head 7 -  Call SalSendMsg( hWndItem, PAM_HIDE,0,0 )
.head 6 +  Else If nAppearanceOnNewRec = nShow
.head 7 -  Call SalSendMsg( hWndItem, PAM_SHOW,0,0 )
.head 6 +  Else If nAppearanceOnNewRec = nEnable
.head 7 -  Call SalSendMsg( hWndItem, PAM_ENABLE,0,0 )
.head 6 +  Else If nAppearanceOnNewRec = nDisable
.head 7 -  Call SalSendMsg( hWndItem, PAM_DISABLE,0,0 )
.head 5 +  On PAM_DISPREC
.head 6 +  If nAppearanceOnDisplayRec = nHide
.head 7 -  Call SalSendMsg( hWndItem, PAM_HIDE,0,0 )
.head 6 +  Else If nAppearanceOnDisplayRec = nShow
.head 7 -  Call SalSendMsg( hWndItem, PAM_SHOW,0,0 )
.head 6 +  Else If nAppearanceOnDisplayRec = nEnable
.head 7 -  Call SalSendMsg( hWndItem, PAM_ENABLE,0,0 )
.head 6 +  Else If nAppearanceOnDisplayRec = nDisable
.head 7 -  Call SalSendMsg( hWndItem, PAM_DISABLE,0,0 )
.head 5 +  On PAM_ENABLE
.head 6 -  Call SalEnableWindow( hWndItem )
.head 5 +  On PAM_DISABLE
.head 6 -  Call SalDisableWindow( hWndItem )
.head 5 +  On PAM_HIDE
.head 6 -  Call SalHideWindow( hWndItem )
.head 5 +  On PAM_SHOW
.head 6 -  Call SalShowWindow( hWndItem )
.head 5 +  On PAM_ALLOWENTRY
.head 6 +  If bAllowEntry
.head 7 +  If wParam
.head 8 -  Call SalEnableWindow( hWndItem )
.head 7 +  Else 
.head 8 -  Call SalDisableWindow( hWndItem )
.head 5 +  On PAM_INITIALIZE
.head 6 +  If bInitialiseOnClear
.head 7 -  Call SalClearField( hWndItem )
.head 6 -  Return TRUE

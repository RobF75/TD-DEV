.head 5 +  On PAM_CREATECOMPLETE
.head 6 +  If nOnCreateAction = PAM_ADDREC
.head 7 -  ! TS 9/5/95 Clearing too much
Call DetailsFrmClear( hWndForm, hWndFocusFieldOnClear, bNew, bEdit )
.head 7 -  Call SalSendMsg( pbClear, PAM_CLICK, 0, 0 )
.head 6 +  Else If nOnCreateAction = PAM_DETREC OR wParam = nPrevious OR wParam = nNext
.head 7 -  Call SalWaitCursor( TRUE )

:dlgPriceFile.sTreeTypeDesc, :dlgPriceFile.sRootId, :dlgPriceFile.nBasePrice,
 :dlgPriceFile.sGeneric, :dlgPriceFile.sVarType, :dlgPriceFile.sVariety, :dlgPriceFile.sCultDesc,

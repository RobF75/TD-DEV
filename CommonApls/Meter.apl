.head 3 +  On PAM_clsMTR_SETPROGRESS
.head 4 +  If nWholeProgress = 0
.head 5 -  Set nWholeProgress = 1
.head 4 -  Call ccMeterBar.SetProgress( ( lParam / nWholeProgress) * 100 )
.head 4 -  Return TRUE
.head 3 +  On PAM_clsMTR_RESET
.head 4 -  Call PopString( sHeading, FALSE )
.head 4 -  Call SalSetWindowText( hWndForm, sHeading )
.head 4 -  Set nWholeProgress = lParam
.head 4 -  Call SalSendMsg( hWndForm, PAM_clsMTR_SETPROGRESS, 0, 0 )
.head 4 -  Return TRUE

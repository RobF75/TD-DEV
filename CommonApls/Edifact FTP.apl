.head 2 +  Functions
.head 3 +  Function: fnSortFiles
.head 4 -  Description: Sorts any files within a specified directory into an array
and then locates and returns the file name of first one by date/time order.
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: sDirectory						! Directory of files to process
.head 5 -  Boolean: bProcessRemoteFiles				! Files to process are on a remote FTP site
.head 5 -  Receive String: sFileName					! Returned file name to action
.head 5 -  Receive String: saFileNames[*]				! Return Array of File Names
.head 5 -  Receive Number: nCount					! Count of items in array
.head 5 -  Receive Boolean: bFoundMsg				! Returned flag to signify files to action
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  ! String: saFileNames[*]					! Array of File Names
.head 5 -  Number: naAttributes[*]					! Array of File Attributes
.head 5 -  Date/Time: dtaCreation[*]					! Array of File Creation dates
.head 5 -  Date/Time: dtaAccess[*]					! Array of File Last Accessed dates
.head 5 -  Date/Time: dtaWrite[*]					! Array of File Last Written dates
.head 5 -  Number: naFileSizes[*]					! Array of File Sizes
.head 5 -  Date/Time: dtaDateCopy[*]					! Working copy of Creation Date array
.head 5 -  ! Number: nCount						! Count of items in array
.head 5 -  Number: nArrayOffset					! Offset to desired array slot
.head 4 +  Actions
.head 5 -  Call SalWaitCursor( TRUE )
.head 5 -  Set bFoundMsg = FALSE					! Initialise successful processing flag
.head 5 -  Set sDirectory = sDirectory || '*.gz'				! Searching for all file types
.head 5 -  Set sFileName = STRING_Null				! Initialise return string
.head 5 -  Set nCount = 0						! Initialise item counter
.head 5 -  !
.head 5 +  If bProcessRemoteFiles = TRUE
.head 6 -  Set nCount = FTPAction.EnumFilesInfo( sDirectory, saFileNames, naAttributes, dtaWrite, dtaAccess, dtaCreation, naFileSizes )
.head 5 +  Else
.head 6 -  Set nCount = VisDosEnumFileInfo( sDirectory, FA_Standard, saFileNames, naFileSizes, dtaCreation, naAttributes )
.head 5 -  !
.head 5 +  If nCount > 0						! If any files were found in the specified directory...
.head 6 +  If bDebugMode = TRUE		! debugging mode
.head 7 -  Call SalMessageBox( 'Found ' || SalNumberToStrX( nCount, 0 ) || ' file(s) to process in the repository located at '|| sDirectory, 'FTP Processing', MB_IconAsterisk | MB_Ok )
.head 6 -  Call VisArrayCopy( dtaCreation, dtaDateCopy, DT_DateTime )		! Make a copy of the date time array for sorting
.head 6 -  Call VisArraySort( dtaDateCopy, SORT_Ascending, DT_DateTime )		! Sort the date/time array into ascending order
.head 6 -  Set nArrayOffset = VisArrayFindDateTime( dtaCreation, dtaDateCopy[0] )	! Find the first date/time value in the original array
.head 6 -  Set sFileName = saFileNames[nArrayOffset]				! Using the offset value obtained, get the matching file name to process
.head 6 -  Set bFoundMsg = TRUE					! Set ON successful processing flag
.head 5 -  !
.head 5 -  Call SalWaitCursor( FALSE )
.head 5 -  Return bFoundMsg
.head 2 +  Window Parameters
.head 3 -  String: sServer
.head 3 -  String: sUsername
.head 3 -  String: sPassword
.head 3 -  Number: nPort
.head 3 -  String: sPartnerIdentifier
.head 3 -  String: sRemoteInbox
.head 3 -  String: sRemoteOutbox
.head 3 -  String: sRemoteSentItems
.head 3 -  String: sLocalInbox
.head 3 -  String: sLocalOutbox
.head 3 -  String: sLocalSentItems
.head 3 -  Receive Number: nErrorCode
.head 3 -  Receive Boolean: bFilesDownloaded
.head 3 -  Receive Boolean: bFilesUploaded
.head 3 -  Boolean: bBunnings
.head 3 -  Boolean: bDebugMode
.head 2 +  Window Variables
.head 3 -  Number: nReturn
.head 3 -  String: sFileName
.head 3 -  String: saFileNames[*]
.head 3 -  Number: nFileCount
.head 3 -  Boolean: bFileFound
.head 3 -  File Handle: hRemoteFile
.head 3 -  File Handle: hLocalFile
.head 3 -  Boolean: bRemoteSite
.head 3 -  Boolean: bCopiedOk
.head 3 -  String: sRemoteFileName
.head 3 -  Number: nArrayCount
.head 3 -  Number: nProcessed
.head 2 +  Message Actions
.head 3 +  On SAM_CreateComplete
.head 4 -  !
.head 4 -  ! Set bDebugMode = FALSE						! Set this switch to TRUE to set FTP debug messages on
.head 4 -  !
.head 4 -  Call SalWaitCursor( TRUE )
.head 4 -  !
.head 4 -  ! +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
.head 4 -  ! +++       First we connect to the remote FTP host using the settings passed to us      +++
.head 4 -  ! +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
.head 4 -  !
.head 4 -  Call SalCreateWindow( fwSysTray, hWndForm, FTP_CONNECT )				! Run System tray Icon routine
.head 4 -  Set nReturn = FTPAction.Connect( sServer, nPort, sUsername, sPassword )			! Connect to FTP server
.head 4 -  Call SalDestroyWindow( fwSysTray )							! Kill system tray Icon routine
.head 4 -  !
.head 4 +  If nReturn = 0									! If connection was successful
.head 5 -  !
.head 5 -  ! +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
.head 5 -  ! +++   Now we download any files supplied by this partner from their remote FTP site  +++
.head 5 -  ! +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
.head 5 -  !
.head 5 -  Set bRemoteSite = TRUE								! Set on Remote site flag
.head 5 -  !
.head 5 -  Call SalCreateWindow( fwSysTray, hWndForm, FTP_DOWNLOAD )				! Run System tray Icon routine
.head 5 -  !
.head 5 -  Call FTPAction.FindFirstFile( sRemoteOutbox, sFileName )					! Look for files in the remote location
.head 5 -  !
.head 5 +  While sFileName != STRING_Null							! Whilst files exist in the remote directory...
.head 6 -  !
.head 6 +  If bBunnings = TRUE								! Processing Bunnings FTP site?
.head 7 +  If SalStrRightX( SalStrUpperX( sFileName ), 3 ) = '.GZ'					! If it has a GZIP extension... 
.head 8 -  Set nReturn = FTPAction.RenameFile( sRemoteOutbox || sFileName, sRemoteSentItems || sFileName )	! Move file to temporary storage location 
.head 8 -  !
.head 8 +  If nReturn = 0									! If the move worked ok...
.head 9 -  Set nReturn = FTPAction.GetFile( sRemoteSentItems || sFileName, sLocalInbox || sFileName, OF_Binary, 0 )	! Copy remote Sent Items file to local directory
.head 9 -  !
.head 9 +  If nReturn = 0									! If the copy worked ok..
.head 10 +  If SalStrRightX( SalStrUpperX( sFileName ), 9 ) = 'CONTRL.GZ'				! If current file is a CONTRL msg
.head 11 -  Set sRemoteFileName = SalStrLeftX( sFileName, SalStrLength( sFileName ) - 3 ) || '.done.gz'		! Alter Control file name
.head 11 -  Call FTPAction.RenameFile( sRemoteSentItems || sFileName, sRemoteSentItems || sRemoteFileName )	! Rename remote Control file to DONE (as per Bunnings FTP spec)
.head 10 -  Set bFilesDownloaded = TRUE							! Flag FTP download done
.head 10 -  Call fnLogFileTransfer( sPartnerIdentifier, sFileName, bRemoteSite )					! Log the file transfer 
.head 6 +  Else
.head 7 -  !
.head 7 -  Set nReturn = FTPAction.GetFile( sRemoteOutbox || sFileName, sLocalInbox || sFileName, OF_Binary, 0 )	! Copy remote Outbox file to local directory
.head 7 +  If nReturn = 0									! If the copy succeeded
.head 8 -  Set nReturn = FTPAction.DeleteFile( sRemoteOutbox || sFileName )				! Delete remote file
.head 8 -  Set bFilesDownloaded = TRUE							! Flag FTP download done
.head 8 -  Call fnLogFileTransfer( sPartnerIdentifier, sFileName, bRemoteSite )					! Log the file transfer 
.head 6 -  !
.head 6 +  If nReturn != 0									! If the download worked ok..
.head 7 -  Set nErrorCode = 2									! File download error
.head 7 -  !
.head 7 +  If bDebugMode = TRUE								! If in Debug mode...
.head 8 -  Call SalMessageBox( 'Unable to DOWNLOAD file '|| sFileName ||' from FTP server', 'Receive Error', MB_Ok | MB_IconHand )	! Display error msg
.head 6 -  !
.head 6 -  Set sFileName = STRING_Null							! Clear out file name area
.head 6 -  !
.head 6 -  Call FTPAction.FindNextFile( sFileName )						! Look for further files in the remote location
.head 5 -  !
.head 5 -  Call SalDestroyWindow( fwSysTray )							! Kill system tray Icon routine
.head 5 -  !
.head 5 -  ! +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
.head 5 -  ! +++  Then we upload any files that we have created for this partner to their remote FTP site +++
.head 5 -  ! +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
.head 5 -  !
.head 5 -  Call SalCreateWindow( fwSysTray, hWndForm, FTP_UPLOAD )				! Run System tray Icon routine
.head 5 -  !
.head 5 -  Set bRemoteSite = FALSE								! Set off Remote site flag
.head 5 -  !
.head 5 -  Set nArrayCount = VisDosEnumFiles( sLocalOutbox || '*.*', FA_Standard, saFileNames )		! Get count of outbound files
.head 5 -  !
.head 5 -  Set nProcessed = 0									! Initialise processed file count
.head 5 +  While nArrayCount > nProcessed							! If files exist to be processed...
.head 6 -  Set sFileName = saFileNames[ nProcessed ]						! Get next file to process
.head 6 -  Set nProcessed = nProcessed + 1							! Increment file processed count
.head 6 -  !
.head 6 +  If SalStrRightX( SalStrUpperX( sFileName ), 3 ) = '.GZ'					! If processing a Gzipped file ( i.e. Bunnings )
.head 7 -  Set sRemoteFileName = SalStrLeftX( sFileName, SalStrLength( sFileName ) - 3 )			! Save truncated filename for re-naming at remote end
.head 6 +  Else
.head 7 -  Set sRemoteFileName = sFileName							! Save normal filename for re-naming at remote end
.head 6 -  !
.head 6 +  If fnCopyFile( sLocalOutbox, sLocalSentItems, sFileName, TRUE )				! Copy to Local 'Sent Items' folder
.head 7 -  Set nReturn = FTPAction.PutFile( sLocalSentItems || sFileName, sRemoteInbox || sRemoteFileName, OF_Binary, 0 )	! Copy up to remote FTP server
.head 7 -  !
.head 7 +  If nReturn = 0									! If the copy worked ok..
.head 8 -  Set nReturn = FTPAction.RenameFile( sRemoteInbox || sRemoteFileName, sRemoteInbox || sFileName )	! Restore the file extension if req'd
.head 8 -  !
.head 8 +  If nReturn = 0									! If the rename worked...
.head 9 -  Set bFilesUploaded = TRUE								! Flag FTP upload done
.head 9 -  !
.head 9 -  Call fnLogFileTransfer( sPartnerIdentifier, sFileName, bRemoteSite )				! Log the file transfer 
.head 9 -  !
.head 8 +  Else
.head 9 -  Set nErrorCode = 4									! File upload error
.head 9 +  If bDebugMode = TRUE								! If in Debug mode...
.head 10 -  Call SalMessageBox( 'Unable to rename file '|| sFileName ||' on remote FTP server', 'Transmit Error', MB_Ok | MB_IconHand )	! Display error msg
.head 7 +  Else
.head 8 -  Set nErrorCode = 4									! File upload error
.head 8 +  If bDebugMode = TRUE								! If in Debug mode...
.head 9 -  Call SalMessageBox( 'Unable to UPLOAD file '|| sFileName ||' to FTP server', 'Transmit Error', MB_Ok | MB_IconHand )	! Display error msg
.head 6 -  !
.head 6 -  Set sFileName = STRING_Null							! Clear out file name area
.head 5 -  !
.head 5 -  Call SalDestroyWindow( fwSysTray )							! Kill system tray Icon routine
.head 5 -  !
.head 5 -  ! +++++++++++++++++++++++++++++++++++++++++++
.head 5 -  ! +++   Finally we disconnect from the remote FTP host  +++
.head 5 -  ! +++++++++++++++++++++++++++++++++++++++++++
.head 5 -  !
.head 5 +  If FTPAction.Disconnect() != 0							! Disconnect from FTP server
.head 6 -  Set nErrorCode = 6								! FTP disconnection error
.head 6 +  If bDebugMode = TRUE
.head 7 -  Call SalMessageBox( 'Unable to DISCONNECT from FTP server', 'Connection Error', MB_Ok | MB_IconHand )
.head 5 -  !
.head 4 +  Else
.head 5 -  Set nErrorCode = 1									! FTP Connection error
.head 5 +  If bDebugMode = TRUE								! If in Debug mode...
.head 6 -  Call SalMessageBox( 'Unable to CONNECT to FTP server', 'Connection Error', MB_Ok | MB_IconHand )	! Display error msg 
.head 4 -  !
.head 4 -  Call SalWaitCursor( FALSE )							! Set off wait cursor
.head 4 -  Call SalEndDialog( hWndForm, 0 )

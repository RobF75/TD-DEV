.head 3 -  String: sFileName
.head 2 +  Internal Functions
.head 3 +  Function: fnCopyFile
.head 4 -  Description: Copies a selected file to a specified location and optionally deletes the original
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: sSourcePath
.head 5 -  String: sDestPath								! Where to copy file to
.head 5 -  String: sFileName
.head 5 -  Boolean: bDeleteOriginal
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nCopyResult							! Result of copy process
.head 5 -  Boolean: bDirCreated							! Directory creation flag
.head 5 -  String: sReason								! Error reason
.head 5 -  File Handle: fhTempFile							! Temporary file handle for deleting source file
.head 5 -  Boolean: bCopied
.head 4 +  Actions
.head 5 -  Set bCopied = FALSE							! Initialise copy success flag
.head 5 -  Set bDirCreated = SalFileCreateDirectory( sDestPath )				! Create destination path
.head 5 -  Set sSourcePath = sSourcePath||'\\'||sFileName					! Fully qualified file name
.head 5 -  Set sDestPath = sDestPath||'\\'||sFileName					! Fully qualified file name
.head 5 -  Set nCopyResult = SalFileCopy( sSourcePath, sDestPath, TRUE )			! Copy file and overwrite if required
.head 5 +  Select Case nCopyResult							! Select process result
.head 6 +  Case FILE_CopyOK
.head 7 +  If bDeleteOriginal = TRUE							! Do we wish to delete the source file too
.head 8 +  If SalFileOpen( fhTempFile, sSourcePath, OF_Delete ) = TRUE			! Delete original file
.head 9 -  Set bCopied = TRUE							! Set ON successful processing flag
.head 8 +  Else
.head 9 -  Set sReason =  'Unable to delete source file'					! Delete failed
.head 7 +  Else
.head 8 -  Set bCopied = TRUE							! Set ON successful processing flag
.head 7 -  Break
.head 6 +  Case FILE_CopySrc
.head 7 -  Set sReason =  'Unable to open source file'
.head 7 -  Break
.head 6 +  Case FILE_CopyDest
.head 7 -  Set sReason = 'Unable to open destination file'
.head 7 -  Break
.head 6 +  Case FILE_CopyExist
.head 7 -  Set sReason = 'This file already exists'
.head 7 -  Break
.head 6 +  Case FILE_CopyRead
.head 7 -  Set sReason = 'Read failed during copy'
.head 7 -  Break
.head 6 +  Case FILE_CopyWrite
.head 7 -  Set sReason = 'Write failed during copy'
.head 7 -  Break
.head 6 +  Default
.head 7 -  Set sReason = 'Unknown Error'
.head 7 -  Break
.head 5 -  Return bCopied
.head 3 +  Function: fnCompressFile
.head 4 -  Description: Uses GZIP to compress or uncompress a passed file. The original file is automatically removed.
- If the input file is a Gzipped file (i.e file name ends in '.gz') then it is automatically uncompressed
and the file name truncated to remove the Gzip extension for returning to the caller.
- If the file is NOT denoted with a '.gz' extension, it is assumed to be requiring compression,
and the Gzip extension is suffixed to the original file name for returning to the caller.

.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: sFilePath				! Location of file to action
.head 5 -  Receive String: sZipFileName		! Name of Pre and Post compression file
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sAppName				! Gzip application location
.head 5 -  String: sAttributes				! Attributes applicable to current compression action 
.head 5 -  Number: nRet				! Application call return code
.head 5 -  File Handle: hZipFile			! handle for file existence test
.head 5 -  Boolean: bCompressed			! Flag to signify conpress or uncompress action
.head 5 -  Boolean: bFileActioned			! Return status flag
.head 4 +  Actions
.head 5 -  Set bFileActioned = FALSE				! Initialise function success status
.head 5 -  Set sAppName = 'c:\\program files\\gzip\\gzip.exe'	! Application location path
.head 5 -  !
.head 5 +  If SalStrRightX( SalStrUpperX( sFilePath || sZipFileName ), 3 ) = '.GZ'	! If file is already compressed
.head 6 -  Set sAttributes = '-d -f -q'				! Set up uncompression attributes
.head 6 -  Set bCompressed = FALSE				! Flag action as an uncompress
.head 5 +  Else
.head 6 -  Set sAttributes = '-f -q'				! Set up compression attributes
.head 6 -  Set bCompressed = TRUE				! Flag action as a compress
.head 5 -  !
.head 5 +  If SalFileOpen( hZipFile, sFilePath || sZipFileName, OF_Exist )	! Check for file existence
.head 6 -  Set bFileActioned = SalLoadAppAndWait( sAppName ||' '|| sFilePath || sZipFileName ||' '|| sAttributes, Window_NotVisible, nRet )	! Run GZIP
.head 6 -  !
.head 6 +  If bFileActioned = TRUE				! If the GZIP application ran ok
.head 7 +  If bCompressed = TRUE				! If this was a compression action
.head 8 -  Set sZipFileName = sZipFileName ||'.gz'			! Add on the compressed file extension suffix
.head 7 +  Else
.head 8 -  Set sZipFileName = SalStrLeftX( sZipFileName, SalStrLength( sZipFileName ) - 3 )	! Remove the compressed file extension
.head 6 -  !
.head 6 +  If NOT SalFileOpen( hZipFile, sFilePath || sZipFileName, OF_Exist )	! Check for new file existence
.head 7 -  Set bFileActioned = FALSE				! Set function failed flag
.head 5 -  !
.head 5 -  Return bFileActioned				! Return function success status
.head 3 +  Function: fnLogFileTransfer
.head 4 -  Description: Logs the transfer of files and their associated customer numbers to the database
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  String: sPartnerIdentifier
.head 5 -  String: sFileName
.head 5 -  Boolean: bDirectionFlag					! Upload/Download flag
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Sql Handle: hSql						! Database connection handle
.head 5 -  String: sSql						! SQL statement to perform
.head 5 -  Boolean: bFileLogged					! External process status flag
.head 5 -  String: sDirection						! Direction of FTP
.head 4 +  Actions
.head 5 +  If bDirectionFlag = TRUE
.head 6 -  Set sDirection = 'DOWNLOAD'
.head 5 +  Else
.head 6 -  Set sDirection = 'UPLOAD'
.head 5 -  !
.head 5 -  Set sSql = ' INSERT INTO TRANSFER_LOG
		SELECT 
			@CHOOSE( @ISNA( MAX( DISTINCT( ID ))), MAX( DISTINCT( ID )) + 1, 1),
			SYSDATETIME, 
			:sPartnerIdentifier, 
			:sFileName,
			:sDirection
		FROM 
			TRANSFER_LOG '				! Set up statement to add new record
.head 5 +  If SqlConnect( hSql )						! Get Database connection
.head 6 -  Set bFileLogged = SqlPrepareAndExecute( hSql, sSql )			! Add new record
.head 6 -  Call SqlDisconnect (hSql)						! Drop Database connection
.head 5 -  !
.head 5 -  Return bFileLogged						! Return the processing status

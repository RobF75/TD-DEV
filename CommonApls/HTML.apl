.head 2 +  Message Actions
.head 3 +  On SAM_CreateComplete
.head 4 -  Call GetRegistryValue( 'GENERAL', 'HTMLPageTitle', dfPageTitle, 'Title' )
.head 4 -  Call GetRegistryValue( 'GENERAL', 'HTMLPageHeading', dfPageHeading, 'Heading' )
.head 4 -  Call GetRegistryValue( 'GENERAL', 'HTMLSubHeading', dfSubHeading, 'Sub Heading' )
.head 4 -  Call GetRegistryValue( 'GENERAL', 'HTMLFooter', dfFooter, 'Footer' )
.head 3 +  On SAM_Destroy
.head 4 -  Call SetRegistryValue( 'GENERAL', 'HTMLPageTitle', dfPageTitle, dfPageTitle )
.head 4 -  Call SetRegistryValue( 'GENERAL', 'HTMLPageHeading', dfPageHeading, dfPageHeading )
.head 4 -  Call SetRegistryValue( 'GENERAL', 'HTMLSubHeading', dfSubHeading, dfSubHeading )
.head 4 -  Call SetRegistryValue( 'GENERAL', 'HTMLFooter', dfFooter, dfFooter )
.head 4 -  Return TRUE

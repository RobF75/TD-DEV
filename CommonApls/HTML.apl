.head 7 -  Set lsHTML = lsHTML || '<p>
' || sContent  || '
</p>
</td></tr></table>
</td>
</tr>
<tr><td colspan="2" valign="bottom" align="center" style="padding:20px; font-family:arial; font-size:16px; font-weight:bold; color:slategray;"> ' || sFooter || '</td></tr>
</table>
</body>
</html>'


.head 5 +  Function: IsPointInMyArea
.head 6 -  Description: [PUBLIC]
Point appartient a la zone définie par la fenetre
.head 6 +  Returns 
.head 7 -  Boolean: 
.head 6 +  Parameters 
.head 7 -  Number: nXFormUnit
.head 7 -  Number: nYFormUnit
.head 6 -  Static Variables 
.head 6 +  Local variables 
.head 7 -  Number: nMyWidth
.head 7 -  Number: nMyHeight
.head 7 -  Number: nMyPosX
.head 7 -  Number: nMyPosY
.head 6 +  Actions 
.head 7 -  Call GetPosition( nMyPosX, nMyPosY)
.head 7 -  Call GetSize( nMyWidth, nMyHeight)
.head 7 +  If nXFormUnit >= nMyPosX AND nYFormUnit >= nMyPosY 
  AND 
      nXFormUnit <= (nMyPosX + nMyWidth) AND nYFormUnit <= ( nMyPosY + nMyHeight )
.head 8 -  Return TRUE
.head 7 -  Return FALSE
.head 5 +  Function: IsPointInRightSizeArea
.head 6 -  Description: [PUBLIC]
Point appartient a la zone définie pour le resize droit de la fenętre
.head 6 +  Returns 
.head 7 -  Boolean: 
.head 6 +  Parameters 
.head 7 -  Number: nXFormUnit
.head 7 -  Number: nYFormUnit
.head 6 -  Static Variables 
.head 6 +  Local variables 
.head 7 -  Number: nMyWidth
.head 7 -  Number: nMyHeight
.head 7 -  Number: nMyPosX
.head 7 -  Number: nMyPosY
.head 7 -  Number: nWidthZone
.head 7 -  Number: nHeightZone
.head 7 -  Number: nPosXBox
.head 7 -  Number: nPosYBox
.head 6 +  Actions 
.head 7 -  Call GetPosition( nMyPosX, nMyPosY)
.head 7 -  Call GetSize( nMyWidth, nMyHeight)
.head 7 -  Call _GetResizeBox( nWidthZone, nHeightZone)
.head 7 -  Set nPosXBox = nMyPosX +  nMyWidth  - ( nWidthZone / 2 )
.head 7 -  Set nPosYBox = nMyPosY + ( nMyHeight / 2 ) - ( nHeightZone / 2 )
.head 7 +  If nXFormUnit >= nPosXBox AND nYFormUnit >= nPosYBox 
  AND 
      nXFormUnit <= (nPosXBox + nWidthZone) AND nYFormUnit <= ( nPosYBox  + nHeightZone )
.head 8 -  Return TRUE
.head 7 -  Return FALSE

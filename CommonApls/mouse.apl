.head 5 -  ! Ajustements
.head 5 +  Function: AdjustSizeWithChilds
.head 6 -  Description: [PUBLIC]
Ajustement de la fenetre avec l'encombrement des fenetres filles
.head 6 -  Returns 
.head 6 -  Parameters 
.head 6 -  Static Variables 
.head 6 +  Local variables 
.head 7 -  Window Handle: hWndChild
.head 7 -  Number: nXMin
.head 7 -  Number: nYMin
.head 7 -  Number: nXMax
.head 7 -  Number: nYMax
.head 7 -  Number: nXChild
.head 7 -  Number: nYChild
.head 7 -  Number: nWidthChild
.head 7 -  Number: nHeightChild
.head 7 -  Number: nDecalXWin
.head 7 -  Number: nDecalYWin
.head 7 -  Number: nDeltaX
.head 7 -  Number: nDeltaY
.head 6 +  Actions 
.head 7 -  Set nXMax = -1
.head 7 -  Set nYMax = -1
.head 7 -  Set nXMin = 32000
.head 7 -  Set nYMin = 32000
.head 7 -  Set hWndChild = SalGetFirstChild( hWndItem, TYPE_Any)
.head 7 +  While hWndChild != hWndNULL
.head 8 -  !
.head 8 -  Call SalGetWindowLoc( hWndChild, nXChild, nYChild )
.head 8 -  Call SalGetWindowSize( hWndChild, nWidthChild, nHeightChild )
.head 8 -  !
.head 8 +  If nXChild  < nXMin
.head 9 -  Set nXMin = nXChild 
.head 8 +  If nYChild  < nYMin
.head 9 -  Set nYMin = nYChild 
.head 8 -  !
.head 8 +  If nXChild + nWidthChild > nXMax
.head 9 -  Set nXMax = nXChild + nWidthChild 
.head 8 +  If nYChild + nHeightChild > nYMax
.head 9 -  Set nYMax = nYChild + nHeightChild 
.head 8 -  !
.head 8 -  Set hWndChild = SalGetNextChild( hWndChild, TYPE_Any)
.head 7 -  Set nWidthChild = nXMax - nXMin
.head 7 -  Set nHeightChild = nYMax - nYMin
.head 7 -  Set nDeltaX  = GetCxBorder( )
.head 7 -  Set nDeltaY  = GetCyBorder( )
.head 7 -  Set nDeltaX  = SalPixelsToFormUnits( hWndItem, nDeltaX , FALSE )
.head 7 -  Set nDeltaY  = SalPixelsToFormUnits( hWndItem, nDeltaY, TRUE )
.head 7 -  Call SalSetWindowSize( hWndItem, nWidthChild + 2 * nDeltaX, nHeightChild + 2 * nDeltaY )
.head 7 -  ! Return TRUE
.head 7 -  ! Repositionnement des fenetres filles a l'interieur
.head 7 -  ! de la fenetre de support 
.head 7 -  Set nDecalXWin = nXMin
.head 7 -  Set nDecalYWin = nYMin
.head 7 -  Set hWndChild = SalGetFirstChild( hWndItem, TYPE_Any)
.head 7 +  While hWndChild != hWndNULL
.head 8 -  !
.head 8 -  Call SalGetWindowLoc( hWndChild, nXChild, nYChild )
.head 8 -  Call SalSetWindowLoc( hWndChild, nXChild - nDecalXWin + nDeltaX, nYChild - nDecalYWin + nDeltaY )
.head 8 -  Set hWndChild = SalGetNextChild( hWndChild, TYPE_Any)

.head 7 -  Number: nPosYBox
.head 6 +  Actions 
.head 7 -  Call GetPosition( nMyPosX, nMyPosY)
.head 7 -  Call GetSize( nMyWidth, nMyHeight)
.head 7 -  Call _GetResizeBox( nWidthZone, nHeightZone)
.head 7 -  Set nPosXBox = nMyPosX  - ( nWidthZone / 2 )
.head 7 -  Set nPosYBox = nMyPosY + ( nMyHeight  / 2 )  - ( nHeightZone / 2 )
.head 7 +  If nXFormUnit >= nPosXBox AND nYFormUnit >= nPosYBox 
  AND 
      nXFormUnit <= (nPosXBox + nWidthZone) AND nYFormUnit <= ( nPosYBox  + nHeightZone )
.head 8 -  Return TRUE

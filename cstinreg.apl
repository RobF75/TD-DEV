.head 4 +  Functions
.head 5 +  Function: GetLoadType
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  String: sLoadId
.head 7 -  Receive String: sLoadType
.head 7 -  Number: nActionType
.head 6 +  Static Variables
.head 7 -  Sql Handle: hSqlHandle
.head 7 -  Boolean: bHandleConnected
.head 7 -  Boolean: bHandlePrepared
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  String: sFuncName
.head 7 -  Boolean: bOk
.head 7 -  Number: nInd
.head 7 -  String: sGotLoadType
.head 6 +  Actions
.head 7 -  Set sFuncName = 'GetLoadType'
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 +  If sLoadId = ''
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 +  Loop Execute
.head 11 +  Loop Connect
.head 12 +  If bHandleConnected
.head 13 -  Break Connect
.head 12 +  Else
.head 13 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 13 +  If bHandleConnected
.head 14 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 14 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 14 -  Break Connect
.head 13 +  Else
.head 14 +  If IDNO = SalMessageBox( 'Could not connect handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
.head 15 -  Break Connect
.head 11 +  Loop Prepare
.head 12 +  If bHandlePrepared
.head 13 -  Break Prepare
.head 12 +  Else
.head 13 -  Set sSql = " SELECT 
  Load_Primary_Type 
FROM 
  Load 
INTO 
  :sGotLoadType
WHERE 
  Load_Id = :sLoadId "
.head 13 +  If SqlPrepare( hSqlHandle, sSql )
.head 14 -  Set bHandlePrepared = TRUE
.head 14 -  Break Prepare
.head 13 +  Else
.head 14 -  Set bHandlePrepared = FALSE
.head 14 +  If IDNO = SalMessageBox( 'Could not prepare handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
.head 15 -  Break Prepare
.head 11 -  !
.head 11 -  Set sGotLoadType = ''
.head 11 -  Set sLoadType = ''
.head 11 -  !
.head 11 +  If SqlExecute( hSqlHandle )
.head 12 -  Call SqlFetchNext( hSqlHandle, nInd )
.head 12 -  Set sLoadType = sGotLoadType
.head 12 -  Return TRUE
.head 11 +  Else
.head 12 -  Set bHandlePrepared = FALSE
.head 12 +  If IDNO = SalMessageBox( 'Could not execute handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
.head 13 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Set bOk = TRUE
.head 9 +  Loop Disconnect
.head 10 +  If bHandleConnected
.head 11 +  If SqlDisconnect( hSqlHandle )
.head 12 -  Set bHandleConnected = FALSE
.head 12 -  Set bHandlePrepared = FALSE
.head 12 -  Break Disconnect
.head 11 +  Else
.head 12 +  If IDNO = SalMessageBox( 'Could not disconnect handle in function '||sFuncName||'Contact programmers! RETRY?', 'Error', MB_YesNo )
.head 13 -  Set bOk = FALSE
.head 13 -  Break Disconnect
.head 10 +  Else
.head 11 -  Break Disconnect
.head 9 -  Return bOk
.head 8 +  Case SH_cls_RePrepare
.head 9 -  Set bHandlePrepared = FALSE
.head 9 -  Return TRUE
.head 4 +  Window Variables
.head 5 -  String: sLoadType
.head 5 -  String: sTmp
.head 5 -  Date/Time: dtTmp
.head 5 -  !
.head 5 -  Number: nLastCustNo
.head 5 -  String: sBusAddr1
.head 5 -  String: sBusAddr2
.head 5 -  String: sSuburb
.head 5 -  String: sPostcode
.head 5 -  String: sState
.head 4 +  Message Actions
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLTABLENAME = ''
.head 6 -  Set sSQLPOPTABLENAME = ' Customer_Master, Region, Customer_Order '
.head 6 -  !
.head 6 +  If frmPrintCustInRegNLoads.nReportType = nSelectionRegions
.head 7 -  Set sSQLWHERE = ' WHERE
  Customer_Master.Region_Id IN ('||frmPrintCustInRegNLoads.mlRegions||') AND 
  Customer_Master.Cust_No = Customer_Order.Cust_No AND 
  Customer_Master.Region_Id = Region.Region_Id AND 
  Customer_Order.Year_Of_Sale = :frmPrintCustInRegNLoads.nYear '
.head 6 +  Else
.head 7 -  Set sSQLWHERE = ' WHERE
  Customer_Master.Cust_No = Customer_Order.Cust_No AND 
  Customer_Master.Region_Id = Region.Region_Id AND 
  Customer_Order.Year_Of_Sale = :frmPrintCustInRegNLoads.nYear '
.head 6 -  !
.head 6 -  Set sORDERBY = ' ORDER BY
  Customer_Master.Region_Id, Customer_Master.Cust_Name, Customer_Order.Load_Id '
.head 6 -  Set sTableHeading = 'Customers In Regions and their Loads'
.head 6 -  Set bSelectFirstRow = FALSE
.head 6 -  Set nSelectType = nSELDISTINCT
.head 6 -  Set sReportFileName = 'g:\\apps\\gupta\\reports\\cstinreg.qrp'
.head 6 -  !
.head 6 -  Set nLastCustNo = 0
.head 6 -  Set sBusAddr1 = ''
.head 6 -  Set sBusAddr2 = ''
.head 6 -  Set sSuburb = ''
.head 6 -  Set sPostcode = ''
.head 6 -  Set sState = ''
.head 5 +  On SAM_FetchRowDone
.head 6 +  If NOT frmPrintCustInRegNLoads.bContWanted
.head 7 -  Call GetLoadType( colLoadId, sLoadType, SH_cls_Execute )
.head 7 +  If sLoadType = 'C'
.head 8 -  Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
.head 8 -  Return TRUE
.head 6 -  !
.head 6 -  Call GetCustTreeGroupsOnLoad( colCustNo, colLoadCustInstNo, colLoadId, frmPrintCustInRegNLoads.nYear, 
frmPrintCustInRegNLoads.bIncludeInvoiced, colFruitTrees, colMSTrees, colMDTrees, 
colSmallFruitTrees, colOrnamTrees, colXlgOrnamTrees, colWeeperTrees, colContTrees, colTotalTrees, 
SH_cls_Execute )
.head 6 +  If colCustNo = nLastCustNo
.head 7 -  Set colBusAddr1 = sBusAddr1
.head 7 -  Set colBusAddr2 = sBusAddr2
.head 7 -  Set colSuburb = sSuburb
.head 7 -  Set colPostcode = sPostcode
.head 7 -  Set colState = sState
.head 6 +  Else
.head 7 -  Call GetBusAddress( colCustNo, dtTmp, sTmp, sBusAddr1, sBusAddr2, sSuburb, sPostcode, sState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
.head 7 -  Set colBusAddr1 = sBusAddr1
.head 7 -  Set colBusAddr2 = sBusAddr2
.head 7 -  Set colSuburb = sSuburb
.head 7 -  Set colPostcode = sPostcode
.head 7 -  Set colState = sState
.head 7 -  Set nLastCustNo = colCustNo
.head 6 -  Return TRUE
.head 5 +  On SAM_Destroy
.head 6 -  Call GetCustTreeGroupsOnLoad( 0, 0, '', 0, FALSE, colFruitTrees, colMSTrees, colMDTrees, colSmallFruitTrees, 
colOrnamTrees, colXlgOrnamTrees, colWeeperTrees, colContTrees, colTotalTrees, SH_cls_Disconnect )
.head 6 -  Call GetLoadType( '', sLoadType, SH_cls_Disconnect )
.head 6 -  Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
.head 3 -  !
.head 2 -  Functions
.head 2 +  Window Parameters
.head 3 -  String: saRegionIds[*]
.head 3 -  Number: nYear
.head 3 -  Boolean: bIncludeInvoiced
.head 3 -  ! User nAllRegions, nSelectionRegions
  NOTE saRegionIds[*] parameter needs only be set with nSelectionRegions report type
.head 3 -  Number: nReportType
.head 3 -  Boolean: bContWanted
.head 2 -  Window Variables
.head 2 +  Message Actions
.head 3 +  On PAM_SETINSTANCEVARS
.head 4 -  Set sDatabase = SqlDatabase
.head 4 -  Set OurFrmWndWithChildTbl.bQueryTableAllowed = FALSE
.head 4 -  Set OurFrmWndWithChildTbl.bAddRowsAllowed = FALSE
.head 4 -  Set OurFrmWndWithChildTbl.bSaveRowsAllowed = FALSE
.head 4 -  Set OurFrmWndWithChildTbl.bDeleteRowsAllowed = FALSE
.head 4 -  Set OurFrmWndWithChildTbl.bUnDeleteRowsAllowed = FALSE
.head 4 -  Set OurFrmWndWithChildTbl.bTablePrintReportAllowed = TRUE
.head 3 +  On SAM_Create
.head 4 +  If nReportType = nSelectionRegions
.head 5 -  Call MakeStringList( saRegionIds, " , ", "'", mlRegions )
.head 4 -  Return SalSendClassMessage( SAM_Create, wParam, lParam )
.head 3 +  On SAM_CreateComplete
.head 4 -  Call SalHideWindow( SalParentWindow( hWndForm ) )
.head 4 -  Call SalWaitCursor( FALSE )
.head 3 +  On SAM_Destroy
.head 4 -  Call SalShowWindow( SalParentWindow( hWndForm ) )
.head 4 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

.head 10 +  If nOldSubsItemNo > 0 
.head 11 +  If NOT NewDeleteFromSub( nOldSubsItemNo, nOldYear, nOldOrdAmt, nOldConfAmt, sOldAllocFlag, SH_cls_Execute )

.head 7 +  If nOldYear = nYear
.head 8 +  If nOldItemNo = nItemNo
.head 9 +  If nOldOrdAmt = nOrdAmt
.head 10 +  If sOldAllocFlag = sAllocFlag
.head 11 +  If nOldConfAmt = nConfAmt
.head 12 -  ! Then nothing has changed to the 5 fields that impact the total amount on order
so we dont need to update anything 
.head 12 -  Return TRUE
.head 7 -  ! Dani added to stop users increasing an ordered amount
.head 7 -  ! Jan took out the check for increasing or decreasing conf_amount
  this should be done local to the screen
.head 7 +  If nOldConfAmt = NUMBER_Null 
.head 8 +  If nOldOrdAmt < nOrdAmt 

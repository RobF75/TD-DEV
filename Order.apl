.head 5 -  Boolean: bUpdateHandlePrepared
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  Boolean: bOk
.head 5 -  Number: nInd
.head 5 -  Number: nCount
.head 5 -  !
.head 5 -  Number: nOnOrdSub
.head 5 -  Number: nSubTotAvail
.head 4 +  Actions
.head 5 +  If IsFlagSet( nActionType, SH_cls_Execute )
.head 6 +  If NOT bHandleConnected
.head 7 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 7 +  If bHandleConnected
.head 8 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 8 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 7 +  Else
.head 8 -  Call SalMessageBeep( 0 )
.head 8 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 8 -  Return FALSE
.head 6 +  If NOT bHandlePrepared
.head 7 -  Set sSql = " SELECT On_Ord_As_Subs, Tot_Avail FROM Stock_Item_Sale 
  INTO :nOnOrdSub, :nSubTotAvail 
  WHERE Stock_Item_No = :nSubItemNos[nCount] AND 
    Year_Of_Sale = :nYear "
.head 7 +  If SqlPrepare( hSqlHandle, sSql )
.head 8 -  Set bHandlePrepared = TRUE
.head 7 +  Else
.head 8 -  Set bHandlePrepared = FALSE
.head 6 -  !
.head 6 +  If NOT bUpdateHandleConnected
.head 7 -  Set bUpdateHandleConnected = SqlConnect( hSqlUpdateHandle ) 
.head 7 +  If bUpdateHandleConnected
.head 8 -  Call SqlSetLockTimeout( hSqlUpdateHandle, SQLTIMEOUT )
.head 8 -  Call SqlSetParameter( hSqlUpdateHandle, DBP_PRESERVE, TRUE, ''  )
.head 7 +  Else
.head 8 -  Call SalMessageBeep( 0 )
.head 8 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 8 -  Return FALSE
.head 6 +  If NOT bUpdateHandlePrepared
.head 7 -  Set sSql = " UPDATE Stock_Item_Sale SET On_Ord_As_Subs = :nOnOrdSub, 
  Tot_Avail = :nSubTotAvail 
  WHERE Stock_Item_No = :nSubItemNos[nCount] AND Year_Of_Sale = :nYear "
.head 7 +  If SqlPrepare( hSqlUpdateHandle, sSql )
.head 8 -  Set bUpdateHandlePrepared = TRUE
.head 7 +  Else
.head 8 -  Set bUpdateHandlePrepared = FALSE
.head 6 -  !
.head 6 -  ! Latest change added if not bgGeneric then return false
.head 6 -  Set nNewSubItemNo = NUMBER_Null
.head 6 +  If sGenericFlag = 'N'
.head 7 -  Return FALSE
.head 6 -  !
.head 6 +  If IsFlagSet( nActionType, nLess20NotOkDontAsk )
.head 7 -  Return FALSE
.head 6 +  Else If NOT IsFlagSet( nActionType, nLess20OkDontAsk )
.head 7 -  Call SalMessageBeep( 0 )
.head 7 +  If IDNO = SalMessageBox( 'Available stock levels are less than 20.   Do you
still want to add the order?', 'Customer Order',
 MB_YesNo )
.head 8 -  Return FALSE
.head 6 -  !
.head 6 -  Set nCount = 0
.head 6 +  If SqlExecute( hSqlHandle )
.head 7 -  ! Only get the first sub and allocate order against it.
.head 7 +  If SqlFetchNext( hSqlHandle, nInd )
.head 8 +  If nInd !=FETCH_EOF
.head 9 +  If sAllocFlag = 'N'
.head 10 -  Set nOnOrdSub = nOnOrdSub + nOrdAmt
.head 10 -  Set nSubTotAvail = nSubTotAvail - nOrdAmt
.head 9 +  Else
.head 10 -  Set nOnOrdSub = nOnOrdSub + nConfAmt
.head 10 -  Set nSubTotAvail = nSubTotAvail - nConfAmt
.head 9 +  If SqlExecute( hSqlUpdateHandle )
.head 10 -  Set nNewSubItemNo = nSubItemNos[nCount]
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Set bUpdateHandlePrepared = FALSE
.head 10 -  Call SalMessageBeep( 0 )
.head 10 -  Call SalMessageBox( 'SqlExecute hSqlUpdateHandle had a error in function QueryOrderAddition! Please contact programmers!', 'Error', MB_Ok )
.head 10 -  Set nCount = nCount + 1
.head 10 -  Return FALSE
.head 8 +  Else
.head 9 -  Set nCount = nCount + 1
.head 7 -  Return FALSE
.head 6 +  Else
.head 7 -  Set bHandlePrepared = FALSE
.head 7 -  Call SalMessageBeep( 0 )
.head 7 -  Call SalMessageBox( 'SqlExecute hSqlHandle had a error in function QueryOrderAddition! Please contact programmers!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 5 +  Else If IsFlagSet( nActionType, SH_cls_Commit )
.head 6 -  Set bOk = TRUE
.head 6 +  If bUpdateHandleConnected
.head 7 +  If NOT SqlCommit( hSqlUpdateHandle )
.head 8 -  Set bOk = FALSE
.head 6 -  Return bOk
.head 5 +  Else If IsFlagSet( nActionType, SH_cls_Rollback )
.head 6 -  Set bOk = TRUE
.head 6 +  If bUpdateHandleConnected
.head 7 +  If NOT SqlPrepareAndExecute( hSqlUpdateHandle, 'ROLLBACK' )
.head 8 -  Set bOk = FALSE
.head 7 -  Set bUpdateHandlePrepared = FALSE
.head 6 -  Return bOk
.head 5 +  Else If IsFlagSet( nActionType, SH_cls_Disconnect )
.head 6 -  Set bOk = TRUE
.head 6 -  Set bHandlePrepared = FALSE
.head 6 +  If bHandleConnected
.head 7 -  Set bHandleConnected = FALSE
.head 7 +  If NOT SqlDisconnect( hSqlHandle )
.head 8 -  Set bOk = FALSE
.head 6 -  Set bUpdateHandlePrepared = FALSE
.head 6 +  If bUpdateHandleConnected
.head 7 -  Set bUpdateHandleConnected = FALSE
.head 7 +  If NOT SqlDisconnect( hSqlUpdateHandle )
.head 8 -  Set bOk = FALSE
.head 6 -  Return bOk
.head 5 +  Else If IsFlagSet( nActionType, SH_cls_RePrepare )
.head 6 -  Set bHandlePrepared = FALSE
.head 6 -  Set bUpdateHandlePrepared = FALSE
.head 6 -  Return TRUE
.head 3 -  ! -----------------------------------------------------------

.head 7 +  If IsFlagSet( nActionType, nLess20OkDontAsk )
.head 8 -  Set nPassDownActionType = SH_cls_Execute | nLess20OkDontAsk
.head 7 +  Else If IsFlagSet( nActionType, nLess20NotOkDontAsk )

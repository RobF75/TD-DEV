.head 6 -  Call JJNewAddToStockItemSale( 0, 0, 0, 0, '', '', '', nNewSubItemNo, SH_cls_RePrepare )
.head 6 -  Call NewDeleteFromSub( 0, 0, 0, 0, '', SH_cls_RePrepare )

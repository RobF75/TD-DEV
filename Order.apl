.head 5 -  Boolean: bUpdateHandlePrepared
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  Boolean: bOk
.head 5 -  !
.head 5 -  Date/Time: dtOrderSysDT
.head 5 -  String: sAllocFlag
.head 5 -  Number: nSubsItemNo
.head 5 -  !
.head 5 -  Number: nPassDownActionType
.head 4 +  Actions
.head 5 +  If IsFlagSet( nActionType, SH_cls_Execute )
.head 6 +  If NOT bInsertHandleConnected
.head 7 -  Set bInsertHandleConnected = SqlConnect( hSqlInsertHandle ) 
.head 7 +  If bInsertHandleConnected
.head 8 -  Call SqlSetLockTimeout( hSqlInsertHandle, SQLTIMEOUT )
.head 8 -  Call SqlSetParameter( hSqlInsertHandle, DBP_PRESERVE, TRUE, ''  )
.head 7 +  Else
.head 8 -  Call SalMessageBeep( 0 )
.head 8 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 8 -  Return FALSE
.head 6 +  If NOT bInsertHandlePrepared
.head 7 -  Set sSql = " INSERT INTO Customer_Order ( Cust_No, Order_Date_Time, 
  Stock_Item_No, Year_Of_Sale, Subs_Ok_Flag, Ordered_Amount, 
  Ord_Date, Sale_Cat, Invoiced_Flag, Alloc_Flag, Conf_Flag, Conf_Amt, User_Id, 
  Pull_Sheet_Issued, NPA_Sent_Flag, Ack_Flag, Lbl_PullSh_Printed, 
  Subs_Item_No, Cont_Price_Flag, Custom_Bud_Flag, Contract_Dep_Reqd, 
  Trialpack_Reqd ) VALUES ( :nCustNo, :dtOrderSysDT, :nItemNo, :nYear, 
  :sSubsOkFlag, :nOrdAmt, :dtOrderedDate, :sSaleCat, 'N', :sAllocFlag, 'N', :nConfAmt, :SqlUser, 
  'N', 'N', 'N', 'N', :nSubsItemNo, 'N', 'N', 'N', 'N' ) "
.head 7 +  If SqlPrepare( hSqlInsertHandle, sSql )
.head 8 -  Set bInsertHandlePrepared = TRUE
.head 7 +  Else
.head 8 -  Set bInsertHandlePrepared = FALSE
.head 6 -  !
.head 6 +  If hWndHandle != hWndNULL
.head 7 +  If NOT bUpdateHandleConnected
.head 8 -  Set bUpdateHandleConnected = SqlConnect( hSqlUpdateHandle ) 
.head 8 +  If bUpdateHandleConnected
.head 9 -  Call SqlSetLockTimeout( hSqlUpdateHandle, SQLTIMEOUT )
.head 9 -  Call SqlSetParameter( hSqlUpdateHandle, DBP_PRESERVE, TRUE, ''  )
.head 8 +  Else
.head 9 -  Call SalMessageBeep( 0 )
.head 9 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  If NOT bUpdateHandlePrepared
.head 8 -  Set sSql = sgSql
.head 8 -  Call CallBuildSql( hWndHandle, nUPDATE, nPAM_EXTRAFIELDSMSG, 
  ' Customer_Order ', 
  ' WHERE Cust_No = :nCustNo AND Order_Date_Time = :dtOrderSysDT ' )
.head 8 +  If SqlPrepare( hSqlUpdateHandle, sgSql )
.head 9 -  Set bUpdateHandlePrepared = TRUE
.head 8 +  Else
.head 9 -  Set bUpdateHandlePrepared = FALSE
.head 8 -  Set sgSql = sSql
.head 7 -  !
.head 7 +  If NOT DetailsFormDataVal( hWndHandle )
.head 8 -  Return FALSE
.head 6 -  Set nSubsItemNo = NUMBER_Null
.head 6 -  !
.head 6 -  Set dtOrderSysDT = SalDateCurrent(  )
.head 6 +  If nConfAmt > 0
.head 7 -  Set sAllocFlag = 'Y'
.head 6 +  Else
.head 7 -  Set sAllocFlag = 'N'
.head 6 -  !
.head 6 +  If IsFlagSet( nActionType, nLess20OkDontAsk )
.head 7 -  Set nPassDownActionType = SH_cls_Execute | nLess20OkDontAsk
.head 6 +  Else If IsFlagSet( nActionType, nLess20NotOkDontAsk )
.head 7 -  Set nPassDownActionType = SH_cls_Execute | nLess20OkDontAsk
.head 6 +  Else
.head 7 -  Set nPassDownActionType = SH_cls_Execute
.head 6 +  If NOT JJNewAdditionLogic( nItemNo, nYear, nOrdAmt, nConfAmt, sAllocFlag, sSubsOkFlag, nSubsItemNo, nPassDownActionType )
.head 7 -  Call JJNewAddOrder( 0, 0, DATETIME_Null, 0, 0, 0, '', '', hWndNULL, 0, SH_cls_Rollback )
.head 7 -  Return FALSE
.head 6 -  !
.head 6 +  If SqlExecute( hSqlInsertHandle )
.head 7 +  If hWndHandle != hWndNULL
.head 8 +  If SqlExecute( hSqlUpdateHandle )
.head 9 -  Call JJNewAddOrder( 0, 0, DATETIME_Null, 0, 0, 0, '', '', hWndNULL, 0, SH_cls_Commit )
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Set bUpdateHandlePrepared = FALSE
.head 9 -  Call SalMessageBeep( 0 )
.head 9 -  Call SalMessageBox( 'SqlExecute hSqlUpdateHandle had a error in function AddOrder! Please contact programmers!', 'Error', MB_Ok )
.head 9 -  Call JJNewAddOrder( 0, 0, DATETIME_Null, 0, 0, 0, '', '', hWndNULL, 0, SH_cls_Rollback )
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Call JJNewAddOrder( 0, 0, DATETIME_Null, 0, 0, 0, '', '', hWndNULL, 0, SH_cls_Commit )
.head 8 -  Return TRUE
.head 6 +  Else
.head 7 -  Set bInsertHandlePrepared = FALSE
.head 7 -  Call SalMessageBeep( 0 )
.head 7 -  Call SalMessageBox( 'SqlExecute hSqlInsertHandle had a error in function AddOrder! Please contact programmers!', 'Error', MB_Ok )
.head 7 -  Call JJNewAddOrder( 0, 0, DATETIME_Null, 0, 0, 0, '', '', hWndNULL, 0, SH_cls_Rollback )
.head 7 -  Return FALSE
.head 5 +  Else If IsFlagSet( nActionType, SH_cls_Commit )
.head 6 -  Set bOk = TRUE
.head 6 +  If bInsertHandleConnected
.head 7 +  If NOT SqlCommit( hSqlInsertHandle )
.head 8 -  Set bOk = FALSE
.head 6 +  If bUpdateHandleConnected
.head 7 +  If NOT SqlCommit( hSqlUpdateHandle )
.head 8 -  Set bOk = FALSE
.head 6 +  If NOT JJNewAdditionLogic( 0, 0, 0, 0, '', '', nSubsItemNo, SH_cls_Commit )

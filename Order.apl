.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  Else If IsFlagSet( nActionType, SH_cls_Commit )
.head 6 -  Set bOk = TRUE
.head 6 +  If NOT JJNewAddToStockItemSale( 0, 0, 0, 0, '', '', '', nNewSubItemNo, SH_cls_Commit )
.head 7 -  Set bOk = FALSE
.head 6 -  Return bOk

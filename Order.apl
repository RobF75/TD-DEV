.head 10 +  Else
.head 11 -  Return FALSE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Else
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  Else If IsFlagSet( nActionType, SH_cls_Commit )
.head 6 -  Set bOk = TRUE
.head 6 +  If NOT NewDeductFromStockItemSale( 0, 0, 0, 0, '', '', 0, 0, SH_cls_Commit  )
.head 7 -  Set bOk = FALSE

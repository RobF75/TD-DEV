.head 2 +  Application Actions
.head 3 +  On SAM_AppStartup
.head 4 +  If strArgArray[0] = ''
.head 5 -  Set SqlDatabase = 'PROPDEV'
.head 5 -  Set SqlUser = 'JAN'
.head 5 -  Set SqlPassword = 'JAN'
.head 4 +  Else
.head 5 -  Set SqlDatabase = strArgArray[1]
.head 5 -  Set SqlUser = strArgArray[2]
.head 5 -  Set SqlPassword = strArgArray[3]
.head 4 -  Call CheckProgramExistance( "Cultivars and Methods", TRUE )
.head 4 -  Call CacheManager.Init( )
.head 4 -  Call CacheManager.AddCache( 'METHOD', 'SELECT METHOD_ID FROM METHOD ORDER BY METHOD_DESC' )
.head 4 -  Call CacheManager.AddCache( 'METHOD1', 'SELECT METHOD_DESC FROM METHOD ORDER BY METHOD_DESC' )
.head 4 -  Call SqlHandlesSetup(  )

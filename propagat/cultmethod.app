.head 6 +  On PAM_clsPB_CLICK
.head 7 -  Call SalSendClassMessage( PAM_clsPB_CLICK, wParam, lParam )
.head 7 -  Set hWndCult = pbCult.hWndActivated
.head 6 +  On SAM_Click
.head 7 +  If hWndCult != hWndNULL
.head 8 -  Call SalBringWindowToTop( hWndCult )
.head 7 +  Else
.head 8 -  Call SalSendClassMessage( SAM_Click, wParam, lParam )
.head 6 +  On PAM_cls_SETINSTANCEVARS

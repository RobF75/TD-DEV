.head 7 -  Return FALSE
.head 6 -  Call SalWaitCursor( TRUE )
.head 6 +  If sQueryDialogName != ''
.head 7 -  Call SalSendMsg( hWndForm, PAM_PUSHFIELDS, 0, 0 )
.head 7 -  Call PushWndHdl( hWndForm )
.head 7 +  If SalModalDialogFromStr( sQueryDialogName, hWndForm )
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 -  Return TRUE
.head 7 +  Else 

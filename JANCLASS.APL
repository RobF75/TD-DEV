.head 5 -  !
.head 5 +  On PAM_MOVESELECTEDROWSUPONE
.head 6 -  ! lParam is assumed to indicate number of rows in table
.head 6 -  ! wParam if not 0 then is assumed to be a ROW_flag which should be set to TRUE
! for every row involved in the movement up one
.head 6 -  Call SalWaitCursor( TRUE )
.head 6 -  Set nRow = TBL_MinRow
.head 6 +  While SalTblFindNextRow( hWndForm, nRow, 0, 0 )
.head 7 -  Call SalTblSetContext( hWndForm, nRow )
.head 7 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_UnusedFlag2, FALSE )
.head 6 -  Set nNumRows = nRow
.head 6 +  If SalSendMsg( hWndForm, PAM_CHECKFORCONSEQUTIVEROWS, 0, 0 )
.head 7 -  Set nRow = TBL_MinRow
.head 7 +  If SalTblFindNextRow( hWndForm, nRow, ROW_UnusedFlag2, 0 )
.head 8 -  Call SalTblFetchRow( hWndForm, nRow )
.head 8 +  If nRow > 0
.head 9 -  Call CopyTableRowFromTo( hWndForm, nRow - 1, TBL_TempRow )
.head 9 -  Set nLastRow = nRow
.head 9 -  Set nRow = nRow - 1
.head 9 +  While SalTblFindNextRow( hWndForm, nRow, ROW_UnusedFlag2, 0 )
.head 10 -  Call SalTblFetchRow( hWndForm, nRow )
.head 10 -  Call CopyTableRowFromTo( hWndForm, nRow, nRow - 1 )
.head 10 -  Call SalTblSetRowFlags( hWndForm, nRow - 1, ROW_Selected, TRUE )
.head 10 +  If wParam != 0
.head 11 -  Call SalTblSetRowFlags( hWndForm, nRow - 1, wParam, TRUE )
.head 10 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_UnusedFlag2, FALSE )
.head 10 -  Set nLastRow = nRow
.head 9 -  Call CopyTableRowFromTo( hWndForm, TBL_TempRow, nLastRow )
.head 9 +  If wParam != 0
.head 10 -  Call SalTblSetRowFlags( hWndForm, nLastRow, wParam, TRUE )
.head 6 +  Else 
.head 7 -  Call SalWaitCursor( FALSE )
.head 7 -  Call SalMessageBox( 'Selected rows need to be in one BLOCK to move! Please rectify!', 'Warning', MB_Ok )
.head 7 -  Call SalWaitCursor( TRUE )
.head 6 -  Call SalWaitCursor( FALSE )
.head 5 +  On PAM_MOVESELECTEDROWSDOWNONE
.head 6 -  ! wParam if not 0 then is assumed to be a ROW_flag which should be set to TRUE
! for every row involved in the movement down one
.head 6 -  Call SalWaitCursor( TRUE )
.head 6 -  Set nRow = TBL_MinRow
.head 6 +  While SalTblFindNextRow( hWndForm, nRow, 0, 0 )
.head 7 -  Call SalTblSetContext( hWndForm, nRow )
.head 7 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_UnusedFlag2, FALSE )
.head 6 -  Set nNumRows = nRow
.head 6 +  If SalSendMsg( hWndForm, PAM_CHECKFORCONSEQUTIVEROWS, 0, 0 )
.head 7 -  Set nRow = TBL_MaxRow
.head 7 +  If SalTblFindPrevRow( hWndForm, nRow, ROW_UnusedFlag2, 0 )
.head 8 -  Call SalTblFetchRow( hWndForm, nRow )
.head 8 +  If nRow < nNumRows - 1
.head 9 -  Call CopyTableRowFromTo( hWndForm, nRow + 1, TBL_TempRow )
.head 9 -  Set nLastRow = nRow
.head 9 -  Set nRow = nRow + 1
.head 9 +  While SalTblFindPrevRow( hWndForm, nRow, ROW_UnusedFlag2, 0 )
.head 10 -  Call SalTblFetchRow( hWndForm, nRow )
.head 10 -  Call CopyTableRowFromTo( hWndForm, nRow, nRow + 1 )
.head 10 -  Call SalTblSetRowFlags( hWndForm, nRow + 1, ROW_Selected, TRUE )
.head 10 +  If wParam != 0
.head 11 -  Call SalTblSetRowFlags( hWndForm, nRow + 1, wParam, TRUE )
.head 10 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_UnusedFlag2, FALSE )
.head 10 -  Set nLastRow = nRow
.head 9 -  Call CopyTableRowFromTo( hWndForm, TBL_TempRow, nLastRow )
.head 9 +  If wParam != 0
.head 10 -  Call SalTblSetRowFlags( hWndForm, nLastRow, wParam, TRUE )
.head 6 +  Else 
.head 7 -  Call SalWaitCursor( FALSE )
.head 7 -  Call SalMessageBox( 'Selected rows need to be in one BLOCK to move! Please rectify!', 'Warning', MB_Ok )
.head 7 -  Call SalWaitCursor( TRUE )
.head 6 -  Call SalWaitCursor( FALSE )
.head 5 +  On PAM_CHECKFORCONSEQUTIVEROWS
.head 6 -  Set nRow = TBL_MinRow
.head 6 -  Set bRowsConsequtive = TRUE
.head 6 -  Set nLastRow = TBL_MinRow
.head 6 +  While SalTblFindNextRow( hWndForm, nRow, ROW_Selected, 0 )
.head 7 -  Call SalTblSetContext( hWndForm, nRow )
.head 7 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, FALSE )
.head 7 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_UnusedFlag2, TRUE )
.head 7 +  If nLastRow = TBL_MinRow
.head 8 -  Set nLastRow = nRow
.head 7 +  Else If nRow - nLastRow = 1
.head 8 -  Set nLastRow = nRow
.head 7 +  Else 
.head 8 -  Set nLastRow = nRow
.head 8 -  Set bRowsConsequtive = FALSE
.head 6 +  If NOT bRowsConsequtive
.head 7 -  Set nRow = TBL_MinRow
.head 7 +  While SalTblFindNextRow( hWndForm, nRow, ROW_UnusedFlag2, 0 )
.head 8 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_UnusedFlag2, FALSE )
.head 6 -  Return bRowsConsequtive
.head 5 -  !

.head 5 +  On PAM_UNDELETEROWS
.head 6 -  Call TableUnDeleteRows( hWndForm )
.head 5 +  On PAM_CLEARSELECTIONS
.head 6 -  Call ClearSelections( hWndForm )
.head 5 +  On PAM_WRITEINSERTSUPDATES
.head 6 -  Set sRowIdColumn = sROWID

.head 7 -  Return FALSE
.head 6 -  Set bEdit = FALSE
.head 6 -  Set bGetSaveConfirmation = TRUE
.head 6 -  Set sROWID = ' ROWID '
.head 6 -  Set sSQLTABLENAME = ''
.head 6 -  Set sSQLPOPTABLENAME = ''
.head 6 -  Set sSQLWHERE = ''
.head 6 -  Set sORDERBY = ''
.head 6 -  Set sTableHeading =  'Class Declaration Heading'
.head 6 -  Set sReportFileName = ''
.head 6 -  Set nReportPrintOrView = nReportPrint
.head 6 -  !
.head 6 -  Call SalGetItemName( SalParentWindow( hWndForm ), sParentName )
.head 6 -  Call SalGetItemName( hWndForm, sTableName )
.head 6 -  Set sTmpStr = sParentName || '.' || sTableName || '.' || 'colRowId'
.head 6 -  Set sSQLWHEREROWID = ' WHERE ROWID = :' || sTmpStr

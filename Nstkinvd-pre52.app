.head 8 +  On PAM_cls_SETINSTANCEVARS
.head 9 -  Set pbRun.sToolTipText = 'Run Stage 1 Allocations for Current Season'
.head 8 +  On PAM_clsPB_CLICK
.head 9 -  ! Set sYear = cSeasonYear.GetNumber( )
.head 9 -  Set nYear = ccSeasonYear.GetSeasonYear( )
.head 9 +  If IDYES = SalMessageBox( 'Are you sure?', 'Warning', MB_YesNo )
.head 10 +  If IDYES = SalMessageBox( 'Are you REALLY sure?', 'Warning', MB_YesNo )
.head 11 +  If IDYES = SalMessageBox( 'Stage 1 should be run only once! Do you still want to continue?', 'Warning', MB_YesNo )
.head 12 +  If IDYES = SalMessageBox( 'Did you check with someone that is up with the allocations? ie:(Chris or Wes)', 'Warning', MB_YesNo )
.head 13 +  If IDYES = SalMessageBox( 'Ok then, Are your ready?', 'Warning', MB_YesNo )
.head 14 -  Call RunStage1Allocations( nYear, SH_cls_Execute )
.head 9 -  Call SalSendMsg( pbExit, SAM_Click, 0, 0 )

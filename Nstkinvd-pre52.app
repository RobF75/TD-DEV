.head 10 -  Call ErrorMessage( 'In order to change the cultivar, the item must be deleted and a new one added.', hWndForm, nTmpContextRow )
.head 9 +  Else If sPickType = 'ROOTSTOCK'
.head 10 -  Call ErrorMessage( 'In order to change the rootstock, the item must be deleted and a new one added.', hWndForm, nTmpContextRow )
.head 9 -  Return FALSE

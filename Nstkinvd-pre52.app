.head 7 +  Function: ExistsItemOnGrowSaleLocation
.head 8 -  Description: 
.head 8 +  Returns 
.head 9 -  Boolean: 
.head 8 +  Parameters 
.head 9 -  Number: nItemNo
.head 9 -  Receive Boolean: bExists
.head 9 -  Number: nActionType
.head 8 +  Static Variables 
.head 9 -  ! hcSqlHandle: fcOurHandle
.head 8 +  Local variables 
.head 9 -  String: sSql
.head 9 -  String: sBind
.head 9 -  String: sInto
.head 9 -  String: sName
.head 9 -  Number: nOurHandleNo
.head 9 -  !
.head 9 -  Number: nInd
.head 8 +  Actions 
.head 9 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'EXSTITMRLOC' )
.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set sSql = " SELECT Location_Id
FROM
  Growing_Sale
WHERE
  Stock_Item_No = :1 "
.head 11 -  Set sName = 'EXSTITMRLOC'
.head 11 -  Set sBind = ':nItemNo'
.head 11 -  Set sInto = ''
.head 11 -  !
.head 11 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 11 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 11 -  !

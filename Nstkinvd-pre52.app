.head 6 +  ! Menu Item: &Bundles
.head 7 -                                                                       Keyboard Accelerator: (none)
.head 7 -                                                                       Status Text: 
.head 7 +                                                                       Menu Settings 
.head 8 -                                                                       Enabled when: 
.head 8 -                                                                       Checked when: 
.head 7 +                                                                       Menu Actions 
.head 8 -                                                                       Call SalWaitCursor( TRUE )
.head 8 +                                                                       If SalModalDialog( dlgGetBundlesDetails, hWndForm )
.head 9 -                                                                       Call SalWaitCursor( TRUE )
.head 9 -                                                                       Call PopNumber( nYear, TRUE )
.head 9 -                                                                       Call PopNumber( nType, TRUE )
.head 9 -                                                                       Set nNumItems = 0
.head 9 +                                                                       If nType = nSelectedItems
.head 10 -                                                                       Set nNumItems = 0
.head 10 -                                                                       Set saItemNos[ nNumItems ] = ''
.head 10 -                                                                       Set nRow = TBL_MinRow
.head 10 +                                                                       While SalTblFindNextRow( tblStock, nRow, ROW_Selected, 0 )
.head 11 -                                                                       Call SalTblFetchRow( tblStock, nRow )
.head 11 -                                                                       Set saItemNos[ nNumItems ] = SalNumberToStrX( tblStock.colItemNo, 0 )
.head 11 -                                                                       Set nNumItems = nNumItems + 1
.head 11 -                                                                       Set saItemNos[ nNumItems ] = ''

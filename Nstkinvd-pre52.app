.head 8 -  Set sSQLPopHandle = '
SELECT
	Item_No,
	Tree_Type,
	Cult_Desc,
	Root_Desc,
	Generic_Stock_Item,
	Allocated_Flag
FROM
	Stock_Item si,
	Stock_Item_Sale sis
WHERE
	si.Item_No = sis.Item_No and
	Year_Of_Sale = :1 
	'

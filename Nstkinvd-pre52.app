.head 8 +  Message Actions
.head 9 +  On PAM_clsTBL_CHECKROWNEW
.head 10 -  Call ExistsItemByItemFields( colTreeType, colCultId, colRootId, colGenericFlag, bExists, SH_cls_Execute )
.head 10 +  If bExists
.head 11 -  Call ErrorMessage( 'This stock item already exists!', hWndForm, lParam )
.head 11 -  Return FALSE
.head 10 +  Else
.head 11 -  Call GetNextNewItemNo( colItemNo, SH_cls_Execute )
.head 11 +  If SalIsNull( hWndItem )
.head 12 -  Set colItemNo = 1
.head 11 -  Call GetTreeTypeDenormDets( colTreeType, colTreeTypeDesc, colTypeDescription, SH_cls_Execute )
.head 11 -  Call GetCultivarDenormDets( colCultId, colVarietyType, colUpperVariety, colCultDesc, colCVNotSale, colCVNPA, SH_cls_Execute )
.head 11 -  Call GetRootstockDenormDets( colRootId, colRootDesc, colRTNotSale, colRTNPA, SH_cls_Execute )
.head 11 +  ! 11/05/04 (PXD) If NOT colTypeDescription = 'Orchard'
.head 12 -  Call SendNewItemEmailNotification('
Variety = '|| colUpperVariety ||'
Cultivar = '|| colCultDesc ||'
Rootstock = '|| colRootDesc ||'
Size = '|| colTypeDescription ||'
Season = '|| SalNumberToStrX( ccSeasonYear.GetSeasonYear (), 0 ) )
.head 11 +  If NOT colTypeDescription = 'Orchard'
AND NOT colTypeDescription = 'Potting'
AND NOT colTypeDescription = 'Trial Trees'
.head 12 -  Call SendNewItemEmailNotification('
Variety = '|| colUpperVariety ||'
Cultivar = '|| colCultDesc ||'
Rootstock = '|| colRootDesc ||'
Size = '|| colTypeDescription ||'
Season = '|| SalNumberToStrX( ccSeasonYear.GetSeasonYear (), 0 ) )
.head 11 -  Return TRUE
.head 9 +  On PAM_clsTBL_CHECKROWEDITED
.head 10 -  Call GetTreeTypeDenormDets( colTreeType, colTreeTypeDesc, colTypeDescription, SH_cls_Execute )
.head 10 -  Call GetCultivarDenormDets( colCultId, colVarietyType, colUpperVariety, colCultDesc, colCVNotSale, colCVNPA, SH_cls_Execute )
.head 10 -  Call GetRootstockDenormDets( colRootId, colRootDesc, colRTNotSale, colRTNPA, SH_cls_Execute )
.head 10 -  Return TRUE
.head 9 +  On PAM_clsTBL_CHECKROWDELETED
.head 10 -  Call CheckItemOnOrder( colItemNo, bExists, SH_cls_Execute )
.head 10 +  If bExists
.head 11 -  Call ErrorMessage( 'This stock item still has orders against it.. Please delete these first!', hWndForm, lParam )
.head 11 -  Return FALSE
.head 10 -  Call ExistsItemOnItemSale( colItemNo, bExists, SH_cls_Execute )
.head 10 +  If bExists
.head 11 -  Call ErrorMessage( 'This stock item still has inventory years against it.. Please delete these first!', hWndForm, lParam )
.head 11 -  Return FALSE
.head 10 -  Call ExistsItemOnScionEvalLocation( colItemNo, bExists, SH_cls_Execute )
.head 10 +  If bExists
.head 11 -  Call ErrorMessage( 'This stock item is still growing on Scion Eval. Please delete these first!', hWndForm, lParam )
.head 11 -  Return FALSE
.head 10 -  Call ExistsItemOnGrowSaleLocation( colItemNo, bExists, SH_cls_Execute )
.head 10 +  If bExists
.head 11 -  Call ErrorMessage( 'This stock item is still growing at a location. Please delete these first!', hWndForm, lParam )
.head 11 -  Return FALSE
.head 10 -  Return TRUE
.head 9 +  On PAM_clsTBL_ROWINSERTED
.head 10 -  Return SalSendMsg( hWndForm, PAM_clsNSTKINVD_CREATEINVYEAR, 1, lParam )
.head 9 +  On PAM_clsTBL_DATAVAL
.head 10 +  If SalIsNull( colTreeType )
.head 11 -  Call ErrorMessage( 'Invalid tree type! Please SELECT a valid one.', hWndForm, lParam )
.head 11 -  Return FALSE
.head 10 +  If SalIsNull( colCultId ) AND SalIsNull( colRootId )
.head 11 -  Call ErrorMessage( 'Invalid cultivar and rootstock! Please SELECT valid ones.', hWndForm, lParam )
.head 11 -  Return FALSE
.head 10 -  Return TRUE
.head 9 +  On PAM_cls_SETINSTANCEVARS
.head 10 -  Set colItemNo.bSelectForCSV = TRUE

.head 7 -  Set sSql = "
UPDATE 
	Customer_Order
SET 
	Conf_Amt = Ordered_Amount,
    	Alloc_Flag = 'Y'
WHERE
  	Year_Of_Sale = :2 AND
  	Conf_Amt IS NULL AND
  	(
    	:1 = Stock_Item_No OR
    	:1 = Subs_Item_No
  	) "
.head 7 -  Set sName = '3004AllocItemOrd'

.head 7 -  ! moved fnCalculateBarCode out to itemfunc.apl
.head 7 +  ! Function: fnCalculateBarCode
.head 8 -  Description: Converts a numeric item code to a string.  Then evaluates it's length
and adds as many 0 as required until string length is 5.
Once that is done the item no is concatenated with the item no and the check digit calculated.
.head 8 +  Returns
.head 9 -  String:
.head 8 +  Parameters
.head 9 -  Number: npItemNo
.head 8 -  Static Variables
.head 8 +  Local variables
.head 9 -  String: sItemNo
.head 9 -  Number: nCount
.head 9 -  String: sPreliminaryValue
.head 9 -  Number: nBarCodeNumbers[*]
.head 9 -  Number: nArrayUpper
.head 9 -  Number: nStepOneResult
.head 9 -  Number: nStepThreeResult
.head 9 -  Number: nCheckDigit
.head 9 -  Number: nStepTwoResult
.head 8 +  Actions
.head 9 -  ! Convert numeric item no to string
.head 9 -  Set sItemNo =  SalNumberToStrX( npItemNo, 0 )
.head 9 -  ! Add as many 0's as are needed to pad the length out to 5 characters
.head 9 +  While SalStrLength( sItemNo ) < 5
.head 10 -  Set sItemNo = '0' || sItemNo
.head 9 -  ! Concatenate company number with item no.
93 represents country
17036 represents company number
.head 9 -  Set sPreliminaryValue = '9317036' || sItemNo
.head 9 -  Set nCount = 0
.head 9 -  ! The following while loop goes through the preliminary string extracting all characters
one by one as numbers into an array. Eg if string was 123456789012 then the characters would be extracted
as follows:   nBarCodeNumbers[0] = 1,nBarCodeNumbers[1] = 2,nBarCodeNumbers[2] = 3
.head 9 +  While nCount <= 11
.head 10 -  Set nBarCodeNumbers[nCount] = SalStrToNumber( SalStrMidX( sPreliminaryValue, nCount, 1 ) )
.head 10 -  Set nCount = nCount + 1
.head 9 -  ! First step in check digit calculation requires all alternate number starting from the right be
added together and then multiplied by three.
.head 9 -  Call SalArrayGetUpperBound( nBarCodeNumbers, 1, nArrayUpper )
.head 9 -  ! Step 1. Starting with the first number on the right, add all the alternate numbers.
Multiply the result by three.
.head 9 -  Set nCount = nArrayUpper
.head 9 +  While nCount >= 0
.head 10 -  Set nStepOneResult = nStepOneResult + nBarCodeNumbers[nCount]
.head 10 -  Set nCount = nCount - 2
.head 9 -  Set nStepOneResult = nStepOneResult * 3
.head 9 -  ! Step 2. Starting with the second number on the right add all the alternate numbers
.head 9 -  Set nCount = nArrayUpper - 1
.head 9 +  While nCount >= 0
.head 10 -  Set nStepTwoResult = nStepTwoResult + nBarCodeNumbers[nCount]
.head 10 -  Set nCount = nCount - 2
.head 9 -  ! Step 3. Add the results of step one and step two together
.head 9 -  Set nStepThreeResult = nStepOneResult + nStepTwoResult
.head 9 -  ! Step 4. The number needed to bring nStepThreeResult to the next multiple of 10 becomes the check digit
.head 9 -  ! In the following code the call to SalNumberMod will return the number left over after dividing by ten.
! To workout the check digit simply take that value from 10.
.head 9 -  Set nCheckDigit = 10 - SalNumberMod( nStepThreeResult, 10 )
.head 9 +  If nCheckDigit = 10
.head 10 -  Set nCheckDigit = 0
.head 9 -  Set sPreliminaryValue = sPreliminaryValue || SalNumberToStrX( nCheckDigit, 0 )
.head 9 -  Return sPreliminaryValue

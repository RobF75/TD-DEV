.head 8 +  On PAM_clsPB_CLICK
.head 9 -  Set clsfrmStockItems.tblStockItems.nYear = ccSeasonYear.GetSeasonYear()
.head 9 -  Call SalSendMsg( tblStockItems, PAM_clsTBL_POPFROMSQL, 0, SalHStringToNumber( "SELECT
	item_no,
	tree_type_desc,
	cult_desc,
	root_desc,
	allocated_flag
INTO
	:clsfrmQueryStockItems.tblStockItems.colItemNo, 
	:clsfrmQueryStockItems.tblStockItems.colTreeTypeDesc, 
	:clsfrmQueryStockItems.tblStockItems.colCultDesc, 
	:clsfrmQueryStockItems.tblStockItems.colRootDesc, 
	:clsfrmQueryStockItems.tblStockItems.colAllocFlag
FROM
	stock_item si,
	stock_item_sale sis
WHERE
	si.item_no = sis.stock_item_no and
	allocated_flag = 'N' and
	year_of_sale = :frmStock.tblStockItems.nYear
ORDER BY
	Variety_Type,
	Variety,
	Cult_desc,
	Root_Desc ") )

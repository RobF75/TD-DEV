.head 3 +  Function: StrArrayFetchStr ! __Exported
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: saStringArray[*]
.head 5 -  ! nArrayCount = number of elements or ARRAY_Null_Terminated constant
.head 5 -  Number: nArrayCount
.head 5 -  Receive String: sGotString
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  Number: nPos
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case ARRAY_Reset
.head 7 -  Set nPos = -1
.head 7 -  Return TRUE
.head 6 +  Case ARRAY_FetchNext
.head 7 -  Set nPos = nPos + 1
.head 7 +  If nArrayCount = ARRAY_Null_Terminated
.head 8 +  If saStringArray[ nPos ] = ''
.head 9 -  Set sGotString = ''
.head 9 -  Set nPos = nPos - 1
.head 9 -  Return FALSE
.head 8 +  Else
.head 9 -  Set sGotString = saStringArray[ nPos ]
.head 9 -  Return TRUE
.head 7 +  Else
.head 8 +  If nPos < nArrayCount
.head 9 -  Set sGotString = saStringArray[ nPos ]
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Set sGotString = ''
.head 9 -  Set nPos = nPos - 1
.head 9 -  Return FALSE
.head 6 +  Case ARRAY_FetchPrevious
.head 7 -  Set nPos = nPos - 1
.head 7 +  If nPos < 0
.head 8 -  Set sGotString = ''
.head 8 -  Set nPos = nPos + 1
.head 8 -  Return FALSE
.head 7 +  Else
.head 8 -  Set sGotString = saStringArray[ nPos ]
.head 8 -  Return TRUE
.head 6 +  Case ARRAY_FetchLast
.head 7 +  If nArrayCount = ARRAY_Null_Terminated
.head 8 -  Set nPos = StrArrayNullEndFindLastPos( saStringArray )
.head 8 -  Set sGotString = saStringArray[ nPos ]
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Set nPos = nArrayCount -1
.head 8 -  Set sGotString = saStringArray[ nPos ]
.head 8 -  Return TRUE
.head 6 +  Case ARRAY_FetchFirst
.head 7 -  Set nPos = 0
.head 7 -  Set sGotString = saStringArray[ nPos ]
.head 7 -  Return TRUE

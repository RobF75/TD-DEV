.head 3 +  Function: LoadPictureIntoLongString ! __Exported
.head 4 -  Description: Function accepts a picture file name and retuns a long string loaded
with the contents of the picture file.
SAMPLE use:
On SAM_ReportStart
	Call SalReportSetObjectVar ( hWndReport, 'pLogo', fLoadPictureIntoLongString( 'logo.bmp' )
.head 4 +  Returns
.head 5 -  Long String:
.head 4 +  Parameters
.head 5 -  String: sPicFileName
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  File Handle: fhPictureFile
.head 5 -  Number: nFileSize
.head 5 -  Long String: lsPicture
.head 4 +  Actions
.head 5 -  Set lsPicture = ''
.head 5 +  If SalFileOpen( fhPictureFile, sPicFileName, OF_Read )
.head 6 -  Call SalFileSeek( fhPictureFile, 0, FILE_SeekEnd )
.head 6 -  Set nFileSize = SalFileTell( fhPictureFile )
.head 6 -  Call SalFileSeek( fhPictureFile, 0, FILE_SeekBegin )
.head 6 -  Call SalFileRead( fhPictureFile, lsPicture, nFileSize )
.head 6 -  Call SalFileClose( fhPictureFile )
.head 5 -  Return lsPicture
.head 3 +  Function: ConvertStrHexToStrBinX ! __Exported
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  String:
.head 4 +  Parameters
.head 5 -  String: sHex
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nStrHexLength
.head 5 -  String: sHexChar
.head 5 -  String: sBinChar
.head 5 -  Number: nPos
.head 5 -  Number: nDecChar
.head 5 -  String: sBin
.head 4 +  Actions
.head 5 -  Set nStrHexLength = SalStrLength( sHex )
.head 5 -  Set sBin = ''
.head 5 -  Set nPos = 0
.head 5 +  While nPos < nStrHexLength
.head 6 -  !
.head 6 -  Set sHexChar = SalStrUpperX( SalStrMidX( sHex, nPos, 1 ) )
.head 6 +  If sHexChar = 'A'
.head 7 -  Set nDecChar = 10
.head 6 +  Else If sHexChar = 'B'
.head 7 -  Set nDecChar = 11
.head 6 +  Else If sHexChar = 'C'
.head 7 -  Set nDecChar = 12
.head 6 +  Else If sHexChar = 'D'
.head 7 -  Set nDecChar = 13
.head 6 +  Else If sHexChar = 'E'
.head 7 -  Set nDecChar = 14
.head 6 +  Else If sHexChar = 'F'
.head 7 -  Set nDecChar = 15
.head 6 +  Else
.head 7 -  Set nDecChar = SalStrToNumber( sHexChar )
.head 6 -  !
.head 6 -  Set sBinChar = ''
.head 6 +  While nDecChar > 0
.head 7 +  If SalNumberMod( nDecChar, 2 ) = 0
.head 8 -  Set sBinChar = '0' || sBinChar
.head 7 +  Else
.head 8 -  Set sBinChar = '1' || sBinChar
.head 7 -  Set nDecChar = SalNumberTruncate( nDecChar / 2, 4, 0 )
.head 6 -  !
.head 6 -  Call StringStartPad( sBinChar, '0', 4 )
.head 6 -  Set sBin = sBin || sBinChar
.head 6 -  Set nPos = nPos + 1
.head 5 -  Return sBin
.head 3 -  ! Belwo are not exported
.head 3 +  Function: OurWaitCursor
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Boolean: bOn
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Call OurWaitCursorOverride( bOn, TRUE )
.head 5 -  ! Call OurWaitCursorOverride( bOn, FALSE )
.head 3 +  Function: OurWaitCursorOverride
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Boolean: bOn
.head 5 -  Boolean: bOverride
.head 4 +  Static Variables
.head 5 -  Number: nWaitCount
.head 5 -  Boolean: bOverriden
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If bOverride
.head 6 +  If bOn
.head 7 -  Call SalWaitCursor( TRUE )
.head 6 +  Else
.head 7 -  Call SalWaitCursor( FALSE )
.head 6 -  Set bOverriden = TRUE
.head 5 +  Else
.head 6 +  If bOn
.head 7 +  If NOT nWaitCount > 0 OR bOverriden
.head 8 -  Call SalWaitCursor( TRUE )
.head 7 -  Set nWaitCount = nWaitCount + 1
.head 6 +  Else
.head 7 -  Set nWaitCount = nWaitCount - 1
.head 7 +  If NOT nWaitCount > 0 OR bOverriden
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 -  Set bOverriden = FALSE

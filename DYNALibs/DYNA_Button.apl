.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Set nStates = 3
.head 6 -  Set nStartState = 1
.head 6 -  Set nToggle = 1
.head 6 -  Set sPicFilePath = OurGetIniFileParameter( 'GENERAL', 'IconsPath', '' )
.head 6 -  Set sPicFile1st = ''
.head 6 -  Set sPicFile2nd = ''
.head 6 -  Set sPicFile3rd = ''
.head 6 -  Call SalSendMsg( hWndItem, PAM_cls_SETINSTANCEVARS, wParam, lParam )
.head 6 -  Set nToggle = nStartState
.head 6 -  Set sPicFile1st = sPicFilePath || '\\' || sPicFile1st
.head 6 -  Set sPicFile2nd = sPicFilePath || '\\' || sPicFile2nd
.head 6 -  Set sPicFile3rd = sPicFilePath || '\\' || sPicFile3rd
.head 6 +  If nToggle = 1
.head 7 -  Call SalPicSetFile( hWndItem, sPicFile1st )
.head 6 +  Else If nToggle = 2
.head 7 -  Call SalPicSetFile( hWndItem, sPicFile2nd )
.head 6 +  Else
.head 7 -  Call SalPicSetFile( hWndItem, sPicFile3rd )
.head 6 +  If sToolTipText != ''
.head 7 -  Call SetTip( sToolTipText )
.head 5 +  On SAM_Click
.head 6 -  Call OurWaitCursor( TRUE )
.head 6 +  If nStates = 2
.head 7 +  If nToggle = 1
.head 8 -  Set nLastToggle = nToggle
.head 8 -  Set nToggle = nToggle + 1
.head 8 -  Call SalPicSetFile( hWndItem, sPicFile2nd )
.head 7 +  Else
.head 8 -  Set nLastToggle = nToggle
.head 8 -  Set nToggle = nToggle - 1
.head 8 -  Call SalPicSetFile( hWndItem, sPicFile1st )
.head 6 +  Else
.head 7 +  If nToggle = 1
.head 8 -  Set nLastToggle = nToggle
.head 8 -  Set nToggle = nToggle + 1
.head 8 -  Call SalPicSetFile( hWndItem, sPicFile2nd )
.head 7 +  Else If nToggle = 2
.head 8 +  If nLastToggle = 1
.head 9 -  Set nLastToggle = nToggle
.head 9 -  Set nToggle = nToggle + 1
.head 9 -  Call SalPicSetFile( hWndItem, sPicFile3rd )
.head 8 +  Else
.head 9 -  Set nLastToggle = nToggle
.head 9 -  Set nToggle = nToggle - 1
.head 9 -  Call SalPicSetFile( hWndItem, sPicFile1st )
.head 7 +  Else
.head 8 -  Set nLastToggle = nToggle
.head 8 -  Set nToggle = nToggle - 1
.head 8 -  Call SalPicSetFile( hWndItem, sPicFile2nd )
.head 6 -  Call SalSendMsg( hWndItem, PAM_clsPIC_STATECLICK, nToggle, 0 )
.head 6 -  Call OurWaitCursor( FALSE )

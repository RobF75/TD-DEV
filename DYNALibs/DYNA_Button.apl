.head 4 -  Functions
.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Set nAppearanceOnClick = PB_Disable
.head 6 -  Set nAppearanceOnCreate = PB_Enable
.head 6 -  Set bDoubleLineTitle = FALSE
.head 6 -  Set bDoubleClickOK = TRUE
.head 6 -  Set sPicture = STRING_Null
.head 6 -  Call SalSendMsg( hWndItem, PAM_cls_SETINSTANCEVARS, 0, 0 )
.head 6 +  Select Case nAppearanceOnCreate
.head 7 +  Case PB_Disable
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsPB_DISABLE, 0, 0 )
.head 8 -  Break
.head 7 +  Case PB_Nothing
.head 8 -  Break
.head 7 +  Default
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsPB_ENABLE, 0, 0 )
.head 8 -  Break
.head 6 +  If sPicFile != STRING_Null
.head 7 -  Call GetRegistryValue( 'WINDOW SETTINGS', sPicFile, sPicture, '' )
.head 7 -  Call SalPicSetFile( hWndItem, sPicture )
.head 6 -  Call SalPicSetFit( hWndItem, PIC_FitBestFit, 0, 0 )
.head 6 +  If bDoubleLineTitle
.head 7 -  Call SetWindowLongA ( hWndItem, GWL_STYLE, GetWindowLongA (hWndItem, GWL_STYLE) | BS_MULTILINE )
.head 6 +  If sToolTipText != ''
.head 7 -  Call SetTip( sToolTipText )
.head 6 +  If sStatusBarText != ''
.head 7 -  Call SetStatusText( sStatusBarText )
.head 6 -  Call GetRegistryValue( 'GENERAL', GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndNULL ) || '_DefaultDoubleClickButton', sDefaultDoubleClickButton, '' )
.head 6 +  If sDefaultDoubleClickButton = GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndItem ) 
.head 7 -  Call SalSendMsg( hWndForm, PAM_cls_SETDEFDBLCLICKBUTTON, 0, SalWindowHandleToNumber( hWndItem ) )
.head 6 -  Call GetRegistryValue( 'GENERAL', GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndNULL ) || '_DefaultRightClickButton', sDefaultRightClickButton, '' )
.head 6 +  If sDefaultRightClickButton = GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndItem ) 
.head 7 -  Call SalSendMsg( hWndForm, PAM_cls_SETDEFRIGHTCLICKBUTTON, 0, SalWindowHandleToNumber( hWndItem ) )
.head 5 +  On WM_LBUTTONDBLCLK
.head 6 -  Set __ibDoubleClicked = TRUE
.head 5 +  On WM_LBUTTONUP
.head 6 +  If __ibDoubleClicked = TRUE
.head 7 -  Set __ibOKToClick = FALSE
.head 7 -  Set __ibDoubleClicked = FALSE
.head 6 +  Else
.head 7 -  Set __ibOKToClick = TRUE
.head 5 +  On SAM_Click
.head 6 -  Call OurWaitCursor( TRUE )
.head 6 +  Select Case nAppearanceOnClick
.head 7 +  Case PB_Hide
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsPB_HIDE, 0, 0 )
.head 8 -  Break
.head 7 +  Case PB_Nothing
.head 8 -  Break
.head 7 +  Default
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsPB_DISABLE, 0, 0 )
.head 8 -  Break
.head 6 +  If NOT bDoubleClickOK
.head 7 +  If __ibOKToClick
.head 8 -  Set bClickReturn = SalSendMsg( hWndItem, PAM_clsPB_CLICK, wParam, lParam )
.head 6 +  Else
.head 7 -  Set bClickReturn = SalSendMsg( hWndItem, PAM_clsPB_CLICK, wParam, lParam )
.head 6 +  Select Case nAppearanceOnClick
.head 7 +  Case PB_Hide
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsPB_SHOW, 0, 0 )
.head 8 -  Break
.head 7 +  Case PB_Nothing
.head 8 -  Break
.head 7 +  Default
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsPB_ENABLE, 0, 0 )
.head 8 -  Break
.head 6 -  Call OurWaitCursor( FALSE )
.head 6 -  Return bClickReturn
.head 5 +  On PAM_clsPB_CLICK
.head 6 -  Call SalMessageBox( 'This action is not implemented as yet!', 'NOTE', MB_Ok )
.head 5 -  !
.head 5 +  On PAM_clsPB_ENABLE
.head 6 -  Return SalEnableWindow( hWndItem )
.head 5 +  On PAM_clsPB_DISABLE
.head 6 -  Return SalDisableWindow( hWndItem )
.head 5 +  On PAM_clsPB_SHOW
.head 6 -  Return SalShowWindow( hWndItem )
.head 5 +  On PAM_clsPB_HIDE
.head 6 -  Return SalHideWindow( hWndItem )
.head 5 +  On PAM_clsPB_PBSTATUS
.head 6 -  Set __hWndCallingForm = SalNumberToWindowHandle( wParam )
.head 6 -  Set __nhWndItem = SalWindowHandleToNumber( hWndItem )
.head 6 +  If SalSendMsg( __hWndCallingForm, PAM_clsPB_PBSTATUS, 0, __nhWndItem )
.head 7 -  Call SalSendMsg( hWndItem, PAM_clsPB_HIDE, 0, 0 )
.head 6 +  Else
.head 7 -  Call SalSendMsg( hWndItem, PAM_clsPB_SHOW, 0, 0 )
.head 5 +  On WM_RBUTTONUP
.head 6 -  Call SalTrackPopupMenu( hWndItem, 'Buttons', TPM_CursorX | TPM_CursorY, 0, 0 )
.head 5 +  On PAM_clsPB_SETDEFAULT
.head 6 -  Call OurSetIniFileParameter( 'GENERAL', GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndNULL ) || '_DefaultDoubleClickButton', GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndItem ) )
.head 6 -  Call SalSendMsg( hWndForm, PAM_cls_SETDEFDBLCLICKBUTTON, 0, SalWindowHandleToNumber( hWndItem ) )

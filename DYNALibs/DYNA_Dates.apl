.head 5 -  Return SalNumberToStrX( dtDate - SalDateYearBegin( dtDate ) + 1, 0 ) || SalStrMidX( SalNumberToStrX( SalDateYear( dtDate ), 0 ), 3, 1 )
.head 3 +  Function: DateTimeToStrHHMMSS ! __Exported
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  String:
.head 4 +  Parameters
.head 5 -  Date/Time: dtDateTime
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sHour
.head 5 -  String: sMin
.head 5 -  String: sSec
.head 4 +  Actions
.head 5 -  Set sHour = SalNumberToStrX( SalDateHour( dtDateTime ), 0 )
.head 5 -  Call StringStartPad( sHour, '0', 2 )
.head 5 -  Set sMin = SalNumberToStrX( SalDateMinute( dtDateTime ), 0 )
.head 5 -  Call StringStartPad( sMin, '0', 2 )
.head 5 -  Set sSec = SalNumberToStrX( SalDateSecond( dtDateTime ), 0 )
.head 5 -  Call StringStartPad( sSec, '0', 2 )
.head 5 -  Return sHour || sMin || sSec
.head 3 +  Function: DateMonthEnd ! __Exported
.head 4 -  Description: Returns the last day of the month given in date/time field
.head 4 +  Returns
.head 5 -  Date/Time:
.head 4 +  Parameters
.head 5 -  Date/Time: dtGivenDate
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Date/Time: dtTmpDate
.head 5 -  Number: nDay
.head 5 -  Number: nMonth
.head 5 -  Number: nYear
.head 4 +  Actions
.head 5 -  Set nDay = SalDateDay( dtGivenDate )
.head 5 -  Set nMonth = SalDateMonth( dtGivenDate )
.head 5 -  Set nYear = SalDateYear( dtGivenDate )
.head 5 +  If nMonth < 12
.head 6 -  Set nMonth = nMonth + 1
.head 5 +  Else
.head 6 -  Set nMonth = 1
.head 6 -  Set nYear = nYear + 1
.head 5 -  Set dtTmpDate = SalDateConstruct( nYear, nMonth, nDay, 0, 0, 0 )
.head 5 -  Set dtTmpDate = SalDateMonthBegin( dtTmpDate ) - 1
.head 5 -  Return dtTmpDate
.head 3 +  Function: GetMonthBegEndDays ! __Exported
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Number: nMonth
.head 5 -  Number: nYear
.head 5 -  Receive Number: nBegDay
.head 5 -  Receive Number: nEndDay
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Set nBegDay = 1
.head 5 -  Set nEndDay = SalDateDay( DateMonthEnd( SalDateConstruct( nYear, nMonth, 1, 0, 0, 0 ) ) )
.head 3 +  Function: DateCurrentPlusDays ! __Exported
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Date/Time:
.head 4 +  Parameters
.head 5 -  Number: nDays
.head 5 -  Date/Time: dtGivenDate
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Date/Time: dtTmpDate
.head 5 -  Number: nDay
.head 5 -  Number: nMonth
.head 5 -  Number: nYear
.head 4 +  Actions
.head 5 -  Set nDay = SalDateDay( dtGivenDate )
.head 5 -  Set nMonth = SalDateMonth( dtGivenDate )
.head 5 -  Set nYear = SalDateYear( dtGivenDate )
.head 5 +  If nMonth = 2
.head 6 +  If nDay + nDays < 27
.head 7 -  Set dtTmpDate = SalDateConstruct( nYear, nMonth, nDay + nDays, 0, 0, 0 )
.head 6 +  Else
.head 7 -  Set dtTmpDate = SalDateConstruct( nYear, nMonth + 1, nDays - (27 - nDay) , 0, 0, 0 )
.head 5 +  Else
.head 6 +  If nDay + nDays < 30
.head 7 -  Set dtTmpDate = SalDateConstruct( nYear, nMonth, nDay + nDays, 0, 0, 0 )
.head 6 +  Else
.head 7 +  If nMonth = 12
.head 8 -  Set dtTmpDate = SalDateConstruct( nYear + 1, 1, nDays - (30 - nDay) , 0, 0, 0 )
.head 7 +  Else
.head 8 -  Set dtTmpDate = SalDateConstruct( nYear, nMonth + 1, nDays - (30 - nDay) , 0, 0, 0 )
.head 5 -  Return dtTmpDate
.head 3 +  Function: DateYearEnd ! __Exported
.head 4 -  Description: Returns the last day of the Year given in date/time field
.head 4 +  Returns
.head 5 -  Date/Time:
.head 4 +  Parameters
.head 5 -  Date/Time: dtGivenDate
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Date/Time: dtTmpDate
.head 5 -  Number: nDay
.head 5 -  Number: nMonth
.head 5 -  Number: nYear
.head 4 +  Actions
.head 5 -  Set nDay = SalDateDay( dtGivenDate )
.head 5 -  Set nMonth = SalDateMonth( dtGivenDate )
.head 5 -  Set nYear = SalDateYear( dtGivenDate ) + 1
.head 5 -  Set dtTmpDate = SalDateConstruct( nYear, nMonth, nDay, 0, 0, 0 )
.head 5 -  Set dtTmpDate = SalDateYearBegin( dtTmpDate ) - 1
.head 5 -  Return dtTmpDate
.head 3 +  Function: SubtractMonthsFromMonth ! __Exported
.head 4 -  Description: Assumes the first parameter is a month and the second is the number
of months to subtract.  month parameter is assumed to be in the
month range 1..12 and NO range checking is performed
.head 4 +  Returns
.head 5 -  Number:
.head 4 +  Parameters
.head 5 -  Number: nMonth
.head 5 -  Number: nSubMonths
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nCount
.head 4 +  Actions
.head 5 -  Set nCount = nSubMonths
.head 5 +  While nCount > 0
.head 6 -  Set nMonth = nMonth - 1
.head 6 -  Set nCount = nCount - 1
.head 6 +  If nMonth < 1
.head 7 -  Set nMonth = 12
.head 5 -  Return nMonth
.head 3 +  Function: DaysDiffBetweenMonths ! __Exported
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Number:
.head 4 +  Parameters
.head 5 -  Number: nFirstMonth
.head 5 -  Number: nSecondMonth
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nMonths
.head 4 +  Actions
.head 5 +  If nFirstMonth < nSecondMonth
.head 6 -  Set nMonths = nSecondMonth - nFirstMonth
.head 5 +  Else If nFirstMonth = nSecondMonth
.head 6 -  Set nMonths = 0
.head 5 +  Else
.head 6 -  Set nMonths = nFirstMonth - nSecondMonth
.head 5 -  Return nMonths
.head 3 +  Function: AdjustYearOfSaleToYear ! __Exported
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Receive Number: nYear
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If nYear < 100 AND nYear >= 50
.head 6 -  Set nYear = nYear + 1900
.head 5 +  Else If nYear >= 0 AND nYear < 50
.head 6 -  Set nYear = nYear + 2000

.head 3 +  Function: AddDateToDate  ! __Exported
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Date/Time: dtOriginalDate
.head 5 -  Number: nAddYears
.head 5 -  Number: nAddMonths
.head 5 -  Number: nAddDays
.head 5 -  Number: nAddHours
.head 5 -  Number: nAddMinutes
.head 5 -  Number: nAddSeconds
.head 5 -  Receive Date/Time: dtNewDate
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nOldYears
.head 5 -  Number: nOldMonths
.head 5 -  Number: nOldDays
.head 5 -  Number: nOldHours
.head 5 -  Number: nOldMinutes
.head 5 -  Number: nOldSeconds
.head 5 -  Number: nNewYears
.head 5 -  Number: nNewMonths
.head 5 -  Number: nNewDays
.head 5 -  Number: nNewHours
.head 5 -  Number: nNewMinutes
.head 5 -  Number: nNewSeconds
.head 5 -  Boolean: bLeapYear
.head 5 -  Date/Time: dtTempNewDate
.head 4 +  Actions
.head 5 +  If (nAddMonths <= 12) and (nAddDays <= 31) and (nAddHours <= 24) and (nAddMinutes <= 60) and (nAddMinutes <= 60)
.head 6 -  Set nOldYears = SalDateYear( dtOriginalDate )
.head 6 -  Set nOldMonths = SalDateMonth( dtOriginalDate )
.head 6 -  Set nOldDays = SalDateDay( dtOriginalDate )
.head 6 -  Set nOldHours = SalDateHour( dtOriginalDate )
.head 6 -  Set nOldMinutes = SalDateMinute( dtOriginalDate )
.head 6 -  Set nOldSeconds = SalDateSecond( dtOriginalDate )
.head 6 +  If nAddSeconds > 0
.head 7 +  If (nAddSeconds + nOldSeconds) < 60
.head 8 -  Set nNewSeconds = nAddSeconds + nOldSeconds
.head 7 +  Else
.head 8 -  Set nNewSeconds = nAddSeconds + nOldSeconds - 60
.head 8 -  Set nAddMinutes = nAddMinutes + 1
.head 6 +  Else
.head 7 -  Set nNewSeconds = nOldSeconds
.head 6 +  If nAddMinutes > 0
.head 7 +  If (nAddMinutes + nOldMinutes) < 60
.head 8 -  Set nNewMinutes = nAddMinutes + nOldMinutes
.head 7 +  Else
.head 8 -  Set nNewMinutes = nAddMinutes + nOldMinutes - 60
.head 8 -  Set nAddHours = nAddHours + 1
.head 6 +  Else
.head 7 -  Set nNewMinutes = nOldMinutes
.head 6 +  If nAddHours > 0
.head 7 +  If (nAddHours + nOldHours) < 24
.head 8 -  Set nNewHours = nAddHours + nOldHours
.head 7 +  Else
.head 8 -  Set nNewHours = nAddHours + nOldHours - 24
.head 8 -  Set nAddDays = nAddDays + 1
.head 6 +  Else
.head 7 -  Set nNewHours = nOldHours
.head 6 +  If nAddDays > 0
.head 7 +  Select Case nOldMonths
.head 8 +  Case 2
.head 9 +  If SalNumberMod( nOldYears, 100 )
.head 10 +  If SalNumberMod( nOldYears, 400 )
.head 11 -  Set bLeapYear = TRUE
.head 10 +  Else
.head 11 -  Set bLeapYear = FALSE
.head 9 +  Else
.head 10 +  If SalNumberMod( nOldYears, 4 )
.head 11 -  Set bLeapYear = TRUE
.head 10 +  Else
.head 11 -  Set bLeapYear = FALSE
.head 9 +  If bLeapYear
.head 10 +  If (nAddDays + nOldDays) < 29
.head 11 -  Set nNewDays = nAddDays + nOldDays
.head 10 +  Else
.head 11 -  Set nAddDays = nAddDays + nAddDays - 29
.head 11 -  Set nAddMonths = nAddMonths + 1
.head 9 +  Else
.head 10 +  If (nAddDays + nOldDays) < 28
.head 11 -  Set nNewDays = nAddDays + nOldDays
.head 10 +  Else
.head 11 -  Set nAddDays = nAddDays + nAddDays - 28
.head 11 -  Set nAddMonths = nAddMonths + 1
.head 9 -  Break
.head 8 +  Case 4
.head 9 +  If (nAddDays + nOldDays) < 30
.head 10 -  Set nNewDays = nAddDays + nOldDays
.head 9 +  Else
.head 10 -  Set nAddDays = nAddDays + nOldDays - 30
.head 10 -  Set nAddMonths = nAddMonths + 1
.head 9 -  Break
.head 8 +  Case 6
.head 9 +  If (nAddDays + nOldDays) < 30
.head 10 -  Set nNewDays = nAddDays + nOldDays
.head 9 +  Else
.head 10 -  Set nAddDays = nAddDays + nOldDays - 30
.head 10 -  Set nAddMonths = nAddMonths + 1
.head 9 -  Break
.head 8 +  Case 9
.head 9 +  If (nAddDays + nOldDays) < 30
.head 10 -  Set nNewDays = nAddDays + nOldDays
.head 9 +  Else
.head 10 -  Set nAddDays = nAddDays + nOldDays - 30
.head 10 -  Set nAddMonths = nAddMonths + 1
.head 9 -  Break
.head 8 +  Case 11
.head 9 +  If (nAddDays + nOldDays) < 30
.head 10 -  Set nNewDays = nAddDays + nOldDays
.head 9 +  Else
.head 10 -  Set nAddDays = nAddDays + nOldDays - 30
.head 10 -  Set nAddMonths = nAddMonths + 1
.head 9 -  Break
.head 8 +  Default
.head 9 +  If (nAddDays + nOldDays) < 31
.head 10 -  Set nNewDays = nAddDays + nOldDays
.head 9 +  Else
.head 10 -  Set nAddDays = nAddDays + nOldDays - 31
.head 10 -  Set nAddMonths = nAddMonths + 1
.head 9 -  Break
.head 6 +  Else
.head 7 -  Set nNewDays = nOldDays
.head 6 +  If nAddMonths > 0
.head 7 +  If (nAddMonths + nOldMonths) < 12
.head 8 -  Set nNewMonths = nAddMonths + nOldMonths
.head 7 +  Else
.head 8 -  Set nNewMonths = nAddMonths + nAddMonths - 12
.head 8 -  Set nAddYears = nAddYears + 1
.head 6 +  Else
.head 7 -  Set nNewMonths = nOldMonths
.head 6 +  If nAddYears > 0
.head 7 -  Set nNewYears = nOldYears + nAddYears
.head 6 +  Else
.head 7 -  Set nNewYears = nOldYears
.head 6 +  If nNewDays = 0
.head 7 -  Set nNewDays = 1
.head 6 +  If nNewMonths = 0
.head 7 -  Set nNewMonths = 1
.head 6 -  Set dtTempNewDate = SalDateConstruct( nNewYears, nNewMonths, nNewDays, nNewHours, nNewMinutes, nNewSeconds )
.head 6 -  Set dtNewDate = dtTempNewDate
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 3 +  Function: IsYearLeapYear ! __Exported
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nYear
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If SalNumberMod( nYear, 100 )
.head 6 +  If SalNumberMod( nYear, 400 )
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  Else
.head 6 +  If SalNumberMod( nYear, 4 )
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 3 +  Function: GetJulianDate ! __Exported
.head 4 -  Description: 16/1/2002 PXD - Returns the date in a YYDDD format - E.g 01-Jun-1999 = 99152
.head 4 +  Returns

.head 4 +  Actions 
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT 
  Stock_Item_No, 
  Year_Of_Sale   
FROM 
  Growing_Sale 
WHERE 
  Est_Sale_Date <= SYSDATE "
.head 7 -  Set sName = 'CHECKESTSALE'
.head 7 -  Set sBind = ''
.head 7 -  Set sInto = ':nItemNo, :nYear'
.head 7 -  Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( fcOurHandle.hSqlHandle )
.head 7 -  !
.head 7 +  If fcOurHandle.Execute( )
.head 8 -  Call fcOurHandle.ResultSetCount( nTotalRows )
.head 8 +  If nTotalRows >= nNumRowsToMeter
.head 9 -  Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Calculating Newly Available Stock', nTotalRows )
.head 8 +  Else 
.head 9 -  Set hWndMeter = hWndNULL
.head 8 -  Set nRowCount = 0
.head 8 +  While fcOurHandle.FetchNext( nInd )
.head 9 -  Set nRowCount = nRowCount + 1
.head 9 -  Call SalSendMsg( hWndMeter, PAM_SETPROGRESS, 0, nRowCount )
.head 9 -  Set nItemNos[ 0 ] = nItemNo
.head 9 -  Set nItemNos[ 1 ] = NUMBER_Null 
.head 9 -  Call RecalculateInventoryFigures( nItemNos, nYear, 'SELECTED', SH_cls_Execute )
.head 8 -  Call SalSendMsg( hWndMeter, PAM_END, 0, 0 )
.head 8 -  Return TRUE
.head 7 +  Else 
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call RecalculateInventoryFigures( nItemNos, 0, '', SH_cls_Disconnect )
.head 7 -  Return fcOurHandle.Disconnect( )
.head 3 +  Function: CheckFutureAvail
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  FunctionalVar: fcOurHandle
.head 6 -  Class: hcSqlHandle
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nInd
.head 5 -  Number: nItemNo
.head 5 -  Number: nYear
.head 5 -  Number: nItemNos[*]
.head 5 -  Window Handle: hWndMeter
.head 5 -  Number: nRowCount
.head 5 -  Number: nTotalRows
.head 5 -  !
.head 5 -  Number: nNewItemCount
.head 5 -  Number: nLastLocationId
.head 5 -  Number: nLastItemNo
.head 5 -  Number: nLastYear
.head 5 -  Number: nLocationId
.head 5 -  Number: nBegCount
.head 5 -  Number: nFirstCount
.head 5 -  Number: nSecondCount
.head 5 -  String: sStockType
.head 5 -  Boolean: bFirst
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT 
  Growing_Sale.Location_Id, 
  Growing_Sale.Stock_Item_No, 
  Growing_Sale.Year_Of_Sale, 
  Growing_Sale.Beg_Count, 
  Growing_Sale.First_Count, 
  Growing_Sale.Second_Count, 
  Stock_Item.Stock_Type 
FROM 
  Growing_Sale, 
  Stock_Item  
WHERE 
  Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
  Growing_Sale.Est_Sale_Date <= SYSDATE AND 
  Growing_Sale.Future_Stock = 'Y' AND 
  ( 
    Growing_Sale.Not_For_Sale = 'N' OR 
    Growing_Sale.Not_For_Sale IS NULL 
  ) 
ORDER BY 
  Growing_Sale.Stock_Item_No, 
  Growing_Sale.Year_Of_Sale "
.head 7 -  Set sName = 'CHECKESTSALE'
.head 7 -  Set sBind = ''
.head 7 -  Set sInto = ':nLocationId, :nItemNo, :nYear, :nBegCount, :nFirstCount, :nSecondCount, :sStockType'
.head 7 -  Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( fcOurHandle.hSqlHandle )
.head 7 -  !
.head 7 +  If fcOurHandle.Execute( )
.head 8 -  Call fcOurHandle.ResultSetCount( nTotalRows )
.head 8 +  If nTotalRows >= nNumRowsToMeter
.head 9 -  Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Calculating Newly Available Stock', nTotalRows )
.head 8 +  Else
.head 9 -  Set hWndMeter = hWndNULL
.head 8 -  !
.head 8 -  Set nNewItemCount = 0
.head 8 -  Set nLastLocationId = NUMBER_Null
.head 8 -  Set nLastItemNo = NUMBER_Null
.head 8 -  Set nLastYear = NUMBER_Null
.head 8 -  !
.head 8 -  Set bFirst = TRUE
.head 8 -  Set nRowCount = 0
.head 8 +  While fcOurHandle.FetchNext( nInd )
.head 9 -  !
.head 9 -  Set nRowCount = nRowCount + 1
.head 9 -  Call SalSendMsg( hWndMeter, PAM_SETPROGRESS, 0, nRowCount )
.head 9 -  !
.head 9 +  If nLastItemNo = nItemNo AND nLastYear = nYear
.head 10 +  If nSecondCount >= 0
.head 11 -  Set nNewItemCount = nNewItemCount + nSecondCount
.head 10 +  Else If nFirstCount >= 0
.head 11 -  Set nNewItemCount = nNewItemCount + nFirstCount
.head 10 +  Else
.head 11 -  Set nNewItemCount = nNewItemCount + nBegCount
.head 9 +  Else
.head 10 +  If bFirst
.head 11 -  Set bFirst = FALSE
.head 10 +  Else
.head 11 +  If sStockType = 'C'
.head 12 +  If IncrementSISGradedFigure( nLastItemNo, nLastYear, nNewItemCount, SH_cls_Execute )
.head 13 +  If UpdtGrSaleFutureStock( nLastLocationId, nLastYear, 'N', SH_cls_Execute )
.head 14 -  Call UpdtGrSaleFutureStock( 0, 0, '', SH_cls_Commit )
.head 14 -  Call IncrementSISGradedFigure( 0, 0, 0, SH_cls_Commit )
.head 13 +  Else
.head 14 -  Call IncrementSISGradedFigure( 0, 0, 0, SH_cls_Rollback )
.head 11 -  !
.head 11 -  Set nItemNos[ 0 ] = nLastItemNo
.head 11 -  Set nItemNos[ 1 ] = NUMBER_Null 
.head 11 +  If RecalculateInventoryFigures( nItemNos, nLastYear, 'SELECTED', SH_cls_Execute ) AND NOT sStockType = 'C'
.head 12 +  If UpdtGrSaleFutureStock( nLastLocationId, nLastYear, 'N', SH_cls_Execute )
.head 13 -  Call UpdtGrSaleFutureStock( 0, 0, '', SH_cls_Commit )
.head 10 -  !
.head 10 +  If nSecondCount >= 0
.head 11 -  Set nNewItemCount = nSecondCount
.head 10 +  Else If nFirstCount >= 0
.head 11 -  Set nNewItemCount = nFirstCount
.head 10 +  Else
.head 11 -  Set nNewItemCount = nBegCount
.head 10 -  !
.head 10 -  Set nLastLocationId = nLocationId
.head 10 -  Set nLastItemNo = nItemNo
.head 10 -  Set nLastYear = nYear
.head 8 -  !
.head 8 +  If sStockType = 'C'
.head 9 +  If IncrementSISGradedFigure( nLastItemNo, nLastYear, nNewItemCount, SH_cls_Execute )
.head 10 +  If UpdtGrSaleFutureStock( nLastLocationId, nLastYear, 'N', SH_cls_Execute )
.head 11 -  Call UpdtGrSaleFutureStock( 0, 0, '', SH_cls_Commit )
.head 11 -  Call IncrementSISGradedFigure( 0, 0, 0, SH_cls_Commit )
.head 10 +  Else
.head 11 -  Call IncrementSISGradedFigure( 0, 0, 0, SH_cls_Rollback )
.head 8 -  !
.head 8 -  Set nItemNos[ 0 ] = nLastItemNo
.head 8 -  Set nItemNos[ 1 ] = NUMBER_Null 
.head 8 +  If RecalculateInventoryFigures( nItemNos, nLastYear, 'SELECTED', SH_cls_Execute ) AND NOT sStockType = 'C'
.head 9 +  If UpdtGrSaleFutureStock( nLastLocationId, nLastYear, 'N', SH_cls_Execute )
.head 10 -  Call UpdtGrSaleFutureStock( 0, 0, '', SH_cls_Commit )
.head 8 -  !
.head 8 -  Call SalSendMsg( hWndMeter, PAM_END, 0, 0 )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call RecalculateInventoryFigures( nItemNos, 0, '', SH_cls_Disconnect )
.head 7 -  Call IncrementSISGradedFigure( 0, 0, 0, SH_cls_Disconnect )
.head 7 -  Call UpdtGrSaleFutureStock( 0, 0, '', SH_cls_Disconnect )
.head 7 -  Return fcOurHandle.Disconnect( )
.head 3 +  Function: IncrementSISGradedFigure
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nItemNo
.head 5 -  Number: nYear
.head 5 -  Number: nIncAmount
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  FunctionalVar: fcOurHandle
.head 6 -  Class: hcSqlHandle
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " UPDATE Stock_Item_Sale 
  SET Amt_Graded = Amt_Graded + :3 
  WHERE 
     Stock_Item_No = :1 AND 
     Year_Of_Sale = :2  "
.head 7 -  Set sName = 'INCSISGRDFIG'
.head 7 -  Set sBind = ':nItemNo, :nYear, :nIncAmount'
.head 7 -  Set sInto = ''
.head 7 -  Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( fcOurHandle.hSqlHandle )
.head 7 -  !
.head 7 -  Return fcOurHandle.Execute( )
.head 6 +  Case SH_cls_Commit
.head 7 -  Return fcOurHandle.Commit( )
.head 6 +  Case SH_cls_Rollback
.head 7 -  Return fcOurHandle.Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return fcOurHandle.Disconnect( )

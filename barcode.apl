.head 4 +  Message Actions
.head 5 +  On PAM_CLICK
.head 6 -  Set dfSaleCat = cmbSaleCat
.head 6 +  If SalIsNull( dfOrdAmt )
.head 7 -  Call SalMessageBeep( 0 )
.head 7 +  If IDNO = SalMessageBox( 'Ordered Amount is blank! Do you want to allow this?', 'Warning', MB_YesNo | MB_DefButton2 )
.head 8 -  Call SalSetFocus( dfOrdAmt )
.head 8 -  Return FALSE
.head 6 +  If SalIsNull( dfConfAmt ) AND dfAllocating = 'ALLOCATING'
.head 7 -  Call SalMessageBeep( 0 )
.head 7 +  If IDNO = SalMessageBox( 'Confirmed Amount is blank! Do you want to allow this?', 'Warning', MB_YesNo | MB_DefButton2 )
.head 8 -  Call SalSetFocus( dfConfAmt )
.head 8 -  Return FALSE
.head 6 +  If dfOrdAmt > 10000
.head 7 -  Call SalMessageBeep( 0 )
.head 7 +  If IDNO = SalMessageBox( 'Ordered Amount is greater than 10000! Do you want to allow this?', 'Warning', MB_YesNo | MB_DefButton2 )
.head 8 -  Call SalSetFocus( dfOrdAmt )
.head 8 -  Return FALSE
.head 6 +  If SalIsNull( dfOrderDate )
.head 7 -  Call SalMessageBox( 'Please enter a order date first via the Change Details button!', 'Warning', MB_Ok )
.head 7 -  Call SalSetFocus( pbChangeDetails )
.head 7 -  Return FALSE
.head 6 -  !
.head 6 +  If NOT nBatchLocId > 0
.head 7 +  If sStockType = 'C'
.head 8 -  Call AllocatedPotsLocation( dfItemNo, dfYear, dfOrdAmt, dfConfAmt, naBatchLocationIds, naBatchLocAllocated, nBatchYear, SH_cls_Execute )
.head 8 +  If NOT naBatchLocationIds[ 0 ] > 0
.head 9 -  Call SalMessageBox( 'Cannot allocate a batch! Either none exist or over sold.  Please verify the stock batches before posting this order.', 'Warning', MB_Ok )
.head 9 -  Call SalMessageBeep( 0 )
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Set naBatchLocationIds[ 0 ] = NUMBER_Null
.head 8 -  Set naBatchLocAllocated[ 0 ] = NUMBER_Null
.head 6 +  Else
.head 7 -  Set naBatchLocationIds[ 0 ] = nBatchLocId
.head 7 -  Set naBatchLocationIds[ 1 ] = NUMBER_Null
.head 7 +  If SalIsNull( dfConfAmt )
.head 8 -  Set naBatchLocAllocated[ 0 ] = dfOrdAmt
.head 8 -  Set naBatchLocAllocated[ 1 ] = NUMBER_Null
.head 7 +  Else
.head 8 -  Set naBatchLocAllocated[ 0 ] = dfConfAmt
.head 8 -  Set naBatchLocAllocated[ 1 ] = NUMBER_Null
.head 6 +  If dfAllocating = 'ALLOCATING'
.head 7 -  Set nAmtOrdered = nAmtOrdered + dfConfAmt
.head 6 +  Else
.head 7 -  Set nAmtOrdered = nAmtOrdered + dfOrdAmt
.head 6 +  If NewAddOrder( dfCustNo, dfYear, dfOrderDate, dfItemNo, dfOrdAmt, dfConfAmt, dfOrderBookNo, dfSaleCat, dfSubsOkFlag, naBatchLocationIds, naBatchLocAllocated, nBatchYear, hWndForm, PAM_UPDATE, dtTmp, SH_cls_Execute|nItemCheck )
.head 7 -  Call SalSendMsg( pbClear, SAM_Click, wParam, lParam )
.head 7 -  Set cbSpecialReq = FALSE
.head 7 -  Call SalSendMsgToChildren( hWndForm, PAM_SPECREQUIREMENT, FALSE, 0 )
.head 5 +  On PAM_DATAVAL
.head 6 +  If SalIsNull( hWndItem )
.head 7 -  Call SalMessageBox( 'Please enter a order date first!', 'Warning', MB_Ok )
.head 7 -  Return FALSE
.head 6 +  Else
.head 7 -  Return TRUE
.head 5 +  On SAM_SetFocus
.head 6 -  Call SalMapEnterToTab( FALSE )
.head 5 +  On SAM_KillFocus
.head 6 -  Call SalMapEnterToTab( TRUE )

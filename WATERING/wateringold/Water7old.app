.head 6 -  Set bRepopulateAllowed = TRUE
.head 6 -  Set bReportAllowed = FALSE
.head 6 -  Set bOrderAllowed = FALSE
.head 6 -  Set bPrintFormAllowed = TRUE
.head 6 -  Set bTreeSystem = FALSE
.head 5 +  On SAM_Create
.head 6 -  Call DIG_Open( )
.head 6 -  Set bRunning = TRUE
.head 6 -  Set bRebooting = FALSE
.head 6 -  Set nTimeCheckCount = 0
.head 6 -  Set nCheckEveryNSeconds = SalStrToNumber( OurGetIniFileParameter( 'GENERAL', 'TimerCheckInterval', '10' ) )
.head 6 -  Set nMinSecondsBetweenProgs = SalStrToNumber( OurGetIniFileParameter( 'GENERAL', 'MinSecondsBetweenPrograms', '300' ) )
.head 6 -  Set sRebootHour = OurGetIniFileParameter( 'GENERAL', 'RebootHour', '' )
.head 6 +  If sRebootHour = ''
.head 7 -  Set nRebootHour = NUMBER_Null
.head 6 +  Else
.head 7 -  Set nRebootHour = SalStrToNumber( sRebootHour )
.head 6 -  Call InitialiseIOCard( 'INIT', SH_cls_Execute )
.head 6 -  Call SalTimerSet( hWndForm, 1, 1000 )
.head 6 -  Return SalSendClassMessage( SAM_Create, wParam, lParam )
.head 5 +  On SAM_Destroy
.head 6 +  If NOT bRebooting
.head 7 -  Call SalSendMsg( hWndForm, PAM_clsWATERING_DESTROY, wParam, lParam )
.head 6 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
.head 5 +  On PAM_clsWATERING_DESTROY
.head 6 -  Call DIG_Close( )
.head 6 -  Call SalTimerKill( hWndForm, 1 )
.head 6 -  Call TimeCheckIrrigation( 0, 0, SH_cls_Disconnect )
.head 6 -  Call InitialiseIOCard( '', SH_cls_Disconnect )
.head 6 -  Call LogMaintenance( 0, '', '', 'DISCONNECT' )
.head 6 -  Call SetProgramStatus( 0, '', SH_cls_Disconnect )
.head 6 -  Call SetProgramNextDT( 0, DATETIME_Null, SH_cls_Disconnect )
.head 5 +  On SAM_Timer
.head 6 +  If NOT bRebooting
.head 7 +  If NOT nRebootHour = NUMBER_Null
.head 8 +  If nRebootHour = SalDateHour( SalDateCurrent(  ) )
.head 9 -  Set bRebooting = TRUE
.head 9 -  Call LogMaintenance( 0, 'REBOOT', 'Rebooting at '||DateToStrX( SalDateCurrent(  ) ), 'APPEND' )
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsWATERING_DESTROY, wParam, lParam )
.head 9 -  Call SqlHandlesDisconnectClose(  )
.head 9 -  Call SalPostMsg( hWndForm, PAM_clsWATERING_REBOOT, 0, 0 )
.head 7 +  If bRunning AND NOT bRebooting
.head 8 -  Set dfClock = SalDateCurrent(  )
.head 8 -  Set nTimeCheckCount = nTimeCheckCount + 1
.head 8 +  If nTimeCheckCount >= nCheckEveryNSeconds
.head 9 -  Set nTimeCheckCount = 0
.head 9 -  Call OurWaitCursor( TRUE )
.head 9 -  Call TimeCheckIrrigation( nCheckEveryNSeconds, nMinSecondsBetweenProgs, SH_cls_Execute )
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsWATERING_REFRESHDATA, 0, 0 )
.head 9 -  Call OurWaitCursor( FALSE )
.head 5 +  On SAM_Close
.head 6 +  If bRunning
.head 7 -  Call SalMessageBox( 'Please stop the watering system before exiting the program.', 'NOTE', MB_Ok )
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return SalSendClassMessage( SAM_Close, wParam, lParam )
.head 5 +  On PAM_cls_CLOSE
.head 6 +  If bRunning
.head 7 -  Call SalMessageBox( 'Please stop the watering system before exiting the program.', 'NOTE', MB_Ok )
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return SalSendClassMessage( PAM_cls_CLOSE, wParam, lParam )
.head 5 +  On PAM_clsWATERING_REFRESHDATA
.head 6 +  If cbAutoRefreshScreen
.head 7 -  Call SalSendMsg( tblProgStations, PAM_clsTBL_POPULATE, 0, 0 )
.head 7 -  Call SalSendMsg( tblPrograms, PAM_clsTBL_POPULATE, 0, 0 )
.head 5 +  On PAM_clsTBL_USERACTIONS
.head 6 +  If bRunning
.head 7 +  If wParam = TBL_cls_RePopTable OR wParam = TBL_cls_OrderTable OR wParam = TBL_cls_ClearRow OR wParam = TBL_cls_ZoomTable
.head 8 +  If lParam = GEN_CommingFromPopUp AND NOT hWndFocus = hWndNULL
.head 9 -  Return UserTableActions( hWndFocus, wParam, lParam )
.head 8 +  Else
.head 9 +  If SalModalDialog( dlgTableChoice, hWndForm, sTableChoice )
.head 10 +  If sTableChoice = 'PROGRAMS'
.head 11 -  Return SalSendClassMessage( PAM_clsTBL_USERACTIONS, wParam, lParam )
.head 10 +  Else
.head 11 -  Return UserTableActions( tblProgStations, wParam, lParam )
.head 9 +  Else
.head 10 -  Return FALSE
.head 7 +  Else
.head 8 -  Call SalMessageBox( 'Please stop the watering system before carring out any maintenance.', 'NOTE', MB_Ok )
.head 8 -  Return TRUE
.head 6 +  Else
.head 7 +  If lParam = GEN_CommingFromPopUp AND NOT hWndFocus = hWndNULL
.head 8 -  Return UserTableActions( hWndFocus, wParam, lParam )
.head 7 +  Else
.head 8 +  If SalModalDialog( dlgTableChoice, hWndForm, sTableChoice )
.head 9 +  If sTableChoice = 'PROGRAMS'
.head 10 -  Return SalSendClassMessage( PAM_clsTBL_USERACTIONS, wParam, lParam )
.head 9 +  Else
.head 10 -  Return UserTableActions( tblProgStations, wParam, lParam )
.head 8 +  Else
.head 9 -  Return FALSE
.head 5 +  On PAM_clsWATERING_REBOOT
.head 6 -  Return ExitWindowsEx( EWX_FORCE | EWX_REBOOT, 0 )
.head 5 +  On PAM_cls_REFRESHAFTRCHILDCHANGE
.head 6 -  Set sChildButtonChanged = SalNumberToHString( lParam )
.head 6 -  ! pb18 is included as centuras bug.  When instance of clspbProgSwitches is dropped it 
assigns instance pb18 then when you rename it pbProgSwitches while running it 
still has pb18 as its name and not pbProgSwitches.
.head 6 +  If sChildButtonChanged = 'pbProgSwitches' OR sChildButtonChanged = 'pb18'
.head 7 -  Return FALSE
.head 6 +  Else
.head 7 -  Return TRUE

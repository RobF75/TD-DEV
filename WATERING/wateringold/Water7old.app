.head 3 +  Function: SecondsBetween
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Number:
.head 4 +  Parameters
.head 5 -  Date/Time: dtFirstTime
.head 5 -  Date/Time: dtSecondTime
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Date/Time: dtLowTime
.head 5 -  Date/Time: dtHiTime
.head 5 -  Number: nHour
.head 5 -  Number: nMinute
.head 5 -  Number: nSecond
.head 5 -  Number: nSecLowTime
.head 5 -  Number: nSecHiTime
.head 4 +  Actions
.head 5 +  If dtSecondTime > dtFirstTime
.head 6 -  Set dtHiTime = dtSecondTime
.head 6 -  Set dtLowTime = dtFirstTime
.head 5 +  Else
.head 6 -  Set dtHiTime = dtFirstTime
.head 6 -  Set dtLowTime = dtSecondTime
.head 5 -  Set nHour = SalDateHour( dtLowTime )
.head 5 -  Set nMinute = SalDateMinute( dtLowTime )
.head 5 -  Set nSecond = SalDateSecond( dtLowTime )
.head 5 -  Set nSecLowTime = ( nHour * 3600 ) + ( nMinute * 60 ) + nSecond
.head 5 -  Set nHour = SalDateHour( dtHiTime )
.head 5 -  Set nMinute = SalDateMinute( dtHiTime )
.head 5 -  Set nSecond = SalDateSecond( dtHiTime )
.head 5 -  Set nSecHiTime = ( nHour * 3600 ) + ( nMinute * 60 ) + nSecond
.head 5 -  Return nSecHiTime - nSecLowTime
.head 3 +  Function: CompareTime
.head 4 -  Description: Returns -1 if dtTimeA < dtTimeB, 0 if dtTimeA = dtTimeB, 1 if dtTimeA > dtTimeB
.head 4 +  Returns
.head 5 -  Number:
.head 4 +  Parameters
.head 5 -  Date/Time: dtTimeA
.head 5 -  Date/Time: dtTimeB
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Set dtTimeA = SalDateConstruct( 1996, 24, 11, SalDateHour( dtTimeA ), SalDateMinute( dtTimeA ), SalDateSecond( dtTimeA ) )
.head 5 -  Set dtTimeB = SalDateConstruct( 1996, 24, 11, SalDateHour( dtTimeB ), SalDateMinute( dtTimeB ), SalDateSecond( dtTimeB ) )
.head 5 +  If dtTimeA < dtTimeB
.head 6 -  Return -1
.head 5 +  Else If dtTimeA = dtTimeB
.head 6 -  Return 0
.head 5 +  Else
.head 6 -  Return 1

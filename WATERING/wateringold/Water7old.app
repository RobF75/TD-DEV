.head 4 +  Message Actions
.head 5 +  On PAM_clsPB_CLICK
.head 6 +  If bRunning
.head 7 -  Call SalMessageBox( 'Please stop the watering system before carring out any maintenance.', 'NOTE', MB_Ok )
.head 6 +  Else
.head 7 +  If rbSet
.head 8 +  If rbOn
.head 9 -  Set nStatus = 1
.head 8 +  Else
.head 9 -  Set nStatus = 0
.head 8 +  If NOT DIG_Out_Line( sBoardNo, sBoardPortNo, nStatus )
.head 9 -  Call SalMessageBox( 'A error has occured on Setting a channel.', 'Warning', MB_Ok )
.head 7 +  Else
.head 8 -  Set nStatus = NUMBER_Null
.head 8 +  If DIG_In_Line( sBoardNo, sBoardPortNo, nStatus )
.head 9 +  If nStatus = 1
.head 10 -  Set rbOn = TRUE
.head 9 +  Else
.head 10 -  Set rbOff = TRUE
.head 8 +  Else
.head 9 -  Call SalMessageBox( 'A error has occured on Getting a channel.', 'Warning', MB_Ok )
.head 2 -  Functions

.head 2 +  Window Parameters
.head 3 -  ! sTableChoice = 'PROGRAMS' OR 'PROG_STATIONS'
.head 3 -  Receive String: sTableChoice
.head 2 -  Window Variables
.head 2 +  Message Actions
.head 3 +  On SAM_CreateComplete
.head 4 +  If sTableChoice = 'PROGRAMS'
.head 5 -  Set rbPrograms = TRUE
.head 4 +  Else
.head 5 -  Set rbStations = TRUE
.head 4 -  Call OurWaitCursorOverride( FALSE, TRUE )
.head 4 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 3 +  On PAM_clsPB_OKACTION
.head 4 +  If rbPrograms
.head 5 -  Set sTableChoice = 'PROGRAMS'
.head 4 +  Else
.head 5 -  Set sTableChoice = 'PROG_STATIONS'
.head 4 -  Return SalSendMsg( pbExit, SAM_Click, TRUE, 0 )
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set bTreeSystem = FALSE

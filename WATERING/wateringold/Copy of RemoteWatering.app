.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SetPumpDelayedSecs' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " UPDATE Pump  
SET 
  Delayed_Secs = :2, 
  Pump_Status = :3 
WHERE Pump_No = :1 "
.head 7 -  Set sName = 'SETPMPDELAYED'
.head 7 -  Set sBind = ':nPumpNo, :nPumpDelayedSecs, :sStatus'
.head 7 -  Set sInto = ''
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Call LogMaintenance( nPumpNo, 'PUMP', sStatus, 'APPEND' )
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  If sStatus = 'ON'
.head 9 -  Call SetChannelState( nChannelNo, 1, SH_cls_Execute )
.head 8 +  Else
.head 9 -  Call SetChannelState( nChannelNo, 0, SH_cls_Execute )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Commit
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Commit( )
.head 6 +  Case SH_cls_Rollback
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call SetChannelState( 0, 0, SH_cls_Disconnect )
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )

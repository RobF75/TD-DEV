.head 9 +  If cbAutoAllocSeqNos
.head 10 +  If AllocStationSeqNos( nCurrentProgramNo, SalStrToNumber( hWndParent.clsfrmPrograms.ccTollerancePercent.GetNumber( ) ), SH_cls_Execute )
.head 11 -  Call AllocStationSeqNos( 0, 0, SH_cls_Commit )
.head 10 +  Else
.head 11 -  Call AllocStationSeqNos( 0, 0, SH_cls_Rollback )
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_POPULATE, wParam, lParam )
.head 8 +  ! If cbProgStationsSeqPressures
.head 9 -                                                                 Call TableLoop( hWndForm, hWndForm, PAM_clsWATERING_ADJUSTSEQNO, 0, 0, 0, 'Calculating Pressures', TBL_cls_LowToHi )
.head 7 +  On SAM_Destroy
.head 8 -  Call GetNextInstanceNo( colInstanceNo, SH_cls_Disconnect )
.head 8 -  Call AllocStationSeqNos( 0, 0, SH_cls_Disconnect )

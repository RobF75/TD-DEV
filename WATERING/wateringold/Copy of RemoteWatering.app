.head 3 -  !
.head 3 +  ! Function: LogMaintenance
.head 4 -   Description: 
.head 4 +   Returns 
.head 5 -   Boolean: 
.head 4 +   Parameters 
.head 5 -   Number: nKeyNo
.head 5 -  ! sKeyType = 'PROGRAM', 'PUMP', 'STATION', 'SWITCH', 'REBOOT'
.head 5 -   String: sKeyType
.head 5 -   String: sStatus
.head 5 -  ! sActionType = 'OPEN', 'CLOSE', 'APPEND', 'DISCONNECT'
.head 5 -   String: sActionType
.head 4 +   Static Variables 
.head 5 -   FunctionalVar: fcLogFile
.head 5 -   String: sFileName
.head 4 +   Local variables 
.head 5 -   String: sLogDT
.head 5 -   String: sLogEntryType
.head 5 -   String: sLogEntryDesc
.head 5 -   String: sLogStatus
.head 5 -   String: sLogChannel
.head 5 -  !
.head 5 -   String: sGotEntryDesc
.head 5 -   Number: nGotChannelNo
.head 5 -   String: sNewFileName
.head 5 -   Boolean: bOk
.head 5 -  !
.head 5 -   Date/Time: dtCurrentDT
.head 5 -   Number: nCount
.head 5 -   String: sLogFilePath
.head 5 -   Number: nNumLogFiles
.head 5 -   String: saLogFiles[*]
.head 5 -   Number: naLogSizes[*]
.head 5 -   Date/Time: dtaLogTimeStamps[*]
.head 5 -   Number: naLogAttributes[*]
.head 5 -   Number: nDaysToKeepLogs
.head 5 -  !
.head 5 -   Date/Time: dtTmp
.head 5 -   Number: nTmp
.head 5 -   String: sTemp
.head 4 +   Actions 
.head 5 +   If sActionType = 'OPEN'
.head 6 -   Set dtCurrentDT = SalDateCurrent(  )
.head 6 -   Set sNewFileName = MakeLogFileName( SalDateCurrent(  ) )
.head 6 +   If sNewFileName != sFileName
.head 7 -   Set sFileName = sNewFileName
.head 7 -  !
.head 7 +   If NOT GetRegistryValue( 'GENERAL', 'DaysToKeepLogs', sTemp, sDefaultValue) or sTemp = sDefaultValue
.head 8 -   Call SetRegistryValue( 'GENERAL', 'DaysToKeepLogs', sDEFAULTDAYSKEEPLOGS, sDEFAULTDAYSKEEPLOGS)
.head 7 -   Set nDaysToKeepLogs = SalStrToNumber(sTemp )
.head 7 +   If NOT GetRegistryValue( 'GENERAL', 'WateringLogsPath', sTemp, sDefaultValue) or sTemp = sDefaultValue
.head 8 -   Call SetRegistryValue('GENERAL', 'WateringLogsPath', sDEFAULTLOGPATH, sDEFAULTLOGPATH)
.head 7 -   Set sLogFilePath = SalStrTrimX( sTemp )
.head 7 -   Set nNumLogFiles = VisDosEnumFileInfo( sLogFilePath || '\\*.log', FA_Standard, saLogFiles, naLogSizes, dtaLogTimeStamps, naLogAttributes )
.head 7 -  !
.head 7 -   Set nCount = 0
.head 7 +   While nCount < nNumLogFiles
.head 8 +   If dtCurrentDT - ExtractLogFileNameDate( saLogFiles[ nCount ] ) > nDaysToKeepLogs
.head 9 -   Call VisFileDelete( sLogFilePath || '\\' || saLogFiles[ nCount ] )
.head 8 -   Set nCount = nCount + 1
.head 6 -   Call fcLogFile.Setup( sFileName, OF_Append | OF_Write | OF_Text, 120 )
.head 6 +   If fcLogFile.Open( )
.head 7 -   Set bOk = TRUE
.head 6 +   Else 

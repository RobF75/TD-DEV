.head 10 +  Case SH_cls_Execute
.head 11 -  Set sSql = " SELECT 
  ToBe_Tested 
FROM 
  Station  
WHERE 
  Station_No = :1 "
.head 11 -  Set sName = 'GETSTTBTSTFLG'
.head 11 -  Set sBind = ':nStationNo'
.head 11 -  Set sInto = ':sGotToBeTested'
.head 11 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 11 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 11 -  !
.head 11 -  Set sToBeTested = ''
.head 11 -  Set sGotToBeTested = ''
.head 11 -  !

.head 7 -  String: sState
.head 7 -  Boolean: bOk
.head 6 +  Actions
.head 7 -  Set bOk = TRUE
.head 7 -  Set bRunning = TRUE
.head 7 +  If NOT GetRegistryValue('GENERAL', 'OnState', sState, sDefaultValue) or sState = sDefaultValue
.head 8 -  Set bOk = FALSE
.head 7 +  If sState = 'OFF'
.head 8 -  Set bRunning = FALSE
.head 7 -  ! Call fcFileHandle.Setup( OurGetIniFileParameter( 'GENERAL', 'WateringLogsPath', 'C:\\TEMP' )||'\\OnState.log', OF_ReadWrite | OF_Text, NUMBER_Null )
.head 7 +  ! If fcFileHandle.Open( )
.head 8 +                     If NOT fcFileHandle.Read( sState )
.head 9 -                     Set bOk = FALSE
.head 8 +                     If sState = 'STATE (ON/OFF)=OFF'
.head 9 -                     Set bRunning = FALSE
.head 8 +                     If NOT fcFileHandle.Close( )
.head 9 -                     Set bOk = FALSE
.head 7 +  ! Else
.head 8 -                     Set bOk = FALSE
.head 7 -  Return bOk

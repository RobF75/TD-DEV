.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 -  Set sSQLPopHandle = " SELECT 
  Station.Station_No, 
  Station.Channel_No, 
  Station.Pump_No, 
  Pump.Pump_Desc, 
  Station.Station_Desc, 
  Station.Station_Litres_Min, 
  Station.Def_Water_Secs
FROM Station, Pump 
WHERE 
   Station.Pump_No = Pump.Pump_No 
ORDER BY Station.Pump_No, Station.Station_Desc"
.head 8 -  Set sNAMEPopHandle = 'POPSTATIONS'
.head 8 -  Set sBINDPopHandle = ''
.head 8 -  Set sINTOPopHandle = ':clsdlgStations.tblStations.colStationNo, 
:clsdlgStations.tblStations.colStationChannelNo,
:clsdlgStations.tblStations.colPumpNo, 
:clsdlgStations.tblStations.colPumpDesc, 
:clsdlgStations.tblStations.colStationDesc,
:clsdlgStations.tblStations.colStationLitresMin,
:clsdlgStations.tblStations.colDefWateringSeconds'
.head 8 -  !
.head 8 -  Set sSQLRefreshHandle = " SELECT 
  Station.Station_No, 
  Station.Channel_No, 
  Station.Pump_No, 
  Pump.Pump_Desc, 
  Station.Station_Desc, 
  Station.Station_Litres_Min, 
  Station.Def_Water_Secs
FROM Station, Pump
WHERE 
  Station.Station_No = :1 AND 
  Station.Pump_No = Pump.Pump_No "
.head 8 -  Set sNAMERefreshHandle = 'REFSTATIONS'
.head 8 -  Set sBINDRefreshHandle = ':clsdlgStations.tblStations.colStationNo'

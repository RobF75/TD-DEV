.head 5 +                                                                                        On PAM_cls_SETINSTANCEVARS
.head 6 -                                                                                        Set bTreeSystem = FALSE
.head 5 +                                                                                        On PAM_clsDLG_POPFIELDS
.head 6 -                                                                                        Call PopNumber( nProgNo, FALSE )
.head 6 -                                                                                        Call PopDateTime( dfProgStartTime, FALSE )
.head 6 -                                                                                        Call PopString( dfProgDescription, FALSE )
.head 6 -                                                                                        Call PopNumber( bRunning, FALSE )
.head 6 -                                                                                        Call PopWndHdl( hWndActivateButton, TRUE )
.head 6 -                                                                                        Return TRUE
.head 5 +                                                                                        On PAM_clsPB_OKACTION
.head 6 -                                                                                        Call GetProgramOverrideDets( nProgNo, sProgStatus, SH_cls_Execute )
.head 6 +                                                                                        If bRunning
.head 7 -                                                                                        Call SalMessageBox( 'Please stop the watering system before carring out any maintenance.', 'NOTE', MB_Ok )
.head 6 +                                                                                        Else 
.head 7 +                                                                                        If SetProgramDueNext( nProgNo, SalDateCurrent(  ), SH_cls_Execute )
.head 8 +                                                                                        If SetProgramStatus( nProgNo, 'WAITING', SH_cls_Execute )
.head 9 +                                                                                        If ResetProgramPumps( nProgNo, 'OFF', SH_cls_Execute )
.head 10 +                                                                                        If ResetProgramStations( nProgNo, 'WAITING', SH_cls_Execute )
.head 11 -                                                                                        Call ResetProgramStations( 0, '', SH_cls_Commit )
.head 11 -                                                                                        Call SetProgramStatus( 0, '', SH_cls_Commit )
.head 11 -                                                                                        Call SetProgramDueNext( 0, DATETIME_Null, SH_cls_Commit )
.head 11 -                                                                                        Call ResetProgramPumps( 0, '', SH_cls_Commit )
.head 10 +                                                                                        Else 
.head 11 -                                                                                        Call SetProgramStatus( 0, '', SH_cls_Rollback )
.head 11 -                                                                                        Call SetProgramDueNext( 0, DATETIME_Null, SH_cls_Rollback )
.head 11 -                                                                                        Call ResetProgramPumps( 0, '', SH_cls_Rollback )
.head 9 +                                                                                        Else 
.head 10 -                                                                                        Call SetProgramStatus( 0, '', SH_cls_Rollback )
.head 10 -                                                                                        Call SetProgramDueNext( 0, DATETIME_Null, SH_cls_Rollback )
.head 6 -                                                                                        Return SalSendMsg( pbExit, SAM_Click, TRUE, 0 )
.head 5 +                                                                                        On SAM_Destroy
.head 6 -                                                                                        Call GetProgramOverrideDets( 0, sProgStatus, SH_cls_Disconnect )
.head 6 -                                                                                        Call SetProgramDueNext( 0, DATETIME_Null, SH_cls_Disconnect )
.head 6 -                                                                                        Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

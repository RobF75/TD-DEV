.head 8 +  Actions
.head 9 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetNextSwitchNo' )
.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set sSql = " SELECT Max( Switch_No ) + 1
FROM Switch "
.head 11 -  Set sName = 'NXTSWTCHNO'
.head 11 -  Set sBind = ''

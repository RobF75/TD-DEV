.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  ! Changing so that status checked after sent so that can set it again if not set
.head 7 -  Set nCount = 0
.head 7 -  ! Set bWarningSent = FALSE
.head 7 -  ! Set bProblemSent = FALSE
.head 7 +  Loop SetStatus
.head 8 -  Call SetOrGetChannelState( nChannelNo, nStatus, 'SET', bOk, SH_cls_Execute )
.head 8 -  Call SetOrGetChannelState( nChannelNo, nGotStatus, 'GET', bOk, SH_cls_Execute )
.head 8 -  Set nCount = nCount + 1
.head 8 -  ! If nGotStatus = nStatus
.head 8 +  If nGotStatus = nStatus 	! or nCount > 5
.head 9 -  Break SetStatus
.head 8 +  Else If nCount > 1000
.head 9 +  If not bWarning
.head 10 -  ! Call SendMail( 'Watering Concern', 'The watering program may have a problem', 'g_flemo@hotmail.com.au', '', '', '' )
.head 10 -  Call SMTPSend( 'graham@flemings.com.au,g_flemo@hotmail.com', '', '', 'Automated', 'automated@flemings.com.au', 'Watering Concern', 'The watering program may have a problem', '', '192.168.42.4', 25 )
.head 10 -  Set bWarning = TRUE
.head 8 +  If nCount > 10000
.head 9 +  If not bProblem
.head 10 -  ! Call SendMail( 'Watering Problem', 'The watering program DOES have a problem', 'g_flemo@hotmail.com.au', '', '', '' )
.head 10 -  Set bProblem= TRUE
.head 10 -  Break SetStatus
.head 7 -  Return TRUE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return SetOrGetChannelState( 0, nStatus, '', bOk, SH_cls_Disconnect )

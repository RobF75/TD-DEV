.head 5 -  Set nHour = SalDateHour( dtHiTime )
.head 5 -  Set nMinute = SalDateMinute( dtHiTime )
.head 5 -  Set nSecond = SalDateSecond( dtHiTime )
.head 5 -  Set nSecHiTime = ( nHour * 3600 ) + ( nMinute * 60 ) + nSecond
.head 5 -  Return nSecHiTime - nSecLowTime

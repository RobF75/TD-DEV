.head 8 +  On PAM_cls_SETINSTANCEVARS
.head 9 -  Call SalSendClassMessage( PAM_cls_SETINSTANCEVARS, wParam, lParam )
.head 9 +  If bRunning
.head 10 -  Set picTrafficLight.nStartState = 3
.head 9 +  Else
.head 10 -  Set picTrafficLight.nStartState = 1
.head 8 +  On PAM_clsPIC_STATECLICK
.head 9 +  If wParam = 1
.head 10 -  Set bRunning = FALSE
.head 10 -  Call SetWateringActiveState( bRunning )
.head 10 -  Call InitialiseIOCard( 'STOP', SH_cls_Execute )
.head 10 +  If StopOnPumps( SH_cls_Execute )
.head 11 -  Call StopOnPumps( SH_cls_Commit )
.head 9 +  Else If wParam = 3
.head 10 -  Set bRunning = TRUE
.head 10 -  Call SetWateringActiveState( bRunning )
.head 10 -  Call InitialiseIOCard( 'START', SH_cls_Execute )
.head 9 -  Return SalSendClassMessage( PAM_clsPIC_STATECLICK, wParam, lParam )

.head 3 -  ! Perform Testing Facility
.head 3 +  Function: PerformTestingFacility
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Window Handle: hWndResults
.head 5 -  Number: nPAM_ResultsMessage
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Boolean: bOk
.head 5 -  Number: nPos
.head 5 -  Number: nSwitchStatus
.head 5 -  Boolean: bInputOk
.head 5 -  Number: nTestingSwitchChannel
.head 5 -  Number: naCommonRelayChannels[*]
.head 5 -  Number: naToBeTestedChannels[*]
.head 5 -  !
.head 5 -  FunctionalVar: fcResultsFile
.head 6 -  Class: clsStrFileHandle
.head 5 -  String: sResultsFile
.head 5 -  Boolean: bResultsFileOpened
.head 5 -  Number: nTestingActivateWait
.head 5 -  String: sBoardNo
.head 5 -  String: sPortNo
.head 5 -  String: sTemp
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT GetRegistryValue( 'GENERAL', 'TestingResultsFile', sResultsFile, sDefaultValue) or sResultsFile = sDefaultValue
.head 8 -  Call SetRegistryValue('GENERAL', 'TestingResultsFile', sDEFAULTTESTINGRESULTSFILE, sDEFAULTTESTINGRESULTSFILE )
.head 7 +  If NOT GetRegistryValue( 'GENERAL', 'TestingActivateWait', sTemp, sDefaultValue) or sTemp = sDefaultValue
.head 8 -  Call SetRegistryValue('GENERAL', 'TestingActivateWait', '0', '0')
.head 7 -  Set nTestingActivateWait = SalStrToNumber(sTemp )
.head 7 -  Call fcResultsFile.Setup( sResultsFile, OF_Create | OF_Write | OF_Text, 120 )
.head 7 +  If fcResultsFile.Open( )
.head 8 -  Set bResultsFileOpened = TRUE
.head 7 +  Else
.head 8 -  Set bResultsFileOpened = TRUE
.head 7 -  !
.head 7 +  If NOT GetCommonRelayChannels( naCommonRelayChannels, SH_cls_Execute )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT GetTestingSwitchChannel( nTestingSwitchChannel, SH_cls_Execute )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT GetToBeTestedChannels( naToBeTestedChannels, SH_cls_Execute )
.head 8 -  Set bOk = FALSE
.head 7 +  If bOk
.head 8 -  ! turn on common relays
.head 8 -  Set nPos = 0
.head 8 +  While naCommonRelayChannels[ nPos ] != NUMBER_Null AND bOk
.head 9 -  Call GetChannelDets( naCommonRelayChannels[ nPos ], sBoardNo, sPortNo, SH_cls_Execute )
.head 9 +  If SetChannelState( naCommonRelayChannels[ nPos ], 1, SH_cls_Execute )
.head 10 -  Set sResultsFile = 'Turning on Common Relay Channel ' || StringStartPadX( SalNumberToStrX( naCommonRelayChannels[ nPos ], 0 ), '0', 3 ) || ', ' || sBoardNo || ' ' || sPortNo || ' appears OK.'
.head 9 +  Else
.head 10 -  Set sResultsFile = 'Turning on Common Relay Channel ' || StringStartPadX( SalNumberToStrX( naCommonRelayChannels[ nPos ], 0 ), '0', 3 ) || ', ' || sBoardNo || ' ' || sPortNo || ' apperared to have failed.'
.head 10 -  Set bOk = FALSE
.head 9 +  If bResultsFileOpened
.head 10 -  Call fcResultsFile.Write( sResultsFile )
.head 9 -  Call SalSendMsg( hWndResults, nPAM_ResultsMessage, 0, SalHStringToNumber( sResultsFile ) )
.head 9 +  If nTestingActivateWait > 0
.head 10 -  Call SalPause( nTestingActivateWait )
.head 9 -  Set nPos = nPos + 1
.head 8 -  !
.head 8 -  Set nPos = 0
.head 8 +  While naToBeTestedChannels[ nPos ] != NUMBER_Null AND bOk
.head 9 +  If SetChannelState( naToBeTestedChannels[ nPos ], 1, SH_cls_Execute )
.head 10 +  If nTestingActivateWait > 0
.head 11 -  Call SalPause( nTestingActivateWait )
.head 10 +  If GetChannelState( nTestingSwitchChannel, nSwitchStatus, bInputOk, SH_cls_Execute )
.head 11 +  If bInputOk
.head 12 -  Call GetChannelDets( naToBeTestedChannels[ nPos ], sBoardNo, sPortNo, SH_cls_Execute )
.head 12 +  If nSwitchStatus = 1
.head 13 -  ! everything OK
.head 13 -  Set sResultsFile = 'To be tested Channel ' || StringStartPadX( SalNumberToStrX( naToBeTestedChannels[ nPos ], 0 ), '0', 3 ) || ', ' || sBoardNo || ' ' || sPortNo || ' PASSED test.'
.head 12 +  Else
.head 13 -  ! relay is blown NOT OK
.head 13 -  Set sResultsFile = 'To be tested Channel ' || StringStartPadX( SalNumberToStrX( naToBeTestedChannels[ nPos ], 0 ), '0', 3 ) || ', ' || sBoardNo || ' ' || sPortNo || ' FAILED test.'
.head 11 +  Else
.head 12 -  Set bOk = FALSE
.head 12 -  Call GetChannelDets( nTestingSwitchChannel, sBoardNo, sPortNo, SH_cls_Execute )
.head 12 -  Set sResultsFile = 'Reading Testing switch Channel ' || StringStartPadX( SalNumberToStrX( nTestingSwitchChannel, 0 ), '0', 3 ) || ', ' || sBoardNo || ' ' || sPortNo || ' appears to have failed.'
.head 10 +  Else
.head 11 -  Set bOk = FALSE
.head 11 -  Call GetChannelDets( nTestingSwitchChannel, sBoardNo, sPortNo, SH_cls_Execute )
.head 11 -  Set sResultsFile = 'Reading Testing switch Channel ' || StringStartPadX( SalNumberToStrX( nTestingSwitchChannel, 0 ), '0', 3 ) || ', ' || sBoardNo || ' ' || sPortNo || ' appears to have failed.'
.head 9 +  Else
.head 10 -  Set bOk = FALSE
.head 10 -  Call GetChannelDets( naToBeTestedChannels[ nPos ], sBoardNo, sPortNo, SH_cls_Execute )
.head 10 -  Set sResultsFile = 'To be tested Channel ' || StringStartPadX( SalNumberToStrX( naToBeTestedChannels[ nPos ], 0 ), '0', 3 ) || ', ' || sBoardNo || ' ' || sPortNo || ' failed to activate for test.'
.head 9 +  If bResultsFileOpened
.head 10 -  Call fcResultsFile.Write( sResultsFile )
.head 9 -  Call SalSendMsg( hWndResults, nPAM_ResultsMessage, 0, SalHStringToNumber( sResultsFile ) )
.head 9 -  Set nPos = nPos + 1
.head 8 -  !
.head 8 -  ! turn off common relays
.head 8 -  Set nPos = 0
.head 8 +  While naCommonRelayChannels[ nPos ] != NUMBER_Null AND bOk
.head 9 -  Call GetChannelDets( naCommonRelayChannels[ nPos ], sBoardNo, sPortNo, SH_cls_Execute )
.head 9 +  If SetChannelState( naCommonRelayChannels[ nPos ], 0, SH_cls_Execute )
.head 10 -  Set sResultsFile = 'Turning off Common Relay Channel ' || StringStartPadX( SalNumberToStrX( naCommonRelayChannels[ nPos ], 0 ), '0', 3 ) || ', ' || sBoardNo || ' ' || sPortNo || ' appears OK.'
.head 9 +  Else
.head 10 -  Set sResultsFile = 'Turning off Common Relay Channel ' || StringStartPadX( SalNumberToStrX( naCommonRelayChannels[ nPos ], 0 ), '0', 3 ) || ', ' || sBoardNo || ' ' || sPortNo || ' appered to have failed.'
.head 10 -  Set bOk = FALSE
.head 9 +  If bResultsFileOpened
.head 10 -  Call fcResultsFile.Write( sResultsFile )
.head 9 -  Call SalSendMsg( hWndResults, nPAM_ResultsMessage, 0, SalHStringToNumber( sResultsFile ) )
.head 9 -  Set nPos = nPos + 1
.head 7 -  !
.head 7 +  If bResultsFileOpened
.head 8 -  Call fcResultsFile.Close( )
.head 7 -  Return bOk
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT GetCommonRelayChannels( naCommonRelayChannels, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT GetTestingSwitchChannel( nTestingSwitchChannel, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT GetToBeTestedChannels( naToBeTestedChannels, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT GetChannelDets( 0, sBoardNo, sPortNo, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk

.head 8 -  Call PushNumber( colPumpLitresMin )
.head 8 +  If NOT SalSendMsg( hWndParent.clsfrmPrograms.tblProgStationsSeqPressures, PAM_clsWATERING_ADJUSTSEQNO, 1, 0 )
.head 9 -  Call PopNumber( colPumpLitresMin, TRUE )
.head 9 -  Call PopNumber( colStationLitresMin, TRUE )
.head 9 -  Call PopNumber( colWaterSeqNo, TRUE )
.head 8 -  Return TRUE

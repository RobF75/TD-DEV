.head 8 +  Actions
.head 9 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetNextStationNo' )
.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set sSql = " SELECT Max( Station_No ) + 1
FROM Station "
.head 11 -  Set sName = 'NXTSTATIONNO'
.head 11 -  Set sBind = ''
.head 11 -  Set sInto = ':nGotStationNo'
.head 11 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 11 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 11 -  !
.head 11 -  Set nNextStationNo = NUMBER_Null
.head 11 -  Set nGotStationNo = NUMBER_Null
.head 11 -  !
.head 11 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 12 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 13 +  If NOT nGotStationNo > 0
.head 14 -  Set nGotStationNo = 1
.head 13 -  Set nNextStationNo = nGotStationNo
.head 12 -  Return TRUE
.head 11 +  Else
.head 12 -  Return FALSE
.head 10 +  Case SH_cls_Disconnect
.head 11 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )

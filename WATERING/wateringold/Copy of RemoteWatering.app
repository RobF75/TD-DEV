.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set sSql = " SELECT Program_No 
FROM Prog_Stations
WHERE Station_No = :1 "
.head 11 -  Set sName = 'EXISTSSTSPROG'
.head 11 -  Set sBind = ''
.head 11 -  Set sInto = ''
.head 11 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )

.head 7 -  Set bOk = TRUE
.head 7 -  ! Call fcFileHandle.Setup( OurGetIniFileParameter( 'GENERAL', 'WateringLogsPath', 'C:\\TEMP' )||'\\OnState.log', NUMBER_Null, NUMBER_Null )
.head 7 +  ! If fcFileHandle.Open( )
.head 8 +                     If NOT fcFileHandle.Close( )
.head 9 -                     Set bOk = FALSE
.head 7 +  If bRunning
.head 8 +  If NOT SetRegistryValue('GENERAL', 'OnState', 'ON', 'ON')
.head 9 -  Set bOk = FALSE

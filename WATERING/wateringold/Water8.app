			Pushbutton: pbDoIt
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: clspbGeneral
				Property Template:
				Class DLL Name:
				Title: DO IT
				Window Location and Size
					Left:   2.3"
					Top:    0.885"
					Width:  Class Default
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name: C:\Centura\icons\Lghtbolt.ico
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_clsPB_CLICK
						If bRunning
							Call SalMessageBox( 'Please stop the watering system before carring out any maintenance.', 'NOTE', MB_Ok )
						Else
							If rbSet
								If rbOn
									Set nStatus = 1
								Else
									Set nStatus = 0
								If NOT DIG_Out_Line( sBoardNo, sBoardPortNo, nStatus )
									Call SalMessageBox( 'A error has occured on Setting a channel.', 'Warning', MB_Ok )
							Else
								Set nStatus = NUMBER_Null
								If DIG_In_Line( sBoardNo, sBoardPortNo, nStatus )
									If nStatus = 1
										Set rbOn = TRUE
									Else
										Set rbOff = TRUE
								Else
									Call SalMessageBox( 'A error has occured on Getting a channel.', 'Warning', MB_Ok )
		Functions
		Window Parameters
			Boolean: bRunning
			String: sBoardNo
			String: sBoardPortNo
		Window Variables
			Number: nStatus
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set bTreeSystem = FALSE
			On SAM_CreateComplete
				Set dfBoardNo = sBoardNo
				Set dfBoardPortNo = sBoardPortNo
				Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
	!

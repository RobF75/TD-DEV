								If bRunning
									Call SalMessageBox( 'Please stop the watering system first.', 'NOTE', MB_Ok )
								Else
									If nCurrentProgramNo > 0
										Call ResetProgram( nCurrentProgramNo, SH_cls_Execute )
										If sCurrentProgramStatus = 'ACTIVE'
											If StopProgramPumps( nCurrentProgramNo, SH_cls_Execute )
												Call StopProgramPumps( 0, SH_cls_Commit )
										Call SalSendMsg( hWndForm, PAM_clsWATERING_REFRESHDATA, 0, 0 )
									Else
										Call SalMessageBox( 'Please select a current program first!', 'Warning', MB_Ok )

			Function: ActivateProgram
				Description:
				Returns
					Boolean:
				Parameters
					Number: nProgramNo
					Date/Time: dtProgStartDT
					Date/Time: dtProgNextDT
					Number: nProgRecurrDays
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'ActivateProgram' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " UPDATE Program  
									SET 
									  Prog_Start_DT = :2, 
									  Prog_Next_DT = :3, 
									  Prog_Status = 'ACTIVE' 
									WHERE 
									  Program_No = :1 "
							Set sName = 'SETPROGACTIVE'
							Set sBind = ':nProgramNo, :dtProgStartDT, :dtProgNextDT'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set dtProgStartDT = SalDateConstruct( SalDateYear( SalDateCurrent(  ) ), SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 
									SalDateHour( dtProgStartDT ), SalDateMinute( dtProgStartDT ), SalDateSecond( dtProgStartDT ) )
							Set dtProgNextDT = dtProgStartDT + nProgRecurrDays
							Return haSqlHandles[ nOurHandleNo ].Execute( )
						Case SH_cls_Commit
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: ResetProgram
				Description:
				Returns
					Boolean:
				Parameters
					Number: nProgramNo
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nOurHandleNo
					Date/Time: dtProgStartDT
					Date/Time: dtProgNextDT
					Number: nRecurrDays
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'ResetProgram' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Prog_Start_DT, 
									  Recurr_Days 
									FROM 
									  Program
									WHERE Program_No = :1 "
							Set sName = 'GTPROGSTRTDT'
							Set sBind = ':nProgramNo'
							Set sInto = ':dtProgStartDT, :nRecurrDays'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									If CompareTime( dtProgStartDT, SalDateCurrent( ) ) > 0
										Set dtProgNextDT = SalDateConstruct( SalDateYear( SalDateCurrent(  ) ), SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 
												SalDateHour( dtProgStartDT ), SalDateMinute( dtProgStartDT ), SalDateSecond( dtProgStartDT ) )
									Else
										Set dtProgNextDT = SalDateConstruct( SalDateYear( SalDateCurrent(  ) ), SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 
												SalDateHour( dtProgStartDT ), SalDateMinute( dtProgStartDT ), SalDateSecond( dtProgStartDT ) ) + nRecurrDays
									If SetProgramNextDT( nProgramNo, dtProgNextDT, SH_cls_Execute )
										If SetProgramStatus( nProgramNo, 'READY', SH_cls_Execute )
											Call SetProgramStatus( 0, '', SH_cls_Commit )
											Call SetProgramNextDT( 0, DATETIME_Null, SH_cls_Commit )
										Else
											Call SetProgramNextDT( 0, DATETIME_Null, SH_cls_Rollback )
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Call SetProgramStatus( 0, '', SH_cls_Disconnect )
							Call SetProgramNextDT( 0, DATETIME_Null, SH_cls_Disconnect )
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			!
			Function: CheckProgActionSwitch
				Description:
				Returns
					Boolean:
				Parameters
					Number: nProgramNo
					String: sProgAction
					Receive Boolean: bSwitchChangeOverStatus
					Receive Boolean: bSwitchCurrentStatus
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					Number: nInd
					Boolean: bOk
					Number: nActivePos
					!
					Number: nGotSwitchPhysicalState
					Number: nGotProgSwitchNo
					String: sGotValidState
					String: sGotSwitchDBState
					Number: nGotSwitchChannelNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'CheckProgActionSwitch' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Prog_Switches.Switch_No, 
									  Prog_Switches.Valid_State, 
									  Switch.Switch_Status, 
									  Switch.Channel_No  
									FROM 
									  Prog_Switches, Switch
									WHERE 
									  Prog_Switches.Program_No = :1 AND 
									  Prog_Switches.Prog_Action = :2 AND 
									  Prog_Switches.Switch_No = Switch.Switch_No "
							Set sName = 'GTPRACTNSW'
							Set sBind = ':nProgramNo, :sProgAction'
							Set sInto = ':nGotProgSwitchNo, :sGotValidState, :sGotSwitchDBState, :nGotSwitchChannelNo'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nGotSwitchPhysicalState = NUMBER_Null
							Set bSwitchChangeOverStatus = FALSE
							Set bSwitchCurrentStatus = FALSE
							!
							Set nGotProgSwitchNo = NUMBER_Null
							Set sGotValidState = ''
							Set sGotSwitchDBState = ''
							Set nGotSwitchChannelNo = NUMBER_Null
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									If GetChannelState( nGotSwitchChannelNo, nGotSwitchPhysicalState, bOk, SH_cls_Execute )
										If bOk
											If ( sGotValidState = 'ON' AND nGotSwitchPhysicalState = 0 ) OR 
													   ( sGotValidState = 'OFF' AND nGotSwitchPhysicalState = 1 )
												Set bSwitchChangeOverStatus = TRUE
											If nGotSwitchPhysicalState = 1
												Set bSwitchCurrentStatus = TRUE
											! here makes sure that DB column Switch.Switch_Status always reflects the 
													  correct physical state while program running and writes entry into log 
													  when switch came on and off.
											If sGotSwitchDBState = 'ON' AND nGotSwitchPhysicalState = 0
												If SetSwitchDBStatus( nGotProgSwitchNo, 'OFF', SH_cls_Execute )
													Call SetSwitchDBStatus( 0, '', SH_cls_Commit )
											Else If sGotSwitchDBState = 'OFF' AND nGotSwitchPhysicalState = 1
												If SetSwitchDBStatus( nGotProgSwitchNo, 'ON', SH_cls_Execute )
													Call SetSwitchDBStatus( 0, '', SH_cls_Commit )
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT SetSwitchDBStatus( 0, '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT GetChannelState( 0, nGotSwitchPhysicalState, bOk, SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurHandleNo ].Disconnect( )
								Set bOk = TRUE
							Return bOk
			!
			Function: GetActivateSwitches
				Description:
				Returns
					Boolean:
				Parameters
					! all arrays are null terminated
					Receive Number: naProgramNos[*]
					Receive String: saProgAction[*]
					Receive String: saProgInProgress[*]
					Receive Boolean: bSomeSwitchActive
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					Number: nInd
					Boolean: bOk
					Number: nActivePos
					!
					Number: nGotSwitchPhysicalState
					Number: nGotProgNo
					Number: nGotProgSwitchNo
					String: sGotValidState
					String: sGotProgAction
					String: sGotProgInProgress
					String: sGotSwitchDBState
					Number: nGotSwitchChannelNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetActivateSwitches' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Prog_Switches.Program_No, 
									  Prog_Switches.Switch_No, 
									  Prog_Switches.Valid_State, 
									  Prog_Switches.Prog_Action, 
									  Prog_Switches.ProgIn_Progress, 
									  Switch.Switch_Status, 
									  Switch.Channel_No  
									FROM 
									  Prog_Switches, Switch
									WHERE 
									  Prog_Switches.Switch_No = Switch.Switch_No "
							Set sName = 'ALLPRGSWTS'
							Set sBind = ''
							Set sInto = ':nGotProgNo, :nGotProgSwitchNo, :sGotValidState, :sGotProgAction, :sGotProgInProgress, :sGotSwitchDBState, :nGotSwitchChannelNo'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nGotSwitchPhysicalState = NUMBER_Null
							Set bSomeSwitchActive = FALSE
							!
							Set nGotProgNo = NUMBER_Null
							Set nGotProgSwitchNo = NUMBER_Null
							Set sGotValidState = ''
							Set sGotProgAction = ''
							Set sGotProgInProgress = ''
							Set sGotSwitchDBState = ''
							Set nGotSwitchChannelNo = NUMBER_Null
							!
							Set nActivePos = 0
							Set naProgramNos[ nActivePos ] = NUMBER_Null
							Set saProgAction[ nActivePos ] = ''
							Set saProgInProgress[ nActivePos ] = ''
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									If GetChannelState( nGotSwitchChannelNo, nGotSwitchPhysicalState, bOk, SH_cls_Execute )
										If bOk
											If ( sGotValidState = 'ON' AND nGotSwitchPhysicalState = 0 ) OR 
													   ( sGotValidState = 'OFF' AND nGotSwitchPhysicalState = 1 )
												Set bSomeSwitchActive = TRUE
												!
												Set naProgramNos[ nActivePos ] = nGotProgNo
												Set saProgAction[ nActivePos ] = sGotProgAction
												Set saProgInProgress[ nActivePos ] = sGotProgInProgress
												Set nActivePos = nActivePos + 1
												Set naProgramNos[ nActivePos ] = NUMBER_Null
												Set saProgAction[ nActivePos ] = ''
												Set saProgInProgress[ nActivePos ] = ''
											! here makes sure that DB column Switch.Switch_Status always reflects the 
													  correct physical state while program running and writes entry into log 
													  when switch came on and off.
											If sGotSwitchDBState = 'ON' AND nGotSwitchPhysicalState = 0
												If SetSwitchDBStatus( nGotProgSwitchNo, 'OFF', SH_cls_Execute )
													Call SetSwitchDBStatus( 0, '', SH_cls_Commit )
											Else If sGotSwitchDBState = 'OFF' AND nGotSwitchPhysicalState = 1
												If SetSwitchDBStatus( nGotProgSwitchNo, 'ON', SH_cls_Execute )
													Call SetSwitchDBStatus( 0, '', SH_cls_Commit )
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT SetSwitchDBStatus( 0, '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT GetChannelState( 0, nGotSwitchPhysicalState, bOk, SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurHandleNo ].Disconnect( )
								Set bOk = TRUE
							Return bOk
			!
			Function: GetNextProgNo
				Description:
				Returns
					Boolean:
				Parameters
					Receive Number: nNextProgNo
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					Number: nInd
					Number: nGotProgNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetNextProgNo' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT Max( Program_No ) + 1
									FROM Program "
							Set sName = 'NXTPROGNO'
							Set sBind = ''
							Set sInto = ':nGotProgNo'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nNextProgNo = NUMBER_Null
							Set nGotProgNo = NUMBER_Null
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									If NOT nGotProgNo > 0
										Set nGotProgNo = 1
									Set nNextProgNo = nGotProgNo
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: GetNextInstanceNo
				Description:
				Returns
					Boolean:
				Parameters
					Receive Number: nNextInstanceNo
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					Number: nInd
					Number: nGotInstanceNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetNextInstanceNo' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT Max( Instance_No ) + 1
									FROM Prog_Stations "
							Set sName = 'NXTINSTNO'
							Set sBind = ''
							Set sInto = ':nGotInstanceNo'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nNextInstanceNo = NUMBER_Null
							Set nGotInstanceNo = NUMBER_Null
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									If NOT nGotInstanceNo > 0
										Set nGotInstanceNo = 1
									Set nNextInstanceNo = nGotInstanceNo
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: ManualStartStations
				Description:
				Returns
					Boolean:
				Parameters
					! naStationNos, naStationCrntWaterSecs is NUMBER_Null terminated array
					Number: naStationNos[*]
					Number: naStationCrntWaterSecs[*]
					Number: nActionType
				Static Variables
				Local variables
					Number: nPos
					!
					Number: nNewProgNo
					Boolean: bOk
				Actions
					Select Case nActionType
						Case SH_cls_Execute
							Set bOk = TRUE
							If InsertManualProgram( nNewProgNo, SH_cls_Execute )
								If nNewProgNo > 0
									Set nPos = 0
									While naStationNos[ nPos ] != NUMBER_Null
										If NOT InsertManualProgStation( nNewProgNo, naStationNos[ nPos ], naStationCrntWaterSecs[ nPos ], SH_cls_Execute )
											Set bOk = FALSE
										Set nPos = nPos + 1
									If bOk
										Call InsertManualProgStation( 0, 0, 0, SH_cls_Commit )
										Call InsertManualProgram( nNewProgNo, SH_cls_Commit )
									Else
										Call InsertManualProgStation( 0, 0, 0, SH_cls_Rollback )
										Call InsertManualProgram( nNewProgNo, SH_cls_Rollback )
								Else
									Call InsertManualProgram( nNewProgNo, SH_cls_Rollback )
									Set bOk = FALSE
							Else
								Set bOk = FALSE
							Return bOk
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT InsertManualProgram( nNewProgNo, SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT InsertManualProgStation( 0, 0, 0, SH_cls_Disconnect )
								Set bOk = FALSE
							Return TRUE
			Function: InsertManualProgram
				Description:
				Returns
					Boolean:
				Parameters
					Receive Number: nProgramNo
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					Number: nNewProgNo
					Date/Time: dtProgStartDT
					Date/Time: dtProgNextDT
					String: sProgDesc
					Number: nRecurrDays
					String: sProgStatus
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'InsertManualProgram' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " INSERT INTO Program  
									( Program_No, Prog_Start_DT, Prog_Next_DT, Prog_Desc, Recurr_Days, Prog_Status ) 
									VALUES ( :1, :2, :3, :4, :5, :6 ) "
							Set sName = 'INSMANPRG'
							Set sBind = ':nNewProgNo, :dtProgStartDT, :dtProgNextDT, :sProgDesc, :nRecurrDays, :sProgStatus'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nProgramNo = NUMBER_Null
							Call GetNextProgNo( nNewProgNo, SH_cls_Execute )
							If nNewProgNo > 0
								Set nProgramNo = nNewProgNo
								Set dtProgStartDT = SalDateCurrent(  )
								Set dtProgNextDT = SalDateCurrent(  )
								Set sProgDesc = 'Manual'
								Set nRecurrDays = 1
								Set sProgStatus = 'READY'
								Return haSqlHandles[ nOurHandleNo ].Execute( )
							Else
								Return FALSE
						Case SH_cls_Commit
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Call GetNextProgNo( nNewProgNo, SH_cls_Disconnect )
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: InsertManualProgStation
				Description:
				Returns
					Boolean:
				Parameters
					Number: nProgramNo
					Number: nStationNo
					Number: nCrntWaterSecs
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					Number: nNewInstanceNo
					Number: nWateredSecs
					String: sStationStatus
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'InsertManualProgStation' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " INSERT INTO Prog_Stations  
									( Instance_No, Program_No, Station_No, Crnt_Water_Sec, Watered_Sec, Station_Status ) 
									VALUES ( :1, :2, :3, :4, :5, :6 ) "
							Set sName = 'INSMANPRGSTS'
							Set sBind = ':nNewInstanceNo, :nProgramNo, :nStationNo, :nCrntWaterSecs, :nWateredSecs, :sStationStatus'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Call GetNextInstanceNo( nNewInstanceNo, SH_cls_Execute )
							If nNewInstanceNo > 0
								Set nWateredSecs = 0
								Set sStationStatus = 'READY'
								Return haSqlHandles[ nOurHandleNo ].Execute( )
							Else
								Return FALSE
						Case SH_cls_Commit
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Call GetNextInstanceNo( nNewInstanceNo, SH_cls_Disconnect )
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: DeleteManualProgram
				Description:
				Returns
					Boolean:
				Parameters
					Number: nProgramNo
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'DeleteManualProgram' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " DELETE FROM Program  
									WHERE Program_No = :1 "
							Set sName = 'DELMANPRG'
							Set sBind = ':nProgramNo'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							If DeleteProgStations( nProgramNo, SH_cls_Execute )
								If DeleteProgSwitches( nProgramNo, SH_cls_Execute )
									If haSqlHandles[ nOurHandleNo ].Execute( )
										Return TRUE
									Else
										Call DeleteProgStations( 0, SH_cls_Rollback )
										Call DeleteProgSwitches( 0, SH_cls_Rollback )
										Return FALSE
								Else
									Call DeleteProgStations( 0, SH_cls_Rollback )
									Return FALSE
							Else
								Return FALSE
						Case SH_cls_Commit
							Call DeleteProgStations( 0, SH_cls_Commit )
							Call DeleteProgSwitches( 0, SH_cls_Commit )
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Call DeleteProgStations( 0, SH_cls_Rollback )
							Call DeleteProgSwitches( 0, SH_cls_Rollback )
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Call DeleteProgStations( 0, SH_cls_Disconnect )
							Call DeleteProgSwitches( 0, SH_cls_Disconnect )
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: DeleteProgStations
				Description:
				Returns
					Boolean:
				Parameters
					Number: nProgramNo
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'DeleteProgStations' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " DELETE FROM Prog_Stations  
									WHERE Program_No = :1 "
							Set sName = 'DELMANPRGSTS'
							Set sBind = ':nProgramNo'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Return haSqlHandles[ nOurHandleNo ].Execute( )
						Case SH_cls_Commit
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: DeleteProgSwitches
				Description:
				Returns
					Boolean:
				Parameters
					Number: nProgramNo
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'DeleteProgSwitches' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " DELETE FROM Prog_Switches
									WHERE Program_No = :1 "
							Set sName = 'DELMANPRGSWS'
							Set sBind = ':nProgramNo'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Return haSqlHandles[ nOurHandleNo ].Execute( )
						Case SH_cls_Commit
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: ClearPumpDelayedSecs
				Description:
				Returns
					Boolean:
				Parameters
					Number: nPumpNo
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'ClearPumpDelayedSecs' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " UPDATE Pump  
									SET 
									  Delayed_Secs = 0
									WHERE Pump_No = :1 "
							Set sName = 'CLSPMPDELAYED'
							Set sBind = ':nPumpNo'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Return haSqlHandles[ nOurHandleNo ].Execute( )
						Case SH_cls_Commit
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Call SetChannelState( 0, 0, SH_cls_Disconnect )
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			!

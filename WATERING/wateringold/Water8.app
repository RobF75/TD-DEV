						Message Actions
							On PAM_clsPB_CLICK
								Set nCurrentProgramNo = tblPrograms.colProgramNo
								Set sCurrentProgramStatus = tblPrograms.colProgStatus
								Set dfCurrentProgDesc = tblPrograms.colProgDesc
								Set dfCurrentProgStartTime = tblPrograms.colProgStartTime

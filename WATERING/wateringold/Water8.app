								List Values
								Message Actions
						Functions
							Function: CalcRowWaterPercentage
								Description:
								Returns
								Parameters
									Number: nDefWateringSeconds
									Number: nCrntWateringSeconds
									Receive Number: nWateringPercent
								Static Variables
								Local variables
								Actions
									If nDefWateringSeconds > 0
										Set nWateringPercent = nCrntWateringSeconds / nDefWateringSeconds * 100
									Else
										Set nWateringPercent = 0
						Window Variables
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = " SELECT 
										  Prog_Stations.Instance_No, 
										  Prog_Stations.Program_No, 
										  Prog_Stations.Station_No, 
										  Station.Pump_No, 
										  Pump.Pump_Desc, 
										  Station.Channel_No, 
										  Prog_Stations.Water_Seq_No, 
										  Prog_Stations.Water_Seq_No, 
										  Station.Station_Desc, 
										  Station.Station_Litres_Min, 
										  Station.Def_Water_Secs, 
										  Prog_Stations.Crnt_Water_Sec, 
										  Prog_Stations.Watered_Sec, 
										  Prog_Stations.Station_Status, 
										  Pump.Channel_No, 
										  Pump.Pump_Litres_Min, 
										  Pump.Start_Delay_Secs, 
										  Pump.Pump_Status 
										FROM Prog_Stations, Station, Pump 
										WHERE 
										   Prog_Stations.Program_No = :1 AND 
										   Prog_Stations.Station_No = Station.Station_No AND 
										   Station.Pump_No = Pump.Pump_No 
										ORDER BY 
										  Prog_Stations.Station_Status, 
										  Prog_Stations.Water_Seq_No, 
										  Station.Station_Litres_Min DESC "
								Set sNAMEPopHandle = 'POPPRGSTATS'
								Set sBINDPopHandle = ':hWndParent.clsfrmPrograms.nCurrentProgramNo'
								Set sINTOPopHandle = ':clsfrmPrograms.tblProgStations.colInstanceNo, 
										:clsfrmPrograms.tblProgStations.colProgramNo, 
										:clsfrmPrograms.tblProgStations.colStationNo, 
										:clsfrmPrograms.tblProgStations.colPumpNo, 
										:clsfrmPrograms.tblProgStations.colPumpDesc, 
										:clsfrmPrograms.tblProgStations.colStationChannelNo,
										:clsfrmPrograms.tblProgStations.colWaterSeqNo, 
										:clsfrmPrograms.tblProgStations.colOrgWaterSeqNo, 
										:clsfrmPrograms.tblProgStations.colStationDesc,
										:clsfrmPrograms.tblProgStations.colStationLitresMin,
										:clsfrmPrograms.tblProgStations.colStationDefWaterSec, 
										:clsfrmPrograms.tblProgStations.colStationCrntWaterSec, 
										:clsfrmPrograms.tblProgStations.colStationWateredSec, 
										:clsfrmPrograms.tblProgStations.colStationStatus, 
										:clsfrmPrograms.tblProgStations.colPumpChannelNo, 
										:clsfrmPrograms.tblProgStations.colPumpLitresMin, 
										:clsfrmPrograms.tblProgStations.colPumpStartDelay, 
										:clsfrmPrograms.tblProgStations.colPumpStatus'
								!
								Set sSQLRefreshHandle = " SELECT 
										  Prog_Stations.Instance_No, 
										  Prog_Stations.Program_No, 
										  Prog_Stations.Station_No, 
										  Station.Pump_No, 
										  Pump.Pump_Desc, 
										  Station.Channel_No, 
										  Prog_Stations.Water_Seq_No, 
										  Prog_Stations.Water_Seq_No, 
										  Station.Station_Desc, 
										  Station.Station_Litres_Min, 
										  Station.Def_Water_Secs, 
										  Prog_Stations.Crnt_Water_Sec, 
										  Prog_Stations.Watered_Sec, 
										  Prog_Stations.Station_Status, 
										  Pump.Channel_No, 
										  Pump.Pump_Litres_Min, 
										  Pump.Start_Delay_Secs, 
										  Pump.Pump_Status 
										FROM Prog_Stations, Station, Pump 
										WHERE 
										   Prog_Stations.Program_No = :1 AND 
										   Prog_Stations.Instance_No = :2 AND 
										   Prog_Stations.Station_No = Station.Station_No AND 
										   Station.Pump_No = Pump.Pump_No  "
								Set sNAMERefreshHandle = 'REFPRGSTATS'
								Set sBINDRefreshHandle = ':clsfrmPrograms.tblProgStations.colProgramNo, 
										:clsfrmPrograms.tblProgStations.colInstanceNo'
								Set sINTORefreshHandle = ':clsfrmPrograms.tblProgStations.colInstanceNo, 
										:clsfrmPrograms.tblProgStations.colProgramNo, 
										:clsfrmPrograms.tblProgStations.colStationNo, 
										:clsfrmPrograms.tblProgStations.colPumpNo, 
										:clsfrmPrograms.tblProgStations.colPumpDesc, 
										:clsfrmPrograms.tblProgStations.colStationChannelNo,
										:clsfrmPrograms.tblProgStations.colWaterSeqNo, 
										:clsfrmPrograms.tblProgStations.colOrgWaterSeqNo, 
										:clsfrmPrograms.tblProgStations.colStationDesc,
										:clsfrmPrograms.tblProgStations.colStationLitresMin,
										:clsfrmPrograms.tblProgStations.colStationDefWaterSec, 
										:clsfrmPrograms.tblProgStations.colStationCrntWaterSec, 
										:clsfrmPrograms.tblProgStations.colStationWateredSec, 
										:clsfrmPrograms.tblProgStations.colStationStatus, 
										:clsfrmPrograms.tblProgStations.colPumpChannelNo, 
										:clsfrmPrograms.tblProgStations.colPumpLitresMin, 
										:clsfrmPrograms.tblProgStations.colPumpStartDelay, 
										:clsfrmPrograms.tblProgStations.colPumpStatus'
								!
								Set sSQLInsertHandle = " INSERT INTO Prog_Stations  
										( Instance_No, 
										  Program_No, 
										  Station_No,  
										  Water_Seq_No, 
										  Crnt_Water_Sec, 
										  Watered_Sec, 
										  Station_Status ) VALUES ( :1, :2, :3, :4, :5, :6, :7 ) "
								Set sNAMEInsertHandle = 'INSPRGSTATS'
								Set sBINDInsertHandle = ':clsfrmPrograms.tblProgStations.colInstanceNo, 
										:clsfrmPrograms.tblProgStations.colProgramNo, 
										:clsfrmPrograms.tblProgStations.colStationNo, 
										:clsfrmPrograms.tblProgStations.colWaterSeqNo, 
										:clsfrmPrograms.tblProgStations.colStationCrntWaterSec, 
										:clsfrmPrograms.tblProgStations.colStationWateredSec, 
										:clsfrmPrograms.tblProgStations.colStationStatus'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE Prog_Stations
										SET 
										  Program_No = :2, 
										  Station_No = :3,  
										  Water_Seq_No = :4, 
										  Crnt_Water_Sec = :5, 
										  Watered_Sec = :6, 
										  Station_Status = :7
										WHERE 
										  Instance_No = :1'
								Set sNAMEUpdateHandle = 'UPDTPRGSTATS'
								Set sBINDUpdateHandle = ':clsfrmPrograms.tblProgStations.colInstanceNo, 
										:clsfrmPrograms.tblProgStations.colProgramNo, 
										:clsfrmPrograms.tblProgStations.colStationNo, 
										:clsfrmPrograms.tblProgStations.colWaterSeqNo, 
										:clsfrmPrograms.tblProgStations.colStationCrntWaterSec, 
										:clsfrmPrograms.tblProgStations.colStationWateredSec, 
										:clsfrmPrograms.tblProgStations.colStationStatus'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = 'DELETE FROM Prog_Stations WHERE Instance_No = :1'
								Set sNAMEDeleteHandle = 'DELPRGSTATS'
								Set sBINDDeleteHandle = ':clsfrmPrograms.tblProgStations.colInstanceNo'
								Set sINTODeleteHandle = ''
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								!
								Set sTableHeading = 'Program Stations'
							On PAM_clsTBL_NOROWS
								Return TRUE
							On PAM_clsTBL_POPULATE
								If cbProgStationsSeqPressures
									Call SalTblReset( tblProgStationsSeqPressures )
								Call SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
								If cbProgStationsSeqPressures
									Call TableLoop( hWndForm, hWndForm, PAM_clsWATERING_ADJUSTSEQNO, 0, 0, 0, 'Calculating Pressures', TBL_cls_LowToHi )
							On PAM_clsTBL_SAVECHANGES
								! If cbProgStationsSeqPressures
									                     Call SalTblReset( tblProgStationsSeqPressures )
								If SalSendClassMessage( PAM_clsTBL_SAVECHANGES, wParam, lParam )
									If cbAutoAllocSeqNos
										If AllocStationSeqNos( nCurrentProgramNo, SalStrToNumber( hWndParent.clsfrmPrograms.ccTollerancePercent.GetNumber( ) ), SH_cls_Execute )
											Call AllocStationSeqNos( 0, 0, SH_cls_Commit )
										Else
											Call AllocStationSeqNos( 0, 0, SH_cls_Rollback )
									Call SalSendMsg( hWndForm, PAM_clsTBL_POPULATE, wParam, lParam )
								! If cbProgStationsSeqPressures
									                     Call TableLoop( hWndForm, hWndForm, PAM_clsWATERING_ADJUSTSEQNO, 0, 0, 0, 'Calculating Pressures', TBL_cls_LowToHi )
							On SAM_Destroy
								Call GetNextInstanceNo( colInstanceNo, SH_cls_Disconnect )
								Call AllocStationSeqNos( 0, 0, SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
							On SAM_FetchRowDone
								Call SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
								Call CalcRowWaterPercentage( colStationDefWaterSec, colStationCrntWaterSec, colWateringPercent )
								Return TRUE
							On PAM_clsWATERING_ADJUSTSEQNO
								! Call hWndParent.clsfrmPrograms.tblProgStationsSeqPressures.AddNew( colWaterSeqNo, colStationLitresMin, colPumpLitresMin )
								Call PushNumber( colWaterSeqNo )
								Call PushNumber( colStationLitresMin )
								Call PushNumber( colPumpLitresMin )
								If NOT SalSendMsg( hWndParent.clsfrmPrograms.tblProgStationsSeqPressures, PAM_clsWATERING_ADJUSTSEQNO, 1, 0 )
									Call PopNumber( colPumpLitresMin, TRUE )
									Call PopNumber( colStationLitresMin, TRUE )
									Call PopNumber( colWaterSeqNo, TRUE )
								Return TRUE

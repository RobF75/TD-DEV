					Number: nTmp
					Window Handle: hWndTmp
				Instance Variables
					! PUBLIC
					Window Handle: hWndPickIntoTable
					! PRIVATE
					Number: nProgramNo
					String: sProgramDesc
					Boolean: bRunning
				Functions
					Function: SetProgSwitchesFields
						Description:
						Returns
							Boolean:
						Parameters
							Boolean: bNewRunning
							Number: nNewProgramNo
							String: sNewProgramDesc
						Static Variables
						Local variables
						Actions
							Set bRunning = bNewRunning
							Set nProgramNo = nNewProgramNo
							Set sProgramDesc = sNewProgramDesc
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbProgSwitches.nActivateWindowType = ACTIVATE_DialogModal
						Set clspbProgSwitches.sActivateDialogName = 'dlgProgSwitches'
						Set clspbProgSwitches.hWndTable = hWndPickIntoTable
						Set clspbProgSwitches.hWndParentTable = hWndPickIntoTable
						Set clspbProgSwitches.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushWndHdl( hWndItem )
						Call PushNumber( bRunning )
						Call PushNumber( nProgramNo )
						Call PushString( sProgramDesc )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopString( sTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopWndHdl( hWndTmp, TRUE )
						Return TRUE

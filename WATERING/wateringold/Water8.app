			Date/Time: dtLastProgStoppedDT
			: fcCom2
				Class: fc_CommPorts
		Named Menus
		Internal Functions
			Function: SecondsBetween
				Description:
				Returns
					Number:
				Parameters
					Date/Time: dtFirstTime
					Date/Time: dtSecondTime
				Static Variables
				Local variables
					Date/Time: dtLowTime
					Date/Time: dtHiTime
					Number: nHour
					Number: nMinute
					Number: nSecond
					Number: nSecLowTime
					Number: nSecHiTime
				Actions
					If dtSecondTime > dtFirstTime
						Set dtHiTime = dtSecondTime
						Set dtLowTime = dtFirstTime
					Else
						Set dtHiTime = dtFirstTime
						Set dtLowTime = dtSecondTime
					Set nHour = SalDateHour( dtLowTime )
					Set nMinute = SalDateMinute( dtLowTime )
					Set nSecond = SalDateSecond( dtLowTime )
					Set nSecLowTime = ( nHour * 3600 ) + ( nMinute * 60 ) + nSecond
					Set nHour = SalDateHour( dtHiTime )
					Set nMinute = SalDateMinute( dtHiTime )
					Set nSecond = SalDateSecond( dtHiTime )
					Set nSecHiTime = ( nHour * 3600 ) + ( nMinute * 60 ) + nSecond
					Return nSecHiTime - nSecLowTime
			Function: CompareTime
				Description: Returns -1 if dtTimeA < dtTimeB, 0 if dtTimeA = dtTimeB, 1 if dtTimeA > dtTimeB
				Returns
					Number:
				Parameters
					Date/Time: dtTimeA
					Date/Time: dtTimeB
				Static Variables
				Local variables
				Actions
					Set dtTimeA = SalDateConstruct( 1996, 24, 11, SalDateHour( dtTimeA ), SalDateMinute( dtTimeA ), SalDateSecond( dtTimeA ) )
					Set dtTimeB = SalDateConstruct( 1996, 24, 11, SalDateHour( dtTimeB ), SalDateMinute( dtTimeB ), SalDateSecond( dtTimeB ) )
					If dtTimeA < dtTimeB
						Return -1
					Else If dtTimeA = dtTimeB
						Return 0
					Else
						Return 1
			!
			Function: TimeCheckIrrigation
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCheckSecondInterval
					Number: nMinSecondsBetweenProgs
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcProgHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nProgHandleNo
					Number: nProgActivateHandleNo
					Boolean: bCurrentlyActiveProgram
					Number: nCurrActiveProg
					!
					Number: nInd
					Boolean: bOk
					Boolean: bFoundSwitch
					Boolean: bProcessCurrentStatus
					Boolean: bProcess
					Boolean: bProgramSwitchStatus
					Boolean: bProgCurrActualSwitchStatus
					Number: nProgActivateSwitchNo
					!
					Number: naCurrentOnSwitchProgNo[*]
					String: saCurrentOnSwitchProgActions[*]
					String: saCurrentOnSwitchPrgInPrgrssAct[*]
					!
					! Program fields
					Number: nProgramNo
					Date/Time: dtProgStartDT
					Date/Time: dtProgNextDT
					String: sProgDesc
					Number: nProgRecurrDays
					String: sProgStatus
					!
					Number: naOnSwitchProgNos[*]
					String: saOnSwitchProgActions[*]
					String: saOnSwitchProgInProgressActions[*]
					Boolean: bSomeSwitchOn
					!
					Boolean: bProgramWatering
					Number: nFoundPos
				Actions
					Set nProgHandleNo = SqlHandlesGetReferenceNo( 'TimeCheckIrrigationProg' )
					Set nProgActivateHandleNo = SqlHandlesGetReferenceNo( 'TimeCheckIrrigationProgActivate' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Program_No, 
									  Prog_Start_DT, 
									  Prog_Next_DT, 
									  Prog_Desc, 
									  Recurr_Days, 
									  Prog_Status
									FROM 
									  Program
									WHERE
									  NOT EXISTS 
									  (
									    SELECT 
									      Prog_Switches.Program_No 
									    FROM 
									      Prog_Switches 
									    WHERE 
									      Prog_Switches.Program_No = Program.Program_No AND 
									      Prog_Action = 'ACTIVATE'
									  )
									ORDER BY 
									  Prog_Status, Prog_Next_DT "
							Set sName = 'PROGCHECK'
							Set sBind = ''
							Set sInto = ':nProgramNo, :dtProgStartDT, :dtProgNextDT, :sProgDesc, :nProgRecurrDays, :sProgStatus'
							Call haSqlHandles[ nProgHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nProgHandleNo ].hSqlHandle )
							!
							!
							Set sSql = " SELECT 
									  Program_No, 
									  Prog_Start_DT, 
									  Prog_Next_DT, 
									  Prog_Desc, 
									  Recurr_Days, 
									  Prog_Status
									FROM 
									  Program
									WHERE
									  EXISTS 
									  (
									    SELECT 
									      Prog_Switches.Program_No 
									    FROM 
									      Prog_Switches 
									    WHERE 
									      Prog_Switches.Program_No = Program.Program_No AND 
									      Prog_Action = 'ACTIVATE'
									  )
									ORDER BY 
									  Prog_Status, Prog_Next_DT "
							Set sName = 'PROGACTCHECK'
							Set sBind = ''
							Set sInto = ':nProgramNo, :dtProgStartDT, :dtProgNextDT, :sProgDesc, :nProgRecurrDays, :sProgStatus'
							Call haSqlHandles[ nProgActivateHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nProgActivateHandleNo ].hSqlHandle )
							!
							! Init program fields
							Set nProgramNo = NUMBER_Null
							Set dtProgStartDT = DATETIME_Null
							Set dtProgNextDT = DATETIME_Null
							Set sProgDesc = ''
							Set nProgRecurrDays = NUMBER_Null
							Set sProgStatus = ''
							Set bProgramWatering = FALSE
							!
							Set bOk = TRUE
							Call LogMaintenance( 0, '', '', 'OPEN' )
							Set bProgramWatering = FALSE
							!
							If haSqlHandles[ nProgActivateHandleNo ].Execute( )
								While haSqlHandles[ nProgActivateHandleNo ].FetchNext( nInd ) AND NOT bProgramWatering AND bOk
									If sProgStatus = 'ACTIVE'
										Call CheckProgActionSwitch( nProgramNo, 'ACTIVATE', bProgramSwitchStatus, bProgCurrActualSwitchStatus, SH_cls_Execute )
										If PerformProgramWatering( nProgramNo, TRUE, bProgCurrActualSwitchStatus, nCheckSecondInterval, bProgramWatering, SH_cls_Execute )
											If NOT bProgramWatering
												Set dtLastProgStoppedDT = SalDateCurrent(  )
												If sProgDesc = 'Manual'
													If DeleteManualProgram( nProgramNo, SH_cls_Execute )
														Call DeleteManualProgram( 0, SH_cls_Commit )
												Else
													If SetProgramStatus( nProgramNo, 'STOPPED', SH_cls_Execute )
														Call SetProgramStatus( 0, '', SH_cls_Commit )
										Else
											Set bOk = FALSE
									Else If sProgStatus = 'READY' OR sProgStatus = 'STOPPED'
										If NOT bProgramWatering AND sProgStatus = 'READY'
											If dtLastProgStoppedDT = DATETIME_Null OR SecondsBetween( dtLastProgStoppedDT, SalDateCurrent(  ) ) > nMinSecondsBetweenProgs
												Call CheckProgActionSwitch( nProgramNo, 'ACTIVATE', bProgramSwitchStatus, bProgCurrActualSwitchStatus, SH_cls_Execute )
												If NOT bProgramSwitchStatus
													Call GetCurrentlyActiveProgram( bCurrentlyActiveProgram, nCurrActiveProg, SH_cls_Execute )
													If bCurrentlyActiveProgram
														Call ResetProgram( nCurrActiveProg, SH_cls_Execute )
													!
													If ActivateProgram( nProgramNo, dtProgStartDT, dtProgNextDT, nProgRecurrDays, SH_cls_Execute )
														Call ActivateProgram( 0, DATETIME_Null, DATETIME_Null, 0, SH_cls_Commit )
														Call LogMaintenance( nProgramNo, 'PROGRAM', 'ACTIVE', 'APPEND' )
														If NOT PerformProgramWatering( nProgramNo, FALSE, bProgramSwitchStatus, nCheckSecondInterval, bProgramWatering, SH_cls_Execute )
															Set bOk = FALSE
													Else
														Set bOk = FALSE
										Else If sProgStatus = 'STOPPED'
											If SetProgramStatus( nProgramNo, 'READY', SH_cls_Execute )
												Call SetProgramStatus( 0, '', SH_cls_Commit )
												Set dtLastProgStoppedDT = SalDateCurrent(  )
											Else
												Set bOk = FALSE
							Else
								Set bOk = FALSE
							!
							If bOk
								If NOT bProgramWatering
									If haSqlHandles[ nProgHandleNo ].Execute( )
										Set bProgramWatering = FALSE
										While haSqlHandles[ nProgHandleNo ].FetchNext( nInd ) AND NOT bProgramWatering AND bOk
											If sProgStatus = 'ACTIVE'
												If PerformProgramWatering( nProgramNo, FALSE, FALSE, nCheckSecondInterval, bProgramWatering, SH_cls_Execute )
													If NOT bProgramWatering
														Set dtLastProgStoppedDT = SalDateCurrent(  )
														If sProgDesc = 'Manual'
															If DeleteManualProgram( nProgramNo, SH_cls_Execute )
																Call DeleteManualProgram( 0, SH_cls_Commit )
														Else
															If SetProgramStatus( nProgramNo, 'STOPPED', SH_cls_Execute )
																Call SetProgramStatus( 0, '', SH_cls_Commit )
												Else
													Set bOk = FALSE
											Else If sProgStatus = 'READY' OR sProgStatus = 'STOPPED'
												If NOT bProgramWatering AND sProgStatus = 'READY' AND dtProgNextDT <= SalDateCurrent(  )
													If dtLastProgStoppedDT = DATETIME_Null OR SecondsBetween( dtLastProgStoppedDT, SalDateCurrent(  ) ) > nMinSecondsBetweenProgs
														Call CheckProgActionSwitch( nProgramNo, 'BYPASS', bProgramSwitchStatus, bProgCurrActualSwitchStatus, SH_cls_Execute )
														If NOT bProgramSwitchStatus
															If ActivateProgram( nProgramNo, dtProgStartDT, dtProgNextDT, nProgRecurrDays, SH_cls_Execute )
																Call ActivateProgram( 0, DATETIME_Null, DATETIME_Null, 0, SH_cls_Commit )
																Call LogMaintenance( nProgramNo, 'PROGRAM', 'ACTIVE', 'APPEND' )
																If NOT PerformProgramWatering( nProgramNo, FALSE, bProgramSwitchStatus, nCheckSecondInterval, bProgramWatering, SH_cls_Execute )
																	Set bOk = FALSE
															Else
																Set bOk = FALSE
														Else
															Call ResetProgram( nProgramNo, SH_cls_Execute )
												Else If sProgStatus = 'STOPPED' AND ( SalNumberAbs( SalDateCurrent( ) - dtProgStartDT ) ) >= nProgRecurrDays 
													If SetProgramStatus( nProgramNo, 'READY', SH_cls_Execute )
														Call SetProgramStatus( 0, '', SH_cls_Commit )
														Set dtLastProgStoppedDT = SalDateCurrent(  )
													Else
														Set bOk = FALSE
									Else
										Set bOk = FALSE
							Call LogMaintenance( 0, '', '', 'CLOSE' )
							Return bOk
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nProgHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT PerformProgramWatering( 0, FALSE, FALSE, nCheckSecondInterval, bProgramWatering, SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT ActivateProgram( 0, DATETIME_Null, DATETIME_Null, 0, SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT SetProgramStatus( 0, '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT DeleteManualProgram( 0, SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT GetActivateSwitches( naOnSwitchProgNos, saOnSwitchProgActions, saOnSwitchProgInProgressActions, bSomeSwitchOn, SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT CheckProgActionSwitch( 0, '', bProgramSwitchStatus, bProgCurrActualSwitchStatus, SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT ResetProgram( nCurrActiveProg, SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT GetCurrentlyActiveProgram( bCurrentlyActiveProgram, nCurrActiveProg, SH_cls_Disconnect )
								Set bOk = FALSE
							Return bOk
			!
			Function: GetCurrentlyActiveProgram
				Description:
				Returns
					Boolean:
				Parameters
					Receive Boolean: bCurrentlyActiveProgram
					Receive Number: nCurrActiveProg
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					Number: nInd
					Number: nGotProgNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetCurrentlyActiveProgram' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Program_No 
									FROM 
									  Program 
									WHERE 
									  Prog_Status = 'ACTIVE' "
							Set sName = 'GTCRACTPRG'
							Set sBind = ''
							Set sInto = ':nGotProgNo'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set bCurrentlyActiveProgram = FALSE
							Set nCurrActiveProg = NUMBER_Null
							Set nGotProgNo = NUMBER_Null
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set nCurrActiveProg = nGotProgNo
									Set bCurrentlyActiveProgram = TRUE
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			!
			Function: ExtractOnSwitchDetails
				Description:
				Returns
					Boolean:
				Parameters
					! sSearchType = 'PROGRAM_ACTION', 'IN_PROGRESS_ACTION'
					String: sSearchType
					String: sSearchString
					Number: naOnSwitchProgNos[*]
					String: saOnSwitchProgActions[*]
					String: saOnSwitchProgInProgressActions[*]
					Receive Number: naCurrentOnSwitchProgNo[*]
					Receive String: saCurrentOnSwitchProgActions[*]
					Receive String: saCurrentOnSwitchPrgInPrgrssAct[*]
				Static Variables
				Local variables
					Number: nPos
					Number: nOnPos
					Boolean: bFound
				Actions
					Set nOnPos = 0
					Set naCurrentOnSwitchProgNo[ nOnPos ] = NUMBER_Null
					Set saCurrentOnSwitchProgActions[ nOnPos ] = ''
					Set saCurrentOnSwitchPrgInPrgrssAct[ nOnPos ] = ''
					Set nPos = 0
					Set bFound = FALSE
					While naOnSwitchProgNos[ nPos ] != NUMBER_Null
						If sSearchType = 'PROGRAM_ACTION'
							If sSearchString = saOnSwitchProgActions[ nPos ]
								Set bFound = TRUE
								Set naCurrentOnSwitchProgNo[ nOnPos ] = naOnSwitchProgNos[ nPos ]
								Set saCurrentOnSwitchProgActions[ nOnPos ] = saOnSwitchProgActions[ nPos ]
								Set saCurrentOnSwitchPrgInPrgrssAct[ nOnPos ] = saOnSwitchProgInProgressActions[ nPos ]
								Set nOnPos = nOnPos + 1
								Set naCurrentOnSwitchProgNo[ nOnPos ] = NUMBER_Null
								Set saCurrentOnSwitchProgActions[ nOnPos ] = ''
								Set saCurrentOnSwitchPrgInPrgrssAct[ nOnPos ] = ''
						Else
							If sSearchString = saOnSwitchProgInProgressActions[ nPos ]
								Set bFound = TRUE
								Set naCurrentOnSwitchProgNo[ nOnPos ] = naOnSwitchProgNos[ nPos ]
								Set saCurrentOnSwitchProgActions[ nOnPos ] = saOnSwitchProgActions[ nPos ]
								Set saCurrentOnSwitchPrgInPrgrssAct[ nOnPos ] = saOnSwitchProgInProgressActions[ nPos ]
								Set nOnPos = nOnPos + 1
								Set naCurrentOnSwitchProgNo[ nOnPos ] = NUMBER_Null
								Set saCurrentOnSwitchProgActions[ nOnPos ] = ''
								Set saCurrentOnSwitchPrgInPrgrssAct[ nOnPos ] = ''
						!
						Set nPos = nPos + 1
					Return bFound
			!
			Function: PerformProgramWatering
				Description:
				Returns
					Boolean:
				Parameters
					Number: nProgramNo
					Boolean: bCircularProgram
					Boolean: bActivateSwitchStatus
					Number: nCheckSecondInterval
					Receive Boolean: bProgramWatering
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nPumpHandleNo
					Number: nStationHandleNo
					Boolean: bFetched
					!
					Number: nInd
					Boolean: bOk
					!
					! Pump fields
					Number: nPumpNo
					Number: nPumpChannelNo
					Number: nPumpStartDelaySecs
					Number: nPumpDelayedSecs
					String: sPumpStatus
					!
					! Station fields
					Number: nActivateWaterSeq
					Number: nLastSeqNo
					Number: nMaxSeqStationCrntWaterSec
					Number: nNumDistinctSeqNos
					Boolean: bOverwaterActiveStations
					!
					Boolean: bStationWatering
					Number: nProgStatInstanceNo
					Number: nStationNo
					Number: nStationWaterSeqNo
					Number: nStationChannelNo
					Number: nStationCrntWaterSec
					Number: nStationWateredSec
					String: sStationStatus
				Actions
					Set nPumpHandleNo = SqlHandlesGetReferenceNo( 'PerformProgramWateringPump' )
					Set nStationHandleNo = SqlHandlesGetReferenceNo( 'PerformProgramWateringStation' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT DISTINCT
									  Station.Pump_No, 
									  Pump.Channel_No,  
									  Pump.Start_Delay_Secs, 
									  Pump.Delayed_Secs, 
									  Pump.Pump_Status 
									FROM 
									  Prog_Stations, Station, Pump 
									WHERE 
									  Prog_Stations.Program_No = :1 AND 
									  Prog_Stations.Station_No = Station.Station_No AND 
									  Station.Pump_No = Pump.Pump_No 
									ORDER BY 
									  Pump.Pump_Status DESC, Pump.Pump_Litres_Min DESC "
							Set sName = 'PROGPUMPCHECK'
							Set sBind = ':nProgramNo'
							Set sInto = ':nPumpNo, :nPumpChannelNo, :nPumpStartDelaySecs, :nPumpDelayedSecs, :sPumpStatus'
							Call haSqlHandles[ nPumpHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nPumpHandleNo ].hSqlHandle )
							!
							Set sSql = " SELECT 
									  Prog_Stations.Instance_No, 
									  Prog_Stations.Station_No, 
									  Prog_Stations.Water_Seq_No, 
									  Station.Channel_No, 
									  Prog_Stations.Crnt_Water_Sec, 
									  Prog_Stations.Watered_Sec, 
									  Prog_Stations.Station_Status
									FROM 
									  Prog_Stations, Station
									WHERE 
									  Prog_Stations.Program_No = :1 AND 
									  Prog_Stations.Station_No = Station.Station_No AND 
									  Station.Pump_No = :2
									ORDER BY 
									  Prog_Stations.Station_Status, 
									  Prog_Stations.Water_Seq_No, 
									  Prog_Stations.Crnt_Water_Sec DESC, 
									  Station.Station_Litres_Min DESC "
							Set sName = 'PROGSTATCHECK'
							Set sBind = ':nProgramNo, :nPumpNo'
							Set sInto = ':nProgStatInstanceNo, 
									:nStationNo, 
									:nStationWaterSeqNo, 
									:nStationChannelNo, 
									:nStationCrntWaterSec, 
									:nStationWateredSec, 
									:sStationStatus'
							Call haSqlHandles[ nStationHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nStationHandleNo ].hSqlHandle )
							!
							! Init pump fields
							Set nPumpNo = NUMBER_Null
							Set nPumpChannelNo = NUMBER_Null
							Set nPumpStartDelaySecs = NUMBER_Null
							Set nPumpDelayedSecs = NUMBER_Null
							Set sPumpStatus = ''
							! Init station fields
							Set nProgStatInstanceNo = NUMBER_Null
							Set nStationNo = NUMBER_Null
							Set nStationChannelNo = NUMBER_Null
							Set nStationCrntWaterSec = NUMBER_Null
							Set nStationWateredSec = NUMBER_Null
							Set sStationStatus = ''
							!
							Set nActivateWaterSeq = NUMBER_Null
							!
							Set bOk = TRUE
							If haSqlHandles[ nPumpHandleNo ].Execute( )
								While haSqlHandles[ nPumpHandleNo ].FetchNext( nInd )
									If nPumpDelayedSecs < nPumpStartDelaySecs
										Set nPumpDelayedSecs = nPumpDelayedSecs + nCheckSecondInterval
										Set bProgramWatering = TRUE
										If SetPumpDelayedSecs( nPumpNo, nPumpChannelNo, nPumpDelayedSecs, 'ON', SH_cls_Execute )
											Call SetPumpDelayedSecs( 0, 0, 0, '', SH_cls_Commit )
										Else
											Set bOk = FALSE
									Else
										If haSqlHandles[ nStationHandleNo ].Execute( )
											!
											Set nNumDistinctSeqNos = 0
											Set nLastSeqNo = NUMBER_Null
											While haSqlHandles[ nStationHandleNo ].FetchNext( nInd )
												If NOT nLastSeqNo = nStationWaterSeqNo
													Set nLastSeqNo = nStationWaterSeqNo
													Set nNumDistinctSeqNos = nNumDistinctSeqNos + 1
											!
											Set bStationWatering = FALSE
											Set nLastSeqNo = NUMBER_Null
											Set nMaxSeqStationCrntWaterSec = NUMBER_Null
											Set bFetched = haSqlHandles[ nStationHandleNo ].FetchFirst( nInd )
											While bFetched
												If nLastSeqNo = nStationWaterSeqNo
													If nStationCrntWaterSec > nMaxSeqStationCrntWaterSec
														Set nMaxSeqStationCrntWaterSec = nStationCrntWaterSec
												Else
													Set nLastSeqNo = nStationWaterSeqNo
													Set nMaxSeqStationCrntWaterSec = nStationCrntWaterSec
												!
												If sStationStatus = 'ACTIVE'
													Set nActivateWaterSeq = nStationWaterSeqNo
													!
													If bCircularProgram AND nNumDistinctSeqNos <= 1 AND bActivateSwitchStatus
														Set bOverwaterActiveStations = TRUE
													Else
														Set bOverwaterActiveStations = FALSE
													!
													If nStationWateredSec >= nMaxSeqStationCrntWaterSec AND NOT bOverwaterActiveStations
														If SetStationStatus( nProgStatInstanceNo, nStationNo, nStationChannelNo, 'STOPPED', SH_cls_Execute )
															Call SetStationStatus( 0, 0, 0, '', SH_cls_Commit )
														Else
															Set bOk = FALSE
													Else
														Set nStationWateredSec = nStationWateredSec + nCheckSecondInterval
														Set bStationWatering = TRUE
														If SetStationWateredSeconds( nProgStatInstanceNo, nStationNo, nStationChannelNo, nStationWateredSec, 'ACTIVE', SH_cls_Execute )
															Call SetStationWateredSeconds( 0, 0, 0, 0, '', SH_cls_Commit )
														Else
															Set bOk = FALSE
												Else If sStationStatus = 'READY'
													If NOT bStationWatering OR nActivateWaterSeq = nStationWaterSeqNo
														Set bStationWatering = TRUE
														Set nActivateWaterSeq = nStationWaterSeqNo
														If SetStationStatus( nProgStatInstanceNo, nStationNo, nStationChannelNo, 'ACTIVE', SH_cls_Execute )
															Call SetStationStatus( 0, 0, 0, '', SH_cls_Commit )
														Else
															Set bOk = FALSE
												Else If sStationStatus = 'STOPPED'
													If bCircularProgram AND bActivateSwitchStatus AND ( NOT bStationWatering ) OR ( nActivateWaterSeq = nStationWaterSeqNo )
														Set bStationWatering = TRUE
														Set nActivateWaterSeq = nStationWaterSeqNo
														If SetStationStatus( nProgStatInstanceNo, nStationNo, nStationChannelNo, 'ACTIVE', SH_cls_Execute )
															Call SetStationStatus( 0, 0, 0, '', SH_cls_Commit )
															If SetStationWateredSeconds( nProgStatInstanceNo, nStationNo, nStationChannelNo, 0, 'ACTIVE', SH_cls_Execute )
																Call SetStationWateredSeconds( 0, 0, 0, 0, '', SH_cls_Commit )
															Else
																Set bOk = FALSE
														Else
															Set bOk = FALSE
												!
												Set bFetched = haSqlHandles[ nStationHandleNo ].FetchNext( nInd )
											If bStationWatering
												Set bProgramWatering = TRUE
												If SetPumpStatus( nPumpNo, nPumpChannelNo, 'ON', SH_cls_Execute )
													Call SetPumpStatus( 0, 0, '', SH_cls_Commit )
												Else
													Set bOk = FALSE
											Else
												Set bProgramWatering = FALSE
												If SetPumpDelayedSecs( nPumpNo, nPumpChannelNo, 0, 'OFF', SH_cls_Execute )
													Call SetPumpDelayedSecs( 0, 0, 0, '', SH_cls_Commit )
												Else
													Set bOk = FALSE
										Else
											Set bOk = FALSE
							Else
								Set bOk = FALSE
							Return bOk
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nPumpHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nStationHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT SetStationStatus( 0, 0, 0, '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT SetPumpStatus( 0, 0, '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT SetStationWateredSeconds( 0, 0, 0, 0, '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT SetPumpDelayedSecs( 0, 0, 0, '', SH_cls_Disconnect )
								Set bOk = FALSE
							Return bOk
			! Function: PerformProgramWatering
				                                       Description: 
				                                       Returns 
					                                       Boolean: 
				                                       Parameters 
					                                       Number: nProgramNo
					                                       Number: nCheckSecondInterval
					                                       Receive Boolean: bProgramWatering
					                                       Number: nActionType
				                                       Static Variables 
					! hcSqlHandle: fcPumpHandle
					! hcSqlHandle: fcStationHandle
				                                       Local variables 
					                                       String: sSql
					                                       String: sBind
					                                       String: sInto
					                                       String: sName
					                                       Number: nPumpHandleNo
					                                       Number: nStationHandleNo
					!
					                                       Number: nInd
					                                       Boolean: bOk
					!
					! Pump fields
					                                       Number: nPumpNo
					                                       Number: nPumpChannelNo
					                                       Number: nPumpLitresMin
					                                       Number: nPumpStartDelaySecs
					                                       Number: nPumpDelayedSecs
					                                       String: sPumpStatus
					!
					                                       Number: nPumpStationFlow
					!
					! Station fields
					                                       Number: nActivateWaterSeq
					                                       Boolean: bStationWatering
					                                       Number: nProgStatInstanceNo
					                                       Number: nStationNo
					                                       Number: nStationWaterSeqNo
					                                       Number: nStationChannelNo
					                                       Number: nStationLitresMin
					                                       Number: nStationCrntWaterSec
					                                       Number: nStationWateredSec
					                                       String: sStationStatus
				                                       Actions 
					                                       Set nPumpHandleNo = SqlHandlesGetReferenceNo( 'PerformProgramWateringPump' )
					                                       Set nStationHandleNo = SqlHandlesGetReferenceNo( 'PerformProgramWateringStation' )
					                                       Select Case nActionType
						                                       Case SH_cls_Execute
							                                       Set sSql = " SELECT DISTINCT
									  Station.Pump_No, 
									  Pump.Channel_No,  
									  Pump.Pump_Litres_Min, 
									  Pump.Start_Delay_Secs, 
									  Pump.Delayed_Secs, 
									  Pump.Pump_Status 
									FROM 
									  Prog_Stations, Station, Pump 
									WHERE 
									  Prog_Stations.Program_No = :1 AND 
									  Prog_Stations.Station_No = Station.Station_No AND 
									  Station.Pump_No = Pump.Pump_No 
									ORDER BY 
									  Pump.Pump_Status DESC, Pump.Pump_Litres_Min DESC "
							                                       Set sName = 'PROGPUMPCHECK'
							                                       Set sBind = ':nProgramNo'
							                                       Set sInto = ':nPumpNo, :nPumpChannelNo, :nPumpLitresMin, :nPumpStartDelaySecs, :nPumpDelayedSecs, :sPumpStatus'
							                                       Call haSqlHandles[ nPumpHandleNo ].Setup( sSql, sName, sBind, sInto )
							                                       Call SqlVarSetup( haSqlHandles[ nPumpHandleNo ].hSqlHandle )
							!
							                                       Set sSql = " SELECT 
									  Prog_Stations.Instance_No, 
									  Prog_Stations.Station_No, 
									  Prog_Stations.Water_Seq_No, 
									  Station.Channel_No, 
									  Station.Station_Litres_Min, 
									  Prog_Stations.Crnt_Water_Sec, 
									  Prog_Stations.Watered_Sec, 
									  Prog_Stations.Station_Status
									FROM 
									  Prog_Stations, Station
									WHERE 
									  Prog_Stations.Program_No = :1 AND 
									  Prog_Stations.Station_No = Station.Station_No AND 
									  Station.Pump_No = :2
									ORDER BY 
									  Prog_Stations.Station_Status, 
									  Prog_Stations.Water_Seq_No, 
									  Station.Station_Litres_Min DESC "
							                                       Set sName = 'PROGSTATCHECK'
							                                       Set sBind = ':nProgramNo, :nPumpNo'
							                                       Set sInto = ':nProgStatInstanceNo, 
									:nStationNo, 
									:nStationWaterSeqNo, 
									:nStationChannelNo, 
									:nStationLitresMin, 
									:nStationCrntWaterSec, 
									:nStationWateredSec, 
									:sStationStatus'
							                                       Call haSqlHandles[ nStationHandleNo ].Setup( sSql, sName, sBind, sInto )
							                                       Call SqlVarSetup( haSqlHandles[ nStationHandleNo ].hSqlHandle )
							!
							! Init pump fields
							                                       Set nPumpNo = NUMBER_Null
							                                       Set nPumpChannelNo = NUMBER_Null
							                                       Set nPumpLitresMin = NUMBER_Null
							                                       Set nPumpStartDelaySecs = NUMBER_Null
							                                       Set nPumpDelayedSecs = NUMBER_Null
							                                       Set sPumpStatus = ''
							! Init station fields
							                                       Set nProgStatInstanceNo = NUMBER_Null
							                                       Set nStationNo = NUMBER_Null
							                                       Set nStationChannelNo = NUMBER_Null
							                                       Set nStationLitresMin = NUMBER_Null
							                                       Set nStationCrntWaterSec = NUMBER_Null
							                                       Set nStationWateredSec = NUMBER_Null
							                                       Set sStationStatus = ''
							!
							                                       Set nActivateWaterSeq = NUMBER_Null
							!
							                                       Set bOk = TRUE
							                                       If haSqlHandles[ nPumpHandleNo ].Execute( )
								                                       While haSqlHandles[ nPumpHandleNo ].FetchNext( nInd )
									                                       Set nPumpStationFlow = 0
									                                       If nPumpDelayedSecs < nPumpStartDelaySecs
										                                       Set nPumpDelayedSecs = nPumpDelayedSecs + nCheckSecondInterval
										                                       Set bProgramWatering = TRUE
										                                       If SetPumpDelayedSecs( nPumpNo, nPumpChannelNo, nPumpDelayedSecs, 'ON', SH_cls_Execute )
											                                       Call SetPumpDelayedSecs( 0, 0, 0, '', SH_cls_Commit )
										                                       Else 
											                                       Set bOk = FALSE
									                                       Else 
										                                       If haSqlHandles[ nStationHandleNo ].Execute( )
											                                       Set bStationWatering = FALSE
											                                       Set bNextWaterSeqNo = FALSE
											                                       While haSqlHandles[ nStationHandleNo ].FetchNext( nInd )
												                                       If sStationStatus = 'ACTIVE'
													                                       Set nActivateWaterSeq = nStationWaterSeqNo
													                                       If nStationWateredSec >= nStationCrntWaterSec
														                                       If SetStationStatus( nProgStatInstanceNo, nStationNo, nStationChannelNo, 'STOPPED', SH_cls_Execute )
															                                       Call SetStationStatus( 0, 0, 0, '', SH_cls_Commit )
															                                       Set bNextWaterSeqNo = TRUE
														                                       Else 
															                                       Set bOk = FALSE
													                                       Else 
														                                       Set nStationWateredSec = nStationWateredSec + nCheckSecondInterval
														                                       Set nPumpStationFlow = nPumpStationFlow + nStationLitresMin
														                                       Set bStationWatering = TRUE
														                                       If SetStationWateredSeconds( nProgStatInstanceNo, nStationNo, nStationChannelNo, nStationWateredSec, 'ACTIVE', SH_cls_Execute )
															                                       Call SetStationWateredSeconds( 0, 0, 0, 0, '', SH_cls_Commit )
														                                       Else 
															                                       Set bOk = FALSE
												                                       Else If sStationStatus = 'READY'
													                                       If ( nPumpStationFlow + nStationLitresMin <= nPumpLitresMin ) OR 
															( nPumpStationFlow = 0 AND nStationLitresMin > nPumpLitresMin )
														                                       Set bStationWatering = TRUE
														                                       Set nPumpStationFlow = nPumpStationFlow + nStationLitresMin
														                                       If SetStationStatus( nProgStatInstanceNo, nStationNo, nStationChannelNo, 'ACTIVE', SH_cls_Execute )
															                                       Call SetStationStatus( 0, 0, 0, '', SH_cls_Commit )
														                                       Else 
															                                       Set bOk = FALSE
												                                       Else If sStationStatus = 'STOPPED'
													                                       If ( ( nPumpStationFlow + nStationLitresMin <= nPumpLitresMin ) OR 
															( nPumpStationFlow = 0 AND nStationLitresMin > nPumpLitresMin ) ) AND bStationWatering
														                                       Set bStationWatering = TRUE
														                                       Set nPumpStationFlow = nPumpStationFlow + nStationLitresMin
														                                       If SetStationStatus( nProgStatInstanceNo, nStationNo, nStationChannelNo, 'SUPPLEMENT', SH_cls_Execute )
															                                       Call SetStationStatus( 0, 0, 0, '', SH_cls_Commit )
														                                       Else 
															                                       Set bOk = FALSE
													                                       Else 
														                                       If sStationStatus = 'SUPPLEMENT'
															                                       If SetStationStatus( nProgStatInstanceNo, nStationNo, nStationChannelNo, 'STOPPED', SH_cls_Execute )
																                                       Call SetStationStatus( 0, 0, 0, '', SH_cls_Commit )
															                                       Else 
																                                       Set bOk = FALSE
											                                       If bStationWatering
												                                       Set bProgramWatering = TRUE
												                                       If SetPumpStatus( nPumpNo, nPumpChannelNo, 'ON', SH_cls_Execute )
													                                       Call SetPumpStatus( 0, 0, '', SH_cls_Commit )
												                                       Else 
													                                       Set bOk = FALSE
											                                       Else 
												                                       Set bProgramWatering = FALSE
												                                       If SetPumpDelayedSecs( nPumpNo, nPumpChannelNo, 0, 'OFF', SH_cls_Execute )
													                                       Call SetPumpDelayedSecs( 0, 0, 0, '', SH_cls_Commit )
												                                       Else 
													                                       Set bOk = FALSE
										                                       Else 
											                                       Set bOk = FALSE
							                                       Else 
								                                       Set bOk = FALSE
							                                       Return bOk
						                                       Case SH_cls_Disconnect
							                                       Set bOk = TRUE
							                                       If NOT haSqlHandles[ nPumpHandleNo ].Disconnect( )
								                                       Set bOk = FALSE
							                                       If NOT haSqlHandles[ nStationHandleNo ].Disconnect( )
								                                       Set bOk = FALSE
							                                       If NOT SetStationStatus( 0, 0, 0, '', SH_cls_Disconnect )
								                                       Set bOk = FALSE
							                                       If NOT SetPumpStatus( 0, 0, '', SH_cls_Disconnect )
								                                       Set bOk = FALSE
							                                       If NOT SetStationWateredSeconds( 0, 0, 0, 0, '', SH_cls_Disconnect )
								                                       Set bOk = FALSE
							                                       If NOT SetPumpDelayedSecs( 0, 0, 0, '', SH_cls_Disconnect )
								                                       Set bOk = FALSE
							                                       Return bOk
			Function: SetPumpDelayedSecs
				Description:
				Returns
					Boolean:
				Parameters
					Number: nPumpNo
					Number: nChannelNo
					Number: nPumpDelayedSecs
					String: sStatus
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SetPumpDelayedSecs' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " UPDATE Pump  
									SET 
									  Delayed_Secs = :2, 
									  Pump_Status = :3 
									WHERE Pump_No = :1 "
							Set sName = 'SETPMPDELAYED'
							Set sBind = ':nPumpNo, :nPumpDelayedSecs, :sStatus'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Call LogMaintenance( nPumpNo, 'PUMP', sStatus, 'APPEND' )
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If sStatus = 'ON'
									Call SetChannelState( nChannelNo, 1, SH_cls_Execute )
								Else
									Call SetChannelState( nChannelNo, 0, SH_cls_Execute )
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Commit
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Call SetChannelState( 0, 0, SH_cls_Disconnect )
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: SetPumpStatus
				Description:
				Returns
					Boolean:
				Parameters
					Number: nPumpNo
					Number: nChannelNo
					String: sStatus
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SetPumpStatus' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " UPDATE Pump  
									SET 
									  Pump_Status = :2
									WHERE Pump_No = :1 "
							Set sName = 'SETPUMPSTATUS'
							Set sBind = ':nPumpNo, :sStatus'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Call LogMaintenance( nPumpNo, 'PUMP', sStatus, 'APPEND' )
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If sStatus = 'ON'
									Call SetChannelState( nChannelNo, 1, SH_cls_Execute )
								Else
									Call SetChannelState( nChannelNo, 0, SH_cls_Execute )
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Commit
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Call SetChannelState( 0, 0, SH_cls_Disconnect )
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			!
			Function: SetChannelState
				Description:
				Returns
					Boolean:
				Parameters
					Number: nChannelNo
					! nStatus = 1 = ON, 0 = OFF
					Number: nStatus
					Number: nActionType
				Static Variables
				Local variables
					Boolean: bOk
				Actions
					Select Case nActionType
						Case SH_cls_Execute
							Return SetOrGetChannelState( nChannelNo, nStatus, 'SET', bOk, SH_cls_Execute )
						Case SH_cls_Disconnect
							Return SetOrGetChannelState( 0, nStatus, '', bOk, SH_cls_Disconnect )
			Function: GetChannelState
				Description:
				Returns
					Boolean:
				Parameters
					Number: nChannelNo
					! nStatus = 1 = ON, 0 = OFF
					Receive Number: nStatus
					Receive Boolean: bInputOk
					Number: nActionType
				Static Variables
				Local variables
					Number: nGotStatus
					Boolean: bOk
				Actions
					Select Case nActionType
						Case SH_cls_Execute
							Set bOk = SetOrGetChannelState( nChannelNo, nGotStatus, 'GET', bInputOk, SH_cls_Execute )
							Set nStatus = nGotStatus
							Return bOk
						Case SH_cls_Disconnect
							Return SetOrGetChannelState( 0, nStatus, '', bInputOk, SH_cls_Disconnect )
			Function: SetOrGetChannelState
				Description:
				Returns
					Boolean:
				Parameters
					Number: nChannelNo
					! nStatus = 1 = ON, 0 = OFF
					Receive Number: nStatus
					! sSetOrGet = 'SET' OR 'GET'
					String: sSetOrGet
					Receive Boolean: bInputOutputOk
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nOurHandleNo
					!
					String: sBoardNo
					String: sBoardPortNo
					Number: nGotStatus
					Boolean: bOk
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SetOrGetChannelState' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Board_No, 
									  Board_Port_No
									FROM 
									  Channels 
									WHERE Channel_No = :1 "
							Set sName = 'SETCHNNELSTATUS'
							Set sBind = ':nChannelNo'
							Set sInto = ':sBoardNo, :sBoardPortNo'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set bInputOutputOk = TRUE
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									If sSetOrGet = 'SET'
										Set bInputOutputOk = DIG_Out_Line( sBoardNo, sBoardPortNo, nStatus )
									Else
										Set nStatus = NUMBER_Null
										Set bInputOutputOk = DIG_In_Line( sBoardNo, sBoardPortNo, nGotStatus )
										!
										! Call PushString( sBoardNo )
										! Call PushString( sBoardPortNo )
										! If SalSendMsg( tblTempSwitchControl, PAM_clsWATERING_REFRESHDATA, 0, 0 )
											                 Call PopNumber( nGotStatus, TRUE )
											                 Set bInputOutputOk = TRUE
										! Else
											                 Call PopString( sBoardPortNo, TRUE )
											                 Call PopString( sBoardNo, TRUE )
											                 Set bInputOutputOk = FALSE
										!
										Set nStatus = nGotStatus
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			!
			Function: SetSwitchDBStatus
				Description:
				Returns
					Boolean:
				Parameters
					Number: nSwitchNo
					String: sStatus
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end

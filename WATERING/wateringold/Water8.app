				Derived From
					Class: clsDialogGeneral
				Class Variables
				Instance Variables
					! PRIVATE
					Boolean: bRunning
					Window Handle: hWndActivateButton
				Functions
					Function: AdjustWaterByPercent
						Description:
						Returns
							Boolean:
						Parameters
							Boolean: bIncrease
							Number: nPercent
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'AdjustWaterByPercent' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " UPDATE Prog_Stations 
											SET 
											  Crnt_Water_Sec = Crnt_Water_Sec + ( ( Crnt_Water_Sec / 100 ) * :1 ) "
									Set sName = 'ADJSTWTRING'
									Set sBind = ':nPercent'
									Set sInto = ''
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									If NOT bIncrease
										Set nPercent = nPercent * -1
									Return haSqlHandles[ nOurHandleNo ].Execute( )
								Case SH_cls_Commit
									Return haSqlHandles[ nOurHandleNo ].Commit( )
								Case SH_cls_Rollback
									Return haSqlHandles[ nOurHandleNo ].Rollback( )
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					Function: ResetToOriginal
						Description:
						Returns
							Boolean:
						Parameters
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nInd
							Number: nOurHandleNo
							!
							Number: nGotStationNo
							Number: nGotDefWaterSecs
							Boolean: bOk
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'ResetToOriginal' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT Station_No, Def_Water_Secs FROM Station "
									Set sName = 'GTADJSTTOORIG'
									Set sBind = ''
									Set sInto = ':nGotStationNo, :nGotDefWaterSecs'
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set nGotStationNo = NUMBER_Null
									Set nGotDefWaterSecs = NUMBER_Null
									If haSqlHandles[ nOurHandleNo ].Execute( )
										While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
											If SetProgStationsCrntWaterSec( nGotStationNo, nGotDefWaterSecs, SH_cls_Execute )
												Call SetProgStationsCrntWaterSec( 0, 0, SH_cls_Commit )
										Return TRUE
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Call SetProgStationsCrntWaterSec( 0, 0, SH_cls_Disconnect )
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					Function: SetProgStationsCrntWaterSec
						Description:
						Returns
							Boolean:
						Parameters
							Number: nStationNo
							Number: nCrntWaterSec
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nInd
							Number: nOurHandleNo
							!
							Boolean: bOk
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SetProgStationsCrntWaterSec' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " UPDATE Prog_Stations 
											SET 
											  Crnt_Water_Sec = :2
											WHERE 
											  Station_No = :1 "
									Set sName = 'SETPRSTCWSEC'
									Set sBind = ':nStationNo, :nCrntWaterSec'
									Set sInto = ''
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Return haSqlHandles[ nOurHandleNo ].Execute( )
								Case SH_cls_Commit
									Return haSqlHandles[ nOurHandleNo ].Commit( )
								Case SH_cls_Rollback
									Return haSqlHandles[ nOurHandleNo ].Rollback( )
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set bTreeSystem = FALSE
					On PAM_clsDLG_POPFIELDS
						Call PopNumber( bRunning, FALSE )
						Call PopWndHdl( hWndActivateButton, TRUE )
						Return TRUE
					On PAM_clsPB_OKACTION
						If bRunning
							Call SalMessageBox( 'Please stop the watering system before carring out any maintenance.', 'NOTE', MB_Ok )
						Else
							If cbAdjust
								If AdjustWaterByPercent( rbIncrease, SalStrToNumber( ccAdjustPercent.GetNumber( ) ), SH_cls_Execute )
									Call AdjustWaterByPercent( FALSE, 0, SH_cls_Commit )
							Else
								If ResetToOriginal( SH_cls_Execute )
									Call ResetToOriginal( SH_cls_Commit )
						Return SalSendMsg( pbExit, SAM_Click, TRUE, 0 )
					On SAM_CreateComplete
						Call SalSendMsg( cbAdjust, PAM_clsCB_SET, TRUE, 0 )
						Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
					On SAM_Destroy
						Call AdjustWaterByPercent( FALSE, 0, SH_cls_Disconnect )
						Call ResetToOriginal( SH_cls_Disconnect )
						Call SalSendMsg( hWndActivateButton, PAM_clsDLG_RETURN, 0, 0 )
						Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
			!

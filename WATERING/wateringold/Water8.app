						Functions
							! Function: AddNew
								                                       Description: 
								                                       Returns 
								                                       Parameters 
									                                       Number: nSeqNo
									                                       Number: nStationLitresMin
									                                       Number: nPumpLitresMin
								                                       Static Variables 
								                                       Local variables 
									                                       Number: nRow
								                                       Actions 
									                                       Set bFound = FALSE
									                                       Set nLookUpSeqNo = nSeqNo
									                                       Call TableLoop( tblProgStationsSeqPressures, tblProgStationsSeqPressures, PAM_clsTBL_ROWACTION, 1, 0, 0, 'Updating Pressures', TBL_cls_LowToHi )
									                                       If bFound
										                                       Set tblProgStationsSeqPressures.colStationLitresMin = tblProgStationsSeqPressures.colStationLitresMin + nStationLitresMin
									                                       Else 
										                                       Set nRow = SalTblInsertRow( tblProgStationsSeqPressures, TBL_MaxRow )
										                                       Call SalTblSetContext( tblProgStationsSeqPressures, nRow )
										! Call SalTblSetRowFlags( tblProgStationsSeqPressures, nRow, ROW_HideMarks, TRUE )
										                                       Set tblProgStationsSeqPressures.colSeqNo = nSeqNo
										                                       Set tblProgStationsSeqPressures.colStationLitresMin = nStationLitresMin
										                                       Set tblProgStationsSeqPressures.colPumpLitresMin = nPumpLitresMin
							! Function: SubtractNew
								                                       Description: 
								                                       Returns 
								                                       Parameters 
									                                       Number: nSeqNo
									                                       Number: nStationLitresMin
									                                       Number: nPumpLitresMin
								                                       Static Variables 
								                                       Local variables 
									                                       Number: nRow
								                                       Actions 
									                                       Set bFound = FALSE
									                                       Set nLookUpSeqNo = nSeqNo
									                                       Call TableLoop( tblProgStationsSeqPressures, tblProgStationsSeqPressures, PAM_clsTBL_ROWACTION, 2, 0, 0, 'Updating Pressures', TBL_cls_LowToHi )
									                                       If bFound
										                                       Set tblProgStationsSeqPressures.colStationLitresMin = tblProgStationsSeqPressures.colStationLitresMin - nStationLitresMin
										                                       If tblProgStationsSeqPressures.colStationLitresMin <= 0
											                                       Call SalTblDeleteRow( tblProgStationsSeqPressures, SalTblQueryContext( tblProgStationsSeqPressures ), TBL_NoAdjust )
						Window Variables
							Boolean: bFound
							Number: nLookUpSeqNo
							Number: nStationLitresMin
							Number: nPumpLitresMin
							Number: nRow
						Message Actions
							On PAM_clsWATERING_ADJUSTSEQNO
								! wParam = 1 = AddNew
								! wParam = 2 = SubtractNew
								If wParam = 1
									Call PopNumber( nPumpLitresMin, TRUE )
									Call PopNumber( nStationLitresMin, TRUE )
									Call PopNumber( nLookUpSeqNo, TRUE )
									Set bFound = FALSE
									Call TableLoop( tblProgStationsSeqPressures, tblProgStationsSeqPressures, PAM_clsTBL_ROWACTION, 1, 0, 0, 'Updating Pressures', TBL_cls_LowToHi )
									If bFound
										Set tblProgStationsSeqPressures.colStationLitresMin = tblProgStationsSeqPressures.colStationLitresMin + nStationLitresMin
										Set tblProgStationsSeqPressures.colDifference = tblProgStationsSeqPressures.colStationLitresMin - tblProgStationsSeqPressures.colPumpLitresMin
									Else
										Set nRow = SalTblInsertRow( tblProgStationsSeqPressures, TBL_MaxRow )
										Call SalTblSetContext( tblProgStationsSeqPressures, nRow )
										Call SalTblSetRowFlags( tblProgStationsSeqPressures, nRow, ROW_HideMarks, TRUE )
										Set tblProgStationsSeqPressures.colSeqNo = nLookUpSeqNo
										Set tblProgStationsSeqPressures.colStationLitresMin = nStationLitresMin
										Set tblProgStationsSeqPressures.colPumpLitresMin = nPumpLitresMin
										Set tblProgStationsSeqPressures.colDifference = tblProgStationsSeqPressures.colStationLitresMin - tblProgStationsSeqPressures.colPumpLitresMin
									Return TRUE
								Else
									Call PopNumber( nPumpLitresMin, TRUE )
									Call PopNumber( nStationLitresMin, TRUE )
									Call PopNumber( nLookUpSeqNo, TRUE )
									Set bFound = FALSE
									Call TableLoop( tblProgStationsSeqPressures, tblProgStationsSeqPressures, PAM_clsTBL_ROWACTION, 2, 0, 0, 'Updating Pressures', TBL_cls_LowToHi )
									If bFound
										Set tblProgStationsSeqPressures.colStationLitresMin = tblProgStationsSeqPressures.colStationLitresMin - nStationLitresMin
										Set tblProgStationsSeqPressures.colDifference = tblProgStationsSeqPressures.colStationLitresMin - tblProgStationsSeqPressures.colPumpLitresMin
										If tblProgStationsSeqPressures.colStationLitresMin <= 0
											Call SalTblDeleteRow( tblProgStationsSeqPressures, SalTblQueryContext( tblProgStationsSeqPressures ), TBL_NoAdjust )
									Return TRUE
							On PAM_clsTBL_ROWACTION
								If nLookUpSeqNo = colSeqNo
									Set bFound = TRUE
									Return FALSE
								Else
									Return TRUE

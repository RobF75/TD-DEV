						Case SH_cls_Execute
							Set sSql = " UPDATE Prog_Stations  
									SET 
									  Station_Status = 'READY', 
									  Watered_Sec = 0
									WHERE Program_No = :1 "
							Set sName = 'STPSTREADY'

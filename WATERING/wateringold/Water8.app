									On PAM_clsTBL_DATAVAL
										If colPumpStatus = 'ON'
											Return TRUE
										If colPumpStatus = 'OFF'
											Return TRUE
										Else
											Call ErrorMessage( 'Please select a valid Pump status!', hWndForm, lParam )
											Return FALSE
									On PAM_clsTBL_ROWNEWINIT
										Set colPumpStatus = 'OFF'
									On PAM_clsTBL_EDITCHECK
										If hWndForm.hWndParent.clsdlgPumps.bRunning
											Return FALSE
										Else
											Return TRUE
						Functions
							Function: GetNextPumpNo
								Description:
								Returns
									Boolean:
								Parameters
									Receive Number: nNextPumpNo
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
									Number: nGotPumpNo
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetNextPumpNo' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Max( Pump_No ) + 1
													FROM Pump "
											Set sName = 'NXTPUMPNO'
											Set sBind = ''
											Set sInto = ':nGotPumpNo'
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set nNextPumpNo = NUMBER_Null
											Set nGotPumpNo = NUMBER_Null
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													If NOT nGotPumpNo > 0
														Set nGotPumpNo = 1
													Set nNextPumpNo = nGotPumpNo
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: ExistsPumpStation
								Description:
								Returns
									Boolean:
								Parameters
									Number: nPumpNo
									Receive Boolean: bExists
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'ExistsPumpStation' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Station_No 
													FROM Station
													WHERE Pump_No = :1 "
											Set sName = 'EXISTPMPSTS'
											Set sBind = ''
											Set sInto = ''
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set bExists = FALSE
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set bExists = TRUE
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
						Window Variables
							Boolean: bExists
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = " SELECT 
										  Pump_No, 
										  Channel_No, 
										  Pump_Desc, 
										  Pump_Litres_Min, 
										  Start_Delay_Secs, 
										  Delayed_Secs, 
										  Pump_Status
										FROM Pump 
										ORDER BY Pump_Desc "
								Set sNAMEPopHandle = 'POPPUMPS'
								Set sBINDPopHandle = ''
								Set sINTOPopHandle = ':clsdlgPumps.tblPumps.colPumpNo,
										:clsdlgPumps.tblPumps.colPumpChannelNo,
										:clsdlgPumps.tblPumps.colPumpDesc,
										:clsdlgPumps.tblPumps.colPumpLitresMin,
										:clsdlgPumps.tblPumps.colPumpStartDelay, 
										:clsdlgPumps.tblPumps.colPumpDelayed, 
										:clsdlgPumps.tblPumps.colPumpStatus'
								!
								Set sSQLRefreshHandle = " SELECT 
										  Pump_No, 
										  Channel_No, 
										  Pump_Desc, 
										  Pump_Litres_Min, 
										  Start_Delay_Secs, 
										  Delayed_Secs, 
										  Pump_Status
										FROM Pump 
										WHERE Pump_No = :1 "
								Set sNAMERefreshHandle = 'REFPUMPS'
								Set sBINDRefreshHandle = ':clsdlgPumps.tblPumps.colPumpNo'
								Set sINTORefreshHandle = ':clsdlgPumps.tblPumps.colPumpNo,
										:clsdlgPumps.tblPumps.colPumpChannelNo,
										:clsdlgPumps.tblPumps.colPumpDesc,
										:clsdlgPumps.tblPumps.colPumpLitresMin,
										:clsdlgPumps.tblPumps.colPumpStartDelay, 
										:clsdlgPumps.tblPumps.colPumpDelayed, 
										:clsdlgPumps.tblPumps.colPumpStatus'
								!
								Set sSQLInsertHandle = " INSERT INTO Pump  
										( Pump_No, 
										  Channel_No, 
										  Pump_Desc, 
										  Pump_Litres_Min, 
										  Start_Delay_Secs, 
										  Delayed_Secs, 
										  Pump_Status ) VALUES ( :1, :2, :3, :4, :5, :6, :7 ) "
								Set sNAMEInsertHandle = 'INSPUMPS'
								Set sBINDInsertHandle = ':clsdlgPumps.tblPumps.colPumpNo,
										:clsdlgPumps.tblPumps.colPumpChannelNo,
										:clsdlgPumps.tblPumps.colPumpDesc,
										:clsdlgPumps.tblPumps.colPumpLitresMin,
										:clsdlgPumps.tblPumps.colPumpStartDelay, 
										:clsdlgPumps.tblPumps.colPumpDelayed, 
										:clsdlgPumps.tblPumps.colPumpStatus'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE Pump
										SET 
										  Channel_No = :2, 
										  Pump_Desc = :3, 
										  Pump_Litres_Min = :4, 
										  Start_Delay_Secs = :5, 
										  Delayed_Secs = :6, 
										  Pump_Status = :7
										WHERE 
										  Pump_No = :1'
								Set sNAMEUpdateHandle = 'UPDTPUMPS'
								Set sBINDUpdateHandle = ':clsdlgPumps.tblPumps.colPumpNo,
										:clsdlgPumps.tblPumps.colPumpChannelNo,
										:clsdlgPumps.tblPumps.colPumpDesc,
										:clsdlgPumps.tblPumps.colPumpLitresMin,
										:clsdlgPumps.tblPumps.colPumpStartDelay, 
										:clsdlgPumps.tblPumps.colPumpDelayed, 
										:clsdlgPumps.tblPumps.colPumpStatus'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = 'DELETE FROM Pump WHERE Pump_No = :1'
								Set sNAMEDeleteHandle = 'DELPUMPS'
								Set sBINDDeleteHandle = ':clsdlgPumps.tblPumps.colPumpNo'
								Set sINTODeleteHandle = ''
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								!
								Set hWndRowNewColumn = colPumpDesc
								Set sTableHeading = 'Pumps'
							On PAM_clsTBL_NOROWS
								Return TRUE
							On SAM_Destroy
								Call GetNextPumpNo( colPumpNo, SH_cls_Disconnect )
								Call ExistsPumpStation( 0, bExists, SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
				Derived From
					Class: clsDialogChildTable
				Class Variables
				Instance Variables
					Window Handle: hWndSelectParent
					Boolean: bRunning
				Functions
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set hWndChildTable = tblPumps
						Set bAddAllowed = TRUE
						Set bSaveAllowed = TRUE
						Set bDeleteAllowed = TRUE
						Set bUnDeleteAllowed = TRUE
						Set bClearSelectAllowed = TRUE
						Set bQueryAllowed = FALSE
						Set bRepopulateAllowed = TRUE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = FALSE
						Set bPrintFormAllowed = TRUE
						Set bTreeSystem = FALSE
					On PAM_clsDLG_POPFIELDS
						Call PopNumber( bRunning, TRUE )
						Call PopWndHdl( hWndSelectParent, TRUE )
						Return TRUE
					On PAM_clsTBL_USERACTIONS
						If bRunning
							If wParam = TBL_cls_RePopTable OR wParam = TBL_cls_OrderTable OR wParam = TBL_cls_ClearRow OR wParam = TBL_cls_ZoomTable
								Return SalSendClassMessage( PAM_clsTBL_USERACTIONS, wParam, lParam )
							Else
								Call SalMessageBox( 'Please stop the watering system before carring out any maintenance.', 'NOTE', MB_Ok )
								Return TRUE
						Else
							Return SalSendClassMessage( PAM_clsTBL_USERACTIONS, wParam, lParam )
			!

				Class Variables
				Instance Variables
					Window Handle: hWndSelectParent
					Boolean: bRunning
				Functions
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set hWndChildTable = tblChannels
						Set bAddAllowed = TRUE
						Set bSaveAllowed = TRUE
						Set bDeleteAllowed = TRUE
						Set bUnDeleteAllowed = TRUE
						Set bClearSelectAllowed = TRUE
						Set bQueryAllowed = FALSE
						Set bRepopulateAllowed = TRUE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = FALSE
						Set bPrintFormAllowed = TRUE
						Set bTreeSystem = FALSE
					On PAM_clsDLG_POPFIELDS
						Call PopNumber( bRunning, TRUE )
						Call PopWndHdl( hWndSelectParent, TRUE )
						Return TRUE
					On PAM_clsTBL_USERACTIONS
						If bRunning
							If wParam = TBL_cls_RePopTable OR wParam = TBL_cls_OrderTable OR wParam = TBL_cls_ClearRow OR wParam = TBL_cls_ZoomTable
								Return SalSendClassMessage( PAM_clsTBL_USERACTIONS, wParam, lParam )
							Else
								Call SalMessageBox( 'Please stop the watering system before carring out any maintenance.', 'NOTE', MB_Ok )
								Return TRUE
						Else
							Return SalSendClassMessage( PAM_clsTBL_USERACTIONS, wParam, lParam )

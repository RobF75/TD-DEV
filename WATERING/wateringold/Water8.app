			Functional Class: fc_CommPorts
				Description: Operats 1 com port at a time, use two instances to operate two com ports.
				Derived From
				Class Variables
				Instance Variables
					Number: nPortId
				Functions
					Function: Open
						Description:
						Returns
							Number:
						Parameters
							String: sInputCom
							Number: nInputBaud
							String: sInputParity
							Number: nInputDataBits
							Number: nInputStopBits
						Static Variables
						Local variables
							Number: nPort
							Number: nRet
							!
							Number: nDCBLength
							Number: nDCBBaudRate
							Number: nDCBfBinary
							Number: nDCBfParity
							Number: nDCBfOutxCtsFlow
							Number: nDCBfOutxDsrFlow
							Number: nDCBfDtrControl
							Number: nDCBfDsrSensitivity
							Number: nDCBfTXContinueOnXoff
							Number: nDCBfOutX
							Number: nDCBfInX
							Number: nDCBfErrorChar
							Number: nDCBfNull
							Number: nDCBfRtsControl
							Number: nDCBfAbortOnError
							Number: nDCBfDummy2
							Number: nDCBwReserved
							Number: nDCBXonLim
							Number: nDCBXoffLim
							Number: nDCBByteSize
							Number: nDCBParity
							Number: nDCBStopBits
							Number: nDCBXonChar
							Number: nDCBXoffChar
							Number: nDCBErrorChar
							Number: nDCBEofChar
							Number: nDCBEvtChar
							Number: nDCBwReserved1
						Actions
							Set nPort = CreateFileA( sInputCom, GENERIC_READWRITE, 0, NUMBER_Null, OPEN_EXISTING, 0, 0 )
							Set nRet = BuildCommDCBA( sInputCom||':'||SalNumberToStrX( nInputBaud, 0 )||','||sInputParity||','||SalNumberToStrX( nInputDataBits, 0 )||','||SalNumberToStrX( nInputStopBits, 0 ), 
									nDCBLength, 
									nDCBBaudRate, 
									nDCBfBinary, 
									nDCBfParity, 
									nDCBfOutxCtsFlow, 
									nDCBfOutxDsrFlow, 
									nDCBfDtrControl, 
									nDCBfDsrSensitivity, 
									nDCBfTXContinueOnXoff, 
									nDCBfOutX, 
									nDCBfInX, 
									nDCBfErrorChar, 
									nDCBfNull, 
									nDCBfRtsControl, 
									nDCBfAbortOnError, 
									nDCBfDummy2, 
									nDCBwReserved, 
									nDCBXonLim, 
									nDCBXoffLim, 
									nDCBByteSize, 
									nDCBParity, 
									nDCBStopBits, 
									nDCBXonChar, 
									nDCBXoffChar, 
									nDCBErrorChar, 
									nDCBEofChar, 
									nDCBEvtChar, 
									nDCBwReserved1 )
							!
							Set nRet = SetCommState( nPort, 
									nDCBLength, 
									nDCBBaudRate, 
									nDCBfBinary, 
									nDCBfParity, 
									nDCBfOutxCtsFlow, 
									nDCBfOutxDsrFlow, 
									nDCBfDtrControl, 
									nDCBfDsrSensitivity, 
									nDCBfTXContinueOnXoff, 
									nDCBfOutX, 
									nDCBfInX, 
									nDCBfErrorChar, 
									nDCBfNull, 
									nDCBfRtsControl, 
									nDCBfAbortOnError, 
									nDCBfDummy2, 
									nDCBwReserved, 
									nDCBXonLim, 
									nDCBXoffLim, 
									nDCBByteSize, 
									nDCBParity, 
									nDCBStopBits, 
									nDCBXonChar, 
									nDCBXoffChar, 
									nDCBErrorChar, 
									nDCBEofChar, 
									nDCBEvtChar, 
									nDCBwReserved1 )
							Set nPortId = nPort
							Return nPort
					Function: Write
						Description:
						Returns
							Number:
						Parameters
							String: sData
						Static Variables
						Local variables
							Number: nBytesWritten
							Number: nErr
						Actions
							Set nErr = WriteFile( nPortId, sData, SalStrLength( sData ), nBytesWritten, 0 )
							Return nBytesWritten
					Function: Read
						Description:
						Returns
							Number:
						Parameters
							Receive String: sData
							Number: nBytesToRead
						Static Variables
						Local variables
							Number: nErr
							Number: nBytesRead
							String: sGotData
						Actions
							Set sGotData = ''
							Set nBytesRead = 0
							Set nErr = ReadFile( nPortId, sGotData, 1, nBytesRead, 0 )
							Set sData = sGotData
							Return nBytesRead
					Function: Close
						Description:
						Returns
							Number:
						Parameters
						Static Variables
						Local variables
						Actions
							Return CloseHandle( nPortId )
			!

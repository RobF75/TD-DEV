				Functions
					Function: GetPumpFields
						Description:
						Returns
							Boolean:
						Parameters
							Receive Number: nNewPumpNo
							Receive Number: nNewPumpChannelNo
							Receive String: sNewPumpDesc
							Receive Number: nNewPumpLitresPerMin
							Receive Number: nNewPumpStartDelay
							Receive String: sNewPumpStatus
						Static Variables
						Local variables
						Actions
							Set nNewPumpNo = nPumpNo
							Set nNewPumpChannelNo = nPumpChannelNo
							Set sNewPumpDesc = sPumpDesc
							Set nNewPumpLitresPerMin = nPumpLitresPerMin
							Set nNewPumpStartDelay = nPumpStartDelay
							Set sNewPumpStatus = sPumpStatus
							Return TRUE
					Function: SetPumpFields
						Description:
						Returns
							Boolean:
						Parameters
							Boolean: bNewRunning
						Static Variables
						Local variables
						Actions
							Set bRunning = bNewRunning
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbPumps.nActivateWindowType = ACTIVATE_DialogModal
						Set clspbPumps.sActivateDialogName = 'dlgPumps'
						Set clspbPumps.hWndTable = hWndPickIntoTable
						Set clspbPumps.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushWndHdl( hWndItem )
						Call PushNumber( bRunning )
						Return TRUE
					On PAM_clsPICK_LOOKUP
						Call PopNumber( nPumpNo, TRUE )
						Call PopNumber( nPumpChannelNo, TRUE )
						Call PopString( sPumpDesc, TRUE )
						Call PopNumber( nPumpLitresPerMin, TRUE )
						Call PopNumber( nPumpStartDelay, TRUE )
						Call PopString( sPumpStatus, TRUE )
						Call SalSendMsg( hWndItem, PAM_cls_GETFIELDS, 0, 0 )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopNumber( nTmp, TRUE )
						Call PopWndHdl( hWndTmp, TRUE )
						Return TRUE

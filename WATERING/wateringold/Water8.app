		                                        Description: 
		                                        Tool Bar 
			                                        Contents 
		                                        Contents 
		                                        Functions 
		                                        Window Parameters 
		                                        Window Variables 
		                                        Message Actions 
		! Description: 
		! Tool Bar 
			                                            Contents 
		! Contents 
			                                            Radio Button: rbGet
				                                            Message Actions 
			                                            Radio Button: rbSet
				                                            Message Actions 
			                                            Background Text: Board
			                                            Data Field: dfBoardNo
				                                            Message Actions 
			                                            Background Text: Port
			                                            Data Field: dfPortNo
				                                            Message Actions 
			                                            Background Text: Status
			                                            Data Field: dfStatus
				                                            Message Actions 
			                                            Pushbutton: pbEquals
				                                            Message Actions 
					                                            On SAM_Click
						                                            If rbGet
							                                            Call DIG_In_Line( dfBoardNo, dfPortNo, dfStatus )
						                                            Else 
							                                            Call DIG_Out_Line( dfBoardNo, dfPortNo, dfStatus )
		! Functions 
		! Window Parameters 
		! Window Variables 
		! Message Actions 
			                                            On SAM_Create
				                                            Call DIG_Open( )
			                                            On SAM_Destroy
				                                            Call DIG_Close( )

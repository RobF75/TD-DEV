			Function: InitialiseIOCard
				Description:
				Returns
					Boolean:
				Parameters
					! sInitType = 'INIT', 'START', 'STOP'
					String: sInitType
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcStationHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcPumpHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nStationHandleNo
					Number: nPumpHandleNo
					Number: nInd
					!
					Boolean: bOk
					Number: nChannelNo
					String: sBoardNo
					String: sBoardPortNo
					String: sStatus
					Number: nPumpNo
					!
					Number: nStatus
				Actions
					Set nStationHandleNo = SqlHandlesGetReferenceNo( 'InitialiseIOCardStation' )
					Set nPumpHandleNo = SqlHandlesGetReferenceNo( 'InitialiseIOCardPump' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Prog_Stations.Station_Status, 
									  Channels.Channel_No, 
									  Channels.Board_No, 
									  Channels.Board_Port_No 
									FROM 
									  Prog_Stations, 
									  Station, 
									  Channels
									WHERE 
									  Prog_Stations.Station_No = Station.Station_No AND 
									  Station.Channel_No = Channels.Channel_No"
							Set sName = 'INITCHNLSTATS'
							Set sBind = ''
							Set sInto = ':sStatus, :nChannelNo, :sBoardNo, :sBoardPortNo'
							Call haSqlHandles[ nStationHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nStationHandleNo ].hSqlHandle )
							!
							Set sSql = " SELECT 
									  Channels.Channel_No, 
									  Channels.Board_No, 
									  Channels.Board_Port_No, 
									  Pump.Pump_No, 
									  Pump.Pump_Status
									FROM 
									  Channels, 
									  Pump 
									WHERE 
									  Channels.Channel_No = Pump.Channel_No "
							Set sName = 'INITCHNLPUMPS'
							Set sBind = ''
							Set sInto = ':nChannelNo, :sBoardNo, :sBoardPortNo, :nPumpNo, :sStatus'
							Call haSqlHandles[ nPumpHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nPumpHandleNo ].hSqlHandle )
							!
							Set bOk = TRUE
							If haSqlHandles[ nStationHandleNo ].Execute( )
								While haSqlHandles[ nStationHandleNo ].FetchNext( nInd )
									If sInitType = 'INIT'
										Call DIG_Prt_Config( sBoardNo, sBoardPortNo )
									If sInitType = 'STOP'
										Set nStatus = 0
									Else
										If sStatus = 'WATERING'
											Set nStatus = 1
										Else
											Set nStatus = 0
									Call DIG_Out_Line( sBoardNo, sBoardPortNo, nStatus )
								If haSqlHandles[ nPumpHandleNo ].Execute( )
									While haSqlHandles[ nPumpHandleNo ].FetchNext( nInd )
										If sInitType = 'INIT'
											Call DIG_Prt_Config( sBoardNo, sBoardPortNo )
										If sInitType = 'STOP'
											Set nStatus = 0
										Else
											If sStatus = 'ON'
												Set nStatus = 1
											Else
												Set nStatus = 0
											If ClearPumpDelayedSecs( nPumpNo, SH_cls_Execute )
												Call ClearPumpDelayedSecs( 0, SH_cls_Commit )
										Call DIG_Out_Line( sBoardNo, sBoardPortNo, nStatus )
								Else
									Set bOk = FALSE
							Else
								Set bOk = FALSE
							Return bOk
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nStationHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nPumpHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT ClearPumpDelayedSecs( 0, SH_cls_Disconnect )
								Set bOk = FALSE
							Return bOk
			!
			Function: DIG_Open
				Description:
				Returns
					Boolean:
				Parameters
				Static Variables
				Local variables
					Number: nStatus
				Actions
					Return DIG_Prt_Communitation( '', '', nStatus, '', 'COMOpen' )
			Function: DIG_Close
				Description:
				Returns
					Boolean:
				Parameters
				Static Variables
				Local variables
					Number: nStatus
				Actions
					Return DIG_Prt_Communitation( '', '', nStatus, '', 'COMClose' )
			Function: DIG_Prt_Config
				Description:
				Returns
					Boolean:
				Parameters
					String: sBoardNo
					String: sBoardPortNo
				Static Variables
				Local variables
					Number: nStatus
				Actions
					Return DIG_Prt_Communitation( sBoardNo, sBoardPortNo, nStatus, '', 'COMBoardConfig' )
			Function: DIG_Out_Line
				Description:
				Returns
					Boolean:
				Parameters
					String: sBoardNo
					String: sBoardPortNo
					Number: nStatus
				Static Variables
				Local variables
					Number: nLocalStatus
				Actions
					Set nLocalStatus = nStatus
					Return DIG_Prt_Communitation( sBoardNo, sBoardPortNo, nLocalStatus, '', 'COMOutput' )
			Function: DIG_In_Line
				Description:
				Returns
					Boolean:
				Parameters
					String: sBoardNo
					String: sBoardPortNo
					Receive Number: nStatus
				Static Variables
				Local variables
					Number: nGotStatus
					Boolean: bOk
				Actions
					Set bOk = DIG_Prt_Communitation( sBoardNo, sBoardPortNo, nGotStatus, '', 'COMInput' )
					Set nStatus = nGotStatus
					Return bOk
			!
			Function: DIG_Prt_Communitation
				Description:
				Returns
					Boolean:
				Parameters
					String: sBoardNo
					String: sBoardPortNo
					Receive Number: nStatus
					String: sOverrideOutputString
					! sActionType = 'COMOpen' or 'COMBoardConfig' or 'COMOutput' or 'COMInput' or 'COMClose'
					String: sActionType
				Static Variables
				Local variables
					String: sStatus
					String: strBuffer
					Number: nErr
					Number: nBytesWritten
					Number: nBytesRead
					String: sCR
					Number: nNoCRRead
					Number: nStopAfterNCR
					Boolean: bInputStrStarted
					Boolean: bContinue
					String: sChar
				Actions
					Set sCR = ' '
					Set sCR = SalNumberToChar( 13 )
					If sActionType = 'COMOpen'
						Set nErr = fcCom2.Open( 'COM2', 9600, 'n', 8, 1 )
						Return TRUE
					Else If sActionType = 'COMBoardConfig'
						Return TRUE
					Else If sActionType = 'COMClose'
						Set nErr = fcCom2.Close( )
						Return TRUE
					Else If sActionType = 'COMInput'
						Set nStatus = NUMBER_Null
						Set strBuffer = '$'||sBoardNo||'6'||sCR
						Set nErr = fcCom2.Write( strBuffer )
						!
						Set nNoCRRead = 0
						Set nStopAfterNCR = 9999
						Set bInputStrStarted = FALSE
						Set strBuffer = ''
						Set bContinue = TRUE
						While bContinue
							If fcCom2.Read( sChar, 1 )
								If bInputStrStarted
									If sChar = sCR
										Set nNoCRRead = nNoCRRead + 1
										Set bContinue = FALSE
									Call SalStrFirstC( sChar, nErr )
									Set strBuffer = strBuffer || SalNumberToChar( nErr )
								Else
									If sChar = '!'
										Set bInputStrStarted = TRUE
										Call SalStrFirstC( sChar, nErr )
										Set strBuffer = strBuffer || SalNumberToChar( nErr )
									Else If sChar = sCR
										Set nNoCRRead = nNoCRRead + 1
								If nNoCRRead >= nStopAfterNCR
									Set bContinue = FALSE
							Else
								Set bContinue = FALSE
						!
						! extract port status here and set nStatus
						If SalStrLeftX( strBuffer, 1 ) = '!'
							If SalStrUpperX( SalStrLeftX( sBoardPortNo, 1 ) ) = 'A'
								Set sStatus = ConvertStrHexToStrBinX( SalStrMidX( strBuffer, 1, 2 ) )
							Else If SalStrUpperX( SalStrLeftX( sBoardPortNo, 1 ) ) = 'B'
								Set sStatus =  ConvertStrHexToStrBinX( SalStrMidX( strBuffer, 3, 2 ) )
							Else
								Set sStatus =  ConvertStrHexToStrBinX( SalStrMidX( strBuffer, 5, 2 ) )
							!
							If SalStrMidX( sStatus, ( 7 - SalStrToNumber( SalStrMidX( sBoardPortNo, 1, 1 ) ) ), 1 ) = '1'
								Set nStatus = 1
							Else
								Set nStatus = 0
							Return TRUE
						Else
							Return FALSE
					Else
						If nStatus
							Set sStatus = '01'
						Else
							Set sStatus = '00'
						Set strBuffer = '#'||sBoardNo||sBoardPortNo||sStatus||sCR
						!
						If NOT sOverrideOutputString = ''
							Set strBuffer = sOverrideOutputString || sCR
						Set nErr = fcCom2.Write( strBuffer )
						Return TRUE

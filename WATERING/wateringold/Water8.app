			!
			Function: SetStationStatus
				Description:
				Returns
					Boolean:
				Parameters
					Number: nInstanceNo
					Number: nStationNo
					Number: nChannelNo
					String: sStatus
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SetStationStatus' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " UPDATE Prog_Stations  
									SET 
									  Station_Status = :2
									WHERE Instance_No = :1 "
							Set sName = 'SETPRGSTSTATUS'
							Set sBind = ':nInstanceNo, :sStatus'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Call LogMaintenance( nStationNo, 'STATION', sStatus, 'APPEND' )
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If sStatus = 'ACTIVE' OR sStatus = 'SUPPLEMENT'
									Call SetChannelState( nChannelNo, 1, SH_cls_Execute )
								Else
									Call SetChannelState( nChannelNo, 0, SH_cls_Execute )
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Commit
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Call SetChannelState( 0, 0, SH_cls_Disconnect )
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )

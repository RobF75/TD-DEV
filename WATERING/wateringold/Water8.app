								List Values
								Message Actions
									On PAM_clsTBL_CHECKROWNEW
										Call GetNextProgNo( colProgramNo, SH_cls_Execute )
										If colProgramNo > 0
											Return TRUE
										Else
											Call ErrorMessage( 'An error has occured in allocating the next Program No. Please try and save again.', hWndForm, lParam )
											Return FALSE
									On PAM_clsTBL_CHECKROWDELETED
										Call ExistsProgStations( colProgramNo, bExists, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'Cannot delete this program, as it still has Stations linked to it.', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE
									On PAM_clsTBL_ROWDELETED
										If DeleteProgSwitches( colProgramNo, SH_cls_Execute )
											Call DeleteProgSwitches( 0, SH_cls_Commit )

							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: SetProgramStatus
				Description:
				Returns
					Boolean:
				Parameters
					Number: nProgramNo
					String: sStatus
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SetProgramStatus' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " UPDATE Program  
									SET 
									  Prog_Status = :2
									WHERE Program_No = :1 "
							Set sName = 'SETPROGSTATUS'
							Set sBind = ':nProgramNo, :sStatus'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Call LogMaintenance( nProgramNo, 'PROGRAM', sStatus, 'APPEND' )
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If sStatus = 'READY'
									Call SetProgramStationsReady( nProgramNo, SH_cls_Execute )
								Else If sStatus = 'STOPPED'
									Call SetProgramStationsStopped( nProgramNo, SH_cls_Execute )
									Set dtLastProgStoppedDT = SalDateCurrent(  )
								Return TRUE
								!
							Else
								Return FALSE
						Case SH_cls_Commit
							Call SetProgramStationsReady( 0, SH_cls_Commit )
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Call SetProgramStationsStopped( 0, SH_cls_Commit )
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Call SetProgramStationsStopped( 0, SH_cls_Disconnect )
							Call SetProgramStationsReady( 0, SH_cls_Disconnect )
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: SetProgramStationsStopped
				Description:
				Returns
					Boolean:
				Parameters
					Number: nProgramNo
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :

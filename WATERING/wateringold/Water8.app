								Class Child Ref Key: 0
								Class ChildKey: 70
								Class: clsColumnGeneral
								Property Template:
								Class DLL Name:
								Title: Seq.No.
								Visible? Class Default
								Editable? Class Default
								Maximum Data Length: Class Default
								Data Type: Number
								Justify: Right
								Width:  0.7"
								Width Editable? Class Default
								Format: #0
								Country: Class Default
								Input Mask: Class Default
								Cell Options
									Cell Type? Class Default
									Multiline Cell? Class Default
									Cell DropDownList
										Sorted? Class Default
										Vertical Scroll? Class Default
										Auto Drop Down? Class Default
										Allow Text Editing? Class Default
									Cell CheckBox
										Check Value:
										Uncheck Value:
										Ignore Case? Class Default
								List Values
								Message Actions
									On PAM_clsTBL_DATAVAL
										If SalIsNull( hWndItem )
											Set colWaterSeqNo = 0
										Return TRUE
									On PAM_clsTBL_EDITCHECK
										If hWndForm.hWndParent.clsfrmPrograms.bRunning
											Return FALSE
										Else If hWndForm.hWndParent.clsfrmPrograms.cbAutoAllocSeqNos
											Return FALSE
										Else
											Return TRUE
									On SAM_AnyEdit
										Call PushNumber( colOrgWaterSeqNo )
										Call PushNumber( colStationLitresMin )
										Call PushNumber( colPumpLitresMin )
										If NOT SalSendMsg( tblProgStationsSeqPressures, PAM_clsWATERING_ADJUSTSEQNO, 2, 0 )
											Call PopNumber( colPumpLitresMin, TRUE )
											Call PopNumber( colStationLitresMin, TRUE )
											Call PopNumber( colOrgWaterSeqNo, TRUE )
										!
										Call PushNumber( colWaterSeqNo )
										Call PushNumber( colStationLitresMin )
										Call PushNumber( colPumpLitresMin )
										If NOT SalSendMsg( tblProgStationsSeqPressures, PAM_clsWATERING_ADJUSTSEQNO, 1, 0 )
											Call PopNumber( colPumpLitresMin, TRUE )
											Call PopNumber( colStationLitresMin, TRUE )
											Call PopNumber( colWaterSeqNo, TRUE )
										! Call clsfrmPrograms.tblProgStationsSeqPressures.SubtractNew( colOrgWaterSeqNo, colStationLitresMin, colPumpLitresMin )
										! Call clsfrmPrograms.tblProgStationsSeqPressures.AddNew( colWaterSeqNo, colStationLitresMin, colPumpLitresMin )
										Set colOrgWaterSeqNo = colWaterSeqNo
										Return VALIDATE_Ok

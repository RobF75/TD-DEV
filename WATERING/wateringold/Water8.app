											Set bOk = FALSE
										Else
											! Call GetStationPumpFlow( colStationNo, nPumpFlow, SH_cls_Execute )
											! If nPumpFlow >= 0
												                                            If colStationLitresMin > nPumpFlow
													                                            If IDCANCEL = SalMessageBox( 'This station is too demanding on the pump!  Allow it anyway?', 'Flow Warning', MB_OkCancel | MB_DefButton2 )
														                                            Set bOk = FALSE
										Return bOk

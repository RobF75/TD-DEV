						Functions
							Function: CheckChannelExists
								Description:
								Returns
									Boolean:
								Parameters
									Number: nChannelNo
									Receive Boolean: bExists
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'CheckChannelExists' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Channel_No 
													FROM Channels  
													WHERE Channel_No = :1"
											Set sName = 'CHNLEXISTS'
											Set sBind = ':nChannelNo'
											Set sInto = ''
											!
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set bExists = FALSE
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set bExists = TRUE
												Else
													Set bExists = FALSE
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: GetChannelAllocStationDesc
								Description:
								Returns
									Boolean:
								Parameters
									Number: nChannelNo
									Receive String: sDesc
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									String: sGotDesc
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetChannelAllocStationDesc' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Station_Desc 
													FROM Station  
													WHERE Channel_No = :1"
											Set sName = 'GTCHNLALLOCST'
											Set sBind = ':nChannelNo'
											Set sInto = ':sGotDesc'
											!
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set sDesc = ''
											Set sGotDesc = ''
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set sDesc = sGotDesc
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: GetChannelAllocPumpDesc
								Description:

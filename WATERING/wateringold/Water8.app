				Class DLL Name:
.end
				                                            Description: 
				                                            Derived From 
					                                            Class: clspbPickInto
				                                            Class Variables 
					                                            String: sTmp
					                                            Number: nTmp
					                                            Window Handle: hWndTmp
					                                            Date/Time: dtTmp
				                                            Instance Variables 
					! PUBLIC
					                                            Number: nProgNo
					                                            Date/Time: dtProgStartTime
					                                            String: sProgDesc
					                                            Boolean: bRunning
					                                            Window Handle: hWndPickIntoTable
					! PRIVATE
				                                            Functions 
					                                            Function: SetProgOverrideFields
						                                            Description: 
						                                            Returns 
							                                            Boolean: 
						                                            Parameters 
							                                            Number: nNewProgNo
							                                            Date/Time: dtNewProgStartTime
							                                            String: sNewProgDesc
							                                            Boolean: bNewRunning
						                                            Static Variables 
						                                            Local variables 
						                                            Actions 
							                                            Set nProgNo = nNewProgNo
							                                            Set dtProgStartTime = dtNewProgStartTime
							                                            Set sProgDesc = sNewProgDesc
							                                            Set bRunning = bNewRunning
							                                            Return TRUE
				                                            Message Actions 
					                                            On SAM_Create
						                                            Set hWndPickIntoTable = hWndItem
						                                            Call SalSendClassMessage( SAM_Create, wParam, lParam )
						                                            Set clspbProgramOverride.nActivateWindowType = ACTIVATE_DialogModal
						                                            Set clspbProgramOverride.sActivateDialogName = 'dlgProgramOverride'
						                                            Set clspbProgramOverride.hWndTable = hWndPickIntoTable
						                                            Set clspbProgramOverride.hWndParentTable = hWndPickIntoTable
						                                            Set clspbProgramOverride.hWndFieldLookUp = hWndItem
					                                            On PAM_clsACTIVATE_PUSHFIELDS
						                                            Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						                                            Call PushWndHdl( hWndItem )
						                                            Call PushNumber( bRunning )
						                                            Call PushString( sProgDesc )
						                                            Call PushDateTime( dtProgStartTime )
						                                            Call PushNumber( nProgNo )
						                                            Return TRUE
					                                            On PAM_clsACTIVATE_POPFIELDS
						                                            Call PopNumber( nTmp, TRUE )
						                                            Call PopDateTime( dtTmp, TRUE )
						                                            Call PopString( sTmp, TRUE )
						                                            Call PopNumber( nTmp, TRUE )
						                                            Call PopWndHdl( hWndTmp, TRUE )
						                                            Return TRUE

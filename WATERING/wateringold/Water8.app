						Functions
							Function: ExistsProgSwitch
								Description:
								Returns
									Boolean:
								Parameters
									Number: nProgramNo
									Number: nSwitchNo
									Receive Boolean: bExists
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'ExistsProgSwitch' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Valid_State 
													FROM Prog_Switches
													WHERE 
													  Program_No = :1 AND 
													  Switch_No = :2 "
											Set sName = 'EXISTPGSWT'
											Set sBind = ':nProgramNo, :nSwitchNo'
											Set sInto = ''
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set bExists = FALSE
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set bExists = TRUE
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
						Window Variables
							Boolean: bExists
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = " SELECT 
										  Prog_Switches.Switch_No, 
										  Switch.Channel_No, 
										  Switch.Switch_Desc, 
										  Prog_Switches.Valid_State, 
										  Prog_Switches.Prog_Action, 
										  Prog_Switches.ProgIn_Progress, 
										  Switch.Switch_Status
										FROM Prog_Switches, Switch 
										WHERE 
										   Prog_Switches.Program_No = :1 AND 
										   Prog_Switches.Switch_No = Switch.Switch_No 
										ORDER BY Switch.Switch_Desc "
								Set sNAMEPopHandle = 'POPPRGSWTCH'
								Set sBINDPopHandle = ':hWndParent.clsdlgProgSwitches.nProgramNo'
								Set sINTOPopHandle = ':clsdlgProgSwitches.tblProgSwitches.colSwitchNo, 
										:clsdlgProgSwitches.tblProgSwitches.colSwitchChannelNo,
										:clsdlgProgSwitches.tblProgSwitches.colSwitchDesc,
										:clsdlgProgSwitches.tblProgSwitches.colSwitchValidState, 
										:clsdlgProgSwitches.tblProgSwitches.colProgAction, 
										:clsdlgProgSwitches.tblProgSwitches.colProgInProgress, 
										:clsdlgProgSwitches.tblProgSwitches.colSwitchStatus'
								!
								Set sSQLRefreshHandle = " SELECT 
										  Prog_Switches.Switch_No, 
										  Switch.Channel_No, 
										  Switch.Switch_Desc, 
										  Prog_Switches.Valid_State, 
										  Prog_Switches.Prog_Action, 
										  Prog_Switches.ProgIn_Progress, 
										  Switch.Switch_Status
										FROM Prog_Switches, Switch 
										WHERE 
										   Prog_Switches.Program_No = :1 AND 
										   Prog_Switches.Switch_No = :2 AND 
										   Prog_Switches.Switch_No = Switch.Switch_No "
								Set sNAMERefreshHandle = 'REFPRGSWTCH'
								Set sBINDRefreshHandle = ':hWndParent.clsdlgProgSwitches.nProgramNo, :clsdlgProgSwitches.tblProgSwitches.colSwitchNo'
								Set sINTORefreshHandle = ':clsdlgProgSwitches.tblProgSwitches.colSwitchNo, 
										:clsdlgProgSwitches.tblProgSwitches.colSwitchChannelNo,
										:clsdlgProgSwitches.tblProgSwitches.colSwitchDesc,
										:clsdlgProgSwitches.tblProgSwitches.colSwitchValidState, 
										:clsdlgProgSwitches.tblProgSwitches.colProgAction, 
										:clsdlgProgSwitches.tblProgSwitches.colProgInProgress, 
										:clsdlgProgSwitches.tblProgSwitches.colSwitchStatus'
								!
								Set sSQLInsertHandle = " INSERT INTO Prog_Switches  
										( Program_No, 
										  Switch_No,  
										  Prog_Action, 
										  ProgIn_Progress, 
										  Valid_State ) VALUES ( :1, :2, :3, :4, :5 ) "
								Set sNAMEInsertHandle = 'INSPRGSWTCH'
								Set sBINDInsertHandle = ':hWndParent.clsdlgProgSwitches.nProgramNo, 
										:clsdlgProgSwitches.tblProgSwitches.colSwitchNo, 
										:clsdlgProgSwitches.tblProgSwitches.colProgAction, 
										:clsdlgProgSwitches.tblProgSwitches.colProgInProgress, 
										:clsdlgProgSwitches.tblProgSwitches.colSwitchValidState'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE Prog_Switches
										SET 
										  Prog_Action = :3, 
										  ProgIn_Progress = :4, 
										  Valid_State = :5 
										WHERE 
										  Program_No = :1 AND 
										  Switch_No = :2'
								Set sNAMEUpdateHandle = 'UPDTPRGSWTCH'
								Set sBINDUpdateHandle = ':hWndParent.clsdlgProgSwitches.nProgramNo, 
										:clsdlgProgSwitches.tblProgSwitches.colSwitchNo, 
										:clsdlgProgSwitches.tblProgSwitches.colProgAction, 
										:clsdlgProgSwitches.tblProgSwitches.colProgInProgress, 
										:clsdlgProgSwitches.tblProgSwitches.colSwitchValidState'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = 'DELETE FROM Prog_Switches 
										WHERE 
										  Program_No = :1 AND 
										  Switch_No = :2'
								Set sNAMEDeleteHandle = 'DELPRGSWTCH'
								Set sBINDDeleteHandle = ':hWndParent.clsdlgProgSwitches.nProgramNo, 
										:clsdlgProgSwitches.tblProgSwitches.colSwitchNo'
								Set sINTODeleteHandle = ''
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								!
								Set sTableHeading = 'Program Switches'
							On PAM_clsTBL_NOROWS
								Return TRUE
							On SAM_Destroy
								Call ExistsProgSwitch( 0, 0, bExists, SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
					Background Text: Column (Valid State) = Which position must the switch be in, to allow the program on operate.

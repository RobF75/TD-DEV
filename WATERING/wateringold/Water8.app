		Functions
		Window Parameters
			! sTableChoice = 'PROGRAMS' OR 'PROG_STATIONS'
			Receive String: sTableChoice
		Window Variables
		Message Actions
			On SAM_CreateComplete
				If sTableChoice = 'PROGRAMS'
					Set rbPrograms = TRUE
				Else
					Set rbStations = TRUE
				Call OurWaitCursorOverride( FALSE, TRUE )
				Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
			On PAM_clsPB_OKACTION
				If rbPrograms
					Set sTableChoice = 'PROGRAMS'
				Else
					Set sTableChoice = 'PROG_STATIONS'
				Return SalSendMsg( pbExit, SAM_Click, TRUE, 0 )
			On PAM_cls_SETINSTANCEVARS
				Set bTreeSystem = FALSE

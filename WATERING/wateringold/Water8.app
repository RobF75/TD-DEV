									Cell CheckBox
										Check Value:
										Uncheck Value:
										Ignore Case? Class Default
								List Values
									Text: OFF
									Text: ON
								Message Actions
									On PAM_clsTBL_DATAVAL
										If colSwitchStatus = 'ON'
											Return TRUE
										If colSwitchStatus = 'OFF'
											Return TRUE
										Else
											Call ErrorMessage( 'Please select a valid Switch status!', hWndForm, lParam )
											Return FALSE
									On PAM_clsTBL_ROWNEWINIT
										Set colSwitchStatus = 'ON'
									On PAM_clsTBL_EDITCHECK
										If hWndForm.hWndParent.clsdlgSwitches.bRunning
											Return FALSE
										Else
											Return TRUE
						Functions
							Function: GetNextSwitchNo
								Description:
								Returns
									Boolean:
								Parameters
									Receive Number: nNextSwitchNo
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
									Number: nGotSwitchNo
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetNextSwitchNo' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Max( Switch_No ) + 1
													FROM Switch "
											Set sName = 'NXTSWTCHNO'
											Set sBind = ''
											Set sInto = ':nGotSwitchNo'
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set nNextSwitchNo = NUMBER_Null
											Set nGotSwitchNo = NUMBER_Null
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													If NOT nGotSwitchNo > 0
														Set nGotSwitchNo = 1
													Set nNextSwitchNo = nGotSwitchNo
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: ExistsSwitchProgram
								Description:
								Returns
									Boolean:
								Parameters
									Number: nSwitchNo
									Receive Boolean: bExists
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'ExistsSwitchProgram' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Program_No 
													FROM Prog_Switches
													WHERE Switch_No = :1 "
											Set sName = 'EXISTPRGSWTCH'
											Set sBind = ':nSwitchNo'
											Set sInto = ''
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set bExists = FALSE
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set bExists = TRUE
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
						Window Variables
							Boolean: bExists
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = " SELECT 
										  Switch_No, 
										  Channel_No, 
										  Switch_Desc, 
										  Switch_Status 
										FROM Switch 
										ORDER BY Switch_Desc "
								Set sNAMEPopHandle = 'POPSWITCHS'
								Set sBINDPopHandle = ''
								Set sINTOPopHandle = ':clsdlgSwitches.tblSwitches.colSwitchNo,
										:clsdlgSwitches.tblSwitches.colSwitchChannelNo,
										:clsdlgSwitches.tblSwitches.colSwitchDesc,
										:clsdlgSwitches.tblSwitches.colSwitchStatus'
								!
								Set sSQLRefreshHandle = " SELECT 
										  Switch_No, 
										  Channel_No, 
										  Switch_Desc, 
										  Switch_Status
										FROM Switch 
										WHERE Switch_No = :1 "
								Set sNAMERefreshHandle = 'REFSWITCHS'
								Set sBINDRefreshHandle = ':clsdlgSwitches.tblSwitches.colSwitchNo'
								Set sINTORefreshHandle = ':clsdlgSwitches.tblSwitches.colSwitchNo,
										:clsdlgSwitches.tblSwitches.colSwitchChannelNo,
										:clsdlgSwitches.tblSwitches.colSwitchDesc,
										:clsdlgSwitches.tblSwitches.colSwitchStatus'
								!
								Set sSQLInsertHandle = " INSERT INTO Switch  
										( Switch_No, 
										  Channel_No, 
										  Switch_Desc, 
										  Switch_Status ) VALUES ( :1, :2, :3, :4 ) "
								Set sNAMEInsertHandle = 'INSSWITCHS'
								Set sBINDInsertHandle = ':clsdlgSwitches.tblSwitches.colSwitchNo,
										:clsdlgSwitches.tblSwitches.colSwitchChannelNo,
										:clsdlgSwitches.tblSwitches.colSwitchDesc,
										:clsdlgSwitches.tblSwitches.colSwitchStatus'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE Switch
										SET 
										  Channel_No = :2, 
										  Switch_Desc = :3, 
										  Switch_Status = :4
										WHERE 
										  Switch_No = :1'
								Set sNAMEUpdateHandle = 'UPDTSWITCHS'
								Set sBINDUpdateHandle = ':clsdlgSwitches.tblSwitches.colSwitchNo,
										:clsdlgSwitches.tblSwitches.colSwitchChannelNo,
										:clsdlgSwitches.tblSwitches.colSwitchDesc,
										:clsdlgSwitches.tblSwitches.colSwitchStatus'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = 'DELETE FROM Switch WHERE Switch_No = :1'
								Set sNAMEDeleteHandle = 'DELSWITCHS'
								Set sBINDDeleteHandle = ':clsdlgSwitches.tblSwitches.colSwitchNo'
								Set sINTODeleteHandle = ''
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								!
								Set hWndRowNewColumn = colSwitchDesc
								Set sTableHeading = 'Switches'
							On PAM_clsTBL_NOROWS
								Return TRUE
							On SAM_Destroy
								Call GetNextSwitchNo( colSwitchNo, SH_cls_Disconnect )
								Call ExistsSwitchProgram( 0, bExists, SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
				Derived From
					Class: clsDialogChildTable
				Class Variables
				Instance Variables
					Window Handle: hWndSelectParent
					Boolean: bRunning
				Functions
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set hWndChildTable = tblSwitches
						Set bAddAllowed = TRUE
						Set bSaveAllowed = TRUE
						Set bDeleteAllowed = TRUE
						Set bUnDeleteAllowed = TRUE
						Set bClearSelectAllowed = TRUE
						Set bQueryAllowed = FALSE
						Set bRepopulateAllowed = TRUE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = FALSE
						Set bPrintFormAllowed = TRUE
						Set bTreeSystem = FALSE
					On PAM_clsDLG_POPFIELDS
						Call PopNumber( bRunning, TRUE )
						Call PopWndHdl( hWndSelectParent, TRUE )
						Return TRUE
					On PAM_clsTBL_USERACTIONS
						If bRunning
							If wParam = TBL_cls_RePopTable OR wParam = TBL_cls_OrderTable OR wParam = TBL_cls_ClearRow OR wParam = TBL_cls_ZoomTable
								Return SalSendClassMessage( PAM_clsTBL_USERACTIONS, wParam, lParam )
							Else
								Call SalMessageBox( 'Please stop the watering system before carring out any maintenance.', 'NOTE', MB_Ok )
								Return TRUE
						Else
							Return SalSendClassMessage( PAM_clsTBL_USERACTIONS, wParam, lParam )

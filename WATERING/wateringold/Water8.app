						Functions
							Function: GetNextStationNo
								Description:
								Returns
									Boolean:
								Parameters
									Receive Number: nNextStationNo
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
									Number: nGotStationNo
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetNextStationNo' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Max( Station_No ) + 1
													FROM Station "
											Set sName = 'NXTSTATIONNO'
											Set sBind = ''
											Set sInto = ':nGotStationNo'
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set nNextStationNo = NUMBER_Null
											Set nGotStationNo = NUMBER_Null
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													If NOT nGotStationNo > 0
														Set nGotStationNo = 1
													Set nNextStationNo = nGotStationNo
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: ExistsStationProg
								Description:
								Returns
									Boolean:
								Parameters
									Number: nStationNo
									Receive Boolean: bExists
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'ExistsStationProg' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Program_No 
													FROM Prog_Stations
													WHERE Station_No = :1 "
											Set sName = 'EXISTSSTSPROG'
											Set sBind = ''
											Set sInto = ''
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set bExists = FALSE
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set bExists = TRUE
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
						Window Variables
							Number: nPos
							Boolean: bExists
							Boolean: bOk
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = " SELECT 
										  Station.Station_No, 
										  Station.Channel_No, 
										  Station.Pump_No, 
										  Pump.Pump_Desc, 
										  Station.Station_Desc, 
										  Station.Station_Litres_Min, 
										  Station.Def_Water_Secs
										FROM Station, Pump 
										WHERE 
										   Station.Pump_No = Pump.Pump_No 
										ORDER BY Station.Pump_No, Station.Station_Desc"
								Set sNAMEPopHandle = 'POPSTATIONS'
								Set sBINDPopHandle = ''
								Set sINTOPopHandle = ':clsdlgStations.tblStations.colStationNo, 
										:clsdlgStations.tblStations.colStationChannelNo,
										:clsdlgStations.tblStations.colPumpNo, 
										:clsdlgStations.tblStations.colPumpDesc, 
										:clsdlgStations.tblStations.colStationDesc,
										:clsdlgStations.tblStations.colStationLitresMin,
										:clsdlgStations.tblStations.colDefWateringSeconds'
								!
								Set sSQLRefreshHandle = " SELECT 
										  Station.Station_No, 
										  Station.Channel_No, 
										  Station.Pump_No, 
										  Pump.Pump_Desc, 
										  Station.Station_Desc, 
										  Station.Station_Litres_Min, 
										  Station.Def_Water_Secs
										FROM Station, Pump
										WHERE 
										  Station.Station_No = :1 AND 
										  Station.Pump_No = Pump.Pump_No "
								Set sNAMERefreshHandle = 'REFSTATIONS'
								Set sBINDRefreshHandle = ':clsdlgStations.tblStations.colStationNo'
								Set sINTORefreshHandle = ':clsdlgStations.tblStations.colStationNo, 
										:clsdlgStations.tblStations.colStationChannelNo,
										:clsdlgStations.tblStations.colPumpNo, 
										:clsdlgStations.tblStations.colPumpDesc, 
										:clsdlgStations.tblStations.colStationDesc,
										:clsdlgStations.tblStations.colStationLitresMin,
										:clsdlgStations.tblStations.colDefWateringSeconds'
								!
								Set sSQLInsertHandle = " INSERT INTO Station  
										( Station_No, 
										  Pump_No, 
										  Channel_No, 
										  Station_Desc, 
										  Station_Litres_Min, 
										  Def_Water_Secs ) VALUES ( :1, :2, :3, :4, :5, :6 ) "
								Set sNAMEInsertHandle = 'INSSTATIONS'
								Set sBINDInsertHandle = ':clsdlgStations.tblStations.colStationNo,
										:clsdlgStations.tblStations.colPumpNo,
										:clsdlgStations.tblStations.colStationChannelNo,
										:clsdlgStations.tblStations.colStationDesc,
										:clsdlgStations.tblStations.colStationLitresMin,
										:clsdlgStations.tblStations.colDefWateringSeconds'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE Station
										SET 
										  Pump_No = :2, 
										  Channel_No = :3, 
										  Station_Desc = :4, 
										  Station_Litres_Min = :5, 
										  Def_Water_Secs = :6
										WHERE 
										  Station_No = :1'
								Set sNAMEUpdateHandle = 'UPDTSTATIONS'
								Set sBINDUpdateHandle = ':clsdlgStations.tblStations.colStationNo,
										:clsdlgStations.tblStations.colPumpNo,
										:clsdlgStations.tblStations.colStationChannelNo,
										:clsdlgStations.tblStations.colStationDesc,
										:clsdlgStations.tblStations.colStationLitresMin,
										:clsdlgStations.tblStations.colDefWateringSeconds'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = 'DELETE FROM Station WHERE Station_No = :1'
								Set sNAMEDeleteHandle = 'DELSTATIONS'
								Set sBINDDeleteHandle = ':clsdlgStations.tblStations.colStationNo'
								Set sINTODeleteHandle = ''
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								!
								Set hWndRowNewColumn = colStationDesc
								Set sTableHeading = 'Stations'
							On PAM_clsTBL_NOROWS
								Return TRUE
							On SAM_Destroy
								Call GetNextStationNo( colPumpNo, SH_cls_Disconnect )
								Call ExistsStationProg( 0, bExists, SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
							On PAM_clsWATERING_MANUALINIT
								Set nPos = 0
								Set clsdlgStations.naStationNos[ nPos ] = NUMBER_Null
								Set clsdlgStations.naStationCrntWaterSecs[ nPos ] = NUMBER_Null
								Return TRUE
							On PAM_clsWATERING_MANUALROW
								Set clsdlgStations.naStationNos[ nPos ] = colStationNo
								Set clsdlgStations.naStationCrntWaterSecs[ nPos ] = colDefWateringSeconds
								Set nPos = nPos + 1
								Set clsdlgStations.naStationNos[ nPos ] = NUMBER_Null
								Set clsdlgStations.naStationCrntWaterSecs[ nPos ] = NUMBER_Null
								Return TRUE
				Derived From
					Class: clsDialogChildTable
				Class Variables
					Number: naStationNos[*]
					Number: naStationCrntWaterSecs[*]
				Instance Variables
					Window Handle: hWndSelectParent
					Boolean: bRunning
				Functions
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set hWndChildTable = tblStations
						Set bAddAllowed = TRUE
						Set bSaveAllowed = TRUE
						Set bDeleteAllowed = TRUE
						Set bUnDeleteAllowed = TRUE
						Set bClearSelectAllowed = TRUE
						Set bQueryAllowed = FALSE
						Set bRepopulateAllowed = TRUE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = FALSE
						Set bPrintFormAllowed = TRUE
						Set bTreeSystem = FALSE
					On PAM_clsDLG_POPFIELDS
						Call PopNumber( bRunning, TRUE )
						Call PopWndHdl( hWndSelectParent, TRUE )
						Return TRUE
					On PAM_clsTBL_USERACTIONS
						If bRunning
							If wParam = TBL_cls_RePopTable OR wParam = TBL_cls_OrderTable OR wParam = TBL_cls_ClearRow OR wParam = TBL_cls_ZoomTable
								Return SalSendClassMessage( PAM_clsTBL_USERACTIONS, wParam, lParam )
							Else
								Call SalMessageBox( 'Please stop the watering system before carring out any maintenance.', 'NOTE', MB_Ok )
								Return TRUE
						Else
							Return SalSendClassMessage( PAM_clsTBL_USERACTIONS, wParam, lParam )
			!

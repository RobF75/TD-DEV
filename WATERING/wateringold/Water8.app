								List Values
								Message Actions
									On PAM_clsTBL_CHECKROWNEW
										Call GetNextStationNo( colStationNo, SH_cls_Execute )
										If colStationNo > 0
											Return TRUE
										Else
											Call ErrorMessage( 'An error has occured in allocating the next Station No. Please try and save again.', hWndForm, lParam )
											Return FALSE
									On PAM_clsTBL_CHECKROWDELETED
										Call ExistsStationProg( colStationNo, bExists, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'Cannot delete this Station, as it still has programs linked to it.', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE

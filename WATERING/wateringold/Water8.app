				Functions
					Function: GetStationFields
						Description:
						Returns
							Boolean:
						Parameters
							Receive Number: nNewStationNo
							Receive Number: nNewStationChannelNo
							Receive String: sNewStationDesc
							Receive Number: nNewStationLitresMin
							Receive Number: nNewDefWateringSeconds

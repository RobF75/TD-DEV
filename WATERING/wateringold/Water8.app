						Window Variables
							Boolean: bExists
						Message Actions
							On SAM_Create
								Call SalTblSetTableFlags( hWndForm, TBL_Flag_SuppressRowLines | TBL_Flag_SuppressLastColLine | TBL_Flag_GrayedHeaders, TRUE )
								Return SalSendClassMessage( SAM_Create, wParam, lParam )
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = 'SELECT 
										  Channel_No, 
										  Board_No, 
										  Board_Port_No 
										FROM 
										  Channels 
										ORDER BY 
										  Channel_No'
								Set sNAMEPopHandle = 'POPCHNL'
								Set sBINDPopHandle = ''
								Set sINTOPopHandle = ':clsdlgChannels.tblChannels.colChannelNo, 
										:clsdlgChannels.tblChannels.colBoardNo, 
										:clsdlgChannels.tblChannels.colPortNo'
								!
								Set sSQLRefreshHandle = 'SELECT 
										  Channel_No, 
										  Board_No, 
										  Board_Port_No
										FROM 
										  Channels 
										WHERE Channel_No = :1 '
								Set sNAMERefreshHandle = 'REFCHNL'
								Set sBINDRefreshHandle = ':clsdlgChannels.tblChannels.colChannelNo'
								Set sINTORefreshHandle = ':clsdlgChannels.tblChannels.colChannelNo, 
										:clsdlgChannels.tblChannels.colBoardNo, 
										:clsdlgChannels.tblChannels.colPortNo'
								!
								Set sSQLInsertHandle = 'INSERT INTO Channels ( 
										  Channel_No, 
										  Board_No, 
										  Board_Port_No ) 
										VALUES ( :1, :2, :3 ) '
								Set sNAMEInsertHandle = 'INSCHNL'
								Set sBINDInsertHandle = ':clsdlgChannels.tblChannels.colChannelNo, 
										:clsdlgChannels.tblChannels.colBoardNo, 
										:clsdlgChannels.tblChannels.colPortNo'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = 'UPDATE Channels 
										SET 
										  Board_No = :2, 
										  Board_Port_No = :3
										WHERE Channel_No = :1'
								Set sNAMEUpdateHandle = 'UPDTCHNL'
								Set sBINDUpdateHandle = ':clsdlgChannels.tblChannels.colChannelNo, 
										:clsdlgChannels.tblChannels.colBoardNo, 
										:clsdlgChannels.tblChannels.colPortNo'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = 'DELETE FROM Channels WHERE Channel_No = :1 '
								Set sNAMEDeleteHandle = 'DELCHNL'
								Set sBINDDeleteHandle = ':clsdlgChannels.tblChannels.colChannelNo'
								Set sINTODeleteHandle = ''
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								Set bQueryAllowed = FALSE
								Set bReportAllowed = FALSE
								Set bOrderAllowed = TRUE
							On SAM_Destroy
								Call CheckChannelExists( 0, bExists, SH_cls_Disconnect )
								Call GetChannelAllocStationDesc( 0, colAllocatedTo, SH_cls_Disconnect )
								Call GetChannelAllocPumpDesc( 0, colAllocatedTo, SH_cls_Disconnect )
								Call GetChannelAllocSwitchDesc( 0, colAllocatedTo, SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
							On SAM_FetchRowDone
								Call SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
								Call GetChannelAllocStationDesc( colChannelNo, colAllocatedTo, SH_cls_Execute )
								If SalIsNull( colAllocatedTo )
									Call GetChannelAllocPumpDesc( colChannelNo, colAllocatedTo, SH_cls_Execute )
									If SalIsNull( colAllocatedTo )
										Call GetChannelAllocSwitchDesc( colChannelNo, colAllocatedTo, SH_cls_Execute )
								Return TRUE
							On PAM_clsTBL_NOROWS
								Return TRUE
							On SAM_RowHeaderDoubleClick
								Call SalModalDialog( dlgPhysicalChannelControl, hWndForm, hWndParent.clsdlgChannels.bRunning, colBoardNo, colPortNo )
					Background Text: Double click the row header to gain access to hardware controls.

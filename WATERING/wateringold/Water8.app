						Contents
							Column: colPumpNo
								Class Child Ref Key: 0
								Class ChildKey: 25
								Class: clsColumnGeneral
								Property Template:
								Class DLL Name:
								Title: Pump No
								Visible? No
								Editable? Class Default
								Maximum Data Length: Class Default
								Data Type: Number
								Justify: Class Default
								Width:  Class Default
								Width Editable? Class Default
								Format: Class Default
								Country: Class Default
								Input Mask: Class Default
								Cell Options
									Cell Type? Class Default
									Multiline Cell? Class Default
									Cell DropDownList
										Sorted? Class Default
										Vertical Scroll? Class Default
										Auto Drop Down? Class Default
										Allow Text Editing? Class Default
									Cell CheckBox
										Check Value:
										Uncheck Value:
										Ignore Case? Class Default
								List Values
								Message Actions
									On PAM_clsTBL_CHECKROWNEW
										Call GetNextPumpNo( colPumpNo, SH_cls_Execute )
										If colPumpNo > 0
											Return TRUE
										Else
											Call ErrorMessage( 'An error has occured in allocating the next Pump No. Please try and save again.', hWndForm, lParam )
											Return FALSE
									On PAM_clsTBL_CHECKROWDELETED
										Call ExistsPumpStation( colPumpNo, bExists, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'Cannot delete this Pump, as it still has stations linked to it.', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE

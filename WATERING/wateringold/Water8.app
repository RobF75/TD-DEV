			Function: LogMaintenance
				Description:
				Returns
					Boolean:
				Parameters
					Number: nKeyNo
					! sKeyType = 'PROGRAM', 'PUMP', 'STATION', 'SWITCH', 'REBOOT'
					String: sKeyType
					String: sStatus
					! sActionType = 'OPEN', 'CLOSE', 'APPEND', 'DISCONNECT'
					String: sActionType
				Static Variables
					: fcLogFile
						Class: clsStrFileHandle
					String: sFileName
				Local variables
					String: sLogDT
					String: sLogEntryType
					String: sLogEntryDesc
					String: sLogStatus
					String: sLogChannel
					!
					String: sGotEntryDesc
					Number: nGotChannelNo
					String: sNewFileName
					Boolean: bOk
					!
					Date/Time: dtCurrentDT
					Number: nCount
					String: sLogFilePath
					Number: nNumLogFiles
					String: saLogFiles[*]
					Number: naLogSizes[*]
					Date/Time: dtaLogTimeStamps[*]
					Number: naLogAttributes[*]
					Number: nDaysToKeepLogs
					!
					Date/Time: dtTmp
					Number: nTmp
				Actions
					If sActionType = 'OPEN'
						Set dtCurrentDT = SalDateCurrent(  )
						Set sNewFileName = MakeLogFileName( SalDateCurrent(  ) )
						If sNewFileName != sFileName
							Set sFileName = sNewFileName
							!
							Set nDaysToKeepLogs = SalStrToNumber( OurGetIniFileParameter( 'GENERAL', 'DaysToKeepLogs', sDEFAULTDAYSKEEPLOGS ) )
							Set sLogFilePath = OurGetIniFileParameter( 'GENERAL', 'WateringLogsPath', sDEFAULTLOGPATH )
							Set sLogFilePath = SalStrTrimX( sLogFilePath )
							Set nNumLogFiles = VisDosEnumFileInfo( sLogFilePath || '\\*.log', FA_Standard, saLogFiles, naLogSizes, dtaLogTimeStamps, naLogAttributes )
							!
							Set nCount = 0
							While nCount < nNumLogFiles
								If dtCurrentDT - ExtractLogFileNameDate( saLogFiles[ nCount ] ) > nDaysToKeepLogs
									Call VisFileDelete( sLogFilePath || '\\' || saLogFiles[ nCount ] )
								Set nCount = nCount + 1
						Call fcLogFile.Setup( sFileName, OF_Append | OF_Write | OF_Text, 120 )
						If fcLogFile.Open( )
							Set bOk = TRUE
						Else
							Call fcLogFile.Setup( sFileName, OF_Create | OF_Write | OF_Text, 120 )
							Set bOk = fcLogFile.Open( )
						Return bOk
					Else If sActionType = 'CLOSE'
						Return fcLogFile.Close( )
					Else If sActionType = 'APPEND'
						Set sLogDT = DateToStrX( SalDateCurrent(  ) )
						Call StringEndPad( sLogDT, ' ', 27 )
						!
						Set sLogEntryType = sKeyType
						Call StringEndPad( sLogEntryType, ' ', 8 )
						!
						If sKeyType = 'PROGRAM'
							Call GetProgramLogDets( nKeyNo, sGotEntryDesc, dtTmp, nTmp, SH_cls_Execute )
						Else If sKeyType = 'PUMP'
							Call GetPumpLogDets( nKeyNo, sGotEntryDesc, nGotChannelNo, SH_cls_Execute )
						Else If sKeyType = 'STATION'
							Call GetStationLogDets( nKeyNo, sGotEntryDesc, nGotChannelNo, SH_cls_Execute )
						Else If sKeyType = 'SWITCH'
							Call GetSwitchLogDets( nKeyNo, sGotEntryDesc, nGotChannelNo, SH_cls_Execute )
						Else
							Set sGotEntryDesc = sStatus
							Set sStatus = ''
							Set nGotChannelNo = NUMBER_Null
						!
						Set sLogEntryDesc = sGotEntryDesc
						Call StringEndPad( sLogEntryDesc, ' ', 60 )
						!
						Set sLogStatus = sStatus
						Call StringEndPad( sLogStatus, ' ', 9 )
						!
						Set sLogChannel = SalNumberToStrX( nGotChannelNo, 0 )
						Call StringEndPad( sLogChannel, ' ', 4 )
						!
						Return fcLogFile.Write( sLogDT || '   ' || sLogEntryType || '   ' || sLogEntryDesc || '   ' || sLogStatus || '   ' || sLogChannel )
					Else If sActionType = 'DISCONNECT'
						Set bOk = TRUE
						If NOT GetProgramLogDets( 0, sGotEntryDesc, dtTmp, nTmp, SH_cls_Disconnect )
							Set bOk = FALSE
						If NOT GetPumpLogDets( 0, sGotEntryDesc, nGotChannelNo, SH_cls_Disconnect )
							Set bOk = FALSE
						If NOT GetStationLogDets( 0, sGotEntryDesc, nGotChannelNo, SH_cls_Disconnect )
							Set bOk = FALSE
						If NOT GetSwitchLogDets( 0, sGotEntryDesc, nGotChannelNo, SH_cls_Disconnect )
							Set bOk = FALSE
						Return bOk
			Function: MakeLogFileName
				Description:
				Returns
					String:
				Parameters
					Date/Time: dtCurrentDT
				Static Variables
				Local variables
					String: sDay
					String: sMonth
					String: sYear
					String: sLogFilePath
				Actions
					Set sDay = SalNumberToStrX( SalDateDay( dtCurrentDT ), 0 )
					Call StringStartPad( sDay, '0', 2 )
					Set sMonth = SalNumberToStrX( SalDateMonth( dtCurrentDT ), 0 )
					Call StringStartPad( sMonth, '0', 2 )
					Set sYear = SalNumberToStrX( SalDateYear( dtCurrentDT ), 0 )
					Set sLogFilePath = OurGetIniFileParameter( 'GENERAL', 'WateringLogsPath', sDEFAULTLOGPATH )
					Set sLogFilePath = SalStrTrimX( sLogFilePath )
					Return sLogFilePath || '\\' || sDay || sMonth || sYear || '.log'
			Function: ExtractLogFileNameDate
				Description:
				Returns
					Date/Time:
				Parameters
					String: sFileName
				Static Variables
				Local variables
					Number: nYear
					Number: nMonth
					Number: nDay
					Number: nDotPos
					Date/Time: dtFileDate
				Actions
					Set nDotPos = SalStrScan( sFileName, '.Log' )
					If nDotPos >= 0
						Set sFileName = SalStrMidX( sFileName, nDotPos-8, 8 )
						Set nDay = SalStrToNumber( SalStrMidX( sFileName, 0, 2 ) )
						Set nMonth = SalStrToNumber( SalStrMidX( sFileName, 2, 2 ) )
						Set nYear = SalStrToNumber( SalStrMidX( sFileName, 4, 4 ) )
						Set dtFileDate = SalDateConstruct( nYear, nMonth, nDay, 0, 0, 0 )
						Return dtFileDate
					Else
						Return DATETIME_Null
			Function: GetProgramLogDets
				Description:
				Returns
					Boolean:
				Parameters
					Number: nProgramNo
					Receive String: sProgDesc
					Receive Date/Time: dtProgStartTime
					Receive Number: nRecurrDays
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Number: nInd
					!
					String: sGotProgDesc
					Date/Time: dtGotProgStartTime
					Number: nGotRecurrDays
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetProgramLogDets' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Prog_Start_DT, 
									  Prog_Desc, 
									  Recurr_Days
									FROM 
									  Program  
									WHERE 
									  Program_No = :1 "
							Set sName = 'GTPROGLGDTS'
							Set sBind = ':nProgramNo'
							Set sInto = ':dtGotProgStartTime, :sGotProgDesc, :nGotRecurrDays'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set sGotProgDesc = ''
							Set dtGotProgStartTime = DATETIME_Null
							Set nGotRecurrDays = NUMBER_Null
							Set sProgDesc = ''
							Set dtProgStartTime = DATETIME_Null
							Set nRecurrDays = NUMBER_Null
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set sProgDesc = sGotProgDesc
									Set dtProgStartTime = dtGotProgStartTime
									Set nRecurrDays = nGotRecurrDays
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )

					                 Menu Item Name: 
		                 Tool Bar 
			                 Contents 
		                 Contents 
			                 Column: colBoardNo
				                 List Values 
				                 Message Actions 
			                 Column: colBoardPortNo
				                 List Values 
				                 Message Actions 
			                 Column: colStatus
				                 List Values 
				                 Message Actions 
		                 Functions 
		                 Window Parameters 
		                 Window Variables 
			                 Number: nRow
			                 Boolean: bFound
			                 String: sLookBoardNo
			                 String: sLookBoardPortNo
		                 Message Actions 
			                 On PAM_clsWATERING_REFRESHDATA
				                 Call PopString( sLookBoardPortNo, TRUE )
				                 Call PopString( sLookBoardNo, TRUE )
				                 Set nRow = TBL_MinRow 
				                 Set bFound = FALSE
				                 While SalTblFindNextRow( hWndForm, nRow, 0, 0 ) AND NOT bFound
					                 Call SalTblSetContext( hWndForm, nRow )
					                 If colBoardNo = sLookBoardNo AND colBoardPortNo = sLookBoardPortNo
						                 Set bFound = TRUE
						                 Call PushNumber( colStatus )
				                 If NOT bFound
					                 Call PushNumber( 0 )
				                 Return TRUE
			                 On SAM_CreateComplete
				                 Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
				                 Call SalTblSetContext( hWndForm, nRow )
				                 Set colBoardNo = '01'
				                 Set colBoardPortNo = 'B5'
				                 Set colStatus = 0
				                 Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
				                 Call SalTblSetContext( hWndForm, nRow )
				                 Set colBoardNo = '01'
				                 Set colBoardPortNo = 'B6'

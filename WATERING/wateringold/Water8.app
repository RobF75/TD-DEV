				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbSwitches.nActivateWindowType = ACTIVATE_DialogModal
						Set clspbSwitches.sActivateDialogName = 'dlgSwitches'
						Set clspbSwitches.hWndTable = hWndPickIntoTable
						Set clspbSwitches.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushWndHdl( hWndItem )
						Call PushNumber( bRunning )
						Return TRUE
					On PAM_clsPICK_LOOKUP
						Call PopNumber( nSwitchNo, TRUE )
						Call PopNumber( nSwitchChannelNo, TRUE )
						Call PopString( sSwitchDesc, TRUE )
						Call PopString( sSwitchStatus, TRUE )
						Call SalSendMsg( hWndItem, PAM_cls_GETFIELDS, 0, 0 )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopNumber( nTmp, TRUE )
						Call PopWndHdl( hWndTmp, TRUE )
						Return TRUE

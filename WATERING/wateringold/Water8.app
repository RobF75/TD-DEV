						Functions
						Window Variables
							Boolean: bExists
							Date/Time: dtTmp
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = " SELECT 
										  Program_No, 
										  Prog_Start_DT, 
										  Prog_Start_DT, 
										  Prog_Next_DT, 
										  Prog_Desc, 
										  Recurr_Days, 
										  Prog_Status
										FROM Program 
										ORDER BY Prog_Status, Prog_Next_DT "
								Set sNAMEPopHandle = 'POPPROGS'
								Set sBINDPopHandle = ''
								Set sINTOPopHandle = ':clsfrmPrograms.tblPrograms.colProgramNo, 
										:clsfrmPrograms.tblPrograms.colProgStartTime, 
										:clsfrmPrograms.tblPrograms.colProgStartDT, 
										:clsfrmPrograms.tblPrograms.colProgNextDT, 
										:clsfrmPrograms.tblPrograms.colProgDesc, 
										:clsfrmPrograms.tblPrograms.colProgRecurrDays, 
										:clsfrmPrograms.tblPrograms.colProgStatus'
								!
								Set sSQLRefreshHandle = " SELECT 
										  Program_No, 
										  Prog_Start_DT, 
										  Prog_Start_DT, 
										  Prog_Next_DT, 
										  Prog_Desc, 
										  Recurr_Days, 
										  Prog_Status
										FROM Program 
										WHERE Program_No = :1 "
								Set sNAMERefreshHandle = 'REFPROGS'
								Set sBINDRefreshHandle = ':clsfrmPrograms.tblPrograms.colProgramNo'
								Set sINTORefreshHandle = ':clsfrmPrograms.tblPrograms.colProgramNo, 
										:clsfrmPrograms.tblPrograms.colProgStartTime, 
										:clsfrmPrograms.tblPrograms.colProgStartDT, 
										:clsfrmPrograms.tblPrograms.colProgNextDT, 
										:clsfrmPrograms.tblPrograms.colProgDesc, 
										:clsfrmPrograms.tblPrograms.colProgRecurrDays, 
										:clsfrmPrograms.tblPrograms.colProgStatus'
								!
								Set sSQLInsertHandle = " INSERT INTO Program  
										( Program_No, 
										  Prog_Start_DT, 
										  Prog_Next_DT, 
										  Prog_Desc, 
										  Recurr_Days, 
										  Prog_Status ) VALUES ( :1, :2, :3, :4, :5, :6 ) "
								Set sNAMEInsertHandle = 'INSPROGS'
								Set sBINDInsertHandle = ':clsfrmPrograms.tblPrograms.colProgramNo, 
										:clsfrmPrograms.tblPrograms.colProgStartDT, 
										:clsfrmPrograms.tblPrograms.colProgNextDT, 
										:clsfrmPrograms.tblPrograms.colProgDesc, 
										:clsfrmPrograms.tblPrograms.colProgRecurrDays, 
										:clsfrmPrograms.tblPrograms.colProgStatus'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE Program 
										SET 
										  Prog_Start_DT = :2, 
										  Prog_Next_DT = :3, 
										  Prog_Desc = :4, 
										  Recurr_Days = :5, 
										  Prog_Status = :6
										WHERE 
										  Program_No = :1'
								Set sNAMEUpdateHandle = 'UPDTPROGS'
								Set sBINDUpdateHandle = ':clsfrmPrograms.tblPrograms.colProgramNo, 
										:clsfrmPrograms.tblPrograms.colProgStartDT, 
										:clsfrmPrograms.tblPrograms.colProgNextDT, 
										:clsfrmPrograms.tblPrograms.colProgDesc, 
										:clsfrmPrograms.tblPrograms.colProgRecurrDays, 
										:clsfrmPrograms.tblPrograms.colProgStatus'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = 'DELETE FROM Program WHERE Program_No = :1'
								Set sNAMEDeleteHandle = 'DELPROGS'
								Set sBINDDeleteHandle = ':clsfrmPrograms.tblPrograms.colProgramNo'
								Set sINTODeleteHandle = ''
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								!
								Set hWndRowNewColumn = colProgDesc
								Set sTableHeading = 'Programs'
							On PAM_clsTBL_NOROWS
								Return TRUE
							On SAM_Destroy
								Call GetNextProgNo( colProgramNo, SH_cls_Disconnect )
								Call ExistsProgStations( 0, bExists, SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
							On PAM_clsTBL_CONTEXTROWCHANGED
								Call SalSendMsg( hWndParent.clsfrmPrograms.pbMakeCurrentProg, SAM_Click, 0, 0 )
							On PAM_clsTBL_POPULATED
								Call SalSendMsg( hWndParent.clsfrmPrograms.pbMakeCurrentProg, SAM_Click, 0, 0 )

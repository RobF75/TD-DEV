					                 Menu Actions 
						                 Call SalSendValidateMsg(  )
						                 Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
						                 Call SalTblSetContext( hWndForm, nRow )
					                 Menu Item Name: 
				                 Menu Item: Delete Row
					                 Keyboard Accelerator: (none)

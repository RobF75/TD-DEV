							Message Actions
								On PAM_cls_SETINSTANCEVARS
									Call SalSendClassMessage( PAM_cls_SETINSTANCEVARS, wParam, lParam )
									If bRunning
										Set picTrafficLight.nStartState = 3
									Else
										Set picTrafficLight.nStartState = 1
								On PAM_clsPIC_STATECLICK
									If wParam = 1
										Set bRunning = FALSE
										Call SetWateringActiveState( bRunning )
										Call InitialiseIOCard( 'STOP', SH_cls_Execute )
										If StopOnPumps( SH_cls_Execute )
											Call StopOnPumps( SH_cls_Commit )
									Else If wParam = 3
										Set bRunning = TRUE
										Call SetWateringActiveState( bRunning )
										Call InitialiseIOCard( 'START', SH_cls_Execute )
									Return SalSendClassMessage( PAM_clsPIC_STATECLICK, wParam, lParam )

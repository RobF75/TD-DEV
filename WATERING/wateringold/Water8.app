					Boolean: bRunning
				Functions
					Function: SetChannelsFields
						Description:
						Returns
							Boolean:
						Parameters
							Boolean: bNewRunning
						Static Variables
						Local variables
						Actions
							Set bRunning = bNewRunning
							Return TRUE
					Function: GetChannelsFields
						Description:
						Returns
							Boolean:
						Parameters
							Receive Number: nNewChannelNo
						Static Variables
						Local variables
						Actions
							Set nNewChannelNo = nChannelNo
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbChannels.nActivateWindowType = ACTIVATE_DialogModal
						Set clspbChannels.sActivateDialogName = 'dlgChannels'
						Set clspbChannels.hWndTable = hWndPickIntoTable
						Set clspbChannels.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushWndHdl( hWndItem )
						Call PushNumber( bRunning )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopNumber( nTmp, TRUE )
						Call PopWndHdl( hWndTmp, TRUE )
						Return TRUE
					On PAM_clsPICK_LOOKUP
						Call PopNumber( nChannelNo, TRUE )
						Call SalSendMsg( hWndItem, PAM_cls_GETFIELDS, 0, 0 )
						Return TRUE

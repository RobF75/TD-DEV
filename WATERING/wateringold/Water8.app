				Functions
					Function: ExistsProgStations
						Description:
						Returns
							Boolean:
						Parameters
							Number: nProgramNo
							Receive Boolean: bExists
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							!
							Number: nInd
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'ExistsProgStations' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT Station_No 
											FROM Prog_Stations
											WHERE Program_No = :1 "
									Set sName = 'EXISTSPROGSTS'
									Set sBind = ''
									Set sInto = ''
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set bExists = FALSE
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
											Set bExists = TRUE
										Return TRUE
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					Function: SetWateringActiveState
						Description:
						Returns
							Boolean:
						Parameters
							Boolean: bRunning
						Static Variables
						Local variables
							: fcFileHandle
								Class: clsStrFileHandle
							Boolean: bOk
						Actions
							Set bOk = TRUE
							Call fcFileHandle.Setup( OurGetIniFileParameter( 'GENERAL', 'WateringLogsPath', 'C:\\TEMP' )||'\\OnState.log', NUMBER_Null, NUMBER_Null )
							If fcFileHandle.Open( )
								If bRunning
									If NOT fcFileHandle.Write( 'STATE (ON/OFF)=ON' )
										Set bOk = FALSE
								Else
									If NOT fcFileHandle.Write( 'STATE (ON/OFF)=OFF' )
										Set bOk = FALSE
								If NOT fcFileHandle.Close( )
									Set bOk = FALSE
							Else
								Set bOk = FALSE
							Return bOk
					Function: GetWateringActiveState
						Description:
						Returns
							Boolean:
						Parameters
							Receive Boolean: bRunning
						Static Variables
						Local variables
							: fcFileHandle
								Class: clsStrFileHandle
							String: sState
							Boolean: bOk
						Actions
							Set bOk = TRUE
							Set bRunning = TRUE
							Call fcFileHandle.Setup( OurGetIniFileParameter( 'GENERAL', 'WateringLogsPath', 'C:\\TEMP' )||'\\OnState.log', OF_ReadWrite | OF_Text, NUMBER_Null )
							If fcFileHandle.Open( )
								If NOT fcFileHandle.Read( sState )
									Set bOk = FALSE
								If sState = 'STATE (ON/OFF)=OFF'
									Set bRunning = FALSE
								If NOT fcFileHandle.Close( )
									Set bOk = FALSE
							Else
								Set bOk = FALSE
							Return bOk
					!
					Function: SetLastRebootDateTime
						Description:
						Returns
							Boolean:
						Parameters
							Date/Time: dtRebootDT
						Static Variables
						Local variables
							: fcFileHandle
								Class: clsStrFileHandle
							Boolean: bOk
						Actions
							Set bOk = TRUE
							Call fcFileHandle.Setup( OurGetIniFileParameter( 'GENERAL', 'WateringLogsPath', 'C:\\TEMP' )||'\\LastBoot.log', NUMBER_Null, NUMBER_Null )
							If fcFileHandle.Open( )
								If NOT fcFileHandle.Write( DateToStrX( SalDateCurrent(  ) ) )
									Set bOk = FALSE
								If NOT fcFileHandle.Close( )
									Set bOk = FALSE
							Else
								Set bOk = FALSE
							Return bOk
					Function: GetLastRebootDateTime
						Description:
						Returns
							Boolean:
						Parameters
							Receive Date/Time: dtLastBootDT
						Static Variables
						Local variables
							: fcFileHandle
								Class: clsStrFileHandle
							String: sTmp
							Boolean: bOk
						Actions
							Set bOk = TRUE
							Set dtLastBootDT = DATETIME_Null
							Call fcFileHandle.Setup( OurGetIniFileParameter( 'GENERAL', 'WateringLogsPath', 'C:\\TEMP' )||'\\LastBoot.log', OF_ReadWrite | OF_Text, NUMBER_Null )
							If fcFileHandle.Open( )
								If NOT fcFileHandle.Read( sTmp )
									Set bOk = FALSE
								Set dtLastBootDT = SalStrToDate( sTmp )
								If NOT fcFileHandle.Close( )
									Set bOk = FALSE
							Else
								Set bOk = FALSE
							Return bOk
					!
					Function: AllocStationSeqNos
						Description:
						Returns
							Boolean:
						Parameters
							Number: nProgramNo
							Number: nMinAllocPressurePerc
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nInd
							Boolean: bOk
							Number: nProgPumpsHandleNo
							Number: nStatUnAllocLTLitresHandleNo
							Number: nStatUnAllocTB4PmpHandleNo
							Number: nStatAllocLTLitresHandleNo
							Number: nStatGTLitresHandleNo
							!
							Boolean: bLoop
							Boolean: bFirst
							Boolean: bFound
							Number: nCrntWaterSecs
							Number: nWateredSecs
							String: sStationStatus
							Number: nNeedAllocLitres
							Number: nOrgNeedAllocLitres
							Number: nSeqNo
							Number: nSeqLitres
							Number: nInstanceNo
							Number: nStationNo
							Number: nPumpNo
							Number: nPumpLitres
							Number: nStationLitres
						Actions
							Set nProgPumpsHandleNo = SqlHandlesGetReferenceNo( 'AllocStationSeqNosPumpsHandle' )
							Set nStatUnAllocLTLitresHandleNo = SqlHandlesGetReferenceNo( 'AllocStationSeqNosUnAllocLTLitresStationsHandle' )
							Set nStatUnAllocTB4PmpHandleNo = SqlHandlesGetReferenceNo( 'AllocStationSeqNosUnAllocTBig4PumpStationsHandle' )
							Set nStatAllocLTLitresHandleNo = SqlHandlesGetReferenceNo( 'AllocStationSeqNosAllocLTLitresStationsHandle' )
							Set nStatGTLitresHandleNo = SqlHandlesGetReferenceNo( 'AllocStationSeqNosGTLitresStationsHandle' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT DISTINCT 
											  Station.Pump_No, 
											  Pump.Pump_Litres_Min 
											FROM 
											  Prog_Stations, 
											  Station, 
											  Pump 
											WHERE 
											  Prog_Stations.Program_No = :1 AND 
											  Prog_Stations.Station_No = Station.Station_No AND 
											  Station.Pump_No = Pump.Pump_No "
									Set sName = 'GTPRGSTATPUMPS'
									Set sBind = ':nProgramNo'
									Set sInto = ':nPumpNo, :nPumpLitres'
									Call haSqlHandles[ nProgPumpsHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nProgPumpsHandleNo ].hSqlHandle )
									!
									Set sSql = " SELECT 
											  Prog_Stations.Instance_No, 
											  Prog_Stations.Station_No, 
											  Station.Station_Litres_Min 
											FROM 
											  Prog_Stations, 
											  Station 
											WHERE 
											  Prog_Stations.Program_No = :1 AND 
											  Prog_Stations.Station_No = Station.Station_No AND 
											  Prog_Stations.Water_Seq_No = 0 AND 
											  Station.Station_Litres_Min <= :2 AND 
											  Station.Pump_No = :3 
											ORDER BY 
											  Prog_Stations.Crnt_Water_Sec DESC, 
											  Station.Station_Litres_Min DESC"
									Set sName = 'GPGUASTAT'
									Set sBind = ':nProgramNo, :nNeedAllocLitres, :nPumpNo'
									Set sInto = ':nInstanceNo, :nStationNo, :nStationLitres'
									Call haSqlHandles[ nStatUnAllocLTLitresHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nStatUnAllocLTLitresHandleNo ].hSqlHandle )
									!
									Set sSql = " SELECT 
											  Prog_Stations.Instance_No, 
											  Prog_Stations.Station_No, 
											  Station.Station_Litres_Min 
											FROM 
											  Prog_Stations, 
											  Station 
											WHERE 
											  Prog_Stations.Program_No = :1 AND 
											  Prog_Stations.Station_No = Station.Station_No AND 
											  Prog_Stations.Water_Seq_No = 0 AND 
											  Station.Station_Litres_Min > :2 AND 
											  Station.Pump_No = :3 
											ORDER BY 
											  Prog_Stations.Crnt_Water_Sec DESC, 
											  Station.Station_Litres_Min DESC"
									Set sName = 'GPGTBSTATFP'
									Set sBind = ':nProgramNo, :nPumpLitres, :nPumpNo'
									Set sInto = ':nInstanceNo, :nStationNo, :nStationLitres'
									Call haSqlHandles[ nStatUnAllocTB4PmpHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nStatUnAllocTB4PmpHandleNo ].hSqlHandle )
									!
									Set sSql = " SELECT 
											  Prog_Stations.Instance_No, 
											  Prog_Stations.Station_No, 
											  Station.Station_Litres_Min, 
											  Prog_Stations.Crnt_Water_Sec, 
											  Prog_Stations.Watered_Sec, 
											  Prog_Stations.Station_Status  
											FROM 
											  Prog_Stations, 
											  Station 
											WHERE 
											  Prog_Stations.Program_No = :1 AND 
											  Prog_Stations.Station_No = Station.Station_No AND 
											  NOT Prog_Stations.Water_Seq_No = :2 AND 
											  Station.Station_Litres_Min <= :3 AND 
											  Station.Pump_No = :4 
											ORDER BY 
											  Prog_Stations.Crnt_Water_Sec DESC, 
											  Station.Station_Litres_Min DESC"
									Set sName = 'GPGASTAT'
									Set sBind = ':nProgramNo, :nSeqNo, :nNeedAllocLitres, :nPumpNo'
									Set sInto = ':nInstanceNo, :nStationNo, :nStationLitres, :nCrntWaterSecs, :nWateredSecs, :sStationStatus'
									Call haSqlHandles[ nStatAllocLTLitresHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nStatAllocLTLitresHandleNo ].hSqlHandle )
									!
									Set sSql = " SELECT 
											  Prog_Stations.Instance_No, 
											  Prog_Stations.Station_No, 
											  Station.Station_Litres_Min 
											FROM 
											  Prog_Stations, 
											  Station 
											WHERE 
											  Prog_Stations.Program_No = :1 AND 
											  Prog_Stations.Station_No = Station.Station_No AND 
											  Station.Station_Litres_Min > :2 AND 
											  Station.Station_Litres_Min <= :3 AND 
											  Station.Pump_No = :4 
											ORDER BY 
											  Prog_Stations.Crnt_Water_Sec DESC, 
											  Station.Station_Litres_Min DESC"
									Set sName = 'GPGGTPSTAT'
									Set sBind = ':nProgramNo, :nNeedAllocLitres, :nPumpLitres, :nPumpNo'
									Set sInto = ':nInstanceNo, :nStationNo, :nStationLitres'
									Call haSqlHandles[ nStatGTLitresHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nStatGTLitresHandleNo ].hSqlHandle )
									!
									Set bOk = TRUE
									If ResetProgramAllocStations( nProgramNo, 0, SH_cls_Execute )
										If NOT ResetProgramAllocStations( 0, 0, SH_cls_Commit )
											Set bOk = FALSE
									Else
										If NOT ResetProgramAllocStations( 0, 0, SH_cls_Rollback )
											Set bOk = FALSE
										Set bOk = FALSE
									!
									If bOk
										If haSqlHandles[ nProgPumpsHandleNo ].Execute( )
											While haSqlHandles[ nProgPumpsHandleNo ].FetchNext( nInd ) AND bOk
												Set nSeqNo = 1
												!
												If haSqlHandles[ nStatUnAllocTB4PmpHandleNo ].Execute( )
													While haSqlHandles[ nStatUnAllocTB4PmpHandleNo ].FetchNext( nInd )
														If SetProgramStationSeqNo( nInstanceNo, nProgramNo, nStationNo, nSeqNo, SH_cls_Execute )
															If NOT SetProgramStationSeqNo( 0, 0, 0, 0, SH_cls_Commit )
																Set bOk = FALSE
														Else
															Set bOk = FALSE
														Set nSeqNo = nSeqNo + 1
												Else
													Set bOk = FALSE
												!
												If bOk
													Set bLoop = TRUE
													While bLoop
														Set nNeedAllocLitres = nPumpLitres
														Set bFirst = TRUE
														Set bFound = TRUE
														While bFound AND nNeedAllocLitres >= ( nPumpLitres * nMinAllocPressurePerc/100 )
															Set nOrgNeedAllocLitres = nNeedAllocLitres
															Set nNeedAllocLitres = nNeedAllocLitres + ( nNeedAllocLitres * nMinAllocPressurePerc/100 )
															If haSqlHandles[ nStatUnAllocLTLitresHandleNo ].Execute( )
																Set nNeedAllocLitres = nOrgNeedAllocLitres
																If haSqlHandles[ nStatUnAllocLTLitresHandleNo ].FetchNext( nInd )
																	If SetProgramStationSeqNo( nInstanceNo, nProgramNo, nStationNo, nSeqNo, SH_cls_Execute )
																		If NOT SetProgramStationSeqNo( 0, 0, 0, 0, SH_cls_Commit )
																			Set bOk = FALSE
																	Else
																		Set bOk = FALSE
																	Set nNeedAllocLitres = nNeedAllocLitres - nStationLitres
																	Set bFirst = FALSE
																Else
																	Set bFound = FALSE
																	If bFirst
																		Set bFound = TRUE
																		While bFound AND nNeedAllocLitres >= ( nPumpLitres * nMinAllocPressurePerc/100 )
																			If haSqlHandles[ nStatGTLitresHandleNo ].Execute( )
																				If haSqlHandles[ nStatGTLitresHandleNo ].FetchNext( nInd )
																					If SetProgramStationSeqNo( nInstanceNo, nProgramNo, nStationNo, nSeqNo, SH_cls_Execute )
																						If NOT SetProgramStationSeqNo( 0, 0, 0, 0, SH_cls_Commit )
																							Set bOk = FALSE
																					Else
																						Set bOk = FALSE
																					Set nNeedAllocLitres = nNeedAllocLitres - nStationLitres
																					Set bFirst = FALSE
																				Else
																					Set bFound = FALSE
																			Else
																				Set bOk = FALSE
																		If NOT bFound
																			Set bLoop = FALSE
															Else
																Set nNeedAllocLitres = nOrgNeedAllocLitres
																Set bOk = FALSE
														If NOT bFound AND bLoop
															Set nOrgNeedAllocLitres = nNeedAllocLitres
															Set nNeedAllocLitres = nNeedAllocLitres + ( nNeedAllocLitres * nMinAllocPressurePerc/100 )
															If haSqlHandles[ nStatAllocLTLitresHandleNo ].Execute( )
																Set nNeedAllocLitres = nOrgNeedAllocLitres
																Set bFound = TRUE
																While bFound AND nNeedAllocLitres >= ( nPumpLitres * nMinAllocPressurePerc/100 )
																	If haSqlHandles[ nStatAllocLTLitresHandleNo ].FetchNext( nInd )
																		If InsertProgStationExtrasNeeded( nProgramNo, nStationNo, 0, nWateredSecs, sStationStatus, nSeqNo, SH_cls_Execute )
																			If NOT InsertProgStationExtrasNeeded( 0, 0, 0, 0, '', 0, SH_cls_Commit )
																				Set bOk = FALSE
																		Else
																			Set bOk = FALSE
																		Set nNeedAllocLitres = nNeedAllocLitres - nStationLitres
																		Set bFirst = FALSE
																	Else
																		Set bFound = FALSE
															Else
																Set nNeedAllocLitres = nOrgNeedAllocLitres
																Set bOk = FALSE
														Set nSeqNo = nSeqNo + 1
										Else
											Set bOk = FALSE
									Return bOk
								Case SH_cls_Commit
									Set bOk = TRUE
									! If NOT haSqlHandles[ nProgPumpsHandleNo ].Commit( )
										         Set bOk = FALSE
									! If NOT haSqlHandles[ nStatUnAllocLTLitresHandleNo ].Commit( )
										         Set bOk = FALSE
									! If NOT haSqlHandles[ nStatUnAllocTB4PmpHandleNo ].Commit( )
										         Set bOk = FALSE
									! If NOT haSqlHandles[ nStatAllocLTLitresHandleNo ].Commit( )
										         Set bOk = FALSE
									! If NOT haSqlHandles[ nStatGTLitresHandleNo ].Commit( )
										         Set bOk = FALSE
									If NOT ResetProgramAllocStations( 0, 0, SH_cls_Commit )
										Set bOk = FALSE
									If NOT SetProgramStationSeqNo( 0, 0, 0, 0, SH_cls_Commit )
										Set bOk = FALSE
									If NOT InsertProgStationExtrasNeeded( 0, 0, 0, 0, '', 0, SH_cls_Commit )
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Rollback
									Set bOk = TRUE
									! If NOT haSqlHandles[ nProgPumpsHandleNo ].Rollback( )
										         Set bOk = FALSE
									! If NOT haSqlHandles[ nStatUnAllocLTLitresHandleNo ].Rollback( )
										         Set bOk = FALSE
									! If NOT haSqlHandles[ nStatUnAllocTB4PmpHandleNo ].Rollback( )
										         Set bOk = FALSE
									! If NOT haSqlHandles[ nStatAllocLTLitresHandleNo ].Rollback( )
										         Set bOk = FALSE
									! If NOT haSqlHandles[ nStatGTLitresHandleNo ].Rollback( )
										         Set bOk = FALSE
									If NOT ResetProgramAllocStations( 0, 0, SH_cls_Rollback )
										Set bOk = FALSE
									If NOT SetProgramStationSeqNo( 0, 0, 0, 0, SH_cls_Rollback )
										Set bOk = FALSE
									If NOT InsertProgStationExtrasNeeded( 0, 0, 0, 0, '', 0, SH_cls_Rollback )
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Disconnect
									Set bOk = TRUE
									! If NOT haSqlHandles[ nProgPumpsHandleNo ].Disconnect( )
										         Set bOk = FALSE
									! If NOT haSqlHandles[ nStatUnAllocLTLitresHandleNo ].Disconnect( )
										         Set bOk = FALSE
									! If NOT haSqlHandles[ nStatUnAllocTB4PmpHandleNo ].Disconnect( )
										         Set bOk = FALSE
									! If NOT haSqlHandles[ nStatAllocLTLitresHandleNo ].Disconnect( )
										         Set bOk = FALSE
									! If NOT haSqlHandles[ nStatGTLitresHandleNo ].Disconnect( )
										         Set bOk = FALSE
									If NOT ResetProgramAllocStations( 0, 0, SH_cls_Disconnect )
										Set bOk = FALSE
									If NOT SetProgramStationSeqNo( 0, 0, 0, 0, SH_cls_Disconnect )
										Set bOk = FALSE
									If NOT InsertProgStationExtrasNeeded( 0, 0, 0, 0, '', 0, SH_cls_Disconnect )
										Set bOk = FALSE
									Return bOk
					! Function: ResetAllProgramSeqNos
						                   Description: 
						                   Returns 
							                   Boolean: 
						                   Parameters 
							                   Number: nProgramNo
							                   Number: nSeqNo
							                   Number: nActionType
						                   Static Variables 
						                   Local variables 
							                   String: sSql
							                   String: sBind
							                   String: sInto
							                   String: sName
							                   Number: nOurHandleNo
							                   Boolean: bOk
						                   Actions 
							                   Set nOurHandleNo = SqlHandlesGetReferenceNo( 'ResetAllProgramSeqNos' )
							                   Select Case nActionType
								                   Case SH_cls_Execute
									                   Set sSql = " UPDATE Prog_Stations 
											SET 
											  Water_Seq_No = :2 
											WHERE 
											  Program_No = :1 "
									                   Set sName = 'RSTPRGSEQNO'
									                   Set sBind = ':nProgramNo, :nSeqNo'
									                   Set sInto = ''
									                   Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									                   Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									                   Return haSqlHandles[ nOurHandleNo ].Execute( )
									                   Return bOk
								                   Case SH_cls_Commit
									                   Return haSqlHandles[ nOurHandleNo ].Commit( )
								                   Case SH_cls_Rollback
									                   Return haSqlHandles[ nOurHandleNo ].Rollback( )
								                   Case SH_cls_Disconnect
									                   Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					!
					Function: ResetProgramAllocStations
						Description:
						Returns
							Boolean:
						Parameters
							Number: nProgramNo
							Number: nSeqNo
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurGetHandleNo
							Number: nOurUpdtHandleNo
							Number: nOurDelHandleNo
							!
							Number: nLastStationNo
							Number: nGotInstanceNo
							Number: nGotStationNo
							Number: nInd
							Boolean: bOk
						Actions
							Set nOurGetHandleNo = SqlHandlesGetReferenceNo( 'ResetProgramAllocStationsGet' )
							Set nOurUpdtHandleNo = SqlHandlesGetReferenceNo( 'ResetProgramAllocStationsUpdt' )
							Set nOurDelHandleNo = SqlHandlesGetReferenceNo( 'ResetProgramAllocStationsDel' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT 
											  Instance_No, 
											  Station_No 
											FROM 
											  Prog_Stations 
											WHERE 
											  Program_No = :1 
											ORDER BY 
											  Station_No, 
											  Instance_No "
									Set sName = 'GPRGSTATTRST'
									Set sBind = ':nProgramNo'
									Set sInto = ':nGotInstanceNo, :nGotStationNo'
									Call haSqlHandles[ nOurGetHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurGetHandleNo ].hSqlHandle )
									!
									Set sSql = " UPDATE Prog_Stations 
											SET 
											  Water_Seq_No = :2 
											WHERE 
											  Instance_No = :1 "
									Set sName = 'RSTPRGSEQNO'
									Set sBind = ':nGotInstanceNo, :nSeqNo'
									Set sInto = ''
									Call haSqlHandles[ nOurUpdtHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurUpdtHandleNo ].hSqlHandle )
									!
									Set sSql = " DELETE FROM Prog_Stations 
											WHERE 
											  Instance_No = :1 "
									Set sName = 'DLPRGSTATTRST'
									Set sBind = ':nGotInstanceNo'
									Set sInto = ''
									Call haSqlHandles[ nOurDelHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurDelHandleNo ].hSqlHandle )
									!
									Set nLastStationNo = NUMBER_Null
									Set nGotInstanceNo = NUMBER_Null
									Set nGotStationNo = NUMBER_Null
									Set bOk = TRUE
									!
									If haSqlHandles[ nOurGetHandleNo ].Execute( )
										While haSqlHandles[ nOurGetHandleNo ].FetchNext( nInd ) AND bOk
											If nGotStationNo = nLastStationNo
												If NOT haSqlHandles[ nOurDelHandleNo ].Execute( )
													Set bOk = FALSE
											Else
												Set nLastStationNo = nGotStationNo
												If NOT haSqlHandles[ nOurUpdtHandleNo ].Execute( )
													Set bOk = FALSE
									Else
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Commit
									Set bOk = TRUE
									If NOT haSqlHandles[ nOurDelHandleNo ].Commit( )
										Set bOk = FALSE
									If NOT haSqlHandles[ nOurUpdtHandleNo ].Commit( )
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Rollback
									Set bOk = TRUE
									If NOT haSqlHandles[ nOurDelHandleNo ].Rollback( )
										Set bOk = FALSE
									If NOT haSqlHandles[ nOurUpdtHandleNo ].Rollback( )
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Disconnect
									Set bOk = TRUE
									If NOT haSqlHandles[ nOurGetHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT haSqlHandles[ nOurDelHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT haSqlHandles[ nOurUpdtHandleNo ].Disconnect( )
										Set bOk = FALSE
									Return bOk
					!
					Function: StopProgramPumps
						Description:
						Returns
							Boolean:
						Parameters
							Number: nProgramNo
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							!
							Number: nGotPumpNo
							Number: nGotPumpChannelNo
							String: sGotPumpStatus
							Number: nInd
							Boolean: bOk
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'StopProgramPumps' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT DISTINCT 
											  Station.Pump_No, 
											  Pump.Pump_Status, 
											  Pump.Channel_No 
											FROM 
											  Prog_Stations, 
											  Station, 
											  Pump 
											WHERE 
											  Prog_Stations.Program_No = :1 AND 
											  Prog_Stations.Station_No = Station.Station_No AND 
											  Station.Pump_No = Pump.Pump_No "
									Set sName = 'GSTPPRGPUMP'
									Set sBind = ':nProgramNo'
									Set sInto = ':nGotPumpNo, :sGotPumpStatus, :nGotPumpChannelNo'
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set nGotPumpNo = NUMBER_Null
									Set nGotPumpChannelNo = NUMBER_Null
									Set sGotPumpStatus = ''
									Set bOk = TRUE
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										While haSqlHandles[ nOurHandleNo ].FetchNext( nInd ) AND bOk
											If sGotPumpStatus = 'ON'
												If NOT SetPumpStatus( nGotPumpNo, nGotPumpChannelNo, 'OFF', SH_cls_Execute )
													Set bOk = FALSE
									Else
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Commit
									Set bOk = TRUE
									If NOT SetPumpStatus( 0, 0, '', SH_cls_Commit )
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Rollback
									Set bOk = TRUE
									If NOT SetPumpStatus( 0, 0, '', SH_cls_Rollback )
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Disconnect
									Set bOk = TRUE
									If NOT haSqlHandles[ nOurHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT SetPumpStatus( 0, 0, '', SH_cls_Disconnect )
										Set bOk = FALSE
									Return bOk
					Function: StopOnPumps
						Description:
						Returns
							Boolean:
						Parameters
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							!
							Number: nGotPumpNo
							Number: nGotPumpChannelNo
							String: sGotPumpStatus
							Number: nInd
							Boolean: bOk
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'StopOnPumps' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT DISTINCT 
											  Pump_No, 
											  Pump_Status, 
											  Channel_No 
											FROM 
											  Pump 
											WHERE 
											  Pump_Status = 'ON' "
									Set sName = 'GONPUMPTSTP'
									Set sBind = ''
									Set sInto = ':nGotPumpNo, :sGotPumpStatus, :nGotPumpChannelNo'
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set nGotPumpNo = NUMBER_Null
									Set nGotPumpChannelNo = NUMBER_Null
									Set sGotPumpStatus = ''
									Set bOk = TRUE
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										While haSqlHandles[ nOurHandleNo ].FetchNext( nInd ) AND bOk
											If sGotPumpStatus = 'ON'
												If NOT SetPumpStatus( nGotPumpNo, nGotPumpChannelNo, 'OFF', SH_cls_Execute )
													Set bOk = FALSE
									Else
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Commit
									Set bOk = TRUE
									If NOT SetPumpStatus( 0, 0, '', SH_cls_Commit )
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Rollback
									Set bOk = TRUE
									If NOT SetPumpStatus( 0, 0, '', SH_cls_Rollback )
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Disconnect
									Set bOk = TRUE
									If NOT haSqlHandles[ nOurHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT SetPumpStatus( 0, 0, '', SH_cls_Disconnect )
										Set bOk = FALSE
									Return bOk
					!
					Function: SetProgramStationSeqNo
						Description:
						Returns
							Boolean:
						Parameters
							Number: nInstanceNo
							Number: nProgramNo
							Number: nStationNo
							Number: nSeqNo
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							Boolean: bOk
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SetProgramStationSeqNo' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " UPDATE Prog_Stations 
											SET 
											  Water_Seq_No = :4
											WHERE 
											  Program_No = :1 AND 
											  Station_No = :2 AND 
											  Instance_No = :3 "
									Set sName = 'STPRGSTSEQNO'
									Set sBind = ':nProgramNo, :nStationNo, :nInstanceNo, :nSeqNo'
									Set sInto = ''
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Return haSqlHandles[ nOurHandleNo ].Execute( )
									Return bOk
								Case SH_cls_Commit
									Return haSqlHandles[ nOurHandleNo ].Commit( )
								Case SH_cls_Rollback
									Return haSqlHandles[ nOurHandleNo ].Rollback( )
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					Function: InsertProgStationExtrasNeeded
						Description:
						Returns
							Boolean:
						Parameters
							Number: nProgramNo
							Number: nStationNo
							Number: nCrntWaterSecs
							Number: nWateredSecs
							String: sStationStatus
							Number: nSeqNo
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							!
							Number: nNewInstanceNo
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'InsertProgStationExtrasNeeded' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " INSERT INTO Prog_Stations  
											( Instance_No, Program_No, Station_No, Crnt_Water_Sec, Watered_Sec, Station_Status, Water_Seq_No ) 
											VALUES ( :1, :2, :3, :4, :5, :6, :7 ) "
									Set sName = 'INSPRGSTSXND'
									Set sBind = ':nNewInstanceNo, :nProgramNo, :nStationNo, :nCrntWaterSecs, :nWateredSecs, :sStationStatus, :nSeqNo'
									Set sInto = ''
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Call GetNextInstanceNo( nNewInstanceNo, SH_cls_Execute )
									If nNewInstanceNo > 0
										Return haSqlHandles[ nOurHandleNo ].Execute( )
									Else
										Return FALSE
								Case SH_cls_Commit
									Return haSqlHandles[ nOurHandleNo ].Commit( )
								Case SH_cls_Rollback
									Return haSqlHandles[ nOurHandleNo ].Rollback( )
								Case SH_cls_Disconnect
									Call GetNextInstanceNo( nNewInstanceNo, SH_cls_Disconnect )
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					!
					Function: XCopyProgram
						Description:
						Returns
							Boolean:
						Parameters
							Number: nProgramNo
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nInd
							Boolean: bOk
							Number: nOurGetHandleNo
							Number: nOurInsHandleNo
							!
							Number: nNewProgNo
							Date/Time: dtProgStartDT
							Date/Time: dtProgNextDT
							String: sProgDesc
							Number: nRecurrDays
							String: sProgStatus
						Actions
							Set nOurGetHandleNo = SqlHandlesGetReferenceNo( 'XCopyProgramGetHandle' )
							Set nOurInsHandleNo = SqlHandlesGetReferenceNo( 'XCopyProgramInsHandle' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT 
											  Prog_Start_DT, 
											  Prog_Next_DT, 
											  Prog_Desc, 
											  Recurr_Days, 
											  Prog_Status 
											FROM 
											  Program 
											WHERE 
											  Program_No = :1 "
									Set sName = 'GETCOPYPRG'
									Set sBind = ':nProgramNo'
									Set sInto = ':dtProgStartDT, :dtProgNextDT, :sProgDesc, :nRecurrDays, :sProgStatus'
									Call haSqlHandles[ nOurGetHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurGetHandleNo ].hSqlHandle )
									!
									Set sSql = " INSERT INTO Program  
											( Program_No, Prog_Start_DT, Prog_Next_DT, Prog_Desc, Recurr_Days, Prog_Status ) 
											VALUES ( :1, :2, :3, :4, :5, :6 ) "
									Set sName = 'INSCOPYPRG'
									Set sBind = ':nNewProgNo, :dtProgStartDT, :dtProgNextDT, :sProgDesc, :nRecurrDays, :sProgStatus'
									Set sInto = ''
									Call haSqlHandles[ nOurInsHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurInsHandleNo ].hSqlHandle )
									!
									Set bOk = TRUE
									If haSqlHandles[ nOurGetHandleNo ].Execute( )
										If haSqlHandles[ nOurGetHandleNo ].FetchNext( nInd )
											Call GetNextProgNo( nNewProgNo, SH_cls_Execute )
											If nNewProgNo > 0
												If NOT haSqlHandles[ nOurInsHandleNo ].Execute( )
													Set bOk = FALSE
											Else
												Set bOk = FALSE
										Else
											Set bOk = FALSE
									Else
										Set bOk = FALSE
									!
									If bOk
										If NOT CopyProgStations( nProgramNo, nNewProgNo, SH_cls_Execute )
											Set bOk = FALSE
									If bOk
										If NOT CopyProgSwitches( nProgramNo, nNewProgNo, SH_cls_Execute )
											Set bOk = FALSE
									Return bOk
								Case SH_cls_Commit
									Set bOk = TRUE
									If NOT haSqlHandles[ nOurInsHandleNo ].Commit( )
										Set bOk = FALSE
									If NOT CopyProgSwitches( nProgramNo, nNewProgNo, SH_cls_Commit )
										Set bOk = FALSE
									If NOT CopyProgStations( nProgramNo, nNewProgNo, SH_cls_Commit )
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Rollback
									Set bOk = TRUE
									If NOT haSqlHandles[ nOurInsHandleNo ].Rollback( )
										Set bOk = FALSE
									If NOT CopyProgSwitches( nProgramNo, nNewProgNo, SH_cls_Rollback )
										Set bOk = FALSE
									If NOT CopyProgStations( nProgramNo, nNewProgNo, SH_cls_Rollback )
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Disconnect
									Set bOk = TRUE
									If NOT GetNextProgNo( nNewProgNo, SH_cls_Disconnect )
										Set bOk = FALSE
									If NOT haSqlHandles[ nOurGetHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT haSqlHandles[ nOurInsHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT CopyProgSwitches( nProgramNo, nNewProgNo, SH_cls_Disconnect )
										Set bOk = FALSE
									If NOT CopyProgStations( nProgramNo, nNewProgNo, SH_cls_Disconnect )
										Set bOk = FALSE
									Return bOk
					Function: CopyProgStations
						Description:
						Returns
							Boolean:
						Parameters
							Number: nFromProgramNo
							Number: nToProgramNo
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nInd
							Boolean: bOk
							Number: nOurGetHandleNo
							Number: nOurInsHandleNo
							!
							Number: nNewInstanceNo
							Number: nStationNo
							Number: nCrntWaterSecs
							Number: nWateredSecs
							String: sStationStatus
						Actions
							Set nOurGetHandleNo = SqlHandlesGetReferenceNo( 'CopyProgStationsGetHandle' )
							Set nOurInsHandleNo = SqlHandlesGetReferenceNo( 'CopyProgStationsInsHandle' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT 
											  Station_No, 
											  Crnt_Water_Sec, 
											  Watered_Sec, 
											  Station_Status 
											FROM 
											  Prog_Stations 
											WHERE 
											  Program_No = :1 "
									Set sName = 'GTCOPYPRGSTS'
									Set sBind = ':nFromProgramNo'
									Set sInto = ':nStationNo, :nCrntWaterSecs, :nWateredSecs, :sStationStatus'
									Call haSqlHandles[ nOurGetHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurGetHandleNo ].hSqlHandle )
									!
									Set sSql = " INSERT INTO Prog_Stations  
											( Instance_No, Program_No, Station_No, Crnt_Water_Sec, Watered_Sec, Station_Status ) 
											VALUES ( :1, :2, :3, :4, :5, :6 ) "
									Set sName = 'INSCOPYPRGSTS'
									Set sBind = ':nNewInstanceNo, :nToProgramNo, :nStationNo, :nCrntWaterSecs, :nWateredSecs, :sStationStatus'
									Set sInto = ''
									Call haSqlHandles[ nOurInsHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurInsHandleNo ].hSqlHandle )
									!
									Set bOk = TRUE
									If haSqlHandles[ nOurGetHandleNo ].Execute( )
										While haSqlHandles[ nOurGetHandleNo ].FetchNext( nInd ) AND bOk
											Call GetNextInstanceNo( nNewInstanceNo, SH_cls_Execute )
											If nNewInstanceNo > 0
												If NOT haSqlHandles[ nOurInsHandleNo ].Execute( )
													Set bOk = FALSE
											Else
												Set bOk = FALSE
									Else
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Commit
									Return haSqlHandles[ nOurInsHandleNo ].Commit( )
								Case SH_cls_Rollback
									Return haSqlHandles[ nOurInsHandleNo ].Rollback( )
								Case SH_cls_Disconnect
									Set bOk = TRUE
									If NOT GetNextInstanceNo( nNewInstanceNo, SH_cls_Disconnect )
										Set bOk = FALSE
									If NOT haSqlHandles[ nOurGetHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT haSqlHandles[ nOurInsHandleNo ].Disconnect( )
										Set bOk = FALSE
									Return bOk
					Function: CopyProgSwitches
						Description:
						Returns
							Boolean:
						Parameters
							Number: nFromProgramNo
							Number: nToProgramNo
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nInd
							Boolean: bOk
							Number: nOurGetHandleNo
							Number: nOurInsHandleNo
							!
							Number: nSwitchNo
							String: sValidState
							String: sProgAction
							String: sProgInProgress
						Actions
							Set nOurGetHandleNo = SqlHandlesGetReferenceNo( 'CopyProgSwitchesGetHandle' )
							Set nOurInsHandleNo = SqlHandlesGetReferenceNo( 'CopyProgSwitchesInsHandle' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT 
											  Switch_No, 
											  Valid_State, 
											  Prog_Action, 
											  ProgIn_Progress 
											FROM 
											  Prog_Switches 
											WHERE 
											  Program_No = :1 "
									Set sName = 'GTCOPYPRGSWT'
									Set sBind = ':nFromProgramNo'
									Set sInto = ':nSwitchNo, :sValidState, :sProgAction, :sProgInProgress'
									Call haSqlHandles[ nOurGetHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurGetHandleNo ].hSqlHandle )
									!
									Set sSql = " INSERT INTO Prog_Switches 
											( Program_No, Switch_No, Valid_State, Prog_Action, ProgIn_Progress ) 
											VALUES ( :1, :2, :3, :4, :5 ) "
									Set sName = 'INSCOPYPRGSWT'
									Set sBind = ':nToProgramNo, :nSwitchNo, :sValidState, :sProgAction, :sProgInProgress'
									Set sInto = ''
									Call haSqlHandles[ nOurInsHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurInsHandleNo ].hSqlHandle )
									!
									Set bOk = TRUE
									If haSqlHandles[ nOurGetHandleNo ].Execute( )
										While haSqlHandles[ nOurGetHandleNo ].FetchNext( nInd ) AND bOk
											If NOT haSqlHandles[ nOurInsHandleNo ].Execute( )
												Set bOk = FALSE
									Else
										Set bOk = FALSE
									Return bOk
								Case SH_cls_Commit
									Return haSqlHandles[ nOurInsHandleNo ].Commit( )
								Case SH_cls_Rollback
									Return haSqlHandles[ nOurInsHandleNo ].Rollback( )
								Case SH_cls_Disconnect
									Set bOk = TRUE
									If NOT haSqlHandles[ nOurGetHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT haSqlHandles[ nOurInsHandleNo ].Disconnect( )
										Set bOk = FALSE
									Return bOk
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set hWndChildTable = tblPrograms
						Set bAddAllowed = TRUE
						Set bSaveAllowed = TRUE
						Set bDeleteAllowed = TRUE
						Set bUnDeleteAllowed = TRUE
						Set bClearSelectAllowed = TRUE
						Set bQueryAllowed = FALSE
						Set bRepopulateAllowed = TRUE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = FALSE
						Set bPrintFormAllowed = TRUE
						Set bTreeSystem = FALSE
					On SAM_Create
						Call DIG_Open( )
						Set bRebooting = FALSE
						Set nTimeCheckCount = 0
						Set nCheckEveryNSeconds = SalStrToNumber( OurGetIniFileParameter( 'GENERAL', 'TimerCheckInterval', '10' ) )
						Set nMinSecondsBetweenProgs = SalStrToNumber( OurGetIniFileParameter( 'GENERAL', 'MinSecondsBetweenPrograms', '3' ) )
						Set sRebootHour = OurGetIniFileParameter( 'GENERAL', 'RebootHour', '23' )
						If sRebootHour = ''
							Set nRebootHour = NUMBER_Null
						Else
							Set nRebootHour = SalStrToNumber( sRebootHour )
						If NOT GetWateringActiveState( bRunning )
							Set bRunning = TRUE
						Call GetLastRebootDateTime( dtLastRebootDT )
						Call InitialiseIOCard( 'INIT', SH_cls_Execute )
						Call SalTimerSet( hWndForm, 1, 1000 )
						Return SalSendClassMessage( SAM_Create, wParam, lParam )
					On SAM_Destroy
						If NOT bRebooting
							Call SalSendMsg( hWndForm, PAM_clsWATERING_DESTROY, wParam, lParam )
						Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
					On PAM_clsWATERING_DESTROY
						Call DIG_Close( )
						Call SalTimerKill( hWndForm, 1 )
						Call TimeCheckIrrigation( 0, 0, SH_cls_Disconnect )
						Call InitialiseIOCard( '', SH_cls_Disconnect )
						Call LogMaintenance( 0, '', '', 'DISCONNECT' )
						Call SetProgramStatus( 0, '', SH_cls_Disconnect )
						Call SetProgramNextDT( 0, DATETIME_Null, SH_cls_Disconnect )
						Call StopProgramPumps( 0, SH_cls_Disconnect )
						Call StopOnPumps( SH_cls_Disconnect )
						Call XCopyProgram( 0, SH_cls_Disconnect )
					On SAM_Timer
						If NOT bRebooting
							If NOT nRebootHour = NUMBER_Null
								If dtLastRebootDT = DATETIME_Null
									Set bContReboot = TRUE
								Else
									If SalDateConstruct( SalDateYear( dtLastRebootDT ), SalDateMonth( dtLastRebootDT ), SalDateDay( dtLastRebootDT ), 0, 0, 0 ) = 
											SalDateConstruct( SalDateYear( SalDateCurrent(  ) ), SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 0, 0, 0 )
										Set bContReboot = FALSE
									Else
										Set bContReboot = TRUE
								If nRebootHour = SalDateHour( SalDateCurrent(  ) ) AND bContReboot
									Set bRebooting = TRUE
									Call SetLastRebootDateTime( SalDateCurrent(  ) )
									Call LogMaintenance( 0, 'REBOOT', 'Rebooting at '||DateToStrX( SalDateCurrent(  ) ), 'APPEND' )
									Call SalSendMsg( hWndForm, PAM_clsWATERING_DESTROY, wParam, lParam )
									Call SqlHandlesDisconnectClose(  )
									Call SalPostMsg( hWndForm, PAM_clsWATERING_REBOOT, 0, 0 )
							If bRunning AND NOT bRebooting
								Set dfClock = SalDateCurrent(  )
								Set nTimeCheckCount = nTimeCheckCount + 1
								If nTimeCheckCount >= nCheckEveryNSeconds
									Set nTimeCheckCount = 0
									Call OurWaitCursor( TRUE )
									Call TimeCheckIrrigation( nCheckEveryNSeconds, nMinSecondsBetweenProgs, SH_cls_Execute )
									Call SalSendMsg( hWndForm, PAM_clsWATERING_REFRESHDATA, 0, 0 )
									Call OurWaitCursor( FALSE )
					On SAM_Close
						If bRunning
							Call SalMessageBox( 'Please stop the watering system before exiting the program.', 'NOTE', MB_Ok )
							Return TRUE
						Else
							Return SalSendClassMessage( SAM_Close, wParam, lParam )
					On PAM_cls_CLOSE
						If bRunning
							Call SalMessageBox( 'Please stop the watering system before exiting the program.', 'NOTE', MB_Ok )
							Return TRUE
						Else
							Return SalSendClassMessage( PAM_cls_CLOSE, wParam, lParam )
					On PAM_clsWATERING_REFRESHDATA
						If cbAutoRefreshScreen
							! Call SalSendMsg( tblProgStations, PAM_clsTBL_POPULATE, 0, 0 )
							Call SalSendMsg( tblPrograms, PAM_clsTBL_POPULATE, 0, 0 )
					On PAM_clsTBL_USERACTIONS
						If bRunning
							If wParam = TBL_cls_RePopTable OR wParam = TBL_cls_OrderTable OR wParam = TBL_cls_ClearRow OR wParam = TBL_cls_ZoomTable
								If lParam = GEN_CommingFromPopUp AND NOT hWndFocus = hWndNULL
									Return UserTableActions( hWndFocus, wParam, lParam )
								Else
									If SalModalDialog( dlgTableChoice, hWndForm, sTableChoice )
										If sTableChoice = 'PROGRAMS'
											Return SalSendClassMessage( PAM_clsTBL_USERACTIONS, wParam, lParam )
										Else
											Return UserTableActions( tblProgStations, wParam, lParam )
									Else
										Return FALSE
							Else
								Call SalMessageBox( 'Please stop the watering system before carring out any maintenance.', 'NOTE', MB_Ok )
								Return TRUE
						Else
							If lParam = GEN_CommingFromPopUp AND NOT hWndFocus = hWndNULL
								Return UserTableActions( hWndFocus, wParam, lParam )
							Else
								If SalModalDialog( dlgTableChoice, hWndForm, sTableChoice )
									If sTableChoice = 'PROGRAMS'
										Return SalSendClassMessage( PAM_clsTBL_USERACTIONS, wParam, lParam )
									Else
										Return UserTableActions( tblProgStations, wParam, lParam )
								Else
									Return FALSE
					On PAM_clsWATERING_REBOOT
						Return ExitWindowsEx( EWX_FORCE | EWX_REBOOT, 0 )
					On PAM_cls_REFRESHAFTRCHILDCHANGE
						Set sChildButtonChanged = SalNumberToHString( lParam )
						! pb18 is included as centuras bug.  When instance of clspbProgSwitches is dropped it 
								assigns instance pb18 then when you rename it pbProgSwitches while running it 
								still has pb18 as its name and not pbProgSwitches.
						If sChildButtonChanged = 'pbProgSwitches' OR sChildButtonChanged = 'pb18'
							Return FALSE
						Else
							Return TRUE
			!

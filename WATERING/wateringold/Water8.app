					                                            String: sProgStatus
				                                            Functions 
					                                            Function: GetProgramOverrideDets
						                                            Description: 
						                                            Returns 
							                                            Boolean: 
						                                            Parameters 
							                                            Number: nProgramNo
							                                            Receive String: sProgStatus
							                                            Number: nActionType
						                                            Static Variables 
							                                            : fcOurHandle
						                                            Local variables 
							                                            String: sSql
							                                            String: sBind
							                                            String: sInto
							                                            String: sName
							                                            Number: nInd
							!
							                                            String: sGotProgStatus
						                                            Actions 
							                                            Select Case nActionType
								                                            Case SH_cls_Execute
									                                            Set sSql = " SELECT 
											  Prog_Status 
											FROM 
											  Program  
											WHERE 
											  Program_No = :1 "
									                                            Set sName = 'GTPROGOVRDTS'
									                                            Set sBind = ':nProgramNo'
									                                            Set sInto = ':sGotProgStatus'
									                                            Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
									                                            Call SqlVarSetup( fcOurHandle.hSqlHandle )
									!
									                                            Set sGotProgStatus = ''
									                                            Set sProgStatus = ''
									!
									                                            If fcOurHandle.Execute( )
										                                            If fcOurHandle.FetchNext( nInd )
											                                            Set sProgStatus = sGotProgStatus
										                                            Return TRUE
									                                            Else 
										                                            Return FALSE
								                                            Case SH_cls_Disconnect
									                                            Return fcOurHandle.Disconnect( )

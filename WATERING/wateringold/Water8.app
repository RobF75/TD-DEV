											Return FALSE
										Else
											Return TRUE
									On PAM_clsTBL_CHECKROWNEW
										Call CheckChannelExists( MyValue, bExists, SH_cls_Disconnect )
										If bExists
											Call ErrorMessage( 'Channel is already in use.  Cannot add.', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE

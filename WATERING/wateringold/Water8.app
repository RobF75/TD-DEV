							                                            String: sBind
							                                            String: sInto
							                                            String: sName
						                                            Actions 
							                                            Select Case nActionType
								                                            Case SH_cls_Execute
									                                            Set sSql = " UPDATE Program  
											SET 
											  Prog_NextDueDT = :2
											WHERE Program_No = :1 "
									                                            Set sName = 'SETPRGDUENXT'
									                                            Set sBind = ':nProgramNo, :dtDueNextDT'
									                                            Set sInto = ''
									                                            Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
									                                            Call SqlVarSetup( fcOurHandle.hSqlHandle )
									!
									                                            Return fcOurHandle.Execute( )
								                                            Case SH_cls_Commit
									                                            Return fcOurHandle.Commit( )
								                                            Case SH_cls_Rollback
									                                            Return fcOurHandle.Rollback( )
								                                            Case SH_cls_Disconnect
									                                            Return fcOurHandle.Disconnect( )
				                                            Message Actions 
					                                            On PAM_cls_SETINSTANCEVARS
						                                            Set bTreeSystem = FALSE
					                                            On PAM_clsDLG_POPFIELDS
						                                            Call PopNumber( nProgNo, FALSE )
						                                            Call PopDateTime( dfProgStartTime, FALSE )
						                                            Call PopString( dfProgDescription, FALSE )
						                                            Call PopNumber( bRunning, FALSE )
						                                            Call PopWndHdl( hWndActivateButton, TRUE )
						                                            Return TRUE
					                                            On PAM_clsPB_OKACTION
						                                            Call GetProgramOverrideDets( nProgNo, sProgStatus, SH_cls_Execute )
						                                            If bRunning
							                                            Call SalMessageBox( 'Please stop the watering system before carring out any maintenance.', 'NOTE', MB_Ok )
						                                            Else 
							                                            If SetProgramDueNext( nProgNo, SalDateCurrent(  ), SH_cls_Execute )
								                                            If SetProgramStatus( nProgNo, 'WAITING', SH_cls_Execute )
									                                            If ResetProgramPumps( nProgNo, 'OFF', SH_cls_Execute )
										                                            If ResetProgramStations( nProgNo, 'WAITING', SH_cls_Execute )
											                                            Call ResetProgramStations( 0, '', SH_cls_Commit )
											                                            Call SetProgramStatus( 0, '', SH_cls_Commit )
											                                            Call SetProgramDueNext( 0, DATETIME_Null, SH_cls_Commit )
											                                            Call ResetProgramPumps( 0, '', SH_cls_Commit )
										                                            Else 
											                                            Call SetProgramStatus( 0, '', SH_cls_Rollback )
											                                            Call SetProgramDueNext( 0, DATETIME_Null, SH_cls_Rollback )
											                                            Call ResetProgramPumps( 0, '', SH_cls_Rollback )
									                                            Else 
										                                            Call SetProgramStatus( 0, '', SH_cls_Rollback )
										                                            Call SetProgramDueNext( 0, DATETIME_Null, SH_cls_Rollback )
						                                            Return SalSendMsg( pbExit, SAM_Click, TRUE, 0 )
					                                            On SAM_Destroy
						                                            Call GetProgramOverrideDets( 0, sProgStatus, SH_cls_Disconnect )
						                                            Call SetProgramDueNext( 0, DATETIME_Null, SH_cls_Disconnect )
						                                            Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
			!
			!

									On PAM_clsTBL_DATAVAL
										Set colProgStartDT = SalDateConstruct( SalDateYear( SalDateCurrent(  ) ), SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 
												SalDateHour( colProgStartTime ), SalDateMinute( colProgStartTime ), SalDateSecond( colProgStartTime ) )
										If CompareTime( colProgStartDT, SalDateCurrent( ) ) > 0
											Set colProgNextDT = colProgStartDT
										Else
											Set colProgNextDT = colProgStartDT + colProgRecurrDays
										Return TRUE
									On PAM_clsTBL_ROWNEWINIT
										Set colProgStartDT = SalDateCurrent(  )

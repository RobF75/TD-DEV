.head 2 +  Message Actions
.head 3 +  On SAM_CreateComplete
.head 4 -  Call SalTimerSet( hWndForm, 1, 1000000 )
.head 4 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 3 +  On SAM_Timer
.head 4 -  Set dfCurrentHour = SalDateHour( SalDateCurrent(  ) )
.head 4 -  Call GetRegistryValue( 'GENERAL', 'CheckTimer', sRecordedHour, '' ) 
.head 4 -  ! Set nRecordedHour = sRecordedHour
.head 4 -  Set dfRecordedHour = SalStrToNumber( sRecordedHour )
.head 4 +  If dfCurrentHour != dfRecordedHour
.head 5 -  ! Call SalMessageBox('different times', 'different times', MB_Ok)
.head 5 -  Set nMinute = SalDateMinute( SalDateCurrent(  ) )
.head 5 +  If nMinute > 20
.head 6 -  Call SMTPSend( 'graham@flemings.com.au,g_flemo@hotmail.com', '', '', 'Automated', 'automated@flemings.com.au', 'Watering Monitor', 'The WATERING MONITOR has discovered a problem, and is rebooting the computer.
Current Hour: ' || SalNumberToStrX( dfCurrentHour, 0 ) || '. Recorded Hour: ' || SalNumberToStrX( dfRecordedHour, 0 ), '', '192.168.42.4', 25 )
.head 6 -  Call LogMaintenance( 'LOG', 0, '', '', 'OPEN' )
.head 6 -  Call LogMaintenance( 'LOG', 0, 'Monitor REBOOT', 'Rebooting at '||DateToStrX( SalDateCurrent(  ) ), 'APPEND' )
.head 6 -  Call LogMaintenance( 'LOG', 0, '', '', 'CLOSE' )
.head 6 -  Call SalTimerKill( hWndForm, 1 )
.head 6 -  Call SetLastRebootDateTime( SalDateCurrent( ) )
.head 6 -  Call SalLoadApp( 'shutdown.exe', '/L /R /Y /C' )
.head 6 -  Call SalLoadApp( 'shutdown', '-r -f' )

  INTO 
  :frmPrintItemRoyPayReport.dfItemNo, 
  :frmPrintItemRoyPayReport.dfTreeType,
  :frmPrintItemRoyPayReport.dfCultDesc,
  :frmPrintItemRoyPayReport.dfRootId,
 :frmPrintItemRoyPayReport.dfCvNPA,
 :frmPrintItemRoyPayReport.dfRtNPA
 ORDER BY Stock_item.Variety_Type, Stock_item.Variety, Stock_item.Cult_Desc, Rootstock_Id, Tree_Type '
.head 6 -  ! Set sSql = ' SELECT 
  Item_No, 
  Tree_Type,
  Cult_Desc,
  Rootstock_Id
  FROM 
    Stock_Item, Cultivar
  INTO 
  :frmPrintItemRoyPayReport.dfItemNo, 
  :frmPrintItemRoyPayReport.dfTreeType,
  :frmPrintItemRoyPayReport.dfCultDesc,
  :frmPrintItemRoyPayReport.dfRootId
WHERE 
  Stock_Item.Cultivar_Id = Cultivar.Cult_Id(+) 
ORDER BY Variety_Type, Variety, Cult_Desc, Rootstock_Id, Tree_Type '

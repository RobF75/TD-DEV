.head 6 -  ! Set sSQLWHERE = "  WHERE (subs_item_no = :frmPrintItemRoyPayReport.dfItemNo OR 
  stock_item_no = :frmPrintItemRoyPayReport.dfItemNo) and
  year_of_sale = :frmPrintItemRoyPayReport.dfYear AND 
  invoiced_flag = 'Y' and 
  conf_amt > 0 and
  not sale_cat in ('RP','FC') and
  customer_order.cust_no = transaction.cust_no and
  invoice_no = reference_Id
GROUP BY invoice_no, customer_order.cust_no, royalties "
.head 6 -  Set sSQLWHERE = " WHERE stock_item_no = :frmPrintItemRoyPayReport.dfItemNo AND 
  year_of_sale = :frmPrintItemRoyPayReport.dfYear AND 
  invoiced_flag = 'Y' and 
  conf_amt > 0 and
  not sale_cat in ('RP','FC') and
  customer_order.cust_no = transaction.cust_no and
  @String(invoice_no,0) = reference_Id
GROUP BY invoice_no, customer_order.cust_no, royalties "

.head 7 +  If dfItemNo > 0
.head 8 +  If dfCvNPA = 'Y' OR dfRtNPA = 'Y'
.head 9 -  Set nNextAction = nProcess
.head 8 +  Else
.head 9 -  Set nNextAction = nSkip

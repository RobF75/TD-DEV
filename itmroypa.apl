.head 6 -  Set sSql = ' SELECT 
  Item_No, 
  Tree_Type,
  Stock_item.Cult_Desc,
  Rootstock_Id,
 Stock_item.CV_Non_Prop_Flag,
 Stock_Item.RT_Non_Prop_Flag 
  FROM 

.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Set hWndPickIntoTable = hWndItem
.head 6 -  Call SalSendClassMessage( SAM_Create, wParam, lParam )
.head 6 -  Set clspbPickPurchOrd.nActivateWindowType = ACTIVATE_MDIFormChild
.head 6 -  Set clspbPickPurchOrd.sActivateDialogName = 'mdiMain.frmPurchOrd'
.head 6 -  Set clspbPickPurchOrd.hWndTable = hWndPickIntoTable
.head 6 -  Set clspbPickPurchOrd.hWndFieldLookUp = hWndItem
.head 6 -  ! Call SalHideWindow( hWndItem )
.head 5 +  On PAM_clsACTIVATE_PUSHFIELDS
.head 6 -  Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
.head 6 -  Call PushString( sPurchOrdNo )
.head 6 -  Call PushString( sCredName )
.head 6 -  Call PushNumber( nCredNo )
.head 6 -  Call PushWndHdl( hWndItem )
.head 6 -  Return TRUE
.head 5 +  On PAM_clsPICK_LOOKUP
.head 6 -  Call PopString( sCredName, TRUE )
.head 6 -  Call PopString( sPurchOrdNo, TRUE )
.head 6 -  Call PopNumber( nCredNo, TRUE )
.head 6 -  Call SalSendMsg( hWndItem, PAM_cls_GETFIELDS, 0, 0 )
.head 6 -  Return TRUE
.head 5 +  On PAM_clsACTIVATE_POPFIELDS
.head 6 -  Call PopWndHdl( hWndTmp, TRUE )
.head 6 -  Call PopString( sTmp, TRUE )
.head 6 -  Call PopString( sTmp, TRUE )
.head 6 -  Call PopNumber( nTmp, TRUE )
.head 6 -  Return TRUE
.head 5 +  On PAM_cls_PARENTACTIVATE
.head 6 -  ! this message is being sent when the window activation where this pb relates to - wParam is the activation status
.head 6 +  If wParam
.head 7 -  Call SalShowWindow( hWndItem )
.head 6 +  Else
.head 7 -  Call SalHideWindow( hWndItem )

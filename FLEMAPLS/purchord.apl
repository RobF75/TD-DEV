.head 8 +  Local variables
.head 9 -  String: sSql
.head 9 -  String: sName
.head 9 -  String: sBind
.head 9 -  String: sInto
.head 9 -  Number: nSqlHandleNo
.head 9 -  Number: nInd
.head 9 -  String: sGotIssuedTo
.head 8 +  Actions
.head 9 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetPurchOrdUser' )
.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set sSql = " SELECT
Issued_To
FROM
Purch_Order_Books
WHERE
  Beginning_Order_No <= :1  order by Beginning_Order_No DESC"
.head 11 -  Set sName = 'POrdUser'
.head 11 -  Set sBind = ':sPONo'
.head 11 -  Set sInto = ':sGotIssuedTo'
.head 11 -  ! !
.head 11 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 11 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 11 -  !
.head 11 -  Set sGotIssuedTo = ''
.head 11 +  If haSqlHandles[nSqlHandleNo ].Execute( )
.head 12 +  If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 13 -  !
.head 13 -  Set sIssuedTo = sGotIssuedTo
.head 12 -  Return TRUE
.head 11 +  Else
.head 12 -  Return FALSE
.head 10 +  Case SH_cls_Disconnect
.head 11 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 11 -  Return TRUE

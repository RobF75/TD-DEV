.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sSQLPopHandle = " SELECT  
  Stock_Labels.Label_Id, 
  Labels.Label_Desc, 
  Stock_Labels.Stock_Label_Use 
FROM   
  Stock_Labels, Labels   
WHERE 
  Stock_Labels.Stock_Item_No = :1 AND 
  Stock_Labels.Label_Id = Labels.Label_Id "
.head 6 -  Set sNAMEPopHandle = 'POPPRSTCKLBLS'
.head 6 -  Set sBINDPopHandle = ':hWndParent.nItemNo'
.head 6 -  Set sINTOPopHandle = ':hWndForm.colLabelId, :hWndForm.colLabelDesc, :hWndForm.colLabelUse'
.head 6 -  !
.head 6 -  Set sSQLRefreshHandle = " SELECT  
  Stock_Labels.Label_Id, 
  Labels.Label_Desc, 
  Stock_Labels.Stock_Label_Use 
FROM   
  Stock_Labels, Labels   
WHERE 
  Stock_Labels.Stock_Item_No = :1 AND 
  Stock_Labels.Label_Id = :2 AND 
  Stock_Labels.Label_Id = Labels.Label_Id "
.head 6 -  Set sNAMERefreshHandle = 'REFPRSTCKLBLS'
.head 6 -  Set sBINDRefreshHandle = ':hWndParent.nItemNo, :hWndForm.colLabelId'
.head 6 -  Set sINTORefreshHandle = ':hWndForm.colLabelId, :hWndForm.colLabelDesc, :hWndForm.colLabelUse'
.head 6 -  !

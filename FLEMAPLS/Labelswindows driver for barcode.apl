.head 7 -  Call haSqlHandles[ nOurHandleNo ].RePrepare( )
.head 7 -  Call haSqlHandles[ nOurHandleNo ].PrepareSetup( sSql )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set sFieldValue = ''
.head 7 -  Set sGotFieldValue = ''
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].PrepareAndExecute( )
.head 8 -  Call haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 8 +  If nOffSet > 0
.head 9 -  Set sPrioSpacesString = ''
.head 9 -  Call SalStrRepeat( ' ', nOffSet, sPrioSpacesString )
.head 9 -  Set sGotFieldValue = sPrioSpacesString || sGotFieldValue
.head 8 +  If bNumber
.head 9 -  Set sGotFieldValue = SalNumberToStrX( nGotFieldValue, 0 )
.head 8 -  Set sFieldValue = sGotFieldValue
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 3 +  Function: ReplaceAtCharToRegisteredChar
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Receive String: sFormatString
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sRegisteredMark
.head 4 +  Actions
.head 5 -  Set sRegisteredMark = ' '
.head 5 -  ! Call CStructPutByte( sRegisteredMark, 0, 169 )
.head 5 -  Set sRegisteredMark = SalNumberToChar( 169 )
.head 5 -  !

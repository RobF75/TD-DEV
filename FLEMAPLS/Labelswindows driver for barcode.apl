.head 8 +  Else If sDataDesc = 'CULTIVAR.CV_LABEL_LINE_3'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||', CV_LL3_OFFSET '||' 
FROM Stock_Item, Cultivar 

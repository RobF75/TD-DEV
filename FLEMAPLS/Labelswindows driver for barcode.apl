.head 2 +  Named Menus
.head 2 +  Internal Functions
.head 3 +  Function: PrintLabels
.head 4 -  Description: Given a stock item no, label Id and how many labels this prints labels to the bar code printer
on the com port
hWndTable is the handle that will receive the PAM_clsLABELS_GETFIELDDATA message with the
wParam as nItemNo and lParam as HString ( use SalNumberToHString to extract the string )
  To Return a value alway Call PushString( ... ) If number comvert to string and MUST 
  RETURN TRUE
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nItemNo
.head 5 -  String: sLabelId
.head 5 -  Number: nHowMany
.head 5 -  Number: nLocId
.head 5 -  Window Handle: hWndTable
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sTmpFileName
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  ! Set sTmpFileName = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'C:\\TEMP' ) || '\\label.tmp'
.head 7 -  Set sTmpFileName = GetNextBCQueueFileName(  )
.head 7 -  Call GenerateLabelFile( 0, '', nItemNo, sLabelId, nHowMany, nLocId, hWndTable, sTmpFileName, 'CREATE/OVERWRITE', SH_cls_Execute )
.head 7 -  ! Call OutputLabelFile( sTmpFileName )
.head 7 -  Return TRUE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return GenerateLabelFile( 0, '', 0, '', 0, 0, hWndNULL, '', '', SH_cls_Disconnect )
.head 3 +  Function: GetNextBCQueueFileName
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  String:
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nNumQueueFiles
.head 5 -  String: sQueuePath
.head 5 -  String: saQueuelFiles[*]
.head 5 -  Number: naQueueSizes[*]
.head 5 -  Date/Time: dtaQueueTimeStamps[*]
.head 5 -  Number: naQueueAttributes[*]
.head 4 +  Actions
.head 5 -  Set sQueuePath = OurGetIniFileParameter( 'GENERAL', 'BCLabelsPath', 'C:\\TEMP' )
.head 5 -  Set nNumQueueFiles = VisDosEnumFileInfo( sQueuePath || '\\*.bcl', FA_Standard, saQueuelFiles, naQueueSizes, dtaQueueTimeStamps, naQueueAttributes )
.head 5 +  If nNumQueueFiles < 0
.head 6 -  Set nNumQueueFiles = 0
.head 5 -  Return sQueuePath||'\\'||SalStrRightX( SqlUser, 3 )||SalNumberToStrX( nNumQueueFiles+1, 0 )||'.bcl'
.head 3 +  Function: PrintStockItemsLabels
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  String: sCustName
.head 5 -  ! naItemNos is a NUMBER_Null terminated array and naQuantities is also and must match the positioning
  of naItemNos with the quantites
.head 5 -  Number: naItemNos[*]
.head 5 -  Number: naQuantities[*]
.head 5 -  ! sLabelUse = 'FC' or 'HG' or 'BC'
.head 5 -  String: sLabelUse
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sLabelFile
.head 5 -  !
.head 5 -  Number: nPos
.head 5 -  Boolean: bFirst
.head 5 -  Boolean: bNoLabelId
.head 5 -  !
.head 5 -  String: sLabelId
.head 5 -  Number: nTotalCount
.head 5 -  FunctionalVar: fcMeter
.head 6 -  Class: clsMeterBar
.head 5 -  !
.head 5 -  String: sShortCustName
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  ! Set sLabelFile = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'C:\\TEMP' ) || '\\label.tmp'
.head 7 -  Set sLabelFile = GetNextBCQueueFileName(  )
.head 7 -  !
.head 7 -  Set nPos = 0
.head 7 +  While naItemNos[ nPos ] != NUMBER_Null
.head 8 -  Set nPos = nPos + 1
.head 7 -  Set nTotalCount = nPos
.head 7 -  !
.head 7 -  Call fcMeter.Setup( 'Generating Labels', nTotalCount )
.head 7 -  !
.head 7 -  Set bNoLabelId = FALSE
.head 7 -  Set bFirst = TRUE
.head 7 -  Set nPos = 0
.head 7 +  While naItemNos[ nPos ] != NUMBER_Null
.head 8 -  Call GetStockItemLabelIdForUse( naItemNos[ nPos ], sLabelUse, sLabelId, SH_cls_Execute )
.head 8 -  !
.head 8 +  If sLabelId = ''
.head 9 -  Set bNoLabelId = TRUE
.head 8 +  Else
.head 9 +  If bFirst
.head 10 +  If sLabelUse = 'BC'
.head 11 +  If SalStrLength( sCustName ) > 33
.head 12 -  Set sShortCustName = SalStrLeftX( sCustName, 33 )
.head 11 +  Else

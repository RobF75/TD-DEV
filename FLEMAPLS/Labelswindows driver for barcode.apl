.head 3 +    On PAM_cls_SETINSTANCEVARS
.head 4 -    Set sReportFileNameNoPath = 'barcode.qrp'
.head 4 -    Set sReportBind = ':frmPrintBarcodeLabels.sInputLine'
.head 4 -    Set sReportInto = 'sInputLine'
.head 3 +    On SAM_ReportStart
.head 4 -    Return SalFileOpen( hOutFile, sLabelFile, OF_Read | OF_Binary )
.head 3 +    On SAM_ReportFetchInit
.head 4 -    Call SalFileSeek( hOutFile, 0, FILE_SeekEnd )
.head 4 -    Set nFileSize = SalFileTell( hOutFile )
.head 4 -    Call SalFileSeek( hOutFile, 0, FILE_SeekBegin )
.head 4 -  !
.head 4 -    Set nLength = 100
.head 4 -    Set nTotalBytesRead = 0
.head 4 -    Return TRUE
.head 3 +    On SAM_ReportFetchNext
.head 4 +    If nTotalBytesRead < nFileSize
.head 5 -    Set nBytesRead = SalFileRead( hOutFile, sInputLine, nLength )
.head 5 -    Set nTotalBytesRead = nTotalBytesRead + nBytesRead
.head 5 -    Return TRUE
.head 4 +    Else 
.head 5 -    Return FALSE
.head 3 +    On SAM_ReportFinish
.head 4 -    Call SalFileClose( hOutFile )
.head 4 -    Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )

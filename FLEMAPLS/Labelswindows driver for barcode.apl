.head 9 -  Set sSql = 'SELECT Cult_Desc 
FROM Stock_Item 
INTO :sGotFieldValue 
WHERE 
  Stock_Item.Item_No = :nItemNo '
.head 8 +  Else
.head 9 -  Set sSql = 'SELECT '||sDataDesc||
' FROM Stock_Item, Cultivar 
INTO :sGotFieldValue 
WHERE 

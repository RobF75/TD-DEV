.head 8 +  Else If sDataDesc = 'CULTIVAR.VARIETY'
.head 9 -  Set sSql = 'SELECT Variety 
FROM Stock_Item 
INTO :sGotFieldValue 
WHERE 
  Stock_Item.Item_No = :nItemNo '

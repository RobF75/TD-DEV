.head 8 +  Else If sDataDesc = 'ROOTSTOCK.RT_LABEL_LINE_5'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||', RT_LL5_OFFSET '||' 
FROM Stock_Item, Rootstock 

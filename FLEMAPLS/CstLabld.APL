.head 10 +  If nCount > 1
.head 11 -  Call ErrorMessage( 'This same CstLblation already exists for this customer! Please rectify!', hWndForm, lParam )
.head 11 -  Return FALSE
.head 10 +  Else
.head 11 -  Return TRUE

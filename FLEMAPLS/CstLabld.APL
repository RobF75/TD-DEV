.head 10 -  Call CountSpecificCstLblas( colCstLblCustNo, colCstLblItemNo, colCstLblYearOfSale, nCount, SH_cls_Execute )
.head 10 +  If nCount > 0
.head 11 -  Call ErrorMessage( 'This same CstLblation already exists for this customer! Please rectify!', hWndForm, lParam )
.head 11 -  Return FALSE
.head 10 +  Else
.head 11 -  Return TRUE
.head 9 +  On PAM_clsTBL_CHECKROWEDITED

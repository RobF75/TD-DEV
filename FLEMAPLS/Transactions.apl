.head 2 +  Named Menus
.head 2 +  Internal Functions
.head 3 +  Function: AgeTrans
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Date/Time: dtTransDate
.head 5 -  Number: nTransAmount
.head 5 -  Receive Number: n0to30
.head 5 -  Receive Number: n31to60
.head 5 -  Receive Number: n61to90
.head 5 -  Receive Number: n90plus
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sPeriod
.head 4 +  Actions
.head 5 -  Set sPeriod = WhichPayPeriod( dtTransDate, SalDateCurrent() )
.head 5 -  !
.head 5 +  If sPeriod = '0-30'
.head 6 -  Set n0to30 = nTransAmount
.head 6 -  Set n31to60 = 0
.head 6 -  Set n61to90 = 0
.head 6 -  Set n90plus = 0
.head 5 +  Else If sPeriod = '31-60'
.head 6 -  Set n0to30 = 0
.head 6 -  Set n31to60 = nTransAmount
.head 6 -  Set n61to90 = 0
.head 6 -  Set n90plus = 0
.head 5 +  Else If sPeriod = '61-90'
.head 6 -  Set n0to30 = 0
.head 6 -  Set n31to60 = 0
.head 6 -  Set n61to90 = nTransAmount
.head 6 -  Set n90plus = 0
.head 5 +  Else
.head 6 -  Set n0to30 = 0
.head 6 -  Set n31to60 = 0
.head 6 -  Set n61to90 = 0
.head 6 -  Set n90plus = nTransAmount
.head 5 -  Return TRUE
.head 3 +  Function: ExtractTransactions
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Receive Number: nCurr
.head 5 -  Receive Number: n30
.head 5 -  Receive Number: n60
.head 5 -  Receive Number: n90
.head 5 -  String: sCompany
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSqlHandle
.head 5 -  String: sBindHandle
.head 5 -  String: sIntoHandle
.head 5 -  String: sNameHandle
.head 5 -  Number: nOurHandleNo
.head 5 -  Number: nInd
.head 5 -  !
.head 5 -  Number: nTransAmt
.head 5 -  Date/Time: dtTransDate
.head 5 -  Number: nCurrent
.head 5 -  Number: n30_60
.head 5 -  Number: n60_90
.head 5 -  Number: n90Plus
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETCUSTTRANSAGE' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSqlHandle = " SELECT
	Trans_Amount_Outst,	
	Transaction_Date
FROM
  	Transaction
WHERE
	Cust_No = :1 and
	Transaction_Type = 'INVOICE' and
	Company = :2"
.head 7 -  Set sNameHandle = 'GETCUSTTRANSAGE'
.head 7 -  Set sBindHandle = ':nCustNo, :sCompany'
.head 7 -  Set sIntoHandle = ':nTransAmt, :dtTransDate'
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSqlHandle, sNameHandle, sBindHandle, sIntoHandle )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 -  Call AgeTrans(dtTransDate, nTransAmt, nCurrent, n30_60, n60_90, n90Plus )
.head 9 -  Set nCurr = nCurr + nCurrent
.head 9 -  Set n30 = n30 + n30_60
.head 9 -  Set n60 = n60 + n60_90
.head 9 -  Set n90 = n90 + n90Plus
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 3 +  Function: WhichPayPeriod
.head 4 -  Description: returns 0-30, 31-60, 61-90 or 91+ depending which
term the transaction date given falls in.
.head 4 +  Returns
.head 5 -  String:
.head 4 +  Parameters
.head 5 -  Date/Time: dtTransDate
.head 5 -  Date/Time: dtCurrentDate
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nDaysOutstanding
.head 5 -  Number: n0to30Days
.head 5 -  Number: n31to60Days
.head 5 -  Number: n61to90Days
.head 5 -  Date/Time: dt0to30MonthBeg
.head 5 -  Date/Time: dt31to60MonthBeg
.head 5 -  Date/Time: dt61to90MonthBeg
.head 4 +  Actions
.head 5 -  Set dt0to30MonthBeg = SalDateMonthBegin( dtCurrentDate )
.head 5 -  Set dt31to60MonthBeg = SalDateMonthBegin( dt0to30MonthBeg - 1 )
.head 5 -  Set dt61to90MonthBeg = SalDateMonthBegin( dt31to60MonthBeg - 1 )
.head 5 -  !
.head 5 -  Set n0to30Days = dtCurrentDate - dt0to30MonthBeg
.head 5 -  Set n31to60Days = dtCurrentDate - dt31to60MonthBeg
.head 5 -  Set n61to90Days = dtCurrentDate - dt61to90MonthBeg
.head 5 -  !
.head 5 -  Set nDaysOutstanding = dtCurrentDate - dtTransDate
.head 5 +  If nDaysOutstanding <= n0to30Days
.head 6 -  Return '0-30'
.head 5 +  Else If nDaysOutstanding <= n31to60Days
.head 6 -  Return '31-60'
.head 5 +  Else If nDaysOutstanding <= n61to90Days
.head 6 -  Return '61-90'
.head 5 +  Else
.head 6 -  Return '91+'

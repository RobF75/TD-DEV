.head 5 +  Message Actions
.head 6 +  On PAM_clsPB_CLICK
.head 7 +  If SqlDatabase = 'STOCK'
.head 8 -  Set sDatabase = 'LIVE'
.head 7 +  Else
.head 8 -  Set sDatabase = 'PLAY'
.head 7 -  !
.head 7 +  When SqlError
.head 8 -  Call SalMessageBox( 'Error!  Please try again.','Login', MB_Ok )
.head 7 -  Set bOk = SqlConnect( hSqlA )
.head 7 +  If bOk
.head 8 -  Call SqlDisconnect( hSqlA )
.head 8 -  Call SalEndDialog( hWndForm,TRUE )
.head 7 +  Else
.head 8 -  Call SalEndDialog( hWndForm, FALSE )

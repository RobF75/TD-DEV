.head 2 +  Message Actions
.head 3 +  On SAM_Create
.head 4 -  ! Set nConnection=NWGetConnectionNumber()
.head 4 -  ! Call SalStrSetBufferLength( sUserName,20 )
.head 4 -  ! Set nRetCode=NWGetConnectionInformation(nConnection,sUserName,nType,nID,nLoginTime)
.head 4 -  Call GetUser( sUserName )
.head 4 +  If sUserName = ''
.head 5 -  Call SalModalDialog( dlgDatabaseInfo, hWndForm )
.head 5 -  Set dfUser = SqlUser
.head 5 -  Set sUserName = SqlUser
.head 4 +  If sUserName = 'SUPERVISOR'
.head 5 -  Set SqlUser = 'SYSADM'
.head 5 -  Set SqlPassword = 'DANI'
.head 4 +  Else If sUserName = 'ADMIN'
.head 5 -  Set SqlUser = 'SYSADM'
.head 5 -  Set SqlPassword = 'DANI'
.head 4 +  Else
.head 5 -  Set sUserName = SalStrLeftX( sUserName, 8 )
.head 5 -  Set SqlDatabase = ''
.head 5 -  Set SqlUser = sUserName
.head 5 -  Set SqlPassword = sUserName
.head 4 +  ! If sStartDatabase = 'STOCKDEV'
.head 5 -  Set rbPlay = TRUE
.head 4 +  ! Else If sStartDatabase = 'STKLOCAL'
.head 5 -  Set rbLocal = TRUE
.head 4 -  ! Else
.head 4 -  Set rbLive = TRUE
.head 4 -  Return SalSendClassMessage( SAM_Create, wParam, lParam )
.head 3 +  On SAM_CreateComplete
.head 4 -  Call SalSetFocus(pbOk)
.head 4 +  ! If rbPlay
.head 5 -  Call SalSendMsg( rbPlay, SAM_Click, 0, 0 )
.head 4 +  ! Else If rbLocal
.head 5 -  Call SalSendMsg( rbLocal, SAM_Click, 0, 0 )
.head 4 -  ! Else
.head 4 -  Call SalSendMsg( rbLive, SAM_Click, 0, 0 )
.head 4 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )

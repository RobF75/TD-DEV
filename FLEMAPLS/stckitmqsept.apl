.head 5 +  On SAM_FetchRowDone
.head 6 +  If colSecondCount > 0
.head 7 -  Set colCurrentCount = colSecondCount
.head 6 +  Else If colFirstCount > 0
.head 7 -  Set colCurrentCount = colFirstCount
.head 6 +  Else
.head 7 -  Set colCurrentCount = colBegCount
.head 6 -  Set colAvailable = colCurrentCount - colForwardOrders
.head 6 -  !
.head 6 +  If SalIsNull( colEstSaleDate )
.head 7 +  If colNotForSale = 'Y'
.head 8 -  Set colSeason = 'Not for sale'
.head 6 +  Else
.head 7 -  Set colSeason = GetSeason( colEstSaleDate )
.head 7 -  Set colSeasonTextColor = GetSeasonColor( colSeason )
.head 7 -  Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_SETCOLUMNCOLOR, 0, colSeasonTextColor )
.head 7 +  If NOT SalIsNull( colEstSaleDate )
.head 8 -  Set colSeason = colSeason || ' ' || SalNumberToStrX( SalDateYear( colEstSaleDate ), 0 )
.head 6 +  If NOT colNotForSale = 'Y'
.head 7 -  Call tblSeasonAvail.Add( colEstSaleDate, colCurrentCount - colForwardOrders )
.head 6 -  Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )

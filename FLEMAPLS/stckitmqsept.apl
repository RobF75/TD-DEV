.head 4 +  Message Actions
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sSQLPopHandle = "SELECT  
  Growing_Sale.Stock_Item_No,  
  Growing_Sale.Year_Of_Sale,  
  Growing_Sale.Location_Id,  
  Growing_Sale.Beg_Count,  
  Growing_Sale.First_Count,  
  Growing_Sale.Second_Count, 
  NULL, 
  Growing_Sale.Est_Sale_Date,  
  NULL, 
  Growing_Sale.Forward_Orders,  
  NULL, 
  Growing_Sale.Not_For_Sale  
FROM   
  Growing_Sale  
WHERE 
  Growing_Sale.Stock_Item_No = :1 AND 
  Growing_Sale.Year_Of_Sale >= :2 AND 
  ( Growing_Sale.Est_Sale_Date >= SYSDATE OR Growing_Sale.Not_For_Sale = 'Y' )  
ORDER BY 
  Growing_Sale.Est_Sale_Date"
.head 6 -  Set sNAMEPopHandle = 'PPFUTAVAIL2'
.head 6 -  Set sBINDPopHandle = ':dlgFutureAvail.nItemNo, :dlgFutureAvail.dfYear'
.head 6 -  Set sINTOPopHandle = ':dlgFutureAvail.tblGrowSale.colItemNo, 
  :dlgFutureAvail.tblGrowSale.colYear, 
  :dlgFutureAvail.tblGrowSale.colLocationId, 
  :dlgFutureAvail.tblGrowSale.colBegCount, 
  :dlgFutureAvail.tblGrowSale.colFirstCount, 
  :dlgFutureAvail.tblGrowSale.colSecondCount, 
  :dlgFutureAvail.tblGrowSale.colSeason, 
  :dlgFutureAvail.tblGrowSale.colEstSaleDate, 
  :dlgFutureAvail.tblGrowSale.colCurrentCount, 
  :dlgFutureAvail.tblGrowSale.colForwardOrders, 
  :dlgFutureAvail.tblGrowSale.colAvailable, 
  :dlgFutureAvail.tblGrowSale.colNotForSale'
.head 6 -  !
.head 6 -  Set sSQLRefreshHandle = 'SELECT  
  Growing_Sale.Stock_Item_No,  
  Growing_Sale.Year_Of_Sale,  
  Growing_Sale.Location_Id,  
  Growing_Sale.Beg_Count,  
  Growing_Sale.First_Count,  
  Growing_Sale.Second_Count,  
  NULL, 
  Growing_Sale.Est_Sale_Date,  
  NULL, 
  Growing_Sale.Forward_Orders,  
  NULL, 
  Growing_Sale.Not_For_Sale  
FROM   
  Growing_Sale  
WHERE 
  Growing_Sale.Location_Id = :1 AND 
  Growing_Sale.Year_Of_Sale = :2 '
.head 6 -  Set sNAMERefreshHandle = 'RFFUTAVAIL2'
.head 6 -  Set sBINDRefreshHandle = ':dlgFutureAvail.tblGrowSale.colLocationId, :dlgFutureAvail.tblGrowSale.colYear'
.head 6 -  Set sINTORefreshHandle = ':dlgFutureAvail.tblGrowSale.colItemNo, 
  :dlgFutureAvail.tblGrowSale.colYear, 
  :dlgFutureAvail.tblGrowSale.colLocationId, 
  :dlgFutureAvail.tblGrowSale.colBegCount, 
  :dlgFutureAvail.tblGrowSale.colFirstCount, 
  :dlgFutureAvail.tblGrowSale.colSecondCount, 
  :dlgFutureAvail.tblGrowSale.colSeason, 
  :dlgFutureAvail.tblGrowSale.colEstSaleDate, 
  :dlgFutureAvail.tblGrowSale.colCurrentCount, 
  :dlgFutureAvail.tblGrowSale.colForwardOrders, 
  :dlgFutureAvail.tblGrowSale.colAvailable, 
  :dlgFutureAvail.tblGrowSale.colNotForSale'
.head 6 -  !
.head 6 -  Set sSQLInsertHandle = ''

.head 11 -                                                     Call SalHideWindow( hWndItem )
.head 9 +  On PAM_clsTBL_EDITCHECK
.head 10 +  If IsUserPriceAdjuster( SqlUser, TRUE )
.head 11 -  Set nRoyalties = 0
.head 11 +  If NOT colCultId = ''
.head 12 -  Call CalcCultivarRoyalty( 0, colCultId, colItemNo, nRoy, SH_cls_Execute )
.head 12 -  Set nRoyalties = nRoyalties + nRoy
.head 11 +  If NOT colRootId = ''
.head 12 -  Call CalcRootstockRoyalty( 0, colRootId, colItemNo, nRoy, SH_cls_Execute )
.head 12 -  Set nRoyalties = nRoyalties + nRoy
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 -  Return FALSE
.head 9 +  On SAM_KillFocus
.head 10 -  ! Below is commented code that starts to work out full sale price, needs to be modified to speed up, 100 fold, and to handle where royalty
is a percentage
.head 10 -  Set colExclPrice = (colPrice / 11) * 10
.head 10 -  Set colBasePrice = colExclPrice - nRoyalties
.head 10 -  ! Call CalcItemPriceForQueries( colItemNo, 0, colPrice, colExclPrice, SH_cls_Execute )
.head 10 -  ! Set nGST = colPrice - colExclPrice
.head 10 -  ! Set nRoyalties = colPrice - colPrice - nGST
.head 10 -  ! Set colBasePrice = colBasePrice + nRoyalties

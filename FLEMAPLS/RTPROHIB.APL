.head 8 -  Set sSQLPopHandle = ' SELECT 
  Prohibition.Prohib_Date_Time, 
  Prohibition.Year_Of_Prohib, 
  Prohibition.Prohib_Entered_By, 
  Prohibition.State_Prohib_In, 
  Prohibition.Prohib_Who_By, 
  Prohibition.Prohib_Reason, 
  Prohibition.Prohib_Comments  
FROM 
  Prohibition 
WHERE 
  Prohibition.Root_Id = :1'
.head 8 -  Set sNAMEPopHandle = 'ROOTPROHIB'
.head 8 -  Set sBINDPopHandle = ':hWndParent.dfRootId'
.head 8 -  Set sINTOPopHandle = ':clsfrmRootProhibition.tblRootProhibition.colProhibSysDT, 
:clsfrmRootProhibition.tblRootProhibition.colProhibYear, 
:clsfrmRootProhibition.tblRootProhibition.colProhibEnteredBy,
:clsfrmRootProhibition.tblRootProhibition.colProhibState, 
:clsfrmRootProhibition.tblRootProhibition.colProhibWhoBy,
:clsfrmRootProhibition.tblRootProhibition.colPollReason, 
:clsfrmRootProhibition.tblRootProhibition.colPollComments'
.head 8 -  !
.head 8 -  Set sSQLRefreshHandle = ' SELECT 
  Prohibition.State_Prohib_In, 
  Prohibition.Prohib_Who_By, 
  Prohibition.Prohib_Reason, 
  Prohibition.Prohib_Comments  
FROM 
  Prohibition 
WHERE 
  Prohibition.Root_Id = :1 AND 
  Prohibition.Prohib_Date_Time = :2 AND 
  Prohibition.Year_Of_Prohib = :3 AND 
  Prohibition.Prohib_Entered_By = :4 '
.head 8 -  Set sNAMERefreshHandle = 'REFROOTPROHIB'
.head 8 -  Set sBINDRefreshHandle = ':hWndParent.dfRootId, 
:clsfrmRootProhibition.tblRootProhibition.colProhibSysDT, 
:clsfrmRootProhibition.tblRootProhibition.colProhibYear, 
:clsfrmRootProhibition.tblRootProhibition.colProhibEnteredBy'
.head 8 -  Set sINTORefreshHandle = ':clsfrmRootProhibition.tblRootProhibition.colProhibState, 
:clsfrmRootProhibition.tblRootProhibition.colProhibWhoBy,
:clsfrmRootProhibition.tblRootProhibition.colPollReason, 
:clsfrmRootProhibition.tblRootProhibition.colPollComments'
.head 8 -  !
.head 8 -  Set sSQLInsertHandle = 'INSERT INTO Prohibition 
( Root_Id, 
  Prohib_Date_Time, 
  Year_Of_Prohib, 
  Prohib_Entered_By, 
  State_Prohib_In, 
  Prohib_Who_By, 
  Prohib_Reason, 
  Prohib_Comments  ) 
VALUES ( :1, :2, :3, :4, :5, :6, :7, :8 ) '
.head 8 -  Set sNAMEInsertHandle = 'INSROOTPROHIB'
.head 8 -  Set sBINDInsertHandle = ':hWndParent.dfRootId, 
:clsfrmRootProhibition.tblRootProhibition.colProhibSysDT, 
:clsfrmRootProhibition.tblRootProhibition.colProhibYear, 
:clsfrmRootProhibition.tblRootProhibition.colProhibEnteredBy,
:clsfrmRootProhibition.tblRootProhibition.colProhibState, 
:clsfrmRootProhibition.tblRootProhibition.colProhibWhoBy,
:clsfrmRootProhibition.tblRootProhibition.colPollReason, 
:clsfrmRootProhibition.tblRootProhibition.colPollComments'
.head 8 -  Set sINTOInsertHandle = ''
.head 8 -  !
.head 8 -  Set sSQLUpdateHandle = ' UPDATE Prohibition 
SET 
  State_Prohib_In = :5, 
  Prohib_Who_By = :6, 
  Prohib_Reason = :7, 
  Prohib_Comments = :8 
WHERE 
  Root_Id = :1 AND 
  Prohib_Date_Time = :2 AND 
  Year_Of_Prohib = :3 AND 
  Prohib_Entered_By = :4 '
.head 8 -  Set sNAMEUpdateHandle = 'UPDTROOTPROHIB'
.head 8 -  Set sBINDUpdateHandle = ':hWndParent.dfRootId, 
:clsfrmRootProhibition.tblRootProhibition.colProhibSysDT, 
:clsfrmRootProhibition.tblRootProhibition.colProhibYear, 
:clsfrmRootProhibition.tblRootProhibition.colProhibEnteredBy,
:clsfrmRootProhibition.tblRootProhibition.colProhibState, 
:clsfrmRootProhibition.tblRootProhibition.colProhibWhoBy,
:clsfrmRootProhibition.tblRootProhibition.colPollReason, 
:clsfrmRootProhibition.tblRootProhibition.colPollComments'
.head 8 -  Set sINTOUpdateHandle = ''
.head 8 -  !
.head 8 -  Set sSQLDeleteHandle = ' DELETE FROM Prohibition 
WHERE 
  Root_Id = :1 AND 
  Prohib_Date_Time = :2 AND 
  Year_Of_Prohib = :3 AND 
  Prohib_Entered_By = :4 '
.head 8 -  Set sNAMEDeleteHandle = 'DELROOTPROHIB'
.head 8 -  Set sBINDDeleteHandle = ':hWndParent.dfRootId, 
:clsfrmRootProhibition.tblRootProhibition.colProhibSysDT, 

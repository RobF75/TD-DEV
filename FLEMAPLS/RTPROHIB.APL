.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sSQLPopHandle = ' SELECT 
  Prohibition.Prohib_Date_Time, 
  Prohibition.Year_Of_Prohib, 
  Prohibition.Prohib_Entered_By, 
  Prohibition.State_Prohib_In, 
  Prohibition.Prohib_Who_By, 
  Prohibition.Prohib_Reason, 
  Prohibition.Prohib_Comments  
FROM 
  Prohibition 
WHERE 
  Prohibition.Root_Id = :1'
.head 6 -  Set sNAMEPopHandle = 'ROOTPROHIB'
.head 6 -  Set sBINDPopHandle = ':hWndParent.dfRootId'
.head 6 -  Set sINTOPopHandle = ':hWndForm.colProhibSysDT, 
:hWndForm.colProhibYear, 
:hWndForm.colProhibEnteredBy,
:hWndForm.colProhibState, 
:hWndForm.colProhibWhoBy,
:hWndForm.colPollReason, 
:hWndForm.colPollComments'
.head 6 -  !
.head 6 -  Set sSQLRefreshHandle = ' SELECT 
  Prohibition.State_Prohib_In, 
  Prohibition.Prohib_Who_By, 
  Prohibition.Prohib_Reason, 
  Prohibition.Prohib_Comments  
FROM 
  Prohibition 
WHERE 
  Prohibition.Root_Id = :1 AND 
  Prohibition.Prohib_Date_Time = :2 AND 
  Prohibition.Year_Of_Prohib = :3 AND 
  Prohibition.Prohib_Entered_By = :4 '
.head 6 -  Set sNAMERefreshHandle = 'REFROOTPROHIB'
.head 6 -  Set sBINDRefreshHandle = ':hWndParent.dfRootId, 
:hWndForm.colProhibSysDT, 
:hWndForm.colProhibYear, 
:hWndForm.colProhibEnteredBy'
.head 6 -  Set sINTORefreshHandle = ':hWndForm.colProhibState, 
:hWndForm.colProhibWhoBy,
:hWndForm.colPollReason, 
:hWndForm.colPollComments'
.head 6 -  !
.head 6 -  Set sSQLInsertHandle = 'INSERT INTO Prohibition 
( Root_Id, 
  Prohib_Date_Time, 
  Year_Of_Prohib, 
  Prohib_Entered_By, 
  State_Prohib_In, 
  Prohib_Who_By, 
  Prohib_Reason, 
  Prohib_Comments  ) 
VALUES ( :1, :2, :3, :4, :5, :6, :7, :8 ) '
.head 6 -  Set sNAMEInsertHandle = 'INSROOTPROHIB'
.head 6 -  Set sBINDInsertHandle = ':hWndParent.dfRootId, 
:hWndForm.colProhibSysDT, 
:hWndForm.colProhibYear, 
:hWndForm.colProhibEnteredBy,
:hWndForm.colProhibState, 
:hWndForm.colProhibWhoBy,
:hWndForm.colPollReason, 
:hWndForm.colPollComments'
.head 6 -  Set sINTOInsertHandle = ''
.head 6 -  !
.head 6 -  Set sSQLUpdateHandle = ' UPDATE Prohibition 
SET 
  State_Prohib_In = :5, 
  Prohib_Who_By = :6, 
  Prohib_Reason = :7, 
  Prohib_Comments = :8 
WHERE 
  Root_Id = :1 AND 
  Prohib_Date_Time = :2 AND 
  Year_Of_Prohib = :3 AND 
  Prohib_Entered_By = :4 '
.head 6 -  Set sNAMEUpdateHandle = 'UPDTROOTPROHIB'
.head 6 -  Set sBINDUpdateHandle = ':hWndParent.dfRootId, 
:hWndForm.colProhibSysDT, 
:hWndForm.colProhibYear, 
:hWndForm.colProhibEnteredBy,
:hWndForm.colProhibState, 
:hWndForm.colProhibWhoBy,
:hWndForm.colPollReason, 
:hWndForm.colPollComments'
.head 6 -  Set sINTOUpdateHandle = ''
.head 6 -  !
.head 6 -  Set sSQLDeleteHandle = ' DELETE FROM Prohibition 
WHERE 
  Root_Id = :1 AND 
  Prohib_Date_Time = :2 AND 
  Year_Of_Prohib = :3 AND 
  Prohib_Entered_By = :4 '
.head 6 -  Set sNAMEDeleteHandle = 'DELROOTPROHIB'
.head 6 -  Set sBINDDeleteHandle = ':hWndParent.dfRootId, 
:hWndForm.colProhibSysDT, 
:hWndForm.colProhibYear, 
:hWndForm.colProhibEnteredBy'
.head 6 -  Set sINTODeleteHandle = ''

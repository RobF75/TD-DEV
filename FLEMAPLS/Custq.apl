.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 -  Set clsTableCustMaster.sQueryDialogName = 'dlgQQCustMaster'
.head 8 -  Set bSelectFirstRow = FALSE
.head 8 -  Set clsTableCustMaster.sSQLPopHandle = "SELECT 
  @UPPER( Cust_Name ), 
  Cust_No,
  Cust_Name, 
  Bus_Name, 
  Cust_AR_Balance
FROM 
  Customer_Master 
WHERE
  (Dont_sell_flag != 'Y' or
  Dont_Sell_Flag is NULL)
ORDER BY 1"
.head 8 -  Set clsTableCustMaster.sNAMEPopHandle = 'POPCUSTQ'
.head 8 -  Set clsTableCustMaster.sBINDPopHandle = ''
.head 8 -  Set clsTableCustMaster.sINTOPopHandle = '
:hWndForm.clsTableCustMaster.colUpperCustName, 
:hWndForm.clsTableCustMaster.colCustNo, 
:hWndForm.clsTableCustMaster.colCustName, 
:hWndForm.clsTableCustMaster.colBusName,
:hWndForm.clsTableCustMaster.colARBalance'
.head 8 -  !
.head 8 -  Set clsTableCustMaster.sSQLRefreshHandle = "SELECT 
  @UPPER( Cust_Name ), 
  Cust_No,
  Cust_Name, 
  Bus_Name,
  Cust_AR_Balance
FROM 
  Customer_Master 
WHERE 
  Cust_No = :1 and
  (Dont_sell_flag != 'Y' or
  Dont_Sell_Flag is NULL) "
.head 8 -  Set clsTableCustMaster.sNAMERefreshHandle = 'REFCUSTQ'
.head 8 -  Set clsTableCustMaster.sBINDRefreshHandle = ':hWndForm.clsTableCustMaster.colCustNo'
.head 8 -  Set clsTableCustMaster.sINTORefreshHandle = '
:hWndForm.clsTableCustMaster.colUpperCustName, 
:hWndForm.clsTableCustMaster.colCustNo, 
:hWndForm.clsTableCustMaster.colCustName, 

.head 8 -  Set sSQLPopHandle = ' SELECT 
  Prohibition.Prohib_Date_Time, 
  Prohibition.Year_Of_Prohib, 
  Prohibition.Prohib_Entered_By, 
  Prohibition.State_Prohib_In, 
  Prohibition.Prohib_Who_By, 
  Prohibition.Prohib_Reason, 
  Prohibition.Prohib_Comments  
FROM 
  Prohibition 
WHERE 
  Prohibition.Cult_Id = :1'
.head 8 -  Set sNAMEPopHandle = 'CULTPROHIB'
.head 8 -  Set sBINDPopHandle = ':hWndParent.dfCultId'
.head 8 -  Set sINTOPopHandle = ':clsfrmCultProhibition.tblCultProhibition.colProhibSysDT, 
:clsfrmCultProhibition.tblCultProhibition.colProhibYear, 
:clsfrmCultProhibition.tblCultProhibition.colProhibEnteredBy,
:clsfrmCultProhibition.tblCultProhibition.colProhibState, 
:clsfrmCultProhibition.tblCultProhibition.colProhibWhoBy,
:clsfrmCultProhibition.tblCultProhibition.colPollReason, 
:clsfrmCultProhibition.tblCultProhibition.colPollComments'
.head 8 -  !
.head 8 -  Set sSQLRefreshHandle = ' SELECT 
  Prohibition.State_Prohib_In, 
  Prohibition.Prohib_Who_By, 
  Prohibition.Prohib_Reason, 
  Prohibition.Prohib_Comments  
FROM 
  Prohibition 
WHERE 
  Prohibition.Cult_Id = :1 AND 
  Prohibition.Prohib_Date_Time = :2 AND 
  Prohibition.Year_Of_Prohib = :3 AND 
  Prohibition.Prohib_Entered_By = :4 '
.head 8 -  Set sNAMERefreshHandle = 'REFCULTPROHIB'
.head 8 -  Set sBINDRefreshHandle = ':hWndParent.dfCultId, 
:clsfrmCultProhibition.tblCultProhibition.colProhibSysDT, 
:clsfrmCultProhibition.tblCultProhibition.colProhibYear, 
:clsfrmCultProhibition.tblCultProhibition.colProhibEnteredBy'
.head 8 -  Set sINTORefreshHandle = ':clsfrmCultProhibition.tblCultProhibition.colProhibState, 
:clsfrmCultProhibition.tblCultProhibition.colProhibWhoBy,
:clsfrmCultProhibition.tblCultProhibition.colPollReason, 
:clsfrmCultProhibition.tblCultProhibition.colPollComments'
.head 8 -  !
.head 8 -  Set sSQLInsertHandle = 'INSERT INTO Prohibition 
( Cult_Id, 
  Prohib_Date_Time, 
  Year_Of_Prohib, 
  Prohib_Entered_By, 
  State_Prohib_In, 
  Prohib_Who_By, 
  Prohib_Reason, 
  Prohib_Comments  ) 
VALUES ( :1, :2, :3, :4, :5, :6, :7, :8 ) '
.head 8 -  Set sNAMEInsertHandle = 'INSCULTPROHIB'
.head 8 -  Set sBINDInsertHandle = ':hWndParent.dfCultId, 
:clsfrmCultProhibition.tblCultProhibition.colProhibSysDT, 
:clsfrmCultProhibition.tblCultProhibition.colProhibYear, 
:clsfrmCultProhibition.tblCultProhibition.colProhibEnteredBy,
:clsfrmCultProhibition.tblCultProhibition.colProhibState, 
:clsfrmCultProhibition.tblCultProhibition.colProhibWhoBy,
:clsfrmCultProhibition.tblCultProhibition.colPollReason, 
:clsfrmCultProhibition.tblCultProhibition.colPollComments'
.head 8 -  Set sINTOInsertHandle = ''
.head 8 -  !
.head 8 -  Set sSQLUpdateHandle = ' UPDATE Prohibition 
SET 
  State_Prohib_In = :5, 
  Prohib_Who_By = :6, 
  Prohib_Reason = :7, 
  Prohib_Comments = :8 
WHERE 
  Cult_Id = :1 AND 
  Prohib_Date_Time = :2 AND 
  Year_Of_Prohib = :3 AND 
  Prohib_Entered_By = :4 '
.head 8 -  Set sNAMEUpdateHandle = 'UPDTCULTPROHIB'
.head 8 -  Set sBINDUpdateHandle = ':hWndParent.dfCultId, 
:clsfrmCultProhibition.tblCultProhibition.colProhibSysDT, 

:clsfrmCultProhibition.tblCultProhibition.colPollReason, 
:clsfrmCultProhibition.tblCultProhibition.colPollComments'
.head 8 -  Set sINTOUpdateHandle = ''
.head 8 -  !
.head 8 -  Set sSQLDeleteHandle = ' DELETE FROM Prohibition 
WHERE 
  Cult_Id = :1 AND 
  Prohib_Date_Time = :2 AND 
  Year_Of_Prohib = :3 AND 
  Prohib_Entered_By = :4 '
.head 8 -  Set sNAMEDeleteHandle = 'DELCULTPROHIB'

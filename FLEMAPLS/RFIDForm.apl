.head 3 -  ! String: sReceive
.head 3 -  ! Window Handle: hWndRFIDField
.head 2 +  Internal Functions
.head 3 +  ! Function: SerReceive
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 +  Parameters 
.head 5 -  Window Handle: hWndOwner
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  Number: nReceive
.head 4 +  Actions 
.head 5 -  ! Read data, max 100 char
.head 5 +  If fcCom1.Receive( sReceive, 100 )
.head 6 -  ! read ok, with SalStrLength( sReceive ) you see the real data length of read
.head 6 -  Call SalSendMsg( hWndOwner, PAM_clsRFID_Recieve, 0, 0 )
.head 6 -  ! Set mlReceive = mlReceive || sReceive
.head 6 -  Return TRUE
.head 5 +  Else 
.head 6 -  Return FALSE
.head 3 +  ! Function: DIG_Open
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 -  Parameters 
.head 4 -  Static Variables 

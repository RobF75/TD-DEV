.head 3 +  ! Function: DIG_Prt_Config
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 +  Parameters 
.head 5 -  String: sBoardNo
.head 5 -  String: sBoardPortNo
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  Number: nStatus
.head 4 +  Actions 
.head 5 -  Return DIG_Prt_Communitation( nStatus, '', 'COMBoardConfig' )
.head 3 +  ! Function: DIG_In_Line
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 +  Parameters 
.head 5 -  Receive Number: nRead
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  Number: nGotStatus
.head 5 -  Boolean: bOk
.head 4 +  Actions 
.head 5 -  Set bOk = DIG_Prt_Communitation( nRead, '', 'COMInput' )
.head 5 -  Return bOk
.head 3 +  ! Function: DIG_Prt_Communitation
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 +  Parameters 
.head 5 -  Receive Number: nRead
.head 5 -  String: sOverrideOutputString
.head 5 -  ! sActionType = 'COMOpen' or 'COMBoardConfig' or 'COMOutput' or 'COMInput' or 'COMClose'
.head 5 -  String: sActionType
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  String: sStatus
.head 5 -  String: strBuffer
.head 5 -  Number: nErr
.head 5 -  Number: nBytesWritten
.head 5 -  Number: nBytesRead
.head 5 -  String: sCR
.head 5 -  Number: nNoCRRead
.head 5 -  Number: nStopAfterNCR
.head 5 -  Boolean: bInputStrStarted
.head 5 -  Boolean: bContinue
.head 5 -  String: sChar
.head 4 +  Actions 
.head 5 -  Set sCR = ' '
.head 5 -  Set sCR = SalNumberToChar( 13 )
.head 5 +  If sActionType = 'COMOpen'
.head 6 -  ! 23/04/2007 (PXD) Changed to use COM1 as most modern PCs only have this available
.head 6 -  ! Set nErr = fcCom2.Open( 'COM2', 9600, 'n', 8, 1 )
.head 6 -  ! 31/10/2007 (PXD) Changed to use COM5 as virtual port for RJ45 based connection - see problem# 1198
.head 6 -  ! Set nErr = fcCom2.Open( 'COM1', 9600, 'n', 8, 1 )
.head 6 -  Set nErr = fcCom1.Open( 'COM1', 9600, 'n', 8, 1 )
.head 6 -  Return TRUE
.head 5 +  Else If sActionType = 'COMBoardConfig'
.head 6 -  Return TRUE
.head 5 +  Else If sActionType = 'COMTimeout'
.head 6 -  Set nErr = fcCom1.SetTimeouts(  )
.head 6 -  Return TRUE
.head 5 +  Else If sActionType = 'COMClose'
.head 6 -  Set nErr = fcCom1.Close( )
.head 6 -  Return TRUE
.head 5 +  Else If sActionType = 'COMInput'
.head 6 -  ! Set nStatus = NUMBER_Null
.head 6 -  ! Set strBuffer = '$'||sBoardNo||'6'||sCR
.head 6 -  ! Set nErr = fcCom2.Write( strBuffer )
.head 6 -  Set nNoCRRead = 0
.head 6 -  Set nStopAfterNCR = 9999
.head 6 -  Set bInputStrStarted = FALSE
.head 6 -  Set strBuffer = ''
.head 6 -  Set bContinue = TRUE
.head 6 +  ! While bContinue
.head 7 +  If fcCom2.Read( sChar, 1 )
.head 8 +  If bInputStrStarted
.head 9 +  If sChar = sCR
.head 10 -  Set nNoCRRead = nNoCRRead + 1
.head 10 -  Set bContinue = FALSE
.head 9 -  Call SalStrFirstC( sChar, nErr )
.head 9 -  Set strBuffer = strBuffer || SalNumberToChar( nErr )
.head 8 +  Else
.head 9 +  If sChar = '!'
.head 10 -  Set bInputStrStarted = TRUE
.head 10 -  Call SalStrFirstC( sChar, nErr )
.head 10 -  Set strBuffer = strBuffer || SalNumberToChar( nErr )
.head 9 +  Else If sChar = sCR
.head 10 -  Set nNoCRRead = nNoCRRead + 1
.head 8 +  If nNoCRRead >= nStopAfterNCR
.head 9 -  Set bContinue = FALSE
.head 7 +  Else
.head 8 -  Set bContinue = FALSE
.head 6 -  !
.head 6 -  Call SalTimerSet ( hWndRFIDField, 1234, 50 )
.head 6 -  !
.head 6 -  ! extract port status here and set nStatus
.head 6 +  ! If SalStrLeftX( strBuffer, 1 ) = '!'
.head 7 +  If SalStrUpperX( SalStrLeftX( sBoardPortNo, 1 ) ) = 'A'
.head 8 -  Set sStatus = ConvertStrHexToStrBinX( SalStrMidX( strBuffer, 1, 2 ) )
.head 7 +  Else If SalStrUpperX( SalStrLeftX( sBoardPortNo, 1 ) ) = 'B'
.head 8 -  Set sStatus =  ConvertStrHexToStrBinX( SalStrMidX( strBuffer, 3, 2 ) )
.head 7 +  Else
.head 8 -  Set sStatus =  ConvertStrHexToStrBinX( SalStrMidX( strBuffer, 5, 2 ) )
.head 7 -  !
.head 7 +  If SalStrMidX( sStatus, ( 7 - SalStrToNumber( SalStrMidX( sBoardPortNo, 1, 1 ) ) ), 1 ) = '1'
.head 8 -  Set nStatus = 1
.head 7 +  Else
.head 8 -  Set nStatus = 0
.head 7 -  Return TRUE
.head 6 +  ! Else
.head 7 -  Return FALSE
.head 5 +  Else 
.head 6 +  ! If nStatus
.head 7 -  Set sStatus = '01'
.head 6 +  ! Else
.head 7 -  Set sStatus = '00'
.head 6 -  ! Set strBuffer = '#'||sBoardNo||sBoardPortNo||sStatus||sCR
.head 6 -  !
.head 6 +  If NOT sOverrideOutputString = ''
.head 7 -  Set strBuffer = sOverrideOutputString || sCR
.head 6 -  Set nErr = fcCom1.Write( strBuffer )
.head 6 +  ! If nErr < 0
.head 7 -  Call SalMessageBox('Failed to set channel','Channel setting', MB_Ok)
.head 6 -  Return TRUE
.head 2 +  Named Menus

.head 6 +  Message Actions
.head 7 +  On PAM_clsTBL_POPULATE
.head 8 +  If wParam = 1
.head 9 -  Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow ) 
.head 9 -  Call SalTblSetContext( hWndForm, nRow )
.head 9 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_HideMarks, TRUE )
.head 9 -  Set colManyCultId = sCultId
.head 9 -  Call ExtractCultivarDescription( colManyCultId, colManyCultDesc, SH_cls_Execute )
.head 8 +  Else
.head 9 -  Call ReadStrArrayListFromFile( sManyCultIdsFile, saCultIds )
.head 9 -  Set nPos = 0
.head 9 +  While saCultIds[ nPos ] != ''
.head 10 -  Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow ) 
.head 10 -  Call SalTblSetContext( hWndForm, nRow )
.head 10 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_HideMarks, TRUE )
.head 10 -  Set colManyCultId = saCultIds[ nPos ]
.head 10 -  Call ExtractCultivarDescription( colManyCultId, colManyCultDesc, SH_cls_Execute )
.head 10 -  Set nPos = nPos + 1
.head 8 -  Call SalTblSetContext( hWndForm, 0 )
.head 8 -  Call SalTblSetRowFlags( hWndForm, 0, ROW_Selected, TRUE )
.head 8 -  Set sCultId = colManyCultId
.head 8 -  Set sCultDesc = colManyCultDesc
.head 7 +  On SAM_Destroy
.head 8 -  Call ExtractCultivarDescription( '', colManyCultDesc, SH_cls_Disconnect )
.head 7 +  On SAM_RowValidate
.head 8 +  If SalSendMsg( hWndChildTable, PAM_clsTBL_CHECKCHANGES, 0, 0 )
.head 9 -  Call SalPostMsg( hWndForm, PAM_clsTBL_CHKCONTEXTROW, 0, 0 )
.head 9 -  Return VALIDATE_Ok
.head 8 +  Else
.head 9 -  Return VALIDATE_Cancel
.head 7 +  On PAM_clsTBL_CHKCONTEXTROW
.head 8 -  Set sCultId = colManyCultId
.head 8 -  Set sCultDesc = colManyCultDesc
.head 8 -  Call SalSendMsg( hWndChildTable, PAM_clsTBL_POPULATE, 0, 0 )
.head 8 -  Call SalSetFocus( hWndForm )
.head 8 -  Return VALIDATE_Ok

  Royalty_Payable.Percentage_Payable, 
  Royalty_Payable.Payment_Due_Date, 
  Royalty_Payable.Currency_Payable 
FROM 
  Royalty_Payable, 
  Royalty_Owner
WHERE 
  Royalty_Payable.Cultivar_Id = :1 AND 
  Royalty_Payable.Royalty_Owner_Id = Royalty_Owner.Royalty_Owner_Id 
ORDER BY 
  Royalty_Payable.Roy_Instance# '

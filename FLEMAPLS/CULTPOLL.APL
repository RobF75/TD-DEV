.head 9 -  Call ErrorMessage( 'This cultivar is the same as the one being pollinated. Please choose another!', hWndForm, lParam )
.head 9 -  Return FALSE
.head 8 +  Else 
.head 9 -  Call CheckCultPollinatorExists( hWndForm.hWndParent.dfCultId, colPollCultId, bExists, SH_cls_Execute )
.head 9 +  If bExists
.head 10 -  Call ErrorMessage( 'This cultivar is already used in this table as a pollinator.', hWndForm, lParam )
.head 10 -  Return FALSE
.head 9 +  Else 
.head 10 -  Return TRUE

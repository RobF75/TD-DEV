.head 6 -  Set sSQLPopHandle = ' SELECT 
  Pollination.Poll_Cult_Id, 
  Cultivar.Cult_Desc, 
  Pollination.Poll_Comments 
FROM 
  Pollination, 
  Cultivar 
WHERE 
  Pollination.Cult_Id = :1 AND 
  Pollination.Poll_Cult_Id = Cultivar.Cult_Id '
.head 6 -  Set sNAMEPopHandle = 'CULTPOLL'
.head 6 -  Set sBINDPopHandle = ':hWndParent.dfCultId'
.head 6 -  Set sINTOPopHandle = ':hWndForm.colPollCultId, 
:hWndForm.colPollCultDesc, 
:hWndForm.colPollComments'
.head 6 -  !
.head 6 -  Set sSQLRefreshHandle = ' SELECT 
  Cultivar.Cult_Desc, 
  Pollination.Poll_Comments 
FROM 
  Pollination, 
  Cultivar 
WHERE 
  Pollination.Cult_Id = :1 AND 
  Pollination.Poll_Cult_Id = :2 AND 
  Pollination.Poll_Cult_Id = Cultivar.Cult_Id '
.head 6 -  Set sNAMERefreshHandle = 'REFCULTPOLL'

.head 7 +  Function: GetDistinctInsNo
.head 8 -  Description:
.head 8 +  Returns
.head 9 -  Boolean:
.head 8 +  Parameters
.head 9 -  String: sOwnerId
.head 9 -  Receive Number: nInstNo
.head 9 -  Number: nActionType
.head 8 -  Static Variables
.head 8 +  Local variables
.head 9 -  String: sSql
.head 9 -  String: sBind
.head 9 -  String: sInto
.head 9 -  String: sName
.head 9 -  Number: nSqlHandleNo
.head 9 -  !
.head 9 -  Number: nInd
.head 8 +  Actions
.head 9 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetDistInstNo' )
.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set sSql = "
SELECT
	Max( Roy_Instance# ) + 1
  FROM
	Royalty_Payable
WHERE
	Royalty_Owner_Id = :1 "
.head 11 -  Set sName = 'GetDistInstNo1'
.head 11 -  Set sBind = ':sOwnerId '
.head 11 -  Set sInto = ' :nInstNo '
.head 11 -  !
.head 11 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 11 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 11 -  !
.head 11 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 12 +  If NOT haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 13 -  Set nInstNo = 0
.head 12 +  Else
.head 13 +  If nInstNo = NUMBER_Null
.head 14 -  Set nInstNo = 0
.head 12 -  Return TRUE
.head 11 +  Else
.head 12 -  Return FALSE
.head 10 +  Case SH_cls_Disconnect
.head 11 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 6 -  Window Variables
.head 6 +  Message Actions
.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 +  If TRUE	! SELECT
.head 9 -  Set sSQLPopHandle = ' SELECT 
  Royalty_Payable.Roy_Instance#, 
  Royalty_Payable.Cultivar_Id, 
  Cultivar.Cult_Desc, 
  Royalty_Payable.Rootstock_Id,  
  Royalty_Payable.Currency_Payable,
  Royalty_Payable.Currency_Roy_Amt,
  Royalty_Payable.Amount_Payable, 
  Royalty_Payable.Percentage_Payable, 
  Royalty_Payable.Payment_Due_Date,
  Royalty_Payable.Paid_Upto_Date,
  Royalty_Payable.Due_Every_Months
FROM 
  Royalty_Payable, 
  Cultivar 
WHERE 
  Royalty_Payable.Royalty_Owner_Id = :1 AND 
  Royalty_Payable.Cultivar_Id = Cultivar.Cult_Id(+)  
ORDER BY 
  Royalty_Payable.Roy_Instance# '
.head 9 -  Set sNAMEPopHandle = 'OWNPATNT4'
.head 9 -  Set sBINDPopHandle = ':hWndParent.dfOwnerId'
.head 9 -  Set sINTOPopHandle = ':clsfrmOwnersPatents.tblOwnerPatents.colRoyInstanceNo, 
:clsfrmOwnersPatents.tblOwnerPatents.colCultId, 
:clsfrmOwnersPatents.tblOwnerPatents.colCultDesc, 
:clsfrmOwnersPatents.tblOwnerPatents.colRootId,  
:clsfrmOwnersPatents.tblOwnerPatents.colCurrency,  
:clsfrmOwnersPatents.tblOwnerPatents.colCurrencyAmtPayable,  
:clsfrmOwnersPatents.tblOwnerPatents.colAmtPayable, 
:clsfrmOwnersPatents.tblOwnerPatents.colPercentage, 
:clsfrmOwnersPatents.tblOwnerPatents.colPayDueDate,
:clsfrmOwnersPatents.tblOwnerPatents.colPaidUptoDate,
:clsfrmOwnersPatents.tblOwnerPatents.colDueEveryMonths'
.head 8 -  !
.head 8 +  If TRUE	! REFRESH
.head 9 -  Set sSQLRefreshHandle = ' SELECT 
  Royalty_Payable.Cultivar_Id, 
  Cultivar.Cult_Desc, 
  Royalty_Payable.Rootstock_Id,  
  Royalty_Payable.Currency_Payable,
  Royalty_Payable.Currency_Roy_Amt,
  Royalty_Payable.Amount_Payable, 
  Royalty_Payable.Percentage_Payable, 
  Royalty_Payable.Payment_Due_Date,
  Royalty_Payable.Paid_Upto_Date,
  Royalty_Payable.Due_Every_Months
FROM 
  Royalty_Payable, 
  Cultivar 
WHERE 
  Royalty_Payable.Royalty_Owner_Id = :1 AND 
  Royalty_Payable.Roy_Instance# = :2 AND 
  Royalty_Payable.Cultivar_Id = Cultivar.Cult_Id(+) '
.head 9 -  Set sNAMERefreshHandle = 'REFOWNPATNT4'
.head 9 -  Set sBINDRefreshHandle = ':hWndParent.dfOwnerId, 
:clsfrmOwnersPatents.tblOwnerPatents.colRoyInstanceNo'
.head 9 -  Set sINTORefreshHandle = ':clsfrmOwnersPatents.tblOwnerPatents.colCultId, 
:clsfrmOwnersPatents.tblOwnerPatents.colCultDesc, 
:clsfrmOwnersPatents.tblOwnerPatents.colRootId,  
:clsfrmOwnersPatents.tblOwnerPatents.colCurrency,  
:clsfrmOwnersPatents.tblOwnerPatents.colCurrencyAmtPayable,  
:clsfrmOwnersPatents.tblOwnerPatents.colAmtPayable, 
:clsfrmOwnersPatents.tblOwnerPatents.colPercentage, 
:clsfrmOwnersPatents.tblOwnerPatents.colPayDueDate,
:clsfrmOwnersPatents.tblOwnerPatents.colPaidUptoDate,
:clsfrmOwnersPatents.tblOwnerPatents.colDueEveryMonths'
.head 8 -  !
.head 8 +  If TRUE	! UPDATE
.head 9 -  Set sSQLUpdateHandle = 'UPDATE Royalty_Payable
SET 
  Currency_Payable = :3,
  Currency_Roy_Amt = :4,
  Amount_Payable = :5, 
  Percentage_Payable = :6, 
  Payment_Due_Date = :7,
  Paid_Upto_Date = :8,
  Due_Every_Months = :9
WHERE 
  Royalty_Owner_Id = :1 AND 
  Roy_Instance# = :2 '
.head 9 -  Set sNAMEUpdateHandle = 'UPTOWNPATNT4'
.head 9 -  Set sBINDUpdateHandle = ':hWndParent.dfOwnerId, 
:clsfrmOwnersPatents.tblOwnerPatents.colRoyInstanceNo,
:clsfrmOwnersPatents.tblOwnerPatents.colCurrency,  
:clsfrmOwnersPatents.tblOwnerPatents.colCurrencyAmtPayable,  
:clsfrmOwnersPatents.tblOwnerPatents.colAmtPayable, 
:clsfrmOwnersPatents.tblOwnerPatents.colPercentage, 
:clsfrmOwnersPatents.tblOwnerPatents.colPayDueDate,
:clsfrmOwnersPatents.tblOwnerPatents.colPaidUptoDate,
:clsfrmOwnersPatents.tblOwnerPatents.colDueEveryMonths'
.head 9 -  Set sINTOUpdateHandle = ''
.head 8 +  If TRUE	! ADD
.head 9 -  Set sSQLInsertHandle = '
INSERT INTO 
	Royalty_Payable
	(  
  	Royalty_Owner_Id, 
	Cultivar_Id, 
  	Roy_Instance#,
	Currency_Payable,
  	Currency_Roy_Amt,
  	Amount_Payable, 
  	Percentage_Payable, 
  	Payment_Due_Date,
  	Paid_Upto_Date,
  	Due_Every_Months
	)

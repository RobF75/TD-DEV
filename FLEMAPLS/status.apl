.head 2 +  Named Menus
.head 2 +  Internal Functions
.head 3 +  Function: AddToStatus
.head 4 -  Description: When the user has entered a status code which doesn't exist in the table, we
prompt them for a  description and action and then add it
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: sStatusCode
.head 5 -  String: sStatusDesc
.head 5 -  String: sPay
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sName
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  Number: nSqlHandleNo
.head 5 -  Number: nInd
.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'AddStatus' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = ' Insert Into Status_codes
(Status_Code,
Description,
Pay)
Values
( :1, :2, :3)'
.head 7 -  Set sName = 'AddStatus'
.head 7 -  Set sBind = ':sStatusCode, :sStatusDesc, :sPay'
.head 7 -  Set sInto = ''
.head 7 -  ! !
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 +  If haSqlHandles[nSqlHandleNo ].Execute( )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Commit
.head 7 -  Call haSqlHandles[nSqlHandleNo ].Commit( )
.head 6 +  Case SH_cls_Rollback
.head 7 -  Call haSqlHandles[nSqlHandleNo ].Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 7 -  Return TRUE

.head 6 +  Message Actions
.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 +  If sStockType = 'C'
.head 9 -  Set sSQLPopHandle = " SELECT 
  Growing_Sale.Year_Of_Sale, 
  Growing_Sale.Location_Id, 
  Location.Farm_Name, 
  Location.Row#, 
  Location.Seq#, 
  Growing_Sale.Beg_Count, 
  Growing_Sale.First_Count, 
  Growing_Sale.Second_Count, 
  Growing_Sale.Est_Sale_Date, 
  Growing_Sale.Not_For_Sale, 
  Growing_Sale.Forward_Orders,
  Growing_Sale.Planning_Reserved 
FROM 
  Growing_Sale, 
  Location 
WHERE 
  Growing_Sale.Location_Id = Location.Location_Id AND 
  Growing_Sale.Stock_Item_No = :1 AND 
  ( Growing_Sale.Not_For_Sale = 'N' OR 
  Growing_Sale.Not_For_Sale IS NULL ) and
  Farm_Name != 'CPLMARK'
ORDER BY 
  Growing_Sale.Est_Sale_Date "
.head 9 -  Set sNAMEPopHandle = 'POPPITMBTCHS3'
.head 9 -  Set sBINDPopHandle = ':hWndParent.clsfrmItemBatches.nItemNo'
.head 9 -  Set sINTOPopHandle = ':clsfrmItemBatches.tblItemBatches.colYearOfSale, 
:clsfrmItemBatches.tblItemBatches.colLocationId, 
:clsfrmItemBatches.tblItemBatches.colFarmName, 
:clsfrmItemBatches.tblItemBatches.colRowNo, 
:clsfrmItemBatches.tblItemBatches.colSeqNo, 
:clsfrmItemBatches.tblItemBatches.colBudCount, 
:clsfrmItemBatches.tblItemBatches.colFirstCount, 
:clsfrmItemBatches.tblItemBatches.colSecondCount, 
:clsfrmItemBatches.tblItemBatches.colWhenAvail, 
:clsfrmItemBatches.tblItemBatches.colNotForSale, 
:clsfrmItemBatches.tblItemBatches.colForwardOrders, 
:clsfrmItemBatches.tblItemBatches.colReserved'
.head 8 +  Else
.head 9 -  Set sSQLPopHandle = " SELECT 
  Growing_Sale.Year_Of_Sale, 
  Growing_Sale.Location_Id, 
  Location.Farm_Name, 
  Location.Row#, 
  Location.Seq#, 
  Growing_Sale.Beg_Count, 
  Growing_Sale.First_Count, 
  Growing_Sale.Second_Count, 
  Growing_Sale.Est_Sale_Date, 
  Growing_Sale.Not_For_Sale, 
  Growing_Sale.Forward_Orders,
  Growing_Sale.Planning_Reserved 
FROM 
  Growing_Sale, 
  Location 
WHERE 
  Growing_Sale.Location_Id = Location.Location_Id AND 
  Growing_Sale.Stock_Item_No = :1 AND 
  ( Growing_Sale.Not_For_Sale = 'N' OR 
  Growing_Sale.Not_For_Sale IS NULL ) and
  Year_Of_Sale = :2
ORDER BY 
  Growing_Sale.Est_Sale_Date "
.head 9 -  Set sNAMEPopHandle = 'POPPITMBROOT2'
.head 9 -  Set sBINDPopHandle = ':hWndParent.clsfrmItemBatches.nItemNo, :hWndParent.clsfrmItemBatches.nYear'
.head 9 -  Set sINTOPopHandle = ':clsfrmItemBatches.tblItemBatches.colYearOfSale, 
:clsfrmItemBatches.tblItemBatches.colLocationId, 
:clsfrmItemBatches.tblItemBatches.colFarmName, 
:clsfrmItemBatches.tblItemBatches.colRowNo, 
:clsfrmItemBatches.tblItemBatches.colSeqNo, 
:clsfrmItemBatches.tblItemBatches.colBudCount, 
:clsfrmItemBatches.tblItemBatches.colFirstCount, 
:clsfrmItemBatches.tblItemBatches.colSecondCount, 
:clsfrmItemBatches.tblItemBatches.colWhenAvail, 
:clsfrmItemBatches.tblItemBatches.colNotForSale, 
:clsfrmItemBatches.tblItemBatches.colForwardOrders, 
:clsfrmItemBatches.tblItemBatches.colReserved'
.head 8 -  !
.head 8 -  Set sSQLRefreshHandle = " SELECT 
  Growing_Sale.Year_Of_Sale, 
  Growing_Sale.Location_Id, 
  Location.Farm_Name, 
  Location.Row#, 
  Location.Seq#,
  Growing_Sale.Beg_Count, 
  Growing_Sale.First_Count, 
  Growing_Sale.Second_Count, 
  Growing_Sale.Est_Sale_Date, 
  Growing_Sale.Not_For_Sale, 
  Growing_Sale.Forward_Orders,
  Growing_Sale.Planning_Reserved
FROM 
  Growing_Sale, 
  Location 
WHERE 
  Growing_Sale.Location_Id = Location.Location_Id AND 
  Growing_Sale.Stock_Item_No = :1 AND 
  Growing_Sale.Year_Of_Sale = :2 AND 
  Growing_Sale.Location_Id = :3 "

.head 8 -  Call CheckSubstituteExists( hWndForm.hWndParent.dfItemNo, colSubsItemNo, bExists, SH_cls_Execute )
.head 8 +  If bExists
.head 9 -  Call ErrorMessage( 'This Substitute is already a sub here! Please SELECT another!', hWndForm, lParam )
.head 9 -  Return FALSE
.head 8 +  Else 
.head 9 -  Return TRUE

:clsfrmItemSuppliers.tblItemSuppliers.colStockOnHand,
:clsfrmItemSuppliers.tblItemSuppliers.colItemAddedDT'
.head 8 -  Set sINTOInsertHandle = ''
.head 8 -  !
.head 8 -  Set sSQLUpdateHandle = ' UPDATE Item_Suppliers 
SET 
  Supplier_Item_No = :4, 
  Priority = :5, 
  Stock_Available = :6
WHERE 
  Stock_Item_No = :1 AND 
  Supplier_Cust_No = :2 and
  Supplier_Item_DT = :3 '

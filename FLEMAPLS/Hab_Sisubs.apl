.head 8 -  Set sSQLPopHandle = ' SELECT 
  Customer_Master.Cust_No, 
  Customer_Master.Cust_name, 
  Customer_Master.Bus_Name, 
  Item_Suppliers.Supplier_Item_No, 
  Item_Suppliers.Priority, 
  Item_Suppliers.Stock_Available,
  Supplier_Item_DT  
FROM 
  Item_Suppliers, 
  Customer_Master 
WHERE 
  Item_Suppliers.Stock_Item_No = :1 AND 
  Item_Suppliers.Supplier_Cust_No = Customer_master.Cust_No 
ORDER BY 
  Item_Suppliers.Priority'
.head 8 -  Set sNAMEPopHandle = 'ITEMSupplier'
.head 8 -  Set sBINDPopHandle = ':hWndParent.dfItemNo'
.head 8 -  Set sINTOPopHandle = '
:clsfrmItemSuppliers.tblItemSuppliers.colCustNo, 
:clsfrmItemSuppliers.tblItemSuppliers.colCustName, 
:clsfrmItemSuppliers.tblItemSuppliers.colCustBusName,
:clsfrmItemSuppliers.tblItemSuppliers.colSupplierItemNo, 
:clsfrmItemSuppliers.tblItemSuppliers.colPriority,
:clsfrmItemSuppliers.tblItemSuppliers.colStockOnHand,
:clsfrmItemSuppliers.tblItemSuppliers.colItemAddedDT'
.head 8 -  !
.head 8 -  Set sSQLRefreshHandle = ' SELECT 
  Customer_Master.Cust_No, 
  Customer_Master.Cust_name, 
  Customer_Master.Bus_Name, 
  Item_Suppliers.Supplier_Item_No, 
  Item_Suppliers.Priority, 
  Item_Suppliers.Stock_Available,
  Supplier_Item_DT   
FROM 
  Item_Suppliers, 
  Customer_Master 
WHERE 
  Item_Suppliers.Stock_Item_No = :1 AND 
  Item_Suppliers.Supplier_Cust_No = :2 AND 
  Item_Suppliers.Supplier_Cust_No = Customer_Master.Cust_No '
.head 8 -  Set sNAMERefreshHandle = 'REFITEMSupplier'
.head 8 -  Set sBINDRefreshHandle = ':hWndParent.dfItemNo, :clsfrmItemSuppliers.tblItemSuppliers.colCustNo'
.head 8 -  Set sINTORefreshHandle = '
:clsfrmItemSuppliers.tblItemSuppliers.colCustNo, 
:clsfrmItemSuppliers.tblItemSuppliers.colCustName, 
:clsfrmItemSuppliers.tblItemSuppliers.colCustBusName,
:clsfrmItemSuppliers.tblItemSuppliers.colSupplierItemNo, 
:clsfrmItemSuppliers.tblItemSuppliers.colPriority,
:clsfrmItemSuppliers.tblItemSuppliers.colStockOnHand,
:clsfrmItemSuppliers.tblItemSuppliers.colItemAddedDT'
.head 8 -  !
.head 8 -  Set sSQLInsertHandle = 'INSERT INTO Item_Suppliers 
( Stock_Item_No, 
  Supplier_Cust_No, 
  Supplier_Item_No, 
  Priority, 
  Stock_Available,
  Supplier_Item_DT ) 
VALUES ( :1, :2, :3, :4, :5, :6 ) '

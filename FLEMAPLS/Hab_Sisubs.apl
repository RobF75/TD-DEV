.head 3 +  Function: fnGetSubsRealStockItemDetails
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nItemNo
.head 5 -  Receive Number: nSubItemNo

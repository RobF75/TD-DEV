.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 5 -  Number: nInd
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( '2404GETSUBSDETS2' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  ! This select only selects the first stock item due to an error in the database that does not allow me to 
know how many of the item to use.
.head 7 -  Set sSql = " SELECT
	Item_No,
	Cult_Desc,
  	Root_Desc,
	Tree_Type_Desc
FROM
  	Stock_Item
WHERE
  	Item_No = (
	SELECT 
		Substitute_item_no
	FROM
		substitutes
	WHERE
		Stock_Item_No = :1 and
		subs_Priority = 1)"
.head 7 -  Set sName = '2404GETSUBSDETS2'
.head 7 -  Set sBind = ':nItemNo'
.head 7 -  Set sInto = ':nSubItemNo, :sSubCultDesc, :sSubRootDesc, :sSubTreeType'
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 7 -  Return TRUE

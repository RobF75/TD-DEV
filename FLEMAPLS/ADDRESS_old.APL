.head 7 +     If fcOurHandle.Execute( )
.head 8 +     If fcOurHandle.FetchNext( nInd )
.head 9 -     Set bExists = TRUE
.head 8 +     Else 
.head 9 -     Set bExists = FALSE
.head 8 -     Set sSoldOutFlag = sGotSoldOutFlag
.head 8 -     Return TRUE
.head 7 +     Else 
.head 8 -     Return FALSE
.head 6 +     Case SH_cls_Disconnect
.head 7 -     Return fcOurHandle.Disconnect( )

.head 3 +  Function: NextField
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  String:
.head 4 +  Parameters
.head 5 -  String: sAttention
.head 5 -  String: sCustName
.head 5 -  String: sBusName

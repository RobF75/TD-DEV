.head 5 -  Number: nProcessingFieldNo
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  Select Case nProcessingFieldNo
.head 6 +  Case 1
.head 7 -  Return sAttention
.head 6 +  Case 2
.head 7 -  Return sCustName
.head 6 +  Case 3
.head 7 -  Return sBusName
.head 6 +  Case 4
.head 7 -  Return sAddrL1
.head 6 +  Case 5
.head 7 -  Return sAddrL2
.head 6 +  Case 6
.head 7 -  Return sSuburb || '  ' || sState || '  ' || sPostcode
.head 6 +  Default
.head 7 -  Return ''
.head 5 +  ! Select Case nProcessingFieldNo
.head 6 +     Case 1
.head 7 +     If sCustName = ''
.head 8 -     Return sBusName
.head 7 +     Else 
.head 8 -     Return sCustName
.head 6 +     Case 2
.head 7 +     If sBusName = ''
.head 8 -     Return sAddrL1
.head 7 +     Else 
.head 8 -     Return sBusName
.head 6 +     Case 3
.head 7 +     If sAddrL1 = ''
.head 8 -     Return sAddrL2
.head 7 +     Else 
.head 8 -     Return sAddrL1
.head 6 +     Case 4
.head 7 +     If sAddrL2 = ''
.head 8 -     Return sSuburb || ' ' || sState || ' ' || sPostcode
.head 7 +     Else 
.head 8 -     Return sAddrL2
.head 6 +     Case 5
.head 7 -     Return sSuburb || ' ' || sState || ' ' || sPostcode
.head 6 +     Default 
.head 7 -     Return ''

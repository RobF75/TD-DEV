.head 5 -  String: sCustRightName
.head 4 +  Actions
.head 5 -  Set nCommaPos = SalStrScan( sCustName, ',' )
.head 5 +  If nCommaPos >= 0
.head 6 -  Call SalStrLeft( sCustName, nCommaPos, sCustLeftName )
.head 6 -  Call SalStrMid( sCustName, nCommaPos + 2, SalStrLength( sCustName ) - nCommaPos, sCustRightName )
.head 6 -  Set sCustName = sCustRightName || ' ' || sCustLeftName

.head 5 +  Function: PostcodeRangeExists
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  String: sPCodeFrom
.head 7 -  String: sPCodeTo
.head 7 -  Number: nExecuteOrDisconnect
.head 6 +  Static Variables
.head 7 -  Sql Handle: hSqlHandle
.head 7 -  Boolean: bHandleConnected
.head 7 -  Boolean: bHandlePrepared
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  Number: nInd
.head 7 -  Boolean: bOk
.head 6 +  Actions
.head 7 +  If nExecuteOrDisconnect != SH_cls_Disconnect
.head 8 +  If NOT bHandleConnected
.head 9 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 9 +  If bHandleConnected
.head 10 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 10 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 9 +  Else
.head 10 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 10 -  Return FALSE
.head 8 +  If NOT bHandlePrepared
.head 9 -  Set sSql = ' SELECT Postcode_From FROM Postcodes  WHERE 
 ( @Value(:sPCodeFrom) >= @Value(Postcode_From) AND 
   @Value(:sPCodeFrom) <= @Value(Postcode_To) AND
   @Value(:sPCodeTo) >= @Value(Postcode_From) AND 
   @Value(:sPCodeTo) <= @Value(Postcode_To) ) OR
 ( @Value(:sPCodeFrom) <= @Value(Postcode_From) AND 
   @Value(:sPCodeFrom) <= @Value(Postcode_To) AND
   @Value(:sPCodeTo) >= @Value(Postcode_From) AND 
   @Value(:sPCodeTo) <= @Value(Postcode_To) ) OR
 ( @Value(:sPCodeFrom) >= @Value(Postcode_From) AND 
   @Value(:sPCodeFrom) <= @Value(Postcode_To) AND
   @Value(:sPCodeTo) >= @Value(Postcode_From) AND 
   @Value(:sPCodeTo) >= @Value(Postcode_To) ) OR 
 ( @Value(:sPCodeFrom) <= @Value(Postcode_From) AND 
   @Value(:sPCodeTo) >= @Value(Postcode_To) ) OR
 ( @Value(:sPCodeFrom) = @Value(Postcode_From) )'
.head 9 -  ! Set sSql = ' SELECT Postcode_From FROM Postcodes  WHERE 
   @Value(Postcode_From) <= @Value(:sPCodeFrom) AND 
   @Value(Postcode_To) >= @Value(:sPCodeFrom) AND
   @Value(Postcode_From) <= @Value(:sPCodeTo) AND 
   @Value(Postcode_To) >= @Value(:sPCodeTo) '
.head 9 +  If SqlPrepare( hSqlHandle, sSql )
.head 10 -  Set bHandlePrepared = TRUE
.head 9 +  Else
.head 10 -  Set bHandlePrepared = FALSE
.head 8 +  If SqlExecute( hSqlHandle )
.head 9 -  Call SqlFetchNext( hSqlHandle, nInd )
.head 9 +  If nInd = FETCH_EOF
.head 10 -  Return FALSE
.head 9 +  Else
.head 10 -  Return TRUE
.head 8 +  Else
.head 9 -  Set bHandlePrepared = FALSE
.head 9 -  Call SalMessageBox( 'SqlExecute had a error in PostcodeRangeExists!, Contact programmers please!', 'ERROR', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Set bOk = TRUE
.head 8 -  Set bHandlePrepared = FALSE
.head 8 +  If bHandleConnected
.head 9 -  Set bHandleConnected = FALSE
.head 9 -  Set bOk = SqlDisconnect( hSqlHandle )
.head 8 -  Return bOk

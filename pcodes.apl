.head 6 +  Message Actions
.head 7 +  On PAM_SETINSTANCEVARS
.head 8 -  Set OurColumnClass.sSQLCOLNAME = ' POSTCODES.REGION_ID '
.head 7 +  On PAM_CHECKROWNEW
.head 8 +  If SalIsNull( hWndItem )
.head 9 +  If NOT SalIsNull( dlgPostcodes.dfRegionId )
.head 10 -  Set colPCodeRegionId = dlgPostcodes.dfRegionId
.head 9 +  Else
.head 10 -  Call ErrorMessage( 'Please enter a Region Id First!', hWndForm, lParam )
.head 10 -  Return FALSE
.head 8 -  Return TRUE

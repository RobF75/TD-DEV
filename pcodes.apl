.head 6 +  Message Actions
.head 7 +  On PAM_SETINSTANCEVARS
.head 8 -  Set OurColumnClass.sSQLCOLNAME = ' POSTCODES.POSTCODE_FROM '
.head 8 -  Set OurColumnClass.bUpdate = FALSE
.head 8 -  Set OurColumnClass.bRenewRowId = TRUE
.head 8 -  Set OurColumnClass.bOrderBy = TRUE
.head 7 +  On PAM_EDITCHECK
.head 8 +  If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Return FALSE
.head 7 +  On PAM_DATAVAL
.head 8 +  If SalIsNull( colPCodeTo )
.head 9 -  Set colPCodeTo = colPCodeFrom
.head 9 -  Call SalSetFieldEdit( colPCodeTo, TRUE )
.head 8 +  If colPCodeTo < colPCodeFrom
.head 9 -  Call ErrorMessage( 'Postcode To must be greater than Postcode From!', hWndForm, lParam )
.head 9 -  Return FALSE
.head 8 +  Else
.head 9 -  Return TRUE
.head 7 +  On PAM_CHECKROWNEW
.head 8 +  If PostcodeRangeExists( colPCodeFrom, colPCodeTo, SH_cls_Execute )
.head 9 -  Call ErrorMessage( 'This postcode range already exists in this table!', hWndForm, lParam )
.head 9 -  Return FALSE
.head 8 +  Else
.head 9 -  Return TRUE
.head 7 +  ! On SAM_Validate
.head 8 +  If SalIsNull( colPCodeTo )
.head 9 -  Set colPCodeTo = colPCodeFrom
.head 9 -  Call SalSetFieldEdit( colPCodeTo, TRUE )
.head 8 -  Return SalSendClassMessage( SAM_Validate, wParam, lParam )

.head 2 +  Named Menus
.head 2 +  Internal Functions
.head 3 +  Function: CheckNPAOrderedItems
.head 4 -  Description: Checks if a customers orders have any stock items on order that
require the signing of NPAs, If yes then this function calls a dialog
that allows the removal of the order.
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  String: sCustName
.head 5 -  String: sBusName
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  Boolean: bExists
.head 5 -  Number: nCurrYr
.head 4 +  Actions
.head 5 -  Set nCurrYr = OurDateYear( SalDateCurrent(  ) )
.head 5 -  Set sSql = " SELECT Customer_Order.Cust_No 
FROM Customer_Order, Stock_Item 
WHERE 
 Customer_Order.Cust_No = :nCustNo AND 
 ( Customer_Order.Year_Of_Sale = :nCurrYr OR 
   Customer_Order.Year_Of_Sale > :nCurrYr ) AND 
 Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
 ( Stock_Item.CV_Non_Prop_Flag  = 'Y' OR 
   Stock_Item.RT_Non_Prop_Flag = 'Y' ) "
.head 5 -  ! Set sSql = ' SELECT Customer_Order.Cust_No FROM 
 Customer_Order, Stock_Item WHERE 
 Customer_Order.Cust_No = :nCustNo AND 
( Customer_Order.Year_Of_Sale = :nCurrYr OR 
  Customer_Order.Year_Of_Sale > :nCurrYr ) AND 
 Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
( EXISTS ( SELECT CV_Non_Prop_Flag FROM Cultivar WHERE 
   CULT_ID = STOCK_ITEM.CULTIVAR_ID AND CV_Non_Prop_Flag = \'Y\' ) OR 
  EXISTS ( SELECT RT_Non_Prop_Flag FROM Rootstock WHERE 
   ROOT_ID = STOCK_ITEM.ROOTSTOCK_ID AND RT_Non_Prop_Flag = \'Y\' ) ) '
.head 5 +  If SqlExists( sSql, bExists )
.head 6 +  If bExists
.head 7 -  Call PushString( sBusName )
.head 7 -  Call PushString( sCustName )
.head 7 -  Call PushNumber( nCustNo )
.head 7 -  Call SalModalDialog( dlgNPARefusal, hWndForm )
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  Else
.head 6 -  Return FALSE

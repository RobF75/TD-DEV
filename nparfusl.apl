.head 6 +  Message Actions
.head 7 +  On PAM_WHEREPOPULATE
.head 8 -  Set sBuildWhere = ' WHERE 
 CUSTOMER_ORDER.CUST_NO = :dlgNPARefusal.dfCustNo AND 
 ( CUSTOMER_ORDER.YEAR_OF_SALE = :dlgNPARefusal.dfCurrYr OR 
   CUSTOMER_ORDER.YEAR_OF_SALE > :dlgNPARefusal.dfCurrYr ) AND 
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO 
AND (STOCK_ITEM.CV_Non_Prop_Flag = \'Y\'  OR 
STOCK_ITEM.RT_Non_Prop_Flag = \'Y\'  ) '
.head 8 -  ! Set sBuildWhere = ' WHERE 
 CUSTOMER_ORDER.CUST_NO = :dlgNPARefusal.dfCustNo AND 
 ( CUSTOMER_ORDER.YEAR_OF_SALE = :dlgNPARefusal.dfCurrYr OR 
   CUSTOMER_ORDER.YEAR_OF_SALE > :dlgNPARefusal.dfCurrYr ) AND 
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND 
 STOCK_ITEM.CULTIVAR_ID = CULTIVAR.CULT_ID(+) AND 
( EXISTS ( SELECT CV_Non_Prop_Flag FROM CULTIVAR WHERE 
 CULT_ID = STOCK_ITEM.CULTIVAR_ID AND CV_Non_Prop_Flag = \'Y\'  ) OR 
 EXISTS (  SELECT RT_Non_Prop_Flag FROM ROOTSTOCK WHERE 
 ROOT_ID = STOCK_ITEM.ROOTSTOCK_ID AND RT_Non_Prop_Flag = \'Y\'  ) ) '
.head 7 +  On PAM_QBE
.head 8 -  Call PushString( NOTHINGFOLLOWING )
.head 8 -  Call PushString( ' CUSTOMER_ORDER.CUST_NO = :dlgNPARefusal.dfCustNo AND 
 ( CUSTOMER_ORDER.YEAR_OF_SALE = :dlgNPARefusal.dfCurrYr OR 
   CUSTOMER_ORDER.YEAR_OF_SALE > :dlgNPARefusal.dfCurrYr ) AND 
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND 
(STOCK_ITEM.CV_Non_Prop_Flag = \'Y\'  OR 
STOCK_ITEM.RT_Non_Prop_Flag = \'Y\' )' )
.head 8 -  ! Call PushString( ' CUSTOMER_ORDER.CUST_NO = :dlgNPARefusal.dfCustNo AND 
 ( CUSTOMER_ORDER.YEAR_OF_SALE = :dlgNPARefusal.dfCurrYr OR 
   CUSTOMER_ORDER.YEAR_OF_SALE > :dlgNPARefusal.dfCurrYr ) AND 
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND 
 STOCK_ITEM.CULTIVAR_ID = CULTIVAR.CULT_ID(+) AND 
( EXISTS ( SELECT CV_Non_Prop_Flag FROM CULTIVAR WHERE 
 CULT_ID = STOCK_ITEM.CULTIVAR_ID AND CV_Non_Prop_Flag = \'Y\'  ) OR 
 EXISTS (  SELECT RT_Non_Prop_Flag FROM ROOTSTOCK WHERE 
 ROOT_ID = STOCK_ITEM.ROOTSTOCK_ID AND RT_Non_Prop_Flag = \'Y\'  ) )' )
.head 7 +  On PAM_DATAVAL
.head 8 -  Return TRUE

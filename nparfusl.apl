.head 2 +  Window Variables
.head 3 -  Sql Handle: hSqlOrders
.head 3 -  Boolean: bSqlOrders
.head 3 -  Sql Handle: hSqlItem
.head 3 -  Boolean: bSqlItem
.head 3 -  String: sSql
.head 3 -  Boolean: bExists
.head 3 -  Number: nInd
.head 3 -  String: sSQLTABLEPOPNAME
.head 3 -  String: sSQLPOPWHERE
.head 2 +  Message Actions
.head 3 +  On SAM_Create
.head 4 -  Set bSqlOrders = SqlConnect( hSqlOrders ) 
.head 4 +  If bSqlOrders
.head 5 -  Call SqlSetLockTimeout( hSqlOrders, SQLTIMEOUT )
.head 5 -  Call SqlSetParameter( hSqlOrders, DBP_PRESERVE, TRUE, ''  )
.head 4 +  Else
.head 5 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 5 -  Return FALSE
.head 4 -  Set bSqlItem = SqlConnect( hSqlItem ) 
.head 4 +  If bSqlItem
.head 5 -  Call SqlSetLockTimeout( hSqlItem, SQLTIMEOUT )
.head 4 +  Else
.head 5 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 5 -  Return FALSE
.head 4 -  !
.head 4 -  Set dfCurrDate = SalDateCurrent(  )
.head 4 -  Set dfCurrYr = cSeasonYear.GetSeasonYear( )
.head 4 -  Call PopString( dfCustName, TRUE )
.head 4 -  Call PopString( dfBusName, TRUE )
.head 4 -  Call PopNumber( dfCustNo, TRUE )
.head 4 -  Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
.head 3 +  On SAM_Destroy
.head 4 +  If bSqlOrders
.head 5 -  Call SqlDisconnect( hSqlOrders )
.head 4 +  If bSqlItem
.head 5 -  Call SqlDisconnect( hSqlItem )
.head 3 +  On PAM_CREATECOMPLETE
.head 4 -  Call SalSendMsg( dlgNPARefusal.tblNPAOrders, PAM_POPULATE, 0, 0 )

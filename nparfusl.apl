.head 6 -  Call SalMessageBox( 'No rows were found.', 'NPA requiring Orders', MB_Ok|MB_IconAsterisk )
.head 5 +  On SAM_Create
.head 6 -  Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 -  Set bLocalSqlDoTbl = SqlConnect( hLocalSqlDoTbl ) 
.head 6 +  If bLocalSqlDoTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlDoTbl, SQLTIMEOUT )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 -  Set bEdit = FALSE
.head 6 -  Set sSQLTABLENAME = ' CUSTOMER_ORDER '
.head 6 -  Set sSQLPOPTABLENAME = ' CUSTOMER_ORDER, STOCK_ITEM '
.head 6 -  ! Set sSQLPOPTABLENAME = ' CUSTOMER_ORDER, STOCK_ITEM, CULTIVAR, ROOTSTOCK '
.head 6 -  Set sORDERBY = ' ORDER BY 1,4,5 '
.head 6 -  Set sWHEREROWID = ' WHERE ROWID = :dlgNPARefusal.tblNPAOrders.colRowId '
.head 5 +  On SAM_Destroy

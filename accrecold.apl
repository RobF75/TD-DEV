.head 3 +  ! Function: NewUnInvoice
.head 4 -  Description: Uninvoice Customer orders matching given invoice No.
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 +  Parameters 
.head 5 -  Number: nCustNo
.head 5 -  ! Number: nYear
.head 5 -  Number: nInvoiceNo
.head 5 -  Number: nActionType
.head 4 +  Static Variables 
.head 5 -  Sql Handle: hSqlOrdersHandle
.head 5 -  Boolean: bOrdersHandleConnected
.head 5 -  Boolean: bOrdersHandlePrepared
.head 4 +  Local variables 
.head 5 -  String: sSql
.head 5 -  Number: nInd
.head 5 -  Boolean: bOk
.head 5 -  !
.head 5 -  Date/Time: dtDateTime
.head 5 -  Number: nItemNo
.head 5 -  Number: nSubsItemNo
.head 5 -  Number: nConfAmt
.head 5 -  Number: nYear
.head 5 -  String: sGenericFlag
.head 4 +  Actions 
.head 5 +  Select Case nActionType
.head 6 +  Case nExecute
.head 7 -  Call SalWaitCursor( TRUE )
.head 7 +  If NOT bOrdersHandleConnected
.head 8 -  Set bOrdersHandleConnected = SqlConnect( hSqlOrdersHandle ) 
.head 8 +  If bOrdersHandleConnected
.head 9 -  Call SqlSetLockTimeout( hSqlOrdersHandle, SQLTIMEOUT )
.head 9 -  Call SqlSetParameter( hSqlOrdersHandle, DBP_PRESERVE, TRUE, ''  )
.head 8 +  Else 
.head 9 -  Call SalWaitCursor( FALSE )
.head 9 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  If NOT bOrdersHandlePrepared
.head 8 -  Set sSql = 'SELECT Order_Date_Time,
  Stock_Item_No, 
  Subs_Item_No, 
  Conf_Amt , Year_Of_Sale     
FROM  Customer_Order 
INTO :dtDateTime, :nItemNo, :nSubsItemNo, :nConfAmt, :nYear   
WHERE Cust_No = :nCustNo  AND
  Invoice_No = :nInvoiceNo '
.head 8 +  If SqlPrepare( hSqlOrdersHandle, sSql )
.head 9 -  Set bOrdersHandlePrepared = TRUE
.head 8 +  Else 
.head 9 -  Set bOrdersHandlePrepared = FALSE
.head 7 -  !
.head 7 -  Set dtDateTime = DATETIME_Null
.head 7 -  Set nItemNo = NUMBER_Null
.head 7 -  Set nSubsItemNo = NUMBER_Null
.head 7 -  Set nConfAmt = NUMBER_Null
.head 7 -  !
.head 7 +  If SqlExecute( hSqlOrdersHandle )
.head 8 +  While SqlFetchNext( hSqlOrdersHandle, nInd )
.head 9 +  If nInd = FETCH_EOF
.head 10 -  Call SalWaitCursor( FALSE )
.head 10 -  Return TRUE
.head 9 +  Else 
.head 10 +  If NewUnInvoiceCustOrder( nCustNo, dtDateTime, nExecute )
.head 11 -  Call NewUnInvoiceCustOrder( 0, DATETIME_Null, nCommit )
.head 10 +  Else 
.head 11 -  Call NewUnInvoiceCustOrder( 0, DATETIME_Null, nRollback )
.head 10 +  If nSubsItemNo > 0
.head 11 +  If NewUnInvoiceShippedForSub( nSubsItemNo, nYear, nConfAmt, nExecute )
.head 12 -  Call NewUnInvoiceShippedForSub( 0, 0, 0, nCommit )
.head 11 +  Else 
.head 12 -  Call NewUnInvoiceShippedForSub( 0, 0, 0, nRollback )
.head 11 -  Call GetGenericStockItemFlag( nItemNo, sGenericFlag, nExecute )
.head 11 +  If sGenericFlag = 'Y'
.head 12 +  If NewUnInvoiceShippedForItem( nItemNo, nYear, nConfAmt, nExecute )
.head 13 -  Call NewUnInvoiceShippedForItem( 0, 0, 0, nCommit )
.head 12 +  Else 
.head 13 -  Call NewUnInvoiceShippedForItem( 0, 0, 0, nRollback )
.head 12 -  Call NewUninvoiceRoyaltyForItem( nItemNo, nCustNo, nConfAmt, nExecute )
.head 10 +  Else 
.head 11 +  If NewUnInvoiceShippedForItem( nItemNo, nYear, nConfAmt, nExecute )
.head 12 -  Call NewUnInvoiceShippedForItem( 0, 0, 0, nCommit )
.head 11 +  Else 
.head 12 -  Call NewUnInvoiceShippedForItem( 0, 0, 0, nRollback )
.head 11 -  Call NewUninvoiceRoyaltyForItem( nItemNo, nCustNo, nConfAmt, nExecute )
.head 8 -  ! The following need to be( in this loop and not outside the loop when invoicing
on a customer basis in the customer module as this customer may be on many
loads with different invoice nos) but in this instance the invoice no will be the
same for every item
.head 8 -  !
.head 8 -  Call ReturnARBalance( nCustNo, nInvoiceNo, nExecute )
.head 8 -  !
.head 8 +  If NewUnInvoiceTotalsToFile( nInvoiceNo, nExecute )
.head 9 -  Call NewUnInvoiceTotalsToFile( 0, nCommit )
.head 8 +  Else 
.head 9 -  Call NewUnInvoiceTotalsToFile( 0, nRollback )
.head 8 +  If NewUnInvoicePOS( nCustNo, nInvoiceNo, nExecute )
.head 9 -  Call NewUnInvoicePOS( 0, 0, nCommit )
.head 8 +  Else 
.head 9 -  Call NewUnInvoicePOS( 0, 0, nRollback )
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 -  Return TRUE
.head 7 +  Else 
.head 8 -  Set bOrdersHandlePrepared = FALSE
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 -  Call SalMessageBox( 'SqlExecute had a error in function Uninvoice! Please contact programmers!', 'Error', MB_Ok )
.head 8 -  Return FALSE
.head 6 +  Case nDisconnect
.head 7 -  Set bOk = TRUE
.head 7 -  Set bOrdersHandlePrepared = FALSE
.head 7 +  If bOrdersHandleConnected
.head 8 -  Set bOrdersHandleConnected = FALSE
.head 8 +  If NOT SqlDisconnect( hSqlOrdersHandle )
.head 9 -  Set bOk = FALSE
.head 7 +  If NOT GetGenericStockItemFlag( 0, sGenericFlag, nDisconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT ReturnARBalance( 0, 0, nDisconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT NewUnInvoiceCustOrder( 0, DATETIME_Null, nDisconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT NewUnInvoiceShippedForSub( 0, 0, 0, nDisconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT NewUnInvoiceShippedForItem( 0, 0, 0, nDisconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT NewUnInvoiceTotalsToFile( 0, nDisconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT NewUnInvoicePOS( 0, 0, nDisconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT NewUninvoiceRoyaltyForItem( 0, 0, 0, nDisconnect )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case nRePrepare
.head 7 -  Set bOrdersHandlePrepared = FALSE
.head 7 -  Call GetGenericStockItemFlag( 0, sGenericFlag, nRePrepare )
.head 7 -  Call ReturnARBalance( 0, 0, nRePrepare )
.head 7 -  Call NewUnInvoiceCustOrder( 0, DATETIME_Null, nRePrepare )
.head 7 -  Call NewUnInvoiceShippedForSub( 0, 0, 0, nRePrepare )
.head 7 -  Call NewUnInvoiceShippedForItem( 0, 0, 0, nRePrepare )
.head 7 -  Call NewUnInvoiceTotalsToFile( 0, nRePrepare )
.head 7 -  Call NewUnInvoicePOS( 0, 0, nRePrepare )
.head 7 -  Call NewUninvoiceRoyaltyForItem( 0, 0, 0, nRePrepare )
.head 7 -  Return TRUE
.head 3 -  !

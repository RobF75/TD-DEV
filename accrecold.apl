.head 7 +  If bUpdtGrowingHandleConnected
.head 8 +  If NOT SqlCommit( hSqlUpdtGrowingHandle )
.head 9 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case nRollback
.head 7 -  Set bOk = TRUE
.head 7 +  If bUpdtGradedHandleConnected
.head 8 +  If NOT SqlPrepareAndExecute( hSqlUpdtGradedHandle, 'ROLLBACK' )
.head 9 -  Set bOk = FALSE
.head 8 -  Set bUpdtGradedHandlePrepared = FALSE
.head 7 +  If bUpdtGrowingHandleConnected
.head 8 +  If NOT SqlPrepareAndExecute( hSqlUpdtGrowingHandle, 'ROLLBACK' )
.head 9 -  Set bOk = FALSE
.head 8 -  Set bUpdtGrowingHandlePrepared = FALSE
.head 7 -  Return bOk
.head 6 +  Case nDisconnect
.head 7 -  Set bOk = FALSE
.head 7 -  Set bHandlePrepared = FALSE
.head 7 +  If bHandleConnected
.head 8 -  Set bHandleConnected = FALSE
.head 8 +  If NOT SqlDisconnect( hSqlHandle )
.head 9 -  Set bOk = FALSE
.head 7 -  !
.head 7 -  Set bUpdtGradedHandlePrepared = FALSE
.head 7 +  If bUpdtGradedHandleConnected
.head 8 -  Set bUpdtGradedHandleConnected = FALSE
.head 8 +  If NOT SqlDisconnect( hSqlUpdtGradedHandle )
.head 9 -  Set bOk = FALSE
.head 7 -  !
.head 7 -  Set bUpdtGrowingHandlePrepared = FALSE
.head 7 +  If bUpdtGrowingHandleConnected
.head 8 -  Set bUpdtGrowingHandleConnected = FALSE
.head 8 +  If NOT SqlDisconnect( hSqlUpdtGrowingHandle )
.head 9 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case nRePrepare
.head 7 -  Set bHandlePrepared = FALSE
.head 7 -  Set bUpdtGradedHandlePrepared = FALSE
.head 7 -  Set bUpdtGrowingHandlePrepared = FALSE
.head 7 -  Return TRUE
.head 3 +  ! Function: NewUnInvoiceCustOrder
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 +  Parameters 
.head 5 -  Number: nCustNo

.head 5 -  Number: nActionType
.head 4 +  Static Variables 
.head 5 -  Sql Handle: hSqlHandle
.head 5 -  Boolean: bHandleConnected
.head 5 -  Boolean: bHandlePrepared
.head 4 +  Local variables 
.head 5 -  String: sSql
.head 5 -  Boolean: bOk
.head 4 +  Actions 
.head 5 +  Select Case nActionType
.head 6 +  Case nExecute
.head 7 +  If NOT bHandleConnected
.head 8 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 8 +  If bHandleConnected
.head 9 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 9 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 8 +  Else 
.head 9 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  If NOT bHandlePrepared
.head 8 -  Set sSql = " UPDATE Customer_Order SET Invoiced_Flag = 'N',
 Invoice_No = NULL, Invoiced_Date = NULL, Invoiced_By = NULL
WHERE Cust_No = :nCustNo AND 
  Order_Date_Time = :dtOrderDateTime "
.head 8 +  If SqlPrepare( hSqlHandle, sSql )
.head 9 -  Set bHandlePrepared = TRUE
.head 8 +  Else 
.head 9 -  Set bHandlePrepared = FALSE
.head 7 -  !
.head 7 +  If SqlExecute( hSqlHandle )
.head 8 -  Return TRUE
.head 7 +  Else 
.head 8 -  Set bHandlePrepared = FALSE
.head 8 -  Return FALSE
.head 6 +  Case nCommit
.head 7 -  Set bOk = TRUE
.head 7 +  If bHandleConnected
.head 8 -  Set bOk = SqlCommit( hSqlHandle )
.head 7 -  Return bOk
.head 6 +  Case nRollback
.head 7 -  Set bOk = TRUE
.head 7 +  If bHandleConnected
.head 8 -  Set bOk = SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
.head 8 -  Set bHandlePrepared = FALSE
.head 7 -  Return bOk
.head 6 +  Case nDisconnect
.head 7 -  Set bOk = FALSE
.head 7 -  Set bHandlePrepared = FALSE
.head 7 +  If bHandleConnected
.head 8 -  Set bHandleConnected = FALSE
.head 8 -  Set bOk = SqlDisconnect( hSqlHandle )
.head 7 -  Return bOk
.head 6 +  Case nRePrepare
.head 7 -  Set bHandlePrepared = FALSE
.head 7 -  Return TRUE

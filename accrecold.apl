.head 5 -  Number: nInd
.head 4 +  Actions 
.head 5 +  If NOT bHdlDepAmtConnected
.head 6 -  Set bHdlDepAmtConnected = SqlConnect( hSqlHdlDepAmt ) 
.head 6 +  If bHdlDepAmtConnected
.head 7 -  Call SqlSetLockTimeout( hSqlHdlDepAmt, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hSqlHdlDepAmt, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else 
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 5 +  If NOT bHdlDepAmtPrepared
.head 6 -  ! Set sgSql =  'SELECT Dep_Amount_Paid,Receipt_User_Id,Rcpt_Sysdatetime
 FROM Outstand_Deposit INTO :ngAmtPaid, :sgRcptUser, :dgRcptDateTime
 WHERE Cust_No = :nCustNo AND Dep_Year_Of_Sale = :nYear'
.head 6 -  Call CallBuildSql(  hWndCalledFrom,nSELECT, PAM_OUTSDEPSQL, OUTSTDEPOSIT, '' )
.head 6 -  Set sWhere = ' WHERE Cust_No = :nCustNo AND Dep_Year_Of_Sale = :nYear' 
.head 6 -  Set sgSql = sgSql||sWhere
.head 6 +  If SqlPrepare( hSqlHdlDepAmt, sgSql )
.head 7 -  Set bHdlDepAmtPrepared = TRUE
.head 6 +  Else 
.head 7 -  Set bHdlDepAmtPrepared = FALSE
.head 5 -  !
.head 5 +  ! If NOT bHdlAmtUnAplidConnected
.head 6 -  Set bHdlAmtUnAplidConnected = SqlConnect( hSqlHdlAmtUnAplid ) 
.head 6 +  If bHdlAmtUnAplidConnected
.head 7 -  Call SqlSetLockTimeout( hSqlHdlAmtUnAplid, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hSqlHdlAmtUnAplid, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else 
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 5 +  ! If NOT bHdlAmtUnAplidPrepared
.head 6 -  Set sgSql =  'SELECT Amount_Unapplied, Receipt_Amount  FROM Cash_Receipt
 INTO :ngUnappliedAmt, :ngRcptAmt
 WHERE Receipt_User_Id = :sgRcptUser AND Rcpt_Sysdatetime = :dgRcptDateTime'
.head 6 +  If SqlPrepare( hSqlHdlAmtUnAplid, sgSql )
.head 7 -  Set bHdlAmtUnAplidPrepared = TRUE
.head 6 +  Else 
.head 7 -  Set bHdlAmtUnAplidPrepared = FALSE
.head 5 -  !
.head 5 +  If SqlExecute( hSqlHdlDepAmt )
.head 6 -  Call SqlFetchNext( hSqlHdlDepAmt, nInd )
.head 6 +  If nInd = FETCH_Ok
.head 7 -  Set sgRcptUser = ''
.head 7 -  Call SalSendMsgToChildren( hWndCalledFrom, PAM_OUTDEPGLOBALS, 0, 0 )
.head 7 -  Set nDeposit = ngAmtPaid
.head 7 +  If sgRcptUser = ''
.head 8 -  Return TRUE
.head 5 +  Else 
.head 6 -  Set bHdlDepAmtPrepared = FALSE
.head 6 -  Return TRUE
.head 5 -  ! To be past here there is a record in the outstanding deposit file, we now need
to know if any has already been used
.head 5 -  ! Set ngUnappliedAmt = 0
.head 5 -  ! Set ngRcptAmt = 0
.head 5 -  !
.head 5 +  ! If SqlExecute( hSqlHdlAmtUnAplid )
.head 6 -  Call SqlFetchNext( hSqlHdlAmtUnAplid, nInd )
.head 6 +  If ngUnappliedAmt > 0
.head 7 -  ! Then we need to use the amount unapplied 
.head 7 -  Set nDeposit = ngUnappliedAmt
.head 6 +  Else 
.head 7 -  ! Then we need to set the deposit to the total deposit amount paid which is
the same as the receipt amount of the cash receipt record
.head 7 -  Set nDeposit = ngAmtPaid
.head 5 +  ! Else 
.head 6 -  Set bHdlAmtUnAplidPrepared = FALSE
.head 6 -  Return TRUE
.head 5 -  !
.head 5 -  ! Cant set the deposit to the invoice total if it is less than it as it hasnt been 
calculated yet, do it when extendprices is being done on the colDeposit
.head 5 -  Return TRUE
.head 3 +  ! Function: UpdateInvoiceTotalsToFile
.head 4 -  Description: To actually write out to file the specific charges and invoice totals etc 
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 +  Parameters 
.head 5 -  Window Handle: hWndCalledFrom
.head 5 -  Number: nDeposit
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  Sql Handle: hSqlUpdateHandle
.head 5 -  Boolean: bSqlUpdateHandle
.head 5 -  String: sWhere
.head 5 -  !
.head 5 -  String: sAppliedFlag
.head 5 -  Date/Time: dDepDateTime
.head 5 -  String: sDepUser
.head 5 -  Number: nTotInvoice
.head 5 -  String: sTransUser
.head 5 -  Date/Time: dTransDateTime
.head 4 +  Actions 
.head 5 -  Set bSqlUpdateHandle = SqlConnect( hSqlUpdateHandle ) 
.head 5 +  If bSqlUpdateHandle
.head 6 -  Call SqlSetLockTimeout( hSqlUpdateHandle, SQLTIMEOUT )
.head 5 +  Else 
.head 6 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -  Return FALSE
.head 5 -  ! Need to add a record into the transaction file first, then using the keys of the
transaction file(noting that the transaction amount needs to be the gross total
invoice, and the transaction amount outstanding needs to be the transaction 
amount minus any deposit paid (found from coldeposit)) and the cash receipt
key. 
.head 5 -  Call SalSendMsgToChildren( hWndCalledFrom, PAM_SETTRANSEDIT, 0, 0 )
.head 5 -  Call CallBuildSql(  hWndCalledFrom,nINSERT, PAM_TRANSSQL, TRANSACTION, '' )
.head 5 +  If NOT MySqlPrepExec( hSqlUpdateHandle, sgSql )
.head 6 -  Call MySqlPrepExec( hSqlUpdateHandle, 'rollback' )
.head 6 +  If bSqlUpdateHandle
.head 7 -  Call SqlDisconnect( hSqlUpdateHandle )
.head 6 -  Call SalMessageBox( 'Contact programmers.  Have been unable to insert a
transaction record for this invoice', 'Invoicing Error', MB_Ok )
.head 6 -  Return FALSE
.head 5 +  Else 
.head 6 -  Call SalSendMsgToChildren( hWndCalledFrom, PAM_ADJUSTARBALANCE, 0, 0 )
.head 6 -  Set hWndTmp = hWndCalledFrom
.head 6 +  If TYPE_ChildTable = SalGetType( hWndCalledFrom )
.head 7 -  Set sWhere = ' WHERE Cust_No = :hWndTmp.colCustno '
.head 6 +  Else 
.head 7 -  Set sWhere = ' WHERE Cust_No = :hWndTmp.dfCustNo '
.head 6 +  If NOT UpdateCustARBalRecord( ' CUSTOMER_MASTER ', sWhere, hWndCalledFrom, PAM_UPDATECUST, 0, nExecute )
.head 7 -  Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nRollback )
.head 7 -  Call SalMessageBox( 'Contact programmers.  Have been unable to update a
customer AR Balance record for this invoice', 'Invoicing Error', MB_Ok )
.head 7 -  Return FALSE
.head 6 +  If sgRcptUser = ''
.head 7 -  Call SqlCommit( hSqlUpdateHandle )
.head 7 -  Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nCommit )
.head 7 +  If bSqlUpdateHandle
.head 8 -  Call SqlDisconnect( hSqlUpdateHandle )
.head 7 -  Return TRUE
.head 5 -  !
.head 5 -  !
.head 5 -  ! If sgRcptUser is not spaces, then a deposit has been paid for and used in this
invoice so we need to record all the details and write the cash application records etc
.head 5 +  ! If sgRcptUser = ''
.head 6 +  If bOk
.head 7 -  Call SqlCommit( hSqlUpdateHandle )
.head 7 +  If bSqlUpdateHandle
.head 8 -  Call SqlDisconnect( hSqlUpdateHandle )
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Call MySqlPrepExec( hSqlUpdateHandle, 'rollback' )
.head 7 +  If bSqlUpdateHandle
.head 8 -  Call SqlDisconnect( hSqlUpdateHandle )
.head 7 -  Return TRUE
.head 5 -  Call CallBuildSql(  hWndCalledFrom,nINSERT, PAM_CSHAPPLICSQL, CASHAPPLIC, '' )
.head 5 +  If NOT MySqlPrepExec( hSqlUpdateHandle, sgSql )
.head 6 -  Call MySqlPrepExec( hSqlUpdateHandle, 'rollback' )
.head 6 -  Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nRollback )
.head 6 +  If bSqlUpdateHandle
.head 7 -  Call SqlDisconnect( hSqlUpdateHandle )
.head 6 -  Call SalMessageBox( 'Contact programmers.  Have been unable to insert a
cash application record for this deposit', 'Invoicing Error', MB_Ok )
.head 6 -  Return FALSE
.head 5 -  ! Then need to update the record in the cash receipt file with the fully applied flag
depending on whether it is or not, and the unapplied amount (if there is).
Need to check if the colDeposit is the same as the outstanding deposit amount
if not, then we need to update the amt unapplied of the cash receipt with the
adjusted amount because the only reason they would be different is if the 
amt to apply (eg the deposit) is greater than the invoice total
.head 5 -  ! Need to check the cash receipt record to see whether we can set the fully applied
flag either by checking the colDeposit.We first need to see if there is an amount
unapplied > 0, if so, adjust this field.  If not then we need to compare against
the cash receipt amount to see if we can fully apply this
.head 5 -  ! The select for this was done in process deposit int function so values are already
set for the unapplied amt and the receipt amt 
.head 5 -  ! 31/10/94 Originally we needed to check the cash receipt record and the applied amount
of the cash application record to see how much had been used of a deposit against an
invoice - if it was in the outstanding deposit file and there were records in the cash application
file with it - it was getting too complex - now, if a deposit is not totally used up against an
invoice we will write the used amount into the deposit history file and reinsert the left over
deposit into the oustanding deposit file with a new key but the same receipt key so that if
ever we need to identify what the total deposit was it is the sum of records in the outstanding
deposit and deposit history file 
.head 5 +  If nDeposit = ngAmtPaid
.head 6 -  Call SalSendMsgToChildren(  hWndCalledFrom, PAM_FULLYAPPLY, 0, 0 )
.head 5 +  Else 
.head 6 -  Call SalSendMsgToChildren(  hWndCalledFrom, PAM_NOTFULLYAPPLY, 0, 0 )
.head 5 -  Call CallBuildSql(  hWndCalledFrom,nUPDATE, PAM_CSHRCPTSQL,
 CASHRCPT, CASHRCPTWHERE )
.head 5 +  If NOT MySqlPrepExec( hSqlUpdateHandle, sgSql )
.head 6 -  Call MySqlPrepExec( hSqlUpdateHandle, 'rollback' )
.head 6 -  Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nRollback )
.head 6 +  If bSqlUpdateHandle
.head 7 -  Call SqlDisconnect( hSqlUpdateHandle )
.head 6 -  Call SalMessageBox( 'Contact programmers.  Have been unable to update the
cash receipt record for this deposit with the applied flag', 'Invoicing Error', MB_Ok )
.head 6 -  Return FALSE

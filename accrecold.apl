.head 7 -  Set bOk = TRUE
.head 7 +  If bHandleConnected
.head 8 +  If NOT SqlCommit( hSqlHandle )
.head 9 -  Set bOk = FALSE
.head 7 -  Return TRUE
.head 6 +  Case nRollback
.head 7 -  Set bOk = TRUE
.head 7 +  If bHandleConnected
.head 8 +  If NOT SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
.head 9 -  Set bOk = FALSE
.head 8 -  Set bHandlePrepared = FALSE
.head 7 -  Return TRUE

.head 4 +  Actions 
.head 5 +  Select Case nActionType
.head 6 +  Case nExecute
.head 7 +  If NOT bHandleConnected
.head 8 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 8 +  If bHandleConnected
.head 9 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 9 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 8 +  Else 
.head 9 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  If NOT bHandlePrepared
.head 8 -  Set sSql = ' SELECT Cultivar_Id, Rootstock_Id FROM Stock_Item
INTO :sCultId, :sRootId WHERE Item_No = :nItemNo'
.head 8 +  If SqlPrepare( hSqlHandle, sSql )
.head 9 -  Set bHandlePrepared = TRUE
.head 8 +  Else 
.head 9 -  Set bHandlePrepared = FALSE
.head 7 +  If SqlExecute( hSqlHandle )
.head 8 +  If SqlFetchNext( hSqlHandle, nInd )
.head 9 +  If nInd != FETCH_EOF
.head 10 +  If NOT sRootId = ''
.head 11 +  If NewUpdateRoyaltyOwnerTotal( nCustNo, nHowMany, nDebitRoy, sRootId, nRootstockId, nExecute )
.head 12 -  Call NewUpdateRoyaltyOwnerTotal( 0, 0, 0, '', 0, nCommit )
.head 11 +  Else 
.head 12 -  Call NewUpdateRoyaltyOwnerTotal( 0, 0, 0, '', 0, nRollback )
.head 10 +  If NOT sCultId = ''
.head 11 +  If NewUpdateRoyaltyOwnerTotal( nCustNo, nHowMany, nDebitRoy, sCultId, nCultivarId, nExecute )
.head 12 -  Call NewUpdateRoyaltyOwnerTotal( 0, 0, 0, '', 0, nCommit )
.head 11 +  Else 
.head 12 -  Call NewUpdateRoyaltyOwnerTotal( 0, 0, 0, '', 0, nRollback )
.head 8 -  Return TRUE
.head 7 +  Else 
.head 8 -  Set bHandlePrepared = FALSE
.head 8 -  Call SalMessageBox( 'SqlExecute had a error in UninvoiceRoyaltyForItem!, Contact programmers please!', 'ERROR', MB_Ok )
.head 8 -  Return FALSE
.head 6 +  Case nCommit
.head 7 -  Set bOk = TRUE
.head 7 +  If bHandleConnected
.head 8 +  If NOT SqlCommit( hSqlHandle )
.head 9 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case nRollback
.head 7 -  Set bOk = TRUE
.head 7 +  If bHandleConnected
.head 8 +  If NOT SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
.head 9 -  Set bOk = FALSE
.head 8 -  Set bHandlePrepared = FALSE
.head 7 -  Return bOk
.head 6 +  Case nDisconnect
.head 7 -  Set bOk = TRUE
.head 7 -  Set bHandlePrepared = FALSE

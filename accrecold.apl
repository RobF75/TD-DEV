.head 5 +  Select Case nActionType
.head 6 +  Case nExecute
.head 7 +  If NOT bHandleConnected
.head 8 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 8 +  If bHandleConnected
.head 9 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 9 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 8 +  Else 
.head 9 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  If NOT bHandlePrepared
.head 8 -  Set sSql = ' SELECT Customer_Master.FNA_Flag,
 Customer_Master.Royalty_Owner_Code, 
 Customer_Type.FMN_Roy_Payable 
FROM Customer_Master, Customer_Type 
INTO :sFNAFlag, :sCustOwnerCode, :sFMNFlag 
WHERE Cust_No = :nCustNo AND 
Customer_Master.Customer_Type = Customer_Type.Cust_Type'
.head 8 +  If SqlPrepare( hSqlHandle, sSql )
.head 9 -  Set bHandlePrepared = TRUE
.head 8 +  Else 
.head 9 -  Set bHandlePrepared = FALSE
.head 7 -  Set sFMNFlag = ' '
.head 7 -  Set sFNAFlag = ' '
.head 7 +  If SqlExecute( hSqlHandle )
.head 8 +  If SqlFetchNext( hSqlHandle, nInd )
.head 9 +  If nInd = FETCH_EOF
.head 10 -  Return FALSE
.head 9 -  Set sRoyOwnerCode = sCustOwnerCode
.head 9 +  If sFMNFlag = 'N'
.head 10 -  Set bIsCustFMN = TRUE
.head 9 +  Else 
.head 10 -  Set bIsCustFMN = FALSE
.head 9 +  If sFNAFlag = 'Y'
.head 10 -  Set bIsCustFNA = TRUE
.head 9 +  Else 
.head 10 -  Set bIsCustFNA = FALSE
.head 9 -  Return TRUE
.head 8 +  Else 
.head 9 -  Return FALSE
.head 7 +  Else 
.head 8 -  Set bHandlePrepared = FALSE
.head 8 -  Call SalMessageBox( 'SqlExecute had a error in CustFMNFNA!, Contact programmers please!', 'ERROR', MB_Ok )
.head 8 -  Return FALSE

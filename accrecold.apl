.head 2 +  Named Menus
.head 2 +  Internal Functions
.head 3 +  ! Function: GetNextInvoiceNoToUse
.head 4 -  Description: Read the customer order file to obtain the last invoice number to use
and then display this in a dialog box asking for the invoice no to use
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 -  Parameters 
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  Number: nOrdInvNo
.head 5 -  Number: nPromoInvNo
.head 5 -  !
.head 5 -  Sql Handle: hLocalSqlNext
.head 5 -  Boolean: bLocalSqlNext
.head 4 +  Actions 
.head 5 -  ! LOCAL SQL HANDLE CONNECTION ESTABLISHED HERE AND CLOSE AT END.
.head 5 -  Set bLocalSqlNext = SqlConnect( hLocalSqlNext ) 
.head 5 +  If bLocalSqlNext
.head 6 -  Call SqlSetLockTimeout( hLocalSqlNext, SQLTIMEOUT )
.head 5 +  Else 
.head 6 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 6 -  Return FALSE
.head 5 -  !
.head 5 +  If SqlPrepare( hLocalSqlNext,
  'SELECT MAX( INVOICE_NO ) + 1 ' ||
  'FROM CUSTOMER_ORDER ' ||
  'INTO :nOrdInvNo' )
.head 6 +  If SqlExecute( hLocalSqlNext )
.head 7 -  Call SqlFetchNext( hLocalSqlNext, ngFetch )
.head 7 -  ! Return TRUE
.head 5 +  If SqlPrepare( hLocalSqlNext,
  'SELECT MAX( PROMO_INVOICE_NO ) + 1 ' ||
  'FROM CUST_PROMO ' ||
  'INTO :nPromoInvNo' )
.head 6 +  If SqlExecute( hLocalSqlNext )
.head 7 -  Call SqlFetchNext( hLocalSqlNext, ngFetch )
.head 7 -  ! Return TRUE
.head 5 +  If nPromoInvNo <= nOrdInvNo
.head 6 -  Set ngInvNo = nOrdInvNo
.head 5 +  Else 
.head 6 -  Set ngInvNo = nPromoInvNo
.head 5 +  If SalModalDialog( dlgInvNo, hWndForm )
.head 6 -  Return TRUE
.head 5 +  Else 
.head 6 -  Return FALSE
.head 5 -  ! LOCAL SQL HANDLE CLOSURE
.head 5 +  If bLocalSqlNext
.head 6 -  Call SqlDisconnect( hLocalSqlNext )
.head 3 +  ! Function: IsUniqueInvNo
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 +  Parameters 
.head 5 -  Number: nInvNo
.head 5 -  Receive Boolean: bUnique
.head 5 -  Number: nExecuteOrDisconnect
.head 4 +  Static Variables 
.head 5 -  Sql Handle: hSqlCOHandle
.head 5 -  Boolean: bCOHandleConnected
.head 5 -  Boolean: bCOHandlePrepared
.head 5 -  !
.head 5 -  Sql Handle: hSqlCOHHandle
.head 5 -  Boolean: bCOHHandleConnected
.head 5 -  Boolean: bCOHHandlePrepared
.head 5 -  !
.head 5 -  Sql Handle: hSqlCPHandle
.head 5 -  Boolean: bCPHandleConnected
.head 5 -  Boolean: bCPHandlePrepared
.head 4 +  Local variables 
.head 5 -  String: sSql
.head 5 -  Number: nInd
.head 5 -  Boolean: bOk
.head 4 +  Actions 
.head 5 +  If nExecuteOrDisconnect != nDisconnect
.head 6 +  If NOT bCOHandleConnected
.head 7 -  Set bCOHandleConnected = SqlConnect( hSqlCOHandle ) 
.head 7 +  If bCOHandleConnected
.head 8 -  Call SqlSetLockTimeout( hSqlCOHandle, SQLTIMEOUT )
.head 8 -  Call SqlSetParameter( hSqlCOHandle, DBP_PRESERVE, TRUE, ''  )
.head 7 +  Else 
.head 8 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 8 -  Return FALSE
.head 6 +  If NOT bCOHandlePrepared
.head 7 -  Set sSql = ' SELECT Invoice_No FROM Customer_Order WHERE Invoice_No = :nInvNo '
.head 7 +  If SqlPrepare( hSqlCOHandle, sSql )
.head 8 -  Set bCOHandlePrepared = TRUE
.head 7 +  Else 
.head 8 -  Set bCOHandlePrepared = FALSE
.head 6 -  !
.head 6 -  Set bUnique = TRUE
.head 6 +  If SqlExecute( hSqlCOHandle )
.head 7 +  If SqlFetchNext( hSqlCOHandle, nInd )
.head 8 -  Set bUnique = FALSE
.head 8 -  Return TRUE
.head 7 -  !
.head 7 +  If NOT bCOHHandleConnected
.head 8 -  Set bCOHHandleConnected = SqlConnect( hSqlCOHHandle ) 
.head 8 +  If bCOHHandleConnected
.head 9 -  Call SqlSetLockTimeout( hSqlCOHHandle, SQLTIMEOUT )
.head 9 -  Call SqlSetParameter( hSqlCOHHandle, DBP_PRESERVE, TRUE, ''  )
.head 8 +  Else 
.head 9 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 9 -  Return FALSE

.head 8 -  Return TRUE
.head 7 -  Call CustOrdHistInvExists( nInvNo, bExists, nExecute )
.head 7 +  If bExists
.head 8 -  Set bUnique = FALSE
.head 8 -  Return TRUE
.head 7 -  Call CustPromoInvExists( nInvNo, bExists, nExecute )

.head 5 +  On SAM_Create
.head 6 -  Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
.head 6 +  If bLocalSqlPopTbl
.head 7 -  Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
.head 7 -  Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 7 -  Return FALSE

.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 -  Set sSQLPopHandle = "
SELECT
	Supp_Order_OrdDT,
	si.Supplier_Item_Id,
	Description,
	Order_Multiples,
	Unit_Of_Measure,
	Price_Per_Multiple,
	Stock_On_Hand,
	Order_Quantity,
	Order_Sent_Date,
	Purchase_Order
FROM
	Supplier_items si,
	Supplier_Orders so
WHERE
	so.Supplier_Item_Id = si.Supplier_Item_Id and
	si.cust_no = :1 and
	Order_Sent_Date is NULL
ORDER BY
	Purchase_Order, Description"

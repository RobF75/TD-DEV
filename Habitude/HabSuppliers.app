.head 7 +  On PAM_SUPPLYORDERSUBMIT
.head 8 -  Set dtOrderDate = SalDateCurrent( )
.head 8 -  Call SalDateToStr( dtOrderDate, sMessageText )
.head 8 -  Call GetNextPurchaseOrder(  nPurchaseOrderNo, SH_cls_Execute )
.head 8 -  Set sPurchaseOrderNo = 'e00' || SalNumberToStrX( nPurchaseOrderNo, 0 )
.head 8 +  If IDYES = SalMessageBox('Press YES to send this purchase order now, or NO to save it to send it later.', 'Puchase Order Sending', MB_YesNo)
.head 9 -  Set sMessageText = sMessageText || '

Purchase Order #: ' || sPurchaseOrderNo || '

Dear ' || sSupplierContact || ',
Please accept an order for:

'
.head 9 -  Call TableLoop( tblItems, tblItems, PAM_SUPPLYORDERPROCESS, ROW_Selected, 0, 0, 'Submitting Order', TBL_cls_LowToHiWithPositioning )
.head 9 -  Call GetRegistryValue( 'GENERAL', 'eMailSenderName', sSenderName, '' )
.head 9 -  Call GetRegistryValue( 'GENERAL', 'eMailSenderAddress', sSenderEmail, 'gfleming@flemings.com.au' )
.head 9 -  Set sMessageText = sMessageText || '

If any of the items above are not immediately available please notify sender via return mail.

'  || sSenderName || '
' || sSenderEmail
.head 9 +  ! If fnEX_CustCreateFile( 0, colCustNo, nSupplierId, 'PUR_ORDER', nPurchaseOrderNo, dtOrderDate, hEX_SuppPOFormatFile )
.head 10 -  Set bEX_SuppPOFileOpened = TRUE
.head 9 -  Call GetRegistryValue( 'GENERAL', 'AccountsManager', sAccountsUser, 'gfleming@flemings.com.au' )
.head 9 -  Call SendMail( 'Purchase Order #: ' || sPurchaseOrderNo, sMessageText, sSupplierEmail, sAccountsUser, 'gfleming@flemings.com.au', '' )
.head 9 -  Call InsertPurshaseOrder( dtOrderDate, nSupplierId, colSupplierItemNo, colOrderQuantity / colMultiples, nPurchaseOrderNo, 'Y', SqlUser, SH_cls_Execute )
.head 8 +  Else 
.head 9 -  Call InsertPurshaseOrder( dtOrderDate, nSupplierId, colSupplierItemNo, colOrderQuantity / colMultiples, nPurchaseOrderNo, 'N', STRING_Null, SH_cls_Execute )

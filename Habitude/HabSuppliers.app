.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 -  Set sSQLPopHandle = "
SELECT
	cm.Cust_No,
	Cust_Name,
	Contact_Given_Name || ' ' || Contact_Surname,
	wrk_phone_code || ' ' || Contact_work_phone,
	ca.Email
FROM
	customer_master cm,
	customer_contacts cc,
	Customer_address ca
WHERE
	cm.cust_no = cc.cust_no and
	ca.cust_no = cm.cust_no and
	main_contact_flag = 'Y' and
	Cust_Or_Supplier = 'S' and 
	Main_Address_Flag = 'Y'
ORDER BY
	2"
.head 8 -  Set sNAMEPopHandle = '2105GetSuppliers1'
.head 8 -  Set sBINDPopHandle = ''
.head 8 -  Set sINTOPopHandle = ':clsfrmSuppliers.tblSuppliers.colSupplierNo,
:clsfrmSuppliers.tblSuppliers.colSupplierName,
:clsfrmSuppliers.tblSuppliers.colContact,
:clsfrmSuppliers.tblSuppliers.colPhone,
:clsfrmSuppliers.tblSuppliers.colEmail'
.head 8 -  !
.head 8 +  If TRUE
.head 9 -  !
.head 9 -  ! Set sSQLUpdateHandle = ' UPDATE 
	Graded_Pallets
SET
  	Processed_By = :2,
	Processed_Date = :3,
	Entered_By = :4,
	Pallet_Number = :5
WHERE
	Pallet_DateTime = :1 '
.head 9 -  ! Set sNAMEUpdateHandle = '0705UpdatePallets1'
.head 9 -  ! Set sBINDUpdateHandle = ':clsfrmSuppliers.tblSuppliers.colDate,

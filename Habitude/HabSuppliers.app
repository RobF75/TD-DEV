.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Call GetCustElectronicDetails( nCustNo, sCustName, sPartnerId, sGLNId, sPayerGLNId, sTestFlag, sBuyerId, SH_cls_Execute )
.head 7 -  Set sLine = ''
.head 7 -  Set sLine = sLine || fnEX_StringField( sPartnerId, 15, 'N' ) || ',' 			! Trading Partner Id		Agreed Trading Partner Id, 1st 4 Char of CustName || FLEM
.head 7 -  Set sLine = sLine || fnEX_StringField( sGLNId, 35, 'N' ) || ',' 			! Trading Partner GLIN
.head 7 -  Set sLine = sLine || fnEX_StringField( sBuyerId, 35, 'N' ) || ',' 			! Buyer Id
.head 7 -  Set sLine = sLine || fnEX_StringField( 'Flemings Nurseries', 35, 'N'  ) || ',' 			! Buyer Name
.head 7 -  Set sLine = sLine || fnEX_StringField( 'Brendan Byatt', 35, 'N'  ) || ',' 			! Buyer contact
.head 7 -  Set sLine = sLine || fnEX_StringField( '03 9756 6105', 35, 'N'  ) || ',' 			! Ship To Name
.head 7 -  Set sLine = sLine || fnEX_StringField( '9317036000007', 35, 'N'  ) || ',' 			! Payer Id
.head 7 -  Set sLine = sLine || fnEX_StringField( '9317036000007', 35, 'N'  ) || ',' 			! Payer Id
.head 7 -  Set sLine = sLine || fnEX_StringField( 'Flemings Nurseries', 35, 'N'  ) || ',' 			! Ship To Name
.head 7 -  Set sLine = sLine || fnEX_StringField( 'Fleming Lane', 35, 'N'  ) || ',' 			! Ship To Address 1
.head 7 -  Set sLine = sLine || ',' 							! Ship To Address 2
.head 7 -  Set sLine = sLine || fnEX_StringField( 'Monbulk', 35, 'N'  ) || ',' 			! Ship To Town
.head 7 -  Set sLine = sLine || fnEX_StringField( 'VIC', 9, 'N'  ) || ',' 			! Ship To State
.head 7 -  Set sLine = sLine || fnEX_StringField( '3793', 9, 'N'  ) || ',' 			! Ship To State
.head 7 -  Set sLine = sLine || ',' 							! Ship To Country
.head 7 -  Set sLine = sLine || fnEX_StringField( SqlUser, 35, 'N'  ) || ',' 			! Ship To Contact
.head 7 -  Set sLine = sLine || fnEX_StringField( '03 9756 6105', 35, 'N'  ) || ',' 			! Ship To Contact
.head 7 -  !
.head 7 -  Set sLine = sLine || ',' 			! Currency
.head 7 -  Set sLine = sLine || fnEX_StringField( 'PO', 15, 'N'  ) || ',' 		! Document Type	PO = Purchase Order
.head 7 +  If SqlDatabase != 'STOCK' or sTestFlag = 'Y'				! Test Indicator
.head 8 -  Set sLine = sLine || fnEX_StringField( 'T', 1, 'N'  ) || ','
.head 7 +  Else
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 1, 'N'  ) || ','
.head 7 -  Set sLine = sLine || fnEX_StringField( '1.0', 3, 'N' ) || ',' 			! HIWG Flat File Version
.head 7 -  Set sLine = sLine || fnEX_DateField( dtCreationDate, 'yyyyMMdd', 8, 'N'  ) || ',' 	! C32 PO Date		PO Date - format YYYYMMDD
.head 7 -  Set sLine = sLine || fnEX_DateField( dtCreationDate, 'yyyyMMddhhmmss', 14, 'N'  ) || ',' 	! C33 PO Creation Date		PO Date - format yyyyMMddhhmmss
.head 7 -  Set sLine = sLine || fnEX_StringField( '10', 2, 'N'  ) || ',' 			! Record Type	10 = Header 20 = Detail
.head 7 -  Set sLine = sLine || fnEX_StringField( sPurchaseOrderNo, 35, 'N' ) || ',' 			! PO Number
.head 7 -  Set sLine = sLine || ',,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,' 					! Extra Stuff
.head 7 +  If SqlDatabase != 'STOCK' or sTestFlag = 'Y'				! Test Indicator	Invoice Line Number
.head 8 -  Set sLine = sLine || fnEX_StringField( 'Last Column for testing only.', 30, 'N'  ) || ','
.head 7 -  ! Call GetRegistryValue( 'ACCOUNTS', 'GSTPercent', sTmp, '0.1' )
.head 7 -  ! Set nGSTPercent = SalStrToNumber( sTmp )
.head 7 +  ! If (colDelCharge + colPackCharge + colLabelCharge) != 0
.head 8 -  Set sLine = sLine || fnEX_StringField( '388', 3, 'N'  ) || ',' 			! Header Charge Code
.head 8 -  Set sLine = sLine || fnEX_NumberField( colDelCharge + colPackCharge + colLabelCharge , 2, 18, '' , 'N' ) || ',' 		! Extra's charges
.head 8 -  Set sLine = sLine || fnEX_NumberField( (nGSTPercent * (colDelCharge + colPackCharge + colLabelCharge)) , 2, 18, '' , 'N' ) || ',' 		! GST Charges
.head 7 +  ! Else
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 3, 'N'  ) || ',' 			! Header Charge Code
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 3, 'N'  ) || ',' 			! Extra's charges
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 3, 'N'  ) || ',' 			! GST charges
.head 7 -  ! Set sLine = sLine || fnEX_NumberField(  colCustTotalExtPrice + colCustTotalExtRoyalty, 2, 18, '' , 'N' ) || ',' 		! DelNote		Delivery Note Number
.head 7 -  ! Set sLine = sLine || fnEX_NumberField(  nGSTPercent * (colCustTotalExtPrice + colCustTotalExtRoyalty), 2, 18, '' , 'N' ) || ',' 		! DelNote		Delivery Note Number
.head 7 -  ! Set sLine = sLine || fnEX_NumberField(  colCustTotalExtPrice + colCustTotalExtRoyalty + colGSTComponent, 2, 18, '' , 'N' ) || ',' 		! DelNote		Delivery Note Number
.head 7 -  ! Set sLine = sLine || fnEX_NumberField(  colDepositPaid, 2, 18, '' , 'N' ) || ',' 		! DelNote		Delivery Note Number
.head 7 -  ! Set sLine = sLine || ',,,,,,,,,,,'						! Extra Stuff
.head 7 +  ! If TRUE
.head 8 -  Call GetRegistryValue( 'ACCOUNTS', 'GSTPercent', sTmp, '0.1' )
.head 8 -  Set nGSTPercent = SalStrToNumber( sTmp )
.head 8 -  Set nTmp = ( colExtPrice + colExtRoyalty ) * nGSTPercent
.head 8 -  Set sLine = sLine || fnEX_NumberField( colExtPrice + colExtRoyalty, 2, 18, '$000.00', 'N'   ) || ',' 		! Lval	Total Line Value (2 decimals, ex: $100.00 expressed as 100.00) GST Excl
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 3 , 'N' ) || ',' 			! Line Charge code	We don't use as charges are totalled at end of report
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 18, 'N'  ) || ',' 			! Tot Line Charge	Line charge ex GST, We don't use as charges are totalled at end of report
.head 8 -  Set sLine = sLine || fnEX_NumberField( nTmp, 2, 18, '$000.00', 'N'   ) || ',' 		! GST Line 	Line  GST
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 18 , 'N' ) || ',' 			! GST Line Charge	Line charge  GST, We don't use as charges are totalled at end of report
.head 8 -  Set sLine = sLine || fnEX_NumberField( colExtPrice + colExtRoyalty + nTmp, 2, 18, '$000.00', 'N'   ) || ',' 		! Lval	Total Line Value (2 decimals, ex: $100.00 expressed as 100.00) GST Excl
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 18, 'N'  ) || ',' 			! TotInv	 	Not used in line data
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 3, 'N'  ) || ',' 			! Tot Charge Code	Not used in line data
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 18, 'N'  ) || ',' 			! Tot Charges	Not used in line data
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 18, 'N'  ) || ',' 			! Tot GST		Not used in line data
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 18, 'N'  ) || ',' 			! Tot Charges GST	Not used in line data
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 18, 'N'  ) || ',' 			! Tot Value	Not used in line data
.head 8 -  Set sLine = sLine || fnEX_StringField( '', 8, 'N'  ) 		! Due Date	Not used in line data
.head 8 -  !
.head 7 -  ! Call SalTblFetchRow( hWndForm, nRow )
.head 7 -  Return sLine
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call GetCustElectronicDetails( 0, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Disconnect )
.head 7 -  Return ''
.head 3 +  Function: fnEX_HIWG_FormatPreHeaderLine
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  String:
.head 4 +  Parameters
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sLine
.head 5 -  String: sTmp
.head 5 -  String: sCustName
.head 5 -  String: sPartnerId
.head 5 -  String: sGLNId
.head 5 -  String: sPayerGLNId
.head 5 -  String: sTestFlag
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sLine = ''
.head 7 -  Set sLine = sLine || StringField( 'C1' ) 		! Trading Partner Id		Agreed Trading Partner Id
.head 7 -  Set sLine = sLine || StringField( 'C2' )		! Supplier Id		Agreed Supplier Id
.head 7 -  Set sLine = sLine || StringField( 'C3' ) 		! Buyer Id		Agreed Buyer Id, default is customer number
.head 7 -  Set sLine = sLine || StringField( 'C4' )		! Buyer Name
.head 7 -  Set sLine = sLine || StringField( 'C5' )		! Buyer Contact
.head 7 -  Set sLine = sLine || StringField( 'C6' ) 		! Buyer Contact PH
.head 7 -  Set sLine = sLine || StringField( 'C7' ) 		! Payer Id		EAN GLN Number
.head 7 -  Set sLine = sLine || StringField( 'C8' ) 		! Ship To Id		EAN GLN Number
.head 7 -  Set sLine = sLine || StringField( 'C9' ) 		! Ship To Name
.head 7 -  Set sLine = sLine || StringField( 'C10' ) 		! Ship To Address 1
.head 7 -  Set sLine = sLine || StringField( 'C11' ) 		! Ship To Address 2
.head 7 -  Set sLine = sLine || StringField( 'C12' ) 		! Ship To Suburb
.head 7 -  Set sLine = sLine || StringField( 'C13' ) 		! Ship To State
.head 7 -  Set sLine = sLine || StringField( 'C14' ) 		! Ship To Postcode
.head 7 -  Set sLine = sLine || StringField( 'C15' ) 		! Ship To Country
.head 7 -  Set sLine = sLine || StringField( 'C16' ) 		! Ship To Contact
.head 7 -  Set sLine = sLine || StringField( 'C17' ) 		! Ship To Phone
.head 7 -  Set sLine = sLine || StringField( 'C18' ) 		! Currency
.head 7 -  Set sLine = sLine || StringField( 'C19' )		! Document Type	PO = Purchase Order
.head 7 -  Set sLine = sLine || StringField( 'C20' )		! Test Indicator
.head 7 -  Set sLine = sLine || StringField( 'C21' )		! Version Control
.head 7 -  Set sLine = sLine || StringField( 'C22' )		! Document Date		Document Date - format yyyyMMdd
.head 7 -  Set sLine = sLine || StringField( 'C23' )		! Creation DateTime		Creation Date - format yyyyMMddhhmm
.head 7 -  Set sLine = sLine || StringField( 'C24' )		! Record Type	10 = Header 20 = Detail
.head 7 -  Set sLine = sLine || StringField( 'C25' )		! PO Number	Purchase Order Number
.head 7 -  Set sLine = sLine || StringField( 'C26' )		! PO Line Number	Purchase Order Line Number
.head 7 -  Set sLine = sLine || StringField( 'C27' )		! EAN		Item EAN - THIS MUST BE THE EAN FOR THE UNIT BELOW
.head 7 -  Set sLine = sLine || StringField( 'C28' )		! Supplier Prod Code	Buyer assigned product code
.head 7 -  Set sLine = sLine || StringField( 'C29' )		! ProdCode	Buyer assigned product code
.head 7 -  Set sLine = sLine || StringField( 'C30' )		! Prod Group 	Agreed Grouping
.head 7 -  Set sLine = sLine || StringField( 'C31' )		! Desc		Product Description
.head 7 -  Set sLine = sLine || StringField( 'C32' )		! Product Classification
.head 7 -  Set sLine = sLine || StringField( 'C33' )		! Number Of Lower level GTINs associated with product, eg box of canned baked beans
.head 7 -  Set sLine = sLine || StringField( 'C34' )		! Discount Basis	$ or %
.head 7 -  Set sLine = sLine || StringField( 'C35' )		! Variable Measure Flag
.head 7 -  Set sLine = sLine || StringField( 'C36' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C37' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C38' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C39' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C40' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C41' )		! Packaging unit of measure
.head 7 -  Set sLine = sLine || StringField( 'C42' )		! Discount Amount
.head 7 -  Set sLine = sLine || StringField( 'C43' )		! Discount Basis
.head 7 -  Set sLine = sLine || StringField( 'C44' )		! Promotional Deal Number
.head 7 -  Set sLine = sLine || StringField( 'C45' )		! Reference Number
.head 7 -  Set sLine = sLine || StringField( 'C46' )		! Ordered Qty
.head 7 -  Set sLine = sLine || StringField( 'C47' )		! Ordered Unit of Measure
.head 7 -  Set sLine = sLine || StringField( 'C48' ) 		! Requested Delivery Date 	yyyyMMdd
.head 7 -  Set sLine = sLine || StringField( 'C49' )		! Cost		Unit cost Ex GST
.head 7 -  Set sLine = sLine || StringField( 'C50' )		! Per Quantity 	Default 1
.head 7 -  Set sLine = sLine || StringField( 'C51' )		! Price UOM	EA
.head 7 -  Set sLine = sLine || StringField( 'C52' )		! Lval	Total Line Value (2 decimals, ex: $100.00 expressed as 100.00) GST Excl
.head 7 -  Set sLine = sLine || StringField( 'C53' )		! GST Line   GST
.head 7 -  Set sLine = sLine || StringField( 'C54' )		! Lval	Total Line Value  GST Incl
.head 7 -  Set sLine = sLine || StringField( 'C55' )		! Tot Inv	Ex GST
.head 7 -  Set sLine = sLine || StringField( 'C56' )		! Tot GST
.head 7 -  Set sLine = sLine || StringField( 'C57' ) 		! Tot Value Incl GST
.head 7 -  Set sLine = sLine || StringField( 'C58' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C59' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C60' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C61' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C62' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C63' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C64' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C65' )		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C66' ) 		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C67' ) 		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C68' ) 		! Not Used
.head 7 -  Set sLine = sLine || StringField( 'C69' ) 		! Not Used
.head 7 -  !
.head 7 -  Return sLine
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return ''
.head 3 +  Function: GetNextPurchaseOrder
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  ! Number: nSupplier
.head 5 -  Receive Number: nNumber
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 5 -  Number: nInd
.head 5 -  !
.head 5 -  Number: nNext
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( '2404GetNextPO' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " 
SELECT
	Max( Purchase_Order) + 1
FROM
	Supplier_Orders"
.head 7 -  Set sName = '2404GetNextPO2'
.head 7 -  Set sBind = ''
.head 7 -  Set sInto = ':nNext'
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 +  If nNext = NUMBER_Null
.head 10 -  Set nNext = 1
.head 9 -  Set nNumber = nNext
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Set nNumber = 1
.head 9 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 3 +  Function: GetNotSentPOs
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nSupplier
.head 5 -  Receive Number: nNumber
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 5 -  Number: nInd
.head 5 -  !
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( '2404GetNotSent' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " 
SELECT
	Count (distinct Purchase_Order)
FROM
	Supplier_Orders
Where
	Cust_No = :1 and
	Order_Sent_Date is NULL"
.head 7 -  Set sName = '2404GetNotSent1'
.head 7 -  Set sBind = ' :nSupplier '
.head 7 -  Set sInto = ':nNumber'
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 3 +  Function: InsertPurshaseOrder
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Date/Time: dtOrdDate
.head 5 -  Number: nSupplier
.head 5 -  String: sItemId
.head 5 -  Number: nQuantity
.head 5 -  Number: nPONumber
.head 5 -  String: sSent
.head 5 -  String: sUser
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 5 -  Number: nInd
.head 5 -  !
.head 5 -  Date/Time: dtSentDate
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( '2404InsertPO' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " 
INSERT INTO
	Supplier_Orders(
		Supp_Order_OrdDT,
		Cust_No,
		Supplier_Item_Id,
		Order_Quantity,
		Purchase_Order,
		Order_Sent_Date,
		Order_Sent_By)
VALUES
	(:1, :2, :3, :4, :5, :6, :7)"
.head 7 -  Set sName = '2404InsertPO4'
.head 7 -  Set sBind = ':dtOrdDate, :nSupplier, :sItemId, :nQuantity, :nPONumber, :dtSentDate, :sUser'
.head 7 -  Set sInto = ''
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 +  If sSent = 'Y'
.head 8 -  Set dtSentDate = dtOrdDate
.head 7 +  Else
.head 8 -  Set dtSentDate = DATETIME_Null
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 -  Call haSqlHandles[ nOurHandleNo ].Commit( )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )

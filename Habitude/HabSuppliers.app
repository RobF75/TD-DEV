	Purchase_Order,
	Order_Received,
	Received_Quantity,
	Received_By,
	Received_DT
FROM
	Supplier_items si,
	Supplier_Orders so
WHERE
	so.Supplier_Item_Id = si.Supplier_Item_Id and
	si.cust_no = :1 and
	Order_Sent_Date is not NULL
ORDER BY
	Purchase_Order, Description"

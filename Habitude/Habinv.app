.head 5 +  ! Function: RunStage1Allocations
.head 6 -  Description: 
.head 6 +  Returns 
.head 7 -  Boolean: 
.head 6 +  Parameters 
.head 7 -  Number: nYear
.head 7 -  Number: nActionType
.head 6 -  Static Variables 
.head 6 +  Local variables 
.head 7 -  String: sSql
.head 7 -  String: sBind
.head 7 -  String: sInto
.head 7 -  String: sName
.head 7 -  Number: nSqlHandleNo
.head 7 -  Number: nInd
.head 7 -  Boolean: bOk
.head 7 -  !
.head 7 -  Number: nItemNo
.head 7 -  Number: nTotAvail
.head 7 -  Number: nAmtOnOrder
.head 7 -  Number: nOnOrdAsSubs
.head 7 -  String: sGeneric
.head 7 -  !
.head 7 -  Number: nTotalRows
.head 7 -  Number: nRowCount
.head 7 -  Window Handle: hWndMeter
.head 6 +  Actions 
.head 7 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( '3004Stage1Alloc' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 +  If TRUE
.head 10 -  Set sSql = "
SELECT
  Stock_Item_Sale.Stock_Item_No,
  Stock_Item_Sale.Tot_Avail,
  Stock_Item_Sale.Amt_On_Order,
  Stock_Item_Sale.On_Ord_As_Subs,
  Stock_Item.Generic_Stock_Item
FROM
  Stock_Item,
  Stock_Item_Sale
WHERE
  Stock_Item.Item_No = Stock_Item_Sale.Stock_Item_No AND
  Stock_Item_Sale.Year_Of_Sale = :1 AND
  Stock_Item_Sale.Allocated_Flag IS NULL AND
  NOT Stock_Item.Tree_Type LIKE 'C%' "
.head 10 -  Set sName = '3004Stage1Alloc'
.head 10 -  Set sBind = ':nYear '
.head 10 -  Set sInto = ':nItemNo,
  	:nTotAvail,
  	:nAmtOnOrder,
  	:nOnOrdAsSubs,
  	:sGeneric '
.head 10 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 10 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 -  !
.head 9 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 10 -  Call haSqlHandles[ nSqlHandleNo ].ResultSetCount( nTotalRows )
.head 10 +  If nTotalRows >= nNumRowsToMeter
.head 11 -  Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Stage 1, Allocating', nTotalRows )
.head 10 -  Set nRowCount = 0
.head 10 +  While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 11 +  If sGeneric = 'Y'
.head 12 +  If UpdateItemAllocatedFlag( nItemNo, nYear, 'Y', SH_cls_Execute )
.head 13 -  Call UpdateItemAllocatedFlag( 0, 0, '', SH_cls_Commit )
.head 12 +  Else 
.head 13 -  Call UpdateItemAllocatedFlag( 0, 0, '', SH_cls_Rollback )
.head 11 +  Else If nAmtOnOrder = 0 AND nOnOrdAsSubs = 0
.head 12 +  If UpdateItemAllocatedFlag( nItemNo, nYear, 'Y', SH_cls_Execute )
.head 13 -  Call UpdateItemAllocatedFlag( 0, 0, '', SH_cls_Commit )
.head 12 +  Else 
.head 13 -  Call UpdateItemAllocatedFlag( 0, 0, '', SH_cls_Rollback )
.head 11 +  Else If nTotAvail >= 0
.head 12 +  If AllocatedItemOrders( nItemNo, nYear, SH_cls_Execute )
.head 13 +  If UpdateItemAllocatedFlag( nItemNo, nYear, 'Y', SH_cls_Execute )
.head 14 -  Call AllocatedItemOrders( 0, 0, SH_cls_Commit )
.head 14 -  Call UpdateItemAllocatedFlag( 0, 0, '', SH_cls_Commit )
.head 13 +  Else 
.head 14 -  Call AllocatedItemOrders( 0, 0, SH_cls_Rollback )
.head 14 -  Call UpdateItemAllocatedFlag( 0, 0, '', SH_cls_Rollback )
.head 12 +  Else 
.head 13 -  Call AllocatedItemOrders( 0, 0, SH_cls_Rollback )
.head 11 +  Else 
.head 12 +  If UpdateItemAllocatedFlag( nItemNo, nYear, 'N', SH_cls_Execute )
.head 13 -  Call UpdateItemAllocatedFlag( 0, 0, '', SH_cls_Commit )
.head 12 +  Else 
.head 13 -  Call UpdateItemAllocatedFlag( 0, 0, '', SH_cls_Rollback )
.head 11 -  !
.head 11 -  Set nRowCount = nRowCount + 1
.head 11 -  Call SalSendMsg( hWndMeter, PAM_clsMTR_SETPROGRESS, 0, nRowCount )
.head 10 -  Call SalSendMsg( hWndMeter, PAM_clsMTR_END, 0, 0 )
.head 10 -  Return TRUE
.head 9 +  Else 
.head 10 -  Return FALSE

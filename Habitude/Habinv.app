.head 7 +                                                                       On SAM_Destroy
.head 8 -                                                                       Call ExistsItemByItemFields( '', '', '', bExists, SH_cls_Disconnect )
.head 8 -                                                                       Call GetNextNewItemNo( colItemNo, SH_cls_Disconnect )

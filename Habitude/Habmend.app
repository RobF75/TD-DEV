.head 5 -  String: sInto
.head 5 -  Number: nSqlHandleNo
.head 5 -  Boolean: bOk
.head 5 -  !
.head 5 -  Number: nInd
.head 5 -  String: sOwnerId
.head 5 -  String: sText
.head 5 -  String: sSubject
.head 5 -  String: sAdminEmail
.head 5 -  !
.head 5 -  Date/Time: dtCurrent
.head 5 -  Date/Time: dtRecentSales
.head 5 -  Boolean: bFoundSome
.head 4 +  Actions 
.head 5 -  Set bOk = TRUE
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( '0104GetRoyDue' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " select
	Royalty_Owner_id
from
	Royalty_payable
where
	Payment_Due_Date < :1 and
	royalty_owner_id in (
	select
		distinct royalty_owner_id 
	from
		royalties_Paid
	Where
		Paid_Date_Time between :2 and :1 )
group by
	royalty_owner_id"
.head 7 -  Set sName = '0104GetRoyDue1'
.head 7 -  Set sBind = ':dtCurrent, :dtRecentSales '
.head 7 -  Set sInto = ':sOwnerId'
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set dtCurrent = SalDateCurrent(  )
.head 7 -  Set dtRecentSales = SalDateConstruct( SalDateYear( dtCurrent ) - 1, 1, 1, 0, 0, 0 )
.head 7 -  Set bFoundSome = FALSE
.head 7 -  !
.head 7 -  Set sSubject = 'Royalties Due for Payment'
.head 7 -  Set sText = 'The following are royalties that are now due for payment
'
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 +  While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 -  Set sText = sText || sOwnerId || '
'
.head 9 -  Set bFoundSome = TRUE
.head 8 +  If bFoundSome
.head 9 -  Set sText = sText || 'Please ensure that the above are paid shortly'
.head 9 -  Call GetRegistryValue( 'GENERAL', 'AdminManagerEmail', sAdminEmail, 'tony@flemings.com.au' )
.head 9 -  Call SendMail( sSubject, sText, sAdminEmail, '', '', '' )
.head 7 +  Else 
.head 8 -  Return FALSE
.head 7 -  Return TRUE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT haSqlHandles[ nSqlHandleNo ].Disconnect( )

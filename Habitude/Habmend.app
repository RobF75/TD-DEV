.head 5 +                                Function: StartProgram
.head 6 -                                Description: 
.head 6 +                                Returns 
.head 7 -                                Boolean: 
.head 6 -                                Parameters 
.head 6 -                                Static Variables 
.head 6 -                                Local variables 
.head 6 +                                Actions 
.head 7 -                                Call DisplayStartMessage( )
.head 7 -                                Call SalGetProfileString( __csSectionName, isAppName, '', __isProgramExePath, FlemSysIniFileName )
.head 7 +                                If ibExecProgram
.head 8 -                                Call ExecProgram(  )
.head 7 +                                Else If ibLoadAndWait
.head 8 -                                Set __isProgramExePath = __isProgramExePath||' '||isDBName||' '||SqlUser||' '||SqlPassword||' '||isParams
.head 8 -                                Call LaunchAppAndWait(  )
.head 7 +                                Else 
.head 8 -                                Call LaunchApp(  )
.head 7 -                                Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
.head 7 -                                Return TRUE
.head 5 +                                Function: DisplayStartMessage
.head 6 -                                Description: 
.head 6 +                                Returns 
.head 7 -                                Boolean: 
.head 6 -                                Parameters 
.head 6 -                                Static Variables 
.head 6 -                                Local variables 
.head 6 +                                Actions 
.head 7 -                                Call SalSendMsg( hWndForm, PAM_clsPB_LOADING_START, 0, SalHStringToNumber( isAppName ) )
.head 4 +                                Message Actions 
.head 5 +                                On SAM_Create
.head 6 +                                If NOT __cbInitialized
.head 7 +                                If sDatabase = 'LIVE'
.head 8 -                                Set __cbLive = TRUE 
.head 8 -                                Set __csSectionName = IniGeneralLiveSectionName
.head 8 -                                Set __csAccSectionName = IniAccountsLiveSectionName
.head 7 +                                Else 
.head 8 -                                Set __cbLive = FALSE
.head 8 -                                Set __csSectionName = IniGeneralPlaySectionName
.head 8 -                                Set __csAccSectionName = IniAccountsPlaySectionName
.head 7 -                                Call SalGetProfileString( __csAccSectionName, 'AccountsUsers', '', __csAccUsers, FlemSysIniFileName )
.head 7 -                                Call SalGetProfileString( __csAccSectionName, 'FlemingsFamily', '', __csFamUsers, FlemSysIniFileName )
.head 7 -                                Call SalGetProfileString( __csSectionName, 'PriceAdjusters', '', __csPAdjUsers, FlemSysIniFileName )
.head 7 -                                Call SalGetProfileString( __csSectionName, 'StockControllers', '', __csSContUsers, FlemSysIniFileName )
.head 7 -                                Call SalGetProfileString( __csAccSectionName, 'SystemAdministrators', '', __csSysAdmUsers, FlemSysIniFileName )
.head 7 -                                Set __cbInitialized = TRUE
.head 6 -                                Set isParams = ''
.head 6 -                                Set ibExecProgram = FALSE
.head 6 -                                Set inRunMode = Window_Normal
.head 6 +                                If sDatabase = 'LIVE'
.head 7 -                                Set isDBName = 'STOCK'
.head 6 +                                Else 
.head 7 -                                Set isDBName = 'STOCKDEV'
.head 6 -  ! do initialize code to get users path and rights etc

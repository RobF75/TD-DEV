.head 4 -                                Description: 
.head 4 +                                Derived From 
.head 5 -                                Class: clsStartProgram
.head 5 -                                Class: clspbGeneral
.head 4 -                                Class Variables 
.head 4 -                                Instance Variables 
.head 4 -                                Functions 
.head 4 +                                Message Actions 
.head 5 +                                On SAM_Create
.head 6 -                                Call SalSendClassMessageNamed( clsStartProgram, SAM_Create, wParam, lParam )
.head 6 -                                Return SalSendClassMessageNamed( clspbGeneral, SAM_Create, wParam, lParam )
.head 5 +                                On PAM_cls_SETINSTANCEVARS
.head 6 -                                Set clspbStartProg.bDoubleClickOK = FALSE
.head 5 +                                On PAM_clsPB_CLICK
.head 6 -                                Call hWndItem.clsStartProgram..StartProgram(  )
.head 6 -                                Return TRUE
.head 5 +                                On PAM_clsPB_LOADING_END
.head 6 +  ! If NOT bLoadAndWait
.head 7 -                                Call SalTimerKill ( hWndItem, nTimerId )
.head 7 -                                Call SalGetWindowText( hWndForm, sTmp, 60 )
.head 7 -                                Set hWndThisWnd = FindWindowA( 0, sTmp )
.head 7 -                                Call ShowWindow( hWndThisWnd, SW_MINIMIZE )
.head 6 +  ! Else
.head 7 -                                Call SalGetWindowText( hWndForm, sTmp, 60 )
.head 7 -                                Set hWndThisWnd = FindWindowA( 0, sTmp )
.head 7 -                                Call ShowWindow( hWndThisWnd, SW_RESTORE )
.head 6 -                                Call SalSendMsg( hWndForm, PAM_clsPB_LOADING_END, wParam, lParam )
.head 6 -                                Call SalSendMsg( hWndItem, PAM_clsPB_ENABLE, 2, 0 )
.head 6 -                                Call OurWaitCursor( FALSE )
.head 5 +                                On PAM_clsPB_ENABLE
.head 6 +                                If wParam = 2
.head 7 -                                Return SalSendClassMessage( PAM_clsPB_ENABLE, 0, 0 )
.head 6 +                                Else 
.head 7 -                                Return TRUE
.head 3 +  ! Data Field Class: clsdfStartProgram
.winattr
.head 4 -  Data
.head 5 -  Maximum Data Length: Default

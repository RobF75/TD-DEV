.head 7 -  !
.head 7 -                                 Call SalGetProfileString( sLiveProgramSection, sLiveProgramTitle, sLiveProgramDefaultPathNameExt, sLiveProgramPathNameExt, sIniFile )
.head 7 -                                 Call SalGetProfileString( sPlayProgramSection, sPlayProgramTitle, sPlayProgramDefaultPathNameExt, sPlayProgramPathNameExt, sIniFile )
.head 7 +                                 If sUserTypeRestrictions != ''
.head 8 -                                 Call SalGetProfileString( sLiveProgramSection, sUserTypeRestrictions, '', sLiveUsers, sIniFile )
.head 8 -                                 Call SalGetProfileString( sPlayProgramSection, sUserTypeRestrictions, '', sPlayUsers, sIniFile )
.head 8 +                                 If SqlDatabase = 'STOCK'
.head 9 +                                 If NOT SalStrScan( sLiveUsers, SqlUser ) >= 0
.head 10 -                                 Call SalSendMsg( hWndItem, PAM_clsPB_HIDE, 0, 0 )
.head 10 -                                 Call SalSendMsg( hWndItem, PAM_clsPB_DISABLE, 0, 0 )
.head 10 -                                 Set bAccessGranted = FALSE
.head 8 +                                 Else 
.head 9 +                                 If NOT SalStrScan( sPlayUsers, SqlUser ) >= 0
.head 10 -                                 Call SalSendMsg( hWndItem, PAM_clsPB_HIDE, 0, 0 )
.head 10 -                                 Call SalSendMsg( hWndItem, PAM_clsPB_DISABLE, 0, 0 )
.head 10 -                                 Set bAccessGranted = FALSE
.head 7 -                                 Return TRUE
.head 5 +                                 Function: GetAppNameFromPath
.head 6 -                                 Description: 
.head 6 +                                 Returns 
.head 7 -                                 String: 
.head 6 +                                 Parameters 
.head 7 -                                 String: sAppFullName
.head 6 -                                 Static Variables 
.head 6 +                                 Local variables 
.head 7 -                                 String: sTokens[*]
.head 7 -                                 Number: nNumTokens
.head 7 -                                 String: sTmp
.head 7 -                                 Number: nPos
.head 6 +                                 Actions 
.head 7 -                                 Set nNumTokens = SalStrTokenize( sAppFullName, '', '\\', sTokens )
.head 7 -                                 Set sTmp = sTokens[ nNumTokens - 1 ]
.head 7 -                                 Set nPos = SalStrScan( sTmp, '.' ) 
.head 7 +                                 If nPos >= 0
.head 8 -                                 Set sTmp = SalStrLeftX( sTmp, nPos )
.head 7 -                                 Return SalStrUpperX( sTmp )

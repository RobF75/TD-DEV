.head 13 -  Set nTotalTrees = nTotalTrees + (nAmtGraded - nAmtShipped)
.head 11 +  Else
.head 12 +  If nGotTotalTrees <= 0
.head 13 -  Set nAmtGraded = GetGradedAmt( nItemNo, SH_cls_Execute ) 
.head 13 +  If (nAmtGraded - nAmtShipped) > nConfAmt
.head 14 -  Set nTotalTrees = nTotalTrees + nConfAmt

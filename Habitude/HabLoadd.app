.head 3 -  !
.head 3 +  Function: ResetLoadsForNewSeason
.head 4 -  Description: A decision was made that when user selects loads, the 
shipping date range for prior season criteria will be 
disregarded.  Else for no load selections ie: ALL the 
shipping date criteria is enforced. Likewise for the 
load_invoiced_flag.  For selected loads it is ignored else 
it must be 'Y' for the ALL operations.

! Changes 1/5/2000 JL
Change was required to ensure that the notification_letter_flag, expected_deliver_date
	also need to be updated.
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nYear
.head 5 -  ! saLoads[*] is assumed to be null terminated.
.head 5 -  String: saLoads[*]
.head 5 -  ! sLoadsType = 'SELECTED' OR 'ALL'
.head 5 -  String: sLoadsType
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nSqlHandleNoL
.head 5 -  Number: nSqlHandleNoLC
.head 5 -  String: sSql
.head 5 -  Boolean: bOk
.head 5 -  Number: nYearMinOne
.head 5 -  Number: nYearMinTwo
.head 5 -  String: sSelectionLoads
.head 4 +  Actions
.head 5 -  Set nSqlHandleNoL = SqlHandlesGetReferenceNo( 'ResetLoadsForNewSeason' )
.head 5 -  Set nSqlHandleNoLC = SqlHandlesGetReferenceNo( 'ResetLoadsForNewSeason2' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 +  If sLoadsType = 'ALL'
.head 8 -  Set sSql = 
"
UPDATE 
	Load 
SET 
	Shipping_Date =  @IF(@DAY(Load.Shipping_Date)-29,
        		@DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)), 
        		@IF(@MONTH(Load.Shipping_Date)-2, 
        		@DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)), 
        		@DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)-1))), 
	Load_Pulled_Flag = 'N', 
	Load_Invoiced_Flag = 'N', 
	Invoice_By_Date = NULL
WHERE 
	Shipping_Date < @DATE(:nYearMinOne, 9, 1) AND 
	Shipping_Date >= @DATE(:nYearMinTwo, 9, 1) AND 	
	Load_Invoiced_Flag = 'Y' 
"
.head 7 +  Else
.head 8 -  Call MakeStringList( saLoads, ',', "'", sSelectionLoads )
.head 8 -  Set sSql = 
"
UPDATE 
	Load 
SET 
	shipping_Date =  @IF(@DAY(Load.Shipping_Date)-29,
		@DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)), 
		@IF(@MONTH(Load.Shipping_Date)-2, 
        		@DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)), 
        		@DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)-1))), 
	Load_Pulled_Flag = 'N', 
	Load_Invoiced_Flag = 'N', 
	Invoice_By_Date = NULL
WHERE 
  	Load_Id IN ( " || sSelectionLoads || " ) "
.head 7 -  Call haSqlHandles[ nSqlHandleNoL ].PrepareSetup( sSql )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNoL ].hSqlHandle )
.head 7 -  !
.head 7 +  If sLoadsType = 'ALL'
.head 8 -  Set sSql = 
"
UPDATE 
	Load_Customers 
SET 
	Anticip_Del_Date = NULL,
  	Cust_Pulled_Flag = 'N',
  	Cust_Inv_Flag = 'N', 
  	Cust_Cont_Flag = 'N',
	Anticip_Del_Time = NULL,
	Deliv_Noti_Letter = 'N',
	HH_Item_Added = 'N',
	HH_Pulled_By = NULL,
	HH_Loaded = 'N',
	HH_Washed = 'N'
WHERE
  	Load_Customers.Load_Id IN 
	(
  		SELECT 
    			Load.Load_Id 
  		FROM 
    			Load 
  		WHERE 
    			Load.Shipping_Date < @DATE(:nYearMinOne, 9, 1) AND 
    			Load.Shipping_Date >= @DATE(:nYearMinTwo, 9, 1) AND 
    			Load.Load_Invoiced_Flag = 'Y'
	)
"
.head 7 +  Else
.head 8 -  Set sSql = 
"
UPDATE 
	Load_Customers 
SET 
  	Anticip_Del_Date = NULL,
	Cust_Pulled_Flag = 'N',
	Cust_Inv_Flag = 'N', 
	Cust_Cont_Flag = 'N',
	Anticip_Del_Time = NULL, 
	Deliv_Noti_Letter = 'N',
	HH_Item_Added = 'N',
	HH_Pulled_By = NULL,
	HH_Loaded = 'N',
	HH_Washed = 'N'
WHERE
	Load_Customers.Load_Id IN ( " || sSelectionLoads || " ) 
"

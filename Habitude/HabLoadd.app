.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'AddCustOrdToLoad' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = 
"UPDATE
	Customer_Order
 SET
	Load_Id = :1, 
	Load_Cust_Inst_No = :2,
	Truck_Stk_Printd = 'N'
WHERE 
	Cust_No = :3 AND 
	Order_Date_Time = :4 and
	(hold_order_date <= :5 or
	hold_order_date IS NULL)"
.head 7 -  Set sName = 'AddCustOrdToLoad'
.head 7 -  Set sBind = ':sLoadId, :nLoadCustInstNo, :nCustNo, :dtOrderDateTime, :dtShipDT '
.head 7 -  Set sInto = ''
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 +  ! If TRUE
.head 8 +  If NOT bHandleConnected
.head 9 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 9 +  If bHandleConnected
.head 10 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 10 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 9 +  Else 
.head 10 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 10 -  Return FALSE
.head 8 +  If NOT bHandlePrepared
.head 9 -  Set sSql = 
'UPDATE
	Customer_Order
 SET
	Load_Id = :sLoadId, 
	Load_Cust_Inst_No = :nLoadCustInstNo,
	Truck_Sht_Printd = 'N'
WHERE 
	Cust_No = :nCustNo AND 
	Order_Date_Time = :dtOrderDateTime and
	(hold_order_date <= :dtShipDT or
	hold_order_date IS NULL)'
.head 9 +  If SqlPrepare( hSqlHandle, sSql )
.head 10 -  Set bHandlePrepared = TRUE
.head 9 +  Else 
.head 10 -  Set bHandlePrepared = FALSE
.head 8 +  If SqlExecute( hSqlHandle )
.head 9 -  Return TRUE
.head 8 +  Else 
.head 9 -  Set bHandlePrepared = FALSE
.head 9 -  Call SalMessageBox( 'SqlExecute had a error in UpdateOrderToLoad, Contact programmers please!', 'ERROR', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Commit
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Commit( )
.head 8 -  Return TRUE
.head 7 -  ! Set bOk = TRUE
.head 7 +  ! If bHandleConnected
.head 8 -  Set bOk = SqlCommit( hSqlHandle )
.head 7 -  ! Return bOk
.head 6 +  Case SH_cls_Rollback
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Rollback( )
.head 8 -  Return TRUE
.head 7 -  ! Set bOk = TRUE
.head 7 +  ! If bHandleConnected
.head 8 -  Set bOk = SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
.head 8 -  Set bHandlePrepared = FALSE
.head 7 -  ! Return bOk
.head 6 +  Case SH_cls_Disconnect
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 8 -  Return TRUE
.head 7 -  ! Set bOk = FALSE
.head 7 -  ! Set bHandlePrepared = FALSE
.head 7 +  ! If bHandleConnected
.head 8 -  Set bHandleConnected = FALSE
.head 8 -  Set bOk = SqlDisconnect( hSqlHandle )
.head 7 -  ! Return bOk
.head 6 +  Case SH_cls_RePrepare
.head 7 +  If haSqlHandles[ nSqlHandleNo ].RePrepare( )
.head 8 -  Return TRUE
.head 7 -  ! Set bHandlePrepared = FALSE
.head 7 -  ! Return TRUE

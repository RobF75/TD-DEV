.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLTABLENAME = ' MEET_ADDRESS '
.head 6 -  Set sSQLPOPTABLENAME = ' Meet_Address, Region_Meet, Region_Load '
.head 6 -  Set sSQLWHERE = ' WHERE Region_Meet.Meet_Id = Meet_Address.Meet_Id and 
Region_Load.Region_Id = Region_Meet.Region_Id and 
region_Load.load_Id = :dlgQueryTblCustomer.sLoadId '
.head 6 -  Set sORDERBY = ' ORDER BY MEET_ADDRESS.MEET_ID '

"
Select 
	Cust_No
From
	Customer_Master
Where
	Cust_No = :colCustNo
AND	Pl_Plus_Refer_Flag = 'Y'
"
.head 7 -  Set spCustNos = STRING_Null
.head 7 -  Set bOk = TRUE
.head 7 -  Set nCurrentRow = -1

.head 6 +  If rbContainerOrdersReady
.head 7 -  Call PushString( '' )
.head 7 -  Call PushString( '' )
.head 7 -  Call PushString( STRINGHDLFOLLOWING )
.head 7 -  ! Call PushString( " EXISTS 
( 
  SELECT 
    Growing_Sale.Location_Id 
  FROM 
    Growing_Sale 
  WHERE 
    Growing_Sale.Stock_Item_No = Customer_Order.Stock_Item_No AND 
    Growing_Sale.Year_Of_Sale = Customer_Order.Year_Of_Sale AND 
    ( Growing_Sale.Not_For_Sale IS NULL OR 
      Growing_Sale.Not_For_Sale = 'N' )  AND 
    Growing_Sale.Location_Id = Customer_Order.Batch_Location_Id 
) " )
.head 7 -  Call PushString( " EXISTS 
( 
  SELECT 
    Growing_Sale.Location_Id 
  FROM 
    Growing_Sale,
    Customer_Order 
  WHERE 
    Growing_Sale.Stock_Item_No = Customer_Order.Stock_Item_No AND 
    Growing_Sale.Year_Of_Sale = Customer_Order.Year_Of_Sale AND 
    ( Growing_Sale.Est_Sale_Date IS NULL OR 
      Growing_Sale.Est_Sale_Date <= :dlgQueryTblCustomer.dtShippingDate ) AND 
    ( Growing_Sale.Not_For_Sale IS NULL OR 
      Growing_Sale.Not_For_Sale = 'N' )  AND 
    Growing_Sale.Location_Id = Customer_Order.Batch_Location_Id 
) " )
.head 7 -  !
.head 7 -  Call PushString( '' )
.head 7 -  Call PushString( '' )
.head 7 -  Call PushString( STRINGHDLFOLLOWING )
.head 7 -  Call PushString( " ( CUSTOMER_ORDER.HOLD_ORDER_DATE <= :dlgQueryTblCustomer.dtShippingDate OR CUSTOMER_ORDER.HOLD_ORDER_DATE IS NULL ) " )
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE

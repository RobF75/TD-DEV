.head 2 +  Application Actions
.head 3 +  On SAM_AppStartup
.head 4 -  ! Note - for the 95 season we need to adjust the label charge calculation in tblCust
so that it calulates correctly again and not incorrectly as the AS400 does in 94
.head 4 -  ! Also in frmRegLoad.tblOrd.colExtPrice - for POS freight charges error to be fixed
in 95
.head 4 -  ! Also in nextinv and printinvoice we need to change so that pos is invoiced at the
point of the first load
.head 4 -  ! Royalty need to be worked on to accumulate for a roy owner, what they currently
  need to be paid instead of doing at year end.
.head 4 -  ! No base price on invoicing message has cult_desc, root_desc and cust_no.
.head 4 -  !
.head 4 -  ! WHEN MAKING EXECUTABLE erase the commands CUSTPOSORDINV, ORDERPOS, POSEXISTSNOTINV
.head 4 -  !
.head 4 +  If SalStrUpperX( SalStrRightX( strArgArray[0],3 ) ) = 'EXE'
.head 5 -  Set SqlDatabase = strArgArray[1]
.head 5 -  Set SqlUser = strArgArray[2]
.head 5 -  Set SqlPassword = strArgArray[3]
.head 4 +  Else
.head 5 -  Set SqlDatabase = 'STOCKDEV'
.head 5 -  ! Set SqlDatabase = 'STKLOCAL'
.head 5 -  Set SqlDatabase = 'STOCK'
.head 5 -  Set SqlUser = 'GRAHAM'
.head 5 -  Set SqlPassword = 'GRAHAM'
.head 4 -  !
.head 4 -  Call SqlHandlesSetup(  )
.head 4 -  !
.head 4 -  Set bShowSql = FALSE
.head 4 -  Set bghSqlDetail = SqlConnect( hSqlDetail )
.head 4 +  If bghSqlDetail
.head 5 -  Call SqlSetIsolationLevel( hSqlDetail,'RL')
.head 5 -  Call SqlSetLockTimeout( hSqlDetail, SQLTIMEOUT )
.head 4 -  ! Set CallProgStr = strArgArray[4]
.head 4 -  ! Set CallProgNum = SalHStringToNumber(CallProgStr )
.head 4 -  ! Set hWndCallProg = SalNumberToWindowHandle( CallProgNum )
.head 3 +  On SAM_SqlError
.head 4 -  Call SqlExtractArgs( wParam, lParam, hSqlError, nSqlError, nErrorPos )
.head 4 -  ! Going to comments the return false line and put in others to do error processing
.head 4 -  ! Return FALSE
.head 4 -  Call SqlGetErrorText( nSqlError, sErrmsg )
.head 4 -  Call SalNumberToStr( nSqlError, 0, sNum )
.head 4 -  Call SalSendMsg( hWndSqlError, PAM_RESETPREPAREDHDLS, 0, 0 )
.head 4 -  Call SalMessageBox( sNum || '-' || sErrmsg || '.
Choose OK to quit.', 'Load', MB_Ok | MB_IconStop )
.head 4 -  ! Call SalQuit(  )
.head 4 -  Return FALSE
.head 3 +  On SAM_AppExit
.head 4 +  If bghSqlDetail
.head 5 -  Call SqlDisconnect( hSqlDetail )
.head 4 -  Call SqlHandlesDisconnectClose(  )

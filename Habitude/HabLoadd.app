.head 7 +  ! On PAM_CHECKROWDELETED
.head 8 -  Call AnyPullnNotInvCustOrdsOnLoad( frmNewLoadCust.dfLoadId, colCustNo, colCustInstanceNo, frmNewLoadCust.cSeasonYear.GetSeasonYear( ), bAny, SH_cls_Execute ) 
.head 8 +  If bAny

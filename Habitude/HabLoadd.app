.head 9 -  Set nTotalTrees = 0
.head 9 -  Set nGotTotalTrees = NUMBER_Null
.head 9 -  !
.head 9 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 10 +  While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 11 +  ! If nGotTotalTrees <= 0
.head 12 -  Set nAmtGraded = GetGradedAmt( nItemNo, SH_cls_Execute ) 
.head 12 +  If (nAmtGraded - nAmtShipped) > nConfAmt
.head 13 -  Set nTotalTrees = nTotalTrees + nConfAmt
.head 12 +  Else If nAmtGraded != NUMBER_Null
.head 13 -  Set nTotalTrees = nTotalTrees + (nAmtGraded - nAmtShipped)
.head 11 -  If nTotAvail < 0 
.head 11 +  Else If nGotTotalTrees >= nConfAmt
.head 12 -  Set nTotalTrees = nTotalTrees + nConfAmt
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 9 -  Return TRUE

.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  String: sBind
.head 7 -  String: sInto
.head 7 -  String: sName
.head 7 -  Number: nSqlHandleNo
.head 7 -  !
.head 7 -  String: sGotFarmName
.head 7 -  Number: nGotRowNo
.head 7 -  Number: nGotSeqNo
.head 7 -  !
.head 7 -  Number: nInd
.head 6 +  Actions
.head 7 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetBatchLocFarmRowSeq' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = " SELECT 
  Farm_Name, 
  Row#, 
  Seq# 
FROM Location
WHERE Location_Id = :1 "
.head 9 -  Set sName = 'GTLCFRSDTS'
.head 9 -  Set sBind = ':nLocationId'
.head 9 -  Set sInto = ':sGotFarmName, :nGotRowNo, :nGotSeqNo'
.head 9 -  !
.head 9 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 9 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 -  Set sFarmName = ''
.head 9 -  Set sGotFarmName = ''
.head 9 -  Set nRowNo = NUMBER_Null
.head 9 -  Set nGotRowNo = NUMBER_Null
.head 9 -  Set nSeqNo = NUMBER_Null
.head 9 -  Set nGotSeqNo = NUMBER_Null
.head 9 -  !
.head 9 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 10 +  If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 11 -  Set sFarmName = sGotFarmName
.head 11 -  Set nRowNo = nGotRowNo
.head 11 -  Set nSeqNo = nGotSeqNo
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 4 -  Window Variables
.head 4 +  Message Actions
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLTABLENAME = ' Customer_Order '
.head 6 -  Set sSQLPOPTABLENAME= ' Customer_Order, Stock_Item '
.head 6 -  Set sSQLWHERE = " WHERE  Customer_Order.Load_Id IN ("||frmPrintTruckStockDugReport.mlLoadIds||") AND
  Customer_Order.Year_Of_Sale = :frmPrintTruckStockDugReport.dfYear AND
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND
  NOT Stock_Item.Generic_Stock_Item = 'Y' AND 
  Stock_Item.Stock_Type = 'C' "
.head 6 -  ! Set sORDERBY = " GROUP BY 9,10, 2,4,7,5,1,3,6,8 "
.head 6 -  Set sORDERBY = " GROUP BY 2,4,7,9,5,1,3,6,8,10 "
.head 6 -  Set sROWID = ' Customer_Order.ROWID '
.head 6 -  Set nTableFillType = TBL_FillAll
.head 5 +  On PAM_POPULATE
.head 6 -  Call SalSendClassMessage( PAM_POPULATE, wParam, lParam )
.head 6 -  Call MyTableLoop( hWndForm, hWndForm, PAM_ROWACTION, 0, 0, 'Populating non generic stock', nLowToHi )
.head 6 -  Return TRUE
.head 5 +  On PAM_ROWACTION
.head 6 -  Call GetBatchLocFarmRowSeq( colBatchLocationId, colFarmName, colRowNo, colSeqNo, SH_cls_Execute )
.head 6 -  Set colShortFarmName = SalStrLeftX( colFarmName, 5 )
.head 6 -  Return SalSendMsg( tblLoadStock, PAM_ADDROW, 3, lParam )
.head 5 +  On PAM_NOROWS
.head 6 -  Return TRUE
.head 5 +  On SAM_Destroy
.head 6 -  Call GetBatchLocFarmRowSeq( 0, colFarmName, colRowNo, colSeqNo, SH_cls_Disconnect )
.head 6 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

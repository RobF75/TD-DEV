.head 5 +  Message Actions
.head 6 +  On PAM_SETINSTANCEVARS
.head 7 -  Set pbMeetAddress.sPickDialogName = 'frmRegionMeets'
.head 7 -  Set pbMeetAddress.hWndChildTable = dlgQCustAddr.tblCustAddr
.head 7 -  Set pbMeetAddress.bPickModalDialog = FALSE
.head 7 -  Set pbMeetAddress.sToolTipText = 'Select ppropriate Meet address'
.head 6 +  On SAM_Click
.head 7 -  Set nRow = 0
.head 7 -  Call MyTableAnyRows( dlgQCustAddr.tblCustAddr, ROW_Selected, 0, nRow )
.head 7 +  If nRow > 1
.head 8 -  Call SalMessageBox( 'Please select only one row to pick a Meet Address for!', 'Warning', MB_Ok )
.head 7 +  Else
.head 8 +  If dlgQCustAddr.tblCustAddr.colAddressType = 'MEET' OR SalIsNull( dlgQCustAddr.tblCustAddr.colAddressType )
.head 9 -  Call SalSendClassMessage( SAM_Click, wParam, lParam )
.head 8 +  Else
.head 9 -  Call SalMessageBox( 'Please select only the meet address row to pick a Meet Address for!', 'Warning', MB_Ok )
.head 6 +  On PAM_PUSHFIELDS
.head 7 -  Call GetCustRegionId( dlgQCustAddr.dfCustNo, sRegionId, SH_cls_Execute )
.head 7 -  Call PushString( sRegionId )

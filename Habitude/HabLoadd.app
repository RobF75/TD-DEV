.head 5 +  Message Actions
.head 6 +  On PAM_CLICK
.head 7 +  If rbFruitOrders
.head 8 +  If cbNoContainers
.head 9 -  Set nLoadOrderType = nFruitOrders | nWithOutContainers
.head 8 +  Else
.head 9 -  Set nLoadOrderType = nFruitOrders
.head 7 +  Else If rbOrnamOrders
.head 8 +  If cbNoContainers
.head 9 -  Set nLoadOrderType = nOrnamOrders | nWithOutContainers
.head 8 +  Else
.head 9 -  Set nLoadOrderType = nOrnamOrders
.head 7 +  Else If rbContOrders
.head 8 -  Set nLoadOrderType = nContainerLoads
.head 7 -  ! ! P# 1, JJ, 17/4/99
.head 7 +  Else If rbBareRootPottedOrders
.head 8 +  If cbNoContainers
.head 9 -  Set nLoadOrderType = nBareRootPottedOrders | nWithOutContainers
.head 8 +  Else
.head 9 -  Set nLoadOrderType = nBareRootPottedOrders
.head 7 -  ! ! P# 1, JJ, 17/4/99 end.
.head 7 +  Else
.head 8 -  Set nLoadOrderType = nSelectionOrders
.head 7 -  !
.head 7 +  If nLoadOrderType = nSelectionOrders
.head 8 +  If MyTableAnyRows( hWndTable, ROW_Selected, 0, nCount )
.head 9 +  If nCount > 1
.head 10 -  Call SalMessageBox( 'Please select one Customer only!', 'NOTE', MB_Ok )
.head 10 -  Call SalSendMsg( pbCancel, SAM_Click, 0, FALSE )
.head 9 +  Else
.head 10 +  If SalTblAnyRows( hWndTable, ROW_Edited | ROW_New | ROW_MarkDeleted, 0 ) 
.head 11 -  Call SalMessageBox( 'Please save your changes first!', 'NOTE', MB_Ok )
.head 11 -  Call SalSendMsg( pbCancel, SAM_Click, 0, FALSE )
.head 10 +  Else
.head 11 -  Call SalCreateWindow( frmAddCustSelectionOrdsOnLoad, hWndForm, hWndTable.colCustNo, hWndTable.colCustInstanceNo, sLoadId, dtShippingDate )
.head 8 +  Else
.head 9 -  Call SalMessageBox( 'Please select a Customer!', 'NOTE', MB_Ok )
.head 9 -  Call SalSendMsg( pbCancel, SAM_Click, 0, FALSE )
.head 7 +  Else
.head 8 -  Call MyTableLoop( hWndTable, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Including Orders', nLowToHi )
.head 8 -  Call SalSendMsg( pbCancel, SAM_Click, 0, TRUE )
.head 6 +  On PAM_ROWACTION
.head 7 +  If NewAddCustOrdTypeToLoad( sLoadId, nYear, hWndTable.colCustNo, hWndTable.colCustInstanceNo, nLoadOrderType, DATETIME_Null, dtShippingDate, SH_cls_Execute )
.head 8 -  Call NewAddCustOrdTypeToLoad( '', 0, 0, 0, 0, DATETIME_Null, DATETIME_Null, SH_cls_Commit )
.head 7 -  Return TRUE

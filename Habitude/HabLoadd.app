.head 3 +  Function: CheckLoadCustForgottenOrders
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: sLoadId
.head 5 -  Number: nCustNo
.head 5 -  Number: nLoadCustInstNo
.head 5 -  String: sLoadOrdType
.head 5 -  Number: nYear
.head 5 -  Date/Time: dtShipDate

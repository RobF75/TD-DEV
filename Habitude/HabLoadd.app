.head 4 +  Message Actions
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLTABLENAME = ' CUSTOMER_ORDER '
.head 6 -  Set sSQLPOPTABLENAME = ' CUSTOMER_ORDER, STOCK_ITEM'
.head 6 -  Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO =
 :frmAddCustSelectionOrdsOnLoad.dfCustNo AND 
 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
 CUSTOMER_ORDER.CONF_AMT > 0 AND 
 NOT CUSTOMER_ORDER.INVOICED_FLAG = 'Y' AND 
 ( Customer_Order.Hold_Order_Date <= :frmAddCustSelectionOrdsOnLoad.dfShipDate OR 
    Customer_Order.Hold_Order_Date IS NULL ) AND 
 CUSTOMER_ORDER.YEAR_OF_SALE = :frmAddCustSelectionOrdsOnLoad.dfYear AND
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO "
.head 6 -  !
.head 6 -  Set sORDERBY = ' ORDER BY 2,3,4,5,9 '
.head 6 -  Set sROWID = ' CUSTOMER_ORDER.ROWID '
.head 6 -  Set sTableHeading = 'Add Customer Selection Order onto This Load'
.head 6 -  Set hWndRowNewColumn = colOrderDate
.head 6 -  Set bSelectFirstRow = FALSE
.head 6 -  Set nTableFillType = TBL_FillAll
.head 5 +  On PAM_WRITEINSERTSUPDATES
.head 6 -  Call MyTableLoop( hWndForm, hWndForm, PAM_ROWACTION, ROW_Selected, 0, 'Save Changes', nLowToHi )
.head 5 +  On PAM_ROWACTION
.head 6 +  If UpdateCustOrdLoadId( colCustNo, nCustInstanceNo, colOrderDateTime, frmAddCustSelectionOrdsOnLoad.dfLoadId, SH_cls_Execute )
.head 7 -  Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
.head 7 -  Return nRowDeleted
.head 6 +  Else
.head 7 -  Return TRUE
.head 5 +  On SAM_Destroy
.head 6 -  Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
.head 6 -  Call UpdateCustOrdLoadId( 0, 0, DATETIME_Null, '', SH_cls_Disconnect )

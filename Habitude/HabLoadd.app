  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
  Customer_Order.Conf_Amt > 0 AND 
  Stock_Item.Prod_Royalty = Prod_Royalty_Class.Prod_Royalty AND 
  Prod_Royalty_Class.Royalty_Company != 'F' AND
  NOT Customer_Order.Invoiced_Flag = 'Y' AND 
  NOT Customer_Order.Pull_Sheet_Issued = 'Y' and
  Customer_Order.Sale_Cat not in ('FC', 'RP', 'TT', 'FR', 'HR') "

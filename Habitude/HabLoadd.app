.head 7 +  If IDYES = SalMessageBox( 'This function will remove any trace of the selected loads of the system! Continue?', 'Warning', MB_YesNo | MB_DefButton2 )
.head 8 -  Set nYear = cSeasonYear.GetSeasonYear( )
.head 8 -  Call MyTableLoop( tblLoads, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Deleting Loads', nLowToHiWithPositioning )
.head 8 -  Call SalSendMsg( tblLoads, PAM_REPOPULATE, 0, 0 )
.head 6 +  On PAM_ROWACTION
.head 7 +  If tblLoads.colLoadId = 'MARKET' or tblLoads.colLoadId = 'CUSTINV' or tblLoads.colLoadId = 'GONE' or tblLoads.colLoadId = 'RECLAIM' or tblLoads.colLoadId = 'PICKUPS' 
.head 8 -  Call SalMessageBox( 'A Load encountered that cannot be deleted as it is one of the required loads!', 'Note', MB_Ok )
.head 8 -  Return FALSE
.head 7 +  If AnyPullnNotInvOrdsOnLoad( tblLoads.colLoadId, nYear, bAny, SH_cls_Execute )
.head 8 +  If bAny
.head 9 +  If DeleteCustOrdersFromLoad( tblLoads.colLoadId, nYear, SH_cls_Execute )
.head 10 -  Call DeleteCustOrdersFromLoad( '', 0, SH_cls_Commit )
.head 9 -  Call SalMessageBox( 'A Load encountered that cannot be deleted as it has pulled but not invoiced orders on it!', 'Note', MB_Ok )
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 +  If DeleteCustOrdersFromLoad( tblLoads.colLoadId, nYear, SH_cls_Execute )
.head 10 +  If DeleteCustFromLoad( tblLoads.colLoadId, nYear, SH_cls_Execute )
.head 11 +  If DeleteLoadFromRegion( tblLoads.colLoadId, SH_cls_Execute )
.head 12 +  If DeleteLoad( tblLoads.colLoadId, SH_cls_Execute )
.head 13 -  Call DeleteLoad( '', SH_cls_Commit )
.head 13 -  Call DeleteLoadFromRegion( '', SH_cls_Commit )
.head 13 -  Call DeleteCustFromLoad( '', 0, SH_cls_Commit )
.head 13 -  Call DeleteCustOrdersFromLoad( '', 0, SH_cls_Commit )
.head 13 -  Return TRUE
.head 12 +  Else

.head 8 -  Call SalSendMsg( hWndForm, PAM_ALLREGONSELLOADS, 0, 0 )
.head 8 -  Set nTmp = SalMessageBox( 'Do you want the Pots version only?', 'Customers In Regions Not On Loads', MB_YesNoCancel )
.head 8 +  If nTmp = IDYES
.head 9 -  Set sStockType = 'CONT'
.head 8 +  Else If nTmp = IDNO

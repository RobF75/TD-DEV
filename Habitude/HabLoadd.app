.head 3 -  Contents
.head 2 -  Contents
.head 2 -  Functions
.head 2 +  Window Parameters
.head 3 -  String: sLoadId
.head 3 -  Number: naArrayNos[*]
.head 3 -  Number: nActionType
.head 2 +  Window Variables
.head 3 -  Number: nSeqCount
.head 3 -  Number: nLoopCount
.head 3 -  Number: nQuantityCount
.head 3 -  Number: nCustNo
.head 3 -  Number: nLabelCustNo
.head 3 -  String: sSqlSelect
.head 3 -  Sql Handle: hSqlSelect
.head 3 -  String: sSqlUpdate
.head 3 -  Sql Handle: hSqlUpdate
.head 3 -  Number: nErr
.head 3 -  Boolean: bCustActionedFlag
.head 2 +  Message Actions
.head 3 +  On SAM_Create
.head 4 -  Call SalHideWindow( hWndForm )
.head 3 +  On SAM_CreateComplete
.head 4 -  !
.head 4 -  Call SetPrinter('StockItemLabels')
.head 4 -  Call SalArrayGetUpperBound( naArrayNos, 1, nSeqCount )
.head 4 -  !
.head 4 -  Set nLoopCount = 0
.head 4 +  While nLoopCount < nSeqCount
.head 5 -  Set sSqlSelect = 
"SELECT
	CO.Cust_No,
	SUM(CO.Conf_amt)
FROM
	Load_Customers LC,
	Customer_Order CO

INTO	:nCustNo
	:nQuantityCount

WHERE
	LC.Cust_No = CO.Cust_No
AND	LC.Load_Id = CO.Load_Id 
AND	LC.Load_Cust_Inst_No = CO.Load_Cust_Inst_No
AND	(LC.Sold_Label_Flag = 'N' OR LC.Sold_Label_Flag IS NULL)
AND	CO.Load_Id = :sLoadId
AND	LC.Sequence_No = :naArrayNos[nLoopCount]

GROUP BY 1"
.head 5 -  !
.head 5 +  If SqlConnect( hSqlSelect )
.head 6 +  If SqlPrepareAndExecute ( hSqlSelect, sSqlSelect )
.head 7 +  If SqlFetchNext ( hSqlSelect, nErr )
.head 8 +  If SalReportPrint( hWndForm,  'k:\\Centura\\Reports\\SoldLabels.qrp', 'nCustNo', 'nLabelCustNo', nQuantityCount, RPT_PrintAll, 0, 0, nErr )
.head 9 -  Set sSqlUpdate = 
"UPDATE
	Load_Customers
SET
	Sold_Label_Flag = 'Y'
WHERE
	Load_Id = :sLoadId
AND	Sequence_No = :naArrayNos[nLoopCount]"
.head 9 -  !
.head 9 -  Call SqlImmediate( sSqlUpdate )
.head 9 -  !
.head 6 -  Call SqlDisconnect( hSqlSelect )
.head 5 -  !
.head 5 -  Set nLoopCount = nLoopCount + 1
.head 4 -  !
.head 4 -  Call SalDestroyWindow( hWndForm )
.head 3 +  On SAM_ReportStart
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchInit
.head 4 -  Set bCustActionedFlag = FALSE
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchNext
.head 4 +  If bCustActionedFlag = TRUE
.head 5 -  Set bCustActionedFlag = FALSE
.head 4 +  Else
.head 5 -  Set bCustActionedFlag = TRUE
.head 4 -  Return bCustActionedFlag
.head 3 +  On SAM_ReportFinish
.head 4 -  Return TRUE
.head 3 +  On SAM_Destroy
.head 4 -  Call SqlClearImmediate ( )
.head 4 -  Call SetDefaultPrinter(  )

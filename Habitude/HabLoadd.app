.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set nOrigInstNo = nLoadCustInstNo
.head 7 +  If ExistsCustOnLoad( sLoadIdTo, nCustNo, nLoadCustInstNo, bExists, SH_cls_Execute )
.head 8 -  Set bCustomerMoved = FALSE
.head 8 +  If NOT bExists
.head 9 +  If GetLoadMaxSeq( sLoadIdTo, nNewSeqNo, SH_cls_Execute )
.head 10 -  Set nNewSeqNo = nNewSeqNo + 5
.head 10 +  If ChangeCustLoadToLoad( sLoadIdFrom, sLoadIdTo, nCustNo, nOrigInstNo, nLoadCustInstNo, nNewSeqNo, SH_cls_Execute )
.head 11 -  Set bCustomerMoved = TRUE
.head 10 +  Else 
.head 11 -  Return FALSE
.head 9 +  Else 
.head 10 -  Return FALSE
.head 8 +  If ChangeCustOrdLoadToLoad( sLoadIdFrom, sLoadIdTo, nCustNo, nOrigInstNo, nLoadCustInstNo, nCurrentYear, SH_cls_Execute )
.head 9 +  If bCustomerMoved
.head 10 -  Call MoveCustLoadToLoad( '', '', 0, 0, 0, SH_cls_Commit )
.head 9 -  Call ChangeCustOrdLoadToLoad( '', '', 0, 0, 0, 0, SH_cls_Commit )
.head 9 -  Return TRUE
.head 8 +  Else 
.head 9 -  Call MoveCustLoadToLoad( '', '', 0, 0, 0, SH_cls_Rollback )
.head 9 -  Return FALSE
.head 7 +  Else 
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Commit
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT ChangeCustLoadToLoad( '', '', 0, 0, 0, 0, SH_cls_Commit )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT ChangeCustOrdLoadToLoad( '', '', 0, 0, 0, 0, SH_cls_Commit )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case SH_cls_Rollback
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT ChangeCustLoadToLoad( '', '', 0, 0, 0, 0, SH_cls_Rollback )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT ChangeCustOrdLoadToLoad( '', '', 0, 0, 0, 0, SH_cls_Rollback )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Set bOk = FALSE
.head 7 +  If NOT ChangeCustLoadToLoad( '', '', 0, 0, 0, 0, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT ChangeCustOrdLoadToLoad( '', '', 0, 0, 0, 0, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT ExistsCustOnLoad( '', 0, nTmp, bExists, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT GetLoadMaxSeq( '', nNewSeqNo, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk

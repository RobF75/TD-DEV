.head 4 +  Message Actions
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLTABLENAME = ' REGION_LOAD '
.head 6 -  Set sSQLPOPTABLENAME = ' REGION_LOAD, REGION, FREIGHT_CODES '
.head 6 -  Set sSQLWHERE = ' WHERE Region_Load.Region_Id = Region.Region_Id AND 
  Region.Freight_Code = Freight_Codes.Freight_Code(+) AND 
  Region_Load.Load_Id = :frmRegionsOnLoad.dfLoadId'
.head 6 -  Set sORDERBY = ' ORDER BY Region_Load.Region_Id '
.head 6 -  Set sROWID = ' REGION_LOAD.ROWID '
.head 6 -  Set sTableHeading = 'Regions On Load'
.head 6 -  Set hWndRowNewColumn = colRegionId
.head 6 -  Set nTableFillType = TBL_FillAll
.head 5 +  On SAM_Destroy
.head 6 -  Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
.head 6 -  Call LoadIdRegionIdExists( '', '', SH_cls_Disconnect )

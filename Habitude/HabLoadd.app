.head 11 -  ! Set sSql = " SELECT 
  Sum( distinct Conf_Amt ) 
FROM 
  Customer_Order,
Stock_Item,
Growing_Sale,
Location
WHERE 
Customer_order.stock_item_no = stock_item.item_no and
Growing_Sale.Stock_item_no = customer_order.stock_item_no and
customer_order.batch_location_id = location.location_id and
growing_sale.location_id = location.location_id and
  Cust_No = :1 AND 
  customer_order.Year_Of_Sale = :2 AND 
  customer_order.Load_Id IS NULL AND 
  ( NOT Invoiced_Flag = 'Y' OR 
    Invoiced_Flag IS NULL ) AND 
  ( NOT Pull_Sheet_Issued = 'Y' OR 
    Pull_Sheet_Issued IS NULL )  and
  stock_type = 'C' and
Est_Sale_Date <= (Select
		Shipping_date
		from
			load
		where
			load_id = :3) " 

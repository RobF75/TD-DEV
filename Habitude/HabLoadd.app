.head 5 -  String: sModuleParent
.head 5 -  String: sTemp
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  !
.head 7 +  If sLoadOrdType = 'A' OR sLoadOrdType = 'E'
.head 8 -  Set nLoadOrderType = nAllOrders
.head 7 +  Else If sLoadOrdType = 'F'
.head 8 -  Set nLoadOrderType = nFruitOrders
.head 7 +  Else If sLoadOrdType = 'O'
.head 8 -  Set nLoadOrderType = nOrnamOrders
.head 7 +  Else If sLoadOrdType = 'ANC'
.head 8 -  Set nLoadOrderType = nAllOrders | nWithOutContainers
.head 7 +  Else If sLoadOrdType = 'FNC'
.head 8 -  Set nLoadOrderType = nFruitOrders | nWithOutContainers
.head 7 +  Else If sLoadOrdType = 'ONC'
.head 8 -  Set nLoadOrderType = nOrnamOrders | nWithOutContainers
.head 7 +  Else If sLoadOrdType = 'C'
.head 8 -  Set nLoadOrderType = nContainerOrders
.head 7 +  Else If sLoadOrdType = 'S'
.head 8 -  Set nLoadOrderType = nSelectionOrders
.head 7 +  Else
.head 8 -  Set nLoadOrderType = nAllOrders
.head 7 -  !
.head 7 +  If ExtractCustOrdToGoOnLoadBrief( sLoadId, nYear, nCustNo, nLoadCustInstNo, nLoadOrderType, dtShipDate, SH_cls_Execute )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call ExtractCustOrdToGoOnLoad( '', 0, 0, 0, 0, dtaOrdSysDTs, sTemp, DATETIME_Null, SH_cls_Disconnect )
.head 7 -  Return TRUE
.head 3 +  Function: ExtractCustOrdToGoOnLoadBrief
.head 4 -  Description: depending on the order Type
Use nOrderLoadType constants :- 
    nSelectionOrder, 
    nContainerOrders,
    nAllOrders,
    nFruitOrders,
    nOrnamOrders,
    nAllOrders | nWithOutContainers,

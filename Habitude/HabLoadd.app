.head 5 +  Message Actions 
.head 6 +  On PAM_CLICK
.head 7 +  If SalIsNull( dfLoadIdTo )
.head 8 -  Call SalMessageBox( 'Please enter a TO Load Id first! ', 'Warning', MB_Ok )
.head 7 +  Else 
.head 8 +  If ExistsLoad( dfLoadIdTo, bExists, SH_cls_Execute )
.head 9 +  If bExists
.head 10 -  Set bError = FALSE
.head 10 -  !
.head 10 -  Set nCustNoPos = 0
.head 10 +  While naCustNos[ nCustNoPos ] > 0
.head 11 +  If NOT  MoveCustLoadToLoad( dfLoadIdFrom, dfLoadIdTo, naCustNos[ nCustNoPos ], naLoadCustInstNos[ nCustNoPos ], nCurrentYear, SH_cls_Execute )
.head 12 -  Set bError = TRUE
.head 11 -  Set nCustNoPos = nCustNoPos + 1
.head 10 -  !
.head 10 +  If bError
.head 11 -  Call SalSendMsg( pbCancel, SAM_Click, 0, FALSE )
.head 10 +  Else 
.head 11 -  Call SalSendMsg( pbCancel, SAM_Click, 0, TRUE )
.head 9 +  Else 
.head 10 -  Call SalMessageBox( 'The TO Load Id is invalid! Please pick a valid one! ', 'Warning', MB_Ok )
.head 8 +  Else 
.head 9 -  Call SalMessageBox( 'Nothing has been moved! Please try again!', 'Warning', MB_Ok )

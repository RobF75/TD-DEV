.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Set nNumRowsCount = 0
.head 5 +  On PAM_ADDROW
.head 6 -  Call TableAddRowNew( hWndForm, hWndNULL )
.head 6 -  Set colLoadOrdType = wParam
.head 6 -  ! lParam contains cust_no:instance_no eg. 333609:1
.head 6 -  Set sTmpStr = SalNumberToHString( lParam )
.head 6 -  Set nPos = SalStrScan( sTmpStr, ':' )
.head 6 -  Set colCustNo = SalStrToNumber( SalStrLeftX( sTmpStr, nPos ) )
.head 6 -  Set colCustInstanceNo = SalStrToNumber( SalStrMidX( sTmpStr, nPos + 1, SalStrLength( sTmpStr ) - nPos + 1 ) )
.head 6 -  Set colOrderDateTime = DATETIME_Null
.head 6 -  Set nNumRowsCount = nNumRowsCount + 1
.head 6 -  Return TRUE
.head 5 +  On PAM_ADDSELECTIONORDROW
.head 6 -  Call TableAddRowNew( hWndForm, hWndNULL )
.head 6 -  Call PopNumber( colCustNo, TRUE )
.head 6 -  Set colLoadOrdType = nSelectionOrders
.head 6 -  Call PopDateTime( colOrderDateTime, TRUE )
.head 6 -  Set nNumRowsCount = nNumRowsCount + 1
.head 6 -  Return TRUE
.head 5 +  On PAM_WRITEINSERTSUPDATES
.head 6 -  Call SalWaitCursor( TRUE )
.head 6 +  If nNumRowsCount > 1
.head 7 -  Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Updating Customer Orders', nNumRowsCount )
.head 6 +  Else
.head 7 -  Set hWndMeter = hWndNULL
.head 6 -  Set bError = FALSE
.head 6 -  ! Set nYear = OurDateYear( frmNewLoadCust.dfShippingDate )
.head 6 -  Set nYear = frmNewLoadCust.cSeasonYear.GetSeasonYear( )
.head 6 -  Set nRow = TBL_MinRow
.head 6 +  While SalTblFindNextRow( hWndForm, nRow, 0, 0 )
.head 7 -  Call SalTblSetContext( hWndForm, nRow )
.head 7 +  If NewAddCustOrdTypeToLoad( frmNewLoadCust.dfLoadId, nYear, colCustNo, colCustInstanceNo, colLoadOrdType, colOrderDateTime, dfShippingDate, SH_cls_Execute )
.head 8 -  Call NewAddCustOrdTypeToLoad( '', 0, 0, 0, 0, DATETIME_Null, DATETIME_Null, SH_cls_Commit )
.head 7 +  Else
.head 8 -  Call NewAddCustOrdTypeToLoad( '', 0, 0, 0, 0, DATETIME_Null, DATETIME_Null, SH_cls_Rollback )
.head 8 -  Set bError = TRUE
.head 7 -  Call SalSendMsg( hWndMeter, PAM_clsMTR_SETPROGRESS, 0, nRow )
.head 6 -  Call SalSendMsg( hWndMeter, PAM_clsMTR_END, 0, 0 )
.head 6 -  Call SalTblReset( hWndForm )
.head 6 -  Call SalWaitCursor( FALSE )
.head 6 +  If bError
.head 7 -  Call SalMessageBox( 'Not all customers on this load had their orders updated!  You are advised to refresh all customers!', 'Error', MB_Ok )
.head 5 +  On SAM_Destroy
.head 6 -  Call NewAddCustOrdTypeToLoad( '', 0, 0, 0, 0, DATETIME_Null, DATETIME_Null, SH_cls_Disconnect )
.head 6 -  Call UpdateOrderToLoadId( '', 0, 0, DATETIME_Null, DATETIME_Null, SH_cls_Disconnect )
.head 6 -  ! Call GetVarietyType( 0, sTmpStr, SH_cls_Disconnect )

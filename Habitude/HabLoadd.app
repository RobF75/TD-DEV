.head 7 +  On PAM_LOOKUPCUST
.head 8 -  Call PopNumber( nOrderType, TRUE )
.head 8 -  !
.head 8 +  If IsFlagSet( nOrderType, nAllOrders )
.head 9 +  If IsFlagSet( nOrderType, nWithOutContainers )
.head 10 -  Set colOrdType = 'ANC'
.head 9 +  Else
.head 10 -  Set colOrdType = 'A'
.head 8 +  Else If IsFlagSet( nOrderType, nFruitOrders )
.head 9 +  If IsFlagSet( nOrderType, nWithOutContainers )
.head 10 -  Set colOrdType = 'FNC'
.head 9 +  Else
.head 10 -  Set colOrdType = 'F'
.head 8 +  Else If IsFlagSet( nOrderType, nOrnamOrders )
.head 9 +  If IsFlagSet( nOrderType, nWithOutContainers )
.head 10 -  Set colOrdType = 'ONC'
.head 9 +  Else
.head 10 -  Set colOrdType = 'O'
.head 8 +  Else If IsFlagSet( nOrderType, nContainerOrders )
.head 9 -  Set colOrdType = 'C'
.head 8 +  Else If IsFlagSet( nOrderType, nContainerOrdersReady )
.head 9 -  Set colOrdType = 'C'
.head 8 -  ! ! P# 1, JJ, 17/4/99
.head 8 +  Else If IsFlagSet( nOrderType, nBareRootPottedOrders )
.head 9 +  If IsFlagSet( nOrderType, nWithOutContainers )
.head 10 -  Set colOrdType = 'PNC'
.head 9 +  Else
.head 10 -  Set colOrdType = 'P'
.head 8 -  ! ! P# 1, JJ, 17/4/99 end.
.head 8 -  !
.head 8 -  Call SalSetFieldEdit( hWndItem, TRUE )
.head 7 +  On PAM_ROWINSERTED
.head 8 -  ! make pointer of customers information ie. CustNo and InstanceNo.
.head 8 -  Set nTemp = SalHStringToNumber( SalNumberToStrX( colCustNo, 0 ) || ':' || SalNumberToStrX( colCustInstanceNo, 0 ) )
.head 8 +  If colOrdType = 'A' OR colOrdType = 'E'
.head 9 -  Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nAllOrders, nTemp )
.head 8 +  Else If colOrdType = 'F'
.head 9 -  Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nFruitOrders, nTemp )
.head 8 +  Else If colOrdType = 'O'
.head 9 -  Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nOrnamOrders, nTemp )
.head 8 +  Else If colOrdType = 'ANC'
.head 9 -  Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nAllOrders | nWithOutContainers, nTemp )
.head 8 +  Else If colOrdType = 'FNC'
.head 9 -  Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nFruitOrders | nWithOutContainers, nTemp )
.head 8 +  Else If colOrdType = 'ONC'
.head 9 -  Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nOrnamOrders | nWithOutContainers, nTemp )
.head 8 +  Else If colOrdType = 'C'
.head 9 -  Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nContainerOrders, nTemp )
.head 8 -  ! ! P# 1, JJ, 17/4/99
.head 8 +  Else If colOrdType = 'P'
.head 9 -  Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nBareRootPottedOrders, nTemp )
.head 8 +  Else If colOrdType = 'PNC'
.head 9 -  Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nBareRootPottedOrders | nWithOutContainers, nTemp )
.head 8 -  ! ! P# 1, JJ, 17/4/99 end.
.head 8 -  Set colOrdTypeChanged = FALSE
.head 8 -  ! selection orders are trapped on click and tblAddCustOrdToLoad is filled seperately.
.head 8 -  ! Dani commented out the class message sends of row updated and row inserted because nothing
is processed after this column and these sends are killing the column edited flag which means more 
than 1 changed row is not being processed as the column edited is no longer true  
.head 8 -  ! Call SalSendClassMessage( PAM_ROWINSERTED, wParam, lParam )
.head 7 +  On PAM_ROWUPDATED
.head 8 +  If colOrdTypeChanged
.head 9 -  Call RemoveCustOrdersFromLoad( frmNewLoadCust.dfLoadId, 
  colCustNo, colCustInstanceNo, frmNewLoadCust.cSeasonYear.GetSeasonYear( ), SH_cls_Execute )
.head 9 +  If colOrdType != 'S'

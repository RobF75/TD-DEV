.head 4 -  Functions
.head 4 -  Window Variables
.head 4 +  Message Actions
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLTABLENAME = ' CUSTOMER_ORDER '
.head 6 -  Set sSQLPOPTABLENAME = ' CUSTOMER_ORDER, CUSTOMER_MASTER, STOCK_ITEM'
.head 6 -  !
.head 6 +  If frmOutstandOrdersOnOrAllRegions.bContWanted
.head 7 +  If frmOutstandOrdersOnOrAllRegions.nActionType = nAllRegions
.head 8 -  Set sSQLWHERE = ' WHERE CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
 CUSTOMER_ORDER.CONF_AMT > 0 AND 
 CUSTOMER_ORDER.YEAR_OF_SALE = :frmOutstandOrdersOnOrAllRegions.nYear AND
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO '
.head 7 +  Else
.head 8 -  Set sSQLWHERE = ' WHERE CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
 CUSTOMER_MASTER.REGION_ID = :frmOutstandOrdersOnOrAllRegions.sRegionId AND  
 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
 CUSTOMER_ORDER.CONF_AMT > 0 AND 
 CUSTOMER_ORDER.YEAR_OF_SALE = :frmOutstandOrdersOnOrAllRegions.nYear AND
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO '
.head 6 +  Else
.head 7 +  ! If frmOutstandOrdersOnOrAllRegions.nActionType = nAllRegions
.head 8 -  Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
 CUSTOMER_ORDER.CONF_AMT > 0 AND 
 CUSTOMER_ORDER.YEAR_OF_SALE = :frmOutstandOrdersOnOrAllRegions.nYear AND
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND 
 NOT STOCK_ITEM.TREE_TYPE LIKE 'C%' "
.head 7 +  ! Else
.head 8 -  Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
 CUSTOMER_MASTER.REGION_ID = :frmOutstandOrdersOnOrAllRegions.sRegionId AND  
 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
 CUSTOMER_ORDER.CONF_AMT > 0 AND 
 CUSTOMER_ORDER.YEAR_OF_SALE = :frmOutstandOrdersOnOrAllRegions.nYear AND
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO  AND 
 NOT STOCK_ITEM.TREE_TYPE LIKE 'C%' "
.head 7 +  If frmOutstandOrdersOnOrAllRegions.nActionType = nAllRegions
.head 8 -  Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
 CUSTOMER_ORDER.LOAD_ID IS NULL AND
 CUSTOMER_ORDER.CONF_AMT > 0 AND
 CUSTOMER_ORDER.YEAR_OF_SALE = :frmOutstandOrdersOnOrAllRegions.nYear AND
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND
 NOT STOCK_ITEM.STOCK_TYPE = 'C' AND NOT STOCK_ITEM.BARE_ROOT_POTTED = 'Y' "
.head 7 +  Else
.head 8 -  Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
 CUSTOMER_MASTER.REGION_ID = :frmOutstandOrdersOnOrAllRegions.sRegionId AND
 CUSTOMER_ORDER.LOAD_ID IS NULL AND
 CUSTOMER_ORDER.CONF_AMT > 0 AND
 CUSTOMER_ORDER.YEAR_OF_SALE = :frmOutstandOrdersOnOrAllRegions.nYear AND
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO  AND
 NOT STOCK_ITEM.STOCK_TYPE = 'C' AND NOT STOCK_ITEM.BARE_ROOT_POTTED = 'Y' "

 CUSTOMER_ORDER.INVOICED_FLAG IS NULL ) AND
 CUSTOMER_ORDER.YEAR_OF_SALE = :dlgCustOutstandOrders.nYear AND
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND
Customer_Order.Batch_Location_Id = Location.Location_Id and
Location.Location_Id = Growing_Sale.Location_Id and

.head 4 +  Functions
.head 5 +  ! New cls version in ITEM.APL Function: UpdateCustOrdLoadId
.head 6 -                                                                                                                                                           Description: Set the load_id for a customer order to the parameter sLoadId
Given the cust_no and Order_Date_Time.
This function commits/ rollsback it self
.head 6 +                                                                                                                                                           Returns 
.head 7 -                                                                                                                                                           Boolean: 
.head 6 +                                                                                                                                                           Parameters 
.head 7 -                                                                                                                                                           Number: nCustNo
.head 7 -                                                                                                                                                           Date/Time: dtOrdDT
.head 7 -                                                                                                                                                           String: sLoadId
.head 7 -                                                                                                                                                           Number: nActionType
.head 6 +                                                                                                                                                           Static Variables 
.head 7 -                                                                                                                                                           Sql Handle: hSqlHandle
.head 7 -                                                                                                                                                           Boolean: bHandleConnected
.head 7 -                                                                                                                                                           Boolean: bHandlePrepared
.head 6 +                                                                                                                                                           Local variables 
.head 7 -                                                                                                                                                           Boolean: bOk
.head 7 -                                                                                                                                                           String: sSql
.head 6 +                                                                                                                                                           Actions 
.head 7 +                                                                                                                                                           Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 +                                                                                                                                                           If NOT bHandleConnected
.head 10 -                                                                                                                                                           Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 10 +                                                                                                                                                           If bHandleConnected
.head 11 -                                                                                                                                                           Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 11 -                                                                                                                                                           Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 10 +                                                                                                                                                           Else 
.head 11 -                                                                                                                                                           Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 11 -                                                                                                                                                           Return FALSE
.head 9 +                                                                                                                                                           If NOT bHandlePrepared
.head 10 -                                                                                                                                                           Set sSql = ' UPDATE Customer_Order 
  SET Load_Id = :sLoadId 
  WHERE 
     Cust_No = :nCustNo AND 
     Order_Date_Time = :dtOrdDT '
.head 10 +                                                                                                                                                           If SqlPrepare( hSqlHandle, sSql )
.head 11 -                                                                                                                                                           Set bHandlePrepared = TRUE
.head 10 +                                                                                                                                                           Else 
.head 11 -                                                                                                                                                           Set bHandlePrepared = FALSE
.head 9 -  !
.head 9 +                                                                                                                                                           If SqlExecute( hSqlHandle )
.head 10 -  Call UpdateCustOrdLoadId( 0, DATETIME_Null, '', SH_cls_Commit )
.head 10 -                                                                                                                                                           Return TRUE
.head 9 +                                                                                                                                                           Else 
.head 10 -  ! Call UpdateCustOrdLoadId( 0, DATETIME_Null, '', SH_cls_Rollback )
.head 10 -                                                                                                                                                           Set bHandlePrepared = FALSE
.head 10 -                                                                                                                                                           Call SalMessageBox( 'SqlExecute had a error in UpdateCustOrdLoadId!, Contact programmers please!', 'ERROR', MB_Ok )
.head 10 -                                                                                                                                                           Return FALSE
.head 8 +  Case SH_cls_Commit
.head 9 -                                                                                                                                                           Set bOk = TRUE
.head 9 +                                                                                                                                                           If bHandleConnected
.head 10 -                                                                                                                                                           Set bOk = SqlCommit( hSqlHandle )
.head 9 -                                                                                                                                                           Return bOk
.head 8 +  Case SH_cls_Rollback
.head 9 -                                                                                                                                                           Set bOk = TRUE
.head 9 +                                                                                                                                                           If bHandleConnected
.head 10 -                                                                                                                                                           Set bOk = SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
.head 10 -                                                                                                                                                           Set bHandlePrepared = FALSE
.head 9 -                                                                                                                                                           Return bOk
.head 8 +  Case SH_cls_Disconnect
.head 9 -                                                                                                                                                           Set bOk = FALSE
.head 9 -                                                                                                                                                           Set bHandlePrepared = FALSE
.head 9 +                                                                                                                                                           If bHandleConnected
.head 10 -                                                                                                                                                           Set bHandleConnected = FALSE
.head 10 -                                                                                                                                                           Set bOk = SqlDisconnect( hSqlHandle )
.head 9 -                                                                                                                                                           Return bOk
.head 8 +                                                                                                                                                           Case nRePrepare
.head 9 -                                                                                                                                                           Set bHandlePrepared = FALSE
.head 9 -                                                                                                                                                           Return TRUE
.head 4 +  Window Variables
.head 5 -  Number: nTemp

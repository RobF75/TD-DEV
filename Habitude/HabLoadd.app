.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( '0905CheckLCust' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 +  If sLoadId = 'GONE'
.head 8 -  Return FALSE
.head 7 -  Set sSql = " SELECT
	cust_pulled_flag,
	cust_inv_flag
FROM
	load_customers
WHERE
	load_id = :1 and
	cust_no = :2 and
	load_cust_inst_no = :3"
.head 7 -  Set sName = '0905CheckLCust'
.head 7 -  Set sBind = ' :sLoadId, :nCustNo, :nInstNo '
.head 7 -  Set sInto = ' :sPulled, :sInv'

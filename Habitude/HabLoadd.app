.head 8 +  If TakeOffCustOrdersFromLoad( frmNewLoadCust.dfLoadId, colCustNo, colCustInstanceNo, frmNewLoadCust.cSeasonYear.GetSeasonYear( ), SH_cls_Execute )
.head 9 -  Return TakeOffCustOrdersFromLoad( '', 0, 0, 0, SH_cls_Commit )

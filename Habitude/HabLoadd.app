.head 6 +  On PAM_CLICK
.head 7 +  If SalSendMsg( tblCustOnLoad, PAM_VALIDATESELECTION, 0, 0 )
.head 8 -  Set nTmp = SalMessageBox( 'Would you Like to REFRESH Orders', 'Maintain Orders', MB_YesNoCancel )
.head 8 +  If nTmp = IDYES
.head 9 -  Call SalSendMsg( hWndItem, PAM_UPDATE, 1, 1 )
.head 8 +  Else If nTmp = IDNO
.head 9 -  Set nTmp = SalMessageBox( 'Would you Like to REDO Orders', 'Maintain Orders', MB_YesNoCancel )
.head 9 +  If nTmp = IDYES
.head 10 -  Call SalSendMsg( hWndItem, PAM_UPDATE, 2, 1 )
.head 6 +  On PAM_UPDATE
.head 7 -  ! wParam = 1 = REFRESH
.head 7 -  ! wParam = 2 = REDO
.head 7 -  ! lParam = 1 = Comming from push button click
.head 7 -  ! lParam = 2 = Comming from menu item
.head 7 +  If lParam = 2
.head 8 +  If SalSendMsg( tblCustOnLoad, PAM_VALIDATESELECTION, 0, 0 )
.head 9 -  Set bContinue = TRUE
.head 8 +  Else
.head 9 -  Set bContinue = FALSE
.head 7 +  Else
.head 8 -  Set bContinue = TRUE
.head 7 -  !
.head 7 +  If bContinue
.head 8 -  Set nCount = 0
.head 8 -  Set nCustNos[ nCount ] = NUMBER_Null
.head 8 -  Set saOrdTypes[ nCount ] = ''
.head 8 -  Call MyTableLoop( tblCustOnLoad, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Collecting Customers', nLowToHi )
.head 8 -  !
.head 8 -  Set bOrderAdded = FALSE
.head 8 +  If nCount > 0
.head 9 -  Call SalWaitCursor( TRUE )
.head 9 +  If wParam = 1
.head 10 -  Call MaintainCustOrders( nCustNos, naLoadCustInstNos, saOrdTypes, dfLoadId, dfShippingDate, cSeasonYear.GetSeasonYear( ), 'REFRESH', bOrderAdded, SH_cls_Execute )
.head 9 +  Else
.head 10 -  Call MaintainCustOrders( nCustNos, naLoadCustInstNos, saOrdTypes, dfLoadId, dfShippingDate, cSeasonYear.GetSeasonYear( ), 'REDO', bOrderAdded, SH_cls_Execute )
.head 9 +  If bOrderAdded
.head 10 -  Call LoadPulledOrInvoiced(dfLoadId, sPulledFlag, sInvoicedFlag, SH_cls_Execute)
.head 10 +  If sPulledFlag = 'Y'
.head 11 -  Call SetLoadPulledFlagForAddedItems( dfLoadId, 'N', SH_cls_Execute )
.head 9 -  Call SalWaitCursor( FALSE )
.head 9 -  !
.head 9 -  Call SalSendMsgToChildren( hWndForm, PAM_POPULATE_CAPACITY, 1, 0 )

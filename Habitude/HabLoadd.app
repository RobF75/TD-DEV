.head 6 -  Set sSQLWHERE = ' WHERE Region_Load.Load_Id = Load.Load_Id AND Region_Load.Region_Id = :frmLoadsOnRegion.dfRegionId'
.head 6 -  Set sORDERBY = ' ORDER BY Region_Load.Load_Id '
.head 6 -  Set sROWID = ' REGION_LOAD.ROWID '
.head 6 -  Set sTableHeading = 'Loads On Region'
.head 6 -  Set hWndRowNewColumn = colLoadId
.head 6 -  Set nTableFillType = TBL_FillAll
.head 5 +  On SAM_Destroy
.head 6 -  Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
.head 6 -  Call LoadIdRegionIdExists( '', '', SH_cls_Disconnect )

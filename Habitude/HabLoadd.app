.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Boolean: bRefresh
.head 5 -  Number: nPos
.head 5 -  !
.head 5 -  Number: nRowCount
.head 5 -  Window Handle: hWndMeter
.head 5 -  !
.head 5 -  Number: nOrdType
.head 5 -  String: sPulledFlag
.head 5 -  String: sInvoicedFlag
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set nPos = 0
.head 7 +  While naCustNos[ nPos ] != NUMBER_Null
.head 8 -  Set nPos = nPos + 1
.head 7 -  !
.head 7 -  Set hWndMeter = hWndNULL
.head 7 -  !
.head 7 +  If nPos > 0
.head 8 +  If sType = 'REDO'
.head 9 -  Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Redoing Customers Orders', nPos )
.head 8 +  Else
.head 9 -  Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Refreshing Customers Orders', nPos )
.head 8 -  Set nRowCount = 0
.head 8 -  !
.head 8 -  Set nPos = 0
.head 8 +  While naCustNos[ nPos ] != NUMBER_Null
.head 9 -  Set nOrdType = NUMBER_Null
.head 9 -  !
.head 9 +  If saOrdTypes[ nPos ] = 'A' OR saOrdTypes[ nPos ] = 'E'
.head 10 -  Set nOrdType = nAllOrders
.head 10 -  Set bRefresh = TRUE
.head 9 +  Else If saOrdTypes[ nPos ] = 'F'
.head 10 -  Set nOrdType = nFruitOrders
.head 10 -  Set bRefresh = TRUE
.head 9 +  Else If saOrdTypes[ nPos ] = 'O'
.head 10 -  Set nOrdType = nOrnamOrders
.head 10 -  Set bRefresh = TRUE
.head 9 +  Else If saOrdTypes[ nPos ] = 'ANC'
.head 10 -  Set nOrdType = nAllOrders | nWithOutContainers
.head 10 -  Set bRefresh = TRUE
.head 9 +  Else If saOrdTypes[ nPos ] = 'FNC'
.head 10 -  Set nOrdType = nFruitOrders | nWithOutContainers
.head 10 -  Set bRefresh = TRUE
.head 9 +  Else If saOrdTypes[ nPos ] = 'ONC'
.head 10 -  Set nOrdType = nOrnamOrders | nWithOutContainers
.head 10 -  Set bRefresh = TRUE
.head 9 +  Else If saOrdTypes[ nPos ] = 'C'
.head 10 -  Set nOrdType = nContainerOrders
.head 10 -  Set bRefresh = TRUE
.head 9 -  ! ! P# 1, JJ, 17/4/99
.head 9 +  Else If saOrdTypes[ nPos ] = 'PNC'
.head 10 -  Set nOrdType = nBareRootPottedOrders | nWithOutContainers
.head 10 -  Set bRefresh = TRUE
.head 9 +  Else If saOrdTypes[ nPos ] = 'P'
.head 10 -  Set nOrdType = nBareRootPottedOrders
.head 10 -  Set bRefresh = TRUE
.head 9 -  ! ! P# 1, JJ, 17/4/99 end.
.head 9 +  Else
.head 10 -  Set bRefresh = FALSE
.head 9 -  !
.head 9 +  If bRefresh
.head 10 +  If sType = 'REDO'
.head 11 -  Call RemoveCustOrdersFromLoad( sLoadId, naCustNos[ nPos ], naLoadCustInstNos[ nPos ], nYear, SH_cls_Execute )
.head 10 +  If NewAddCustOrdTypeToLoad( sLoadId, nYear, naCustNos[ nPos ], naLoadCustInstNos[ nPos ], nOrdType, DATETIME_Null, dtShipDate, SH_cls_Execute )
.head 11 -  Call NewAddCustOrdTypeToLoad( '', 0, 0, 0, 0, DATETIME_Null, DATETIME_Null, SH_cls_Commit )
.head 11 -  Set bOrderAdded = TRUE
.head 11 -  Call LoadCustPulledOrInvoiced(sLoadId, naCustNos[ nPos ], naLoadCustInstNos[ nPos ], sPulledFlag, sInvoicedFlag, SH_cls_Execute)
.head 11 +  If sPulledFlag = 'Y'
.head 12 -  Call UpdateLoadCustPullFlag( sLoadId, naCustNos[ nPos ], naLoadCustInstNos[ nPos ], 'N', SH_cls_Execute )
.head 12 -  Call SetOrderAddedFlag( sLoadId, naCustNos[ nPos ], 'Y', SH_cls_Execute )
.head 11 -  ! Call LoadPulledOrInvoiced(sLoadId, sPulledFlag, sInvoicedFlag, SH_cls_Execute)
.head 11 +  ! If sPulledFlag = 'Y'
.head 12 -  Call SetLoadPulledFlagForAddedItems( sLoadId, 'N', SH_cls_Execute )
.head 11 -  ! Set nCount = 0
.head 11 +  ! While nCustNos[nCount] != NUMBER_Null
.head 12 -  Set nCount = nCount + 1
.head 9 -  !
.head 9 -  Set nRowCount = nRowCount + 1
.head 9 -  Call SalSendMsg( hWndMeter, PAM_clsMTR_SETPROGRESS, 0, nRowCount )
.head 9 -  !
.head 9 -  Set nPos = nPos + 1
.head 8 -  !
.head 8 -  Call SalSendMsg( hWndMeter, PAM_clsMTR_END, 0, 0 )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return TRUE
.head 6 +  ! Case SH_cls_Commit
.head 7 -                                                                                                                                                           Return fcOurHandle.Commit( )
.head 6 +  ! Case SH_cls_Rollback
.head 7 -                                                                                                                                                           Return fcOurHandle.Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call RemoveCustOrdersFromLoad( '', 0, 0, 0, SH_cls_Disconnect )
.head 7 -  ! Call SetLoadPulledFlagForAddedItems( '', '', SH_cls_Disconnect )
.head 7 -  Call UpdateLoadCustPullFlag( '', 0, 0, '', SH_cls_Disconnect )
.head 7 -  Call SetOrderAddedFlag( '', 0, '', SH_cls_Disconnect )
.head 7 -  Call LoadPulledOrInvoiced('', sPulledFlag, sInvoicedFlag, SH_cls_Disconnect)
.head 7 -  Call NewAddCustOrdTypeToLoad( '', 0, 0, 0, 0, DATETIME_Null, DATETIME_Null, SH_cls_Disconnect )
.head 7 -  Return TRUE

.head 6 +  Actions
.head 7 -  ! Number: nSqlHandleNo
.head 7 -  ! haSqlHandles[ nSqlHandleNo ]
.head 7 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GETITMAMTORD' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = " SELECT Amt_On_Order, On_Ord_As_Subs 
FROM Stock_Item_Sale
WHERE Stock_Item_No = :1 AND Year_Of_Sale = :2 "
.head 9 -  Set sName = 'GETITMAMTORD'
.head 9 -  Set sBind = ':nItemNo, :nYear'
.head 9 -  Set sInto = ':nGotAmtOnOrder, :nGotAmtOnOrderAsSubs'
.head 9 -  !
.head 9 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 9 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 -  Set nAmtOnOrder = 0
.head 9 -  Set nGotAmtOnOrder = 0
.head 9 -  !
.head 9 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 10 -  Call haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 10 -  Set nAmtOnOrder = nGotAmtOnOrder
.head 10 -  Set nAmtOnOrderAsSubs = nGotAmtOnOrderAsSubs
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 4 +  Window Variables
.head 5 -  Number: nRow
.head 5 -  Number: nDug
.head 5 -  Boolean: bFound
.head 5 -  Boolean: bItemNoExists
.head 5 -  Number: nItemAmtOnOrder
.head 5 -  Number: nItemAmtOnOrderAsSubs
.head 4 +  Message Actions
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sTableHeading = ''
.head 6 -  Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\trckstkDug.qrp'
.head 6 -  Set sPrinter = 'LaserPrinter'
.head 5 +  On PAM_POPULATE
.head 6 -  Call SalSendMsg( tblLoadStockNoGenBare, PAM_POPULATE, 0, 0 )
.head 6 -  Call SalSendMsg( tblLoadStockGenBare, PAM_POPULATE, 0, 0 )
.head 6 -  Call SalSendMsg( tblLoadStockCont, PAM_POPULATE, 0, 0 )
.head 6 +  If frmPrintTruckStockDugReport.bShowNotDug
.head 7 -  Call MyTableLoop( hWndForm, hWndForm, PAM_ROWACTION, 0, 0, 'Calculating NOT dug', nLowToHi )
.head 5 +  On PAM_ROWACTION
.head 6 -  Set nDug = GetGradedAmt( colItemNo, SH_cls_Execute )
.head 6 -  Set colStillOutstand = nDug - (colItemConfAmt + colSubConfAmt)
.head 6 +  If colStillOutstand > 0
.head 7 -  Set colStillOutstand = NUMBER_Null
.head 6 -  Return TRUE
.head 5 +  On PAM_ADDROW
.head 6 +  If wParam = 3
.head 7 -  Set bFound = FALSE
.head 7 -  Set nRow = TBL_MinRow
.head 7 +  While NOT bFound AND SalTblFindNextRow( hWndForm, nRow, ROW_UnusedFlag2, 0 )
.head 8 -  Call SalTblFetchRow( hWndForm, nRow )
.head 8 +  If tblLoadStockCont.colFarmName < colFarmName
.head 9 -  Set bFound = TRUE
.head 8 +  Else If tblLoadStockCont.colFarmName = colFarmName
.head 9 +  If tblLoadStockCont.colRowNo < colRowNo
.head 10 -  Set bFound = TRUE
.head 9 +  Else If tblLoadStockCont.colRowNo = colRowNo
.head 10 +  If tblLoadStockCont.colSeqNo < colSeqNo
.head 11 -  Set bFound = TRUE
.head 10 +  Else If tblLoadStockCont.colSeqNo = colSeqNo
.head 11 +  If tblLoadStockCont.colVarietyType < colVarietyType
.head 12 -  Set bFound = TRUE
.head 11 +  Else If tblLoadStockCont.colVarietyType = colVarietyType
.head 12 +  If tblLoadStockCont.colUpperVariety < colUpperVariety
.head 13 -  Set bFound = TRUE
.head 12 +  Else If tblLoadStockCont.colUpperVariety = colUpperVariety
.head 13 +  If tblLoadStockCont.colUpperCultDesc < colUpperCultDesc
.head 14 -  Set bFound = TRUE
.head 13 +  Else If tblLoadStockCont.colUpperCultDesc = colUpperCultDesc
.head 14 +  If tblLoadStockCont.colUpperRootDesc < colUpperRootDesc
.head 15 -  Set bFound = TRUE
.head 14 +  Else If tblLoadStockCont.colUpperRootDesc = colUpperRootDesc
.head 15 +  If tblLoadStockCont.colTreeTypeDesc < colTreeTypeDesc
.head 16 -  Set bFound = TRUE
.head 15 +  Else If tblLoadStockCont.colTreeTypeDesc = colTreeTypeDesc
.head 16 +  If tblLoadStockCont.colItemNo < colItemNo
.head 17 -  Set bFound = TRUE
.head 7 -  !
.head 7 +  If bFound
.head 8 -  Set nRow = SalTblInsertRow( hWndForm, nRow )
.head 7 +  Else
.head 8 -  Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
.head 7 -  !
.head 7 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_HideMarks, TRUE )
.head 7 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_UnusedFlag2, TRUE )
.head 7 -  Call SalTblSetContext( hWndForm, nRow )
.head 7 -  Set colItemNo = tblLoadStockCont.colItemNo
.head 7 -  Set colVarietyType = tblLoadStockCont.colVarietyType
.head 7 -  Set colVariety = tblLoadStockCont.colVariety
.head 7 -  Set colUpperVariety = tblLoadStockCont.colUpperVariety
.head 7 -  Set colTreeTypeDesc = tblLoadStockCont.colTreeTypeDesc
.head 7 -  Set colCultDesc = tblLoadStockCont.colCultDesc
.head 7 -  Set colUpperCultDesc = tblLoadStockCont.colUpperCultDesc
.head 7 -  Set colRootDesc = tblLoadStockCont.colRootDesc
.head 7 -  Set colUpperRootDesc = tblLoadStockCont.colUpperRootDesc
.head 7 -  Set colItemConfAmt = tblLoadStockCont.colConfAmt
.head 7 -  Set colFarmName = tblLoadStockCont.colFarmName
.head 7 -  Set colShortFarmName = tblLoadStockCont.colShortFarmName
.head 7 -  Set colRowNo = tblLoadStockCont.colRowNo
.head 7 -  Set colSeqNo = tblLoadStockCont.colSeqNo
.head 6 +  Else
.head 7 -  Set bItemNoExists = FALSE
.head 7 +  If wParam = 2
.head 8 -  Set nRow = TBL_MinRow
.head 8 +  While NOT bItemNoExists AND SalTblFindNextRow( hWndForm, nRow, 0, 0 )
.head 9 -  Call SalTblFetchRow( hWndForm, nRow )
.head 9 +  If tblLoadStockGenBare.colItemNo = colItemNo
.head 10 -  Set bItemNoExists = TRUE
.head 7 -  !
.head 7 -  !
.head 7 +  If bItemNoExists
.head 8 -  Set colSubConfAmt = colSubConfAmt + tblLoadStockGenBare.colConfAmt
.head 7 +  Else
.head 8 -  Set bFound = FALSE
.head 8 -  Set nRow = TBL_MinRow
.head 8 +  While NOT bFound AND SalTblFindNextRow( hWndForm, nRow, 0, 0 )
.head 9 -  Call SalTblFetchRow( hWndForm, nRow )
.head 9 +  If wParam = 1
.head 10 +  ! If tblLoadStockNoGen.colVarietyType < colVarietyType
.head 11 -   Set bFound = TRUE

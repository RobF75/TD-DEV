.head 8 -  Call SalMessageBox( 'Please pick a region first!', 'Warning', MB_Ok )
.head 7 +  Else
.head 8 +  If RegionIdExists( dfRegionId, SH_cls_Execute )
.head 9 +  If NOT SalCreateWindow( frmOutstandOrdersOnOrAllRegions, hWndForm, dfRegionId, nOneRegion, rbContWanted )
.head 10 -  Call SalMessageBox( 'Can NOT create screen! Not enough memory!', 'Error', MB_Ok )
.head 8 +  Else
.head 9 -  Call SalMessageBox( 'Region does not exists!  Please Pick a region via the Region button.', 'Warning', MB_Ok )
.head 8 +  ! If NewRegionIdExists( dfRegionId, SH_cls_Execute )
.head 9 +                                                                                                                                                           If NOT SalCreateWindow( frmOutstandOrdersOnOrAllRegions, hWndForm, dfRegionId, nOneRegion )
.head 10 -                                                                                                                                                           Call SalMessageBox( 'Can NOT create screen! Not enough memory!', 'Error', MB_Ok )
.head 8 +  ! Else 
.head 9 -                                                                                                                                                           Call SalMessageBox( 'Region does not exists!  Please Pick a region via the Region button.', 'Warning', MB_Ok )

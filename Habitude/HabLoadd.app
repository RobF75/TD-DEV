.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'UpdtCustDenormMeetAddrs' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 +  If sSelectCustType = 'ALL'
.head 8 -  Set sSql = " SELECT  
  Customer_Address.Address_Meet_Id, 
  Customer_Address.Cust_No, 
  Meet_Address.Meet_Address_1, 
  Meet_Address.Meet_Address_2, 
  Meet_Address.Meet_Suburb, 
  Meet_Address.Meet_Postcode, 
  Meet_Address.Meet_State, 
  Meet_Address.Meet_Country, 
  Meet_Address.Meet_Area_Code, 
  Meet_Address.Meet_Phone_No, 
  Meet_Address.Meet_Area_Code_Fax, 
  Meet_Address.Meet_Fax_No, 
  Meet_Address.Meet_Comments 
FROM 
  Customer_Address, 
  Meet_Address 
INTO 
  :sGotMeetId, 
  :nGotCustNo, 
  :sGotAddress1, 
  :sGotAddress2, 
  :sGotSuburb, 
  :sGotPostcode, 
  :sGotState, 
  :sGotCountry, 
  :sGotAreaCode, 
  :sGotPhoneNo, 
  :sGotAreaCodeFax, 
  :sGotFaxNo, 
  :sGotComments 
WHERE 
  Customer_Address.Address_Meet_Id = Meet_Address.Meet_Id AND 
  (
    NOT Customer_Address.Address_1 = Meet_Address.Meet_Address_1 OR 
    NOT Customer_Address.Address_2 = Meet_Address.Meet_Address_2 OR 
    NOT Customer_Address.Suburb = Meet_Address.Meet_Suburb OR 
    NOT Customer_Address.Postcode = Meet_Address.Meet_Postcode OR 
    NOT Customer_Address.State = Meet_Address.Meet_State OR 
    NOT Customer_Address.Country = Meet_Address.Meet_Country OR 
    NOT Customer_Address.Area_Code = Meet_Address.Meet_Area_Code OR 
    NOT Customer_Address.Phone_No = Meet_Address.Meet_Phone_No OR 
    NOT Customer_Address.Area_Code_Fax = Meet_Address.Meet_Area_Code_Fax OR 

.head 10 -  Set bOk = FALSE
.head 9 +  Else
.head 10 +  If SqlFetchNext ( hSqlPlantsPlus, nFetch )
.head 11 +  If spCustNos != STRING_Null
.head 12 -  Set spCustNos = spCustNos || ',' 
.head 11 -  Set spCustNos = spCustNos || SalNumberToStrX ( colCustNo, 0 ) 
.head 9 -  Set nCurrentRow = nCurrentRow + 1
.head 8 -  Call SqlDisconnect ( hSqlPlantsPlus )
.head 7 -  Return bOk

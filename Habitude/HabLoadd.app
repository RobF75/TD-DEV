.head 6 +  On PAM_CLICK
.head 7 +  If SalSendMsg( tblTransport, PAM_VALIDATESELECTION, 0, 0 )
.head 8 +  If MyTableAnyRows( tblTransport, ROW_Selected, 0, nTransportCount )
.head 9 +  If nTransportCount > 1
.head 10 -  Call SalWaitCursor( FALSE )
.head 10 -  Call SalMessageBox( 'Please select one Transport only!', 'Warning', MB_Ok )
.head 10 -  Call SalWaitCursor( TRUE )
.head 9 +  Else
.head 10 -  Call SalModalDialog( dlgTransportCharges, hWndForm, tblTransport.colTranspId  )
.head 10 -  ! Call SalMessageBox( 'Can NOT create screen! Not enough memory!', 'Error', MB_Ok )

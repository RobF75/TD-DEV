.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = 'SELECT
	amt_graded,
	Tot_Avail,
	conf_amt,
	Amt_Shipped
FROM 
	Customer_Order co,
	stock_item_sale sis
WHERE 
	co.stock_item_no = sis.stock_item_no and
  	Load_Id = :1 AND
  	Cust_No = :2 AND 
  	sis.Year_Of_Sale = :3 AND
  	Load_Cust_Inst_No = :4 and
	sis.Stock_Item_No = :5 and
	Total_Graded > 0 and
	Order_Date_Time = :6 '
.head 9 -  Set sName = '3006CTotGraded2'
.head 9 -  Set sBind = ':sLoadId, :nCustNo, :nYear, :nLoadCustInstNo, :nItemNo, :dtOrdDT'
.head 9 -  Set sInto = ':nGotTotalTrees, :nTotAvail, :nConfAmt, :nAmtShipped '

.head 11 -  ! Set sSql = " SELECT 
  Sum( Conf_Amt ) 
FROM 
  Customer_Order,
Stock_Item
WHERE 
Customer_order.stock_item_no = stock_item.item_no and
  Cust_No = :1 AND 
  Year_Of_Sale = :2 AND 
  Load_Id IS NULL AND 
  ( NOT Invoiced_Flag = 'Y' OR 
    Invoiced_Flag IS NULL ) AND 
  ( NOT Pull_Sheet_Issued = 'Y' OR 
    Pull_Sheet_Issued IS NULL )  and
  stock_type = 'C' " 
.head 11 -  Set sSql = " SELECT
  Sum( Conf_Amt )
FROM
  Customer_Order,
Stock_Item
WHERE
Customer_order.stock_item_no = stock_item.item_no and
  Cust_No = :1 AND
  Year_Of_Sale = :2 AND
  Load_Id IS NULL AND
  ( NOT Invoiced_Flag = 'Y' OR
    Invoiced_Flag IS NULL ) AND
  ( NOT Pull_Sheet_Issued = 'Y' OR
    Pull_Sheet_Issued IS NULL )  and
  ( stock_type = 'C' OR ( stock_type = 'B' and bare_root_potted = 'Y' ) ) "

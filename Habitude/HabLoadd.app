.head 4 +  Message Actions
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 +  ! If sgStockType = 'C'
.head 7 +  ! If nOrdType = nContainerOrdersReady
.head 8 -  Set sSQLTABLENAME = ' CUSTOMER_ORDER '
.head 8 -  Set sSQLPOPTABLENAME = ' CUSTOMER_ORDER, STOCK_ITEM, Growing_Sale, Location'
.head 8 -  Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO =
 :dlgCustOutstandOrders.dfCustNo AND 
 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
 CUSTOMER_ORDER.CONF_AMT > 0 AND 
 ( CUSTOMER_ORDER.INVOICED_FLAG = 'N' OR 
 CUSTOMER_ORDER.INVOICED_FLAG IS NULL ) AND 
 CUSTOMER_ORDER.YEAR_OF_SALE = :dlgCustOutstandOrders.nYear AND
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND
Customer_Order.Batch_Location_Id = Location.Location_Id and
Location.Location_Id = Growing_Sale.Location_Id and
 Stock_Item.Stock_Type = 'C' and Est_Sale_Date <= 
		(Select
			Shipping_Date
		From
			Load
		Where
			Load_Id = :dlgCustOutstandOrders.sLoadId)"
.head 7 +  ! Else
.head 8 -  Set sSQLTABLENAME = ' CUSTOMER_ORDER '
.head 8 -  Set sSQLPOPTABLENAME = ' CUSTOMER_ORDER, STOCK_ITEM'
.head 8 -  Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO =
 :dlgCustOutstandOrders.dfCustNo AND 
 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
 CUSTOMER_ORDER.CONF_AMT > 0 AND 
 ( CUSTOMER_ORDER.INVOICED_FLAG = 'N' OR 
 CUSTOMER_ORDER.INVOICED_FLAG IS NULL ) AND 
 CUSTOMER_ORDER.YEAR_OF_SALE = :dlgCustOutstandOrders.nYear AND
 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND
 Stock_Item.Stock_Type = 'C' "
.head 7 +  If nOrdType = nContainerOrdersReady
.head 8 -  Set sSQLTABLENAME = ' CUSTOMER_ORDER '
.head 8 -  Set sSQLPOPTABLENAME = ' CUSTOMER_ORDER, STOCK_ITEM, Growing_Sale, Location'
.head 8 -  Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO =
 :dlgCustOutstandOrders.dfCustNo AND
 CUSTOMER_ORDER.LOAD_ID IS NULL AND
 CUSTOMER_ORDER.CONF_AMT > 0 AND

.head 13 -  Call DeleteCustFromLoad( '', 0, SH_cls_Rollback )
.head 13 -  Call DeleteCustOrdersFromLoad( '', 0, SH_cls_Rollback )
.head 13 -  Return FALSE
.head 11 +  Else
.head 12 -  Call DeleteCustFromLoad( '', 0, SH_cls_Rollback )
.head 12 -  Call DeleteCustOrdersFromLoad( '', 0, SH_cls_Rollback )

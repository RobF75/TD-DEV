.head 3 +  Function: StrToDateTimeFromDateToStrX !__Exported
.head 4 -  Description: assumption to this function is that the format came from DateToStrX( ) being YYYY-MM-DD-HH.MM.SS.TTTTTT
.head 4 +  Returns
.head 5 -  Date/Time: !__Exported
.head 4 +  Parameters
.head 5 -  String: sDateTime !__Exported
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Return SalDateConstruct( SalStrToNumber( SalStrLeftX( sDateTime, 4 ) ), 
SalStrToNumber( SalStrMidX( sDateTime, 5, 2 ) ), 
SalStrToNumber( SalStrMidX( sDateTime, 8, 2 ) ), 
SalStrToNumber( SalStrMidX( sDateTime, 11, 2 ) ), 
SalStrToNumber( SalStrMidX( sDateTime, 14, 2 ) ), 
SalStrToNumber( SalStrMidX( sDateTime, 17, 9 ) ) )

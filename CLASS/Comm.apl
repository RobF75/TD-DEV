.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Set __nReceived = NUMBER_Null
.head 6 -  Set __sReceived = ''
.head 6 -  Set __dtReceived = DATETIME_Null
.head 6 -  Set __hReceived = hWndNULL
.head 6 -  Return SalSendMsg( hWndItem, PAM_cls_SETINSTANCEVARS, 0, 0 )
.head 5 +  On PAM_clsCOM_SEND_NUMBER
.head 6 -  Set __nReceived = lParam
.head 6 -  Call SalSendMsg( hWndItem, PAM_clsCOM_SENDNOTIFY, wParam, lParam )
.head 6 -  Return TRUE
.head 5 +  On PAM_clsCOM_SEND_STRING
.head 6 -  Set __sReceived = SalNumberToHString( lParam )
.head 6 -  Call SalSendMsg( hWndItem, PAM_clsCOM_SENDNOTIFY, wParam, lParam )
.head 6 -  Return TRUE
.head 5 +  On PAM_clsCOM_SEND_DATETIME
.head 6 -  Set __dtReceived = SalStrToDate( SalNumberToHString( lParam ) )
.head 6 -  Call SalSendMsg( hWndItem, PAM_clsCOM_SENDNOTIFY, wParam, lParam )
.head 6 -  Return TRUE
.head 5 +  On PAM_clsCOM_SEND_WNDHANDLE
.head 6 -  Set __hReceived = SalNumberToWindowHandle( lParam )
.head 6 -  Call SalSendMsg( hWndItem, PAM_clsCOM_SENDNOTIFY, wParam, lParam )
.head 6 -  Return TRUE

.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 +  If sLabel = ''
.head 7 -  Set sLabel = 'Label'
.head 6 -  Call SalSendClassMessage( SAM_Create, wParam, lParam )
.head 6 -  Set MyValue = sLabel
.head 5 +  On PAM_clsDF_CLEAR
.head 6 -  Call SalSendClassMessage( PAM_clsDF_CLEAR, wParam, lParam )
.head 6 -  Set MyValue = sLabel
.head 5 +  On PAM_clsBGT_SETLABEL
.head 6 -  ! lParam is assumed to have the string value
.head 6 -  Set MyValue = SalNumberToHString( lParam )
.head 6 -  Set sLabel = MyValue

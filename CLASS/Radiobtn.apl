.head 5 +  Function: fSetDefaultWindowSettings
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  Window Handle: hWndParent
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  Window Handle: hWndChild
.head 7 -  Boolean: bOk
.head 6 +  Actions
.head 7 -  Set bOk = TRUE
.head 7 -  Set hWndChild = SalGetFirstChild( hWndParent, TYPE_RadioButton )
.head 7 +  While bOk AND NOT hWndChild = hWndNULL
.head 8 +  If SalIsButtonChecked( hWndChild )
.head 9 +  If NOT OurSetIniFileParameter( 'WINDOW SETTINGS', GetFullItemName( SalParentWindow( hWndParent ), hWndParent, hWndChild ), 'TRUE' )
.head 10 -  Set bOk = FALSE
.head 8 +  Else
.head 9 +  If NOT OurSetIniFileParameter( 'WINDOW SETTINGS', GetFullItemName( SalParentWindow( hWndParent ), hWndParent, hWndChild ), 'FALSE' )
.head 10 -  Set bOk = FALSE
.head 8 -  Set hWndChild = SalGetNextChild( hWndChild, TYPE_RadioButton )
.head 7 -  Return bOk
.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Set nValueOnInitialize = FALSE
.head 6 -  Set hWndOwner = hWndItem
.head 6 -  Set nRadioId = 1
.head 6 -  Call SalSendMsg( hWndItem, PAM_cls_SETINSTANCEVARS, 0, 0 ) 
.head 6 -  Set sTmp = OurGetIniFileParameter( 'WINDOW SETTINGS', GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndItem ), '' )
.head 6 +  If sTmp = 'TRUE'
.head 7 -  Set MyValue = TRUE
.head 6 +  Else
.head 7 -  Set MyValue = FALSE
.head 5 +  On SAM_Click
.head 6 +  If SalIsButtonChecked( hWndItem )
.head 7 -  Call SalSendMsg( hWndOwner, PAM_clsRB_CLICK, TRUE, nRadioId )
.head 5 -  !
.head 5 +  ! On PAM_cls_INITIALISE
.head 6 +    If nValueOnInitialize
.head 7 -    Set clsrbGeneral = TRUE
.head 6 +    Else 
.head 7 -    Set clsrbGeneral = FALSE
.head 5 -  !
.head 5 +  On PAM_clsRB_DISABLE
.head 6 -  Return SalDisableWindow( hWndItem )
.head 5 +  On PAM_clsRB_ENABLE
.head 6 -  Return SalEnableWindow( hWndItem )
.head 5 +  On PAM_clsRB_HIDE
.head 6 -  Return SalHideWindow( hWndItem )
.head 5 +  On PAM_clsRB_SHOW
.head 6 -  Return SalShowWindow( hWndItem )
.head 5 -  !
.head 5 +  On WM_RBUTTONDBLCLK
.head 6 -  Call SalGetWindowText( hWndForm, sTmp, 60 )
.head 6 +  If fSetDefaultWindowSettings( SalParentWindow( hWndItem ) )
.head 7 -  Call SalMessageBox( 'Default radio button settings have been stored.', sTmp, MB_Ok )
.head 6 +  Else
.head 7 -  Call SalMessageBox( 'Default radio button settings have NOT been stored.', 'Error', MB_Ok )

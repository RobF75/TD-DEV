.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Set nActionOnInitialize = CMB_ClearOnInit
.head 6 -  Set sSqlPopStatement = ''
.head 6 -  Set bListPopulated = FALSE
.head 6 -  Set bFixedPopulateOnly = FALSE
.head 6 -  Set bUsedInQueryDialog = FALSE
.head 6 -  Set bUpperCaseOnly = FALSE
.head 6 -  Set bPopulateOnce = TRUE
.head 6 -  Set nLength = NUMBER_Null
.head 6 -  Call SalSendMsg( hWndItem, PAM_cls_SETINSTANCEVARS, 0, 0 ) 
.head 6 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( GetFullItemName( hWndNULL, hWndForm, hWndItem ) || 'CMB' )
.head 5 +  On SAM_Validate
.head 6 +  If bUpperCaseOnly
.head 7 -  Set MyValue = SalStrUpperX( MyValue )
.head 6 -  Return VALIDATE_Ok
.head 5 +  On SAM_DropDown
.head 6 +  If MyValue != STRING_Null
.head 7 -  Set sValueBeforePopulate = MyValue
.head 6 +  If NOT bFixedPopulateOnly
.head 7 +  If NOT bPopulateOnce
.head 8 -  Set bListPopulated = FALSE
.head 7 +  If NOT sSqlPopStatement = '' AND NOT bListPopulated
.head 8 +  If bUsedInQueryDialog
.head 9 -  Call OurWaitCursorOverride( TRUE, TRUE )
.head 8 +  Else
.head 9 -  Call OurWaitCursor( TRUE )
.head 8 +  If haSqlHandles[ nOurHandleNo ].Connect( )
.head 9 +  If SalListPopulate( hWndItem, haSqlHandles[ nOurHandleNo ].hSqlHandle, sSqlPopStatement )
.head 10 -  Set bListPopulated = TRUE
.head 8 +  If bUsedInQueryDialog
.head 9 -  Call OurWaitCursorOverride( FALSE, TRUE )
.head 8 +  Else
.head 9 -  Call OurWaitCursor( FALSE )
.head 6 +  Else
.head 7 -  Call SalSendMsg( hWndItem, PAM_clsCMB_DROPDOWN, 0, 0 ) 
.head 6 +  If sValueBeforePopulate != STRING_Null 
.head 7 -  ! Call SalListInsert( hWndItem, 0, sValueBeforePopulate )
.head 7 -  Set MyValue = sValueBeforePopulate
.head 5 +  On SAM_Destroy
.head 6 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 5 -  !
.head 5 +  On PAM_cls_INITIALISE
.head 6 +  Select Case nActionOnInitialize
.head 7 +  Case CMB_ClearOnInit
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsCMB_CLEAR, 0, 0 )
.head 8 -  Break
.head 7 +  Case CMB_DisableOnInit
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsCMB_DISABLE, 0, 0 )
.head 8 -  Break
.head 7 +  Case CMB_EnableOnInit
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsCMB_ENABLE, 0, 0 )
.head 8 -  Break
.head 7 +  Case CMB_HideOnInit
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsCMB_HIDE, 0, 0 )
.head 8 -  Break
.head 7 +  Case CMB_ShowOnInit
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsCMB_SHOW, 0, 0 )
.head 8 -  Break
.head 5 -  !
.head 5 +  On PAM_clsCMB_DISABLE
.head 6 -  Return SalDisableWindow( hWndItem )
.head 5 +  On PAM_clsCMB_ENABLE
.head 6 -  Return SalEnableWindow( hWndItem )
.head 5 +  On PAM_clsCMB_HIDE
.head 6 -  Return SalHideWindow( hWndItem )
.head 5 +  On PAM_clsCMB_SHOW

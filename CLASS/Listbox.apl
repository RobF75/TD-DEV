.head 6 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 6 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 6 -  !
.head 6 +  If SalListClear( hWndItem )
.head 7 -  Set nContextRow = NUMBER_Null
.head 7 -  Set sContextRow = ''
.head 7 -  Call SalSendMsg( hWndItem, PAM_clsLB_RESET, 0, 0 )
.head 6 -  !
.head 6 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 7 -  Set nContextRow = 0
.head 7 +  While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 8 -  Set sContextRow = ''
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsLB_FORMATCONTEXTROW, 0, nContextRow )
.head 8 +  If SalListAdd( hWndItem, sContextRow ) >= 0
.head 9 -  Set nContextRow = nContextRow + 1
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  On SAM_Destroy
.head 6 -  Call haSqlHandles[ nOurHandleNo ].Disconnect( )

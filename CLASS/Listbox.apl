.head 4 -  List Initialization
.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Set sSqlPopStatement = ''
.head 6 -  Set bListPopulated = FALSE
.head 6 -  Set bUsedInQueryDialog = FALSE
.head 6 -  Set sCurrentSelectionString = ''
.head 6 -  Set bPopulateOnce = TRUE
.head 6 -  Set bGetCountOnPopulate = FALSE
.head 6 -  Set bPopulateOnStartup = FALSE
.head 6 -  Call SalSendMsg( hWndItem, PAM_cls_SETINSTANCEVARS, 0, 0 ) 
.head 6 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( GetFullItemName( hWndNULL, hWndForm, hWndItem ) || 'LB' )
.head 6 +  If bPopulateOnStartup
.head 7 -  Call SalPostMsg( hWndItem, PAM_clsLB_POPULATE, 0, 0 )
.head 5 +  On PAM_clsLB_POPULATE
.head 6 +  If bPopulateOnce
.head 7 +  If NOT sSqlPopStatement = '' AND NOT bListPopulated
.head 8 -  Set bOk = TRUE
.head 7 +  Else
.head 8 -  Set bOk = FALSE
.head 6 +  Else
.head 7 +  If NOT sSqlPopStatement = ''
.head 8 -  Set bOk = TRUE
.head 7 +  Else
.head 8 -  Set bOk = FALSE
.head 6 +  If bOk
.head 7 +  If bUsedInQueryDialog
.head 8 -  Call OurWaitCursorOverride( TRUE, TRUE )
.head 7 +  Else
.head 8 -  Call OurWaitCursor( TRUE )
.head 7 +  If haSqlHandles[ nOurHandleNo ].Connect( )
.head 8 +  If SalListPopulate( hWndItem, haSqlHandles[ nOurHandleNo ].hSqlHandle, sSqlPopStatement )
.head 9 -  Set bListPopulated = TRUE
.head 9 +  If bGetCountOnPopulate
.head 10 -  Set nRowCount = SalListQueryCount( hWndItem )
.head 10 -  Call SalSendMsg( hWndItem, PAM_clsLB_POPULATEDCOUNT, 0, nRowCount )
.head 7 +  If bUsedInQueryDialog
.head 8 -  Call OurWaitCursorOverride( FALSE, TRUE )
.head 7 +  Else
.head 8 -  Call OurWaitCursor( FALSE )
.head 5 +  On PAM_clsLB_RESET
.head 6 -  Set bListPopulated = FALSE
.head 6 -  Return SalListClear( hWndItem )
.head 5 +  On SAM_Destroy
.head 6 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 5 +  On SAM_Click
.head 6 -  Set sCurrentSelectionString = SalListQueryTextX( hWndItem, SalListQuerySelection( hWndItem ) ) 
.head 6 -  Return TRUE

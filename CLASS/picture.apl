.head 6 +  Actions
.head 7 -  Set __isPicturePath = OurGetIniFileParameter( 'GENERAL', 'PicturePath', 'c:\\temp' )
.head 7 -  Set __isPicturePath = SalStrTrimX( __isPicturePath )
.head 7 -  Set __inFileCount = VisDosEnumFiles( __isPicturePath || '\\*.*', FA_Standard, __isFiles )
.head 7 -  Call RetrieveRandomIndex(  )
.head 7 +  If __inRandomIndex >= __inFileCount
.head 8 -  Set __inRandomIndex = __inFileCount - 1
.head 7 -  Set sPicToLoad = __isPicturePath || '\\' || __isFiles[ __inRandomIndex ]
.head 7 -  !
.head 7 -  ! Call SalGetProfileString( IniGeneralLiveSectionName, 'PicturePath', '', __isPicturePath, FlemSysIniFileName )
.head 7 -  ! Set __isPicturePath = SalStrTrimX( __isPicturePath )
.head 7 -  ! Set __isPicturePath = __isPicturePath||'\\*.*'
.head 7 -  ! Set __inFileCount = VisDosEnumFiles( __isPicturePath, FA_Standard, __isFiles )
.head 7 -  ! Set __inFileCount = VisDosEnumFileInfo( __isPicturePath, FA_Standard, __isFiles, __naSizes, __dtaTimeStamps, __naAttributes )
.head 7 -  ! Call RetrieveRandomIndex(  )
.head 7 +  ! If __inRandomIndex >= __inFileCount
.head 8 -  Set __inRandomIndex = __inFileCount - 1
.head 7 -  ! Set sPicToLoad = __isFiles[ __inRandomIndex ]

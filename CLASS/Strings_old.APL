.head 6 +  While saFolders[ nCount ] != '' AND bOk
.head 7 -  Set bOk = SalFileCreateDirectory( sPath || '\\' || saFolders[ nCount ] )
.head 7 -  Set nCount = nCount + 1
.head 5 -  Return bOk
.head 3 +  ! Function: GetCustNoState
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  String: 
.head 4 +  Parameters 
.head 5 -  Number: nCustNo
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  String: sState
.head 4 +  Actions 
.head 5 +  If nCustNo >= 080000 AND nCustNo <= 099999
.head 6 -  Set sState = 'NT'
.head 5 +  Else If nCustNo >= 200000 AND nCustNo <= 299999
.head 6 -  Set sState = 'NSW'
.head 5 +  Else If nCustNo >= 300000 AND nCustNo <= 399999
.head 6 -  Set sState = 'VIC'
.head 5 +  Else If nCustNo >= 400000 AND nCustNo <= 499999
.head 6 -  Set sState = 'QLD'
.head 5 +  Else If nCustNo >= 500000 AND nCustNo <= 599999
.head 6 -  Set sState = 'SA'
.head 5 +  Else If nCustNo >= 600000 AND nCustNo <= 699999
.head 6 -  Set sState = 'WA'
.head 5 +  Else If nCustNo >= 700000 AND nCustNo <= 799999
.head 6 -  Set sState = 'TAS'
.head 5 +  Else 
.head 6 -  Set sState = 'OS'
.head 5 -  Return sState
.head 3 -  ! Below Functions have been included in Strings.apd
.head 3 +  ! Function: StripOutFileName
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  String: 
.head 4 +  Parameters 
.head 5 -  String: sFullPathFileName
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  String: sLast
.head 5 -  String: sCurrent
.head 5 -  Number: nPos
.head 5 -  String: sChar
.head 4 +  Actions 
.head 5 -  Set sCurrent = ''
.head 5 -  ! replace the " \ " with " ~ " because SalStrScan has problems.
.head 5 -  Set nPos = 0
.head 5 +  While nPos < SalStrLength( sFullPathFileName )
.head 6 -  Set sChar = SalStrMidX( sFullPathFileName, nPos, 1 )
.head 6 +  If sChar = '\\'
.head 7 -  Set sChar = '~'
.head 6 -  Set sCurrent = sCurrent || sChar
.head 6 -  Set nPos = nPos + 1
.head 5 -  !
.head 5 -  Set sLast = sCurrent
.head 5 -  Set sCurrent = GetStringBetweenCharMarks( sCurrent, '~', '.' )
.head 5 +  While sLast != sCurrent
.head 6 -  Set sLast = sCurrent
.head 6 -  Set sCurrent = GetStringBetweenCharMarks( sCurrent, '~', '.' )
.head 5 -  Return sCurrent
.head 3 +  ! Function: StringStartPad
.head 4 -  Description: 
.head 4 -  Returns 
.head 4 +  Parameters 

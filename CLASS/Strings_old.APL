.head 2 +  Named Menus
.head 2 +  Internal Functions
.head 3 +  ! Function: StringReplace  
.head 4 -  Description: Given the source string, the search string and the replacing string.
This function finds every occurance of Search String in source string
and replaces it with Replace String.  The source string will contain
the replaced characters on return.
.head 4 -  Returns 
.head 4 +  Parameters 
.head 5 -  Receive String: sSourceStr  
.head 5 -  String: sSearchStr  
.head 5 -  String: sReplaceStr  
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  Number: nOffSet  
.head 5 -  String: sNewSourceStr  
.head 5 -  String: sTmpStr  
.head 4 +  Actions 
.head 5 -  Set sNewSourceStr = ''
.head 5 +  Loop 
.head 6 -  Set nOffSet = SalStrScan( sSourceStr, sSearchStr )
.head 6 +  If nOffSet >= 0
.head 7 -  Call SalStrLeft( sSourceStr, nOffSet, sTmpStr )
.head 7 -  Set sNewSourceStr = sNewSourceStr || sTmpStr || sReplaceStr
.head 7 -  Call SalStrMid( sSourceStr, nOffSet + SalStrLength( sSearchStr ), SalStrLength( sSourceStr ) - ( nOffSet + SalStrLength( sSearchStr ) ), sSourceStr )
.head 6 +  Else 
.head 7 -  Set sNewSourceStr = sNewSourceStr || sSourceStr
.head 7 -  Break 
.head 5 -  Set sSourceStr = sNewSourceStr
.head 3 +  ! Function: StringValidate
.head 4 -  Description: 10/12/2003 (PXD) Ensures that the string given are within valid parameters.
Only normal alpha/numeric values and Underscores are allowed.
.head 4 +  Returns 
.head 5 -  Boolean: 
.head 4 +  Parameters 
.head 5 -  String: sString
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  Number: nCharValue
.head 5 -  Number: nLoopCount
.head 5 -  Boolean: bValidString
.head 4 +  Actions 
.head 5 -  !
.head 5 -  Set bValidString = TRUE 					! Initialise flag string as valid
.head 5 -  Set nLoopCount = SalStrLength( sString )			! Get count of loops to perform
.head 5 +  While nLoopCount > 0					! While still more to do...
.head 6 -  Set nLoopCount = nLoopCount - 1				! Decrement loop control counter
.head 6 -  !
.head 6 -  Set nCharValue = SalStrLop( sString ) 				! Get ASCII value of character
.head 6 -  !
.head 6 +  If (nCharValue > 47 AND nCharValue < 58 )
	OR ( nCharValue > 64 AND nCharValue < 91 )
	OR ( nCharValue > 94 AND nCharValue < 123)		! Ensure type of character is valid (alpha/numerics)
.head 7 -  ! Valid character - do nothing
.head 6 +  Else 
.head 7 -  Set bValidString = FALSE 					! flag entire string as invalid
.head 5 -  Return bValidString						! Return flag
.head 3 +  ! Function: StringScan  
.head 4 -  Description: Works just like SalStrScan except if case sensitivity is required set bCaseSensitive = TRUE
.head 4 +  Returns 
.head 5 -  Number: 
.head 4 +  Parameters 
.head 5 -  String: sString1  
.head 5 -  String: sString2  
.head 5 -  Boolean: bCaseSensitive  
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  Boolean: bFound  
.head 5 -  Number: nOffSet  
.head 4 +  Actions 
.head 5 +  If bCaseSensitive
.head 6 -  Set bFound = FALSE
.head 6 -  Set nOffSet = 0
.head 6 +  While NOT bFound AND nOffSet >= 0
.head 7 -  Set nOffSet = SalStrScan( sString1, sString2 )
.head 7 +  If nOffSet >= 0
.head 8 +  If SalStrMidX( sString1, nOffSet, SalStrLength( sString2 ) ) = sString2
.head 9 -  Set bFound = TRUE
.head 8 +  Else 
.head 9 -  Set sString1 = SalStrReplaceX( sString1, nOffSet, SalStrLength( sString2 ), SalStrRepeatX( ' ', SalStrLength( sString2 ) ) )
.head 6 -  Return nOffSet
.head 5 +  Else 
.head 6 -  Return SalStrScan( sString1, sString2 )
.head 3 +  ! Function: StringEndPad
.head 4 -  Description: 
.head 4 -  Returns 
.head 4 +  Parameters 
.head 5 -  Receive String: sSource  
.head 5 -  String: sPad  
.head 5 -  Number: nLength  
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  Number: nActualLength  
.head 4 +  Actions 
.head 5 -  Set nActualLength = SalStrLength( sSource )
.head 5 +  While nActualLength < nLength
.head 6 -  Set sSource = sSource || sPad
.head 6 -  Set nActualLength = SalStrLength( sSource )
.head 3 +  ! Function: StringEndPadX
.head 4 -  Description: 
.head 4 +  Returns 
.head 5 -  String: 
.head 4 +  Parameters 
.head 5 -  String: sSource  
.head 5 -  String: sPad  
.head 5 -  Number: nLength  
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  String: sTmp
.head 4 +  Actions 
.head 5 -  Set sTmp = sSource
.head 5 -  Call StringEndPad( sTmp, sPad, nLength )
.head 5 -  Return sTmp
.head 3 +  ! Function: RemoveStringBetweenCharMarks  
.head 4 -  Description: Returns a string with the substring encapsulated by starting and ending characters removed.
.head 4 +  Returns 
.head 5 -  String: 
.head 4 +  Parameters 
.head 5 -  String: sInputStr  
.head 5 -  String: sStartCharacter  
.head 5 -  String: sEndCharacter  
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  Number: nStartCharPos  
.head 5 -  Number: nEndCharPos  
.head 5 -  String: sFirstInputStr  
.head 5 -  String: sLastInputStr  
.head 5 -  String: sTmpInputStr  
.head 5 -  String: sOutputStr  
.head 4 +  Actions 
.head 5 -  Set nStartCharPos = SalStrScan( sInputStr, sStartCharacter )
.head 5 +  If nStartCharPos >= 0
.head 6 -  Set sFirstInputStr = SalStrLeftX( sInputStr, nStartCharPos )
.head 6 -  Set sTmpInputStr = SalStrRightX( sInputStr, SalStrLength( sInputStr ) - nStartCharPos - SalStrLength( sStartCharacter ) )
.head 6 -  Set nEndCharPos = SalStrScan( sTmpInputStr, sEndCharacter )
.head 6 +  If nEndCharPos >= 0
.head 7 -  Set sLastInputStr = SalStrRightX( sTmpInputStr, SalStrLength( sTmpInputStr ) - nEndCharPos - SalStrLength( sEndCharacter ))
.head 6 +  Else 
.head 7 -  Set sLastInputStr = ''
.head 6 -  Set sOutputStr = sFirstInputStr || sLastInputStr
.head 5 +  Else 
.head 6 -  Set sOutputStr = sInputStr
.head 5 -  Return sOutputStr
.head 3 -  !
.head 3 +  Function: StrArrayFind  
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: saStringArray[*]  
.head 5 -  ! nArrayCount = number of elements or ARRAY_Null_Terminated constant
.head 5 -  Number: nArrayCount  
.head 5 -  String: sStrToFind  
.head 5 -  Receive Number: nFoundPos  
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nPos  
.head 5 -  Boolean: bFound  
.head 4 +  Actions
.head 5 -  Set nFoundPos = NUMBER_Null
.head 5 -  Set nPos = 0
.head 5 -  Set bFound = FALSE
.head 5 +  If nArrayCount = ARRAY_Null_Terminated
.head 6 +  While saStringArray[ nPos ] != '' AND NOT bFound
.head 7 +  If saStringArray[ nPos ] = sStrToFind
.head 8 -  Set bFound = TRUE
.head 8 -  Set nFoundPos = nPos
.head 7 -  Set nPos = nPos + 1
.head 5 +  Else
.head 6 +  While nPos <= nArrayCount AND NOT bFound
.head 7 +  If saStringArray[ nPos ] = sStrToFind
.head 8 -  Set bFound = TRUE
.head 8 -  Set nFoundPos = nPos
.head 7 -  Set nPos = nPos + 1
.head 5 -  Return bFound

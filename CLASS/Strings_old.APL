.head 4 +  Actions 
.head 5 -  Set nStrHexLength = SalStrLength( sHex )
.head 5 -  Set sBin = ''
.head 5 -  Set nPos = 0
.head 5 +  While nPos < nStrHexLength
.head 6 -  !
.head 6 -  Set sHexChar = SalStrUpperX( SalStrMidX( sHex, nPos, 1 ) )
.head 6 +  If sHexChar = 'A'
.head 7 -  Set nDecChar = 10
.head 6 +  Else If sHexChar = 'B'
.head 7 -  Set nDecChar = 11
.head 6 +  Else If sHexChar = 'C'
.head 7 -  Set nDecChar = 12
.head 6 +  Else If sHexChar = 'D'
.head 7 -  Set nDecChar = 13
.head 6 +  Else If sHexChar = 'E'
.head 7 -  Set nDecChar = 14
.head 6 +  Else If sHexChar = 'F'
.head 7 -  Set nDecChar = 15
.head 6 +  Else 
.head 7 -  Set nDecChar = SalStrToNumber( sHexChar )
.head 6 -  !
.head 6 -  Set sBinChar = ''
.head 6 +  While nDecChar > 0
.head 7 +  If SalNumberMod( nDecChar, 2 ) = 0
.head 8 -  Set sBinChar = '0' || sBinChar
.head 7 +  Else 
.head 8 -  Set sBinChar = '1' || sBinChar
.head 7 -  Set nDecChar = SalNumberTruncate( nDecChar / 2, 4, 0 )
.head 6 -  !
.head 6 -  Call StringStartPad( sBinChar, '0', 4 )
.head 6 -  Set sBin = sBin || sBinChar
.head 6 -  Set nPos = nPos + 1
.head 5 -  Return sBin

.head 3 +  Function: OurWaitCursorOverride  
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Boolean: bOn  
.head 5 -  Boolean: bOverride  
.head 4 +  Static Variables
.head 5 -  Number: nWaitCount  
.head 5 -  Boolean: bOverriden  
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If bOverride
.head 6 +  If bOn
.head 7 -  Call SalWaitCursor( TRUE )
.head 6 +  Else
.head 7 -  Call SalWaitCursor( FALSE )
.head 6 -  Set bOverriden = TRUE
.head 5 +  Else
.head 6 +  If bOn
.head 7 +  If NOT nWaitCount > 0 OR bOverriden
.head 8 -  Call SalWaitCursor( TRUE )
.head 8 -  Set bOverriden = FALSE
.head 7 -  Set nWaitCount = nWaitCount + 1
.head 6 +  Else
.head 7 -  Set nWaitCount = nWaitCount - 1
.head 7 +  If NOT nWaitCount > 0 OR bOverriden
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 -  Set bOverriden = FALSE
.head 3 +  Function: OurMapEnterToTab  
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Boolean: bOn  
.head 4 +  Static Variables
.head 5 -  Number: nCount  
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If bOn
.head 6 +  If NOT nCount > 0
.head 7 -  Call SalMapEnterToTab( TRUE )
.head 6 -  Set nCount = nCount + 1
.head 5 +  Else
.head 6 -  Set nCount = nCount - 1
.head 6 +  If NOT nCount > 0
.head 7 -  Call SalMapEnterToTab( FALSE )

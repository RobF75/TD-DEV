.head 3 +  Function: GetFullItemName
.head 4 -  Description: Gets full item name eg frmCust.tblCust.colCustNo.
If parameter is null then it is ignored
.head 4 +  Returns
.head 5 -  String:
.head 4 +  Parameters
.head 5 -  Window Handle: hWndParnt
.head 5 -  Window Handle: hWndFrm
.head 5 -  Window Handle: hWndItm
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sFullItmName
.head 5 -  String: sItmName
.head 4 +  Actions
.head 5 +  If hWndItm = hWndNULL
.head 6 -  Set sItmName = ''
.head 6 -  Set sFullItmName = sItmName
.head 5 +  Else
.head 6 -  Call SalGetItemName( hWndItm, sItmName )
.head 6 -  Set sFullItmName = sItmName
.head 5 +  If hWndFrm = hWndNULL
.head 6 -  Set sItmName = ''
.head 5 +  Else
.head 6 -  Call SalGetItemName( hWndFrm, sItmName )
.head 6 -  Set sFullItmName = sItmName || '.' || sFullItmName
.head 5 +  If hWndParnt = hWndNULL
.head 6 -  Set sItmName = ''
.head 5 +  Else
.head 6 -  Call SalGetItemName( hWndParnt, sItmName )
.head 6 -  Set sFullItmName = sItmName || '.' || sFullItmName
.head 5 -  Return sFullItmName

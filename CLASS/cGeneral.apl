.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sHelpFileName
.head 4 +  Actions
.head 5 +  If ExtractHelpFileName( hWnd, sHelpFileName )
.head 6 -  Set sHelpFileName = OurGetIniFileParameter( 'GENERAL', 'HelpStoragePath', '' ) || '\\' || sHelpFileName
.head 6 -  Call SalMessageBox( 'Loading.. '||sHelpFileName, 'Help', MB_Ok )

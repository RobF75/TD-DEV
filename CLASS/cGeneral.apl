.head 3 +  Function: ExtractHelpFileName
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Window Handle: hWnd
.head 5 -  Receive String: sHelpFileName
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sTemplet
.head 5 -  Number: nPos
.head 5 -  Number: nTempletLength
.head 5 -  Number: nNum
.head 4 +  Actions
.head 5 +  If SalGetItemName( hWnd, sTemplet )
.head 6 -  Set sHelpFileName = ''
.head 6 -  Set nTempletLength = SalStrLength( sTemplet )
.head 6 -  Set nNum = 0
.head 6 -  Set nPos = 1
.head 6 +  While nPos <= nTempletLength
.head 7 -  Set nNum = nNum + SalStrLop( sTemplet ) * nPos
.head 7 -  Set nPos = nPos + 1
.head 6 -  Set sHelpFileName = SalNumberToStrX( nNum, 0 ) || '.hlp'
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 3 +  Function: OurGetIniFileParameter
.head 4 -  Description: sGeneralOrAccounts = 'GENERAL' OR 'ACCOUNTS' exact strings only.
sEntry = 'Customer' is the name of the program eg  Customer='g:\apps\....'
sDefalt is what to return if entry cannot be found.
.head 4 +  Returns
.head 5 -  String:
.head 4 +  Parameters
.head 5 -  String: sGeneralOrAccounts
.head 5 -  String: sEntry
.head 5 -  String: sDefault
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sValue
.head 5 -  String: sSection
.head 4 +  Actions
.head 5 -  Set sValue = ''
.head 5 +  If SqlDatabase = 'STOCK'
.head 6 +  If sGeneralOrAccounts = 'GENERAL'
.head 7 -  Set sSection = IniGeneralLiveSectionName
.head 6 +  Else
.head 7 -  Set sSection = IniAccountsLiveSectionName
.head 5 +  Else
.head 6 +  If sGeneralOrAccounts = 'GENERAL'
.head 7 -  Set sSection = IniGeneralPlaySectionName
.head 6 +  Else
.head 7 -  Set sSection = IniAccountsPlaySectionName
.head 5 -  Call SalGetProfileString( sSection, sEntry, sDefault, sValue, FlemSysIniFileName )
.head 5 -  Return sValue
.head 3 +  Function: OurSetIniFileParameter
.head 4 -  Description: sGeneralOrAccounts = 'GENERAL' OR 'ACCOUNTS' exact strings only.
sEntry = 'Customer' is the name of the program eg  Customer='g:\apps\....'
sValue is the entry value.
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: sGeneralOrAccounts
.head 5 -  String: sEntry
.head 5 -  String: sValue
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSection
.head 4 +  Actions
.head 5 +  If SqlDatabase = 'STOCK'
.head 6 +  If sGeneralOrAccounts = 'GENERAL'
.head 7 -  Set sSection = IniGeneralLiveSectionName
.head 6 +  Else
.head 7 -  Set sSection = IniAccountsLiveSectionName
.head 5 +  Else
.head 6 +  If sGeneralOrAccounts = 'GENERAL'
.head 7 -  Set sSection = IniGeneralPlaySectionName
.head 6 +  Else
.head 7 -  Set sSection = IniAccountsPlaySectionName
.head 5 -  Return SalSetProfileString( sSection, sEntry, sValue, FlemSysIniFileName )

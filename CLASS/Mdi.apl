.head 5 -  ! bParentForm is set if the form is the controlling form in the mdi window - if it is destroyed then every other
form needs to be destroyed
.head 5 -  Boolean: bParentForm
.head 5 -  ! Private
.head 5 -  Window Handle: hWndChild
.head 5 -  Number: nhWndForm
.head 5 -  Window Handle: hWndPb

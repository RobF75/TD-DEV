.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Call OurWaitCursor( TRUE )
.head 6 -  Call SalGetWindowText( hWndMDI, sMDIHeading, 130 )
.head 6 -  Set nActionOnExit = MDI_EndOnExit
.head 6 -  Set sHelpFileName = ''
.head 6 -  Set bMapEnterToTab = FALSE
.head 6 -  Set bPrintFormAllowed = TRUE
.head 6 -  Set bTreeSystem = TRUE
.head 6 -  Call SalSendMsg( hWndMDI, PAM_clsMDI_POPFIELDS, 0, 0 )
.head 6 -  Call SalSendMsg( hWndMDI, PAM_cls_SETINSTANCEVARS, 0, 0 )
.head 6 +  If NOT bPrintFormAllowed
.head 7 -  Call SalSendMsg( pbPrintForm, PAM_clsPB_HIDE, 0, 0 )
.head 6 +  If NOT bTreeSystem
.head 7 -  Call SalSendMsgToChildren( hWndMDI, PAM_clsMDI_NOTTREESYS, 0, 0 )
.head 5 +  On SAM_CreateComplete
.head 6 +  If bMapEnterToTab
.head 7 -  Call OurMapEnterToTab( TRUE )
.head 6 -  Call OurWaitCursor( FALSE )
.head 6 -  Call SalSendMsg( SalParentWindow( hWndMDI ), PAM_clsMDI_CHILDWINACTIVATED, 0, 0 )
.head 6 +  If VisWinIsMaximized( hWndMDI )
.head 7 -  Set __sWinShowType = 'MAXIMIZED'
.head 6 +  Else If VisWinIsMinimized( hWndMDI )
.head 7 -  Set __sWinShowType = 'MINIMIZED'
.head 6 +  Else
.head 7 -  Set __sWinShowType = 'RESTORED'
.head 6 -  Call SalPostMsg( hWndMDI, PAM_cls_PARENTACTIVATE, 0, 0 )
.head 5 +  On SAM_Destroy
.head 6 -  Call SalPostMsg( SalParentWindow( hWndMDI ), PAM_cls_PARENTACTIVATE, 0, 0 )
.head 6 +  If bMapEnterToTab
.head 7 -  Call OurMapEnterToTab( FALSE )
.head 5 +  On SAM_Close
.head 6 -  Set nReturn = SalSendMsg( hWndMDI, PAM_cls_EXIT, 0, 0 )
.head 6 +  If nReturn = PB_ExitHideWindow
.head 7 -  Call SalHideWindow( hWndMDI )
.head 7 -  Return FALSE
.head 5 +  On PAM_cls_CLOSE
.head 6 -  Set nReturn =  SalSendMsg( hWndMDI, PAM_cls_EXIT, wParam, lParam )
.head 6 +  If nReturn = PB_ExitDestroyWindow
.head 7 -  Return SalDestroyWindow( hWndMDI )
.head 6 +  Else If nReturn = PB_ExitEndDialog
.head 7 -  Return SalEndDialog( hWndMDI, wParam )
.head 6 +  Else If nReturn = PB_ExitHideWindow
.head 7 -  Return SalHideWindow( hWndMDI )
.head 5 +  On PAM_cls_PARENTACTIVATE
.head 6 -  Call SalEnableWindow( hWndMDI )
.head 6 -  Call SalShowWindow( hWndMDI )
.head 6 -  Call SalBringWindowToTop( hWndMDI )
.head 6 +  If __sWinShowType = 'MAXIMIZED'
.head 7 -  Call VisWinShow( hWndMDI, SHOW_Maximized )
.head 6 +  Else If __sWinShowType = 'MINIMIZED'
.head 7 -  Call VisWinShow( hWndMDI, SHOW_Minimized )
.head 6 +  Else
.head 7 -  Call VisWinShow( hWndMDI, SHOW_Normal )
.head 5 +  On SAM_Activate
.head 6 -  Call SalSendMsgToChildren( hWndMDI, PAM_clsMDI_ACTIVATE, wParam, lParam )
.head 5 +  On PAM_cls_EXIT
.head 6 -  Call SalSendMsg( hWndMDI, PAM_clsMDI_PUSHFIELDS, 0, 0 )
.head 6 -  Call SalSendMsg( SalParentWindow( hWndMDI ), PAM_clsMDI_RETURN, 0, SalWindowHandleToNumber( hWndMDI ) )
.head 6 +  If nActionOnExit = MDI_HideOnExit
.head 7 -  Return PB_ExitHideWindow
.head 6 +  Else
.head 7 -  Return PB_ExitDestroyWindow
.head 5 +  On PAM_cls_HELP
.head 6 -  Return DisplayHelp( hWndMDI )
.head 5 +  On PAM_cls_ITEMENQUIRY
.head 6 +  If bTreeSystem
.head 7 -  Return SalSendMsg( pbItemEnq, SAM_Click, wParam, lParam )
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  On PAM_clsMDI_SHOW
.head 6 -  Call SalSendMsg( hWndMDI, PAM_clsMDI_POPFIELDS, 0, 0 )
.head 6 -  Return SalShowWindow( hWndMDI )
.head 5 +  On PAM_clsMDI_CHILDWINACTIVATED
.head 6 -  Call VisWinShow( hWndMDI, SHOW_Minimized )
.head 6 -  Call SalDisableWindow( hWndMDI )
.head 6 +  If VisWinIsMaximized( hWndMDI )
.head 7 -  Set __sWinShowType = 'MAXIMIZED'
.head 6 +  Else If VisWinIsMinimized( hWndMDI )
.head 7 -  Set __sWinShowType = 'MINIMIZED'
.head 6 +  Else
.head 7 -  Set __sWinShowType = 'RESTORED'
.head 6 -  Return TRUE

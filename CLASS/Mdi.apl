.head 4 +  Functions
.head 5 +  Function: GetHandleFromItemName
.head 6 -  Description: Passing in a string variable to find the related instances window handle to be able to
send messages to it
.head 6 +  Returns
.head 7 -  Boolean: bOk 
.head 6 +  Parameters
.head 7 -  Receive Window Handle: hWndHdl
.head 7 -  String: sItemName
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  Number: i
.head 7 -  Window Handle: hWndChild
.head 7 -  String: sGotItemName
.head 6 +  Actions
.head 7 -  Set hWndChild = SalGetFirstChild( hWndMDI, TYPE_FormWindow )
.head 7 +  While hWndChild != hWndNULL
.head 8 -  Call SalGetItemName( hWndChild, sGotItemName )
.head 8 +  If sGotItemName = sItemName
.head 9 -  ! Then we have the one we want 
.head 9 -  Set hWndHdl = hWndChild
.head 9 -  Return TRUE
.head 8 -  Set hWndChild = SalGetNextChild( hWndChild, TYPE_FormWindow )
.head 7 -  Return FALSE
.head 5 +  Function: SetMenuItems
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 -  Parameters
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  Number: hMenu
.head 7 -  Number: i
.head 7 -  Number: nMenuCount
.head 7 -  String: sText
.head 7 -  Number: hMenuPopup
.head 7 -  Number: nChildPos
.head 6 +  Actions
.head 7 -  Set hMenu = VisMenuGetHandle( hWndMDI )
.head 7 -  Set nMenuCount = VisMenuGetCount( hMenu )
.head 7 -  Set i = 0
.head 7 +  While i < nMenuCount
.head 8 -  Set sText = VisMenuGetText( hWndMDI, hMenu, i )
.head 8 +  If sText = 'TableActions'
.head 9 -  Set hMenuPopup = VisMenuGetPopupHandle( hMenu, i )
.head 9 -  ! To break out of the while loop
.head 9 -  Set i = nMenuCount
.head 8 -  Set i = i + 1
.head 7 +  If NOT clsfrmmdiChildTable.bAddAllowed
.head 8 +  If GetMenuPos( hMenuPopup, 'Add', nChildPos )
.head 9 -  Call VisMenuDelete( hWndMDI, hMenuPopup, nChildPos )
.head 7 +  If NOT clsfrmmdiChildTable.bSaveAllowed
.head 8 +  If GetMenuPos( hMenuPopup, 'Save', nChildPos )
.head 9 -  Call VisMenuDelete( hWndMDI, hMenuPopup, nChildPos )
.head 7 +  If NOT clsfrmmdiChildTable.bDeleteAllowed
.head 8 +  If GetMenuPos( hMenuPopup, 'Delete', nChildPos )
.head 9 -  Call VisMenuDelete( hWndMDI, hMenuPopup, nChildPos )
.head 7 +  If NOT clsfrmmdiChildTable.bUnDeleteAllowed
.head 8 +  If GetMenuPos( hMenuPopup, 'UnDelete', nChildPos )
.head 9 -  Call VisMenuDelete( hWndMDI, hMenuPopup, nChildPos )
.head 7 +  If NOT clsfrmmdiChildTable.bRepopulateAllowed
.head 8 +  If GetMenuPos( hMenuPopup, 'Repopulate', nChildPos )
.head 9 -  Call VisMenuDelete( hWndMDI, hMenuPopup, nChildPos )
.head 5 +  Function: GetMenuPos
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  Number: hMenuPopup
.head 7 -  String: sText
.head 7 -  Receive Number: nPos
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  String: sChildText
.head 7 -  Number: nChildCount
.head 6 +  Actions
.head 7 -  Set nChildCount = VisMenuGetCount( hMenuPopup )
.head 7 -  Set nPos = 0
.head 7 +  While nPos < nChildCount
.head 8 -  Set sChildText = VisMenuGetText( hWndMDI, hMenuPopup, nPos )
.head 8 -  Set sChildText = VisStrSubstitute( sChildText, '&', STRING_Null )
.head 8 +  If sChildText = sText
.head 9 -  Return TRUE
.head 8 -  Set nPos = nPos + 1
.head 7 -  ! Required text is not found
.head 7 -  Return FALSE
.head 4 +  Message Actions
.head 5 +  On SAM_Destroy
.head 6 +  If bParentForm
.head 7 -  Set hWndChild = SalGetFirstChild( hWndMDI, TYPE_FormWindow )
.head 7 +  While hWndChild != hWndNULL
.head 8 -  Call SalPostMsg( hWndChild, SAM_Destroy, 0, 0 )
.head 8 -  Set hWndChild = SalGetNextChild( hWndChild, TYPE_FormWindow )
.head 6 -  Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
.head 5 +  On SAM_Create
.head 6 -  Set bParentForm = FALSE
.head 6 -  Return SalSendClassMessage( SAM_Create, wParam, lParam )
.head 5 +  On SAM_CreateComplete
.head 6 +  If GetHandleFromItemName( hWndParent, sParentForm )
.head 7 +  If SalSendMsg(  hWndParent, PAM_cls_SETFIELDS, 0, 0 )
.head 8 -  Call SalSendMsg( hWndForm, PAM_cls_GETFIELDS, 0, 0 )
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsMDI_PBHIDDEN, wParam, lParam )
.head 6 -  Call SetMenuItems( )
.head 6 -  ! If the form is the parent form then we want the pb hiding code to be executed
.head 6 +  If bParentForm
.head 7 -  Call SalPostMsg( hWndForm, PAM_clsMDI_PBSENDSTATUS, 0, 0 )
.head 6 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 5 +  On PAM_clsMDI_PBSENDSTATUS
.head 6 -  Set nhWndForm = SalWindowHandleToNumber( hWndForm )
.head 6 -  Call SalSendMsgToChildren( hWndMDI, PAM_clsPB_PBSTATUS, nhWndForm, lParam )
.head 5 +  On PAM_clsMDI_PARENTCHANGE
.head 6 -  Set i = 0
.head 6 +  While sChildForm[i] != ''
.head 7 +  If GetHandleFromItemName( hWndChild, sChildForm[i] )
.head 8 -  Call SalPostMsg( hWndChild, PAM_cls_CHILDCHANGED, 0, 0 )
.head 7 -  Set i = i + 1
.head 5 +  On PAM_clsMDI_PBHIDDEN
.head 6 -  Set spbToHide[0] = ''
.head 5 +  On PAM_cls_GETFIELDS
.head 6 -  Return TRUE
.head 5 +  On PAM_cls_SETFIELDS
.head 6 -  Return TRUE
.head 5 +  On PAM_cls_CHILDCHANGED
.head 6 +  If SalSendMsg(  hWndParent, PAM_cls_SETFIELDS, 0, 0 )
.head 7 -  Call SalSendMsg( hWndForm, PAM_cls_GETFIELDS, 0, 0 )
.head 6 -  Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_POPULATE, 0, 0 )
.head 6 -  Call SalBringWindowToTop( hWndForm )
.head 6 -  Set i = 0
.head 6 +  While sChildForm[i] != ''
.head 7 +  If GetHandleFromItemName( hWndChild, sChildForm[i] )
.head 8 -  Call SalPostMsg( hWndChild, PAM_cls_CHILDCHANGED, 0, 0 )
.head 7 -  Set i = i + 1
.head 5 +  On SAM_Activate
.head 6 +  If wParam
.head 7 -  Call SalPostMsg( hWndForm, PAM_clsMDI_PBSENDSTATUS, 0, 0 )
.head 6 -  Set nhWndForm = SalWindowHandleToNumber( hWndForm )
.head 6 -  Call SalPostMsg( SalParentWindow( hWndForm ), PAM_clsMDI_ACTIVATED, wParam, nhWndForm )
.head 5 +  On PAM_cls_REFRESHAFTRCHILDCHANGE
.head 6 -  Return FALSE
.head 5 +  On PAM_clsTBL_CHECKCHANGES
.head 6 -  Set hWndMDIChild = SalGetFirstChild( hWndForm, TYPE_ChildTable )
.head 6 +  While hWndMDIChild != hWndNULL
.head 7 +  If NOT SalSendMsg( hWndMDIChild, PAM_clsTBL_CHECKCHANGES, wParam, lParam )
.head 8 -  Return TRUE
.head 7 -  Set hWndMDIChild = SalGetNextChild( hWndMDIChild, TYPE_ChildTable )
.head 6 -  Return FALSE
.head 5 +  On PAM_clsPB_PBSTATUS
.head 6 -  Set hWndPb = SalNumberToWindowHandle( lParam )
.head 6 -  Call SalGetItemName( hWndPb, sPb )
.head 6 -  Set i = 0
.head 6 -  ! have to loop thru the array of pbtohide to see if this pb is in the array, if not return false to not hide it
.head 6 +  While spbToHide[i] != ''
.head 7 +  If spbToHide[i] = sPb
.head 8 -  Return TRUE
.head 7 -  Set i = i + 1
.head 6 -  Return FALSE

.head 4 +  Message Actions
.head 5 +  On PAM_clsMDI_ADD
.head 6 -  Call SalSendMsg( pbAddRows, SAM_Click, 0, 0 )
.head 5 +  On PAM_clsMDI_SAVE
.head 6 -  Call SalSendMsg( pbSaveRows, SAM_Click, 0, 0 )
.head 5 +  On PAM_clsMDI_DELETE
.head 6 -  Call SalSendMsg( pbDeleteRows, SAM_Click, 0, 0 )
.head 5 +  On PAM_clsMDI_UNDELETE
.head 6 -  Call SalSendMsg( pbUnDeleteRows, SAM_Click, 0, 0 )
.head 5 +  On PAM_clsMDI_REPOPULATE
.head 6 -  Call SalSendMsg( pbRePopulate, SAM_Click, 0, 0 )
.head 5 +  On PAM_clsMDI_OKTOPOPCHILD
.head 6 -  Set hWndChild = SalGetFirstChild( hWndMDI, TYPE_FormWindow )
.head 6 +  While hWndChild != hWndNULL
.head 7 -  ! Want a return of true from the form windows if their children require changes to be saved
.head 7 +  If SalSendMsg( hWndChild, PAM_clsTBL_CHECKCHANGES, 0, 0 )
.head 8 -  Return FALSE
.head 7 -  Set hWndChild = SalGetNextChild( hWndChild, TYPE_FormWindow )
.head 6 -  Return TRUE
.head 5 +  On SAM_Close
.head 6 -  Set hWndChild = SalGetFirstChild( hWndMDI, TYPE_FormWindow )
.head 6 +  While hWndChild != hWndNULL
.head 7 +  If NOT SalSendMsg( hWndChild, PAM_cls_EXIT, 0, 0 )
.head 8 -  Return FALSE
.head 7 -  Set hWndChild = SalGetNextChild( hWndChild, TYPE_FormWindow )
.head 6 -  Return TRUE
.head 5 +  On PAM_clsMDI_ACTIVATED
.head 6 -  ! the window handle of the form being activated or deactivated
.head 6 -  Set hWndChildForm = SalNumberToWindowHandle( lParam )
.head 6 -  ! Need to trap the active form to be able to process on a table level whether we allow the rowvalidate to
occur 
.head 6 +  If wParam
.head 7 -  Set hWndActiveForm = hWndChildForm
.head 5 +  On PAM_clsMDI_AMIACTIVE
.head 6 -  Set hWndCurrForm = SalNumberToWindowHandle( lParam )
.head 6 +  If hWndCurrForm = hWndActiveForm
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  On VTM_MenuSelect
.head 6 -  ! Set sMenuSelected = VisMenuGetText( hWndForm, lParam, -1 ) 
.head 6 +  ! If sMenuSelected = 'Add'
.head 7 -      Call SalSendMsg( hWndMDI, PAM_clsMDI_ADD, 0, 0 )
.head 6 +  If lParam = nAddMenu
.head 7 -  Call SalSendMsg( hWndMDI, PAM_clsMDI_ADD, 0, 0 )
.head 6 +  Else If lParam = nSaveMenu
.head 7 -  Call SalSendMsg( hWndMDI, PAM_clsMDI_SAVE, 0, 0 )
.head 6 +  Else If lParam = nDeleteMenu
.head 7 -  Call SalSendMsg( hWndMDI, PAM_clsMDI_DELETE, 0, 0 )
.head 6 +  Else If lParam = nUnDeleteMenu
.head 7 -  Call SalSendMsg( hWndMDI, PAM_clsMDI_UNDELETE, 0, 0 )
.head 6 +  Else If lParam = nRePopMenu
.head 7 -  Call SalSendMsg( hWndMDI, PAM_clsMDI_REPOPULATE, 0, 0 )

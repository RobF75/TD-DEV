.head 6 -  Local variables
.head 6 +  Actions
.head 7 +  If nSeasonYear != SalStrToNumber( GetNumber(  ) )
.head 8 -  Call SetNumber( nSeasonYear )
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsSPN_VALIDATE, 0, 0 )
.head 5 -  !
.head 5 +  Function: IsValidNumber
.head 6 -  Description: Same as IsValidNumber except doesnt return false if the
number is not a multiple of nIncrement.
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 -  Parameters
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  String: sValue
.head 7 -  Number: nValue
.head 6 +  Actions
.head 7 -  Set sValue = clsSpinSeasonYear.GetNumber()
.head 7 -  !
.head 7 -  ! ***** Validate for valid number
.head 7 +  If Not SalStrIsValidNumber( sValue )
.head 8 -  Return FALSE
.head 7 -  !
.head 7 -  Set nValue = SalStrToNumber( sValue )
.head 7 -  !
.head 7 +  If nValue >=97 AND nValue <=99
.head 8 -  Set nValue = nValue + 1900
.head 8 -  Call clsSpinSeasonYear.SetNumber( nValue )
.head 7 +  Else If nValue >=0 AND nValue <=50
.head 8 -  Set nValue = nValue + 2000
.head 8 -  Call clsSpinSeasonYear.SetNumber( nValue )
.head 7 -  Set nSeasonYear = nValue
.head 7 -  !
.head 7 -  Return TRUE
.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 +  If NOT nSeasonYear > 0
.head 7 -  Set nSeasonYear = SetSeasonYear( SalDateCurrent(  ) )
.head 6 -  Call SalSendClassMessage( SAM_Create, wParam, lParam )
.head 6 -  Return SetNumber( nSeasonYear )
.head 5 +  On SAM_Validate
.head 6 +  If IsValidNumber(  )
.head 7 -  Call SalSendMsg( hWndItem, PAM_clsSPN_VALIDATE, 0, 0 )
.head 7 -  Return VALIDATE_Ok
.head 6 +  Else
.head 7 -  Return VALIDATE_Cancel
.head 5 +  On VTM_SpinSetValue
.head 6 -  Call SalSendMsg( hWndItem, PAM_clsSPN_VALIDATE, 0, 0 )
.head 5 +  On VTM_SpinScrollUp
.head 6 -  Call IncSeasonYear( nIncrement )
.head 6 -  Call SetNumber( nSeasonYear )
.head 6 -  Call SalSendMsg( hWndItem, PAM_clsSPN_VALIDATE, 0, 0 )
.head 6 -  Return TRUE
.head 5 +  On VTM_SpinScrollDown
.head 6 -  Call DecSeasonYear( nIncrement )
.head 6 -  Call SetNumber( nSeasonYear )
.head 6 -  Call SalSendMsg( hWndItem, PAM_clsSPN_VALIDATE, 0, 0 )
.head 6 -  Return TRUE

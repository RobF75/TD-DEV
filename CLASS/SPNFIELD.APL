.head 6 +  Actions
.head 7 -  Set nSeasonYear = nSeasonYear + nIncAmt
.head 7 +  If nSeasonYear >=97 AND nSeasonYear <=99
.head 8 -  Set nSeasonYear = nSeasonYear + 1900
.head 7 +  Else If nSeasonYear >=0 AND nSeasonYear <=50
.head 8 -  Set nSeasonYear = nSeasonYear + 2000
.head 5 +  Function: DecSeasonYear
.head 6 -  Description:
.head 6 -  Returns
.head 6 +  Parameters
.head 7 -  Number: nDecAmt
.head 6 -  Static Variables
.head 6 -  Local variables
.head 6 +  Actions
.head 7 -  Set nSeasonYear = nSeasonYear - nDecAmt
.head 7 +  If nSeasonYear <1997 AND nSeasonYear >1950
.head 8 -  Set nSeasonYear = nSeasonYear - 1900

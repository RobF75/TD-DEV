.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Date/Time: dtStartWinter
.head 5 -  Date/Time: dtEndWinter
.head 4 +  Actions
.head 5 -  Set dtStartWinter = SalDateConstruct( SalDateYear( dtDate ), 6, 1, 0, 0, 0 )
.head 5 -  Set dtEndWinter = SalDateConstruct( SalDateYear( dtDate ), 8, 31, 23, 59, 059 )
.head 5 +  If dtDate >= dtStartWinter AND dtDate <= dtEndWinter
.head 6 -  Return 'WINTER'
.head 5 +  Else
.head 6 -  Return 'OTHER'

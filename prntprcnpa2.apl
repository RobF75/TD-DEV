.head 5 -  String: sGotBusName
.head 5 -  String: sSql
.head 5 -  Number: nInd
.head 4 +  Actions
.head 5 +  If nExecuteOrDisconnect != nDisconnect
.head 6 +  If NOT bHandleConnected
.head 7 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 7 +  If bHandleConnected
.head 8 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 8 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 7 +  Else
.head 8 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 8 -  Return -1
.head 6 +  If NOT bHandlePrepared
.head 7 -  Set sSql = ' SELECT Cust_Name, Bus_Name 
  FROM Customer_Master 
  INTO :sGotCustName, :sGotBusName 
  WHERE Cust_No = :nCustNo '
.head 7 +  If SqlPrepare( hSqlHandle, sSql )
.head 8 -  Set bHandlePrepared = TRUE
.head 7 +  Else
.head 8 -  Set bHandlePrepared = FALSE
.head 6 -  Set sCustName = ''
.head 6 -  Set sBusName = ''
.head 6 -  Set sGotCustName = ''
.head 6 -  Set sGotBusName = ''
.head 6 +  If SqlExecute( hSqlHandle )
.head 7 -  Call SqlFetchNext( hSqlHandle, nInd )
.head 7 -  Set sCustName = sGotCustName
.head 7 -  Set sBusName = sGotBusName
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Set bHandlePrepared = FALSE
.head 7 -  Call SalMessageBox( 'SqlExecute had a error in function GetCustNames! Please contact programmers!', 'Error', MB_Ok )
.head 7 -  Return FALSE
.head 5 +  Else
.head 6 +  If bHandleConnected
.head 7 -  Set bHandlePrepared = FALSE
.head 7 -  Set bHandleConnected = FALSE
.head 7 -  Call SqlDisconnect( hSqlHandle )
.head 6 -  Return TRUE
.head 3 +  Function: DoesCustGetNPA
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Number: nExecuteOrDisconnect
.head 4 +  Static Variables
.head 5 -  Sql Handle: hSqlHandle
.head 5 -  Boolean: bHandleConnected
.head 5 -  Boolean: bHandlePrepared
.head 4 +  Local variables
.head 5 -  String: sGotNPAReqd
.head 5 -  String: sSql
.head 5 -  Number: nInd
.head 4 +  Actions
.head 5 +  If nExecuteOrDisconnect != nDisconnect
.head 6 +  If NOT bHandleConnected
.head 7 -  Set bHandleConnected = SqlConnect( hSqlHandle ) 
.head 7 +  If bHandleConnected
.head 8 -  Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
.head 8 -  Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
.head 7 +  Else
.head 8 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 8 -  Return TRUE
.head 6 +  If NOT bHandlePrepared
.head 7 -  Set sSql = " SELECT NPA_REQUIRED  
  FROM Customer_Type, CUSTOMER_MASTER 
  INTO :sGotNPAReqd  
  WHERE Cust_No = :nCustNo AND CUSTOMER_MASTER.CUSTOMER_TYPE = 
CUSTOMER_TYPE.CUST_TYPE  AND 
  ( NOT Customer_Master.FNA_Flag = 'Y' OR 
    Customer_Master.FNA_Flag IS NULL ) "
.head 7 +  If SqlPrepare( hSqlHandle, sSql )
.head 8 -  Set bHandlePrepared = TRUE
.head 7 +  Else
.head 8 -  Set bHandlePrepared = FALSE
.head 6 -  Set sGotNPAReqd = ''
.head 6 +  If SqlExecute( hSqlHandle )
.head 7 -  Call SqlFetchNext( hSqlHandle, nInd )
.head 7 +  If sGotNPAReqd = 'Y'
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Else
.head 7 -  Set bHandlePrepared = FALSE
.head 7 -  Call SalMessageBox( 'SqlExecute had a error in function GetCustNPAReqd! Please contact programmers!', 'Error', MB_Ok )
.head 7 -  Return TRUE
.head 5 +  Else
.head 6 +  If bHandleConnected
.head 7 -  Set bHandlePrepared = FALSE
.head 7 -  Set bHandleConnected = FALSE
.head 7 -  Call SqlDisconnect( hSqlHandle )
.head 6 -  Return TRUE
.head 3 -  !
.head 3 +  Function: CalcItemPrice
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Number: nItemNo
.head 5 -  Number: nYear
.head 5 -  String: sSaleCat
.head 5 -  String: sCultId
.head 5 -  String: sRootId
.head 5 -  Number: nContractPrice
.head 5 -  Boolean: bPrioNPAYear
.head 5 -  ! assumes nPricePerUnit is prior set to stock item base price
.head 5 -  Receive Number: nPricePerUnit
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Boolean: bFound
.head 5 -  Number: nQuotPrice
.head 5 -  Number: nBillCustNo
.head 5 -  Number: nCultRoy
.head 5 -  Number: nRootRoy
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case nExecute
.head 7 +  If bPriorNPAYear
.head 8 -  Set nPricePerUnit = NUMBER_Null
.head 7 +  Else
.head 8 -  Call GetItemBasePrice( nItemNo, nPricePerUnit, nExecute )
.head 8 -  !
.head 8 +  If nContractPrice != NUMBER_Null
.head 9 -  Set nPricePerUnit = nContractPrice
.head 8 +  Else
.head 9 -  Set bFound = FALSE
.head 9 -  Call GetCustItemQuotPrice( nCustNo, nYear, nItemNo, bFound, nQuotPrice, nExecute )
.head 9 +  If bFound
.head 10 -  Set nPricePerUnit = nQuotPrice
.head 9 +  Else
.head 10 -  Call GetBillingParent( nCustNo, nBillCustNo, nExecute )
.head 10 +  If nBillCustNo > 0
.head 11 -  Call GetCustItemQuotPrice( nBillCustNo, nYear, nItemNo, bFound, nQuotPrice, nExecute )
.head 11 +  If bFound
.head 12 -  Set nPricePerUnit = nQuotPrice
.head 9 -  !
.head 9 +  If sSaleCat = 'FC' OR sSaleCat = 'RP' OR sSaleCat = 'TT'
.head 10 -  Set nPricePerUnit = 0
.head 9 +  Else If sSaleCat = 'HP'
.head 10 -  Set nPricePerUnit = nPricePerUnit / 2
.head 8 +  If NOT ( sSaleCat = 'FC' OR sSaleCat = 'RP' OR sSaleCat = 'TT')
.head 9 +  If sCultId != ''
.head 10 -  Call CalcCultivarRoyalty( nCustNo, sCultId, nItemNo, nCultRoy, nExecute )
.head 9 +  If sRootId != ''
.head 10 -  Call CalcRootstockRoyalty( nCustNo, sRootId, nItemNo, nRootRoy, nExecute )
.head 8 -  Set nPricePerUnit = nPricePerUnit + nCultRoy + nRootRoy
.head 7 -  !
.head 7 -  Return TRUE
.head 6 +  Case nDisconnect
.head 7 -  Call GetCustItemQuotPrice( 0, 0, 0, bFound, nQuotPrice, nDisconnect )
.head 7 -  Call GetBillingParent( 0, nBillCustNo, nDisconnect )
.head 7 -  Call CalcCultivarRoyalty( 0, '', 0, nCultRoy, nDisconnect )
.head 7 -  Call CalcRootstockRoyalty( 0, '', 0, nRootRoy, nDisconnect )
.head 7 -  Call GetItemBasePrice( 0, nPricePerUnit, nDisconnect )
.head 7 -  Return TRUE

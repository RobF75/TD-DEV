.head 4 +  Message Actions
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLTABLENAME = ' Customer_Order '
.head 6 -  Set sSQLPOPTABLENAME = ' Customer_Order, Stock_Item '
.head 6 -  ! Set sSQLPOPTABLENAME = ' Customer_Order, Stock_Item, Cultivar '
.head 6 -  Set sROWID = ' CUSTOMER_ORDER.ROWID '
.head 6 -  Set sSQLWHERE = " WHERE Customer_Order.Cust_No = :frmPrintAcknowlegments.dfCustNo AND 
    Customer_Order.Year_Of_Sale = :frmPrintAcknowlegments.dfYear AND 
    Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
    NOT Customer_Order.pull_sheet_issued = 'Y' "
.head 6 -  ! Set sSQLWHERE = " WHERE Customer_Order.Cust_No = :frmPrintAcknowlegments.dfCustNo AND 
    Customer_Order.Year_Of_Sale = :frmPrintAcknowlegments.dfYear AND 
    Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
    Stock_Item.Cultivar_Id = Cultivar.Cult_Id(+) AND 
    NOT Customer_Order.pull_sheet_issued = 'Y' "
.head 6 -  Set sORDERBY = ' ORDER BY Stock_Item.Variety_Type, Stock_Item.Variety,
 Stock_Item.Cult_Desc,   Stock_Item.Rootstock_Id '
.head 6 -  ! Set sORDERBY = ' ORDER BY Cultivar.Variety_Type, Cultivar.Variety, Cultivar.Cult_Desc, 
  Stock_Item.Rootstock_Id '
.head 5 +  On SAM_FetchRowDone
.head 6 +  ! If colConfAmt > 0
.head 7 -  Set colQuantity = colConfAmt
.head 6 +  ! Else 
.head 7 -  Set colQuantity = colOrdAmt
.head 6 -  ! tRYING TO trap for where conf amt = 0 we want to print the zero
.head 6 +  If colConfAmt > NUMBER_Null
.head 7 -  Set colQuantity = colConfAmt
.head 6 +  Else
.head 7 -  Set colQuantity = colOrdAmt
.head 6 -  !
.head 6 +  If colSaleType = 'FC'
.head 7 -  Set colSaleTypeDesc = 'No Charge'
.head 6 +  Else If colSaleType = 'RP'
.head 7 -  Set colSaleTypeDesc = 'Replacement'
.head 6 +  Else If colSaleType = 'HP'
.head 7 -  Set colSaleTypeDesc = 'Half Price'
.head 6 +  Else If colSaleType = 'CS'
.head 7 -  Set colSaleTypeDesc = 'Consignment'
.head 6 +  Else
.head 7 -  Set colSaleTypeDesc = ''
.head 6 -  !
.head 6 -  Call GetTreeTypeDescription( colTreeType, colTreeTypeDesc, SH_cls_Execute )
.head 6 -  ! Call GetRootDescription( colRootId, colRootDesc, SH_cls_Execute )
.head 6 -  ! Call NewCalcTotalAvailGrowGraded( colItemNo, frmPrintAcknowlegments.dfYear, nTotalGrowing, nTotalGraded, nTotalAvail, SH_cls_Execute )
.head 6 +  If frmPrintAcknowlegments.bUseMessages
.head 7 -  Call NewCalcTotalAvail( colItemNo, frmPrintAcknowlegments.dfYear, nTotalAvail, SH_cls_Execute )
.head 7 +  If nTotalAvail >= 0
.head 8 -  Call GetTreeTypeMesssage( colTreeType, nGeneralMessage, sMessage, SH_cls_Execute )
.head 7 +  Else
.head 8 -  Call CalculateCustomersAvailPoint( colItemNo, frmPrintAcknowlegments.dfYear, frmPrintAcknowlegments.dfCustNo, colOrderDate, nTotalAvail, nAvailPoint, bAllocated, SH_cls_Execute )
.head 8 +  If nAvailPoint - colQuantity >= 0
.head 9 -  Call GetTreeTypeMesssage( colTreeType, nGeneralMessage, sMessage, SH_cls_Execute )
.head 8 +  Else
.head 9 -  Call GetTreeTypeMesssage( colTreeType, nCountMessage, sMessage, SH_cls_Execute )
.head 7 -  Call GetMessageLegend( sMessage, colMessageLegendNo, nSelectLegendNo )
.head 6 -  ! Call GetCultNonPropFlag( colCultId, sCultNonPropFlag, SH_cls_Execute )
.head 6 -  ! Call GetRootNonPropFlag( colRootId, sRootNonPropFlag, SH_cls_Execute )
.head 6 +  If colCvNPA = 'Y' OR colRtNPA = 'Y'
.head 7 -  Set colPatentedItem = 'Y'
.head 7 -  Set sMessage = sPatentedSIMessage
.head 7 -  Call GetMessageLegend( sMessage, nPatentedMessageLegendNo, nSelectLegendNo )
.head 6 +  Else
.head 7 -  Set colPatentedItem = 'N'
.head 6 +  ! If sCultNonPropFlag = 'Y' OR sRootNonPropFlag = 'Y'
.head 7 -  Set colPatentedItem = 'Y'
.head 7 -  Set sMessage = sPatentedSIMessage
.head 7 -  Call GetMessageLegend( sMessage, nPatentedMessageLegendNo, nSelectLegendNo )
.head 6 +  ! Else 
.head 7 -  Set colPatentedItem = 'N'
.head 5 +  On PAM_RESET
.head 6 -  Call PushWndHdl( hWndNULL )
.head 6 -  Call SalSendClassMessage( PAM_RESET, wParam, lParam )
.head 5 +  On PAM_NOROWS
.head 6 -  Return TRUE
.head 5 +  On SAM_Destroy
.head 6 -  ! Call GetRootDescription( '', colRootDesc, SH_cls_Disconnect )
.head 6 -  Call GetTreeTypeDescription( '', colTreeTypeDesc, SH_cls_Disconnect )
.head 6 -  Call NewCalcTotalAvail( 0, 0, nTotalAvail, SH_cls_Disconnect )
.head 6 -  ! Call GetCultNonPropFlag( '', sCultNonPropFlag, SH_cls_Disconnect )
.head 6 -  ! Call GetRootNonPropFlag( '', sRootNonPropFlag, SH_cls_Disconnect )
.head 6 -  Call SalSendClassMessage( SAM_Destroy, wParam, lParam )

.head 8 +  If nMessageType = nCountMessage
.head 9 +  If NOT bCntMsgHandleConnected
.head 10 -  Set bCntMsgHandleConnected = SqlConnect( hSqlCntMsgHandle ) 
.head 10 +  If bCntMsgHandleConnected
.head 11 -  Call SqlSetLockTimeout( hSqlCntMsgHandle, SQLTIMEOUT )
.head 11 -  Call SqlSetParameter( hSqlCntMsgHandle, DBP_PRESERVE, TRUE, ''  )
.head 10 +  Else
.head 11 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 11 -  Return FALSE
.head 9 +  If NOT bCntMsgHandlePrepared
.head 10 -  Set sSql = 'SELECT Ack_Count_Message FROM Tree_Type INTO :sGotMessage
  WHERE Tree_Type = :sTreeType '
.head 10 +  If SqlPrepare( hSqlCntMsgHandle, sSql )
.head 11 -  Set bCntMsgHandlePrepared = TRUE
.head 10 +  Else
.head 11 -  Set bCntMsgHandlePrepared = FALSE
.head 9 -  !
.head 9 +  If SqlExecute( hSqlCntMsgHandle )
.head 10 -  Call SqlFetchNext( hSqlCntMsgHandle, nInd )
.head 10 -  Set sMessage = sGotMessage
.head 9 +  Else
.head 10 -  Set bCntMsgHandlePrepared = FALSE
.head 10 -  Call SalMessageBox( 'SqlExecute had a error in function GetTreeTypeMesssage! Please contact programmers!', 'Error', MB_Ok )
.head 10 -  Return FALSE
.head 8 +  Else
.head 9 +  If NOT bGenMsgHandleConnected
.head 10 -  Set bGenMsgHandleConnected = SqlConnect( hSqlGenMsgHandle ) 
.head 10 +  If bGenMsgHandleConnected
.head 11 -  Call SqlSetLockTimeout( hSqlGenMsgHandle, SQLTIMEOUT )
.head 11 -  Call SqlSetParameter( hSqlGenMsgHandle, DBP_PRESERVE, TRUE, ''  )

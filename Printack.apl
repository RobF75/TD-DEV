.head 11 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 11 -  Return FALSE
.head 9 +  If NOT bGenMsgHandlePrepared
.head 10 -  Set sSql = 'SELECT Ack_Gen_Message FROM Tree_Type INTO :sGotMessage
  WHERE Tree_Type = :sTreeType '
.head 10 +  If SqlPrepare( hSqlGenMsgHandle, sSql )
.head 11 -  Set bGenMsgHandlePrepared = TRUE
.head 10 +  Else
.head 11 -  Set bGenMsgHandlePrepared = FALSE
.head 9 -  !
.head 9 +  If SqlExecute( hSqlGenMsgHandle )
.head 10 -  Call SqlFetchNext( hSqlGenMsgHandle, nInd )
.head 10 -  Set sMessage = sGotMessage
.head 9 +  Else
.head 10 -  Set bGenMsgHandlePrepared = FALSE
.head 10 -  Call SalMessageBox( 'SqlExecute had a error in function GetTreeTypeMesssage! Please contact programmers!', 'Error', MB_Ok )
.head 10 -  Return FALSE
.head 7 +  Else
.head 8 -  Set bCntMsgHandlePrepared = FALSE
.head 8 +  If bCntMsgHandleConnected
.head 9 -  Set bCntMsgHandleConnected = FALSE
.head 9 -  Call SqlDisconnect( hSqlCntMsgHandle )
.head 8 -  Set bGenMsgHandlePrepared = FALSE
.head 8 +  If bGenMsgHandleConnected
.head 9 -  Set bGenMsgHandleConnected = FALSE
.head 9 -  Call SqlDisconnect( hSqlGenMsgHandle )
.head 8 -  Return FALSE

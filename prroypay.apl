.head 8 +  If NOT bAllHandleConnected
.head 9 -  Set bAllHandleConnected = SqlConnect( hSqlAllHandle ) 
.head 9 +  If bAllHandleConnected
.head 10 -  Call SqlSetLockTimeout( hSqlAllHandle, SQLTIMEOUT )
.head 10 -  Call SqlSetParameter( hSqlAllHandle, DBP_PRESERVE, TRUE, ''  )

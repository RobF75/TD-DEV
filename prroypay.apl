  invoiced_date >= :dtRoyFromDate AND 
  invoiced_date <= :dtRoyToDate AND   
  invoiced_flag = 'Y' and 
  ( sale_cat in ('FC','RP') or
    contract_price = 0) and
  customer_order.stock_item_no = stock_item.item_no and
  stock_item.cultivar_id = :sCultId "

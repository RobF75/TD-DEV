.head 10 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 10 -  Return FALSE
.head 8 +  If NOT bAllHandlePrepared
.head 9 -  Set sSql = "select 
  sum(conf_amt), sum(NO_TREES_CREDITED) 
from 
  stock_item, customer_order
into :nGotNumRoyTrees, :nGotCreditedRoyTrees
where 
  invoiced_date >= :dtRoyFromDate AND 
  invoiced_date <= :dtRoyToDate AND  
  invoiced_flag = 'Y' and 
  customer_order.stock_item_no = stock_item.item_no and
  stock_item.cultivar_id = :sCultId "
.head 9 +  If SqlPrepare( hSqlAllHandle, sSql )

			Pushbutton Class: clspbPaintMaster
				Title: Paints
				Window Location and Size
					Left:  
					Top:   
					Width:  Class Default
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name: C:\CENTURA\ICONS\PAINTS.BMP
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				List in Tool Palette? Yes
				Property Template:
				Class DLL Name:
				Description:
				Derived From
					Class: clspbPickInto
				Class Variables
					String: sTmp
					Window Handle: hWndTmp
				Instance Variables
					! PUBLIC
					Window Handle: hWndPickIntoTable
					! PRIVATE
					String: sPaintId
					String: sPaintDesc
				Functions
					Function: SetPaintMasterFields
						Description:
						Returns
							Boolean:
						Parameters
							String: sNewPaintId
							String: sNewPaintDesc
						Static Variables
						Local variables
						Actions
							Set sPaintId = sNewPaintId
							Set sPaintDesc = sNewPaintDesc
							Return TRUE
					Function: GetPaintMasterFields
						Description:
						Returns
							Boolean:
						Parameters
							Receive String: sNewPaintId
							Receive String: sNewPaintDesc
						Static Variables
						Local variables
						Actions
							Set sNewPaintId = sPaintId
							Set sNewPaintDesc = sPaintDesc
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbPaintMaster.nActivateWindowType = ACTIVATE_FormWindow
						Set clspbPaintMaster.sActivateDialogName = 'frmPaintMaster'
						Set clspbPaintMaster.hWndTable = hWndPickIntoTable
						Set clspbPaintMaster.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushString( sPaintId )
						Call PushString( sPaintDesc )
						Call PushWndHdl( hWndItem )
						Return TRUE
					On PAM_clsPICK_LOOKUP
						Call PopString( sPaintDesc, TRUE )
						Call PopString( sPaintId, TRUE )
						Call SalSendMsg( hWndItem, PAM_cls_GETFIELDS, 0, 0 )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopWndHdl( hWndTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Return TRUE

								List Values
								Message Actions
									On PAM_cls_SETINSTANCEVARS
										Set colPaintId.bOrderBy = TRUE
									On PAM_clsTBL_EDITCHECK
										If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
											Return TRUE
										Else
											Return FALSE
									On PAM_clsTBL_CHECKROWNEW
										Call ExistsPaintId( colPaintId, bExists, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'This Paint ID already exists! Please change it first!', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE

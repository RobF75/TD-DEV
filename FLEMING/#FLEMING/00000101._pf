						Functions
						Window Variables
							Boolean: bExists
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = ' SELECT 
										  Paint_Id, 
										  Paint_Desc, 
										  Paint_Colour 
										FROM 
										  Paint_Master '
								Set sNAMEPopHandle = 'POPPAINTMIV'
								Set sBINDPopHandle = ''
								Set sINTOPopHandle = ':clsfrmPaintMaster.tblPaintMaster.colPaintId, 
										:clsfrmPaintMaster.tblPaintMaster.colPaintDesc, 
										:clsfrmPaintMaster.tblPaintMaster.colPaintColour'
								!
								Set sSQLRefreshHandle = ' SELECT 
										  Paint_Desc, 
										  Paint_Colour 
										FROM 
										  Paint_Master 
										WHERE Paint_Id = :1 '
								Set sNAMERefreshHandle = 'REFPAINTMIV'
								Set sBINDRefreshHandle = ':clsfrmPaintMaster.tblPaintMaster.colPaintId'
								Set sINTORefreshHandle = ':clsfrmPaintMaster.tblPaintMaster.colPaintDesc, 
										:clsfrmPaintMaster.tblPaintMaster.colPaintColour'
								!
								Set sSQLInsertHandle = ' INSERT INTO Paint_Master 
										( Paint_Id, Paint_Desc, Paint_Colour ) VALUES ( :1, :2, :3 ) '
								Set sNAMEInsertHandle = 'INSPAINTMIV'
								Set sBINDInsertHandle = ':clsfrmPaintMaster.tblPaintMaster.colPaintId, 
										:clsfrmPaintMaster.tblPaintMaster.colPaintDesc, 
										:clsfrmPaintMaster.tblPaintMaster.colPaintColour'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE Paint_Master 
										SET 
										  Paint_Desc = :2, 
										  Paint_Colour = :3 
										WHERE 
										  Paint_Id = :1'
								Set sNAMEUpdateHandle = 'UPDTPAINTMIV'
								Set sBINDUpdateHandle = ':clsfrmPaintMaster.tblPaintMaster.colPaintId, 
										:clsfrmPaintMaster.tblPaintMaster.colPaintDesc, 
										:clsfrmPaintMaster.tblPaintMaster.colPaintColour'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = ' DELETE FROM Paint_Master WHERE Paint_Id = :1 '
								Set sNAMEDeleteHandle = 'DELPAINTM'
								Set sBINDDeleteHandle = ':clsfrmPaintMaster.tblPaintMaster.colPaintId'
								Set sINTODeleteHandle = ''
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								Set bQueryAllowed = TRUE
								Set bReportAllowed = FALSE
								Set bOrderAllowed = TRUE
								!
								Set sQueryDialogName = 'dlgQueryPaintMaster'
							On SAM_Destroy
								Call ExistsPaintId( '', bExists, SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
							On PAM_clsTBL_PUSHFIELDS
								Call PushString( hWndParent.clsfrmPaintMaster.sPaintId )
								Call PushString( hWndParent.clsfrmPaintMaster.sPaintDesc )
								Return TRUE

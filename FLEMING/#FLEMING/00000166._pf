				                              Description: 
				                              Derived From 
				                              Class Variables 
					                              String: sIniFile
					                              String: sAppFileName
					                              String: sAppDescription
					                              Number: nRunModeReturn
					                              Window Handle: hWndThisWnd
					                              String: sTmp
					                              Number: nTmp
				                              Instance Variables 
					! PUBLIC
					                              String: sLiveProgramSection
					                              String: sLiveProgramDescription
					                              String: sLiveProgramTitle
					                              String: sLiveProgramDefaultPathNameExt
					!
					                              String: sPlayProgramSection
					                              String: sPlayProgramDescription
					                              String: sPlayProgramTitle
					                              String: sPlayProgramDefaultPathNameExt
					!
					! sUserTypeRestrictions = NULL, SystemAdministrators, AccountsUsers, SQLConsoleUsers, 
							WinTalkUsers, RepWinUsers, QuestUsers, TeamWinUsers, SqlWinUsers
					                              String: sUserTypeRestrictions
					                              Boolean: bLoadAndWait
					                              Number: nRunMode
					                              String: sExtraParameterCommandLine
					                              Boolean: bStartGuptaApps
					! PRIVATE
					                              String: sLiveProgramPathNameExt
					                              String: sPlayProgramPathNameExt
					                              String: sLiveUsers
					                              String: sPlayUsers
					                              Boolean: bAccessGranted
				                              Functions 
					                              Function: Setup
						                              Description: 
						                              Returns 
						                              Parameters 
							                              String: sNewLiveProgramSection
							                              String: sNewLiveProgramDescription
							                              String: sNewLiveProgramTitle
							                              String: sNewLiveProgramDefaultPathNameExt
							                              String: sNewPlayProgramSection
							                              String: sNewPlayProgramDescription
							                              String: sNewPlayProgramTitle
							                              String: sNewPlayProgramDefaultPathNameExt
							                              String: sNewUserTypeRestrictions
							                              Boolean: bNewLoadAndWait
							                              Number: nNewRunMode
							                              String: sNewExtraParameterCommandLine
							                              Number: nNewTimerDelay
							                              Number: nNewTimerId
							                              Boolean: bNewStartGuptaApps
						                              Static Variables 
						                              Local variables 
						                              Actions 
							                              Set sIniFile = FlemSysIniFileName
							                              Set sLiveProgramSection = IniGeneralLiveSectionName
							                              Set sLiveProgramDescription = ''
							                              Set sLiveProgramTitle = ''
							                              Set sLiveProgramDefaultPathNameExt = ''
							                              Set sLiveProgramPathNameExt = ''
							                              Set sPlayProgramSection = IniGeneralPlaySectionName
							                              Set sPlayProgramDescription = ''
							                              Set sPlayProgramTitle = ''
							                              Set sPlayProgramDefaultPathNameExt = ''
							                              Set sPlayProgramPathNameExt = ''
							                              Set sUserTypeRestrictions = ''
							                              Set bLoadAndWait = FALSE
							                              Set nRunMode = Window_Normal
							                              Set sExtraParameterCommandLine = ''
							                              Set nTimerDelay = 5000
							                              Set nTimerId = 5000
							                              Set bStartGuptaApps = TRUE
							                              Set bAccessGranted = TRUE
							!
							                              Set sLiveProgramSection = sNewLiveProgramSection
							                              Set sLiveProgramDescription = sNewLiveProgramDescription
							                              Set sLiveProgramTitle = sNewLiveProgramTitle
							                              Set sLiveProgramDefaultPathNameExt = sNewLiveProgramDefaultPathNameExt
							                              Set sPlayProgramSection = sNewPlayProgramSection
							                              Set sPlayProgramDescription = sNewPlayProgramDescription
							                              Set sPlayProgramTitle = sNewPlayProgramTitle
							                              Set sPlayProgramDefaultPathNameExt = sNewPlayProgramDefaultPathNameExt
							                              Set sUserTypeRestrictions = sNewUserTypeRestrictions
							                              Set bLoadAndWait = bNewLoadAndWait
							                              Set nRunMode = nNewRunMode
							                              Set sExtraParameterCommandLine = sNewExtraParameterCommandLine
							                              Set nTimerDelay = nNewTimerDelay
							                              Set nTimerId = nNewTimerId
							                              Set bStartGuptaApps = bNewStartGuptaApps
							!
							                              Call SalGetProfileString( sLiveProgramSection, sLiveProgramTitle, sLiveProgramDefaultPathNameExt, sLiveProgramPathNameExt, sIniFile )
							                              Call SalGetProfileString( sPlayProgramSection, sPlayProgramTitle, sPlayProgramDefaultPathNameExt, sPlayProgramPathNameExt, sIniFile )
							                              If sUserTypeRestrictions != ''
								                              Call SalGetProfileString( sLiveProgramSection, sUserTypeRestrictions, '', sLiveUsers, sIniFile )
								                              Call SalGetProfileString( sPlayProgramSection, sUserTypeRestrictions, '', sPlayUsers, sIniFile )
								                              If SqlDatabase = 'STOCK'
									                              If NOT SalStrScan( sLiveUsers, SqlUser ) >= 0
										                              Call SalSendMsg( hWndItem, PAM_clsPB_HIDE, 0, 0 )
										                              Call SalSendMsg( hWndItem, PAM_clsPB_DISABLE, 0, 0 )
										                              Set bAccessGranted = FALSE
								                              Else 
									                              If NOT SalStrScan( sPlayUsers, SqlUser ) >= 0
										                              Call SalSendMsg( hWndItem, PAM_clsPB_HIDE, 0, 0 )
										                              Call SalSendMsg( hWndItem, PAM_clsPB_DISABLE, 0, 0 )
										                              Set bAccessGranted = FALSE
							                              Return TRUE
					                              Function: GetAppNameFromPath
						                              Description: 
						                              Returns 
							                              String: 
						                              Parameters 
							                              String: sAppFullName
						                              Static Variables 
						                              Local variables 
							                              String: sTokens[*]
							                              Number: nNumTokens
							                              String: sTmp
							                              Number: nPos
						                              Actions 
							                              Set nNumTokens = SalStrTokenize( sAppFullName, '', '\\', sTokens )
							                              Set sTmp = sTokens[ nNumTokens - 1 ]
							                              Set nPos = SalStrScan( sTmp, '.' ) 
							                              If nPos >= 0
								                              Set sTmp = SalStrLeftX( sTmp, nPos )
							                              Return SalStrUpperX( sTmp )
			! General Window Class: clsStartProgram
.winattr
.end

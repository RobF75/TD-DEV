		Functions
			Function: Scheduler
				Description:
				Returns
					Boolean:
				Parameters
					Number: nActionType
				Static Variables
					! hcSqlHandle: hCheckScheduleHdl
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: hUpdtScheduleHdl
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: hInsScheduleHdl
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sName
					String: sBind
					String: sInto
					Number: nOurCheckScheduleHandleNo
					Number: nOurUpdtScheduleHandleNo
					Number: nOurInsScheduleHandleNo
					Boolean: bOk
					!
					Number: nInd
					!
					Date/Time: dtPerformedSysDT
					String: sActivityDesc
					String: sStatus
					Date/Time: dtNextDateTime
					String: sUserId
				Actions
					Set nOurCheckScheduleHandleNo = SqlHandlesGetReferenceNo( 'NEXTSCHEDULE' )
					Set nOurUpdtScheduleHandleNo = SqlHandlesGetReferenceNo( 'UPDTSCHEDULE' )
					Set nOurInsScheduleHandleNo = SqlHandlesGetReferenceNo( 'NEWSCHEDULE' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Performed_Sys_DT, 
									  Activity_Desc, 
									  Status, 
									  Next_DateTime, 
									  User_Id 
									FROM 
									  Schedule 
									WHERE 
									  Next_DateTime < SYSDATETIME AND 
									  Status = 'READY' "
							Set sName = 'NEXTSCHEDULE'
							Set sBind = ''
							Set sInto = ':dtPerformedSysDT, :sActivityDesc, :sStatus, :dtNextDateTime, :sUserId'
							Call haSqlHandles[ nOurCheckScheduleHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurCheckScheduleHandleNo ].hSqlHandle )
							!
							Set sSql = "UPDATE Schedule 
									SET 
									  Status = :3, 
									  User_Id = :4 
									WHERE 
									  Performed_Sys_DT = :1 AND 
									  Activity_Desc = :2 "
							Set sName = 'UPDTSCHEDULE'
							Set sBind = ':dtPerformedSysDT, :sActivityDesc, :sStatus, :sUserId'
							Set sInto = ''
							Call haSqlHandles[ nOurUpdtScheduleHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurUpdtScheduleHandleNo ].hSqlHandle )
							!
							Set sSql = "INSERT INTO Schedule 
									( Performed_Sys_DT, 
									  Activity_Desc, 
									  Status, 
									  Next_DateTime, 
									  User_Id ) 
									VALUES ( :1, :2, :3, :4, :5 ) "
							Set sName = 'NEWSCHEDULE'
							Set sBind = ':dtPerformedSysDT, :sActivityDesc, :sStatus, :dtNextDateTime, :sUserId'
							Set sInto = ''
							Call haSqlHandles[ nOurInsScheduleHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurInsScheduleHandleNo ].hSqlHandle )
							!
							Set dtPerformedSysDT = DATETIME_Null
							Set sActivityDesc = ''
							Set sStatus = ''
							Set dtNextDateTime = DATETIME_Null
							Set sUserId = ''
							!
							If haSqlHandles[ nOurCheckScheduleHandleNo ].Execute( )
								While haSqlHandles[ nOurCheckScheduleHandleNo ].FetchNext( nInd )
									Set sStatus = 'PERFORMING'
									If haSqlHandles[ nOurUpdtScheduleHandleNo ].Execute( )
										Call haSqlHandles[ nOurUpdtScheduleHandleNo ].Commit( )
										Set sUserId = SqlUser
										If PerformAction( sActivityDesc, dtNextDateTime )
											Set sStatus = 'COMPLETE'
										Else
											Set sStatus = 'INCOMPLETE'
										If haSqlHandles[ nOurUpdtScheduleHandleNo ].Execute( )
											Set sStatus = 'READY'
											Set dtPerformedSysDT = SalDateCurrent(  )
											If haSqlHandles[ nOurInsScheduleHandleNo ].Execute( )
												Call haSqlHandles[ nOurInsScheduleHandleNo ].Commit( )
												Call haSqlHandles[ nOurUpdtScheduleHandleNo ].Commit( )
											Else
												Call haSqlHandles[ nOurUpdtScheduleHandleNo ].Rollback( )
												Return FALSE
										Else
											Return FALSE
									Else
										Return FALSE
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nOurCheckScheduleHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurUpdtScheduleHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurInsScheduleHandleNo ].Disconnect( )
								Set bOk = FALSE
							Return bOk
			Function: PerformAction
				Description:
				Returns
					Boolean:
				Parameters
					String: sActivityDesc
					Receive Date/Time: dtNextDateTime
				Static Variables
				Local variables
					Boolean: bOk
					Number: nReturn
				Actions
					Set bOk = TRUE
					If sActivityDesc = 'UPDT WHEN AVAILABLE'
						! Call hWndForm.clsStartProgram..SetAppName( 'ScheduleUpdateWhenAvailable'  )
						! Call hWndForm.clsStartProgram..SetLoadAndWait( TRUE )
						! Call hWndForm.clsStartProgram..SetRunMode( Window_Minimized )
						! If hWndForm.clsStartProgram..StartProgram(  )
							                           Set dtNextDateTime = SalDateConstruct( SalDateYear( SalDateCurrent(  ) ), SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 0, 0, 0 ) + 1
						Call CheckForNewAvailPotsStock( SalDateCurrent(  ), SH_cls_Execute )
						Set dtNextDateTime = SalDateConstruct( SalDateYear( SalDateCurrent(  ) ), SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 0, 0, 0 ) + 1
					Else If sActivityDesc = 'UPDT DENORM FIELDS'
						Call UpdtDenormStckItmFields( naItemNos, 'ALL', SH_cls_Execute )
						Set dtNextDateTime = SalDateConstruct( SalDateYear( SalDateCurrent(  ) ), SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 0, 0, 0 ) + 1
					Return bOk
		Window Parameters
		Window Variables
			Number: naItemNos[*]
		Message Actions
			On SAM_CreateComplete
				Call SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
				Call SalSendMsg( hWndForm, PAM_SCHEDULER_START, 0, 0 )
				Call Scheduler( SH_cls_Disconnect )
				Call UpdtDenormStckItmFields( naItemNos, '', SH_cls_Disconnect )
				Call CheckForNewAvailPotsStock( DATETIME_Null, SH_cls_Disconnect )
				Call SqlHandlesDisconnectClose(  )
			On SAM_Destroy
				Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
			On PAM_SCHEDULER_START
				Call OurWaitCursor( TRUE )
				Set dfLoading = 'Please Wait, Running - Scheduler'
				If IsUserSELECTUser( SqlUser, FALSE ) AND 
						IsUserINSERTUser( SqlUser, FALSE ) AND 
						IsUserUPDATEUser( SqlUser, FALSE ) AND 
						IsUserDELETEUser( SqlUser, FALSE )
					Call Scheduler( SH_cls_Execute )
				Set dfLoading = ''
				Call OurWaitCursor( FALSE )
			!
			On PAM_clsPB_LOADING_START
				Set dfLoading = 'Please Wait, Loading - '||SalNumberToHString( lParam )
				Return TRUE
			On PAM_clsPB_LOADING_END
				Set dfLoading = ''
				Return TRUE

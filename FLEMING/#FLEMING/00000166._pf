				Property Template:
				Class DLL Name:
.end
				                             Description: 
				                             Derived From 
					                             Class: clsStartProgram
					                             Class: clspbGeneral
				                             Class Variables 
				                             Instance Variables 
				                             Functions 
				                             Message Actions 
					                             On SAM_Create
						                             Call SalSendClassMessageNamed( clsStartProgram, SAM_Create, wParam, lParam )
						                             Return SalSendClassMessageNamed( clspbGeneral, SAM_Create, wParam, lParam )
					                             On PAM_cls_SETINSTANCEVARS
						                             Set clspbStartProg.bDoubleClickOK = FALSE
					                             On PAM_clsPB_CLICK
						                             Call hWndItem.clsStartProgram..StartProgram(  )
						                             Return TRUE
					                             On PAM_clsPB_LOADING_END
						! If NOT bLoadAndWait
							                             Call SalTimerKill ( hWndItem, nTimerId )
							                             Call SalGetWindowText( hWndForm, sTmp, 60 )
							                             Set hWndThisWnd = FindWindowA( 0, sTmp )
							                             Call ShowWindow( hWndThisWnd, SW_MINIMIZE )
						! Else
							                             Call SalGetWindowText( hWndForm, sTmp, 60 )
							                             Set hWndThisWnd = FindWindowA( 0, sTmp )
							                             Call ShowWindow( hWndThisWnd, SW_RESTORE )
						                             Call SalSendMsg( hWndForm, PAM_clsPB_LOADING_END, wParam, lParam )
						                             Call SalSendMsg( hWndItem, PAM_clsPB_ENABLE, 2, 0 )
						                             Call OurWaitCursor( FALSE )
					                             On PAM_clsPB_ENABLE
						                             If wParam = 2
							                             Return SalSendClassMessage( PAM_clsPB_ENABLE, 0, 0 )
						                             Else 
							                             Return TRUE

				                             Functions 
					                             Function: LaunchApp
						                             Description: 
						                             Returns 
						                             Parameters 
						                             Static Variables 
						                             Local variables 
							                             Window Handle: hWnd
						                             Actions 
							! Try to find an existing instance of the app
									and bring it to the top
							                             Set hWnd = SalAppFind( __isProgramExePath, FALSE )
							! If we found it
							                             If hWnd
								! GetLastActivePopup will return the handle of any modal dialogs in use
								                             Set hWnd = GetLastActivePopup( hWnd )
								                             Return SalBringWindowToTop( hWnd )
							                             Else 
								! The app was not found, try to load it
								                             Return SalLoadApp( __isProgramExePath, isDBName||' '||SqlUser||' '||SqlPassword||' '||isParams )
					                             Function: LaunchAppAndWait
						                             Description: 
						                             Returns 
						                             Parameters 
						                             Static Variables 
						                             Local variables 
							                             Window Handle: hWnd
							                             Number: nRunModeReturn
						                             Actions 
							! Try to find an existing instance of the app
									and bring it to the top
							                             Set hWnd = SalAppFind( __isProgramExePath, FALSE )
							! If we found it
							                             If hWnd
								! GetLastActivePopup will return the handle of any modal dialogs in use
								                             Set hWnd = GetLastActivePopup( hWnd )
								                             Return SalBringWindowToTop( hWnd )
							                             Else 
								! The app was not found, try to load it
								                             Return SalLoadAppAndWait( __isProgramExePath, inRunMode, __inRunModeReturn )
					                             Function: ExecProgram
						                             Description: 
						                             Returns 
							                             Boolean: 
						                             Parameters 
						                             Static Variables 
						                             Local variables 
							                             Number: nTmp
						                             Actions 
							                             Set nTmp = WinExec( __isProgramExePath||' '||isParams, SW_SHOW )
							                             If nTmp >= 32
								                             Return TRUE
							                             Else 
								                             Return FALSE
					                             Function: CloseApp
						                             Description: 
						                             Returns 
						                             Parameters 
							                             String: sApp
						                             Static Variables 
						                             Local variables 
							                             Window Handle: hWnd
							                             Window Handle: hWndChild
						                             Actions 
							! Try to find an existing instance of the app
									and bring it to the top
							                             Set hWnd = SalAppFind( sApp, FALSE )
							! If we found it
							                             If hWnd
								! Post it a close message
								! This message must be posted, if you send,
										it screws up Windows
								                             Call SalPostMsg( hWnd, SAM_Close, 0, 0 )
							                             Return TRUE
					                             Function: OnClose
						                             Description: 
						                             Returns 
							                             Boolean: 
						                             Parameters 
							                             String: sProgName
							                             Window Handle: hWndCalledFrom
						                             Static Variables 
						                             Local variables 
						                             Actions 
							                             If not CloseApp( sProgName )
								                             Return FALSE
							! Post ourselves a close message
							                             Call SalPostMsg( hWndCalledFrom, PAM_cls_CLOSE, 0, 0  )
					                             Function: ShutDown
						                             Description: 
						                             Returns 
							                             Boolean: 
						                             Parameters 
							                             String: sProgName
						                             Static Variables 
						                             Local variables 
						                             Actions 
							! If either of the subsystem apps is still around, don't exit
							                             If SalAppFind( sProgName, FALSE )
								                             Return FALSE
							                             Call SalQuit()
					                             Function: Enabled
						                             Description: 
						                             Returns 
							                             Boolean: 
						                             Parameters 
							                             Number: nUserType
						                             Static Variables 
						                             Local variables 
						                             Actions 
							                             Select Case nUserType
								                             Case USR_ACCT
									                             If SalStrScan( __csAccUsers, SqlUser ) >= 0
										                             Return TRUE
									                             Else 
										                             Return FALSE
								                             Case USR_FAMILY
									                             If SalStrScan( __csFamUsers, SqlUser ) >= 0
										                             Return TRUE
									                             Else 
										                             Return FALSE
								                             Case USR_PRICEADJ
									                             If SalStrScan( __csPAdjUsers, SqlUser ) >= 0
										                             Return TRUE
									                             Else 
										                             Return FALSE
								                             Case USR_STCKCONTROL
									                             If SalStrScan( __csSContUsers, SqlUser ) >= 0
										                             Return TRUE
									                             Else 
										                             Return FALSE
								                             Case USR_SYSADM
									                             If SalStrScan( __csSysAdmUsers, SqlUser ) >= 0
										                             Return TRUE
									                             Else 
										                             Return FALSE
								                             Case USR_GENERAL
									                             Return TRUE
								                             Default 
									                             Return TRUE
					                             Function: SetCreditorDatabase
						                             Description: 
						                             Returns 
							                             Boolean: 
						                             Parameters 
						                             Static Variables 
						                             Local variables 
						                             Actions 
							                             If sDatabase = 'LIVE'
								                             Set isDBName = 'CREDITOR'
							                             Else 
								                             Set isDBName = 'CREDDEV'
					                             Function: SetAppName
						                             Description: 
						                             Returns 
							                             Boolean: 
						                             Parameters 
							                             String: sAppName
						                             Static Variables 
						                             Local variables 
						                             Actions 
							                             Set isAppName = sAppName
					                             Function: SetParams
						                             Description: 
						                             Returns 
							                             Boolean: 
						                             Parameters 
							                             String: sParams
						                             Static Variables 
						                             Local variables 
						                             Actions 
							                             Set isParams = sParams
					                             Function: SetRunMode
						                             Description: 
						                             Returns 
							                             Boolean: 
						                             Parameters 
							                             Number: nRunMode
						                             Static Variables 
						                             Local variables 
						                             Actions 
							                             Set inRunMode = nRunMode
					                             Function: SetLoadAndWait
						                             Description: 
						                             Returns 
							                             Boolean: 
						                             Parameters 
							                             Boolean: bLoadAndWait
						                             Static Variables 
						                             Local variables 
						                             Actions 
							                             Set ibLoadAndWait = bLoadAndWait
					                             Function: SetExecProgram
						                             Description: 
						                             Returns 
							                             Boolean: 
						                             Parameters 
							                             Boolean: bExecProgram
						                             Static Variables 
						                             Local variables 
						                             Actions 
							                             Set ibExecProgram = bExecProgram
					                             Function: StartProgram
						                             Description: 
						                             Returns 
							                             Boolean: 
						                             Parameters 
						                             Static Variables 
						                             Local variables 
						                             Actions 
							                             Call DisplayStartMessage( )
							                             Call SalGetProfileString( __csSectionName, isAppName, '', __isProgramExePath, FlemSysIniFileName )
							                             If ibExecProgram
								                             Call ExecProgram(  )
							                             Else If ibLoadAndWait
								                             Set __isProgramExePath = __isProgramExePath||' '||isDBName||' '||SqlUser||' '||SqlPassword||' '||isParams
								                             Call LaunchAppAndWait(  )
							                             Else 
								                             Call LaunchApp(  )
							                             Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
							                             Return TRUE
					                             Function: DisplayStartMessage
						                             Description: 
						                             Returns 
							                             Boolean: 
						                             Parameters 
						                             Static Variables 
						                             Local variables 
						                             Actions 
							                             Call SalSendMsg( hWndForm, PAM_clsPB_LOADING_START, 0, SalHStringToNumber( isAppName ) )
				                             Message Actions 
					                             On SAM_Create
						                             If NOT __cbInitialized
							                             If sDatabase = 'LIVE'
								                             Set __cbLive = TRUE 
								                             Set __csSectionName = IniGeneralLiveSectionName
								                             Set __csAccSectionName = IniAccountsLiveSectionName
							                             Else 
								                             Set __cbLive = FALSE
								                             Set __csSectionName = IniGeneralPlaySectionName
								                             Set __csAccSectionName = IniAccountsPlaySectionName
							                             Call SalGetProfileString( __csAccSectionName, 'AccountsUsers', '', __csAccUsers, FlemSysIniFileName )
							                             Call SalGetProfileString( __csAccSectionName, 'FlemingsFamily', '', __csFamUsers, FlemSysIniFileName )
							                             Call SalGetProfileString( __csSectionName, 'PriceAdjusters', '', __csPAdjUsers, FlemSysIniFileName )
							                             Call SalGetProfileString( __csSectionName, 'StockControllers', '', __csSContUsers, FlemSysIniFileName )
							                             Call SalGetProfileString( __csAccSectionName, 'SystemAdministrators', '', __csSysAdmUsers, FlemSysIniFileName )
							                             Set __cbInitialized = TRUE
						                             Set isParams = ''
						                             Set ibExecProgram = FALSE
						                             Set inRunMode = Window_Normal
						                             If sDatabase = 'LIVE'
							                             Set isDBName = 'STOCK'
						                             Else 
							                             Set isDBName = 'STOCKDEV'

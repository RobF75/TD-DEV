								Message Actions
									On PAM_clsTBL_DATAVAL
										If SalIsNull( hWndItem )
											Call ErrorMessage( 'No Stock Item was selected here! Please select a valid stock item first.', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE
									On PAM_clsTBL_CHECKROWNEW
										Call CountSpecificCstLblas( colCstLblCustNo, colCstLblItemNo, colCstLblYearOfSale, nCount, SH_cls_Execute )
										If nCount > 0
											Call ErrorMessage( 'This same CstLblation already exists for this customer! Please rectify!', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE
									On PAM_clsTBL_CHECKROWEDITED
										Call CountSpecificCstLblas( colCstLblCustNo, colCstLblItemNo, colCstLblYearOfSale, nCount, SH_cls_Execute )
										If nCount > 1
											Call ErrorMessage( 'This same CstLblation already exists for this customer! Please rectify!', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE

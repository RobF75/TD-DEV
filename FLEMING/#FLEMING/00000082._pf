				Functions
				Message Actions
					On SAM_Create
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set bMapEnterToTab = TRUE
						Set hWndFirstFocus = dfCustNo
					On PAM_clsDLG_POPFIELDS
						Call PopString( dfRootDesc, FALSE )
						Call PopString( dfCultDesc, FALSE )
						Call PopString( dfTreeTypeDesc, FALSE )
						Call PopNumber( dfItemNo, FALSE )
						Call PopNumber( dfYear, FALSE )
						Call PopString( dfBusName, FALSE )
						Call PopString( dfCustName, FALSE )
						Call PopNumber( dfCustNo, FALSE )
						Return TRUE
					On PAM_clsDLG_PUSHFIELDS
						Call PushNumber( dfCustNo )
						Call PushString( dfCustName )
						Call PushString( dfBusName )
						Call PushNumber( dfYear )
						Call PushNumber( dfItemNo )
						Call PushString( dfTreeTypeDesc )
						Call PushString( dfCultDesc )
						Call PushString( dfRootDesc )
						Return TRUE

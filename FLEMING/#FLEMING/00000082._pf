					Class: clspbPickInto
				Class Variables
					String: sTmp
					Number: nTmp
					Window Handle: hWndTmp
				Instance Variables
					! PUBLIC
					Window Handle: hWndPickIntoTable
					! PRIVATE
					Number: nCustNo
					String: sCustName
					Number: nItemNo
					Number: nYear
					String: sTreeTypeDesc
					String: sCultDesc
					String: sRootDesc
				Functions
					Function: SetCstLblationsFields
						Description:
						Returns
							Boolean:
						Parameters
							Number: nNewCustNo
							String: sNewCustName
							Number: nNewItemNo
							Number: nNewYear
							String: sNewTreeTypeDesc
							String: sNewCultDesc
							String: sNewRootDesc
						Static Variables
						Local variables
						Actions
							Set nCustNo = nNewCustNo
							Set sCustName = sNewCustName
							Set nItemNo = nNewItemNo
							Set nYear = nNewYear
							Set sTreeTypeDesc = sNewTreeTypeDesc
							Set sCultDesc = sNewCultDesc
							Set sRootDesc = sNewRootDesc
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbCustLabels.nActivateWindowType = ACTIVATE_FormWindow
						Set clspbCustLabels.sActivateDialogName = 'frmCustLabels'
						Set clspbCustLabels.hWndTable = hWndPickIntoTable
						Set clspbCustLabels.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushNumber( nCustNo )
						Call PushString( sCustName )
						Call PushNumber( nItemNo )
						Call PushNumber( nYear )
						Call PushString( sTreeTypeDesc )
						Call PushString( sCultDesc )
						Call PushString( sRootDesc )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Return TRUE

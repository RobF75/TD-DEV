						Functions
							Function: CountSpecificCstLblas
								Description:
								Returns
									Boolean:
								Parameters
									Number: nCustNo
									Number: nItemNo
									Number: nYear
									Receive Number: nCount
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nGotCount
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'CNTSPECCstLblA' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT 
													  Count( * ) 
													FROM 
													  CstLblation 
													WHERE 
													  Cust_No = :1 AND 
													  Stock_Item_No = :2 AND 
													  Year_Of_Sale = :3 "
											Set sName = 'CNTSPECCstLblA'
											Set sBind = ':nCustNo, :nItemNo, :nYear'
											Set sInto = ':nGotCount'
											!
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set nCount = NUMBER_Null
											Set nGotCount = NUMBER_Null
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set nCount = nGotCount
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: CustNoExists
								Description:
								Returns
									Boolean:
								Parameters
									Number: nCustNo
									Number: nActionType
								Static Variables
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nGotCustNo
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'CstLblCUSTNOEXISTS' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT 
													  CUST_NO
													FROM 
													  Customer_Master
													WHERE 
													  Cust_No = :1 "
											Set sName = 'CstLblCUSTNOEXISTS'
											Set sBind = ':nCustNo'
											Set sInto = ':nGotCustNo'
											!
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set nGotCustNo = NUMBER_Null
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													! Set nCount = nGotCount
													Return TRUE
												Else
													Return FALSE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
						Window Variables
							Number: nCount
							Boolean: bExists
							String: sTmp
							! Query hold fields
							String: sRootDesc
							String: sCultDesc
							String: sTreeTypeDesc
							Number: nItemNo
							Number: nYear
							String: sBusName
							String: sCustName
							Number: nCustNo
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = ' SELECT 
										  CstLblation.User_Id, 
										  CstLblation.Sys_Date_Time, 
										  CstLblation.Stock_Item_No, 
										  CstLblation.Year_Of_Sale,
										  Stock_Item.Variety_Type, 
										  @UPPER( Stock_Item.Variety ), 
										  @UPPER( Stock_Item.Cult_Desc ), 
										  @UPPER( Stock_Item.Root_Desc ), 
										  Stock_Item.Tree_Type_Desc, 
										  Stock_Item.Cult_Desc, 
										  Stock_Item.Root_Desc, 
										  CstLblation.Contract_Price, 
										  CstLblation.Cust_No, 
										  @UPPER( Customer_Master.Cust_Name ), 
										  Customer_Master.Cust_Name 
										FROM 
										  CstLblation, 
										  Customer_Master, 
										  Stock_Item 
										WHERE 
										  CstLblation.Cust_No = Customer_Master.Cust_No AND 
										  CstLblation.Stock_Item_No = Stock_Item.Item_No
										ORDER BY 14,13,4,5,6,7,8,9 '
								Set sNAMEPopHandle = 'POPCstLblS'
								Set sBINDPopHandle = ''
								Set sINTOPopHandle = ':clsfrmCustLabels.tblCustLabels.colCstLblUserId, 
										:clsfrmCustLabels.tblCustLabels.colCstLblSysDT, 
										:clsfrmCustLabels.tblCustLabels.colCstLblItemNo, 
										:clsfrmCustLabels.tblCustLabels.colCstLblYearOfSale, 
										:clsfrmCustLabels.tblCustLabels.colVarietyType, 
										:clsfrmCustLabels.tblCustLabels.colUpperVariety, 
										:clsfrmCustLabels.tblCustLabels.colUpperCultDesc, 
										:clsfrmCustLabels.tblCustLabels.colUpperRootDesc, 
										:clsfrmCustLabels.tblCustLabels.colTreeTypeDesc, 
										:clsfrmCustLabels.tblCustLabels.colCultDesc,
										:clsfrmCustLabels.tblCustLabels.colRootDesc, 
										:clsfrmCustLabels.tblCustLabels.colCstLblContPrice, 
										:clsfrmCustLabels.tblCustLabels.colCstLblCustNo, 
										:clsfrmCustLabels.tblCustLabels.colUpperCustName, 
										:clsfrmCustLabels.tblCustLabels.colCustName'
								!
								Set sSQLRefreshHandle = ' SELECT 
										  CstLblation.User_Id, 
										  CstLblation.Sys_Date_Time, 
										  CstLblation.Stock_Item_No, 
										  CstLblation.Year_Of_Sale,
										  Stock_Item.Variety_Type, 
										  @UPPER( Stock_Item.Variety ), 
										  @UPPER( Stock_Item.Cult_Desc ), 
										  @UPPER( Stock_Item.Root_Desc ), 
										  Stock_Item.Tree_Type_Desc, 
										  Stock_Item.Cult_Desc, 
										  Stock_Item.Root_Desc, 
										  CstLblation.Contract_Price, 
										  CstLblation.Cust_No, 
										  @UPPER( Customer_Master.Cust_Name ), 
										  Customer_Master.Cust_Name  
										FROM 
										  CstLblation, 
										  Customer_Master, 
										  Stock_Item 
										WHERE 
										  CstLblation.User_Id = :1 AND 
										  CstLblation.Sys_Date_Time = :2 AND 
										  CstLblation.Cust_No = Customer_Master.Cust_No AND 
										  CstLblation.Stock_Item_No = Stock_Item.Item_No '
								Set sNAMERefreshHandle = 'REFCstLblS'
								Set sBINDRefreshHandle = ':clsfrmCustLabels.tblCustLabels.colCstLblUserId, :clsfrmCustLabels.tblCustLabels.colCstLblSysDT'
								Set sINTORefreshHandle = ':clsfrmCustLabels.tblCustLabels.colCstLblUserId, 
										:clsfrmCustLabels.tblCustLabels.colCstLblSysDT, 
										:clsfrmCustLabels.tblCustLabels.colCstLblItemNo, 
										:clsfrmCustLabels.tblCustLabels.colCstLblYearOfSale, 
										:clsfrmCustLabels.tblCustLabels.colVarietyType, 
										:clsfrmCustLabels.tblCustLabels.colUpperVariety, 
										:clsfrmCustLabels.tblCustLabels.colUpperCultDesc, 
										:clsfrmCustLabels.tblCustLabels.colUpperRootDesc, 
										:clsfrmCustLabels.tblCustLabels.colTreeTypeDesc, 
										:clsfrmCustLabels.tblCustLabels.colCultDesc,
										:clsfrmCustLabels.tblCustLabels.colRootDesc, 
										:clsfrmCustLabels.tblCustLabels.colCstLblContPrice, 
										:clsfrmCustLabels.tblCustLabels.colCstLblCustNo, 
										:clsfrmCustLabels.tblCustLabels.colUpperCustName, 
										:clsfrmCustLabels.tblCustLabels.colCustName'
								!
								Set sSQLInsertHandle = ' INSERT INTO CstLblation 
										( 
										  User_Id, 
										  Sys_Date_Time, 
										  Cust_No, 
										  Stock_Item_No, 
										  Year_Of_Sale,
										  Contract_Price 
										) VALUES ( :1, :2, :3, :4, :5, :6 ) '
								Set sNAMEInsertHandle = 'INSCstLblS'
								Set sBINDInsertHandle = ':clsfrmCustLabels.tblCustLabels.colCstLblUserId, 
										:clsfrmCustLabels.tblCustLabels.colCstLblSysDT, 
										:clsfrmCustLabels.tblCustLabels.colCstLblCustNo, 
										:clsfrmCustLabels.tblCustLabels.colCstLblItemNo, 
										:clsfrmCustLabels.tblCustLabels.colCstLblYearOfSale, 
										:clsfrmCustLabels.tblCustLabels.colCstLblContPrice'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE CstLblation 
										SET 
										  Cust_No = :3, 
										  Stock_Item_No = :4, 
										  Year_Of_Sale = :5,
										  Contract_Price = :6
										WHERE 
										  CstLblation.User_Id = :1 AND 
										  CstLblation.Sys_Date_Time = :2 '
								Set sNAMEUpdateHandle = 'UPDTCstLblS'
								Set sBINDUpdateHandle = ':clsfrmCustLabels.tblCustLabels.colCstLblUserId, 
										:clsfrmCustLabels.tblCustLabels.colCstLblSysDT, 
										:clsfrmCustLabels.tblCustLabels.colCstLblCustNo, 
										:clsfrmCustLabels.tblCustLabels.colCstLblItemNo, 
										:clsfrmCustLabels.tblCustLabels.colCstLblYearOfSale, 
										:clsfrmCustLabels.tblCustLabels.colCstLblContPrice'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = ' DELETE FROM CstLblation 
										WHERE 
										  CstLblation.User_Id = :1 AND 
										  CstLblation.Sys_Date_Time = :2 '
								Set sNAMEDeleteHandle = 'DELCstLblS'
								Set sBINDDeleteHandle = ':clsfrmCustLabels.tblCustLabels.colCstLblUserId, :clsfrmCustLabels.tblCustLabels.colCstLblSysDT'
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								Set bQueryAllowed = TRUE
								Set bReportAllowed = FALSE
								Set bOrderAllowed = TRUE
								!
								Set sQueryDialogName = 'dlgQCstLblations'
								!
								Set sRootDesc = ''
								Set sCultDesc = ''
								Set sTreeTypeDesc = ''
								Set nItemNo = NUMBER_Null
								Set nYear = NUMBER_Null
								Set sBusName = ''
								Set sCustName = ''
								Set nCustNo = NUMBER_Null
							On SAM_Destroy
								Call CheckYearItemExists( 0, 0, bExists, sTmp, SH_cls_Disconnect )
								Call CountSpecificCstLblas( 0, 0, 0, nCount, SH_cls_Disconnect )
								Call CustNoExists( 0, SH_cls_Disconnect)
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
							!
							On PAM_clsTBL_POPFIELDS
								Call PopString( sRootDesc, FALSE )
								Call PopString( sCultDesc, FALSE )
								Call PopString( sTreeTypeDesc, FALSE )
								Call PopNumber( nItemNo, FALSE )
								Call PopNumber( nYear, FALSE )
								Call PopString( sBusName, FALSE )
								Call PopString( sCustName, FALSE )
								Call PopNumber( nCustNo, FALSE )
								Return TRUE
							On PAM_clsTBL_PUSHFIELDS
								Call PushNumber( nCustNo )
								Call PushString( sCustName )
								Call PushString( sBusName )
								Call PushNumber( nYear )
								Call PushNumber( nItemNo )
								Call PushString( sTreeTypeDesc )
								Call PushString( sCultDesc )
								Call PushString( sRootDesc )
								Return TRUE

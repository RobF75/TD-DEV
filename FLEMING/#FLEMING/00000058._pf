					String: sAccountsUsers
				Actions
					Set sAccountsUsers = OurGetIniFileParameter( 'ACCOUNTS', 'AccountsUsers', '' )
					Return ValidateUserRightsList( sAccountsUsers, sUserId, bNotify )

												SH_cls_Execute )
											Return TRUE
							Return GetBusAddressPrivateFunction( nCustNo,
									dtAddressDT,
									sAddrType,
									sAddressLine1,
									sAddressLine2,
									sSuburb,
									sPostcode,
									sState,
									sCountry,
									sAreaCode,
									sPhoneNo,
									sAreaCodeFax,
									sFaxNo,
									sComments,
									sMeetId,

		Named Menus
		Internal Functions
			Function: GetCustBusNames
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Receive String: sCustName
					Receive String: sBusName
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSqlHandle
					String: sBindHandle
					String: sIntoHandle
					String: sNameHandle
					Number: nOurHandleNo
					Number: nInd
					String: sGotCustName
					String: sGotBusName
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETCUSTBUSNAME' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSqlHandle = " SELECT
									  Cust_Name, 
									  Bus_Name
									FROM
									  Customer_Master
									WHERE
									  Cust_No = :1 "
							Set sNameHandle = 'GETCUSTBUSNAME'
							Set sBindHandle = ':nCustNo'
							Set sIntoHandle = ':sGotCustName, :sGotBusName'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSqlHandle, sNameHandle, sBindHandle, sIntoHandle )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set sCustName = ''
							Set sBusName = ''
							Set sGotCustName = ''
							Set sGotBusName = ''
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set sCustName = sGotCustName
									Set sBusName = sGotBusName
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: GetCustTypeAndDefDelType2
				Description: Given a customer number this function returns the customer_type
						and the second receive parameter classifies GC for Garden Centers
						OR for orchadists and the third parameter returns the customers
						Default delivery type
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Receive String: sCustType
					Receive String: sGCOR
					Receive String: sDefDelType
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Number: nInd
					!
					String: sGotCustType
					String: sGotDefDelType
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETCUSTDELTYPES' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = "  SELECT Customer_Type, Def_Deliv_Type 
									FROM Customer_Master 
									WHERE Cust_No = :1 "
							Set sName = 'GETCUSTDELTYPES'
							Set sBind = ':nCustNo'
							Set sInto = ':sGotCustType, :sGotDefDelType'
							!
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set sCustType = ''
							Set sGotCustType = ''
							Set sGCOR = ''
							Set sDefDelType = ''
							Set sGotDefDelType = ''
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set sCustType = sGotCustType
									Set sDefDelType = sGotDefDelType
									If ( SalStrScan( sCustType, 'OR%' ) >= 0 ) OR ( sCustType = 'NOR' )
										Set sGCOR = 'OR'
									Else
										Set sGCOR = 'GC'
									Return TRUE
								Else
									Return FALSE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: GetShipAddress
				Description: Given a customer number this function returns the customer_type
						and the second receive parameter classifies GC for Garden Centers
						OR for orchadists and the third parameter returns the customers
						Default delivery type
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Number: nYear
					Receive Date/Time: dtAddressDT
					Receive String: sAddrType
					Receive String: sAddressLine1
					Receive String: sAddressLine2
					Receive String: sSuburb
					Receive String: sPostcode
					Receive String: sState
					Receive String: sCountry
					Receive String: sAreaCode
					Receive String: sPhoneNo
					Receive String: sAreaCodeFax
					Receive String: sFaxNo
					Receive String: sComments
					Receive String: sMeetId
					Receive String: sMainAddressFlag
					Receive Boolean: bPickUpAddress
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcOurConfAmtHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSqlHandle
					String: sBindHandle
					String: sIntoHandle
					String: sNameHandle
					!
					Number: nOurHandleNo
					Number: nOurConfAmtHandleNo
					String: sSqlConfAmtHandle
					String: sBindConfAmtHandle
					String: sIntoConfAmtHandle
					String: sNameConfAmtHandle
					!
					Date/Time: dtGotAddressDT
					String: sGotAddressType
					String: sGotAddressLine1
					String: sGotAddressLine2
					String: sGotSuburb
					String: sGotPostcode
					String: sGotState
					String: sGotCountry
					String: sGotAreaCode
					String: sGotPhoneNo
					String: sGotAreaCodeFax
					String: sGotFaxNo
					String: sGotComments
					String: sGotMeetId
					String: sGotMainAddressFlag
					!
					Number: nInd
					!
					String: sAddressType
					String: sCustType
					String: sGCOR
					String: sDefDelType
					Boolean: bStopFetch
					Boolean: bAfterConfirmations
					Number: nSumConfAmt
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETSHIPADDRS' )
					Set nOurConfAmtHandleNo = SqlHandlesGetReferenceNo( 'CUSTTOTCONF' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSqlHandle = " SELECT 
									Add_Added_DT, 
									Address_Type, 
									Address_1, 
									Address_2,
									Suburb,
									Postcode,
									State,
									Country,
									Area_Code,
									Phone_No,
									Area_Code_Fax,
									Fax_No,
									Comments,
									Address_Meet_Id,
									Main_Address_Flag 
									FROM Customer_Address 
									WHERE Cust_No = :1 AND Address_Type = :2 "
							Set sNameHandle = 'GETSHIPADDRS'
							Set sBindHandle = ':nCustNo, :sAddressType'
							Set sIntoHandle = ':dtGotAddressDT, :sGotAddressType, :sGotAddressLine1, :sGotAddressLine2, :sGotSuburb, :sGotPostcode,:sGotState, 
									:sGotCountry, :sGotAreaCode, :sGotPhoneNo, :sGotAreaCodeFax, :sGotFaxNo, :sGotComments, 
									:sGotMeetId, :sGotMainAddressFlag'
							!
							Set sSqlConfAmtHandle = " SELECT Sum(Conf_Amt) 
									FROM Customer_Order 
									WHERE Cust_No = :1 AND Year_Of_Sale = :2 "
							Set sNameConfAmtHandle = 'CUSTTOTCONF'
							Set sBindConfAmtHandle = ':nCustNo, :nYear'
							Set sIntoConfAmtHandle = ':nSumConfAmt'
							!
							Call haSqlHandles[ nOurHandleNo ].Setup( sSqlHandle, sNameHandle, sBindHandle, sIntoHandle )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Call haSqlHandles[ nOurConfAmtHandleNo ].Setup( sSqlConfAmtHandle, sNameConfAmtHandle, sBindConfAmtHandle, sIntoConfAmtHandle )
							Call SqlVarSetup( haSqlHandles[ nOurConfAmtHandleNo ].hSqlHandle )
							!
							Set sCustType = ''
							Set sGCOR = ''
							Set sDefDelType = ''
							!
							Set dtAddressDT = DATETIME_Null
							Set sAddressType = ''
							Set sAddressLine1 = ''
							Set sAddressLine2 = ''
							Set sSuburb = ''
							Set sPostcode = ''
							Set sState = ''
							Set sCountry = ''
							Set sAreaCode = ''
							Set sPhoneNo = ''
							Set sAreaCodeFax = ''
							Set sFaxNo = ''
							Set sComments = ''
							Set sMeetId = ''
							Set sMainAddressFlag = ''
							!
							Set dtGotAddressDT = DATETIME_Null
							Set sGotAddressType = ''
							Set sGotAddressLine1 = ''
							Set sGotAddressLine2 = ''
							Set sGotSuburb = ''
							Set sGotPostcode = ''
							Set sGotState = ''
							Set sGotCountry = ''
							Set sGotAreaCode = ''
							Set sGotPhoneNo = ''
							Set sGotAreaCodeFax = ''
							Set sGotFaxNo = ''
							Set sGotComments = ''
							Set sGotMeetId = ''
							Set sGotMainAddressFlag = ''
							!
							Set bPickUpAddress = FALSE
							Call GetCustTypeAndDefDelType2( nCustNo, sCustType, sGCOR, sDefDelType, SH_cls_Execute )
							If sGCOR = 'GC'
								Set sAddressType = 'SHIP'
								Set bStopFetch = FALSE
								Set nInd = FETCH_EOF
								While nInd != FETCH_Ok AND NOT bStopFetch
									If haSqlHandles[ nOurHandleNo ].Execute( )
										If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
											Set dtAddressDT = dtGotAddressDT
											Set sAddrType = sGotAddressType
											Set sAddressLine1 = sGotAddressLine1
											Set sAddressLine2 = sGotAddressLine2
											Set sSuburb = sGotSuburb
											Set sPostcode = sGotPostcode
											Set sState = sGotState
											Set sCountry = sGotCountry
											Set sAreaCode = sGotAreaCode
											Set sPhoneNo = sGotPhoneNo
											Set sAreaCodeFax = sGotAreaCodeFax
											Set sFaxNo = sGotFaxNo
											Set sComments = sGotComments
											Set sMeetId = sGotMeetId
											Set sMainAddressFlag = sGotMainAddressFlag
											Return TRUE
										Else If sAddressType = 'SHIP'
											Set sAddressType = 'BUS'
										Else If sAddressType = 'BUS'
											Return TRUE
										Else
											Return TRUE
									Else
										Set bStopFetch = TRUE
										Return FALSE
							Else
								If sDefDelType = 'PICKUP'
									Set bPickUpAddress = TRUE
									Return TRUE
								!
								If haSqlHandles[ nOurConfAmtHandleNo ].Execute( )
									If haSqlHandles[ nOurConfAmtHandleNo ].FetchNext( nInd )
										Set bAfterConfirmations = TRUE
									Else
										Set bAfterConfirmations = FALSE
									!
									If sDefDelType = 'DELIVER'
										Set sAddressType = 'SHIP'
										Set bStopFetch = FALSE
										Set nInd = FETCH_EOF
										While nInd != FETCH_Ok AND NOT bStopFetch
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set dtAddressDT = dtGotAddressDT
													Set sAddrType = sGotAddressType
													Set sAddressLine1 = sGotAddressLine1
													Set sAddressLine2 = sGotAddressLine2
													Set sSuburb = sGotSuburb
													Set sPostcode = sGotPostcode
													Set sState = sGotState
													Set sCountry = sGotCountry
													Set sAreaCode = sGotAreaCode
													Set sPhoneNo = sGotPhoneNo
													Set sAreaCodeFax = sGotAreaCodeFax
													Set sFaxNo = sGotFaxNo
													Set sComments = sGotComments
													Set sMeetId = sGotMeetId
													Set sMainAddressFlag = sGotMainAddressFlag
													Return TRUE
												Else If sAddressType = 'SHIP'
													Set sAddressType = 'BUS'
												Else If sAddressType = 'BUS'
													If bAfterConfirmations
														If nSumConfAmt < MINOrdersForDelivery
															Set sAddressType = 'MEET'
														Else
															Return TRUE
													Else
														! The next line was added and the return uncommented
														! Set sAddressType = 'MEET'
														Return TRUE
												Else If sAddressType = 'MEET'
													Return TRUE
												Else
													Return TRUE
											Else
												Set bStopFetch = TRUE
												Return FALSE
									Else If sDefDelType = 'GROUP' 
										! Else is for GROUP DefDelType
										Set sAddressType = 'MEET'
										Set bStopFetch = FALSE
										Set nInd = FETCH_EOF
										While nInd != FETCH_Ok AND NOT bStopFetch
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set dtAddressDT = dtGotAddressDT
													Set sAddrType = sGotAddressType
													Set sAddressLine1 = sGotAddressLine1
													Set sAddressLine2 = sGotAddressLine2
													Set sSuburb = sGotSuburb
													Set sPostcode = sGotPostcode
													Set sState = sGotState
													Set sCountry = sGotCountry
													Set sAreaCode = sGotAreaCode
													Set sPhoneNo = sGotPhoneNo
													Set sAreaCodeFax = sGotAreaCodeFax
													Set sFaxNo = sGotFaxNo
													Set sComments = sGotComments
													Set sMeetId = sGotMeetId
													Set sMainAddressFlag = sGotMainAddressFlag
													Return TRUE
												Else If sAddressType = 'MEET'
													If bAfterConfirmations
														If nSumConfAmt >= MINOrdersForDelivery
															Set sAddressType = 'SHIP'
														Else
															Return TRUE
													Else
														! The next line was added and the return uncommented
														! Set sAddressType = 'SHIP'
														Return TRUE
												Else If sAddressType = 'SHIP'
													Set sAddressType = 'BUS'
												Else If sAddressType = 'BUS'
													Return TRUE
												Else
													Return TRUE
											Else
												Set bStopFetch = TRUE
												Return FALSE
									Else
										! Else is for Blank DefDelType
										If bAfterConfirmations AND nSumConfAmt >= MINOrdersForDelivery
											Set sAddressType = 'SHIP'
											Set bStopFetch = FALSE
											Set nInd = FETCH_EOF
											While nInd != FETCH_Ok AND NOT bStopFetch
												If haSqlHandles[ nOurHandleNo ].Execute( )
													If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
														Set dtAddressDT = dtGotAddressDT
														Set sAddrType = sGotAddressType
														Set sAddressLine1 = sGotAddressLine1
														Set sAddressLine2 = sGotAddressLine2
														Set sSuburb = sGotSuburb
														Set sPostcode = sGotPostcode
														Set sState = sGotState
														Set sCountry = sGotCountry
														Set sAreaCode = sGotAreaCode
														Set sPhoneNo = sGotPhoneNo
														Set sAreaCodeFax = sGotAreaCodeFax
														Set sFaxNo = sGotFaxNo
														Set sComments = sGotComments
														Set sMeetId = sGotMeetId
														Set sMainAddressFlag = sGotMainAddressFlag
														Return TRUE
													Else If sAddressType = 'SHIP'
														Set sAddressType = 'BUS'
													Else If sAddressType = 'BUS'
														Set sAddressType = 'MEET'
													Else If sAddressType = 'MEET'
														Return TRUE
													Else
														Return TRUE
												Else
													Set bStopFetch = TRUE
													Return FALSE
										Else
											Set sAddressType = 'MEET'
											Set bStopFetch = FALSE
											Set nInd = FETCH_EOF
											While nInd != FETCH_Ok AND NOT bStopFetch
												If haSqlHandles[ nOurHandleNo ].Execute( )
													If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
														Set dtAddressDT = dtGotAddressDT
														Set sAddrType = sGotAddressType
														Set sAddressLine1 = sGotAddressLine1
														Set sAddressLine2 = sGotAddressLine2
														Set sSuburb = sGotSuburb
														Set sPostcode = sGotPostcode
														Set sState = sGotState
														Set sCountry = sGotCountry
														Set sAreaCode = sGotAreaCode
														Set sPhoneNo = sGotPhoneNo
														Set sAreaCodeFax = sGotAreaCodeFax
														Set sFaxNo = sGotFaxNo
														Set sComments = sGotComments
														Set sMeetId = sGotMeetId
														Set sMainAddressFlag = sGotMainAddressFlag
														Return TRUE
													Else If sAddressType = 'MEET'
														Return TRUE
													Else
														Return TRUE
												Else
													Set bStopFetch = TRUE
													Return FALSE
								Else
									Return FALSE
						Case SH_cls_Disconnect
							Call haSqlHandles[ nOurHandleNo ].Disconnect( )
							Call haSqlHandles[ nOurConfAmtHandleNo ].Disconnect( )
							Return TRUE
			! Care needs to be taken modifying the select statements is GetBusAddress and GetBusAddressPrivateFunction
					  as they are also declared and used with the same names in GetPostalAddress and GetPostalAddressPrivateFunction
			Function: GetBusAddress
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Receive Date/Time: dtAddressDT
					Receive String: sAddrType
					Receive String: sAddressLine1
					Receive String: sAddressLine2
					Receive String: sSuburb
					Receive String: sPostcode
					Receive String: sState
					Receive String: sCountry
					Receive String: sAreaCode
					Receive String: sPhoneNo
					Receive String: sAreaCodeFax
					Receive String: sFaxNo
					Receive String: sComments
					Receive String: sMeetId
					Receive String: sMainAddressFlag
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSqlHandle
					String: sBindHandle
					String: sIntoHandle
					String: sNameHandle
					Number: nOurHandleNo
					Number: nInd
					Number: nGotParentCustNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetBusAddressGETPARENTCSTNO' )
					Select Case nActionType
						Case SH_cls_Execute
							! if editing bellow sql statement NOTE that this exact name and statement is referenced in 
									GetMainAddress function so you must change both.
							Set sSqlHandle = " SELECT
									  Ass_Cust_No
									FROM
									  Customer_Master
									WHERE
									  Cust_No = :1 "
							Set sNameHandle = 'GETPARENTCSTNO'
							Set sBindHandle = ':nCustNo'
							Set sIntoHandle = ':nGotParentCustNo'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSqlHandle, sNameHandle, sBindHandle, sIntoHandle )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!

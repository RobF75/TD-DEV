			Function: GetMainAddressPrivateFunction
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Receive Date/Time: dtAddressDT
					Receive String: sAddrType
					Receive String: sAddressLine1
					Receive String: sAddressLine2
					Receive String: sSuburb
					Receive String: sPostcode
					Receive String: sState
					Receive String: sCountry
					Receive String: sAreaCode
					Receive String: sPhoneNo
					Receive String: sAreaCodeFax
					Receive String: sFaxNo
					Receive String: sComments
					Receive String: sMeetId
					String: sMainAddressFlag
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSqlHandle
					String: sBindHandle
					String: sIntoHandle
					String: sNameHandle
					!
					Number: nOurHandleNo
					Date/Time: dtGotAddressDT
					String: sGotAddrType
					String: sGotAddressLine1
					String: sGotAddressLine2
					String: sGotSuburb
					String: sGotPostcode
					String: sGotState
					String: sGotCountry
					String: sGotAreaCode
					String: sGotPhoneNo
					String: sGotAreaCodeFax
					String: sGotFaxNo
					String: sGotComments
					String: sGotMeetId
					String: sGotMainAddressFlag
					!
					Number: nInd
					Boolean: bOk
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetMainAddressPrivateFunctionGETMAINADDRS' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSqlHandle = " SELECT 
									Add_Added_DT, 
									Address_Type, 
									Address_1, 
									Address_2,
									Suburb,
									Postcode,
									State,
									Country,
									Area_Code,
									Phone_No,
									Area_Code_Fax,
									Fax_No,
									Comments,
									Address_Meet_Id
									FROM Customer_Address 
									WHERE Cust_No = :1 AND Main_Address_Flag = 'Y' "
							Set sNameHandle = 'GETMAINADDRS'
							Set sBindHandle = ':nCustNo'
							Set sIntoHandle = ':dtGotAddressDT, :sGotAddrType, :sGotAddressLine1, :sGotAddressLine2, :sGotSuburb, :sGotPostcode,:sGotState, 
									:sGotCountry, :sGotAreaCode, :sGotPhoneNo, :sGotAreaCodeFax, :sGotFaxNo, :sGotComments, 
									:sGotMeetId'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSqlHandle, sNameHandle, sBindHandle, sIntoHandle )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set dtAddressDT = DATETIME_Null
							Set sAddrType = ''
							Set sAddressLine1 = ''
							Set sAddressLine2 = ''
							Set sSuburb = ''
							Set sPostcode = ''
							Set sState = ''
							Set sCountry = ''
							Set sAreaCode = ''
							Set sPhoneNo = ''
							Set sAreaCodeFax = ''
							Set sFaxNo = ''
							Set sComments = ''
							Set sMeetId = ''
							Set sMainAddressFlag = ''
							!
							Set dtGotAddressDT = DATETIME_Null
							Set sGotAddrType = ''
							Set sGotAddressLine1 = ''
							Set sGotAddressLine2 = ''
							Set sGotSuburb = ''
							Set sGotPostcode = ''
							Set sGotState = ''
							Set sGotCountry = ''
							Set sGotAreaCode = ''
							Set sGotPhoneNo = ''
							Set sGotAreaCodeFax = ''
							Set sGotFaxNo = ''
							Set sGotComments = ''
							Set sGotMeetId = ''
							Set sGotMainAddressFlag = ''
							!
							Set bOk = FALSE
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set dtAddressDT = dtGotAddressDT
									Set sAddrType = sGotAddrType
									Set sAddressLine1 = sGotAddressLine1
									Set sAddressLine2 = sGotAddressLine2
									Set sSuburb = sGotSuburb
									Set sPostcode = sGotPostcode
									Set sState = sGotState
									Set sCountry = sGotCountry
									Set sAreaCode = sGotAreaCode
									Set sPhoneNo = sGotPhoneNo
									Set sAreaCodeFax = sGotAreaCodeFax
									Set sFaxNo = sGotFaxNo
									Set sComments = sGotComments
									Set sMeetId = sGotMeetId
									Set sMainAddressFlag = sGotMainAddressFlag
									Set bOk = TRUE
								Else
									Set bOk = FALSE
							Else
								Set bOk = FALSE
							!
							If bOk
								Return TRUE
							Else
								Return GetBusAddressPrivateFunction( nCustNo,
										dtAddressDT,
										sAddrType,
										sAddressLine1,
										sAddressLine2,
										sSuburb,
										sPostcode,
										sState,
										sCountry,
										sAreaCode,
										sPhoneNo,
										sAreaCodeFax,
										sFaxNo,
										sComments,
										sMeetId,
										sMainAddressFlag,
										SH_cls_Execute )
						Case SH_cls_Disconnect
							Call haSqlHandles[ nOurHandleNo ].Disconnect( )
							Call GetBusAddressPrivateFunction( 0,
									dtAddressDT,
									sAddrType,
									sAddressLine1,
									sAddressLine2,
									sSuburb,
									sPostcode,
									sState,
									sCountry,
									sAreaCode,
									sPhoneNo,
									sAreaCodeFax,
									sFaxNo,
									sComments,
									sMeetId,
									sMainAddressFlag,
									SH_cls_Disconnect )
							Return TRUE

				Local variables
					String: sSqlHandle
					String: sBindHandle
					String: sIntoHandle
					String: sNameHandle
					!
					Number: nOurHandleNo
					Number: nOurAnyHandleNo
					String: sSqlAnyHandle
					String: sBindAnyHandle
					String: sIntoAnyHandle
					String: sNameAnyHandle
					!
					Date/Time: dtGotAddressDT
					String: sGotAddressType
					String: sGotAddressLine1
					String: sGotAddressLine2
					String: sGotSuburb
					String: sGotPostcode
					String: sGotState
					String: sGotCountry
					String: sGotAreaCode
					String: sGotPhoneNo
					String: sGotAreaCodeFax
					String: sGotFaxNo
					String: sGotComments
					String: sGotMeetId
					String: sGotMainAddressFlag
					!
					Number: nInd
					!
					String: sAddressType
					Boolean: bStopFetch
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetBusAddressPrivateFunctionGETBUSADDRS' )
					Set nOurAnyHandleNo = SqlHandlesGetReferenceNo( 'GetBusAddressPrivateFunctionGETBUSANYADDRS' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSqlHandle = " SELECT 
									Add_Added_DT, 
									Address_Type, 
									Address_1, 
									Address_2,
									Suburb,
									Postcode,
									State,
									Country,
									Area_Code,
									Phone_No,
									Area_Code_Fax,
									Fax_No,
									Comments,
									Address_Meet_Id,
									Main_Address_Flag 
									FROM Customer_Address 
									WHERE Cust_No = :1 AND Address_Type = :2 "
							Set sNameHandle = 'GETBUSADDRS'
							Set sBindHandle = ':nCustNo, :sAddressType'
							Set sIntoHandle = ':dtGotAddressDT, :sGotAddressType, :sGotAddressLine1, :sGotAddressLine2, :sGotSuburb, :sGotPostcode,:sGotState, 
									:sGotCountry, :sGotAreaCode, :sGotPhoneNo, :sGotAreaCodeFax, :sGotFaxNo, :sGotComments, 
									:sGotMeetId, :sGotMainAddressFlag'
							!
							Set sSqlAnyHandle = " SELECT 
									Add_Added_DT, 
									Address_Type, 
									Address_1, 
									Address_2,
									Suburb,
									Postcode,
									State,
									Country,
									Area_Code,
									Phone_No,
									Area_Code_Fax,
									Fax_No,
									Comments,
									Address_Meet_Id,
									Main_Address_Flag 
									FROM Customer_Address 
									WHERE Cust_No = :1 "
							Set sNameAnyHandle = 'GETBUSANYADDRS'
							Set sBindAnyHandle = ':nCustNo'
							Set sIntoAnyHandle = ':dtGotAddressDT, :sGotAddressType, :sGotAddressLine1, :sGotAddressLine2, :sGotSuburb, :sGotPostcode,:sGotState, 
									:sGotCountry, :sGotAreaCode, :sGotPhoneNo, :sGotAreaCodeFax, :sGotFaxNo, :sGotComments, 
									:sGotMeetId, :sGotMainAddressFlag'
							!
							Set dtAddressDT = DATETIME_Null
							Set sAddressType = ''
							Set sAddressLine1 = ''
							Set sAddressLine2 = ''
							Set sSuburb = ''
							Set sPostcode = ''
							Set sState = ''
							Set sCountry = ''
							Set sAreaCode = ''
							Set sPhoneNo = ''
							Set sAreaCodeFax = ''
							Set sFaxNo = ''
							Set sComments = ''
							Set sMeetId = ''
							Set sMainAddressFlag = ''
							!
							Set dtGotAddressDT = DATETIME_Null
							Set sGotAddressType = ''
							Set sGotAddressLine1 = ''
							Set sGotAddressLine2 = ''
							Set sGotSuburb = ''
							Set sGotPostcode = ''
							Set sGotState = ''
							Set sGotCountry = ''
							Set sGotAreaCode = ''
							Set sGotPhoneNo = ''
							Set sGotAreaCodeFax = ''
							Set sGotFaxNo = ''
							Set sGotComments = ''
							Set sGotMeetId = ''
							Set sGotMainAddressFlag = ''
							!
							Call haSqlHandles[ nOurHandleNo ].Setup( sSqlHandle, sNameHandle, sBindHandle, sIntoHandle )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set sAddressType = 'BUS'
							Set bStopFetch = FALSE
							Set nInd = FETCH_EOF
							While nInd != FETCH_Ok AND NOT bStopFetch
								If haSqlHandles[ nOurHandleNo ].Execute( )
									If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
										Set dtAddressDT = dtGotAddressDT
										Set sAddrType = sGotAddressType
										Set sAddressLine1 = sGotAddressLine1
										Set sAddressLine2 = sGotAddressLine2
										Set sSuburb = sGotSuburb
										Set sPostcode = sGotPostcode
										Set sState = sGotState
										Set sCountry = sGotCountry
										Set sAreaCode = sGotAreaCode
										Set sPhoneNo = sGotPhoneNo
										Set sAreaCodeFax = sGotAreaCodeFax
										Set sFaxNo = sGotFaxNo
										Set sComments = sGotComments
										Set sMeetId = sGotMeetId
										Set sMainAddressFlag = sGotMainAddressFlag
										Return TRUE
									Else If sAddressType = 'BUS'
										Set sAddressType = 'POSTAL'
									Else If sAddressType = 'POSTAL'
										Set sAddressType = 'HOME'
									Else If sAddressType = 'HOME'
										Set sAddressType = 'SHIP'
									Else If sAddressType = 'SHIP'
										Set sAddressType = 'RAIL'
									Else If sAddressType = 'RAIL'
										Set sAddressType = 'ANY'
										Set bStopFetch = TRUE
								Else
									Set bStopFetch = TRUE
									Return FALSE
							!
							Call haSqlHandles[ nOurAnyHandleNo ].Setup( sSqlAnyHandle, sNameAnyHandle, sBindAnyHandle, sIntoAnyHandle )
							Call SqlVarSetup( haSqlHandles[ nOurAnyHandleNo ].hSqlHandle )
							!
							If bStopFetch AND sAddressType = 'ANY'
								If haSqlHandles[ nOurAnyHandleNo ].Execute( )
									Call haSqlHandles[ nOurAnyHandleNo ].FetchNext( nInd )
									!
									Set dtAddressDT = dtGotAddressDT
									Set sAddrType = sGotAddressType
									Set sAddressLine1 = sGotAddressLine1
									Set sAddressLine2 = sGotAddressLine2
									Set sSuburb = sGotSuburb
									Set sPostcode = sGotPostcode
									Set sState = sGotState
									Set sCountry = sGotCountry
									Set sAreaCode = sGotAreaCode
									Set sPhoneNo = sGotPhoneNo
									Set sAreaCodeFax = sGotAreaCodeFax
									Set sFaxNo = sGotFaxNo
									Set sComments = sGotComments
									Set sMeetId = sGotMeetId
									Set sMainAddressFlag = sGotMainAddressFlag
									Return TRUE
								Else
									Return FALSE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Call haSqlHandles[ nOurHandleNo ].Disconnect( )
							Call haSqlHandles[ nOurAnyHandleNo ].Disconnect( )
							Return TRUE

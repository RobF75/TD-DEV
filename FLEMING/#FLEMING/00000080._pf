			Function: GetMainContact
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Receive String: sContactTitle
					Receive String: sContactGivenName
					Receive String: sContactSurname
					Boolean: bForceOnlyMainContact
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					String: sGotContactTitle
					String: sGotContactGivenName
					String: sGotContactSurname
					String: sGotMainContactFlag
					!
					Number: nInd
					Boolean: bFound
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetMainContact' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Contact_Title, 
									  Contact_Given_Name, 
									  Contact_Surname, 
									  Main_Contact_Flag 
									FROM 
									  Customer_Contacts 
									WHERE 
									  Cust_No = :1 
									ORDER BY 
									  Main_Contact_Flag DESC "
							Set sName = 'GTCSTMAINCNTCT'
							Set sBind = ':nCustNo'
							Set sInto = ':sGotContactTitle, :sGotContactGivenName, :sGotContactSurname, :sGotMainContactFlag'
							!
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set sContactTitle = ''
							Set sContactGivenName = ''
							Set sContactSurname = ''
							!
							Set sGotContactTitle = ''
							Set sGotContactGivenName = ''
							Set sGotContactSurname = ''
							Set sGotMainContactFlag = ''
							Set bFound = FALSE
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								While haSqlHandles[ nOurHandleNo ].FetchNext( nInd ) AND NOT bFound
									If bForceOnlyMainContact
										If sGotMainContactFlag = 'Y'
											Set bFound = TRUE
										Else
											Set bFound = FALSE
									Else
										Set bFound = TRUE
									!
									If bFound
										Set sContactTitle = sGotContactTitle
										Set sContactGivenName = sGotContactGivenName
										Set sContactSurname = sGotContactSurname
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: FormatAttentionContactName
				Description:
				Returns
					String:
				Parameters
					String: sTitle
					String: sGivenName
					String: sSurname
				Static Variables
				Local variables
				Actions
					Return 'Attn: ' || SalStrTrimX( sTitle ) || ' ' || SalStrTrimX( sGivenName ) || ' ' || SalStrTrimX( sSurname )
			!
			Function: FixLineSpaceAddress
				Description: This function assumes that the variables passed in for all paramentes are strings of the 
						same length.  Even though the database columns are not, data can be fetched into variables
						of the same length.  This function will then remove any blank line ( ie null string ) by 
						suffling DOWN the parameters values.  Therefore the names of the parements will not
						necessaraly match the values.
				Returns
				Parameters
					String: sAttention
					String: sCustName
					String: sBusName
					String: sAddrL1
					String: sAddrL2
					String: sSuburb
					String: sState
					String: sPostcode
					Receive String: sAddressLine1
					Receive String: sAddressLine2
					Receive String: sAddressLine3
					Receive String: sAddressLine4
					Receive String: sAddressLine5
					Receive String: sAddressLine6
				Static Variables
					Number: nLine
				Local variables
					String: sField
					Number: nField
				Actions
					Set nField = 1
					Set sField = ''
					While sField = '' AND nField <= 6
						Set sField = NextField( sAttention, sCustName, sBusName, sAddrL1, sAddrL2, sSuburb, sState, sPostcode, nField )
						Set nField = nField + 1
					Set sAddressLine1 = sField
					!
					Set sField = ''
					While sField = '' AND nField <= 6
						Set sField = NextField( sAttention, sCustName, sBusName, sAddrL1, sAddrL2, sSuburb, sState, sPostcode, nField )
						Set nField = nField + 1
					Set sAddressLine2 = sField
					!
					Set sField = ''
					While sField = '' AND nField <= 6
						Set sField = NextField( sAttention, sCustName, sBusName, sAddrL1, sAddrL2, sSuburb, sState, sPostcode, nField )
						Set nField = nField + 1
					Set sAddressLine3 = sField
					!
					Set sField = ''
					While sField = '' AND nField <= 6
						Set sField = NextField( sAttention, sCustName, sBusName, sAddrL1, sAddrL2, sSuburb, sState, sPostcode, nField )
						Set nField = nField + 1
					Set sAddressLine4 = sField
					!
					Set sField = ''
					While sField = '' AND nField <= 6
						Set sField = NextField( sAttention, sCustName, sBusName, sAddrL1, sAddrL2, sSuburb, sState, sPostcode, nField )
						Set nField = nField + 1
					Set sAddressLine5 = sField
					!
					Set sField = ''
					While sField = '' AND nField <= 6
						Set sField = NextField( sAttention, sCustName, sBusName, sAddrL1, sAddrL2, sSuburb, sState, sPostcode, nField )
						Set nField = nField + 1
					Set sAddressLine6 = sField
			Function: NextField
				Description:
				Returns
					String:
				Parameters
					String: sAttention
					String: sCustName
					String: sBusName
					String: sAddrL1
					String: sAddrL2
					String: sSuburb
					String: sState
					String: sPostcode
					Number: nProcessingFieldNo
				Static Variables
				Local variables
				Actions
					Select Case nProcessingFieldNo
						Case 1
							Return sAttention
						Case 2
							Return sCustName
						Case 3
							Return sBusName
						Case 4
							Return sAddrL1
						Case 5
							Return sAddrL2
						Case 6
							Return sSuburb || '  ' || sState || '  ' || sPostcode
						Default
							Return ''
					! Select Case nProcessingFieldNo
						   Case 1
							   If sCustName = ''
								   Return sBusName
							   Else 
								   Return sCustName
						   Case 2
							   If sBusName = ''
								   Return sAddrL1
							   Else 
								   Return sBusName
						   Case 3
							   If sAddrL1 = ''
								   Return sAddrL2
							   Else 
								   Return sAddrL1
						   Case 4
							   If sAddrL2 = ''
								   Return sSuburb || ' ' || sState || ' ' || sPostcode
							   Else 
								   Return sAddrL2
						   Case 5
							   Return sSuburb || ' ' || sState || ' ' || sPostcode
						   Default 
							   Return ''
			Function: SwapSurnameWithFirstname
				Description:
				Returns
				Parameters
					Receive String: sCustName
				Static Variables
				Local variables
					Number: nCommaPos
					String: sCustLeftName
					String: sCustRightName
				Actions
					Set nCommaPos = SalStrScan( sCustName, ',' )
					If nCommaPos >= 0
						Call SalStrLeft( sCustName, nCommaPos, sCustLeftName )
						Call SalStrMid( sCustName, nCommaPos + 2, SalStrLength( sCustName ) - nCommaPos, sCustRightName )
						Set sCustName = sCustRightName || ' ' || sCustLeftName
			!
			! Function: FormatAddressToAddressLines
				   Description: 
				   Returns 
				   Parameters 
					   String: sCustName
					   String: sBusName
					   String: sAddrL1
					   String: sAddrL2
					   String: sSuburb
					   String: sState
					   String: sPostcode
					   Receive String: sAddressLine1
					   Receive String: sAddressLine2
					   Receive String: sAddressLine3
					   Receive String: sAddressLine4
					   Receive String: sAddressLine5
				   Static Variables 
				   Local variables 
					   String: sAddressLines[5]
					   String: sFormatedAddressLines[5]
					   Number: nAddrPos
					   Number: nFmtAddrPos
				   Actions 
					   Set sAddressLines[1] = sCustName
					   Set sAddressLines[2] = sBusName
					   Set sAddressLines[3] = sAddrL2
					   Set sAddressLines[4] = sAddrL1
					   Set sAddressLines[5] = sSuburb || ' ' || sState || ' ' || sPostcode
					!
					   Set sFormatedAddressLines[1] = ''
					   Set sFormatedAddressLines[2] = ''
					   Set sFormatedAddressLines[3] = ''
					   Set sFormatedAddressLines[4] = ''
					   Set sFormatedAddressLines[5] = ''
					!
					! Set nWorkPos = 1
					! While nWorkPos < 6
						   Set nPos = nWorkPos
						   While sAddressLines[ nPos ] = ''
							   While nPos < 6
								   Set sAddressLines[ nPos ] = sAddressLines[ nPos + 1 ]
								   Set nPos = nPos + 1
							   Set sAddressLines[ nPos ] = ''
						   Set nWorkPos = nWorkPos + 1
					!
					   Set nAddrPos = 1
					   Set nFmtAddrPos = 1
					   While nAddrPos <= 5
						   If sAddressLines[ nAddrPos ] != ''
							   Set sFormatedAddressLines[ nFmtAddrPos ] = sAddressLines[ nAddrPos ]
							   Set nFmtAddrPos = nFmtAddrPos + 1
						   Set nAddrPos = nAddrPos + 1
					!
					   Set sAddressLine1 = sFormatedAddressLines[1]
					   Set sAddressLine2 = sFormatedAddressLines[2]
					   Set sAddressLine3 = sFormatedAddressLines[3]
					   Set sAddressLine4 = sFormatedAddressLines[4]
					   Set sAddressLine5 = sFormatedAddressLines[5]
			!
			! Function: GetContactDetails
				   Description: 
				   Returns 
					   Boolean: 
				   Parameters 
					   Number: nCustNo
					   Receive String: sContactTitle
					   Receive String: sContactGivenName
					   Receive String: sContactSurname
					   Receive String: sContactWrkPhCode
					   Receive String: sContactWrkPh
					   Receive String: sContactAHPhCode
					   Receive String: sContactAHPh
					   Number: nActionType
				   Static Variables 
					   : fcOurHandle
					   : fcOurAnyHandle
				   Local variables 
					   String: sSql
					   String: sFuncName
					   Boolean: bOk
					   Number: nInd
					   String: sGotContactTitle
					   String: sGotContactGivenName
					   String: sGotContactSurname
					   String: sGotContactWrkPhCode
					   String: sGotContactWrkPh
					   String: sGotContactAHPhCode
					   String: sGotContactAHPh
				   Actions 
					   Select Case nActionType
						   Case nExecute
							   Loop Execute
								   Loop Connect
									   If NOT bHandleConnected
										   Set bHandleConnected = SqlConnect( hSqlHandle ) 
										   If bHandleConnected
											   Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
											   Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
											! Break Connect
										   Else 
											   If IDNO = SalMessageBox( 'Could not connect handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												   Break Connect
									   If bAnyHandleConnected
										   Break Connect
									   Else 
										   Set bAnyHandleConnected = SqlConnect( hSqlAnyHandle ) 
										   If bAnyHandleConnected
											   Call SqlSetLockTimeout( hSqlAnyHandle, SQLTIMEOUT )
											   Call SqlSetParameter( hSqlAnyHandle, DBP_PRESERVE, TRUE, ''  )
											   Break Connect
										   Else 
											   If IDNO = SalMessageBox( 'Could not connect handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												   Break Connect
								   Loop Prepare
									   If NOT bHandlePrepared
										   Set sSql = " SELECT Contact_Title, Contact_Given_Name, Contact_Surname, 
												  Wrk_Phone_Code, Contact_Work_Phone, AH_Phone_code, Contact_AH_Phone
												  FROM Customer_Contacts
												  INTO :sGotContactTitle, :sGotContactGivenName, :sGotContactSurname, 
												  :sGotContactWrkPhCode, :sGotContactWrkPh, :sGotContactAHPhCode, :sGotContactAHPh
												  WHERE Cust_No = :nCustNo AND MAIN_CONTACT_FLAG = 'Y' "
										   If SqlPrepare( hSqlHandle, sSql )
											   Set bHandlePrepared = TRUE
											! Break Prepare
										   Else 
											   Set bHandlePrepared = FALSE
											   If IDNO = SalMessageBox( 'Could not prepare handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												   Break Prepare
									   If bAnyHandlePrepared
										   Break Prepare
									   Else 
										   Set sSql = ' SELECT Contact_Title, Contact_Given_Name, Contact_Surname, 
												  Wrk_Phone_Code, Contact_Work_Phone, AH_Phone_code, Contact_AH_Phone
												  FROM Customer_Contacts
												  INTO :sGotContactTitle, :sGotContactGivenName, :sGotContactSurname, 
												  :sGotContactWrkPhCode, :sGotContactWrkPh, :sGotContactAHPhCode, :sGotContactAHPh
												  WHERE Cust_No = :nCustNo '
										   If SqlPrepare( hSqlAnyHandle, sSql )
											   Set bAnyHandlePrepared = TRUE
											   Break Prepare
										   Else 
											   Set bAnyHandlePrepared = FALSE
											   If IDNO = SalMessageBox( 'Could not prepare handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												   Break Prepare
								!
								   Set sGotContactTitle = ''
								   Set sGotContactGivenName = ''
								   Set sGotContactSurname = ''
								   Set sGotContactWrkPhCode = ''
								   Set sGotContactWrkPh = ''
								   Set sGotContactAHPhCode = ''
								   Set sGotContactAHPh = ''
								!
								   Set sContactTitle = ''
								   Set sContactGivenName = ''
								   Set sContactSurname = ''
								   Set sContactWrkPhCode = ''
								   Set sContactWrkPh = ''
								   Set sContactAHPhCode = ''
								   Set sContactAHPh = ''
								!
								   If SqlExecute( hSqlHandle )
									   If SqlFetchNext( hSqlHandle, nInd )
										   Set sContactTitle = sGotContactTitle
										   Set sContactGivenName = sGotContactGivenName
										   Set sContactSurname = sGotContactSurname
										   Set sContactWrkPhCode = sGotContactWrkPhCode
										   Set sContactWrkPh = sGotContactWrkPh
										   Set sContactAHPhCode = sGotContactAHPhCode
										   Set sContactAHPh = sGotContactAHPh
										   Return TRUE
									   Else 
										   If SqlExecute( hSqlAnyHandle )
											   Call SqlFetchNext( hSqlAnyHandle, nInd )
											   Set sContactTitle = sGotContactTitle
											   Set sContactGivenName = sGotContactGivenName
											   Set sContactSurname = sGotContactSurname
											   Set sContactWrkPhCode = sGotContactWrkPhCode
											   Set sContactWrkPh = sGotContactWrkPh
											   Set sContactAHPhCode = sGotContactAHPhCode
											   Set sContactAHPh = sGotContactAHPh
											   Return TRUE
										   Else 
											   Set bAnyHandlePrepared = FALSE
											   If IDNO = SalMessageBox( 'Could not execute ANY handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												   Return FALSE
								   Else 
									   Set bHandlePrepared = FALSE
									   If IDNO = SalMessageBox( 'Could not execute handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
										   Return FALSE
						   Case nDisconnect
							   Set bOk = TRUE
							   Loop Disconnect
								   If bHandleConnected
									   If SqlDisconnect( hSqlHandle )
										   Set bHandleConnected = FALSE
										   Set bHandlePrepared = FALSE
									   Else 
										   If IDNO = SalMessageBox( 'Could not disconnect handle in function '||sFuncName||'Contact programmers! RETRY?', 'Error', MB_YesNo )
											   Set bOk = FALSE
											   Break Disconnect
								   If bAnyHandleConnected
									   If SqlDisconnect( hSqlAnyHandle )
										   Set bAnyHandleConnected = FALSE
										   Set bAnyHandlePrepared = FALSE
										   Break Disconnect
									   Else 
										   If IDNO = SalMessageBox( 'Could not disconnect ANY handle in function '||sFuncName||'Contact programmers! RETRY?', 'Error', MB_YesNo )
											   Set bOk = FALSE
											   Break Disconnect
								   Else 
									   Break Disconnect
							   Return bOk
						   Case nRePrepare
							   Set bHandlePrepared = FALSE
							   Set bAnyHandlePrepared = FALSE
							   Return TRUE
					! Select Case nActionType
						   Case SH_cls_Execute
							   Set sSql = " SELECT Sold_Out_Flag 
									FROM Stock_Item_Sale 
									WHERE Stock_Item_No = :1 AND Year_Of_Sale = :2 "
							   Set sName = 'SISYREXISTS'
							   Set sBind = ':nItemNo, :nYear'
							   Set sInto = ':sGotSoldOutFlag'
							!
							   Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							   Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							   Set bExists = FALSE
							   Set sSoldOutFlag = ''
							   Set sGotSoldOutFlag = ''
							!
							   If fcOurHandle.Execute( )
								   If fcOurHandle.FetchNext( nInd )
									   Set bExists = TRUE
								   Else 
									   Set bExists = FALSE
								   Set sSoldOutFlag = sGotSoldOutFlag
								   Return TRUE
							   Else 
								   Return FALSE
						   Case SH_cls_Disconnect
							   Return fcOurHandle.Disconnect( )

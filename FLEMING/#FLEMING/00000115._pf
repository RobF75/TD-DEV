											  :frmPrintLabels.sBusName 
											WHERE 
											  Customer_Master.Cust_No " || sStateRange || " AND 
											  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
											  Customer_Master.Mailing_List_Flag = 'Y' AND 
											  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
											    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
											  ( Customer_Master.Bad_Debt_Flag = 'N' OR
											    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
											  ( Customer_Master.Closed_Account = 'N' OR 
											    Customer_Master.Closed_Account IS NULL ) 
											ORDER BY 1 "
							Else
								If sStateRange = ''
									Set sSql = " SELECT 
											  @UPPER( Customer_Master.Cust_Name ), 
											  Customer_Master.Cust_No, 
											  Customer_Master.Cust_Name, 
											  Customer_Master.Bus_Name 
											FROM Customer_Master 
											INTO 
											  :frmPrintLabels.sTmp, 
											  :frmPrintLabels.nCustNo, 
											  :frmPrintLabels.sCustName, 
											  :frmPrintLabels.sBusName 
											WHERE 
											  Customer_Master.Customer_Type LIKE " || sCustLikeType || " 
											ORDER BY 1 "
								Else
									Set sSql = " SELECT 
											  @UPPER( Customer_Master.Cust_Name ), 
											  Customer_Master.Cust_No, 
											  Customer_Master.Cust_Name, 
											  Customer_Master.Bus_Name 
											FROM Customer_Master 
											INTO 
											  :frmPrintLabels.sTmp, 
											  :frmPrintLabels.nCustNo, 
											  :frmPrintLabels.sCustName, 
											  :frmPrintLabels.sBusName 
											WHERE 
											  Customer_Master.Cust_No " || sStateRange || " AND 
											  Customer_Master.Customer_Type LIKE " || sCustLikeType || " 
											ORDER BY 1 "
				Else
					Call fcSelectionFile.Setup( sSelectionFileName, OF_Read | OF_Text, NUMBER_Null )
				!
				If sCustomerType = 'ORCHARDISTS' OR sCustomerType = 'GARDEN_CENTRES'
					If fcLabelHdl.PrepareSetup( sSql )
						If NOT fcLabelHdl.PrepareAndExecute( )
							Set bOk = FALSE
					Else
						Set bOk = FALSE
				Else
					If NOT fcSelectionFile.Open( )
						Set bOk = FALSE
				Return bOk
			On SAM_ReportFetchNext
				Loop
					Call ResetReportFields(  )
					If sCustomerType = 'SELECTED'
						If fcSelectionFile.Read( sFileString )
							If sSelectionType = 'CUSTOMER_MASTER'
								Set bValidCustomer = TRUE
								Set nCustNo = SalStrToNumber( sFileString )
								If bInforceSelectionCriteria
									Call GetCustBusNamesNSelectCriteria( nCustNo, sCustName, sBusName, bValidCustomer, SH_cls_Execute )
								Else
									Call GetCustBusNames( nCustNo, sCustName, sBusName, SH_cls_Execute )
								If bValidCustomer
									Call SwapSurnameWithFirstname( sCustName )
									!
									If bAttentionMainContact
										Call GetMainContact( nCustNo, sContactTitle, sContactGivenName, sContactSurname, TRUE, SH_cls_Execute )
										Set sAttention = FormatAttentionContactName( sContactTitle, sContactGivenName, sContactSurname )
									!
									If sAddressType = 'BUS'
										If bForceChildAddress
											Call GetBusAddressPrivateFunction( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
										Else
											Call GetBusAddress( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
										Call FixLineSpaceAddress( sAttention, sCustName, sBusName, sAddressL1BA, sAddressL2BA, sSuburbBA, sStateBA, sPostcodeBA, sAddressL1, sAddressL2, sAddressL3, sAddressL4, sAddressL5, sAddressL6 )
									Else If sAddressType = 'SHIP'
										Call GetShipAddress( nCustNo, nYear, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, bTmp, SH_cls_Execute )
										Call FixLineSpaceAddress( sAttention, sCustName, sBusName, sAddressL1BA, sAddressL2BA, sSuburbBA, sStateBA, sPostcodeBA, sAddressL1, sAddressL2, sAddressL3, sAddressL4, sAddressL5, sAddressL6 )
									Else If sAddressType = 'MAIN'
										If bForceChildAddress
											Call GetMainAddressPrivateFunction( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
										Else
											Call GetMainAddress( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
										Call FixLineSpaceAddress( sAttention, sCustName, sBusName, sAddressL1BA, sAddressL2BA, sSuburbBA, sStateBA, sPostcodeBA, sAddressL1, sAddressL2, sAddressL3, sAddressL4, sAddressL5, sAddressL6 )
									Else
										If bForceChildAddress
											Call GetPostalAddressPrivateFunction( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
										Else
											Call GetPostalAddress( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
										Call FixLineSpaceAddress( sAttention, sCustName, sBusName, sAddressL1BA, sAddressL2BA, sSuburbBA, sStateBA, sPostcodeBA, sAddressL1, sAddressL2, sAddressL3, sAddressL4, sAddressL5, sAddressL6 )
									!
									If bCSVFileOk
										Set bTmp = fcReprintCSVFile.Write( MakeCSVLine( ) )
									Return TRUE
							Else
								Set dtMailListTimeStamp = SalStrToDate( sFileString )
								Call GetMailListCustDetails( dtMailListTimeStamp, sCustName, sBusName, sAddressL1BA, sAddressL2BA, sSuburbBA, sStateBA, sPostcodeBA, SH_cls_Execute )
								Call FixLineSpaceAddress( sAttention, sCustName, sBusName, sAddressL1BA, sAddressL2BA, sSuburbBA, sStateBA, sPostcodeBA, sAddressL1, sAddressL2, sAddressL3, sAddressL4, sAddressL5, sAddressL6 )
								If bCSVFileOk
									Call fcReprintCSVFile.Write( MakeCSVLine( ) )
								Return TRUE
						Else
							Return FALSE
					Else
						If fcLabelHdl.FetchNext( nInd )
							Call SwapSurnameWithFirstname( sCustName )
							!
							If bAttentionMainContact
								Call GetMainContact( nCustNo, sContactTitle, sContactGivenName, sContactSurname, TRUE, SH_cls_Execute )
								Set sAttention = FormatAttentionContactName( sContactTitle, sContactGivenName, sContactSurname )
							!
							If sAddressType = 'BUS'
								If bForceChildAddress
									Call GetBusAddressPrivateFunction( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
								Else
									Call GetBusAddress( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
								Call FixLineSpaceAddress( sAttention, sCustName, sBusName, sAddressL1BA, sAddressL2BA, sSuburbBA, sStateBA, sPostcodeBA, sAddressL1, sAddressL2, sAddressL3, sAddressL4, sAddressL5, sAddressL6 )
							Else If sAddressType = 'SHIP'
								Call GetShipAddress( nCustNo, nYear, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, bTmp, SH_cls_Execute )
								Call FixLineSpaceAddress( sAttention, sCustName, sBusName, sAddressL1BA, sAddressL2BA, sSuburbBA, sStateBA, sPostcodeBA, sAddressL1, sAddressL2, sAddressL3, sAddressL4, sAddressL5, sAddressL6 )
							Else If sAddressType = 'MAIN'
								If bForceChildAddress
									Call GetMainAddressPrivateFunction( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
								Else
									Call GetMainAddress( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
								Call FixLineSpaceAddress( sAttention, sCustName, sBusName, sAddressL1BA, sAddressL2BA, sSuburbBA, sStateBA, sPostcodeBA, sAddressL1, sAddressL2, sAddressL3, sAddressL4, sAddressL5, sAddressL6 )
							Else
								If bForceChildAddress
									Call GetPostalAddressPrivateFunction( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
								Else
									Call GetPostalAddress( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
								Call FixLineSpaceAddress( sAttention, sCustName, sBusName, sAddressL1BA, sAddressL2BA, sSuburbBA, sStateBA, sPostcodeBA, sAddressL1, sAddressL2, sAddressL3, sAddressL4, sAddressL5, sAddressL6 )
							If bCSVFileOk
								Call fcReprintCSVFile.Write( MakeCSVLine( ) )
							Return TRUE
						Else
							Return FALSE
			On SAM_ReportFinish
				If sCustomerType = 'SELECTED'
					Call fcSelectionFile.Close( )
				If bCSVFileOk
					Call fcReprintCSVFile.Close( )
				Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )
			On SAM_Destroy
				Call GetCustBusNames( 0, sCustName, sBusName, SH_cls_Disconnect )
				Call GetCustBusNamesNSelectCriteria( 0, sCustName, sBusName, bValidCustomer, SH_cls_Disconnect )
				Call GetBusAddress( 0, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Disconnect )
				Call GetMainAddress( 0, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Disconnect )
				Call GetShipAddress( 0, 0, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, bTmp, SH_cls_Execute )
				Call GetMailListCustDetails( DATETIME_Null, sCustName, sBusName, sAddressL1BA, sAddressL2BA, sSuburbBA, sStateBA, sPostcodeBA, SH_cls_Disconnect )
				Call fcLabelHdl.Disconnect( )
				Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

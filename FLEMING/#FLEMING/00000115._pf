				Pushbutton: pbReport
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Prnt Lbl
					Window Location and Size
						Left:   4.45"
						Top:    0.0"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\LABELS.ICO
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_clsPB_CLICK
							! Set parameters here
							If rbPostalAddress
								Set sAddressTypes = 'POSTAL'
							Else If rbBusAddress
								Set sAddressTypes = 'BUS'
							Else
								Set sAddressTypes = 'SHIP'
							!
							If rbLaserPrinter
								Set sPrinterTypes = 'LASER'
							Else
								Set sPrinterTypes = 'IMPACT'
							!
							If rbSelectedPrior
								If rbCustomerMaster
									Set sSelectionType = 'CUSTOMER_MASTER'
								Else
									Set sSelectionType = 'MAILING_LIST'
								Set sCustomerTypes = 'SELECTED'
							Else If rbOrchardists
								Set sCustomerTypes = 'ORCHARDISTS'
							Else
								Set sCustomerTypes = 'GARDEN_CENTRES'
							!
							If rbAllStates
								Set sStates = 'ALL'
							Else If rbACT
								Set sStates = 'ACT'
							Else If rbNSW
								Set sStates = 'NSW'
							Else If rbNT
								Set sStates = 'NT'
							Else If rbQLD
								Set sStates = 'QLD'
							Else If rbSA
								Set sStates = 'SA'
							Else If rbTAS
								Set sStates = 'TAS'
							Else If rbVIC
								Set sStates = 'VIC'
							Else
								Set sStates = 'WA'
							!
							If cbCurrentYearsOrders
								Set sCurrentOrdersSelection = 'CURRENT_YEARS_ORDERS_PLACED'
							Else If cbNoCurrentYearsOrders
								Set sCurrentOrdersSelection = 'NO_CURRENT_YEARS_ORDERS_PLACED'
							Else
								Set sCurrentOrdersSelection = ''
							!
							Call SalCreateWindow( frmPrintLabels, hWndForm, 
									sAddressTypes, 
									sPrinterTypes, 
									sCustomerTypes, 
									sStates, 
									sCurrentOrdersSelection, 
									cbUseSelectionCriteria, 
									dfSelectedPriorFile, 
									sSelectionType, 
									ccSeasonYear.GetSeasonYear( ), 
									cbForceChildAddress, 
									cbAttentionMainContact, 
									dfSelectedOutputCSVFile )
						On PAM_ADDRLBLD_PRNTLABELS
							If wParam
								Return SalSendMsg( hWndItem, PAM_clsPB_ENABLE, 0, 0 )
							Else
								Return SalSendMsg( hWndItem, PAM_clsPB_DISABLE, 0, 0 )
				Pushbutton: pbPrintGCOrderForm
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbPrintGCOrderForm
					Property Template:
					Class DLL Name:
					Title:
					Window Location and Size
						Left:   5.05"
						Top:    0.0"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name:
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_cls_SETFIELDS
							Set bOk = TRUE
							Set pbPrintGCOrderForm.nYear = ccSeasonYear.GetSeasonYear( )
							!
							If rbCustomerMaster
								Set pbPrintGCOrderForm.sOrderFormSourceType = 'CUSTOMER_MASTER'
							Else
								Set pbPrintGCOrderForm.sOrderFormSourceType = 'MAILING_LIST'
							!
							If rbSelectedPrior
								If rbCustomerMaster
									Call ReadNumArrayListFromFile( dfSelectedPriorFile, pbPrintGCOrderForm.naCustNos )
								Else
									Call ReadDateTimeArrayListFromFile( dfSelectedPriorFile, pbPrintGCOrderForm.dtaMailListTimeStamps )
							Else
								Set sCustLikeType = "'%GC%'"
								!
								If rbNT
									Set sStateRange = ' BETWEEN 080000 AND 099999 '
								Else If rbNSW
									Set sStateRange = ' BETWEEN 200000 AND 299999 '
								Else If rbACT
									Set sStateRange = ' BETWEEN 200000 AND 299999 '
								Else If rbVIC
									Set sStateRange = ' BETWEEN 300000 AND 399999 '
								Else If rbQLD
									Set sStateRange = ' BETWEEN 400000 AND 499999 '
								Else If rbSA
									Set sStateRange = ' BETWEEN 500000 AND 599999 '
								Else If rbWA
									Set sStateRange = ' BETWEEN 600000 AND 699999 '
								Else If rbTAS
									Set sStateRange = ' BETWEEN 700000 AND 799999 '
								Else
									Set sStateRange = ''
								!
								If cbCurrentYearsOrders
									If cbUseSelectionCriteria
										If sStateRange = ''
											Set sSql = " SELECT 
													  @UPPER( Customer_Master.Cust_Name ), 
													  Customer_Master.Cust_No 
													FROM Customer_Master 
													INTO 
													  :frmUserOptions.sTmp, 
													  :frmUserOptions.pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] 
													WHERE 
													  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
													  Customer_Master.Mailing_List_Flag = 'Y' AND 
													  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
													    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
													  ( Customer_Master.Bad_Debt_Flag = 'N' OR
													    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
													  ( Customer_Master.Closed_Account = 'N' OR 
													    Customer_Master.Closed_Account IS NULL ) AND 
													  EXISTS ( SELECT 
													                    Customer_Order.Cust_No 
													                 FROM 
													                   Customer_Order 
													                 WHERE 
													                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
													                   Customer_Order.Year_Of_Sale = :frmPrintLabels.nYear AND 
													                   Customer_Order.Conf_Amt > 0 ) 
													ORDER BY 2 "
										Else
											Set sSql = " SELECT 
													  @UPPER( Customer_Master.Cust_Name ), 
													  Customer_Master.Cust_No 
													FROM Customer_Master 
													INTO 
													  :frmUserOptions.sTmp, 
													  :frmUserOptions.pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] 
													WHERE 
													  Customer_Master.Cust_No " || sStateRange || " AND 
													  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
													  Customer_Master.Mailing_List_Flag = 'Y' AND 
													  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
													    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
													  ( Customer_Master.Bad_Debt_Flag = 'N' OR
													    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
													  ( Customer_Master.Closed_Account = 'N' OR 
													    Customer_Master.Closed_Account IS NULL ) AND 
													  EXISTS ( SELECT 
													                    Customer_Order.Cust_No 
													                 FROM 
													                   Customer_Order 
													                 WHERE 
													                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
													                   Customer_Order.Year_Of_Sale = :frmPrintLabels.nYear AND 
													                   Customer_Order.Conf_Amt > 0 ) 
													ORDER BY 2 "
									Else
										If sStateRange = ''
											Set sSql = " SELECT 
													  @UPPER( Customer_Master.Cust_Name ), 
													  Customer_Master.Cust_No 
													FROM Customer_Master 
													INTO 
													  :frmUserOptions.sTmp, 
													  :frmUserOptions.pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] 
													WHERE 
													  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
													  EXISTS ( SELECT 
													                    Customer_Order.Cust_No 
													                 FROM 
													                   Customer_Order 
													                 WHERE 
													                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
													                   Customer_Order.Year_Of_Sale = :frmPrintLabels.nYear AND 
													                   Customer_Order.Conf_Amt > 0 ) 
													ORDER BY 2 "
										Else
											Set sSql = " SELECT 
													  @UPPER( Customer_Master.Cust_Name ), 
													  Customer_Master.Cust_No 
													FROM Customer_Master 
													INTO 
													  :frmUserOptions.sTmp, 
													  :frmUserOptions.pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] 
													WHERE 
													  Customer_Master.Cust_No " || sStateRange || " AND 
													  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
													  EXISTS ( SELECT 
													                    Customer_Order.Cust_No 
													                 FROM 
													                   Customer_Order 
													                 WHERE 
													                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
													                   Customer_Order.Year_Of_Sale = :frmPrintLabels.nYear AND 
													                   Customer_Order.Conf_Amt > 0 ) 
													ORDER BY 2 "
								If cbNoCurrentYearsOrders
									If cbUseSelectionCriteria
										If sStateRange = ''
											Set sSql = " SELECT 
													  @UPPER( Customer_Master.Cust_Name ), 
													  Customer_Master.Cust_No 
													FROM Customer_Master 
													INTO 
													  :frmUserOptions.sTmp, 
													  :frmUserOptions.pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] 
													WHERE 
													  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
													  Customer_Master.Mailing_List_Flag = 'Y' AND 
													  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
													    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
													  ( Customer_Master.Bad_Debt_Flag = 'N' OR
													    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
													  ( Customer_Master.Closed_Account = 'N' OR 
													    Customer_Master.Closed_Account IS NULL ) AND 
													  NOT EXISTS ( SELECT 
													                    Customer_Order.Cust_No 
													                 FROM 
													                   Customer_Order 
													                 WHERE 
													                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
													                   Customer_Order.Year_Of_Sale = :frmPrintLabels.nYear AND 
													                   Customer_Order.Conf_Amt > 0 ) 
													ORDER BY 2 "
										Else
											Set sSql = " SELECT 
													  @UPPER( Customer_Master.Cust_Name ), 
													  Customer_Master.Cust_No 
													FROM Customer_Master 
													INTO 
													  :frmUserOptions.sTmp, 
													  :frmUserOptions.pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] 
													WHERE 
													  Customer_Master.Cust_No " || sStateRange || " AND 
													  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
													  Customer_Master.Mailing_List_Flag = 'Y' AND 
													  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
													    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
													  ( Customer_Master.Bad_Debt_Flag = 'N' OR
													    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
													  ( Customer_Master.Closed_Account = 'N' OR 
													    Customer_Master.Closed_Account IS NULL ) AND 
													  NOT EXISTS ( SELECT 
													                    Customer_Order.Cust_No 
													                 FROM 
													                   Customer_Order 
													                 WHERE 
													                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
													                   Customer_Order.Year_Of_Sale = :frmPrintLabels.nYear AND 
													                   Customer_Order.Conf_Amt > 0 ) 
													ORDER BY 2 "
									Else
										If sStateRange = ''
											Set sSql = " SELECT 
													  @UPPER( Customer_Master.Cust_Name ), 
													  Customer_Master.Cust_No 
													FROM Customer_Master 
													INTO 
													  :frmUserOptions.sTmp, 
													  :frmUserOptions.pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] 
													WHERE 
													  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
													  NOT EXISTS ( SELECT 
													                    Customer_Order.Cust_No 
													                 FROM 
													                   Customer_Order 
													                 WHERE 
													                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
													                   Customer_Order.Year_Of_Sale = :frmPrintLabels.nYear AND 
													                   Customer_Order.Conf_Amt > 0 ) 
													ORDER BY 2 "
										Else
											Set sSql = " SELECT 
													  @UPPER( Customer_Master.Cust_Name ), 
													  Customer_Master.Cust_No 
													FROM Customer_Master 
													INTO 
													  :frmUserOptions.sTmp, 
													  :frmUserOptions.pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] 
													WHERE 
													  Customer_Master.Cust_No " || sStateRange || " AND 
													  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
													  NOT EXISTS ( SELECT 
													                    Customer_Order.Cust_No 
													                 FROM 
													                   Customer_Order 
													                 WHERE 
													                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
													                   Customer_Order.Year_Of_Sale = :frmPrintLabels.nYear AND 
													                   Customer_Order.Conf_Amt > 0 ) 
													ORDER BY 2 "
								Else
									If cbUseSelectionCriteria
										If sStateRange = ''
											Set sSql = " SELECT 
													  @UPPER( Customer_Master.Cust_Name ), 
													  Customer_Master.Cust_No 
													FROM Customer_Master 
													INTO 
													  :frmUserOptions.sTmp, 
													  :frmUserOptions.pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] 
													WHERE 
													  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
													  Customer_Master.Mailing_List_Flag = 'Y' AND 
													  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
													    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
													  ( Customer_Master.Bad_Debt_Flag = 'N' OR
													    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
													  ( Customer_Master.Closed_Account = 'N' OR 
													    Customer_Master.Closed_Account IS NULL ) 
													ORDER BY 2 "
										Else
											Set sSql = " SELECT 
													  @UPPER( Customer_Master.Cust_Name ), 
													  Customer_Master.Cust_No
													FROM Customer_Master 
													INTO 
													  :frmUserOptions.sTmp, 
													  :frmUserOptions.pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] 
													WHERE 
													  Customer_Master.Cust_No " || sStateRange || " AND 
													  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
													  Customer_Master.Mailing_List_Flag = 'Y' AND 
													  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
													    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
													  ( Customer_Master.Bad_Debt_Flag = 'N' OR
													    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
													  ( Customer_Master.Closed_Account = 'N' OR 
													    Customer_Master.Closed_Account IS NULL ) 
													ORDER BY 2 "
									Else
										If sStateRange = ''
											Set sSql = " SELECT 
													  @UPPER( Customer_Master.Cust_Name ), 
													  Customer_Master.Cust_No 
													FROM Customer_Master 
													INTO 
													  :frmUserOptions.sTmp, 
													  :frmUserOptions.pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] 
													WHERE 
													  Customer_Master.Customer_Type LIKE " || sCustLikeType || " 
													ORDER BY 2 "
										Else
											Set sSql = " SELECT 
													  @UPPER( Customer_Master.Cust_Name ), 
													  Customer_Master.Cust_No 
													FROM Customer_Master 
													INTO 
													  :frmUserOptions.sTmp, 
													  :frmUserOptions.pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] 
													WHERE 
													  Customer_Master.Cust_No " || sStateRange || " AND 
													  Customer_Master.Customer_Type LIKE " || sCustLikeType || " 
													ORDER BY 2 "
								!
								If fcOurHandle.PrepareSetup( sSql )
									If fcOurHandle.PrepareAndExecute( )
										Set pbPrintGCOrderForm.nPos = 0
										Set pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] = NUMBER_Null
										While fcOurHandle.FetchNext( nInd )
											Set pbPrintGCOrderForm.nPos = pbPrintGCOrderForm.nPos + 1
											Set pbPrintGCOrderForm.naCustNos[ pbPrintGCOrderForm.nPos ] = NUMBER_Null
									Else
										Set bOk = FALSE
								Else
									Set bOk = FALSE
							Return bOk
						On PAM_ADDRLBLD_PRNTLABELS
							If wParam
								Return SalSendMsg( hWndItem, PAM_clsPB_DISABLE, 0, 0 )
							Else
								Return SalSendMsg( hWndItem, PAM_clsPB_ENABLE, 2, 0 )

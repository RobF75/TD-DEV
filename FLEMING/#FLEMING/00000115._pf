		Application Actions
			On SAM_AppStartup
				! Set strArgArray[1] = 'STOCKDEV'
				! Set strArgArray[2] = 'JAN'
				! Set strArgArray[3] = 'JAN'
				! Set strArgArray[4] = 'C:\\TEMP\\DORMBUDCUST.TXT'
				! Set strArgArray[5] = 'CUSTOMER_MASTER'
				!
				If SalStrUpperX( SalStrRightX( strArgArray[0],3 ) ) = 'EXE'
					Set SqlDatabase = strArgArray[1]
					Set SqlUser = strArgArray[2]
					Set SqlPassword = strArgArray[3]
				Else
					Set SqlDatabase = 'STKLOCAL'
					Set SqlUser = 'JAN'
					Set SqlPassword = 'JAN'
				!
				! strArgArray[4] = sSelectionFileName = full path of string file of selection cust_no, or datetime_stamps
				! strArgArray[5] = sSelectionType = 'CUSTOMER_MASTER' OR 'MAILING_LIST'
				!
				Call CheckProgramExistance( 'Printing Address Labels', TRUE )
				!
				Call SqlHandlesSetup(  )
			On SAM_AppExit
				Call SqlHandlesDisconnectClose(  )

			Function: GetMailListCustDetails
				Description:
				Returns
					Boolean:
				Parameters
					Date/Time: dtMailListTimeStamp
					Receive String: sCustName
					Receive String: sBusName
					Receive String: sAddressL1
					Receive String: sAddressL2
					Receive String: sSuburb
					Receive String: sState
					Receive String: sPostcode
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSqlHandle
					String: sBindHandle
					String: sIntoHandle
					String: sNameHandle
					Number: nOurHandleNo
					Number: nInd
					String: sGotCustName
					String: sGotBusName
					String: sGotAddressL1
					String: sGotAddressL2
					String: sGotSuburb
					String: sGotState
					String: sGotPostcode
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETMLCSTDETS' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSqlHandle = " SELECT
									  Name, 
									  Bus_Name, 
									  Address_1, 
									  Address_2, 
									  Suburb, 
									  State, 
									  Postcode 
									FROM
									  Mailing_List
									WHERE
									  Time_Stamp = :1 "
							Set sNameHandle = 'GETMLCSTDETS'
							Set sBindHandle = ':dtMailListTimeStamp'
							Set sIntoHandle = ':sGotCustName, 
									:sGotBusName, 
									:sGotAddressL1, 
									:sGotAddressL2, 
									:sGotSuburb, 
									:sGotState, 
									:sGotPostcode'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSqlHandle, sNameHandle, sBindHandle, sIntoHandle )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set sCustName = ''
							Set sBusName = ''
							Set sAddressL1 = ''
							Set sAddressL2 = ''
							Set sSuburb = ''
							Set sState = ''
							Set sPostcode = ''
							Set sGotCustName = ''
							Set sGotBusName = ''
							Set sGotAddressL1 = ''
							Set sGotAddressL2 = ''
							Set sGotSuburb = ''
							Set sGotState = ''
							Set sGotPostcode = ''
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set sCustName = sGotCustName
									Set sBusName = sGotBusName
									Set sAddressL1 = sGotAddressL1
									Set sAddressL2 = sGotAddressL2
									Set sSuburb = sGotSuburb
									Set sState = sGotState
									Set sPostcode = sGotPostcode
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: GetCustBusNamesNSelectCriteria
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Receive String: sCustName
					Receive String: sBusName
					Receive Boolean: bValidCustomer
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSqlHandle
					String: sBindHandle
					String: sIntoHandle
					String: sNameHandle
					Number: nOurHandleNo
					Number: nInd
					String: sGotCustName
					String: sGotBusName
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETCSTDTSWCHKS' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSqlHandle = " SELECT
									  Cust_Name, 
									  Bus_Name
									FROM
									  Customer_Master
									WHERE
									  Cust_No = :1 AND 
									  Mailing_List_Flag = 'Y' AND 
									  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
									    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
									  ( Customer_Master.Bad_Debt_Flag = 'N' OR
									    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
									  ( Customer_Master.Closed_Account = 'N' OR 
									    Customer_Master.Closed_Account IS NULL ) "
							Set sNameHandle = 'GETCSTDTSWCHKS'
							Set sBindHandle = ':nCustNo'
							Set sIntoHandle = ':sGotCustName, :sGotBusName'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSqlHandle, sNameHandle, sBindHandle, sIntoHandle )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set sCustName = ''
							Set sBusName = ''
							Set sGotCustName = ''
							Set sGotBusName = ''
							Set bValidCustomer = TRUE
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set sCustName = sGotCustName
									Set sBusName = sGotBusName
								Else
									Set bValidCustomer = FALSE
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: MakeCSVLine
				Description:
				Returns
					String:
				Parameters
				Static Variables
				Local variables
				Actions
					Return '"' || sAddressL1 || '",' ||
							'"' || sAddressL2 || '",' ||
							'"' || sAddressL3 || '",' ||
							'"' || sAddressL4 || '",' ||
							'"' || sAddressL5 || '",' ||
							'"' || sAddressL6 || '",' ||
							SalNumberToStrX( nCustNo, 0 )
		Window Parameters
			! sAddressType = 'POSTAL' OR 'MAIN' OR 'BUS' OR 'SHIP'
			String: sAddressType
			! sPrinterType = 'IMPACT' OR 'LASER'
			String: sPrinterType
			! sCustomerType = 'SELECTED' OR 'ORCHARDISTS' OR 'GARDEN_CENTRES'
			String: sCustomerType
			! sState = 'ALL' OR 'ACT' OR 'NSW' OR 'NT' OR 'QLD' OR 'SA' OR 'TAS' OR 'VIC' OR 'WA'
			String: sState
			! sCurrentOrdersSelection = 'CURRENT_YEARS_ORDERS_PLACED' OR 'NO_CURRENT_YEARS_ORDERS_PLACED'
			String: sCurrentOrdersSelection
			Boolean: bInforceSelectionCriteria
			String: sSelectionFileName
			String: sSelectionType
			Number: nYear
			Boolean: bForceChildAddress
			Boolean: bAttentionMainContact
			String: sOutputCSVFileName
		Window Variables
			: fcLabelHdl
				Class: hcSqlHandle
			Number: nInd
			String: sSql
			Boolean: bOk
			String: sCustLikeType
			String: sStateRange
			: fcSelectionFile
				Class: clsStrFileHandle
			String: sTmp
			Date/Time: dtTmp
			Boolean: bTmp
			Boolean: bValidCustomer
			: fcReprintCSVFile
				Class: clsStrFileHandle
			Boolean: bCSVFileOk
			String: sContactTitle
			String: sContactGivenName
			String: sContactSurname
			!
			String: sFileString
			Date/Time: dtMailListTimeStamp
			Number: nCustNo
			String: sAttention
			String: sCustName
			String: sBusName
			String: sAddressL1BA
			String: sAddressL2BA
			String: sSuburbBA
			String: sStateBA
			String: sPostcodeBA
			!
			! Report Fields bellow
			String: sAddressL1
			String: sAddressL2
			String: sAddressL3
			String: sAddressL4
			String: sAddressL5
			String: sAddressL6
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				If sPrinterType = 'LASER'
					Call SalMessageBox( 'Please insert label sheets into the Laser Printer now.', 'Labels', MB_Ok )
					Set sReportFileNameNoPath = 'laserlb3.qrp'
				Else
					! Call SalMessageBox( 'Please check now, that the Impact label printer has user defined paper size of ( Width 1310 and Lenghth 1200 inches ) set.', 'Labels', MB_Ok )
					Set sReportFileNameNoPath = 'impctlb3.qrp'
				Set sReportBind = ':sAddressL1,
						:sAddressL2,
						:sAddressL3,
						:sAddressL4,
						:sAddressL5, 
						:sAddressL6, 
						:nCustNo'
				Set sReportInto = 'AddressLine1,
						AddressLine2,
						AddressLine3,
						AddressLine4,
						AddressLine5, 
						AddressLine6, 
						CustNo'
			On SAM_ReportStart
				Call fcReprintCSVFile.Setup( sOutputCSVFileName, NUMBER_Null, NUMBER_Null )
				If fcReprintCSVFile.Open( )
					Set bCSVFileOk = TRUE
				Else
					Set bCSVFileOk = FALSE
				Return TRUE
			On SAM_ReportFetchInit
				Set bOk = TRUE
				!
				If sCustomerType = 'ORCHARDISTS' OR sCustomerType = 'GARDEN_CENTRES'
					If sCustomerType = 'ORCHARDISTS'
						Set sCustLikeType = "'%OR%'"
					Else
						Set sCustLikeType = "'%GC%'"
					!
					If sState = 'NT'
						Set sStateRange = ' BETWEEN 080000 AND 099999 '
					Else If sState = 'NSW'
						Set sStateRange = ' BETWEEN 200000 AND 299999 '
					Else If sState = 'ACT'
						Set sStateRange = ' BETWEEN 200000 AND 299999 '
					Else If sState = 'VIC'
						Set sStateRange = ' BETWEEN 300000 AND 399999 '
					Else If sState = 'QLD'
						Set sStateRange = ' BETWEEN 400000 AND 499999 '
					Else If sState = 'SA'
						Set sStateRange = ' BETWEEN 500000 AND 599999 '
					Else If sState = 'WA'
						Set sStateRange = ' BETWEEN 600000 AND 699999 '
					Else If sState = 'TAS'
						Set sStateRange = ' BETWEEN 700000 AND 799999 '
					Else
						Set sStateRange = ''
					!
					If sAddressType = 'MAIN'
						If sCurrentOrdersSelection = 'CURRENT_YEARS_ORDERS_PLACED'
							If bInforceSelectionCriteria
								If sStateRange = ''
									Set sSql = " SELECT 
											  @UPPER( Customer_Master.Cust_Name ), 
											  Customer_Master.Cust_No, 
											  Customer_Master.Cust_Name, 
											  Customer_Master.Bus_Name, 
											  Customer_Address.Address_1, 
											  Customer_Address.Address_2, 
											  Customer_Address.Suburb, 
											  Customer_Address.State, 
											  Customer_Address.Postcode
											 FROM 
											  Customer_Master, 
											  Customer_Address 
											INTO 
											  :frmPrintLabels.sTmp, 
											  :frmPrintLabels.nCustNo, 
											  :frmPrintLabels.sCustName, 
											  :frmPrintLabels.sBusName, 
											  :frmPrintLabels.sAddressL1BA, 
											  :frmPrintLabels.sAddressL2BA, 
											  :frmPrintLabels.sSuburbBA, 
											  :frmPrintLabels.sStateBA, 
											  :frmPrintLabels.sPostcodeBA 
											WHERE 
											  Customer_Master.Cust_No = Customer_Address.Cust_No AND 
											  Customer_Address.Main_Address_Flag = 'Y' AND 
											  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
											  Customer_Master.Mailing_List_Flag = 'Y' AND 
											  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
											    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
											  ( Customer_Master.Bad_Debt_Flag = 'N' OR
											    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
											  ( Customer_Master.Closed_Account = 'N' OR 
											    Customer_Master.Closed_Account IS NULL ) AND 
											  EXISTS ( SELECT 
											                    Customer_Order.Cust_No 
											                 FROM 
											                   Customer_Order 
											                 WHERE 
											                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
											                   Customer_Order.Year_Of_Sale = :frmPrintLabels.nYear AND 
											                   Customer_Order.Conf_Amt > 0 ) 
											ORDER BY 1 "
								Else
									Set sSql = " SELECT 
											  @UPPER( Customer_Master.Cust_Name ), 
											  Customer_Master.Cust_No, 
											  Customer_Master.Cust_Name, 
											  Customer_Master.Bus_Name, 
											  Customer_Address.Address_1, 
											  Customer_Address.Address_2, 
											  Customer_Address.Suburb, 
											  Customer_Address.State, 
											  Customer_Address.Postcode
											 FROM 
											  Customer_Master, 
											  Customer_Address 
											INTO 
											  :frmPrintLabels.sTmp, 
											  :frmPrintLabels.nCustNo, 
											  :frmPrintLabels.sCustName, 
											  :frmPrintLabels.sBusName, 
											  :frmPrintLabels.sAddressL1BA, 
											  :frmPrintLabels.sAddressL2BA, 
											  :frmPrintLabels.sSuburbBA, 
											  :frmPrintLabels.sStateBA, 
											  :frmPrintLabels.sPostcodeBA 
											WHERE 
											  Customer_Master.Cust_No " || sStateRange || " AND 
											  Customer_Master.Cust_No = Customer_Address.Cust_No AND 
											  Customer_Address.Main_Address_Flag = 'Y' AND 
											  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
											  Customer_Master.Mailing_List_Flag = 'Y' AND 
											  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
											    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
											  ( Customer_Master.Bad_Debt_Flag = 'N' OR
											    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
											  ( Customer_Master.Closed_Account = 'N' OR 
											    Customer_Master.Closed_Account IS NULL ) AND 
											  EXISTS ( SELECT 
											                    Customer_Order.Cust_No 
											                 FROM 
											                   Customer_Order 
											                 WHERE 
											                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
											                   Customer_Order.Year_Of_Sale = :frmPrintLabels.nYear AND 
											                   Customer_Order.Conf_Amt > 0 ) 
											ORDER BY 1 "
							Else
								If sStateRange = ''
									Set sSql = " SELECT 
											  @UPPER( Customer_Master.Cust_Name ), 
											  Customer_Master.Cust_No, 
											  Customer_Master.Cust_Name, 
											  Customer_Master.Bus_Name, 
											  Customer_Address.Address_1, 
											  Customer_Address.Address_2, 
											  Customer_Address.Suburb, 
											  Customer_Address.State, 
											  Customer_Address.Postcode 
											FROM 
											  Customer_Master, 
											  Customer_Address 
											INTO 
											  :frmPrintLabels.sTmp, 
											  :frmPrintLabels.nCustNo, 
											  :frmPrintLabels.sCustName, 
											  :frmPrintLabels.sBusName, 
											  :frmPrintLabels.sAddressL1BA, 
											  :frmPrintLabels.sAddressL2BA, 
											  :frmPrintLabels.sSuburbBA, 
											  :frmPrintLabels.sStateBA, 
											  :frmPrintLabels.sPostcodeBA 
											WHERE 
											  Customer_Master.Cust_No = Customer_Address.Cust_No AND 
											  Customer_Address.Main_Address_Flag = 'Y' AND 
											  Customer_Master.Customer_Type LIKE " || sCustLikeType || " AND 
											  EXISTS ( SELECT 
											                    Customer_Order.Cust_No 
											                 FROM 
											                   Customer_Order 
											                 WHERE 
											                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
											                   Customer_Order.Year_Of_Sale = :frmPrintLabels.nYear AND 
											                   Customer_Order.Conf_Amt > 0 ) 
											ORDER BY 1 "
								Else
									Set sSql = " SELECT 
											  @UPPER( Customer_Master.Cust_Name ), 
											  Customer_Master.Cust_No, 
											  Customer_Master.Cust_Name, 
											  Customer_Master.Bus_Name, 
											  Customer_Address.Address_1, 
											  Customer_Address.Address_2, 
											  Customer_Address.Suburb, 
											  Customer_Address.State, 
											  Customer_Address.Postcode 
											FROM 
											  Customer_Master, 
											  Customer_Address 

		Functions
		Window Parameters
		Window Variables
			String: sAddressTypes
			String: sPrinterTypes
			String: sCustomerTypes
			String: sStates
			! String: sSelectionFileName
			String: sCurrentOrdersSelection
			String: sSelectionType

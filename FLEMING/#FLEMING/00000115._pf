			String: sTmp
			: fcOurHandle
				Class: hcSqlHandle
			Number: nInd
			String: sSql
			Boolean: bOk
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set dfSelectedPriorFile = strArgArray[4]
				Set sSelectionType = strArgArray[5]
				!
				! If sSelectionType = 'CUSTOMER_MASTER'
					     Set rbBusAddress = TRUE
				! Else
					     Set rbPostalAddress = TRUE
				Set rbLabels = TRUE
				Call SalSendMsg( rbLabels, PAM_clsRB_CLICK, TRUE, 0 )
				Set rbPostalAddress = TRUE
				If dfSelectedPriorFile = ''
					Set rbGardenCentres = TRUE
				Else
					Set rbSelectedPrior = TRUE
				Set rbAllStates = TRUE
				Set rbImpactPrinter = TRUE
				Set cbUseSelectionCriteria = TRUE
				!
				Call SalSendMsg( cbSelectedOutputCSVFile, PAM_clsCB_CLICK, FALSE, 0 )
				Set dfSelectedOutputCSVFile = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'c:\\temp' ) || '\\lbloutpt.csv'
			On SAM_CreateComplete
				If sSelectionType = 'CUSTOMER_MASTER'
					Set rbCustomerMaster = TRUE
					Call SalSendMsg( rbCustomerMaster, SAM_Click, 0, 0 )
				Else
					Set rbMailList = TRUE
					Call SalSendMsg( rbMailList, SAM_Click, 0, 0 )
				Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
			On SAM_Destroy
				Call fcOurHandle.Disconnect( )
				Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

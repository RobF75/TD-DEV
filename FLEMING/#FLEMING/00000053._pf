.head 4 +  Derived From
.head 5 -  Class: clspbStartProgram
.head 4 +  Class Variables
.head 5 -  Number: nPos
.head 4 +  Instance Variables
.head 5 -  ! PUBLIC
.head 5 -  ! both arrays bellow must be NULL terminated
.head 5 -  Number: naCustNos[*]
.head 5 -  Date/Time: dtaMailListTimeStamps[*]
.head 5 -  ! sOrderFormSourceType = 'CUSTOMER_MASTER' = default OR 'MAILING_LIST'
.head 5 -  String: sOrderFormSourceType
.head 5 -  ! nYear defaults to current season Year
.head 5 -  Number: nYear
.head 5 -  ! PRIVATE
.head 5 -  String: sStringListFileName
.head 4 -  Functions
.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Set nPos = 0
.head 6 -  Set naCustNos[ nPos ] = NUMBER_Null
.head 6 -  Set dtaMailListTimeStamps[ nPos ] = DATETIME_Null
.head 6 -  Set sOrderFormSourceType = 'CUSTOMER_MASTER'
.head 6 -  Set sStringListFileName = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', '' ) || '\\gcofrm.csv'
.head 6 -  Set nYear = WhichSeasonYear( SalDateCurrent(  ) )
.head 6 -  Return SalSendClassMessage( SAM_Create, wParam, lParam )
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set clspbPrintGCOrderForm.sLiveProgramSection = IniGeneralLiveSectionName
.head 6 -  Set clspbPrintGCOrderForm.sLiveProgramDescription = 'Print Garden Centre Order Forms'
.head 6 -  Set clspbPrintGCOrderForm.sLiveProgramTitle = 'PrintGCOrderForm'
.head 6 -  Set clspbPrintGCOrderForm.sPlayProgramSection = IniGeneralPlaySectionName
.head 6 -  Set clspbPrintGCOrderForm.sPlayProgramDescription = 'Print Garden Centre Order Forms'
.head 6 -  Set clspbPrintGCOrderForm.sPlayProgramTitle = 'PrintGCOrderForm'
.head 5 +  On PAM_clsPB_CLICK
.head 6 +  If SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
.head 7 +  If sOrderFormSourceType = 'CUSTOMER_MASTER'
.head 8 -  Call WriteNumArrayListToFile( sStringListFileName, naCustNos )
.head 7 +  Else
.head 8 -  Call WriteDateTimeArrayListToFile( sStringListFileName, dtaMailListTimeStamps )
.head 7 -  Set sExtraParameterCommandLine = sStringListFileName || ' ' || sOrderFormSourceType || ' ' || SalNumberToStrX( nYear, 0 )
.head 7 -  Return SalSendClassMessage( PAM_clsPB_CLICK, wParam, lParam )
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 -  ! TRAP PAM_cls_SETFIELDS to initialise selection arrays for each click of button and MAKE SURE
  to return TRUE for processing to continue

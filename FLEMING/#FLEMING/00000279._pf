							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_WHEREPOPULATE
								If sSelectedRegionIds = ''
									Set sBuildWhere = sPreBuildWhere||' AND CUSTOMER_MASTER.CUSTOMER_TYPE = CUSTOMER_TYPE.CUST_TYPE  '
								Else
									Set sBuildWhere = sPreBuildWhere||' AND CUSTOMER_MASTER.CUSTOMER_TYPE = CUSTOMER_TYPE.CUST_TYPE  AND 
											CUSTOMER_MASTER.REGION_ID IN ( ' || sSelectedRegionIds || ' ) '
								! Set sBuildWhere = " WHERE 
										   CUSTOMER_MASTER.CUSTOMER_TYPE = CUSTOMER_TYPE.CUST_TYPE AND 
										   CUSTOMER_MASTER.CUSTOMER_TYPE LIKE '%GC%' AND 
										   CUSTOMER_MASTER.CUST_NO BETWEEN 300000 AND 399999 AND 
										  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
										    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
										  ( Customer_Master.Bad_Debt_Flag = 'N' OR
										    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
										  ( Customer_Master.Closed_Account = 'N' OR 
										    Customer_Master.Closed_Account IS NULL ) "
					Column: colWhere5
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title:
						Visible? No

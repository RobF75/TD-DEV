				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					String: sSQLPOPTABLENAME
					String: sORDERBY
					String: sPreBuildWhere
					String: sQueryTmpStr
					String: sCurrentBuildWhere
				Message Actions
					On PAM_POPULATE
						Call PopString( sPreBuildWhere, TRUE )
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, 
								sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
						Call SalTblSetLockedColumns( hWndForm, 2 )
					On PAM_REPOPULATE
						Call TableRePopulate( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, 
								sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_SEARCH
						Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, 
								sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
						Call SalTblSetLockedColumns( hWndForm, 2 )
					On SAM_FetchRowDone
						If bPrintCustDets
							If NOT SalIsNull( colMeetId )
								Call GetMeetAddress( hWndForm, PAM_MEETADDRESS, nExecute )
					On PAM_RESET
						Call TableReset( hWndForm, colCustNo )
					On PAM_NOROWS
						If NOT bPrintCustDets
							Call SalMessageBox( 'No rows match the search criteria', 'Customer & Address Query', MB_Ok )
					On PAM_ENABLE
						If wParam
							Call SalShowWindow( hWndForm )
						Else
							Call SalHideWindow( hWndForm )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set sSQLPOPTABLENAME = ' CUSTOMER_MASTER, CUSTOMER_ADDRESS '
						Set sORDERBY = ' ORDER BY 2,1,6 '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
						Call GetMeetAddress( hWndForm, PAM_MEETADDRESS, nDisconnect )

					Message Actions
						On SAM_Click 
							Call SalHideWindow( hWndForm )
							Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
						On PAM_SETINSTANCEVARS
							Set pbExit.nAppearanceOnClick =nDisable
							Set pbExit.nAppearanceOnDisplayRec = nEnable
							Set pbExit.nAppearanceOnNewRec =nEnable

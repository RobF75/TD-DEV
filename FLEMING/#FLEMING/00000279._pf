								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					!
					Boolean: bSqlCurrSales
					Boolean: bSqlCurrSalesPrep
					Sql Handle: hSqlCurrSales
					!
					Boolean: bSqlHistSales
					Boolean: bSqlHistSalesPrep
					Sql Handle: hSqlHistSales
					!
					Number: nSumOrdAmt
					Number: nSumConfAmt
					String: sSQLPOPTABLENAME
					String: sSQLORCHTABLENAME
					String: sORDERBY
					String: sOrderByName
					Number: nWhichPopulate
					String: sPreBuildWhere
					String: sCurrentBuildWhere
				Message Actions
					On PAM_POPULATE
						Set nWhichPopulate = 1
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere1, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
					On PAM_POPULATE2
						! for NPAs
						Set nWhichPopulate = 2
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere2, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
					On PAM_POPULATE3
						! for Hail Damaged Letters
						Set nWhichPopulate = 3
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere3, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
					On PAM_POPULATE4
						! for Customer Details listing
						Set nWhichPopulate = 4
						If bgOrderByName
							Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere4, nSELECT, sSQLPOPTABLENAME, sOrderByName, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
						Else
							Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere4, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
					On PAM_POPULATE5
						! for Order Form master listing for customers who arent orchardists and have
								their mailist flag = Y 
						Set nWhichPopulate = 5
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere5, nSELECT, sSQLPOPTABLENAME, sOrderByName, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
					On PAM_POPULATE6
						! for ORCHARDISTS listing for customers AND Have
								their mailist flag = Y 
						Set nWhichPopulate = 6
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere6, nSELECT, sSQLORCHTABLENAME, sOrderByName, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
					On SAM_FetchRowDone
						If bPrintCustDets
							If NOT bSqlCurrSalesPrep
								If SqlPrepare( hSqlCurrSales, 'SELECT SUM(ORDERED_AMOUNT), SUM(CONF_AMT) FROM
										CUSTOMER_ORDER INTO :frmQCustomer.tblMaster.nSumOrdAmt, 
										:frmQCustomer.tblMaster.nSumConfAmt 
										 WHERE CUST_NO = :frmQCustomer.tblMaster.colCustNo
										AND YEAR_OF_SALE = :frmQCustomer.tblMaster.colYrForOrder'  )
									Set bSqlCurrSalesPrep = TRUE
							If NOT bSqlHistSalesPrep
								If SqlPrepare( hSqlHistSales, 'SELECT SUM(ORDERED_AMOUNT), SUM(CONF_AMT) FROM
										CUST_ORDER_HISTORY INTO :frmQCustomer.tblMaster.nSumOrdAmt, 
										:frmQCustomer.tblMaster.nSumConfAmt 
										 WHERE CUST_NO = :frmQCustomer.tblMaster.colCustNo
										AND YEAR_OF_SALE = :frmQCustomer.tblMaster.colYrForOrder'  )
									Set bSqlHistSalesPrep = TRUE
							!
							Set nSumOrdAmt = 0
							Set nSumConfAmt = 0
							Set frmQCustomer.tblMaster.colYrForOrder = 94
							If SqlExecute( hSqlHistSales )
								Call SqlFetchNext( hSqlHistSales, nInd )
								If nSumConfAmt > 0
									Set colPrev94 = nSumConfAmt 
								Else
									Set colPrev94 = nSumOrdAmt 
							!
							Set nSumOrdAmt = 0
							Set nSumConfAmt = 0
							Set frmQCustomer.tblMaster.colYrForOrder = 95
							If SqlExecute( hSqlHistSales )
								Call SqlFetchNext( hSqlHistSales, nInd )
								If nSumConfAmt > 0
									Set colPrev95 = nSumConfAmt 
								Else
									Set colPrev95 = nSumOrdAmt 
							!
							Set nSumOrdAmt = 0
							Set nSumConfAmt = 0
							Set frmQCustomer.tblMaster.colYrForOrder = 96
							If SqlExecute( hSqlHistSales )
								Call SqlFetchNext( hSqlHistSales, nInd )
								If nSumConfAmt > 0
									Set colPrev96 = nSumConfAmt 
								Else
									Set colPrev96 = nSumOrdAmt 
							!
							Set nSumOrdAmt = 0
							Set nSumConfAmt = 0
							Set frmQCustomer.tblMaster.colYrForOrder = 1997
							If SqlExecute( hSqlCurrSales )
								Call SqlFetchNext( hSqlCurrSales, nInd )
								If nSumConfAmt > 0
									Set colCurrSales = nSumConfAmt 
								Else
									Set colCurrSales = nSumOrdAmt 
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						!
						Set bSqlCurrSales = SqlConnect( hSqlCurrSales ) 
						If bSqlCurrSales
							Call SqlSetLockTimeout( hSqlCurrSales, SQLTIMEOUT )
							Call SqlSetParameter( hSqlCurrSales, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						!
						Set bSqlHistSales = SqlConnect( hSqlHistSales ) 
						If bSqlHistSales
							Call SqlSetLockTimeout( hSqlHistSales, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHistSales, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						!
						Set nWhichPopulate = 1
						Set sSQLPOPTABLENAME = ' CUSTOMER_MASTER, CUSTOMER_TYPE '
						Set sSQLORCHTABLENAME = ' CUSTOMER_MASTER '
						Set sORDERBY = ' ORDER BY CUSTOMER_MASTER.CUST_NO '
						Set sOrderByName = ' ORDER BY CUSTOMER_MASTER.CUST_NAME '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
						If bSqlCurrSales
							Call SqlDisconnect( hSqlCurrSales )
						If bSqlHistSales
							Call SqlDisconnect( hSqlHistSales )

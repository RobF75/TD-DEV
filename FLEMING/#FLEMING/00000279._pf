				!
				!
				String: CUSTOMER = 'CUSTOMER_MASTER'
				! String: CUSTTYPREG = 'CUSTOMER_MASTER,CUSTOMER_TYPE '
				String: CUSTTYPREGFCODES = ' CUSTOMER_MASTER, CUSTOMER_TYPE, REGION, FREIGHT_CODES'
				String: LOADTRANSP = ' LOAD, TRANSPORT_METHOD'
				String: OUTSTAND_DEPOSIT = ' OUTSTAND_DEPOSIT'
				String: CUSTPOSPOS = ' CUST_PROMO, PROMO'
				String: WHLOADTRANSP = ' WHERE LOAD.LOAD_ID = :frmOrders.tblOrder.colLoad AND
						TRANSPORT_METHOD.TRANSPORT_ID = LOAD.TRANSPORT_ID'
				String: REGION = 'REGION'
				! String: CMTML = 'CUSTOMER_MASTER, TRANSPORT_METHOD, LOAD'
				String: CANCELLATION = 'CUST_CANCELLATION'
				! denorm
				String: WHORDSUBPRINTPULL = ' WHERE STOCK_ITEM.ITEM_NO = 
						:frmOrders.tblOrder.colSubsItemNo'
				String: WHORDPOSPRINTINV = ' WHERE CUST_PROMO.CUST_NO = 
						:frmOrders.dfCustNo AND CUST_PROMO.PROMO_SENT_FLAG != \'Y\' 
						 AND CUST_PROMO.YEAR_OF_ORDER = :frmOrders.dfYr AND
						PROMO.PROMO_ID = CUST_PROMO.PROMO_ID'
				String: CM = ' CUSTOMER_MASTER '
				! String: WHERECMTML = ' WHERE  CUSTOMER_MASTER.CUST_NO  = :frmOrders.dfCustNo 
						AND LOAD.LOAD_ID IN (SELECT DISTINCT LOAD_ID FROM LOAD_CUSTOMERS
						WHERE CUST_NO = :frmOrders.dfCustNo) AND
						LOAD.TRANSPORT_ID = TRANSPORT_METHOD.TRANSPORT_ID
						ORDER BY LOAD.SHIPPING_DATE '
				! DENORM
				String: SI = ' STOCK_ITEM'
				! String: CUSTNOTYPREG = ' WHERE CUST_NO = :hWndForm.dfCustNo AND
						 CUSTOMER_MASTER.CUSTOMER_TYPE = CUSTOMER_TYPE.CUST_TYPE'
				String: CUSTNOTYPREGFCODES = ' WHERE CUST_NO = :hWndForm.dfCustno AND
						 CUSTOMER_MASTER.CUSTOMER_TYPE = CUSTOMER_TYPE.CUST_TYPE
						 AND CUSTOMER_MASTER.REGION_ID = REGION.REGION_ID AND 
						 REGION.FREIGHT_CODE = FREIGHT_CODES.FREIGHT_CODE(+)'
				String: CUSTNO = ' WHERE CUST_NO = :hWndForm.dfCustno'
				String: ADDCUSTNO = ' WHERE CUST_NO = :dlgCustAdd.dfCustno'
				String: CONTCUSTNO = ' WHERE CUST_NO = :dlgCustCont.dfCustno'
				!
				String: CUSTORDROWIDORD = ' WHERE CUSTOMER_ORDER.ROWID = :frmOrders.tblOrder.colRowId'
				String: CUSTORDROWIDPOS = ' WHERE CUST_PROMO.ROWID = :frmOrders.tblOrder.colRowId'
				String: PROMO = ' PROMO '
				String: CNORD = ' WHERE CUSTOMER_ORDER.ROWID =
						 :hWndForm.dfRowId'
				String: ASSCUSTNO = ' WHERE CUST_NO = :hWndForm.dfAsscustno'
				String: ADDRESS = 'ADDRESS'
				String: CONTACT = 'CONTACT'
				! Help file names for forms and dialogs
				String: sFrmCustomerHelpFileName = 'g:\\apps\\gupta\\help\\customer.hlp'
				String: sFrmQCustContHelpFileName = 'g:\\apps\\gupta\\help\\qcstcont.hlp'
				String: sFrmOrdersHelpFileName = 'g:\\apps\\gupta\\help\\orders.hlp'
				String: sFrmOrdersDetsHelpFileName = 'g:\\apps\\gupta\\help\\orddets.hlp'

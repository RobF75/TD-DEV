				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					Sql Handle: hLocalSqlExtraTbl
					Boolean: bLocalSqlExtraTbl
					String: sSqlExtra
					Sql Handle: hSqlHdlRootDesc
					Boolean: bHdlRootDescConnected
					Boolean: bHdlRootDescPrepared
					Number: nInd
					String: sSQLPOPTABLENAME
					String: sORDERBY
					String: sCurrentBuildWhere
				Message Actions
					On PAM_POPULATE
						If bgPrintConfirmats
							Set ngAckYear = ngConfYear
						Set frmQCustomer.nNoNPAs = 0
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillAll, PAM_SQL )
					On SAM_FetchRowDone
						! If NOT SalIsNull( colRootId )
							      Call MyGetRootDesc( hSqlHdlRootDesc, bHdlRootDescConnected,
									 bHdlRootDescPrepared, 'frmQCustomer.tblOrd.colRootDesc',
									 'frmQCustomer.tblOrd.colRootNPAflag', 'frmQCustomer.tblOrd.colRootId' )
						If frmQCustomer.tblOrd.colRootNPAflag = 'Y' OR frmQCustomer.tblOrd.colCultNPAflag = 'Y'
							If frmQCustomer.tblOrd.colNPARcd = 'N'
								If frmQCustomer.tblOrd.colConfAmt > 0
									If frmQCustomer.tblOrd.colSaleCat != 'RP'
										Set frmQCustomer.tblOrd.colNPANeeded = 'Y'
										Set frmQCustomer.nNoNPAs = frmQCustomer.nNoNPAs + 1
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bLocalSqlExtraTbl = SqlConnect( hLocalSqlExtraTbl ) 
						If bLocalSqlExtraTbl
							Call SqlSetLockTimeout( hLocalSqlExtraTbl, SQLTIMEOUT )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bHdlRootDescConnected = FALSE
						Set bHdlRootDescPrepared = FALSE
						Set sSQLPOPTABLENAME = 'CUSTOMER_ORDER, STOCK_ITEM, CUSTOMER_TYPE, TREE_TYPE, CUSTOMER_MASTER '
						! Set sSQLPOPTABLENAME = 'CUSTOMER_ORDER, STOCK_ITEM, CULTIVAR, CUSTOMER_TYPE, TREE_TYPE, CUSTOMER_MASTER '
						Set sORDERBY = ' ORDER BY 1,2,6 '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
						If bLocalSqlExtraTbl
							Call SqlDisconnect( hLocalSqlExtraTbl )
						If bHdlRootDescConnected
							Call SqlDisconnect( hSqlHdlRootDesc )
			Pushbutton: pbHelp
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:

				Message Actions
					On SAM_Click
						Set sFilters[0] = 'CSV'
						Set sFilters[1] = '*.CSV'
						Set sFilters[2] = '*.*'
						Set sFilters[3] = '*.*'
						Call SalDlgSaveFile( hWndForm, 'CSV Mail File', sFilters, 4, nChosenFilter, dfCSVFileName, sCSVPath )
						! Call SalDlgOpenFile( hWndForm, 'CSV Mail File', sFilters, 4, nChosenFilter, dfCSVFileName, sCSVPath )
						Set dfCSVFileName = sCSVPath

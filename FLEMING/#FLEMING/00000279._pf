			Contents
				Pushbutton: pbGenerate
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Report
					Window Location and Size
						Left:   4.688"
						Top:    0.0"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: F7
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: G:\APPS\GUPTA\ICONS\LETTERS.ICO
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_CLICK
							If cbLabels
								Call SalMessageBox( 'Please task switch ( Alt Tab ), and make sure that printers settings are correct as bellow!', 'Warning', MB_Ok )
							If cbCSVFile AND SalIsNull( dfCSVFileName )
								Call SalMessageBox( 'Please enter a CSV File name first!', 'Warning', MB_Ok )
								Return FALSE
							!
							If rbSelectedPrior
								! Dataval and unselect any rows not matching conditions
								Set bFailedConditions = FALSE
								Call MyTableLoop( hWndTable, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Checking Selected Customers against conditions.', nLowToHi )
								If bFailedConditions
									If IDNO = SalMessageBox( 'One or More selected Customers do NOT match mail merge conditions! Continue?', 'Warning', MB_YesNo )
										Return FALSE
								If cbMainAddress
									Set sSql = " SELECT 
											  Customer_Master.Cust_No, 
											  Customer_Master.Cust_Name, 
											  Customer_Master.Bus_Name, 
											  Customer_Address.Address_1, 
											  Customer_Address.Address_2, 
											  Customer_Address.Suburb, 
											  Customer_Address.State, 
											  Customer_Address.Postcode 
											FROM 
											  Customer_Master, 
											  Customer_Address 
											INTO 
											  :dlgMailMerge.nCustNo, 
											  :dlgMailMerge.sCustName, 
											  :dlgMailMerge.sBusName, 
											  :dlgMailMerge.sAddLine1, 
											  :dlgMailMerge.sAddLine2, 
											  :dlgMailMerge.sSuburb, 
											  :dlgMailMerge.sState, 
											  :dlgMailMerge.sPostCode 
											WHERE 
											  Customer_Master.Cust_No = :dlgMailMerge.hWndTable.colCustNo AND 
											  Customer_Master.Cust_No = Customer_Address.Cust_No AND 
											  Customer_Address.Main_Address_Flag = 'Y' "
									If NOT fcMailMergeHdl.PrepareSetup( sSql )
										Return FALSE
							Else
								If rbOrchadists
									If cbMainAddress
										If cbCurrentYearOrders
											Set sSql = " SELECT DISTINCT 
													  Customer_Master.Cust_No, 
													  Customer_Master.Cust_Name, 
													  Customer_Master.Bus_Name, 
													  Customer_Address.Address_1, 
													  Customer_Address.Address_2, 
													  Customer_Address.Suburb, 
													  Customer_Address.State, 
													  Customer_Address.Postcode 
													FROM 
													  Customer_Master, 
													  Customer_Address
													INTO 
													  :dlgMailMerge.nCustNo, 
													  :dlgMailMerge.sCustName, 
													  :dlgMailMerge.sBusName, 
													  :dlgMailMerge.sAddLine1, 
													  :dlgMailMerge.sAddLine2, 
													  :dlgMailMerge.sSuburb, 
													  :dlgMailMerge.sState, 
													  :dlgMailMerge.sPostCode 
													WHERE 
													  Customer_Master.Cust_No = Customer_Address.Cust_No AND 
													  Customer_Address.Main_Address_Flag = 'Y' AND 
													  Customer_Master.Customer_Type LIKE '%OR%' AND 
													  Customer_Master.Mailing_List_Flag = 'Y' AND 
													  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
													    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
													  ( Customer_Master.Bad_Debt_Flag = 'N' OR
													    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
													  ( Customer_Master.Closed_Account = 'N' OR 
													    Customer_Master.Closed_Account IS NULL ) AND 
													  EXISTS ( SELECT 
													                    Customer_Order.Cust_No 
													                 FROM 
													                   Customer_Order 
													                 WHERE 
													                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
													                   Customer_Order.Year_Of_Sale = :dlgMailMerge.nYear AND 
													                  Customer_Order.Ordered_Amount > 0 ) 
													ORDER BY Customer_Master.Cust_Name "
										Else If cbNoCurrentYearOrders
											Set sSql = " SELECT DISTINCT 
													  Customer_Master.Cust_No, 
													  Customer_Master.Cust_Name, 
													  Customer_Master.Bus_Name, 
													  Customer_Address.Address_1, 
													  Customer_Address.Address_2, 
													  Customer_Address.Suburb, 
													  Customer_Address.State, 
													  Customer_Address.Postcode 
													FROM 
													  Customer_Master, 
													  Customer_Address
													INTO 
													  :dlgMailMerge.nCustNo, 
													  :dlgMailMerge.sCustName, 
													  :dlgMailMerge.sBusName, 
													  :dlgMailMerge.sAddLine1, 
													  :dlgMailMerge.sAddLine2, 
													  :dlgMailMerge.sSuburb, 
													  :dlgMailMerge.sState, 
													  :dlgMailMerge.sPostCode 
													WHERE 
													  Customer_Master.Cust_No = Customer_Address.Cust_No AND 
													  Customer_Address.Main_Address_Flag = 'Y' AND 
													  Customer_Master.Customer_Type LIKE '%OR%' AND 
													  Customer_Master.Mailing_List_Flag = 'Y' AND 
													  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
													    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
													  ( Customer_Master.Bad_Debt_Flag = 'N' OR
													    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
													  ( Customer_Master.Closed_Account = 'N' OR 
													    Customer_Master.Closed_Account IS NULL ) AND NOT
													  EXISTS ( SELECT 
													                    Customer_Order.Cust_No 
													                 FROM 
													                   Customer_Order 
													                 WHERE 
													                   Customer_Order.Cust_No = Customer_Master.Cust_No AND  
													                   Customer_Order.Year_Of_Sale = :dlgMailMerge.nYear AND 
													                  Customer_Order.Ordered_Amount > 0 ) 
													ORDER BY Customer_Master.Cust_Name "
										Else
											Set sSql = " SELECT 
													  Customer_Master.Cust_No, 
													  Customer_Master.Cust_Name, 
													  Customer_Master.Bus_Name, 
													  Customer_Address.Address_1, 
													  Customer_Address.Address_2, 
													  Customer_Address.Suburb, 
													  Customer_Address.State, 
													  Customer_Address.Postcode 
													FROM 
													  Customer_Master, 
													  Customer_Address 
													INTO 
													  :dlgMailMerge.nCustNo, 
													  :dlgMailMerge.sCustName, 
													  :dlgMailMerge.sBusName, 
													  :dlgMailMerge.sAddLine1, 
													  :dlgMailMerge.sAddLine2, 
													  :dlgMailMerge.sSuburb, 
													  :dlgMailMerge.sState, 
													  :dlgMailMerge.sPostCode 
													WHERE 
													  Customer_Master.Cust_No = Customer_Address.Cust_No AND 
													  Customer_Address.Main_Address_Flag = 'Y' AND 
													  Customer_Master.Customer_Type LIKE '%OR%' AND 
													  Customer_Master.Mailing_List_Flag = 'Y' AND 
													  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
													    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
													  ( Customer_Master.Bad_Debt_Flag = 'N' OR
													    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
													  ( Customer_Master.Closed_Account = 'N' OR 
													    Customer_Master.Closed_Account IS NULL ) 
													ORDER BY Customer_Master.Cust_Name "
									Else
										Set sSql = " SELECT 
												  Customer_Master.Cust_No, 
												  Customer_Master.Cust_Name, 
												  Customer_Master.Bus_Name 
												FROM 
												  Customer_Master 
												INTO 
												  :dlgMailMerge.nCustNo, 
												  :dlgMailMerge.sCustName, 
												  :dlgMailMerge.sBusName 
												WHERE 
												  Customer_Master.Customer_Type LIKE '%OR%' AND 
												  Customer_Master.Mailing_List_Flag = 'Y' AND 
												  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
												    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
												  ( Customer_Master.Bad_Debt_Flag = 'N' OR
												    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
												  ( Customer_Master.Closed_Account = 'N' OR 
												    Customer_Master.Closed_Account IS NULL ) 
												ORDER BY Customer_Master.Cust_Name "
								Else
									If cbMainAddress
										If cbCurrentYearOrders
											Set sSql = " SELECT DISTINCT 
													  Customer_Master.Cust_No, 
													  Customer_Master.Cust_Name, 
													  Customer_Master.Bus_Name, 
													  Customer_Address.Address_1, 
													  Customer_Address.Address_2, 
													  Customer_Address.Suburb, 
													  Customer_Address.State, 
													  Customer_Address.Postcode 
													FROM 
													  Customer_Master, 
													  Customer_Address
													INTO 
													  :dlgMailMerge.nCustNo, 
													  :dlgMailMerge.sCustName, 
													  :dlgMailMerge.sBusName, 
													  :dlgMailMerge.sAddLine1, 
													  :dlgMailMerge.sAddLine2, 
													  :dlgMailMerge.sSuburb, 
													  :dlgMailMerge.sState, 
													  :dlgMailMerge.sPostCode 
													WHERE 
													  Customer_Master.Cust_No = Customer_Address.Cust_No AND 
													  Customer_Address.Main_Address_Flag = 'Y' AND 
													  Customer_Master.Customer_Type LIKE '%GC%' AND 
													  Customer_Master.Mailing_List_Flag = 'Y' AND 
													  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
													    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
													  ( Customer_Master.Bad_Debt_Flag = 'N' OR
													    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
													  ( Customer_Master.Closed_Account = 'N' OR 
													    Customer_Master.Closed_Account IS NULL ) AND 
													  EXISTS ( SELECT 
													                    Customer_Order.Cust_No 
													                 FROM 
													                   Customer_Order 
													                 WHERE 
													                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
													                   Customer_Order.Year_Of_Sale = :dlgMailMerge.nYear AND 
													                  Customer_Order.Ordered_Amount > 0 ) 
													ORDER BY Customer_Master.Cust_Name "
										Else If cbNoCurrentYearOrders
											Set sSql = " SELECT DISTINCT 
													  Customer_Master.Cust_No, 
													  Customer_Master.Cust_Name, 
													  Customer_Master.Bus_Name, 
													  Customer_Address.Address_1, 
													  Customer_Address.Address_2, 
													  Customer_Address.Suburb, 
													  Customer_Address.State, 
													  Customer_Address.Postcode 
													FROM 
													  Customer_Master, 
													  Customer_Address
													INTO 
													  :dlgMailMerge.nCustNo, 
													  :dlgMailMerge.sCustName, 
													  :dlgMailMerge.sBusName, 
													  :dlgMailMerge.sAddLine1, 
													  :dlgMailMerge.sAddLine2, 
													  :dlgMailMerge.sSuburb, 
													  :dlgMailMerge.sState, 
													  :dlgMailMerge.sPostCode 
													WHERE 
													  Customer_Master.Cust_No = Customer_Address.Cust_No AND 
													  Customer_Address.Main_Address_Flag = 'Y' AND 
													  Customer_Master.Customer_Type LIKE '%GC%' AND 
													  Customer_Master.Mailing_List_Flag = 'Y' AND 
													  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
													    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
													  ( Customer_Master.Bad_Debt_Flag = 'N' OR
													    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
													  ( Customer_Master.Closed_Account = 'N' OR 
													    Customer_Master.Closed_Account IS NULL ) AND NOT 
													  EXISTS ( SELECT 
													                    Customer_Order.Cust_No 
													                 FROM 
													                   Customer_Order 
													                 WHERE 
													                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
													                   Customer_Order.Year_Of_Sale = :dlgMailMerge.nYear AND 
													                  Customer_Order.Ordered_Amount > 0 ) 
													ORDER BY Customer_Master.Cust_Name "
										Else
											Set sSql = " SELECT 
													  Customer_Master.Cust_No, 
													  Customer_Master.Cust_Name, 
													  Customer_Master.Bus_Name, 
													  Customer_Address.Address_1, 
													  Customer_Address.Address_2, 
													  Customer_Address.Suburb, 
													  Customer_Address.State, 
													  Customer_Address.Postcode 
													FROM 
													  Customer_Master, 
													  Customer_Address 
													INTO 
													  :dlgMailMerge.nCustNo, 
													  :dlgMailMerge.sCustName, 
													  :dlgMailMerge.sBusName, 
													  :dlgMailMerge.sAddLine1, 
													  :dlgMailMerge.sAddLine2, 
													  :dlgMailMerge.sSuburb, 
													  :dlgMailMerge.sState, 
													  :dlgMailMerge.sPostCode 
													WHERE 
													  Customer_Master.Cust_No = Customer_Address.Cust_No AND 
													  Customer_Address.Main_Address_Flag = 'Y' AND 
													  Customer_Master.Customer_Type LIKE '%GC%' AND 
													  Customer_Master.Mailing_List_Flag = 'Y' AND 
													  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
													    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
													  ( Customer_Master.Bad_Debt_Flag = 'N' OR
													    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
													  ( Customer_Master.Closed_Account = 'N' OR 
													    Customer_Master.Closed_Account IS NULL ) 
													ORDER BY Customer_Master.Cust_Name "
									Else
										Set sSql = " SELECT 
												  Customer_Master.Cust_No, 
												  Customer_Master.Cust_Name, 
												  Customer_Master.Bus_Name 
												FROM 
												  Customer_Master 
												INTO 
												  :dlgMailMerge.nCustNo, 
												  :dlgMailMerge.sCustName, 
												  :dlgMailMerge.sBusName 
												WHERE 
												  Customer_Master.Customer_Type LIKE '%GC%' AND 
												  Customer_Master.Mailing_List_Flag = 'Y' AND 
												  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
												    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
												  ( Customer_Master.Bad_Debt_Flag = 'N' OR
												    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
												  ( Customer_Master.Closed_Account = 'N' OR 
												    Customer_Master.Closed_Account IS NULL ) 
												ORDER BY Customer_Master.Cust_Name "
								If fcMailMergeHdl.PrepareSetup( sSql )
									If NOT fcMailMergeHdl.PrepareAndExecute( )
										Return FALSE
								Else
									Return FALSE
							If cbLabels
								Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\lbl.qrp'
								Set sReportBind = ':dlgMailMerge.sCustName, :dlgMailMerge.sAddLine1, :dlgMailMerge.sAddLine2, 
										:dlgMailMerge.sSuburb, :dlgMailMerge.sState, :dlgMailMerge.sPostCode'
								Set sReportInto = 'Cust_name, add1, add2, suburb, state, pcode'
								Set nReportError = 1
								Call SalReportPrint( hWndForm, sReportFileName, sReportBind, sReportInto, 1, RPT_PrintAll, 0, 0, nReportError )
								Return TRUE
							Else If cbCSVFile
								If SalSendMsg( hWndForm, SAM_ReportStart, 0, 0 ) 
									If SalSendMsg( hWndForm, SAM_ReportFetchInit, 0, 0 ) 
										Set bLoop = TRUE
										While bLoop
											Set bLoop = SalSendMsg( hWndForm, SAM_ReportFetchNext, 0, 0 ) 
										Call SalSendMsg( hWndForm, SAM_ReportFinish, 0, 0 ) 
										Return TRUE
									Else
										Return FALSE
								Else
									Return FALSE
							!
							If cbLabels
								Call SalMessageBox( 'Please task switch ( Alt Tab ), and make return your printer settings', 'Warning', MB_Ok )
						On PAM_SETINSTANCEVARS
							Set pbGenerate.nAppearanceOnClick =nDisable
							Set pbGenerate.nAppearanceOnDisplayRec = nEnable
							Set pbGenerate.nAppearanceOnNewRec =nEnable
						On PAM_ROWACTION
							Call CheckCustConditions( hWndTable.colCustNo, nYear, cbCurrentYearOrders, cbNoCurrentYearOrders, bOk, nExecute )
							If bOk
								Return TRUE
							Else
								Call SalTblSetRowFlags( hWndTable, lParam, ROW_Selected, FALSE )
								Set bFailedConditions = TRUE
								Return nRowDeleted
				Pushbutton: pbExit
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:

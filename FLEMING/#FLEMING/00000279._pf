								Set sBuildWhere = ' WHERE CUSTOMER_MASTER.CUSTOMER_TYPE = CUSTOMER_TYPE.CUST_TYPE AND ( CUSTOMER_TYPE.CUST_TYPE LIKE \'OR_\' OR CUSTOMER_TYPE.CUST_TYPE = \'NOR\' ) '
					Column: colWhere4
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title:
						Visible? No
						Editable? Yes
						Maximum Data Length: Default

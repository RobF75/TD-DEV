						List Values
						Message Actions
							On PAM_WHEREPOPULATE
								If frmQCustomer.bPrintAckments
									! denorm
									Set sBuildWhere = ' WHERE CUSTOMER_ORDER.CUST_NO = :frmQCustomer.tblMaster.colCustNo AND
											CUSTOMER_ORDER.YEAR_OF_SALE = :frmQCustomer.nYear AND
											CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
											CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO  AND
											CUSTOMER_MASTER.CUSTOMER_TYPE = CUSTOMER_TYPE.CUST_TYPE AND
											STOCK_ITEM.TREE_TYPE = TREE_TYPE.TREE_TYPE '
									! Set sBuildWhere = ' WHERE CUSTOMER_ORDER.CUST_NO = :frmQCustomer.tblMaster.colCustNo AND
											CUSTOMER_ORDER.YEAR_OF_SALE = :frmQCustomer.nYear AND
											CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
											CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND
											STOCK_ITEM.CULTIVAR_ID = CULTIVAR.CULT_ID(+) AND
											CUSTOMER_MASTER.CUSTOMER_TYPE = CUSTOMER_TYPE.CUST_TYPE AND
											STOCK_ITEM.TREE_TYPE = TREE_TYPE.TREE_TYPE '
								Else
									! denorm
									Set sBuildWhere = ' WHERE CUSTOMER_ORDER.CUST_NO = :frmQCustomer.tblMaster.colCustNo AND
											CUSTOMER_ORDER.YEAR_OF_SALE = :frmQCustomer.nYear AND
											CUSTOMER_ORDER.CONF_AMT > 0 AND 
											CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
											CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO  AND
											CUSTOMER_MASTER.CUSTOMER_TYPE = CUSTOMER_TYPE.CUST_TYPE AND
											STOCK_ITEM.TREE_TYPE = TREE_TYPE.TREE_TYPE '
									! Set sBuildWhere = ' WHERE CUSTOMER_ORDER.CUST_NO = :frmQCustomer.tblMaster.colCustNo AND
											CUSTOMER_ORDER.YEAR_OF_SALE = :frmQCustomer.nYear AND
											CUSTOMER_ORDER.CONF_AMT > 0 AND 
											CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
											CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND
											STOCK_ITEM.CULTIVAR_ID = CULTIVAR.CULT_ID(+) AND
											CUSTOMER_MASTER.CUSTOMER_TYPE = CUSTOMER_TYPE.CUST_TYPE AND
											STOCK_ITEM.TREE_TYPE = TREE_TYPE.TREE_TYPE '
					! colVariety needs to be the first column - if it is not change the order by in 
					Column: colVarietyType

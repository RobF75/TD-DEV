		Functions
			Function: CheckCustConditions
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Number: nYear
					Boolean: bCurrentYearOrders
					Boolean: bNoCurrentYearOrders
					Receive Boolean: bOk
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					Number: nInd
				Actions
					Select Case nActionType
						Case nExecute
							If bCurrentYearOrders
								Set sSql = " SELECT DISTINCT 
										  Customer_Master.Cust_No
										FROM 
										  Customer_Master 
										WHERE 
										  Customer_Master.Cust_No = :1 AND 
										  Customer_Master.Mailing_List_Flag = 'Y' AND 
										  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
										    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
										  ( Customer_Master.Bad_Debt_Flag = 'N' OR
										    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
										  ( Customer_Master.Closed_Account = 'N' OR 
										    Customer_Master.Closed_Account IS NULL ) AND 
										  EXISTS ( SELECT 
										                    Customer_Order.Cust_No 
										                 FROM 
										                   Customer_Order 
										                 WHERE 
										                   Customer_Order.Cust_No = Customer_Master.Cust_No AND 
										                   Customer_Order.Year_Of_Sale = :2 AND 
										                  Customer_Order.Ordered_Amount > 0 )"
								Set sName = 'CHCKMMRGCONDYR'
								Set sBind = ':nCustNo, :nYear'
								Set sInto = ''
							Else If bNoCurrentYearOrders
								Set sSql = " SELECT DISTINCT 
										  Customer_Master.Cust_No
										FROM 
										  Customer_Master 
										WHERE 
										  Customer_Master.Cust_No = :1 AND 
										  Customer_Master.Mailing_List_Flag = 'Y' AND 
										  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
										    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
										  ( Customer_Master.Bad_Debt_Flag = 'N' OR
										    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
										  ( Customer_Master.Closed_Account = 'N' OR 
										    Customer_Master.Closed_Account IS NULL ) AND NOT
										  EXISTS ( SELECT 
										                    Customer_Order.Cust_No 
										                 FROM 
										                   Customer_Order 
										                 WHERE 
										                   Customer_Order.Cust_No = Customer_Master.Cust_No AND
										                   Customer_Order.Year_Of_Sale = :2 AND 
										                  Customer_Order.Ordered_Amount > 0 )"
								Set sName = 'CHCKMMRGCONDYR'
								Set sBind = ':nCustNo, :nYear'
								Set sInto = ''
							Else
								Set sSql = " SELECT 
										  Customer_Master.Cust_No 
										FROM 
										  Customer_Master 
										WHERE 
										  Customer_Master.Cust_No = :1 AND 
										  Customer_Master.Mailing_List_Flag = 'Y' AND 
										  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
										    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
										  ( Customer_Master.Bad_Debt_Flag = 'N' OR
										    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
										  ( Customer_Master.Closed_Account = 'N' OR 
										    Customer_Master.Closed_Account IS NULL ) "
								Set sName = 'CHCKMMRGCONDYR'
								Set sBind = ':nCustNo'
								Set sInto = ''
							!
							Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							Set bOk = FALSE
							!
							If fcOurHandle.Execute( )
								If fcOurHandle.FetchNext( nInd )
									Set bOk = TRUE
								Else
									Set bOk = FALSE
								Return TRUE
							Else
								Return FALSE
						Case nDisconnect
							Return fcOurHandle.Disconnect( )
		Window Parameters
			Window Handle: hWndTable
		Window Variables
			String: sFilters[0:3]
			Number: nYear
			String: sCSVPath
			Number: nChosenFilter
			Boolean: bOk
			Boolean: bLoop
			Boolean: bFailedConditions
			String: sReportFileName
			String: sReportBind
			String: sReportInto
			Number: nReportError
			Number: nSelectedRow
			File Handle: hCSVFileHandle
			: fcMailMergeHdl
				Class: hcSqlHandle
			String: sTmp
			Date/Time: dtTmp
			Boolean: bPickUp
			String: sSql
			Number: nInd
			!
			Number: nCustNo
			String: sBusName
			String: sBusAddL1
			String: sBusAddL2
			String: sBusSuburb
			String: sBusPostcode
			String: sBusState
			String: sShipAddL1
			String: sShipAddL2
			String: sShipSuburb
			String: sShipPostcode
			String: sShipState
			! Label Fields
			String: sCustName
			String: sAddLine1
			String: sAddLine2
			String: sSuburb
			String: sState
			String: sPostCode
		Message Actions
			On SAM_CreateComplete
				Set cbLabels = TRUE
				Set cbMainAddress = TRUE
				Return SalSendMsg( hWndForm, PAM_CREATECOMPLETE, wParam, lParam )
			On PAM_CREATECOMPLETE
				Set nYear = OurDateYear( SalDateCurrent(  ) )
				Call SalShowWindow( hWndForm )
				Call SalBringWindowToTop( hWndForm )
				If SalTblAnyRows( hWndTable, ROW_Selected, 0 )
					Call SalEnableWindow( rbSelectedPrior )
					Set rbSelectedPrior = TRUE
				Else
					Call SalDisableWindow( rbSelectedPrior )
					Set rbSelectedPrior = FALSE
			On SAM_ReportStart
				Return TRUE
			On SAM_ReportFetchInit
				If rbSelectedPrior
					Set nSelectedRow = TBL_MinRow
				If cbCSVFile
					If cbCSVAppend
						If NOT SalFileOpen( hCSVFileHandle, dfCSVFileName, OF_Text | OF_Write | OF_Append )
							Call SalMessageBox( 'A problem has occoured opening your CSV File. Please try again!', 'Error', MB_Ok )
							Return FALSE
					Else
						If NOT SalFileOpen( hCSVFileHandle, dfCSVFileName, OF_Text | OF_Write | OF_Create )
							Call SalMessageBox( 'A problem has occoured opening your CSV File. Please try again!', 'Error', MB_Ok )
							Return FALSE
				Return TRUE
			On SAM_ReportFetchNext
				Set bOk = TRUE
				!
				Set nCustNo = NUMBER_Null
				Set sCustName = ''
				Set sBusName = ''
				Set sAddLine1 = ''
				Set sAddLine2 = ''
				Set sSuburb = ''
				Set sState = ''
				Set sPostCode = ''
				Set sBusAddL1 = ''
				Set sBusAddL2 = ''
				Set sBusSuburb = ''
				Set sBusState = ''
				Set sBusPostcode = ''
				Set sShipAddL1 = ''
				Set sShipAddL2 = ''
				Set sShipSuburb = ''
				Set sShipState = ''
				Set sShipPostcode = ''
				!
				If rbSelectedPrior
					If SalTblFindNextRow( hWndTable, nSelectedRow, ROW_Selected, 0 ) 
						Call SalTblFetchRow( hWndTable, nSelectedRow )
						If cbMainAddress
							If fcMailMergeHdl.PrepareAndExecute( )
								Call fcMailMergeHdl.FetchNext( nInd )
							Else
								Set bOk = FALSE
						Else
							Set nCustNo = hWndTable.colCustNo
							Set sCustName = hWndTable.colCustName
							Set sBusName = hWndTable.colBusName
							!
							If cbBusAddress
								Call GetBusAddress( nCustNo, dtTmp, sTmp, sBusAddL1, sBusAddL2, 
										sBusSuburb, sBusPostcode, sBusState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, 
										sTmp, nExecute )
							If cbShipAddress
								Call GetShipAddress( nCustNo, nYear, dtTmp, sTmp, sShipAddL1, sShipAddL2, 
										sShipSuburb, sShipPostcode, sShipState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, 
										sTmp, bPickUp, nExecute )
							!
							If cbLabels
								If cbBusAddress
									Set sAddLine1 = sBusAddL1
									Set sAddLine2 = sBusAddL2
									Set sSuburb = sBusSuburb
									Set sState = sBusState
									Set sPostCode = sBusPostcode
								Else
									Set sAddLine1 = sShipAddL1
									Set sAddLine2 = sShipAddL2
									Set sSuburb = sShipSuburb
									Set sState = sShipState
									Set sPostCode = sShipPostcode
					Else
						Set bOk = FALSE
				Else
					If cbMainAddress
						If NOT fcMailMergeHdl.FetchNext( nInd )
							Set bOk = FALSE
					Else
						If NOT fcMailMergeHdl.FetchNext( nInd )
							Set bOk = FALSE
						!
						If cbBusAddress
							Call GetBusAddress( nCustNo, dtTmp, sTmp, sBusAddL1, sBusAddL2, 
									sBusSuburb, sBusPostcode, sBusState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, 
									sTmp, nExecute )
						If cbShipAddress
							Call GetShipAddress( nCustNo, nYear, dtTmp, sTmp, sShipAddL1, sShipAddL2, 
									sShipSuburb, sShipPostcode, sShipState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, 
									sTmp, bPickUp, nExecute )
						!
						If cbLabels
							If cbBusAddress
								Set sAddLine1 = sBusAddL1
								Set sAddLine2 = sBusAddL2
								Set sSuburb = sBusSuburb
								Set sState = sBusState
								Set sPostCode = sBusPostcode
							Else
								Set sAddLine1 = sShipAddL1
								Set sAddLine2 = sShipAddL2
								Set sSuburb = sShipSuburb
								Set sState = sShipState
								Set sPostCode = sShipPostcode
				If cbCSVFile AND bOk
					If cbBusAddress AND cbShipAddress
						Set sTmp = SalNumberToStrX( nCustNo, 0 ) || ', ' || 
								'"' || sCustName || '", ' || 
								'"' || sBusName || '", ' || 
								'"' || sBusAddL1 || '", ' || 
								'"' || sBusAddL2 || '", ' || 
								'"' || sBusSuburb || '", ' || 
								'"' || sBusState || '", ' || 
								'"' || sBusPostcode || '", ' || 
								'"' || sShipAddL1 || '", ' || 
								'"' || sShipAddL2 || '", ' || 
								'"' || sShipSuburb || '", ' || 
								'"' || sShipState || '", ' || 
								'"' || sShipPostcode || '"' 
					Else
						Set sTmp = SalNumberToStrX( nCustNo, 0 ) || ', ' || 
								'"' || sCustName || '", ' || 
								'"' || sBusName || '", ' || 
								'"' || sAddLine1 || '", ' || 
								'"' || sAddLine2 || '", ' || 
								'"' || sSuburb || '", ' || 
								'"' || sState || '", ' || 
								'"' || sPostCode || '"' 
					Call SalFilePutStr( hCSVFileHandle, sTmp )
				Return bOk
			On SAM_ReportFinish
				If cbCSVFile
					Call SalFileClose( hCSVFileHandle )
				Call SalHideWindow( hWndForm )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				Return TRUE
			On SAM_Destroy
				Call fcMailMergeHdl.Disconnect( )
				Call GetBusAddress( 0, dtTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, 
						sTmp, sTmp, sTmp, sTmp, nDisconnect )
				Call GetShipAddress( 0, 0, dtTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, 
						sTmp, sTmp, sTmp, sTmp, sTmp, bPickUp, nDisconnect )
	!

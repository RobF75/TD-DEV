		Application Actions
			On SAM_AppStartup
				If strArgArray[0] = ''
					Set SqlDatabase ='STKLOCAL'
					Set SqlUser = 'JAN'
					Set SqlPassword = 'JAN'
				Else
					Set SqlDatabase = strArgArray[1]
					Set SqlUser = strArgArray[2]
					Set SqlPassword = strArgArray[3]
				!
				! Check if program already active - TS 4/5/95
				!
				Set hWndCheckExists = FindWindowA(0,"Customer Reports")
				Set bCheckExistsWindowHidden = FALSE
				If hWndCheckExists
					If NOT SalIsWindowVisible( hWndCheckExists )
						Set bCheckExistsWindowHidden = TRUE
					Call SalBringWindowToTop( hWndCheckExists )
					! Maximize the window
					Call ShowWindow(hWndCheckExists,3)
					! TS 4/5/95 Doesn't work correctly - If bCheckExistsWindowHidden
						      Call SalHideWindow( hWndCheckExists )
					Call SalMessageBeep( 1 )
					Call SalQuit(  )
				!
				Call SalWaitCursor( TRUE )
				! Call SalCreateWindow( dlgLogin, hWndNULL )
				Set bShowSql = FALSE
				Set bghSqlDetail = SqlConnect( hSqlDetail )
				If bghSqlDetail
					Call SqlSetIsolationLevel( hSqlDetail, 'RL')
					Call SqlSetLockTimeout( hSqlDetail, SQLTIMEOUT )
			On SAM_SqlError
				Call SqlExtractArgs( wParam, lParam, hSqlError, nSqlError, nErrorPos )
				! Going to comments the return false line and put in others to do error processing
				! Return FALSE
				Call SqlGetErrorText( nSqlError, sErrmsg )
				Call SalNumberToStr( nSqlError, 0, sNum )
				Call SalMessageBox( sNum || '-' || sErrmsg || '.
						Choose OK to quit.', 'Customer Reports', MB_Ok | MB_IconStop )
				! Call SalQuit(  )
				Return FALSE
			On SAM_AppExit
				If bghSqlDetail
					Call SqlDisconnect( hSqlDetail )

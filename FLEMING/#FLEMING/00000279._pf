				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					String: sSQLPOPTABLENAME
					String: sORDERBY
					String: sPreBuildWhere
					String: sQueryTmpStr
					String: sCurrentBuildWhere
					Number: nCommaPos
				Message Actions
					On PAM_POPULATE
						Call PopString( sPreBuildWhere, TRUE )
						! order by customer.master.customer_name is by column number position becuase
								  the name can be upper and lower case.  The colCustName must stay at its current position
								  otherwise the order by will need to be adjusted.
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
						Call SalTblSetLockedColumns( hWndForm, 2 )
					On PAM_REPOPULATE
						Call TableRePopulate( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_SEARCH
						Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
						Call SalTblSetLockedColumns( hWndForm, 2 )
					On PAM_RESET
						Call TableReset( hWndForm, colCustNo )
					On PAM_NOROWS
						If NOT bPrintCustDets
							Call SalMessageBox( 'No rows match the search criteria', 'Customer & Contact Query', MB_Ok )
					On PAM_ENABLE
						If wParam
							Call SalShowWindow( hWndForm )
						Else
							Call SalHideWindow( hWndForm )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set sSQLPOPTABLENAME = ' CUSTOMER_MASTER, CUSTOMER_CONTACTS '
						Set sORDERBY = ' ORDER BY 2,1 '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )

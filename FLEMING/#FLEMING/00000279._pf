			Pushbutton: pbQCustomer
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Query Customer - ENTER
				Window Location and Size
					Left:   3.588"
					Top:    0.49"
					Width:  2.2"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: Enter
				Font Name: Default
				Font Size: Default
				Font Enhancement: Bold
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						! Send message pam_qcustcheck to hWndForm children and if some return false
								then confirm with user if they have clicked the right button.
						Set hWndChild = SalGetFirstChild( hWndForm, TYPE_DataField )
						While NOT hWndChild = hWndNULL 
							If NOT SalSendMsg( hWndChild, PAM_QCUSTCHECK, 0, 0 )
								If IDCANCEL = SalMessageBox( 'You have clicked the QUERY CUSTOMER button, any other details other than Customer No or Customer Name are not applicable!  Do you still want to continue! ', 'NOTE', MB_OkCancel | MB_IconQuestion )
									Return FALSE
								Else
									Break
							Set hWndChild = SalGetNextChild( hWndChild, TYPE_DataField )
						Call SalWaitCursor( TRUE )
						Call PushWndHdl( hWndForm )
						Call PushNumber( PAM_QBECUST )
						Call BuildWhereQBE(  )
						Set sBuildWhere = StripWhereFromSQL( sBuildWhere )
						Call SalEndDialog( hWndForm, nCustomerTbl )
			Pushbutton: pbQCustAddress
				Class Child Ref Key: 0
				Class ChildKey: 0

			Child Table: tblQRegions
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Display Settings
					Window Location and Size
						Left:   5.15"
						Top:    0.479"
						Width:  4.175"
						Width Editable? Yes
						Height: 1.521"
						Height Editable? Yes
					Visible? Yes
					Font Name: Arial
					Font Size: 8
					Font Enhancement: Default
					Text Color: Dark Blue
					Background Color: Sky
					View: Table
					Allow Row Sizing? No
					Lines Per Row: Default
				Memory Settings
					Maximum Rows in Memory: Default
					Discardable? Yes
				Contents
					Column: colRegionId
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: RegionId
						Visible? Yes
						Editable? No
						Maximum Data Length: Default
						Data Type: String
						Justify: Left
						Width:  1.15"
						Width Editable? Yes
						Format: Uppercase
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL( wParam,hWndItem,'REGION_ID' )
					Column: colRegionDesc
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Region Desc.
						Visible? Yes
						Editable? No
						Maximum Data Length: Default
						Data Type: String
						Justify: Left
						Width:  3.733"
						Width Editable? Yes
						Format: Unformatted
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL( wParam,hWndItem,'REGION_DESC' )
				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					String: sSql
					String: sRegionIds
				Message Actions
					On PAM_POPULATE
						Set sSql = ' SELECT 
								  REGION_ID, 
								  REGION_DESC 
								FROM  
								  REGION   
								INTO 
								  :dlgCustDets.tblQRegions.colRegionId, 
								  :dlgCustDets.tblQRegions.colRegionDesc 
								ORDER BY 
								  REGION_DESC, REGION_ID '
						Call SalTblPopulate( hWndForm, hLocalSqlPopTbl, sSql, TBL_FillNormal )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					On PAM_GetSelectedRegions
						Set sRegionIds = ''
						Call MyTableLoop( hWndForm, hWndForm, PAM_ROWACTION, ROW_Selected, 0, 'Extracting selected regions.', nLowToHi )
						If sRegionIds = ''
							Return FALSE
						Else
							Call PushString( sRegionIds )
							Return TRUE
					On PAM_ROWACTION
						If sRegionIds = ''
							Set sRegionIds = "'" || colRegionId || "'"
						Else
							Set sRegionIds = sRegionIds || ', ' || "'" || colRegionId || "'"
						Return TRUE
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
		Functions
		Window Parameters
		Window Variables
			String: sCustnoFrom
			String: sCustnoTo
			String: sSql
			Boolean: bFirst
		Message Actions
			On SAM_Create
				Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
			On PAM_CREATECOMPLETE
				Set hWndForm.dfCurrDate = SalDateCurrent(  )
				Call SalSetFocus( pbCancel )
				Set bgOrderByName = FALSE
				Call SalSendMsg( tblQRegions, PAM_POPULATE, 0, 0 )
				Call SalWaitCursor( FALSE )
			On SAM_Close
				Call SalWaitCursor( TRUE )

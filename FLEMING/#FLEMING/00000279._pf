			!
			Window Handle: hWndPushbutton
			Window Handle: hWndReport
			File Handle: hNPALabelFile
			Boolean: bNPALabelFile
			Boolean: bSetOk
			String: sNPALabelStr
			Number: nAddShowOrdersFirst
			!
			!
			Sql Handle: hSqlHdlCultRoy
			Boolean: bHdlCultRoyConnected
			Boolean: bHdlCultRoyPrepared
			!
			Sql Handle: hSqlHdlRootRoy
			Boolean: bHdlRootRoyConnected
			Boolean: bHdlRootRoyPrepared
			!
			Sql Handle: hSqlHdlFNARoy
			Boolean: bHdlFNARoyConnected
			Boolean: bHdlFNARoyPrepared
			!
			Sql Handle: hSqlNPAHdl
			Boolean: bSqlNPAHdlConnected
			Boolean: bSqlNPAHdlPrepared
			!
			Sql Handle: hSqlNPAUpdHdl
			Boolean: bSqlNPAUpdHdlConnected
			Boolean: bSqlNPAUpdHdlPrepared
			!
			File Handle: hHailLabelFile
			Boolean: bHailLabelFile
			String: sHailLabelStr
			!
			File Handle: hMailMrgFile
			Boolean: bMailMrgFile
			String: sMailMrgLabelStr
			File Handle: hOrderFormFile
			Boolean: bOrderFormFile
			String: sOrderFormLabelStr
			String: sOrchdistStr
			File Handle: hOrchdistFile
			Boolean: bOrchdistFile
			!
			Number: nMaypole
			Number: nWaltz
			String: sMaypole
			String: sWaltz
			Number: nItemCount
			Number: nItemNo
			Number: nTotalOrd
			Number: nPrev93OrdAmt
			Number: nPrev92OrdAmt
			Number: nPrev91OrdAmt
			Number: nPrev90OrdAmt
			String: sTotalOrd
			String: sPrev93OrdAmt
			String: sPrev92OrdAmt
			String: sPrev91OrdAmt
			String: sPrev90OrdAmt
			Sql Handle: hSqlSumTotal
			Boolean: bSqlSumTotal
			Sql Handle: hSqlOrdHistory
			Boolean: bSqlOrdHistory
			!
			Boolean: bPrintNPAs
			Boolean: bPrintCustDets
			Boolean: bSelectedRows
			Boolean: bPrintHailDamage
			Boolean: bPrintAckments
			Boolean: bPrintConfirmats
			Boolean: bShowQueryOk
			Number: nNoNPAs
			Number: nNoHails
			Number: nPageNo
			Number: nNoItemsPrinted
			Number: nCustNo
			Number: nCommaPos
			String: sCustLeftName
			String: sCustRightName
			!
			Number: nWhichTableActive
			Number: nOldTableActive
			String: sHelpFileName
			Number: nRow
			Number: nYear
			Number: nQtr
			Number: nUseOrNotUseStockCount
			Boolean: bFirstCreateComplete
			!
			String: sRepInto
			String: sRepBind
			String: sReportFile
			Number: nError
			Number: nCustRow
			Number: nOrderRow
			Number: nContRow
			Number: nAddressRow
			String: sMessageLegend[1:*]
			Number: nLastArrayEntry
			Boolean: bProcessCust
			Boolean: bProcessOrders
			Boolean: bProcessCont
			Boolean: bProcessAddress
			Boolean: bProcessLegend
			Boolean: bPopulateTblOrd
			Boolean: bPopulateTblCont
			Boolean: bPopulateTblAddress
			Boolean: bItemisedAck
			Sql Handle: hSqlHandle
			Boolean: bSqlHandle
			String: sSql
			Number: nInd
			!
			Sql Handle: hSqlBusAddrHdl
			Boolean: bSqlBusAddrHdl
			Boolean: bSqlBusAddrHdlPrep
			Number: nNoCont
			Number: nNoAddr
		Message Actions
			On SAM_Create
				Set sHelpFileName = 'g:\\apps\\gupta\\help\\qcustadd.hlp'
				Set bFirstCreateComplete = TRUE
				!
				Set bSqlBusAddrHdl = FALSE
				Set bSqlBusAddrHdlPrep = FALSE
				Set bSqlNPAHdlConnected = FALSE
				Set bSqlNPAHdlPrepared = FALSE
				Set bSqlNPAUpdHdlConnected = FALSE
				Set bSqlNPAUpdHdlPrepared = FALSE
				Set hWndMailMerge = hWndNULL
				!
				! Call SalDestroyWindow( dlgLogin)
				Call SalWaitCursor( FALSE )
				Call SalPostMsg( hWndForm,PAM_CREATECOMPLETE,0,0 )
			On SAM_Destroy
				If bSqlBusAddrHdl
					Call SqlDisconnect( hSqlBusAddrHdl )
				Call GetBusAddressHdlNewLogic( 0, hWndNULL, 0, nDisconnect )
				Call GetShipAddressHdlNewLogic( 0, 0, hWndNULL, 0, bPickUpAddress, nDisconnect )
				! If bSqlCVHdlConnected
					      Call SqlDisconnect( hSqlCVHdl )
				! If bSqlRtHdlConnected
					      Call SqlDisconnect( hSqlRtHdl )
				If bSqlNPAHdlConnected
					Call SqlDisconnect( hSqlNPAHdl )
				If bSqlNPAUpdHdlConnected
					Call SqlDisconnect( hSqlNPAUpdHdl )
				Call SalSendMsg( hWndCallProg, PAM_ENABLE, 0, 0 )
			On SAM_Close
				If bShowQueryOk
					Return FALSE
				If IDCANCEL = SalMessageBox( 'You are about to EXIT the 
						CUSTOMER REPORTS program, 
						Do you want to do this?', 'Warning', MB_OkCancel )
					Return FALSE
			On PAM_CREATECOMPLETE
				Set dfCurrDate = SalDateCurrent(  )
				Set bgOrderByName = FALSE
				Set nOldTableActive = nWhichTableActive
				Set nWhichTableActive = SalModalDialog( dlgInitialQCustomer, hWndForm )
				Select Case nWhichTableActive
					Case nCustomerTbl
						If NOT sBuildWhere = ''
							Set sBuildWhere = ' WHERE ' || sBuildWhere
						Else
							Set sBuildWhere = ' '
						! Call PushString( sBuildWhere )
						Call SalSendMsg( dfQueryTypeHeading, PAM_REFRESH, 0, 0 )
						Call SalSendMsg( frmQCustomer.tblQCustomer, PAM_ENABLE, TRUE, 0 )
						Call SalSendMsg( frmQCustomer.tblQCustAddr, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( frmQCustomer.tblQCustCont, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( frmQCustomer.tblQCustomer, PAM_POPULATE, 0, 0 )
						Call SalSetFocus( frmQCustomer.tblQCustomer )
						Set bFirstCreateComplete = FALSE
						Break
					Case nCustAddrTbl
						Call PushString( sBuildWhere )
						Call SalSendMsg( dfQueryTypeHeading, PAM_REFRESH, 0, 0 )
						Call SalSendMsg( frmQCustomer.tblQCustomer, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( frmQCustomer.tblQCustAddr, PAM_ENABLE, TRUE, 0 )
						Call SalSendMsg( frmQCustomer.tblQCustCont, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( frmQCustomer.tblQCustAddr, PAM_POPULATE, 0, 0 )
						Call SalSetFocus( frmQCustomer.tblQCustAddr )
						Set bFirstCreateComplete = FALSE
						Break
					Case nCustContTbl
						Call PushString( sBuildWhere )
						Call SalSendMsg( dfQueryTypeHeading, PAM_REFRESH, 0, 0 )
						Call SalSendMsg( frmQCustomer.tblQCustomer, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( frmQCustomer.tblQCustAddr, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( frmQCustomer.tblQCustCont, PAM_ENABLE, TRUE, 0 )
						Call SalSendMsg( frmQCustomer.tblQCustCont, PAM_POPULATE, 0, 0 )
						Call SalSetFocus( frmQCustomer.tblQCustCont )
						Set bFirstCreateComplete = FALSE
						Break
					! Case nAddNewCust
						      Call SalPostMsg( pbAdd, SAM_Click, 0, 0 )
						      Set bFirstCreateComplete = FALSE
						      Break 
					Default nCancel
						If bFirstCreateComplete
							Call SalDestroyWindow( hWndForm )
						Else
							Set bFirstCreateComplete = FALSE
							Set nWhichTableActive = nOldTableActive
							Call SalWaitCursor( FALSE )
				Call SalWaitCursor( FALSE )
			On PAM_PRINTNPAS
				Call SalWaitCursor( TRUE )
				Set bPrintAckments = FALSE
				Set bPrintConfirmats = FALSE
				Set bPrintNPAs = TRUE
				Select Case nWhichTableActive
					Case nCustomerTbl
						If SalTblAnyRows( frmQCustomer.tblQCustomer, ROW_Selected, 0 )
							If IDCANCEL = SalMessageBox( 'All Customers will have NPAs printed if they were not received as yet for the choosen year! Selected Rows are ignored.', 'Warning', MB_IconHand | MB_OkCancel )
								Call SalWaitCursor( FALSE )
								Return FALSE
						Break
					Case nCustAddrTbl
						If SalTblAnyRows( frmQCustomer.tblQCustAddr, ROW_Selected, 0 )
							If IDCANCEL = SalMessageBox( 'All Customers will have NPAs printed if they were not received as yet for the choosen year! Selected Rows are ignored.', 'Warning', MB_IconHand | MB_OkCancel )
								Call SalWaitCursor( FALSE )
								Return FALSE
						Break
					Case nCustContTbl
						If SalTblAnyRows( frmQCustomer.tblQCustCont, ROW_Selected, 0 )
							If IDCANCEL = SalMessageBox( 'All Customers will have NPAs printed if they were not received as yet for the choosen year! Selected Rows are ignored.', 'Warning', MB_IconHand | MB_OkCancel )
								Call SalWaitCursor( FALSE )
								Return FALSE
						Break
				Set sRepInto = 'AgreementDate '
				Set sRepBind = ':frmQCustomer.dfCurrDate '
				Call CallBuildSql( frmQCustomer.tblMaster, nSELECT, PAM_NPACUSTBITS, '', '' )
				Set sRepInto = sRepInto||','||sColumns
				Set sRepBind = sRepBind||','||sIntoVars
				Call CallBuildSql( frmQCustomer.tblMaster, nSELECT, PAM_TABLENPAFIELDS, '', '' )
				Set sRepInto = sRepInto||','||sColumns
				Set sRepBind = sRepBind||','||sIntoVars
				Call CallBuildSql( frmQCustomer.tblOrd, nSELECT, PAM_TABLENPAFIELDS, '', '' )
				Set sRepInto = sRepInto||','||sColumns
				Set sRepBind = sRepBind||','||sIntoVars
				Set sReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\npa.qrp'
				Set nError = 1
				Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, RPT_PrintAll,0,0, nError )
			On PAM_PRINTCUSTDETS
				Set bPrintAckments = FALSE
				Set bPrintConfirmats = FALSE
				Set bPrintNPAs = FALSE
				Set bPrintCustDets = TRUE
				Call CallBuildSql( frmQCustomer.tblMaster, nSELECT, PAM_TABLECUSTFIELDS, '', '' )
				Set sRepInto = sColumns
				Set sRepBind = sIntoVars
				Set sReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\ncustdt2.qrp'
				Set nError = 1
				Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, 
						RPT_PrintAll|RPT_PrintDraft,0,0, nError )
			On PAM_PRINTNUMBALL
				Call SalWaitCursor( TRUE )
				! Handle used to determine if customer has hail damaged stock
				Set bSqlHandle = SqlConnect( hSqlHandle ) 
				If bSqlHandle
					Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
					Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
				Else
					Call SalWaitCursor( FALSE )
					Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
					Return FALSE
				Set bSqlSumTotal = SqlConnect( hSqlSumTotal ) 
				If bSqlSumTotal
					Call SqlSetLockTimeout( hSqlSumTotal, SQLTIMEOUT )
					Call SqlSetParameter( hSqlSumTotal, DBP_PRESERVE, TRUE, ''  )
				Else
					If bSqlHandle
						Call SqlDisconnect( hSqlHandle )
					Call SalWaitCursor( FALSE )
					Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
					Return FALSE
				Set bSqlOrdHistory = SqlConnect( hSqlOrdHistory ) 
				If bSqlOrdHistory
					Call SqlSetLockTimeout( hSqlOrdHistory, SQLTIMEOUT )
					Call SqlSetParameter( hSqlOrdHistory, DBP_PRESERVE, TRUE, ''  )
				Else
					If bSqlHandle
						Call SqlDisconnect( hSqlHandle )
					If bSqlSumTotal
						Call SqlDisconnect( hSqlSumTotal )
					Call SalWaitCursor( FALSE )
					Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
					Return FALSE
				Set bHailLabelFile = SalFileOpen( hHailLabelFile, 'f:\\data\\amipro\\lan\\ballerin.dat', 
						OF_Create | OF_Text | OF_Write )
				!
				Set sSql = 'SELECT SUM( Conf_Amt ) 
						FROM customer_order
						INTO :nItemCount
						WHERE 
						  Cust_no = :frmQCustomer.tblQCustAddr.colCustNo AND 
						  Year_Of_Sale = 94 AND 
						  Stock_Item_NO = :nItemNo '
				If NOT SqlPrepare( hSqlHandle, sSql )
					Call SalWaitCursor( FALSE )
					Call SalMessageBox( 'SqlPrepare had a error in PAM_PRINTNUMBALL.  Please contact programmers.', 'Error', MB_Ok )
					If bSqlHandle
						Call SqlDisconnect( hSqlHandle )
					If bSqlSumTotal
						Call SqlDisconnect( hSqlSumTotal )
					If bSqlOrdHistory
						Call SqlDisconnect( hSqlOrdHistory )
					If bHailLabelFile
						Call SalFileClose( hHailLabelFile )
					Return FALSE
				!
				Set sSql = 'SELECT SUM( Conf_Amt ) 
						FROM customer_order
						INTO :nTotalOrd
						WHERE 
						  Cust_no = :frmQCustomer.tblQCustAddr.colCustNo AND 
						  Year_Of_Sale = 94 '
				If NOT SqlPrepare( hSqlSumTotal, sSql )
					Call SalWaitCursor( FALSE )
					Call SalMessageBox( 'SqlPrepare had a error in PAM_PRINTNUMBALL.  Please contact programmers.', 'Error', MB_Ok )
					If bSqlHandle
						Call SqlDisconnect( hSqlHandle )
					If bSqlSumTotal
						Call SqlDisconnect( hSqlSumTotal )
					If bSqlOrdHistory
						Call SqlDisconnect( hSqlOrdHistory )
					If bHailLabelFile
						Call SalFileClose( hHailLabelFile )
					Return FALSE
				!
				Set sSql = 'SELECT Prev_93YearOrdAmt, Prev_92YearOrdAmt, 
						Prev_91YearOrdAmt, Prev_90YearOrdAmt FROM Customer_Master 
						INTO :nPrev93OrdAmt, :nPrev92OrdAmt, :nPrev91OrdAmt, :nPrev90OrdAmt 
						WHERE Cust_No = :frmQCustomer.tblQCustAddr.colCustNo '
				If NOT SqlPrepare( hSqlOrdHistory, sSql )
					Call SalWaitCursor( FALSE )
					Call SalMessageBox( 'SqlPrepare had a error in PAM_PRINTNUMBALL.  Please contact programmers.', 'Error', MB_Ok )
					If bSqlHandle
						Call SqlDisconnect( hSqlHandle )
					If bSqlSumTotal
						Call SqlDisconnect( hSqlSumTotal )
					If bSqlOrdHistory
						Call SqlDisconnect( hSqlOrdHistory )
					If bHailLabelFile
						Call SalFileClose( hHailLabelFile )
					Return FALSE
				!
				Set nCustRow = TBL_MinRow
				While SalTblFindNextRow( frmQCustomer.tblQCustAddr, nCustRow, 0, 0 )
					Call SalTblFetchRow( frmQCustomer.tblQCustAddr, nCustRow )
					! get count of maypole generics ordered
					Set nItemCount = NUMBER_Null
					Set nItemNo = 1350
					If SqlExecute( hSqlHandle )
						Call SqlFetchNext( hSqlHandle, nInd )
					Else
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'SqlExecute had a error in PAM_PRINTNUMDAMAGE.  Please contact programmers.', 'Error', MB_Ok )
						If bSqlHandle
							Call SqlDisconnect( hSqlHandle )
						If bSqlSumTotal
							Call SqlDisconnect( hSqlSumTotal )
						If bSqlOrdHistory
							Call SqlDisconnect( hSqlOrdHistory )
						If bHailLabelFile
							Call SalFileClose( hHailLabelFile )
						Return FALSE
					If nItemCount != NUMBER_Null
						Set nMaypole = nItemCount
					Else
						Set nMaypole = 0
					!
					! get count of waltz generics ordered
					Set nItemCount = NUMBER_Null
					Set nItemNo = 1349
					If SqlExecute( hSqlHandle )
						Call SqlFetchNext( hSqlHandle, nInd )
					Else
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'SqlExecute had a error in PAM_PRINTNUMDAMAGE.  Please contact programmers.', 'Error', MB_Ok )
						If bSqlHandle
							Call SqlDisconnect( hSqlHandle )
						If bSqlSumTotal
							Call SqlDisconnect( hSqlSumTotal )
						If bSqlOrdHistory
							Call SqlDisconnect( hSqlOrdHistory )
						If bHailLabelFile
							Call SalFileClose( hHailLabelFile )
						Return FALSE
					If nItemCount != NUMBER_Null
						Set nWaltz = nItemCount
					Else
						Set nWaltz = 0
					!
					If nMaypole + nWaltz > 0
						Set nTotalOrd = NUMBER_Null
						If SqlExecute( hSqlSumTotal )
							Call SqlFetchNext( hSqlSumTotal, nInd )
							If nTotalOrd != NUMBER_Null
								Call SalNumberToStr( nTotalOrd, 0, sTotalOrd )
							Else
								Set sTotalOrd = ' '
						Else
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'SqlExecute had a error in PAM_PRINTNUMDAMAGE.  Please contact programmers.', 'Error', MB_Ok )
							If bSqlHandle
								Call SqlDisconnect( hSqlHandle )
							If bSqlSumTotal
								Call SqlDisconnect( hSqlSumTotal )
							If bSqlOrdHistory
								Call SqlDisconnect( hSqlOrdHistory )
							If bHailLabelFile
								Call SalFileClose( hHailLabelFile )
							Return FALSE
						!
						Set nPrev93OrdAmt = NUMBER_Null
						Set nPrev92OrdAmt = NUMBER_Null
						Set nPrev91OrdAmt = NUMBER_Null
						Set nPrev90OrdAmt = NUMBER_Null
						If SqlExecute( hSqlOrdHistory )
							Call SqlFetchNext( hSqlOrdHistory, nInd )
							If nPrev93OrdAmt != NUMBER_Null
								Call SalNumberToStr( nPrev93OrdAmt, 0, sPrev93OrdAmt )
							Else
								Set sPrev93OrdAmt = ' '
							If nPrev92OrdAmt != NUMBER_Null
								Call SalNumberToStr( nPrev92OrdAmt, 0, sPrev92OrdAmt )
							Else
								Set sPrev92OrdAmt = ' '
							If nPrev91OrdAmt != NUMBER_Null
								Call SalNumberToStr( nPrev91OrdAmt, 0, sPrev91OrdAmt )
							Else
								Set sPrev91OrdAmt = ' '
							If nPrev90OrdAmt != NUMBER_Null
								Call SalNumberToStr( nPrev90OrdAmt, 0, sPrev90OrdAmt )
							Else
								Set sPrev90OrdAmt = ' '
						Else
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'SqlExecute had a error in PAM_PRINTNUMDAMAGE.  Please contact programmers.', 'Error', MB_Ok )
							If bSqlHandle
								Call SqlDisconnect( hSqlHandle )
							If bSqlSumTotal
								Call SqlDisconnect( hSqlSumTotal )
							If bSqlOrdHistory
								Call SqlDisconnect( hSqlOrdHistory )
							If bHailLabelFile
								Call SalFileClose( hHailLabelFile )
							Return FALSE
						!
						Call SalNumberToStr( nMaypole, 0, sMaypole )
						Call SalNumberToStr( nWaltz, 0, sWaltz )
						!
						Call GetBusAddressHdlNewLogic( frmQCustomer.tblQCustAddr.colCustNo, 
								frmQCustomer.tblQCustAddr, PAM_BUSADDRESS, nExecute )
						!
						! NOTE sCustRightName = first name and sCustLeftName = surname
						Set nCommaPos = SalStrScan( frmQCustomer.tblQCustAddr.colCustName, ',' )
						If nCommaPos >= 0
							Call SalStrLeft( frmQCustomer.tblQCustAddr.colCustName, nCommaPos, sCustLeftName )
							Call SalStrMid( frmQCustomer.tblQCustAddr.colCustName, nCommaPos+2,
									SalStrLength( frmQCustomer.tblQCustAddr.colCustName ) - nCommaPos, sCustRightName )
						Else
							Set sCustRightName = ''
							Set sCustLeftName = frmQCustomer.tblQCustAddr.colCustName
						Set sHailLabelStr = sCustRightName || ',' || 
								  sCustLeftName || ',' ||
								  frmQCustomer.tblQCustAddr.colPOAdd1 || ',' ||
								  frmQCustomer.tblQCustAddr.colPOAdd2 || ',' ||
								  frmQCustomer.tblQCustAddr.colPOSuburb || ',' ||
								  frmQCustomer.tblQCustAddr.colPOState || ',' ||
								  frmQCustomer.tblQCustAddr.colPOPostcode || ' , Maypole: ' || sMaypole ||
								  ', Waltz: ' || sWaltz || ', Total: ' || sTotalOrd || ', Yr93: ' || sPrev93OrdAmt || 
								  ', Yr92: ' || sPrev92OrdAmt || ', Yr91: ' || sPrev91OrdAmt || ', Yr90: ' || sPrev90OrdAmt
						Call SalFilePutStr( hHailLabelFile, sHailLabelStr )
				!
				If bSqlHandle
					Call SqlDisconnect( hSqlHandle )
				If bSqlSumTotal
					Call SqlDisconnect( hSqlSumTotal )
				If bSqlOrdHistory
					Call SqlDisconnect( hSqlOrdHistory )
				If bHailLabelFile
					Call SalFileClose( hHailLabelFile )
				Call SalWaitCursor( FALSE )
			On SAM_ReportStart
				If bPrintNPAs
					Set nCustRow = TBL_MinRow
					Set nOrderRow = TBL_MinRow
					Set bProcessCust = TRUE
					Set bProcessOrders = FALSE
					Set bPopulateTblOrd = FALSE
					Set bSqlHandle = SqlConnect( hSqlHandle ) 
					If bSqlHandle
						Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
					Else
						Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						Return FALSE
					Set bNPALabelFile = SalFileOpen( hNPALabelFile, 'f:\\data\\amipro\\lan\\npacust.dat', OF_Create | OF_Text | OF_Write )
					Return TRUE
				If bPrintCustDets
					Set nCustRow = TBL_MinRow
					Set nContRow = TBL_MinRow
					Set nAddressRow = TBL_MinRow
					Set bProcessCust = TRUE
					Set bProcessCont = FALSE
					Set bProcessAddress = FALSE
					Set bPopulateTblCont = FALSE
					Set bPopulateTblAddress = FALSE
					Return TRUE
			On SAM_ReportFetchInit
				If bPrintNPAs
					Call SalSendMsg( frmQCustomer.tblMaster, PAM_POPULATE2, 0, 0 )
					Return TRUE
				If bPrintCustDets
					Call SalSendMsg( frmQCustomer.tblMaster, PAM_POPULATE4, 0, 0 )
					Return TRUE
			On SAM_ReportFetchNext
				If bPrintNPAs
					If bProcessCust
						Call SalSendMsgToChildren( frmQCustomer.tblOrd, PAM_INITIALIZE, 0, 0 )
						Loop
							Set bOk = SalTblFindNextRow( frmQCustomer.tblMaster, nCustRow, 0, 0 )
							If bOk
								Call SalTblFetchRow( frmQCustomer.tblMaster, nCustRow )
								If HasCustAnyNPAstock( frmQCustomer.tblMaster.colCustNo, nYear,hSqlNPAHdl, bSqlNPAHdlConnected, bSqlNPAHdlPrepared )
									Set bProcessCust = FALSE
									Set bProcessOrders = TRUE
									Set nOrderRow = TBL_MinRow
									Set nNoItemsPrinted = 0
									!
									Call GetBusAddressHdlNewLogic( frmQCustomer.tblMaster.colCustNo, frmQCustomer.tblMaster, PAM_BUSADDRESS, nExecute )
									!
									Set nCommaPos = SalStrScan( frmQCustomer.tblMaster.colCustName, ',' )
									If nCommaPos >= 0
										Call SalStrLeft( frmQCustomer.tblMaster.colCustName, nCommaPos, sCustLeftName )
										Call SalStrMid( frmQCustomer.tblMaster.colCustName, nCommaPos+2, SalStrLength( frmQCustomer.tblMaster.colCustName ) - nCommaPos, sCustRightName )
										Set frmQCustomer.tblMaster.colCustName = sCustRightName || ' ' || sCustLeftName
									Set sNPALabelStr = frmQCustomer.tblMaster.colCustName || ',' || 
											  frmQCustomer.tblMaster.colPOAdd1 || ',' ||
											  frmQCustomer.tblMaster.colPOAdd2 || ',' ||
											  frmQCustomer.tblMaster.colPOSuburb || ',' ||
											  frmQCustomer.tblMaster.colPOState || ',' ||
											  frmQCustomer.tblMaster.colPOPostcode
									Call SalFilePutStr( hNPALabelFile, sNPALabelStr )
									Set bPopulateTblOrd = TRUE
									Return TRUE
							If NOT bOk
								Return FALSE
					If bProcessOrders
						If bPopulateTblOrd
							Call SalSendMsg( frmQCustomer.tblOrd, PAM_POPULATE, 0, 0 )
							! Set nNoNPAs = MarkNPItems ( hSqlCVHdl, bSqlCVHdlConnected, bSqlCVHdlPrepared,
									 hSqlRtHdl, bSqlRtHdlConnected, bSqlRtHdlPrepared, frmQCustomer.tblOrd )
							Set bPopulateTblOrd = FALSE
						Loop
							Set bOk = SalTblFindNextRow( frmQCustomer.tblOrd, nOrderRow, 0, 0 )
							If bOk
								If NOT SalTblFindNextRow( frmQCustomer.tblOrd, nOrderRow, 0, 0 )
									Set bProcessCust = TRUE
									Set bProcessOrders = FALSE
								Else
									Call SalTblFindPrevRow( frmQCustomer.tblOrd, nOrderRow, 0, 0  )
								Call SalTblFetchRow( frmQCustomer.tblOrd, nOrderRow )
								If frmQCustomer.tblOrd.colNPANeeded = 'Y'
									Set nNoItemsPrinted = nNoItemsPrinted + 1
									Break
							If NOT bOk
								Set bProcessCust = TRUE
								Set bProcessOrders = FALSE
								Return TRUE
						If nNoItemsPrinted = nNoNPAs
							Set bProcessCust = TRUE
							Set bProcessOrders = FALSE
						!
						If frmQCustomer.tblOrd.colCultNPAflag = 'N' AND frmQCustomer.tblOrd.colRootNPAflag = 'Y'
							Set frmQCustomer.tblOrd.colCultdesc = frmQCustomer.tblOrd.colVariety
						Else If frmQCustomer.tblOrd.colCultNPAflag = 'Y' AND frmQCustomer.tblOrd.colRootNPAflag = 'N'
							Set tblOrd.colRootDesc = ''
						! If NOT SalIsNull( frmQCustomer.tblOrd.colConfAmt )
						Set frmQCustomer.tblOrd.colQuantity = frmQCustomer.tblOrd.colConfAmt
						! Else 
							      Set frmQCustomer.tblOrd.colQuantity = frmQCustomer.tblOrd.colOrdAmt
						!
						If frmQCustomer.tblOrd.colSaleCat = 'RP' OR frmQCustomer.tblOrd.colSaleCat = 'FC'
							Set frmQCustomer.tblOrd.colPurchasePrice = 0
						Else
							If NOT SalIsNull( frmQCustomer.tblOrd.colContractPrice )
								Set frmQCustomer.tblOrd.colPurchasePrice = frmQCustomer.tblOrd.colContractPrice
							Else
								Set sSql = 'Select Stock_Item.Base_Price From Stock_Item 
										Into :frmQCustomer.tblOrd.colPurchasePrice 
										Where Stock_Item.Item_no = :frmQCustomer.tblOrd.colItemNo'
								Call SqlPrepare( hSqlHandle, sSql )
								Call SqlExecute( hSqlHandle )
								Call SqlFetchNext( hSqlHandle, nInd )
								If frmQCustomer.tblOrd.colSaleCat = 'HP'
									Set frmQCustomer.tblOrd.colPurchasePrice = frmQCustomer.tblOrd.colPurchasePrice / 2
							If frmQCustomer.tblOrd.colPurchasePrice != 0
								Set frmQCustomer.tblOrd.colPurchasePrice = frmQCustomer.tblOrd.colPurchasePrice + CultivarRoyalty( frmQCustomer.hSqlHdlFNARoy, frmQCustomer.bHdlFNARoyConnected, frmQCustomer.bHdlFNARoyPrepared,
										frmQCustomer.hSqlHdlCultRoy, frmQCustomer.bHdlCultRoyConnected, frmQCustomer.bHdlCultRoyPrepared, 
										frmQCustomer.tblMaster.colCustNo, frmQCustomer.tblOrd.colCultId  )
								Set frmQCustomer.tblOrd.colPurchasePrice = frmQCustomer.tblOrd.colPurchasePrice + RootstockRoyalty( frmQCustomer.hSqlHdlFNARoy, frmQCustomer.bHdlFNARoyConnected, frmQCustomer.bHdlFNARoyPrepared,
										frmQCustomer.hSqlHdlRootRoy, frmQCustomer.bHdlRootRoyConnected, frmQCustomer.bHdlRootRoyPrepared, 
										frmQCustomer.tblMaster.colCustNo, frmQCustomer.tblOrd.colRootId  )
						!
						If NOT bSqlNPAUpdHdlConnected
							Set bSqlNPAUpdHdlConnected = SqlConnect( hSqlNPAUpdHdl ) 
							If bSqlNPAUpdHdlConnected
								Call SqlSetLockTimeout( hSqlNPAUpdHdl, SQLTIMEOUT )
								Call SqlSetParameter( hSqlNPAUpdHdl, DBP_PRESERVE, TRUE, ''  )
							Else
								Call SalWaitCursor( FALSE )
								Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
								Return FALSE
						If NOT bSqlNPAUpdHdlPrepared
							Set sSql = ' UPDATE Customer_Order SET NPA_Sent_Flag = \'Y\', 
									NPA_Sent_Date = :frmQCustomer.dfCurrDate WHERE ROWID = :frmQCustomer.tblOrd.colRowId '
							If SqlPrepare( hSqlNPAUpdHdl, sSql )
								Set bSqlNPAUpdHdlPrepared = TRUE
							Else
								Set bSqlNPAUpdHdlPrepared = FALSE
								Call SalMessageBox( 'SqlPrepare had a error in updating NPA Items.  Please contact programmers.', 'Error', MB_Ok )
								Call SalWaitCursor( FALSE )
								Return FALSE
						If SqlExecute( hSqlNPAUpdHdl )
							Call SqlCommit( hSqlNPAUpdHdl )
						Else
							Call SqlPrepareAndExecute( hSqlNPAUpdHdl, 'ROLLBACK' )
							Call SalMessageBox( 'SqlExecute had a error in updating NPA Items.  Please contact programmers.', 'Error', MB_Ok )
							Set bSqlNPAUpdHdlPrepared = FALSE
							Call SalWaitCursor( FALSE )
							Return FALSE
						Return TRUE
				If bPrintCustDets
					Loop
						Set bOk = SalTblFindNextRow( tblMaster, nCustRow, 0, 0 )
						If bOk
							Call SalTblFetchRow( tblMaster, nCustRow )
							Call SalSendMsgToChildren( frmQCustomer.tblQCustCont, PAM_INITIALIZE, 0, 0 )
							Call PushString( 'CUSTOMER_MASTER.CUST_NO = :frmQCustomer.tblMaster.colCustNo' )
							Call SalSendMsg( frmQCustomer.tblQCustCont, PAM_POPULATE, 0, 0 )
							Set nContRow = TBL_MinRow
							Set nNoCont = 0
							While SalTblFindNextRow( frmQCustomer.tblQCustCont, nContRow, 0, 0 )
								Call SalTblFetchRow( frmQCustomer.tblQCustCont, nContRow )
								Set nNoCont = nNoCont + 1
								If nNoCont > 4
									Call SalMessageBox( 'Customer no xxxxx has more than 4 contacts.  Cannot print them all', 'Print Customer Details', MB_Ok )
									! there was a break here which was cancelling the program so
											put in an else
								Else
									If nNoCont = 1
										Set frmQCustomer.tblMaster.colSurname1 = frmQCustomer.tblQCustCont.colSurname
										Set frmQCustomer.tblMaster.colFirstName1 = frmQCustomer.tblQCustCont.colFirstName
										Set frmQCustomer.tblMaster.colAHCode1 = frmQCustomer.tblQCustCont.colAHCode
										Set frmQCustomer.tblMaster.colAHPhNo1 = frmQCustomer.tblQCustCont.colAHPhNo
										Set frmQCustomer.tblMaster.colWkCode1 = frmQCustomer.tblQCustCont.colACode
										Set frmQCustomer.tblMaster.colWkPhNo1 = frmQCustomer.tblQCustCont.colPhNo
										Set frmQCustomer.tblMaster.colMailFlag1 = frmQCustomer.tblQCustCont.colMail
										Set frmQCustomer.tblMaster.colPosition1 = frmQCustomer.tblQCustCont.colPos
									Else If nNoCont = 2
										Set frmQCustomer.tblMaster.colSurname2 = frmQCustomer.tblQCustCont.colSurname
										Set frmQCustomer.tblMaster.colFirstName2 = frmQCustomer.tblQCustCont.colFirstName
										Set frmQCustomer.tblMaster.colAHCode2 = frmQCustomer.tblQCustCont.colAHCode
										Set frmQCustomer.tblMaster.colAHPhNo2 = frmQCustomer.tblQCustCont.colAHPhNo
										Set frmQCustomer.tblMaster.colWkCode2 = frmQCustomer.tblQCustCont.colACode
										Set frmQCustomer.tblMaster.colWkPhNo2 = frmQCustomer.tblQCustCont.colPhNo
										Set frmQCustomer.tblMaster.colMailFlag2 = frmQCustomer.tblQCustCont.colMail
										Set frmQCustomer.tblMaster.colPosition2 = frmQCustomer.tblQCustCont.colPos
									Else If nNoCont = 3
										Set frmQCustomer.tblMaster.colSurname3 = frmQCustomer.tblQCustCont.colSurname
										Set frmQCustomer.tblMaster.colFirstName3 = frmQCustomer.tblQCustCont.colFirstName
										Set frmQCustomer.tblMaster.colAHCode3 = frmQCustomer.tblQCustCont.colAHCode
										Set frmQCustomer.tblMaster.colAHPhNo3 = frmQCustomer.tblQCustCont.colAHPhNo
										Set frmQCustomer.tblMaster.colWkCode3 = frmQCustomer.tblQCustCont.colACode
										Set frmQCustomer.tblMaster.colWkPhNo3 = frmQCustomer.tblQCustCont.colPhNo
										Set frmQCustomer.tblMaster.colMailFlag3 = frmQCustomer.tblQCustCont.colMail
										Set frmQCustomer.tblMaster.colPosition3 = frmQCustomer.tblQCustCont.colPos
									Else If nNoCont = 4
										Set frmQCustomer.tblMaster.colSurname4 = frmQCustomer.tblQCustCont.colSurname
										Set frmQCustomer.tblMaster.colFirstName4 = frmQCustomer.tblQCustCont.colFirstName
										Set frmQCustomer.tblMaster.colAHCode4 = frmQCustomer.tblQCustCont.colAHCode
										Set frmQCustomer.tblMaster.colAHPhNo4 = frmQCustomer.tblQCustCont.colAHPhNo
										Set frmQCustomer.tblMaster.colWkCode4 = frmQCustomer.tblQCustCont.colACode
										Set frmQCustomer.tblMaster.colWkPhNo4 = frmQCustomer.tblQCustCont.colPhNo
										Set frmQCustomer.tblMaster.colMailFlag4 = frmQCustomer.tblQCustCont.colMail
										Set frmQCustomer.tblMaster.colPosition4 = frmQCustomer.tblQCustCont.colPos
							Call SalSendMsgToChildren( frmQCustomer.tblQCustAddr, PAM_INITIALIZE, 0, 0 )
							Call PushString( 'CUSTOMER_MASTER.CUST_NO = :frmQCustomer.tblMaster.colCustNo' )
							Call SalSendMsg( frmQCustomer.tblQCustAddr, PAM_POPULATE, 0, 0 )
							Set nAddressRow = TBL_MinRow
							Set nNoAddr = 0
							While SalTblFindNextRow( frmQCustomer.tblQCustAddr, nAddressRow, 0, 0 )
								Call SalTblFetchRow( frmQCustomer.tblQCustAddr, nAddressRow )
								Set nNoAddr = nNoAddr + 1
								If nNoAddr > 4
									Call SalMessageBox( 'Customer no xxxxx has more than 4 addresses.  Cannot print them all', 'Print Customer Details', MB_Ok )
									! Break
									! there was a break here which was cancelling the program so
											put in an else
								Else
									If nNoAddr = 1
										Set frmQCustomer.tblMaster.colAddType1 = frmQCustomer.tblQCustAddr.colAddType
										Set frmQCustomer.tblMaster.col1st1 = frmQCustomer.tblQCustAddr.colAdd1
										Set frmQCustomer.tblMaster.col2nd1 = frmQCustomer.tblQCustAddr.colAdd2
										Set frmQCustomer.tblMaster.colSuburb1 = frmQCustomer.tblQCustAddr.colSuburb
										Set frmQCustomer.tblMaster.colPostcode1 = frmQCustomer.tblQCustAddr.colPostcode
										Set frmQCustomer.tblMaster.colState1 = frmQCustomer.tblQCustAddr.colState
										Set frmQCustomer.tblMaster.colACode1 = frmQCustomer.tblQCustAddr.colACode
										Set frmQCustomer.tblMaster.colPhNo1 = frmQCustomer.tblQCustAddr.colPhNo
										Set frmQCustomer.tblMaster.colFaxCode1 = frmQCustomer.tblQCustAddr.colFaxCode
										Set frmQCustomer.tblMaster.colFaxNo1 = frmQCustomer.tblQCustAddr.colFaxNo
									Else If nNoAddr = 2
										Set frmQCustomer.tblMaster.colAddType2 = frmQCustomer.tblQCustAddr.colAddType
										Set frmQCustomer.tblMaster.col1st2 = frmQCustomer.tblQCustAddr.colAdd1
										Set frmQCustomer.tblMaster.col2nd2 = frmQCustomer.tblQCustAddr.colAdd2
										Set frmQCustomer.tblMaster.colSuburb2 = frmQCustomer.tblQCustAddr.colSuburb
										Set frmQCustomer.tblMaster.colPostcode2 = frmQCustomer.tblQCustAddr.colPostcode
										Set frmQCustomer.tblMaster.colState2 = frmQCustomer.tblQCustAddr.colState
										Set frmQCustomer.tblMaster.colACode2 = frmQCustomer.tblQCustAddr.colACode
										Set frmQCustomer.tblMaster.colPhNo2 = frmQCustomer.tblQCustAddr.colPhNo
										Set frmQCustomer.tblMaster.colFaxCode2 = frmQCustomer.tblQCustAddr.colFaxCode
										Set frmQCustomer.tblMaster.colFaxNo2 = frmQCustomer.tblQCustAddr.colFaxNo
									Else If nNoAddr = 3
										Set frmQCustomer.tblMaster.colAddType3 = frmQCustomer.tblQCustAddr.colAddType
										Set frmQCustomer.tblMaster.col1st3 = frmQCustomer.tblQCustAddr.colAdd1
										Set frmQCustomer.tblMaster.col2nd3 = frmQCustomer.tblQCustAddr.colAdd2
										Set frmQCustomer.tblMaster.colSuburb3 = frmQCustomer.tblQCustAddr.colSuburb
										Set frmQCustomer.tblMaster.colPostcode3 = frmQCustomer.tblQCustAddr.colPostcode
										Set frmQCustomer.tblMaster.colState3 = frmQCustomer.tblQCustAddr.colState
										Set frmQCustomer.tblMaster.colACode3 = frmQCustomer.tblQCustAddr.colACode
										Set frmQCustomer.tblMaster.colPhNo3 = frmQCustomer.tblQCustAddr.colPhNo
										Set frmQCustomer.tblMaster.colFaxCode3 = frmQCustomer.tblQCustAddr.colFaxCode
										Set frmQCustomer.tblMaster.colFaxNo3 = frmQCustomer.tblQCustAddr.colFaxNo
									Else If nNoAddr = 4
										Set frmQCustomer.tblMaster.colAddType4 = frmQCustomer.tblQCustAddr.colAddType
										Set frmQCustomer.tblMaster.col1st4 = frmQCustomer.tblQCustAddr.colAdd1
										Set frmQCustomer.tblMaster.col2nd4 = frmQCustomer.tblQCustAddr.colAdd2
										Set frmQCustomer.tblMaster.colSuburb4 = frmQCustomer.tblQCustAddr.colSuburb
										Set frmQCustomer.tblMaster.colPostcode4 = frmQCustomer.tblQCustAddr.colPostcode
										Set frmQCustomer.tblMaster.colState4 = frmQCustomer.tblQCustAddr.colState
										Set frmQCustomer.tblMaster.colACode4 = frmQCustomer.tblQCustAddr.colACode
										Set frmQCustomer.tblMaster.colPhNo4 = frmQCustomer.tblQCustAddr.colPhNo
										Set frmQCustomer.tblMaster.colFaxCode4 = frmQCustomer.tblQCustAddr.colFaxCode
										Set frmQCustomer.tblMaster.colFaxNo4 = frmQCustomer.tblQCustAddr.colFaxNo
							Return TRUE
						If NOT bOk
							Return FALSE
			On SAM_ReportFinish
				If bPrintNPAs
					If bSqlHandle
						Call SqlDisconnect( hSqlHandle )
					If bNPALabelFile
						Call SalFileClose( hNPALabelFile )

				String: sDlgCusttypeHelpFileName = 'g:\\apps\\gupta\\help\\custtype.hlp'
				String: sFrmLabelChargeHelpFileName = 'g:\\apps\\gupta\\help\\lblchgsl.hlp'
				String: sDlgCustAddHelpFileName = 'g:\\apps\\gupta\\help\\custadd.hlp'
				String: sDlgCustContHelpFileName = 'g:\\apps\\gupta\\help\\custcont.hlp'

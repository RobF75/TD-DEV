				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						Call SalDisableWindow( hWndForm )
						Call SalWaitCursor( TRUE )
						Call SalSendMsg( cmbHailYear, SAM_Validate, 0, 0 )
						Call PushNumber( nHailYear )
						Call PushNumber( nQtr )
						Call SalEndDialog( hWndForm, nOk )

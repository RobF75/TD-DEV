					Menu Item Name:
				Menu Separator
				Menu Item: Generate &Mail Merge
					Resource Id: 3754
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when: bShowQueryOk = FALSE
						Checked when:
					Menu Actions
						Select Case nWhichTableActive
							Case nCustomerTbl
								If hWndMailMerge = hWndNULL
									Set hWndMailMerge = SalCreateWindow( dlgMailMerge, hWndForm, tblQCustomer )
								Else
									Call SalSendMsg( hWndMailMerge, PAM_CREATECOMPLETE, 0, 0 )
							Case nCustAddrTbl
								If hWndMailMerge = hWndNULL
									Set hWndMailMerge = SalCreateWindow( dlgMailMerge, hWndForm, tblQCustAddr )
								Else
									Call SalSendMsg( hWndMailMerge, PAM_CREATECOMPLETE, 0, 0 )
								Break
							Case nCustContTbl
								If hWndMailMerge = hWndNULL
									Set hWndMailMerge = SalCreateWindow( dlgMailMerge, hWndForm, tblQCustCont )
								Else
									Call SalSendMsg( hWndMailMerge, PAM_CREATECOMPLETE, 0, 0 )
						! If IDOK =  SalMessageBox( 'The merge file generated will be 
								f:\\data\\amipro\\lan\\mailmrg.csv
								The format of the Comma Separated Value File is :-
								Name, Address_Line_1,
								Address_Line_2, Suburb, State, Postcode', 'NOTE', MB_OkCancel )
							      Call SalSendMsg( hWndForm, PAM_PRINTMAILMRG, 0, 0 )
					Menu Item Name:
				! Menu Item: Generate &Order Form Merge File
					      Keyboard Accelerator: (none)
					      Status Text: 
					      Menu Settings 
						      Enabled when: bShowQueryOk = FALSE
						      Checked when: 
					      Menu Actions 
						      If IDOK =  SalMessageBox( 'The merge file generated will be 
								f:\\data\\amipro\\lan\\orderfrm.csv
								The format of the Comma Separated Value File is :-
								First_Name, Surname, Address_Line_1,
								Address_Line_2, Suburb, State, Postcode,
								ShipAddress_Line_1, ShipAddress_Line_2, ShipSuburb, ShipState, ShipPostcode,
								 Custno', 'NOTE', MB_OkCancel )
							      Call SalSendMsg( hWndForm, PAM_PRINTORDERFORM, 0, 0 )
					      Menu Item Name: 
				! Menu Item: Generate Orchardists &Merge File
					      Keyboard Accelerator: (none)
					      Status Text: 
					      Menu Settings 
						      Enabled when: bShowQueryOk = FALSE
						      Checked when: 
					      Menu Actions 
						      If IDOK =  SalMessageBox( 'The merge file generated will be 
								f:\\data\\amipro\\lan\\orchdist.csv
								The format of the Comma Separated Value File is :-
								First_Name, Surname, Address_Line_1,
								Address_Line_2, Suburb, State, Postcode,
								ShipAddress_Line_1, ShipAddress_Line_2, ShipSuburb, ShipState, ShipPostcode,
								 Custno', 'NOTE', MB_OkCancel )
							      Call SalSendMsg( hWndForm, PAM_PRINTORCHARDISTS, 0, 0 )
					      Menu Item Name: 
				Menu Separator
				Menu Item: Customer Contacts + Addresses
					Resource Id: 3757
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when: bShowQueryOk = FALSE
						Checked when:
					Menu Actions
						! Select Case nWhichTableActive
							      Case nCustomerTbl
								      If SalTblAnyRows( frmQCustomer.tblQCustomer, ROW_Selected, 0 )
									      If IDCANCEL = SalMessageBox( 'Only the selected customers will have their contacts and addresses printed.', 'Warning', MB_IconHand | MB_OkCancel )
										      Set bSelectedRows = FALSE
									      Else 
										      Set bSelectedRows = TRUE
									      Break 
							      Case nCustAddrTbl
								      If SalTblAnyRows( frmQCustomer.tblQCustAddr, ROW_Selected, 0 )
									      If IDCANCEL = SalMessageBox( 'All Customers will have their contacts and addresses printed.', 'Warning', MB_IconHand | MB_OkCancel )
										      Set bSelectedRows = FALSE
									      Else 
										      Set bSelectedRows = TRUE
									      Break 
							      Case nCustContTbl
								      If SalTblAnyRows( frmQCustomer.tblQCustCont, ROW_Selected, 0 )
									      If IDCANCEL = SalMessageBox( 'All Customers will have their contacts and addresses printed.', 'Warning', MB_IconHand | MB_OkCancel )
										      Set bSelectedRows = FALSE
									      Else 
										      Set bSelectedRows = TRUE
									      Break 
						If SalModalDialog( dlgCustDets, hWndForm )
							Call SalWaitCursor( TRUE )
							Call PopString( sSelectedRegionIds, TRUE )
							Call PopString( tblMaster.sPreBuildWhere, TRUE )
							Call SalSendMsg( frmQCustomer, PAM_PRINTCUSTDETS, 0, 0 )
						Else
							Call SalWaitCursor( FALSE )
					Menu Item Name:
				Menu Separator
				! Menu Item: &Non-Prop Agreements
					      Keyboard Accelerator: (none)
					      Status Text: 
					      Menu Settings 
						      Enabled when: bShowQueryOk = FALSE
						      Checked when: 
					      Menu Actions 
						      If nOk = SalModalDialog( dlgGenNPAReport, hWndForm )
							      Call PopNumber( nQtr, TRUE )
							      Call PopNumber( nYear, TRUE )
							      Call SalPostMsg( hWndForm, PAM_PRINTNPAS, TRUE, 0 )
						      Else 
							      Call SalWaitCursor( FALSE )
					      Menu Item Name: 
				! Menu Item: &Hail Damaged Letters
					      Keyboard Accelerator: (none)
					      Status Text: 
					      Menu Settings 
						      Enabled when: 
						      Checked when: 
					      Menu Actions 
						      If nOk = SalModalDialog( dlgGenHailReport, hWndForm )
							      Call PopNumber( nQtr, TRUE )
							      Call PopNumber( nYear, TRUE )
							      Call SalPostMsg( hWndForm, PAM_PRINTHAILDAMAGE, TRUE, 0 )
						      Else 
							      Call SalWaitCursor( FALSE )

			Pushbutton: pbOk
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Generate Customer Listing - Enter
				Window Location and Size
					Left:   0.138"
					Top:    2.219"
					Width:  3.025"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: Enter
				Font Name: Default
				Font Size: Default
				Font Enhancement: Italic
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						! If rbCustNoRange OR rbAlphaRange
							     If SalQueryFieldEdit( dfAlphaFrom )
								     If NOT SalQueryFieldEdit( dfAlphaTo )
									     Set dfAlphaTo = 'ZZZZZZZZ'
								     Set bgOrderByName = TRUE
							     Else If SalQueryFieldEdit( dfAlphaTo )
								     Set bgOrderByName = TRUE
								     Set dfAlphaFrom = 'AAAAAAAAA'
							     Else If SalQueryFieldEdit( dfCustnoFrom )
								     If SalQueryFieldEdit( dfCustnoTo )
									     Call SalNumberToStr( dfCustnoFrom, 0, sCustnoFrom )
									     Call SalNumberToStr( dfCustnoTo, 0, sCustnoTo )
								     Else 
									     Call SalNumberToStr( dfCustnoFrom, 0, sCustnoFrom )
									     Call SalNumberToStr( 999999, 0, sCustnoTo )
							     Else If SalQueryFieldEdit( dfCustnoTo )
								     Call SalNumberToStr( 1, 0, sCustnoFrom )
								     Call SalNumberToStr( dfCustnoTo, 0, sCustnoTo )
							     Else 
								     Call SalNumberToStr( 1, 0, sCustnoFrom )
								     Call SalNumberToStr( 999999, 0, sCustnoTo )
							     If bgOrderByName
								     Call PushString( " WHERE @UPPER(CUSTOMER_MASTER.CUST_NAME)  
										BETWEEN '"||dfAlphaFrom||"' AND '"||dfAlphaTo||"'" )
							     Else 
								     Call PushString( ' WHERE CUSTOMER_MASTER.CUST_NO 
										BETWEEN '||sCustnoFrom||' AND '||sCustnoTo )
						! Else
							     Set bgOrderByName = TRUE
							     Call PushString( " WHERE CUSTOMER_MASTER.CUSTOMER_TYPE LIKE '%"||dfCustType||"%' " )
						!
						Set sSql = ' WHERE '
						Set bFirst = TRUE
						If NOT SalIsNull( dfAlphaFrom ) OR NOT SalIsNull( dfAlphaTo )
							If SalIsNull( dfAlphaTo )
								Set dfAlphaTo = 'ZZZZZZZZ'
							If SalIsNull( dfAlphaFrom )
								Set dfAlphaFrom = 'AAAAAAAAA'
							Set sSql = sSql || " @UPPER(CUSTOMER_MASTER.CUST_NAME)  
									BETWEEN '"||dfAlphaFrom||"' AND '"||dfAlphaTo||"'"
							Set bFirst = FALSE
						!
						If NOT SalIsNull( dfCustnoFrom ) OR NOT SalIsNull( dfCustnoTo )
							If SalIsNull( dfCustnoTo )
								Set dfCustnoTo = 999999
							If SalIsNull( dfCustnoFrom )
								Set dfCustnoFrom = 1
							Call SalNumberToStr( dfCustnoFrom, 0, sCustnoFrom )
							Call SalNumberToStr( dfCustnoTo, 0, sCustnoTo )
							!
							If NOT bFirst
								Set sSql = sSql || ' AND '
							Set sSql = sSql || ' CUSTOMER_MASTER.CUST_NO 
									BETWEEN '||sCustnoFrom||' AND '||sCustnoTo
							Set bFirst = FALSE
						Else
							Set dfCustnoFrom = 1
							Set dfCustnoTo = 999999
						!
						If NOT SalIsNull( dfCustType )
							If NOT bFirst
								Set sSql = sSql || ' AND '
							Set sSql = sSql || " CUSTOMER_MASTER.CUSTOMER_TYPE LIKE '%"||dfCustType||"%' "
							Set bFirst = FALSE
						!
						If SalSendMsg( tblQRegions, PAM_GetSelectedRegions, 0, 0 )
							Call PopString( sSelectedRegionIds, TRUE )
						Else
							Set sSelectedRegionIds = ''
						!
						If rbSortByCustNo
							Set bgOrderByName = FALSE
						Else
							Set bgOrderByName = TRUE
						Call PushString( sSql )
						Call PushString( sSelectedRegionIds )
						Call SalEndDialog( hWndForm, TRUE )

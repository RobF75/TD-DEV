							On PAM_WHEREPOPULATE
								If sPreBuildWhere = ''
									Set sBuildWhere = ' WHERE CUSTOMER_MASTER.CUST_NO = CUSTOMER_CONTACTS.CUST_NO '
								Else
									Set sBuildWhere = ' WHERE CUSTOMER_MASTER.CUST_NO = CUSTOMER_CONTACTS.CUST_NO AND ' || sPreBuildWhere 
							On PAM_QBE
								Call PushString( NOTHINGFOLLOWING )
								Call PushString( 'CUSTOMER_MASTER.CUST_NO = CUSTOMER_CONTACTS.CUST_NO ' )

				Font Enhancement: Default
				Text Color: Dark Blue
				Background Color: Default
				Input Mask: Unformatted
				List Initialization
				Message Actions
					On SAM_Validate
						Set nHailYear = SalStrToNumber( cmbHailYear )
					On SAM_DropDown
						Call SalListClear( hWndItem )
						Set sSql = 'SELECT DISTINCT Year_Of_Sale FROM Customer_Order'
						Call SalListPopulate( hWndItem, hLocalSqlA, sSql )
					On SAM_Create
						Set nHailYear = OurDateYear( SalDateCurrent(  ) )
						Set nQtr = SalDateQuarter( SalDateCurrent(  ) )
						! If nQtr = 4
							      Set nHailYear = nHailYear + 1
						Call SalNumberToStr( nHailYear, 0, cmbHailYear )
			Pushbutton: pbOk
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:

				Functions
				Window Variables
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set sSQLPopHandle = 'SELECT 
								  Cust_Cancellation.Cust_No, 
								  Customer_Master.Cust_Name, 
								  Cust_Cancellation.Canc_DT, 
								  Cust_Cancellation.Cultivar_Desc, 
								  Cust_Cancellation.Root_Id, 
								  Cust_Cancellation.Canc_Reason, 
								  Cust_Cancellation.Ord_Amt, 
								  Cust_Cancellation.Conf_Amt, 
								  Cust_Cancellation.Year_Of_Sale, 
								  Cust_Cancellation.Order_Date, 
								  Cust_Cancellation.Contract_Price, 
								  Cust_Cancellation.Sale_Cat, 
								  Cust_Cancellation.Orig_order_book_no, 
								  Cust_Cancellation.Del_order_book_no, 
								  Cust_Cancellation.Canc_By 
								FROM 
								  Cust_Cancellation, Customer_Master 
								WHERE 
								  Cust_Cancellation.Cust_No = Customer_Master.Cust_No'
						Set sNAMEPopHandle = 'CUSTCANCEL'
						Set sBINDPopHandle = ''
						Set sINTOPopHandle = ':colCustNo, 
								:colCustName, 
								:colCancelDT, 
								:colCultDesc, 
								:colRootId, 
								:colReason, 
								:colOrdAmt, 
								:colConfAmt, 
								:colYearOfSale, 
								:colOrdDate, 
								:colContPrice, 
								:colSaleCat, 
								:colOrigOrderBookNo, 
								:colCancelBookNo, 
								:colCanceledBy'
						!
						Set sSQLRefreshHandle = ''
						Set sNAMERefreshHandle = ''
						Set sBINDRefreshHandle = ''
						Set sINTORefreshHandle = ''
						!
						Set sSQLInsertHandle = ''
						Set sNAMEInsertHandle = ''
						Set sBINDInsertHandle = ''
						Set sINTOInsertHandle = ''
						!
						Set sSQLUpdateHandle = ''
						Set sNAMEUpdateHandle = ''
						Set sBINDUpdateHandle = ''
						Set sINTOUpdateHandle = ''
						!
						Set sSQLDeleteHandle = ''
						Set sNAMEDeleteHandle = ''
						Set sBINDDeleteHandle = ''
						Set sINTODeleteHandle = ''
						!
						Set bAddAllowed = FALSE
						Set bSaveAllowed = FALSE
						Set bDeleteAllowed = FALSE
						Set bUnDeleteAllowed = FALSE
						Set bRepopulateAllowed = TRUE
						Set bClearSelectAllowed = TRUE
						Set bQueryAllowed = TRUE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = TRUE
						!
						Set bSelectFirstRow = FALSE
						!
						Set nTableFillType = TBL_FillNormal
						!
						Set sQueryDialogName = 'dlgQueryCustCancellation'

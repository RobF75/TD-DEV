  Substitutes.Subs_Added_DT, 
  Substitutes.Substitute_Item_No, 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Substitutes.Subs_Priority, 
  Substitutes.Sub_Up_To_Max 
FROM 
  Substitutes, 
  Stock_Item 
WHERE 
  Substitutes.Stock_Item_No = :1 AND 
  Substitutes.Substitute_Item_No = Stock_Item.Item_No 
ORDER BY 
  Substitutes.Subs_Priority'

.head 3 +  On SAM_AppStartup
.head 4 +  If strArgArray[0] = ''
.head 5 -  Set SqlDatabase = 'STOCKDEV'
.head 5 -  Set SqlUser = 'JAN'
.head 5 -  Set SqlPassword = 'JAN'
.head 4 +  Else
.head 5 -  Set SqlDatabase = strArgArray[1]
.head 5 -  Set SqlUser = strArgArray[2]
.head 5 -  Set SqlPassword = strArgArray[3]
.head 4 -  !
.head 4 -  ! strArgArray[4] = 'Selected load Ids file name ie: c:\\temp\\delivnoti.tmp'
.head 4 -  ! Set strArgArray[4] = 'C:\\TEMP\\DELNOTI.TMP'
.head 4 -  !
.head 4 -  Call CheckProgramExistance( 'Load customers delivery notification', TRUE )
.head 4 -  !
.head 4 -  Call SqlHandlesSetup(  )
.head 4 -  !
.head 4 -  Set sLoadIdCommaList = ''
.head 4 -  Call ReadStrArrayListFromFile( strArgArray[4], saLoadIds )
.head 4 -  Call MakeStringList( saLoadIds, ',', "'", sLoadIdCommaList )
.head 3 +  On SAM_AppExit
.head 4 -  Call SqlHandlesDisconnectClose(  )

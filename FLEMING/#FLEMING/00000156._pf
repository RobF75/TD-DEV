.head 3 -  String: sAddressLine5
.head 2 +  Message Actions
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set sReportType = 'PRINT'
.head 4 -  !
.head 4 -  Set sReportFileNameNoPath = 'delivnoti.qrp'
.head 4 -  Set sReportBind = ':frmNotification.sAddressLine1, 
  :frmNotification.sAddressLine2, 
  :frmNotification.sAddressLine3, 
  :frmNotification.sAddressLine4, 
  :frmNotification.sAddressLine5, 
  :frmNotification.dtShippingDate, 
  :frmNotification.sMainContactFirstName, 
  :frmNotification.sMainContactSurname'
.head 4 -  Set sReportInto = 'sAddressLine1, 
  sAddressLine2, 
  sAddressLine3, 
  sAddressLine4, 
  sAddressLine5, 
  dtShippingDate, 
  sMainContactFirstName, 
  sMainContactSurname'
.head 4 -  !
.head 4 -  Set sReportSql = " SELECT 
  Load.Load_Id, 
  Load.Shipping_Date, 
  Load_Customers.Cust_No,  
  Customer_Master.Cust_Name, 
  Customer_Master.Bus_Name 
FROM 
  Load, 
  Load_Customers,  
  Customer_Master 
INTO 
  :frmNotification.sLoadId, 
  :frmNotification.dtShippingDate, 
  :frmNotification.nCustNo, 
  :frmNotification.sCustName, 
  :frmNotification.sBusName 
WHERE 
  Load.Load_Id IN ( " || sLoadIdCommaList || " ) AND 
  Load.Load_Id = Load_Customers.Load_Id AND 
  ( NOT Load_Customers.Deliv_Noti_Letter = 'Y' OR 
    Load_Customers.Deliv_Noti_Letter IS NULL ) AND 
  Load_Customers.Cust_No = Customer_Master.Cust_No AND 
  EXISTS 
  ( 
    SELECT 
      Customer_Order.Cust_No 
    FROM 
      Customer_Order 
    WHERE 
      Customer_Order.Cust_No = Load_Customers.Cust_No AND 
      Customer_Order.Load_Id = Load.Load_Id AND 
      Customer_Order.Year_Of_Sale = :frmNotification.nYearOfSale 
  ) 
ORDER BY 
  Load.Load_Id, Load_Customers.Sequence_No "
.head 3 +  On SAM_ReportStart
.head 4 -  Set nYearOfSale = OurDateYear( SalDateCurrent(  ) )
.head 4 -  Call SalReportCmd( SalNumberToWindowHandle( wParam ), RPT_CmdPrinterSetup )
.head 4 -  Return SalSendClassMessage( SAM_ReportStart, wParam, lParam )
.head 3 +  On PAM_clsFRM_REPORTFETCHINIT
.head 4 -  Set sLoadId = ''
.head 4 -  Set dtShippingDate = DATETIME_Null
.head 4 -  Set nCustNo = NUMBER_Null
.head 4 -  Set sCustName = ''
.head 4 -  Set sBusName = ''
.head 4 -  Set sBusAddLine1 = ''
.head 4 -  Set sBusAddLine2 = ''
.head 4 -  Set sBusSuburb = ''
.head 4 -  Set sBusState = ''
.head 4 -  Set sBusPostcode = ''
.head 4 -  Set sMainContactFirstName = ''
.head 4 -  Set sMainContactSurname = ''
.head 4 -  Set sAddressLine1 = ''
.head 4 -  Set sAddressLine2 = ''
.head 4 -  Set sAddressLine3 = ''
.head 4 -  Set sAddressLine4 = ''
.head 4 -  Set sAddressLine5 = ''
.head 4 -  !
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFETCHNEXT
.head 4 -  Call SwapSurnameWithFirstname( sCustName )
.head 4 +  ! If bForceChildAddress
.head 5 -  Call GetBusAddressPrivateFunction( nCustNo, dtTmp, sTmp, sAddressL1BA, sAddressL2BA, sSuburbBA, sPostcodeBA, sStateBA, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
.head 4 -  Call GetBusAddress( nCustNo, dtTmp, sTmp, sBusAddLine1, sBusAddLine2, sBusSuburb, sBusPostcode, sBusState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
.head 4 -  Call FixLineSpaceAddress( sCustName, sBusName, sBusAddLine1, sBusAddLine2, sBusSuburb, sBusState, sBusPostcode, sAddressLine1, sAddressLine2, sAddressLine3, sAddressLine4, sAddressLine5 )
.head 4 -  !
.head 4 -  Call GetMainContactName( nCustNo, sMainContactFirstName, sMainContactSurname, SH_cls_Execute )
.head 4 +  If UpdtDelivNotiLetterFlag( sLoadId, nCustNo, 'Y', SH_cls_Execute )
.head 5 -  Call UpdtDelivNotiLetterFlag( '', 0, '', SH_cls_Commit )
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFINISH
.head 4 -  Call GetBusAddress( 0, dtTmp, sTmp, sBusAddLine1, sBusAddLine2, sBusSuburb, sBusPostcode, sBusState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Disconnect )
.head 4 -  Call GetMainContactName( 0, sMainContactFirstName, sMainContactSurname, SH_cls_Disconnect )
.head 4 -  Call UpdtDelivNotiLetterFlag( '', 0, '', SH_cls_Disconnect )
.head 4 -  Return TRUE

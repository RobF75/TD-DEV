						Functions
							Function: CheckTreeTypeExists
								Description:
								Returns
									Boolean:
								Parameters
									String: sTreeType
									Receive Boolean: bExists
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'TRTYPEEXISTS' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Tree_Type 
													FROM Tree_Type  
													WHERE Tree_Type = :1"
											Set sName = 'TRTYPEEXISTS'
											Set sBind = ':sTreeType'
											Set sInto = ''
											!
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set bExists = FALSE
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set bExists = TRUE
												Else
													Set bExists = FALSE
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: CheckItemTreeTypeExists
								Description:
								Returns
									Boolean:
								Parameters
									String: sTreeType
									Receive Boolean: bExists
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'ITMTRTYPEEXISTS' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Tree_Type 
													FROM Stock_Item  
													WHERE Tree_Type = :1"
											Set sName = 'ITMTRTYPEEXISTS'
											Set sBind = ':sTreeType'
											Set sInto = ''
											!
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set bExists = FALSE
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set bExists = TRUE
												Else
													Set bExists = FALSE
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: ExtractTrTypeDenomEffectedDets
								Description:
								Returns
									Boolean:
								Parameters
									String: sTreeType
									Receive String: sTreeTypeDesc
									Receive String: sTypeDesc
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									String: sGotTreeTypeDesc
									String: sGotTypeDesc
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'DENOMTRTYPES' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT 
													  Tree_Type_Desc, 
													  Type_Description 
													FROM 
													  Tree_Type  
													WHERE 
													  Tree_Type = :1 "
											Set sName = 'DENOMTRTYPES'
											Set sBind = ':sTreeType'
											Set sInto = ':sGotTreeTypeDesc, :sGotTypeDesc'
											!
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set sTreeTypeDesc = ''
											Set sTypeDesc = ''
											Set sGotTreeTypeDesc = ''
											Set sGotTypeDesc = ''
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set sTreeTypeDesc = sGotTreeTypeDesc
													Set sTypeDesc = sGotTypeDesc
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: TreeTypeDenormalise
								Description:
								Returns
									Boolean:
								Parameters
									String: sTreeType
									String: sTreeTypeDesc
									String: sTypeDesc
									!
									String: sOldTreeTypeDesc
									String: sOldTypeDesc
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									Boolean: bOk
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SIDENOMTRTPE' )
									Select Case nActionType
										Case SH_cls_Execute
											If sTreeTypeDesc != sOldTreeTypeDesc OR 
													   sTypeDesc != sOldTypeDesc
												Set sSql = " UPDATE Stock_Item 
														SET 
														  Tree_Type_Desc = :2, 
														  Type_Description = :3 
														WHERE 
														  Tree_Type = :1 "
												Set sName = 'SIDENOMTRTPE'
												Set sBind = ':sTreeType, :sTreeTypeDesc, :sTypeDesc'
												Set sInto = ''
												Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
												Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
												!
												If haSqlHandles[ nOurHandleNo ].Execute( )
													Call haSqlHandles[ nOurHandleNo ].Commit( )
													Return TRUE
												Else
													Return FALSE
											Else
												Return TRUE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
						Window Variables
							Boolean: bExists
							String: sOldTreeTypeDesc
							String: sOldTypeDesc
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = 'SELECT Tree_Type, 
										Tree_Type_Desc, 
										When_Ready_Time, 
										When_Ready_Units, 
										Ack_Gen_Message, 
										Ack_Count_Message, 
										ExcFrmStockReports, 
										Type_Description   
										FROM Tree_Type 
										ORDER BY Tree_Type'
								Set sNAMEPopHandle = 'TREETYPEPOP'
								Set sBINDPopHandle = ''
								Set sINTOPopHandle = ':clsdlgTreeTypes.tblTreeTypes.colTreeType, 
										:clsdlgTreeTypes.tblTreeTypes.colTreeDesc, 
										:clsdlgTreeTypes.tblTreeTypes.colWhenRdy, 
										:clsdlgTreeTypes.tblTreeTypes.colRdyUnits, 
										:clsdlgTreeTypes.tblTreeTypes.colCountMessage, 
										:clsdlgTreeTypes.tblTreeTypes.colGeneralMessage,
										:clsdlgTreeTypes.tblTreeTypes.colExcFrmStockReports,
										:clsdlgTreeTypes.tblTreeTypes.colOutsideTreeDesc'
								!
								Set sSQLRefreshHandle = 'SELECT Tree_Type, 
										Tree_Type_Desc, 
										When_Ready_Time, 
										When_Ready_Units, 
										Ack_Gen_Message, 
										Ack_Count_Message, 
										ExcFrmStockReports, 
										Type_Description   
										FROM Tree_Type 
										WHERE Tree_Type = :1 '
								Set sNAMERefreshHandle = 'TREETYPEREF'
								Set sBINDRefreshHandle = ':clsdlgTreeTypes.tblTreeTypes.colTreeType'
								Set sINTORefreshHandle = ':clsdlgTreeTypes.tblTreeTypes.colTreeType, 
										:clsdlgTreeTypes.tblTreeTypes.colTreeDesc, 
										:clsdlgTreeTypes.tblTreeTypes.colWhenRdy, 
										:clsdlgTreeTypes.tblTreeTypes.colRdyUnits, 
										:clsdlgTreeTypes.tblTreeTypes.colCountMessage, 
										:clsdlgTreeTypes.tblTreeTypes.colGeneralMessage,
										:clsdlgTreeTypes.tblTreeTypes.colExcFrmStockReports, 
										:clsdlgTreeTypes.tblTreeTypes.colOutsideTreeDesc'
								!
								Set sSQLInsertHandle = 'INSERT INTO Tree_Type ( 
										Tree_Type, 
										Tree_Type_Desc, 
										When_Ready_Time, 
										When_Ready_Units, 
										Ack_Gen_Message, 
										Ack_Count_Message, 
										ExcFrmStockReports, 
										Type_Description   ) 
										VALUES ( :1, :2, :3, :4, :5, :6, :7, :8 ) '
								Set sNAMEInsertHandle = 'TREETYPEINS'
								Set sBINDInsertHandle = ':clsdlgTreeTypes.tblTreeTypes.colTreeType, 
										:clsdlgTreeTypes.tblTreeTypes.colTreeDesc, 
										:clsdlgTreeTypes.tblTreeTypes.colWhenRdy, 
										:clsdlgTreeTypes.tblTreeTypes.colRdyUnits, 
										:clsdlgTreeTypes.tblTreeTypes.colCountMessage, 
										:clsdlgTreeTypes.tblTreeTypes.colGeneralMessage,
										:clsdlgTreeTypes.tblTreeTypes.colExcFrmStockReports, 
										:clsdlgTreeTypes.tblTreeTypes.colOutsideTreeDesc'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = 'UPDATE Tree_Type SET Tree_Type_Desc = :2, 
										When_Ready_Time = :3, 
										When_Ready_Units = :4, 
										Ack_Gen_Message = :5, 
										Ack_Count_Message = :6, 
										ExcFrmStockReports = :7, 
										Type_Description = :8  
										WHERE Tree_Type = :1'
								Set sNAMEUpdateHandle = 'TREETYPEUPDT'
								Set sBINDUpdateHandle = ':clsdlgTreeTypes.tblTreeTypes.colTreeType, 
										:clsdlgTreeTypes.tblTreeTypes.colTreeDesc, 
										:clsdlgTreeTypes.tblTreeTypes.colWhenRdy, 
										:clsdlgTreeTypes.tblTreeTypes.colRdyUnits, 
										:clsdlgTreeTypes.tblTreeTypes.colCountMessage, 
										:clsdlgTreeTypes.tblTreeTypes.colGeneralMessage,
										:clsdlgTreeTypes.tblTreeTypes.colExcFrmStockReports, 
										:clsdlgTreeTypes.tblTreeTypes.colOutsideTreeDesc'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = 'DELETE FROM Tree_Type WHERE Tree_Type = :1 '
								Set sNAMEDeleteHandle = 'TREETYPEDEL'
								Set sBINDDeleteHandle = ':clsdlgTreeTypes.tblTreeTypes.colTreeType'
								Set sINTODeleteHandle = ''
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								Set bQueryAllowed = FALSE
								Set bReportAllowed = FALSE
								Set bOrderAllowed = TRUE
							On SAM_Destroy
								Call CheckTreeTypeExists( '', bExists, SH_cls_Disconnect )
								Call CheckItemTreeTypeExists( '', bExists, SH_cls_Disconnect )
								Call ExtractTrTypeDenomEffectedDets( '', sOldTreeTypeDesc, sOldTypeDesc, SH_cls_Disconnect )
								Call TreeTypeDenormalise( '', '', '', '', '', SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
				Derived From
					Class: clsDialogChildTable

							Column: colTreeType
								Class Child Ref Key: 0
								Class ChildKey: 17
								Class: clsColumnGeneral
								Property Template:
								Class DLL Name:
								Title: Tree Type
								Visible? Class Default
								Editable? Class Default
								Maximum Data Length: 8
								Data Type: Class Default
								Justify: Class Default
								Width:  0.875"
								Width Editable? Class Default
								Format: Uppercase
								Country: Class Default
								Input Mask: Class Default
								Cell Options
									Cell Type? Class Default
									Multiline Cell? Class Default
									Cell DropDownList
										Sorted? Class Default
										Vertical Scroll? Class Default
										Auto Drop Down? Class Default
										Allow Text Editing? Class Default
									Cell CheckBox
										Check Value:
										Uncheck Value:
										Ignore Case? Class Default
								List Values
								Message Actions
									On PAM_cls_SETINSTANCEVARS
										Set colTreeType.bOrderBy = TRUE
									On PAM_clsTBL_EDITCHECK
										If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
											Return TRUE
										Else
											Return FALSE
									On PAM_clsTBL_DATAVAL
										If SalIsNull( hWndItem )
											Call ErrorMessage( 'Please enter a Tree Type first!', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE
									On PAM_clsTBL_CHECKROWNEW
										Call CheckTreeTypeExists( colTreeType, bExists, SH_cls_Disconnect )
										If bExists
											Call ErrorMessage( 'Tree Type is already in use by some stock items.  Cannot add.', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE
									On PAM_clsTBL_CHECKROWDELETED
										Call CheckItemTreeTypeExists( colTreeType, bExists, SH_cls_Disconnect )
										If bExists
											Call ErrorMessage( 'Tree Type is still in use by a stock item.  Cannot delete.', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE
									On PAM_clsTBL_CHECKROWEDITED
										Return ExtractTrTypeDenomEffectedDets( colTreeType, sOldTreeTypeDesc, sOldTypeDesc, SH_cls_Execute )
									On PAM_clsTBL_ROWUPDATED
										Return TreeTypeDenormalise( colTreeType, colTreeDesc, colOutsideTreeDesc, sOldTreeTypeDesc, sOldTypeDesc, SH_cls_Execute )

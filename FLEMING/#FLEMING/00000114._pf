				Property Template:
				Class DLL Name:
				Description:
				Derived From
					Class: clspbPickInto
				Class Variables
					String: sTmp
					Number: nTmp
					Window Handle: hWndTmp
				Instance Variables
					! PUBLIC
					Window Handle: hWndPickIntoTable
					! PRIVATE
					String: sTreeType
					String: sTreeDesc
					String: sTypeDescription
				Functions
					Function: GetTreeTypeFields
						Description:
						Returns
							Boolean:
						Parameters
							Receive String: sNewTreeType
							Receive String: sNewTreeDesc
							Receive String: sNewTypeDescription
						Static Variables
						Local variables
						Actions
							Set sNewTreeType = sTreeType
							Set sNewTreeDesc = sTreeDesc
							Set sNewTypeDescription = sTypeDescription
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbTreeTypes.nActivateWindowType = ACTIVATE_DialogModal
						Set clspbTreeTypes.sActivateDialogName = 'dlgTreeTypes'
						Set clspbTreeTypes.hWndTable = hWndPickIntoTable
						Set clspbTreeTypes.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushWndHdl( hWndItem )
						Return TRUE
					On PAM_clsPICK_LOOKUP
						Call PopString( sTypeDescription, TRUE )
						Call PopString( sTreeDesc, TRUE )
						Call PopString( sTreeType, TRUE )
						Call SalSendMsg( hWndItem, PAM_cls_GETFIELDS, 0, 0 )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopWndHdl( hWndTmp, TRUE )
						Return TRUE

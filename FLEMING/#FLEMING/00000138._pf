			!
			Boolean: bProcessHistTrans
			Boolean: bProcessTrans
			Boolean: bProcessOrders
			Boolean: bFetchedOrders
			!
			String: sSql
			String: sName
			String: sBinds
			String: sIntos
			Number: nInd
			!
			Number: nCustNo
			String: sCustName
			Number: nCreditNoteNo
			String: sReferenceId
			Date/Time: dtTransDate
			Number: nTransAmount
			String: sTransNotes
			Number: nLabelCharges
			Number: nPostalCharges
			Number: nRailCharges
			Number: nFreightCharges
			Number: nNoTreesCredited
			Number: nTreesCreditedAmount
			Number: nInvoiceNo
			Date/Time: dtInvoiceDate
			String: sTreeTypeDesc
			String: sCultDesc
			String: sRootDesc
			Number: nTotalTreesCredited
			Number: nTotalCreditedAmount
			!
			: hSqlTransHdl
				Class: hcSqlHandle
			: hSqlHistTransHdl
				Class: hcSqlHandle
			: hSqlOrdersHdl
				Class: hcSqlHandle
			!
			String: sCompany
		Message Actions
			On SAM_CreateComplete
				Set dfFromDate = SalDateMonthBegin( SalDateCurrent(  ) )
				Set dfToDate = SalDateCurrent(  )
				If strArgArray[0] = ''
					Set sCompany = 'F'
				Else
					Set sCompany = strArgArray[4]
				Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
			On PAM_CRNOTE_REPORT
				Set sReportName = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\credlst4.qrp'
				Set sReportBinds = ':dlgCreditNoteListing.nCustNo, 
						:dlgCreditNoteListing.sCustName, 
						:dlgCreditNoteListing.dfFromDate,
						:dlgCreditNoteListing.dfToDate, 
						:dlgCreditNoteListing.nCreditNoteNo, 
						:dlgCreditNoteListing.sReferenceId, 
						:dlgCreditNoteListing.dtTransDate, 
						:dlgCreditNoteListing.nTransAmount, 
						:dlgCreditNoteListing.sTransNotes, 
						:dlgCreditNoteListing.nLabelCharges, 
						:dlgCreditNoteListing.nPostalCharges, 
						:dlgCreditNoteListing.nRailCharges, 
						:dlgCreditNoteListing.nFreightCharges, 
						:dlgCreditNoteListing.nNoTreesCredited, 
						:dlgCreditNoteListing.nTreesCreditedAmount, 
						:dlgCreditNoteListing.sTreeTypeDesc, 
						:dlgCreditNoteListing.sCultDesc, 
						:dlgCreditNoteListing.sRootDesc, 
						:dlgCreditNoteListing.nInvoiceNo, 
						:dlgCreditNoteListing.dtInvoiceDate, 
						:dlgCreditNoteListing.nTotalTreesCredited, 
						:dlgCreditNoteListing.nTotalCreditedAmount,
						:sCompany'
				Set sReportInputs = 'CustNo, 
						CustName, 
						FromDate, 
						ToDate, 
						CreditNoteNo, 
						ReferenceId, 
						TransDate, 
						TransAmount, 
						TransNotes, 
						LabelCharges, 
						PostalCharges, 
						RailCharges, 
						FreightCharges, 
						NoTreesCredit,
						TreesCreditedAmount, 
						TreeTypeDesc, 
						CultDesc, 
						RootDesc, 
						InvoiceNo,  
						InvDate, 
						TotalTreesCredited, 
						TotalCreditedAmount,
						Company'
				Set nError = 1
				Call SalReportPrint( hWndForm, sReportName, sReportBinds, sReportInputs, 1, RPT_PrintAll | RPT_PrintNoWarn, 0, 0, nError )
			On SAM_ReportStart
				Set sSql = 'SELECT 
						  Transaction.Cust_No, 
						  Customer_Master.Cust_Name, 
						  Transaction.Credit_Note_No, 
						  Transaction.Reference_Id, 
						  Transaction.Transaction_Date, 
						  Transaction.Transaction_Amount, 
						  Transaction.Transaction_Notes, 
						  Transaction.Label_Charges, 
						  Transaction.Postal_Charges, 
						  Transaction.Rail_Charges,
						  Transaction.Freight_Charges 
						FROM 
						  Transaction, 
						  Customer_Master
						WHERE
						  Transaction.Transaction_Date >= :1 AND
						  Transaction.Transaction_Date <= :2 AND 
						  Transaction.Cust_No = Customer_Master.Cust_No AND 
						  NOT Transaction.Credit_Note_No IS NULL  and
						Transaction.Company = :3
						ORDER BY 
						  Transaction.Credit_Note_No'
				Set sName = 'TRANSCREDLSTC'
				Set sBinds = ':dfFromDate, :dfToDate, :sCompany'
				Set sIntos = ':nCustNo, 
						:sCustName, 
						:nCreditNoteNo, 
						:sReferenceId, 
						:dtTransDate, 
						:nTransAmount, 
						:sTransNotes, 
						:nLabelCharges, 
						:nPostalCharges, 
						:nRailCharges, 
						:nFreightCharges'
				Call hSqlTransHdl.Setup( sSql, sName, sBinds, sIntos )
				Call SqlVarSetup( hSqlTransHdl.hSqlHandle )
				!
				Set sSql = 'SELECT 
						  Trans_History.Cust_No, 
						  Customer_Master.Cust_Name, 
						  Trans_History.Credit_Note_No, 
						  Trans_History.Hist_Reference_Id, 
						  Trans_History.Hist_Trans_Date, 
						  Trans_History.Hist_Trans_Amount, 
						  Trans_History.Hist_Trans_Notes, 
						  Trans_History.Hist_Label_Charges, 
						  Trans_History.Hist_Postal_Charge, 
						  Trans_History.Hist_Rail_Charges,
						  Trans_History.Hist_Freight_Charg 
						FROM 
						  Trans_History, 
						  Customer_Master
						WHERE
						  Trans_History.Hist_Trans_Date >= :1 AND
						  Trans_History.Hist_Trans_Date <= :2 AND 
						  Trans_History.Cust_No = Customer_Master.Cust_No AND 
						  NOT Trans_History.Credit_Note_No IS NULL and
						Trans_History.Hist_Company = :3
						ORDER BY 
						  Trans_History.Credit_Note_No'
				Set sName = 'TRHISTCREDLSTC'
				Set sBinds = ':dfFromDate, :dfToDate, :sCompany'
				Set sIntos = ':nCustNo, 
						:sCustName, 
						:nCreditNoteNo, 
						:sReferenceId, 
						:dtTransDate, 
						:nTransAmount, 
						:sTransNotes, 
						:nLabelCharges, 
						:nPostalCharges, 
						:nRailCharges, 
						:nFreightCharges'
				Call hSqlHistTransHdl.Setup( sSql, sName, sBinds, sIntos )
				Call SqlVarSetup( hSqlHistTransHdl.hSqlHandle )
				!
				Set sSql = 'SELECT 
						  Customer_Order.No_Trees_Credited, 
						  Customer_Order.Credited_Amount, 
						  Customer_Order.Invoice_No, 
						  Customer_Order.Invoiced_Date, 
						  Stock_Item.Tree_Type_Desc, 
						  Stock_Item.Cult_Desc, 
						  Stock_Item.Root_Desc
						FROM 
						  Customer_Order,  
						  Stock_Item 
						WHERE
						  Customer_Order.Credit_Note_No = :1 AND
						  Customer_Order.Stock_Item_No = Stock_Item.Item_No
						UNION
						SELECT 
						  Cust_Order_History.No_Trees_Credited, 
						  Cust_Order_History.Credited_Amount, 
						  Cust_Order_History.Invoice_No, 
						  Cust_Order_History.Invoiced_Date, 
						  Stock_Item.Tree_Type_Desc, 
						  Stock_Item.Cult_Desc, 
						  Stock_Item.Root_Desc
						FROM 
						  Cust_Order_History,  
						  Stock_Item 
						WHERE
						  Cust_Order_History.Credit_Note_No = :1 AND
						  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No'
				Set sName = 'CREDORDDETSU'
				Set sBinds = ':nCreditNoteNo'
				Set sIntos = ':nNoTreesCredited, 
						:nTreesCreditedAmount, 
						:nInvoiceNo, 
						:dtInvoiceDate, 
						:sTreeTypeDesc, 
						:sCultDesc, 
						:sRootDesc'
				Call hSqlOrdersHdl.Setup( sSql, sName, sBinds, sIntos )
				Call SqlVarSetup( hSqlOrdersHdl.hSqlHandle )
				Return TRUE
			On SAM_ReportFetchInit
				Call hSqlTransHdl.Execute( )
				Call hSqlHistTransHdl.Execute( )
				Set bProcessHistTrans = TRUE
				Set bProcessTrans = FALSE
				Set bProcessOrders = FALSE
				Set nTotalTreesCredited = NUMBER_Null
				Set nTotalCreditedAmount = NUMBER_Null
				Return TRUE
			On SAM_ReportFetchNext
				Loop
					If bProcessHistTrans AND NOT bProcessOrders 
						Call ClearAllReportFields( nCustNo, sCustName, nCreditNoteNo, sReferenceId, dtTransDate,
								nTransAmount, sTransNotes, nLabelCharges, nPostalCharges, nRailCharges, nFreightCharges, nNoTreesCredited,
								nTreesCreditedAmount, nInvoiceNo, dtInvoiceDate, sTreeTypeDesc, sCultDesc, sRootDesc )
						If hSqlHistTransHdl.FetchNext( nInd )
							Set bProcessOrders = TRUE
							Set bFetchedOrders = FALSE
							Set nTotalCreditedAmount = nTotalCreditedAmount + nTransAmount
							Call hSqlOrdersHdl.Execute( )
						Else
							Set bProcessHistTrans = FALSE
							Set bProcessTrans = TRUE
					If bProcessTrans AND NOT bProcessOrders
						Call ClearAllReportFields( nCustNo, sCustName, nCreditNoteNo, sReferenceId, dtTransDate,
								nTransAmount, sTransNotes, nLabelCharges, nPostalCharges, nRailCharges, nFreightCharges, nNoTreesCredited,
								nTreesCreditedAmount, nInvoiceNo, dtInvoiceDate, sTreeTypeDesc, sCultDesc, sRootDesc )
						If hSqlTransHdl.FetchNext( nInd )
							Set bProcessOrders = TRUE
							Set bFetchedOrders = FALSE
							Set nTotalCreditedAmount = nTotalCreditedAmount + nTransAmount
							Call hSqlOrdersHdl.Execute( )
						Else
							Return FALSE
					If bProcessOrders
						Call ClearOrderReportFields( nNoTreesCredited,nTreesCreditedAmount, nInvoiceNo, dtInvoiceDate, 
								sTreeTypeDesc, sCultDesc, sRootDesc )
						If hSqlOrdersHdl.FetchNext( nInd )
							Set bFetchedOrders = TRUE
							Set nTotalTreesCredited = nTotalTreesCredited + nNoTreesCredited
							Return TRUE
						Else If NOT bFetchedOrders
							Set bProcessOrders = FALSE
							Return TRUE
						Else
							Set bProcessOrders = FALSE
			On SAM_ReportFinish
				Call hSqlTransHdl.Disconnect( )
				Call hSqlHistTransHdl.Disconnect( )
				Call hSqlOrdersHdl.Disconnect( )
				Call SalMessageBox( 'Listing Generated!', 'Credit Note Listing', MB_Ok )
				Return TRUE

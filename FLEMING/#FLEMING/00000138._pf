		Application Actions
			On SAM_AppStartup
				If strArgArray[0] = ''
					Set SqlDatabase = 'STOCKDEV'
					Set SqlUser = 'GRAHAM'
					Set SqlPassword = 'GRAHAM'
				Else
					Set SqlDatabase = strArgArray[1]
					Set SqlUser = strArgArray[2]
					Set SqlPassword = strArgArray[3]
				!
				Call CheckProgramExistance( 'Credit Note Listing', TRUE )
				!
				Call SqlHandlesSetup(  )
				!
				Call SalModalDialog( dlgCreditNoteListing, hWndNULL )
			On SAM_AppExit
				Call SqlHandlesDisconnectClose(  )

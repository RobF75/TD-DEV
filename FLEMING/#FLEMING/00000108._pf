.head 9 +  On PAM_cls_SETINSTANCEVARS
.head 10 -  Set colRoyOwnerId.bOrderBy = TRUE
.head 9 +  On PAM_clsTBL_EDITCHECK
.head 10 +  If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 -  Return FALSE
.head 9 +  On PAM_clsTBL_DATAVAL
.head 10 +  If SalIsNull( hWndItem )
.head 11 -  Call ErrorMessage( 'Please enter a Owner ID first!', hWndForm, lParam )
.head 11 -  Return FALSE
.head 10 +  Else
.head 11 -  Return TRUE
.head 9 +  On PAM_clsTBL_CHECKROWNEW
.head 10 -  Call CheckOwnerIdExists( colRoyOwnerId, bExists, SH_cls_Disconnect )
.head 10 +  If bExists
.head 11 -  Call ErrorMessage( 'Owner Id is already in use by some other royalty owner.  Cannot add.', hWndForm, lParam )
.head 11 -  Return FALSE
.head 10 +  Else
.head 11 -  Return TRUE
.head 9 +  On PAM_clsTBL_CHECKROWDELETED
.head 10 -  Call CheckOwnerIdRoyPayExists( colRoyOwnerId, bExists, SH_cls_Disconnect )
.head 10 +  If bExists
.head 11 -  Call ErrorMessage( 'Owner still has royalties assigned to them.  Cannot delete.', hWndForm, lParam )
.head 11 -  Return FALSE
.head 10 +  Else
.head 11 -  Return TRUE

.head 6 +  Message Actions 
.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 -  Set colRoyOwnerId.bOrderBy = TRUE
.head 7 +  On PAM_clsTBL_EDITCHECK
.head 8 +  If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
.head 9 -  Return TRUE
.head 8 +  Else 
.head 9 -  Return FALSE
.head 7 +  On PAM_clsTBL_DATAVAL
.head 8 +  If SalIsNull( hWndItem )
.head 9 -  Call ErrorMessage( 'Please enter a Owner ID first!', hWndForm, lParam )
.head 9 -  Return FALSE
.head 8 +  Else 
.head 9 -  Return TRUE
.head 7 +  On PAM_clsTBL_CHECKROWNEW
.head 8 -  Call CheckOwnerIdExists( colRoyOwnerId, bExists, SH_cls_Disconnect )
.head 8 +  If bExists
.head 9 -  Call ErrorMessage( 'Owner Id is already in use by some other royalty owner.  Cannot add.', hWndForm, lParam )
.head 9 -  Return FALSE
.head 8 +  Else 
.head 9 -  Return TRUE
.head 7 +  On PAM_clsTBL_CHECKROWDELETED
.head 8 -  Call CheckOwnerIdRoyPayExists( colRoyOwnerId, bExists, SH_cls_Disconnect )
.head 8 +  If bExists
.head 9 -  Call ErrorMessage( 'Owner still has royalties assigned to them.  Cannot delete.', hWndForm, lParam )
.head 9 -  Return FALSE
.head 8 +  Else 
.head 9 -  Return TRUE

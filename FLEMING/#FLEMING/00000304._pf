				  Functions 
				  Window Variables 
				  Message Actions 
					  On PAM_SETINSTANCEVARS
						  Set sSQLTABLENAME = ''
						!
						  If frmPrintOutstandingNPAs.nYear < OurDateYear( SalDateCurrent(  ) )
							  Set sSQLPOPTABLENAME = 'CUST_ORDER_HISTORY, STOCK_ITEM'
						  Else 
							  Set sSQLPOPTABLENAME = 'CUSTOMER_ORDER, STOCK_ITEM'
						!
						  Set sROWID = ''
						  Set sSQLWHERE = " WHERE Stock_Item_No = Stock_Item.Item_No AND 
								Year_Of_Sale = :frmPrintOutstandingNPAs.nYear AND 
								Cust_No = :frmPrintOutstandingNPAs.tblCust.colCustNo AND 
								NOT NPA_Recd_Flag = 'Y' "
						  Set sORDERBY = ''
					  On PAM_NOROWS
						  Return TRUE
			  Pushbutton: pbExit
				  Message Actions 
			  Frame 
			  Pushbutton: pbItemEnq
				  Message Actions 
		  Functions 
			  Function: GetLoadDesc
				  Description: 
				  Returns 
					  Boolean: 
				  Parameters 
					  String: sLoadId
					  Receive String: sLoadDesc
					  Number: nActionType
				  Static Variables 
					  : fcOurHandle
				  Local variables 
					  String: sSql
					  String: sBind
					  String: sInto
					  String: sName
					!
					  String: sGotLoadDesc
					!
					  Number: nInd
				  Actions 
					  Select Case nActionType
						  Case nExecute
							  Set sSql = " SELECT Load_Description 
									FROM Load 
									WHERE Load_Id = :1 "
							  Set sName = 'GETLOADDESC'
							  Set sBind = ':sLoadId'
							  Set sInto = ':sGotLoadDesc'
							!
							  Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							  Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							  Set sLoadDesc = ''
							  Set sGotLoadDesc = ''
							!
							  If fcOurHandle.Execute( )
								  Call fcOurHandle.FetchNext( nInd )
								!
								  Set sLoadDesc = sGotLoadDesc
								  Return TRUE
							  Else 
								  Return FALSE
						! Case nCommit
							  Return fcOurHandle.Commit( )
						! Case nRollback
							  Return fcOurHandle.Rollback( )
						  Case nDisconnect
							  Return fcOurHandle.Disconnect( )
		  Window Parameters 
		  Window Variables 
			  String: saLoadIds[ * ]
			  Number: nYear
			  String: sActionType
			!
			  String: sRepInto
			  String: sRepBind
			  String: sReportFile
			  Number: nError
			!
			  Boolean: bProcessLoads
			  Boolean: bProcessCust
			  Boolean: bProcessOrders
			  Boolean: bPopulateTblCust
			  Boolean: bPopulateTblOrd
			  Boolean: bFinishedWithCust
			  Number: nLoadIdsPos
			  Number: nCustRow
			  Number: nOrderRow
			!
			! Report Binds
			  String: sLoadId
			  String: sLoadDescription
			!
		  Message Actions 
			  On PAM_SETINSTANCEVARS
				  Set sDatabase = SqlDatabase
			  On SAM_Create
				  Set nYear = SalStrToNumber( strArgArray[ 5 ] )
				  Set sActionType = strArgArray[ 6 ]
				  Return SalSendClassMessage( SAM_Create, wParam, lParam )
			  On SAM_CreateComplete
				  Call SalHideWindow( hWndForm )
				!
				  If sActionType = 'SELECTED_LOADS'
					  If NOT ReadStrArrayListFromFile( strArgArray[ 4 ], saLoadIds )
						  Call SalMessageBox( 'An error occurred! Cannot do this report now! Contact Programmers.', 'Error', MB_Ok )
						  Call SalDestroyWindow( hWndForm )
				!
				  Call SalSendMsg( hWndForm, PAM_PRINTNPAS, 0, 0 )
				  Call SalWaitCursor( FALSE )
			  On PAM_PRINTNPAS
				  Call SalWaitCursor( TRUE )
				!
				  Set sRepInto = 'Cust_No, Cust_Name, BusName, Region_Desc, Ship_Address_Line1, Ship_Address_Line2,
						Suburb, State, Postcode, Contact_Wrk_Ph_Code, Contact_Wrk_Ph, Tree_Type, CultivarDesc, RootDesc,
						NPASent, NPASentDate, ConfAmt, Load_Description'
				!
				  Set sRepBind = 'frmPrintOutstandingNPAs.tblCust.colCustNo, frmPrintOutstandingNPAs.tblCust.colCustName,
						frmPrintOutstandingNPAs.tblCust.colBusName, frmPrintOutstandingNPAs.tblCust.colRegionDesc, 
						frmPrintOutstandingNPAs.tblCust.colBusAddrL1, frmPrintOutstandingNPAs.tblCust.colBusAddrL2, 
						frmPrintOutstandingNPAs.tblCust.colBusSuburb, frmPrintOutstandingNPAs.tblCust.colBusState, 
						frmPrintOutstandingNPAs.tblCust.colBusPostcode, frmPrintOutstandingNPAs.tblCust.colContactWrkAreaCode,
						frmPrintOutstandingNPAs.tblCust.colContactWrkPhone, frmPrintOutstandingNPAs.tblOrd.colTreeType, 
						frmPrintOutstandingNPAs.tblOrd.colCultDesc, frmPrintOutstandingNPAs.tblOrd.colRootDesc, 
						frmPrintOutstandingNPAs.tblOrd.colNPASentFlag, frmPrintOutstandingNPAs.tblOrd.colNPASentDate, 
						frmPrintOutstandingNPAs.tblOrd.colConfAmt, frmPrintOutstandingNPAs.sLoadDescription'
				!
				  Set sReportFile = 'g:\\apps\\gupta\\reports\\npaoutst.qrp'
				  Set nError = 1
				  Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, RPT_PrintAll,0,0, nError )
			  On SAM_ReportStart
				  Return TRUE
			  On SAM_ReportFetchInit
				  Set bProcessLoads = TRUE
				  Set bProcessCust = FALSE
				  Set bProcessOrders = FALSE
				!
				  Set bPopulateTblCust = FALSE
				  Set bPopulateTblOrd = FALSE
				!
				  Set nLoadIdsPos = 0
				  Set nCustRow = TBL_MinRow
				  Set nOrderRow = TBL_MinRow
				!
				  Set bFinishedWithCust = FALSE
				  Return TRUE
			  On SAM_ReportFetchNext
				  Loop 
					  If bProcessLoads
						  If sActionType = 'SELECTED_LOADS'
							  Set sLoadId = saLoadIds[ nLoadIdsPos ]
							  If sLoadId = ''
								  Return FALSE
							  Else 
								  Set bProcessLoads = FALSE
								  Set bProcessCust = TRUE
								  Set bPopulateTblCust = TRUE
								  Set nLoadIdsPos = nLoadIdsPos + 1
								!
								  Call GetLoadDesc( sLoadId, sLoadDescription, nExecute )
						  Else 
							! else assumes nAllCustomers
							  If bFinishedWithCust
								  Return FALSE
							  Else 
								  Set bProcessLoads = FALSE
								  Set bProcessCust = TRUE
								  Set bPopulateTblCust = TRUE
					  If bProcessCust
						  If bPopulateTblCust
							  Call SalSendMsg( tblCust, PAM_POPULATE, 0, 0 )
							  Set bPopulateTblCust = FALSE
						!
						  If SalTblFindNextRow( tblCust, nCustRow, 0, 0 )
							  Call SalTblFetchRow( tblCust, nCustRow )
							  Set bProcessCust = FALSE
							  Set bProcessOrders = TRUE
							  Set bPopulateTblOrd = TRUE
						  Else 
							  Set bProcessCust = FALSE
							  Set bProcessLoads = TRUE
							  Set bFinishedWithCust = TRUE
					  If bProcessOrders
						  If bPopulateTblOrd
							  Call SalSendMsg( tblOrd, PAM_POPULATE, 0, 0 )
							  Set bPopulateTblOrd = FALSE
						!
						  If SalTblFindNextRow( tblOrd, nOrderRow, 0, 0 )
							  Call SalTblFetchRow( tblOrd, nOrderRow )
							  Return TRUE
						  Else 
							  Set bProcessOrders = FALSE
							  Set bProcessCust = TRUE
			  On SAM_ReportFinish
				  Call GetLoadDesc( '', sLoadDescription, nDisconnect )
				  Call SalDestroyWindow( hWndForm )
				  Call SalWaitCursor( FALSE )
				  Return TRUE

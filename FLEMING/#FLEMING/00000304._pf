				Functions
					Function: GetRegionDesc
						Description:
						Returns
							Boolean:
						Parameters
							String: sRegionId
							Receive String: sRegionDesc
							Number: nActionType
						Static Variables
							: fcOurHandle
								Class: hcSqlHandle
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							!
							String: sGotRegionDesc
							!
							Number: nInd
						Actions
							Select Case nActionType
								Case nExecute
									Set sSql = " SELECT Region_Desc 
											FROM Region 
											WHERE Region_Id = :1 "
									Set sName = 'GETREGDESC'
									Set sBind = ':sRegionId'
									Set sInto = ':sGotRegionDesc'
									!
									Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( fcOurHandle.hSqlHandle )
									!
									Set sRegionDesc = ''
									Set sGotRegionDesc = ''
									!
									If fcOurHandle.Execute( )
										Call fcOurHandle.FetchNext( nInd )
										!
										Set sRegionDesc = sGotRegionDesc
										Return TRUE
									Else
										Return FALSE
								! Case nCommit
									  Return fcOurHandle.Commit( )
								! Case nRollback
									  Return fcOurHandle.Rollback( )
								Case nDisconnect
									Return fcOurHandle.Disconnect( )
				Window Variables
				Message Actions
					On PAM_SETINSTANCEVARS
						If frmPrintOutstandingTAs.sActionType = 'ALL_CUST'
							If frmPrintOutstandingTAs.nYear < OurDateYear( SalDateCurrent(  ) )
								Set sSQLTABLENAME = ''
								Set sSQLPOPTABLENAME = 'Customer_Master, Customer_Address, Customer_Contacts, 
										Cust_Order_History, Stock_Item, Customer_Type '
								Set sROWID = ''
								Set sSQLWHERE = " WHERE Customer_Master.Customer_Type LIKE '%OR%' AND 
										Customer_Master.Customer_Type = Customer_Type.Cust_Type AND 
										Customer_Type.NPA_Required = 'Y' AND 
										Customer_Master.Cust_No = Customer_Address.Cust_No AND
										Customer_Address.Main_Address_Flag = 'Y' AND 
										Customer_Master.Cust_No = Customer_Contacts.Cust_No AND 
										Customer_Contacts.Main_Contact_Flag = 'Y' AND 
										Customer_Master.Cust_No = Cust_Order_History.Cust_No AND 
										Cust_Order_History.Year_Of_Sale = :frmPrintOutstandingTAs.nYear AND 
										Cust_Order_History.CONF_AMT > 0 AND 
										Cust_Order_History.TA_Recd_Flag != 'Y' AND 
										Cust_Order_History.SALE_CAT != 'RP' AND
										Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
										( Stock_Item.CV_on_trial_Flag = 'Y' OR Stock_Item.RT_on_trial_Flag = 'Y' ) "
								Set sORDERBY = 'ORDER BY Customer_Master.Region_Id, Customer_Master.Cust_Name, Customer_Master.Cust_No'
							Else
								Set sSQLTABLENAME = ''
								Set sSQLPOPTABLENAME = 'Customer_Master, Customer_Address, Customer_Contacts, 
										Customer_Order, Stock_Item, Customer_Type'
								Set sROWID = ''
								Set sSQLWHERE = " WHERE Customer_Master.Customer_Type LIKE '%OR%' AND 
										Customer_Master.Cust_No = Customer_Address.Cust_No AND
										Customer_Address.Main_Address_Flag = 'Y' AND 
										Customer_Master.Customer_Type = Customer_Type.Cust_Type AND 
										Customer_Type.NPA_Required = 'Y' AND 
										Customer_Master.Cust_No = Customer_Contacts.Cust_No AND 
										Customer_Contacts.Main_Contact_Flag = 'Y' AND 
										Customer_Master.Cust_No = Customer_Order.Cust_No AND 
										Customer_Order.Year_Of_Sale = :frmPrintOutstandingTAs.nYear AND 
										CUSTOMER_ORDER.CONF_AMT > 0 AND 
										Customer_Order.TA_Recd_Flag != 'Y' AND 
										CUSTOMER_ORDER.SALE_CAT != 'RP' AND
										Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
										( Stock_Item.CV_on_trial_Flag = 'Y' OR Stock_Item.RT_on_trial_Flag = 'Y' ) "
								Set sORDERBY = 'ORDER BY Customer_Master.Region_Id, Customer_Master.Cust_Name, Customer_Master.Cust_No'
						Else
							Set sSQLTABLENAME = ''
							Set sSQLPOPTABLENAME = 'Load_Customers, Customer_Master, Customer_Address, 
									Customer_Contacts, Customer_Order, Stock_Item, Customer_Type '
							Set sROWID = ''
							Set sSQLWHERE = " WHERE Load_Customers.Load_Id = :frmPrintOutstandingTAs.sLoadId AND 
									Load_Customers.Cust_No = Customer_Master.Cust_No AND 
									Customer_Master.Customer_Type = Customer_Type.Cust_Type AND 
									Customer_Type.NPA_Required = 'Y' AND 
									Customer_Master.Customer_Type LIKE '%OR%' AND 
									Customer_Master.Cust_No = Customer_Address.Cust_No AND 
									Customer_Address.Main_Address_Flag = 'Y' AND 
									Customer_Master.Cust_No = Customer_Contacts.Cust_No AND 
									Customer_Contacts.Main_Contact_Flag = 'Y' AND 
									Customer_Master.Cust_No = Customer_Order.Cust_No AND 
									Customer_Order.Year_Of_Sale = :frmPrintOutstandingTAs.nYear AND 
									CUSTOMER_ORDER.CONF_AMT > 0 AND 
									Customer_Order.TA_Recd_Flag != 'Y' AND 
									CUSTOMER_ORDER.SALE_CAT != 'RP' AND
									Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									( Stock_Item.CV_Non_Prop_Flag = 'Y' OR Stock_Item.RT_Non_Prop_Flag = 'Y' ) "
							Set sORDERBY = ' ORDER BY Load_Customers.Sequence_No'
					On SAM_FetchRowDone
						If NOT SalIsNull( colRegionId )
							Call GetRegionDesc( colRegionId, colRegionDesc, nExecute )
					On PAM_NOROWS
						Return TRUE
					On SAM_Destroy
						Call GetRegionDesc( '', colRegionDesc, nDisconnect )
						Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

							  On PAM_SETINSTANCEVARS
								  Set colBusState.sSQLCOLNAME = 'CUSTOMER_ADDRESS.STATE'
					  Column: colBusPostcode
						  List Values 
						  Message Actions 
							  On PAM_SETINSTANCEVARS
								  Set colBusPostcode.sSQLCOLNAME = 'CUSTOMER_ADDRESS.POSTCODE'
					  Column: colContactWrkAreaCode
						  List Values 
						  Message Actions 
							  On PAM_SETINSTANCEVARS
								  Set colContactWrkAreaCode.sSQLCOLNAME = 'CUSTOMER_CONTACTS.WRK_PHONE_CODE'
					  Column: colContactWrkPhone
						  List Values 
						  Message Actions 
							  On PAM_SETINSTANCEVARS
								  Set colContactWrkPhone.sSQLCOLNAME = 'CUSTOMER_CONTACTS.CONTACT_WORK_PHONE'
				  Functions 
					  Function: GetRegionDesc
						  Description: 
						  Returns 
							  Boolean: 
						  Parameters 
							  String: sRegionId
							  Receive String: sRegionDesc
							  Number: nActionType
						  Static Variables 
							  : fcOurHandle
						  Local variables 
							  String: sSql
							  String: sBind
							  String: sInto
							  String: sName
							!
							  String: sGotRegionDesc
							!
							  Number: nInd
						  Actions 
							  Select Case nActionType
								  Case nExecute
									  Set sSql = " SELECT Region_Desc 
											FROM Region 
											WHERE Region_Id = :1 "
									  Set sName = 'GETREGDESC'
									  Set sBind = ':sRegionId'
									  Set sInto = ':sGotRegionDesc'
									!
									  Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
									  Call SqlVarSetup( fcOurHandle.hSqlHandle )
									!
									  Set sRegionDesc = ''
									  Set sGotRegionDesc = ''
									!
									  If fcOurHandle.Execute( )
										  Call fcOurHandle.FetchNext( nInd )
										!
										  Set sRegionDesc = sGotRegionDesc
										  Return TRUE
									  Else 
										  Return FALSE
								! Case nCommit
									  Return fcOurHandle.Commit( )
								! Case nRollback
									  Return fcOurHandle.Rollback( )
								  Case nDisconnect
									  Return fcOurHandle.Disconnect( )
				  Window Variables 
				  Message Actions 
					  On PAM_SETINSTANCEVARS
						  If frmPrintOutstandingNPAs.sActionType = 'ALL_CUST'
							  If frmPrintOutstandingNPAs.nYear < OurDateYear( SalDateCurrent(  ) )
								  Set sSQLTABLENAME = ''
								  Set sSQLPOPTABLENAME = 'Customer_Master, Customer_Address, Customer_Contacts, Cust_Order_History'
								  Set sROWID = ''
								  Set sSQLWHERE = " WHERE Customer_Master.Cust_No = Customer_Address.Cust_No AND
										Customer_Address.Main_Address_Flag = 'Y' AND 
										Customer_Master.Cust_No = Customer_Contacts.Cust_No AND 
										Customer_Contacts.Main_Contact_Flag = 'Y' AND 
										Customer_Master.Cust_No = Cust_Order_History.Cust_No AND 
										Cust_Order_History.Year_Of_Sale = :frmPrintOutstandingNPAs.nYear AND 
										NOT Cust_Order_History.NPA_Recd_Flag = 'Y' "
								  Set sORDERBY = 'ORDER BY Customer_Master.Region_Id, Customer_Master.Cust_Name, Customer_Master.Cust_No'
							  Else 
								  Set sSQLPOPTABLENAME = 'CUSTOMER_ORDER, STOCK_ITEM'
								!
								  Set sSQLTABLENAME = ''
								  Set sSQLPOPTABLENAME = 'Customer_Master, Customer_Address, Customer_Contacts, Customer_Order'
								  Set sROWID = ''
								  Set sSQLWHERE = " WHERE Customer_Master.Cust_No = Customer_Address.Cust_No AND
										Customer_Address.Main_Address_Flag = 'Y' AND 
										Customer_Master.Cust_No = Customer_Contacts.Cust_No AND 
										Customer_Contacts.Main_Contact_Flag = 'Y' AND 
										Customer_Master.Cust_No = Customer_Order.Cust_No AND 
										Customer_Order.Year_Of_Sale = :frmPrintOutstandingNPAs.nYear AND 
										NOT Customer_Order.NPA_Recd_Flag = 'Y' "
								  Set sORDERBY = 'ORDER BY Customer_Master.Region_Id, Customer_Master.Cust_Name, Customer_Master.Cust_No'
						  Else 
							  Set sSQLTABLENAME = ''
							  Set sSQLPOPTABLENAME = 'Load_Customers, Customer_Master, Customer_Address, 
									Customer_Contacts, Customer_Order'
							  Set sROWID = ''
							  Set sSQLWHERE = " WHERE Load_Customers.Load_Id = :frmPrintOutstandingNPAs.sLoadId AND 
									Load_Customers.Cust_No = Customer_Master.Cust_No AND 
									Customer_Master.Cust_No = Customer_Address.Cust_No AND 
									Customer_Address.Main_Address_Flag = 'Y' AND 
									Customer_Master.Cust_No = Customer_Contacts.Cust_No AND 
									Customer_Contacts.Main_Contact_Flag = 'Y' AND 
									Customer_Master.Cust_No = Customer_Order.Cust_No AND 
									Customer_Order.Year_Of_Sale = :frmPrintOutstandingNPAs.nYear AND 
									NOT Customer_Order.NPA_Recd_Flag = 'Y' "
							  Set sORDERBY = ' ORDER BY Load_Customers.Sequence_No'
					  On SAM_FetchRowDone
						  If NOT SalIsNull( colRegionId )
							  Call GetRegionDesc( colRegionId, colRegionDesc, nExecute )
					  On PAM_NOROWS
						  Return TRUE
					  On SAM_Destroy
						  Call GetRegionDesc( '', colRegionDesc, nDisconnect )
						  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
			  Child Table: tblOrd

		Application Actions
			On SAM_AppStartup
				! ASSUMPTION FOR Command Line arguments
						Argument 1 - SqlDatabase
						Argument 2 - SqlUser
						Argument 3 - SqlPassword
						Argument 4 - File Name for list of selected load Ids
						Argument 5 - Year ( number )
						Argument 6 - Action Type ( string ) = ( 'SELECTED_LOADS' OR 'ALL_CUST' )
				!
				Set strArgArray[1] = 'STOCKDEV'
				Set strArgArray[2] = 'GRAHAM'
				Set strArgArray[3] = 'GRAHAM'
				Set strArgArray[4] = 'c:\\temp\\loadids.tmp'
				Set strArgArray[5] = '1998'
				Set strArgArray[6] = 'SELECTED_LOADS'
				!
				Set SqlDatabase = strArgArray[ 1 ]
				Set SqlUser = strArgArray[ 2 ]
				Set SqlPassword = strArgArray[ 3 ]
				!
				Set bghSqlDetail = SqlConnect( hSqlDetail )
				If bghSqlDetail
					Call SqlSetIsolationLevel( hSqlDetail,'RL')
					Call SqlSetLockTimeout( hSqlDetail, SQLTIMEOUT )
			On SAM_AppExit
				If bghSqlDetail
					Call SqlDisconnect( hSqlDetail )

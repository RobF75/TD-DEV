		Functions
			Function: GetLoadDesc
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Receive String: sLoadDesc
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					String: sGotLoadDesc
					!
					Number: nInd
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT Load_Description 
									FROM Load 
									WHERE Load_Id = :1 "
							Set sName = 'GETLOADDESC'
							Set sBind = ':sLoadId'
							Set sInto = ':sGotLoadDesc'
							!
							Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							Set sLoadDesc = ''
							Set sGotLoadDesc = ''
							!
							If fcOurHandle.Execute( )
								Call fcOurHandle.FetchNext( nInd )
								!
								Set sLoadDesc = sGotLoadDesc
								Return TRUE
							Else
								Return FALSE
						! Case nCommit
							   Return fcOurHandle.Commit( )
						! Case nRollback
							   Return fcOurHandle.Rollback( )
						Case nDisconnect
							Return fcOurHandle.Disconnect( )
		Window Parameters
		Window Variables
			String: saLoadIds[ * ]
			Number: nYear
			String: sActionType
			!
			String: sRepInto
			String: sRepBind
			String: sReportFile
			Number: nError
			!
			Boolean: bProcessLoads
			Boolean: bProcessCust
			Boolean: bProcessOrders
			Boolean: bPopulateTblCust
			Boolean: bPopulateTblOrd
			Boolean: bFinishedWithCust
			Number: nLoadIdsPos
			Number: nCustRow
			Number: nOrderRow
			!
			! Report Binds
			String: sLoadId
			String: sLoadDescription
			!
		Message Actions
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
			On SAM_Create
				Set nYear = SalStrToNumber( strArgArray[ 5 ] )
				Set sActionType = strArgArray[ 6 ]
				Return SalSendClassMessage( SAM_Create, wParam, lParam )
			On SAM_CreateComplete
				Call SalHideWindow( hWndForm )
				!
				If sActionType = 'SELECTED_LOADS'
					If NOT ReadStrArrayListFromFile( strArgArray[ 4 ], saLoadIds )
						Call SalMessageBox( 'An error occurred! Cannot do this report now! Contact Programmers.', 'Error', MB_Ok )
						Call SalDestroyWindow( hWndForm )
				!
				Call SalSendMsg( hWndForm, PAM_PRINTPRCS, 0, 0 )
				Call SalWaitCursor( FALSE )
			On PAM_PRINTPRCS
				Call SalWaitCursor( TRUE )
				!
				Set sRepInto = 'Cust_No, Cust_Name, BusName, Region_Desc, Ship_Address_Line1, Ship_Address_Line2,
						Suburb, State, Postcode, Contact_Wrk_Ph_Code, Contact_Wrk_Ph, Tree_Type_Desc, CultivarDesc, 
						PRCSent, PRCSentDate, ConfAmt, Load_Description'
				!
				Set sRepBind = 'frmPrintOutstandingPRCs.tblCust.colCustNo, frmPrintOutstandingPRCs.tblCust.colCustName,
						frmPrintOutstandingPRCs.tblCust.colBusName, frmPrintOutstandingPRCs.tblCust.colRegionDesc, 
						frmPrintOutstandingPRCs.tblCust.colBusAddrL1, frmPrintOutstandingPRCs.tblCust.colBusAddrL2, 
						frmPrintOutstandingPRCs.tblCust.colBusSuburb, frmPrintOutstandingPRCs.tblCust.colBusState, 
						frmPrintOutstandingPRCs.tblCust.colBusPostcode, frmPrintOutstandingPRCs.tblCust.colContactWrkAreaCode,
						frmPrintOutstandingPRCs.tblCust.colContactWrkPhone, frmPrintOutstandingPRCs.tblCust.colTreeTypeDesc, 
						frmPrintOutstandingPRCs.tblCust.colCultDesc, 
						frmPrintOutstandingPRCs.tblCust.colPRCSentFlag, frmPrintOutstandingPRCs.tblCust.colPRCSentDate, 
						frmPrintOutstandingPRCs.tblCust.colConfAmt, frmPrintOutstandingPRCs.sLoadDescription'
				!
				Set sReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\PRCouts2.qrp'
				Set nError = 1
				Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, RPT_PrintAll,0,0, nError )
			On SAM_ReportStart
				Return TRUE
			On SAM_ReportFetchInit
				Set bProcessLoads = TRUE
				Set bProcessCust = FALSE
				!
				Set bPopulateTblCust = FALSE
				!
				Set nLoadIdsPos = 0
				Set nCustRow = TBL_MinRow
				!
				Set bFinishedWithCust = FALSE
				Return TRUE
			On SAM_ReportFetchNext
				Loop
					If bProcessLoads
						If sActionType = 'SELECTED_LOADS'
							Set sLoadId = saLoadIds[ nLoadIdsPos ]
							If sLoadId = ''
								Return FALSE
							Else
								Set bProcessLoads = FALSE
								Set bProcessCust = TRUE
								Set bPopulateTblCust = TRUE
								Set nLoadIdsPos = nLoadIdsPos + 1
								!
								Call GetLoadDesc( sLoadId, sLoadDescription, nExecute )
						Else
							! else assumes nAllCustomers
							If bFinishedWithCust
								Return FALSE
							Else
								Set bProcessLoads = FALSE
								Set bProcessCust = TRUE
								Set bPopulateTblCust = TRUE
					If bProcessCust
						If bPopulateTblCust
							Call SalSendMsg( tblCust, PAM_POPULATE, 0, 0 )
							Set bPopulateTblCust = FALSE
						!
						If SalTblFindNextRow( tblCust, nCustRow, 0, 0 )
							Call SalTblFetchRow( tblCust, nCustRow )
							Return TRUE
						Else
							Set bProcessCust = FALSE
							Set bProcessLoads = TRUE
							Set bFinishedWithCust = TRUE
			On SAM_ReportFinish
				Call GetLoadDesc( '', sLoadDescription, nDisconnect )
				Call SalDestroyWindow( hWndForm )
				Call SalWaitCursor( FALSE )
				Return TRUE

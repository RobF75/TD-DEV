				Message Actions
		Functions
			Function: GetTableFields
				Description:
				Returns
					Boolean:
				Parameters
					String: sTableName
					Receive String: sColumns
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
					String: sOrgUser
					String: sOrgPassword
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					Number: nInd
					String: sGotColumn
					Boolean: bFirst
					Boolean: bOk
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETTBLCOLS' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sOrgUser = SqlUser
							Set sOrgPassword = SqlPassword
							!
							Set SqlUser = 'SYSADM'
							Set SqlPassword = 'DANI'
							!
							Set sSql = " SELECT NAME 
									FROM SYSCOLUMNS 
									WHERE 
									  TBNAME = :1 
									ORDER BY COLNO "
							Set sName = 'GETTBLCOLS'
							Set sBind = ':sTableName'
							Set sInto = ':sGotColumn'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set sTableName = SalStrUpperX( sTableName )
							Set sGotColumn = ''
							Set sColumns = ''
							!
							Set bOk = TRUE
							If haSqlHandles[ nOurHandleNo ].Execute( )
								Set bFirst = TRUE
								While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									If bFirst
										Set bFirst = FALSE
										Set sColumns = sGotColumn
									Else
										Set sColumns = sColumns || ', ' || sGotColumn
							Else
								Set bOk = FALSE
								Return FALSE
							!
							Set SqlUser = sOrgUser
							Set SqlPassword = sOrgPassword
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
		Window Parameters
		Window Variables
			String: sLineCount
			Boolean: bOk
			String: sSql
			Number: nCustNo
			Date/Time: dtOrdDate
			Number: nItemNo
			String: sCustOrderColumns
			: fcCopyHdl
				Class: hcSqlHandle
			: fcSelectHdl
				Class: hcSqlHandle
			: fcDeleteHdl
				Class: hcSqlHandle
			Number: nInd
			Number: nYear
			Number: nConfAmt
			Number: nOrdAmt
			Number: nLineCount
		Message Actions

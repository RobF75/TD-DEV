			Pushbutton: pbDoIt
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: clspbGeneral
				Property Template:
				Class DLL Name:
				Title: DO IT NOW!
				Window Location and Size
					Left:   0.763"
					Top:    2.125"
					Width:  1.988"
					Width Editable? Class Default
					Height: 0.271"
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_clsPB_CLICK
						If ccSeasonYear.GetSeasonYear( ) = WhichSeasonYear( SalDateCurrent(  ) )
							If IDCANCEL = SalMessageBox( 'YOU WANT TO ROLL THE CURRENT SEASON!', 'Huhhhh..', MB_OkCancel | MB_DefButton2 )
								Return FALSE
						If IDYES = SalMessageBox( 'The season showing is the rolling over season?', 'Warning', MB_YesNo | MB_DefButton2 )
							If IDNO = SalMessageBox( 'Will anyone invoice any orders in the rolling season?', 'Warning', MB_YesNo | MB_DefButton1 )
								If IDYES = SalMessageBox( 'The database server has heaps of room for log files?', 'Warning', MB_YesNo | MB_DefButton2 )
									If IDYES = SalMessageBox( 'Final chance!  Continue?', 'Warning', MB_YesNo | MB_DefButton2 )
										Call SalListAdd( lbStatus, 'Action 1 of 5, Connecting to database.' )
										Call SalUpdateWindow( hWndForm )
										!
										Set nYear = ccSeasonYear.GetSeasonYear( )
										Set nLineCount = 0
										Call GetTableFields( 'CUSTOMER_ORDER', sCustOrderColumns, SH_cls_Execute )
										!
										Set sSql = " INSERT INTO CUST_ORDER_HISTORY 
												  ( " || sCustOrderColumns || " ) 
												 SELECT " || sCustOrderColumns || " FROM  
												    CUSTOMER_ORDER  
												  WHERE  
												    	Cust_No = :nCustNo AND 
												    	Order_Date_Time = :dtOrdDate and
													Stock_Item_No = :nItemNo "
										Call fcCopyHdl.PrepareSetup( sSql )
										!
										Set sSql = "  SELECT
													distinct(Cust_no), 
													order_date_time, 
													stock_item_no
												FROM  
												    	CUSTOMER_ORDER  
												INTO
													:nCustNo,
													:dtOrdDate,
													:nItemNo
												  WHERE  
												    	Year_of_Sale =  :nYear AND 
												    	(Invoiced_Flag = 'Y' or
													Conf_Amt = 0)  "
										Call fcSelectHdl.PrepareSetup( sSql )
										!
										Set sSql = " DELETE FROM Customer_Order 
												WHERE 
												  Cust_No = :nCustNo AND 
												    	Order_Date_Time = :dtOrdDate and
													Stock_Item_No = :nItemNo "
										Call fcDeleteHdl.PrepareSetup( sSql )
										!
										Call SalListAdd( lbStatus, 'Action 2 of 5, Copying invoiced orders to order history.' )
										Call SalUpdateWindow( hWndForm )
										Set bOk = TRUE
										If fcSelectHdl.PrepareAndExecute( )
											Call SalListAdd( lbStatus, 'Action 3.1 of 5, Fetching Orders.....' )
											Call SalUpdateWindow( hWndForm )
											Call SalListAdd( lbStatus, 'Action 3.2 of 5, and Deleting Orders.....' )
											Call SalUpdateWindow( hWndForm )
											! While bOk
											While fcSelectHdl.FetchNext(nInd)
												If fcCopyHdl.PrepareAndExecute( )
													If NOT fcCopyHdl.Commit( )
														Call SalListAdd( lbStatus, 'Error, Insert failed.' )
														Call SalUpdateWindow( hWndForm )
														Call fcCopyHdl.Rollback( )
														Call SalListAdd( lbStatus, 'Action 3.1 of 5, Rolling back copy of invoiced orders.' )
														Call SalUpdateWindow( hWndForm )
														Set bOk = FALSE
													Else
														If NOT fcDeleteHdl.PrepareAndExecute( )
															Call SalListAdd( lbStatus, 'Error, Delete failed.' )
															Call SalUpdateWindow( hWndForm )
															Call fcCopyHdl.Rollback( )
															Call SalListAdd( lbStatus, 'Action 3.1 of 5, Rolling back delete of invoiced orders.' )
															Call SalUpdateWindow( hWndForm )
															Set bOk = FALSE
														Else
															If NOT fcDeleteHdl.Commit( )
																Call SalListAdd( lbStatus, 'Error, Delete failed.' )
																Call SalUpdateWindow( hWndForm )
																Call SalListAdd( lbStatus, 'Action 3.1 of 5, Rolling back copy of invoiced orders.' )
																Call SalUpdateWindow( hWndForm )
																Set bOk = FALSE
															Else
																Set nLineCount = nLineCount + 1
												Else
													Set bOk = FALSE
										! If fcCopyHdl.PrepareAndExecute( )
											  Call SalListAdd( lbStatus, 'Action 3 of 5, Deleting invoiced orders.' )
											  Call SalUpdateWindow( hWndForm )
											  If fcDeleteHdl.PrepareAndExecute( )
												  Call SalListAdd( lbStatus, 'Action 4 of 5, Commiting transaction.' )
												  Call SalUpdateWindow( hWndForm )
												  If NOT fcCopyHdl.Commit( )
													  Set bOk = FALSE
												  If NOT fcDeleteHdl.Commit( )
													  Set bOk = FALSE
											  Else 
												  Set bOk = FALSE
												  Call SalListAdd( lbStatus, 'Action 3.1 of 5, Rolling back copy of invoiced orders.' )
												  Call SalUpdateWindow( hWndForm )
												  Call fcCopyHdl.Rollback( )
										!
										Set sLineCount =  'Message: ' || SalNumberToStrX( nLineCount, 0 ) || ' order lines transferred'
										Call SalListAdd( lbStatus, sLineCount )
										Call SalUpdateWindow( hWndForm )
										Call SalListAdd( lbStatus, 'Action 4 of 5, Commiting transaction.' )
										Call SalUpdateWindow( hWndForm )
										Call SalListAdd( lbStatus, 'Action 5 of 5, Disconnecting from database.' )
										Call SalUpdateWindow( hWndForm )
										Call fcCopyHdl.Disconnect( )
										Call fcSelectHdl.Disconnect( )
										Call fcDeleteHdl.Disconnect( )
										Call GetTableFields( '', sCustOrderColumns, SH_cls_Disconnect )
										!
										If bOk
											Call SalListAdd( lbStatus, 'Rolling over was a success!' )
											Call SalListAdd( lbStatus, 'Now a log backup is needed' )
											Call SalListAdd( lbStatus, 'Check the total size of logs generated and make changes to log backup path as needed.' )
										Else
											Call SalListAdd( lbStatus, 'Rolling over has not completed!' )
											Call SalListAdd( lbStatus, 'Call Programmer please.' )
										Call SalUpdateWindow( hWndForm )
										Call SqlHandlesDisconnectClose(  )
										If cbExitOnFinish
											Return SalSendMsg( pbExit, SAM_Click, 0, 0 )
			List Box: lbStatus
				Class Child Ref Key: 0
				Class ChildKey: 0

.head 4 +  Message Actions
.head 5 +  On SAM_Destroy
.head 6 +  If bParentForm
.head 7 -  Set hWndChild = SalGetFirstChild( hWndMDI, TYPE_FormWindow )
.head 7 +  While hWndChild != hWndNULL
.head 8 -  Call SalPostMsg( hWndChild, SAM_Destroy, 0, 0 )
.head 8 -  Set hWndChild = SalGetNextChild( hWndChild, TYPE_FormWindow )
.head 6 -  Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
.head 5 +  On SAM_Create
.head 6 -  Set bParentForm = FALSE
.head 6 -  Return SalSendClassMessage( SAM_Create, wParam, lParam )
.head 5 +  On SAM_CreateComplete
.head 6 +  If GetHandleFromItemName( hWndParent, sParentForm )
.head 7 +  If SalSendMsg(  hWndParent, PAM_cls_SETFIELDS, 0, 0 )
.head 8 -  Call SalSendMsg( hWndForm, PAM_cls_GETFIELDS, 0, 0 )
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsMDI_PBHIDDEN, wParam, lParam )
.head 6 -  Call SetMenuItems( )
.head 6 -  ! If the form is the parent form then we want the pb hiding code to be executed
.head 6 +  If bParentForm
.head 7 -  Call SalPostMsg( hWndForm, PAM_clsMDI_PBSENDSTATUS, 0, 0 )
.head 6 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 5 +  On PAM_clsMDI_PBSENDSTATUS
.head 6 -  Set nhWndForm = SalWindowHandleToNumber( hWndForm )
.head 6 -  Call SalSendMsgToChildren( hWndMDI, PAM_clsPB_PBSTATUS, nhWndForm, lParam )
.head 5 +  On PAM_clsMDI_PARENTCHANGE
.head 6 -  Set i = 0
.head 6 +  While sChildForm[i] != ''
.head 7 +  If GetHandleFromItemName( hWndChild, sChildForm[i] )
.head 8 -  Call SalPostMsg( hWndChild, PAM_cls_CHILDCHANGED, 0, 0 )
.head 7 -  Set i = i + 1
.head 5 +  On PAM_clsMDI_PBHIDDEN
.head 6 -  Set spbToHide[0] = ''
.head 5 +  On PAM_cls_GETFIELDS
.head 6 -  Return TRUE
.head 5 +  On PAM_cls_SETFIELDS
.head 6 -  Return TRUE
.head 5 +  On PAM_cls_CHILDCHANGED
.head 6 +  If SalSendMsg(  hWndParent, PAM_cls_SETFIELDS, 0, 0 )
.head 7 -  Call SalSendMsg( hWndForm, PAM_cls_GETFIELDS, 0, 0 )
.head 6 -  Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_POPULATE, 0, 0 )
.head 6 -  Call SalBringWindowToTop( hWndForm )
.head 6 -  Set i = 0
.head 6 +  While sChildForm[i] != ''
.head 7 +  If GetHandleFromItemName( hWndChild, sChildForm[i] )
.head 8 -  Call SalPostMsg( hWndChild, PAM_cls_CHILDCHANGED, 0, 0 )
.head 7 -  Set i = i + 1
.head 5 +  On SAM_Activate
.head 6 +  If wParam
.head 7 -  Call SalPostMsg( hWndForm, PAM_clsMDI_PBSENDSTATUS, 0, 0 )
.head 6 -  Set nhWndForm = SalWindowHandleToNumber( hWndForm )
.head 6 -  Call SalPostMsg( SalParentWindow( hWndForm ), PAM_clsMDI_ACTIVATED, wParam, nhWndForm )
.head 5 +  On PAM_cls_REFRESHAFTRCHILDCHANGE
.head 6 -  Return FALSE
.head 5 +  On PAM_clsTBL_CHECKCHANGES
.head 6 -  Set hWndMDIChild = SalGetFirstChild( hWndForm, TYPE_ChildTable )
.head 6 +  While hWndMDIChild != hWndNULL
.head 7 +  If NOT SalSendMsg( hWndMDIChild, PAM_clsTBL_CHECKCHANGES, wParam, lParam )
.head 8 -  Return TRUE
.head 7 -  Set hWndMDIChild = SalGetNextChild( hWndMDIChild, TYPE_ChildTable )
.head 6 -  Return FALSE
.head 5 +  On PAM_clsPB_PBSTATUS
.head 6 -  Set hWndPb = SalNumberToWindowHandle( lParam )
.head 6 -  Call SalGetItemName( hWndPb, sPb )
.head 6 -  Set i = 0
.head 6 -  ! have to loop thru the array of pbtohide to see if this pb is in the array, if not return false to not hide it
.head 6 +  While spbToHide[i] != ''
.head 7 +  If spbToHide[i] = sPb
.head 8 -  Return TRUE
.head 7 -  Set i = i + 1
.head 6 -  Return FALSE
.head 5 +  ! On PAM_clsMDI_MENUCREATE
.head 6 -      Set nMenu = VisMenuGetHandle( clsmdiMain )
.head 6 -  ! Set nMenu = VisMenuGetPopupHandle( nMenu, 1 )
.head 6 -      Set nMenuCount = VisMenuGetCount( nMenu )
.head 6 -      Set i = 0
.head 6 +      While i < nMenuCount
.head 7 -      Set sText = VisMenuGetText( clsmdiMain, nMenu, i )
.head 7 +      If sText = 'TableActions'
.head 8 -      Set nMenuPopup = VisMenuGetPopupHandle( nMenu, i )
.head 8 -      Break 
.head 7 -      Set i = i + 1
.head 6 +      If NOT clsmdifrmChld.bAddAllowed
.head 7 -  ! Set nAddMenu = VisMenuInsert( hWndForm, nMenu, -1, 'Add', 0 )
.head 7 -  ! Call VisWinLoadAccelerator(  hWndForm, VTM_MenuSelect, KDS_None, 0, nAddMenu )
.head 7 -      Set nChildCount = VisMenuGetCount( nMenuPopup )
.head 7 -      Set nChildPos = 0
.head 7 +      While nChildPos < nChildCount
.head 8 -      Set sChildText = VisMenuGetText( clsmdiMain, nMenuPopup, nChildPos )
.head 8 +      If sChildText = 'Add'
.head 9 -      Call VisMenuDelete( clsmdiMain, nMenuPopup, nChildPos )
.head 8 -      Set nChildPos = nChildPos + 1
.head 6 -      Call SalTrackPopupMenu( hWndForm, 'TableActions', TPM_CursorX|TPM_CursorY, 0, 0 )
.head 5 +  ! On VTM_MenuSelect
.head 6 -      Set sMenuSelected = VisMenuGetText( hWndForm, lParam, -1 ) 
.head 6 +      If sMenuSelected = 'Add'
.head 7 -      Call SalSendMsg( hWndMDI, PAM_clsMDI_ADD, 0, 0 )

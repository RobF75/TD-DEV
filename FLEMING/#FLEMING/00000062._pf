.head 6 -  Set hMenu = CreatePopupMenu(  )
.head 6 -  Set i = 0
.head 6 +  If clsmdifrmChldTbl.bAddAllowed
.head 7 -  Set nAddMenu = VisMenuInsert( hWndMDI, hMenu, -1, '&Add', 0 )
.head 7 -  Set hAcc[i] = VisWinLoadAccelerator( hWndMDI, VTM_MenuSelect, KDS_Alt, VK_A, nAddMenu )
.head 7 -  Set i = i + 1

.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Set bSeqNoKey = FALSE
.head 6 -  Return SalSendClassMessage( SAM_Create, wParam, lParam )
.head 5 +  On PAM_clsTBL_REFRESHROW
.head 6 -  ! If there are row news - we want to override the refresh row function as the seq no is generated
via a trigger in the database and we want to do a populate instead
.head 6 +  If bSeqNoKey
.head 7 -  ! Means that the primary key on this table is an internally triggered before insert seq no so we dont
want to do the refreshrow
.head 7 +  If bRowNew
.head 8 -  Set nReturn = TRUE
.head 7 +  Else
.head 8 -  Set nReturn = SalSendClassMessage( PAM_clsTBL_REFRESHROW, wParam, lParam )
.head 6 +  Else
.head 7 -  Set nReturn = SalSendClassMessage( PAM_clsTBL_REFRESHROW, wParam, lParam )
.head 6 -  ! ! Seems to be that if only 1 row is in the table, especially after the one row is added, sam_rowValidate
doesnt get processed on the click of the row
.head 6 +  If clsmdifrmChldTbl.__nTableTotalRows = 1
.head 7 -  Call SalSendMsg( hWndForm, SAM_RowValidate, wParam, lParam )
.head 6 -  Return nReturn
.head 5 +  On PAM_clsTBL_SAVECHANGES
.head 6 -  Set bRowNew = SalTblAnyRows( hWndForm, ROW_New, 0 )
.head 6 +  If SalSendClassMessage( PAM_clsTBL_SAVECHANGES, wParam, lParam )
.head 7 +  If bRowNew
.head 8 -  Call SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
.head 5 +  On SAM_RowValidate
.head 6 -  Set nhWndForm = SalWindowHandleToNumber( SalParentWindow( hWndForm ) )
.head 6 +  If SalSendMsg( hWndMDI, PAM_clsMDI_AMIACTIVE, 0, nhWndForm )
.head 7 -  Return VALIDATE_Ok
.head 7 +  ! If NOT SalSendMsg( hWndForm, PAM_clsTBL_CHECKCHANGES, wParam, lParam )
.head 8 -      Return VALIDATE_Ok
.head 6 -  ! First off we need to check if any of the windows have data changed which needs to be saved
.head 6 +  If SalSendMsg( hWndMDI, PAM_clsMDI_OKTOPOPCHILD, wParam, lParam )
.head 7 -  Call SalSendMsg( SalParentWindow( hWndForm ), PAM_clsMDI_PARENTCHANGE, 0, 0 )
.head 7 -  Return VALIDATE_Ok
.head 6 +  Else
.head 7 -  Return VALIDATE_Cancel
.head 5 +  On PAM_clsTBL_NOROWS
.head 6 -  Return FALSE

				Property Template:
				Class DLL Name:
				Description:
				Derived From
				Class Variables
				Instance Variables
					! PUBLIC
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					String: sContextRow
					!
					Boolean: bPopulateOnStartup
					! PRIVATE
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
					Number: nOurHandleNo
					Number: nContextRow
					Number: nInd
				Functions
				List Initialization
				Message Actions
					On SAM_Create
						Set sSql = ''
						Set sName = ''
						Set sBind = ''
						Set sInto = ''
						Set bPopulateOnStartup = TRUE
						Set nContextRow = NUMBER_Null
						Set sContextRow = ''
						Call SalSendMsg( hWndItem, PAM_cls_SETINSTANCEVARS, 0, 0 ) 
						Set nOurHandleNo = SqlHandlesGetReferenceNo( GetFullItemName( hWndNULL, hWndForm, hWndItem ) || 'LB' )
						If bPopulateOnStartup
							Call SalPostMsg( hWndItem, PAM_clsLB_POPULATE, 0, 0 )
					On PAM_clsLB_POPULATE
						Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
						Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
						!
						If SalListClear( hWndItem )
							Set nContextRow = NUMBER_Null
							Set sContextRow = ''
							Call SalSendMsg( hWndItem, PAM_clsLB_RESET, 0, 0 )
						!
						If haSqlHandles[ nOurHandleNo ].Execute( )
							Set nContextRow = 0
							While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
								Set sContextRow = ''
								Call SalSendMsg( hWndItem, PAM_clsLB_FORMATCONTEXTROW, 0, nContextRow )
								If SalListAdd( hWndItem, sContextRow ) >= 0
									Set nContextRow = nContextRow + 1
							Return TRUE
						Else
							Return FALSE
					On SAM_Destroy
						Call haSqlHandles[ nOurHandleNo ].Disconnect( )

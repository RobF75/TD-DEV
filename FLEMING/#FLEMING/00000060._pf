				Property Template:
				Class DLL Name:
				Description:
				Derived From
				Class Variables
				Instance Variables
					String: sSqlPopStatement
					! Set bUsedInQueryDialog = TRUE to fix wait cursor staying on after drop down on a query dialog
					Boolean: bUsedInQueryDialog
					Boolean: bPopulateOnce
					Boolean: bGetCountOnPopulate
					String: sCurrentSelectionString
					Boolean: bPopulateOnStartup
					! PRIVATE
					Boolean: bListPopulated
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
					Number: nOurHandleNo
					Boolean: bOk
					Number: nRowCount
				Functions
					Function: GetListSelectionString
						Description:
						Returns
							String:
						Parameters
						Static Variables
						Local variables
						Actions
							Return SalListQueryTextX( hWndItem, SalListQuerySelection( hWndItem ) )
					Function: GetListSelectionNumber
						Description:
						Returns
							Number:
						Parameters
						Static Variables
						Local variables
						Actions
							Return SalListQuerySelection( hWndItem )
				List Initialization
				Message Actions
					On SAM_Create
						Set sSqlPopStatement = ''
						Set bListPopulated = FALSE
						Set bUsedInQueryDialog = FALSE
						Set sCurrentSelectionString = ''
						Set bPopulateOnce = TRUE
						Set bGetCountOnPopulate = FALSE
						Set bPopulateOnStartup = FALSE
						Call SalSendMsg( hWndItem, PAM_cls_SETINSTANCEVARS, 0, 0 ) 
						Set nOurHandleNo = SqlHandlesGetReferenceNo( GetFullItemName( hWndNULL, hWndForm, hWndItem ) || 'LB' )
						If bPopulateOnStartup
							Call SalPostMsg( hWndItem, PAM_clsLB_POPULATE, 0, 0 )
					On PAM_clsLB_POPULATE
						If bPopulateOnce
							If NOT sSqlPopStatement = '' AND NOT bListPopulated
								Set bOk = TRUE
							Else
								Set bOk = FALSE
						Else
							If NOT sSqlPopStatement = ''
								Set bOk = TRUE
							Else
								Set bOk = FALSE
						If bOk
							If bUsedInQueryDialog
								Call OurWaitCursorOverride( TRUE, TRUE )
							Else
								Call OurWaitCursor( TRUE )
							If haSqlHandles[ nOurHandleNo ].Connect( )
								If SalListPopulate( hWndItem, haSqlHandles[ nOurHandleNo ].hSqlHandle, sSqlPopStatement )
									Set bListPopulated = TRUE
									If bGetCountOnPopulate
										Set nRowCount = SalListQueryCount( hWndItem )
										Call SalSendMsg( hWndItem, PAM_clsLB_POPULATEDCOUNT, 0, nRowCount )
							If bUsedInQueryDialog
								Call OurWaitCursorOverride( FALSE, TRUE )
							Else
								Call OurWaitCursor( FALSE )
					On PAM_clsLB_RESET
						Set bListPopulated = FALSE
						Return SalListClear( hWndItem )
					On SAM_Destroy
						Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					On SAM_Click
						Set sCurrentSelectionString = SalListQueryTextX( hWndItem, SalListQuerySelection( hWndItem ) ) 
						Return TRUE

				Class Variables
				Instance Variables
					! numbering of states in relation to list initialization bellow
					Number: nStartState
				Functions
					Function: GetSelectState
						Description:
						Returns
							String:
						Parameters
						Static Variables
						Local variables
						Actions
							Return clslbStatesClass.GetListSelectionString( )
					Function: GetCustNoRangeForState
						Description:
						Returns
						Parameters
							String: sState
							Receive Number: nLoCustNo
							Receive Number: nHiCustNo
						Static Variables
						Local variables
						Actions
							If sState = 'NT'
								Set nLoCustNo = 080000
								Set nHiCustNo = 099999 
							Else If sState = 'NSW'
								Set nLoCustNo = 200000
								Set nHiCustNo = 299999
							Else If sState = 'ACT'
								Set nLoCustNo = 200000
								Set nHiCustNo = 299999
							Else If sState = 'VIC'
								Set nLoCustNo = 300000
								Set nHiCustNo = 399999
							Else If sState = 'QLD'
								Set nLoCustNo = 400000
								Set nHiCustNo = 499999
							Else If sState = 'SA'
								Set nLoCustNo = 500000
								Set nHiCustNo = 599999
							Else If sState = 'WA'
								Set nLoCustNo = 600000
								Set nHiCustNo = 699999
							Else If sState = 'TAS'
								Set nLoCustNo = 700000
								Set nHiCustNo = 799999
							Else
								Set nLoCustNo = 0
								Set nHiCustNo = 0
					Function: GetSelectStateCustNoRange
						Description:
						Returns
						Parameters
							Receive Number: nLoCustNo
							Receive Number: nHiCustNo
						Static Variables
						Local variables
						Actions
							Call GetCustNoRangeForState( GetSelectState(  ), nLoCustNo, nHiCustNo )
				List Initialization
					Text: ACT
					Text: NSW
					Text: NT
					Text: QLD
					Text: SA
					Text: TAS
					Text: VIC
					Text: WA
				Message Actions
					On SAM_Create
						Set nStartState = 7
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Call SalListSetSelect( hWndItem, nStartState - 1 )

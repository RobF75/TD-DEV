					On PAM_clsCB_VALIDATE
						Return SalSendMsg( hWndForm, PAM_clsFRMDETS_VALIDATE, wParam, lParam )
					On PAM_clsRB_CLICK
						Call SalSendMsg( hWndForm, PAM_clsFRMDETS_VALIDATE, wParam, lParam )

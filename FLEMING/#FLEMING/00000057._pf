		Named Menus
		Internal Functions
			Function: UserFormActions
				Description:
				Returns
					Boolean:
				Parameters
					Window Handle: hWndFormHdl
					Number: wParam
				Static Variables
				Local variables
				Actions
					Select Case wParam
						Case FRMDETS_cls_SAVE
							Return SalSendMsg( hWndFormHdl, PAM_clsFRMDETS_SAVE, 0, 0 )
						Case FRMDETS_cls_CLEAR
							Return SalSendMsg( hWndFormHdl, PAM_clsFRMDETS_CLEAR, 0, 0 )
						Case FRMDETS_cls_DELETE
							Return SalSendMsg( hWndFormHdl, PAM_clsFRMDETS_DELETE, 0, 0 )
						Case FRMDETS_cls_REPOP
							Return SalSendMsg( hWndFormHdl, PAM_clsFRMDETS_REPOPULATE, 0, 0 )
						Case FRMDETS_cls_REPORT
							Return SalSendMsg( hWndFormHdl, PAM_clsFRMDETS_REPORT, 0, 0 )
						Case FRMDETS_cls_FIRSTREC
							Return SalSendMsg( hWndFormHdl, PAM_clsFRMDETS_FIRSTREC, 0, 0 )
						Case FRMDETS_cls_PREVREC
							Return SalSendMsg( hWndFormHdl, PAM_clsFRMDETS_PREVREC, 0, 0 )
						Case FRMDETS_cls_NEXTREC
							Return SalSendMsg( hWndFormHdl, PAM_clsFRMDETS_NEXTREC, 0, 0 )
						Case FRMDETS_cls_LASTREC
							Return SalSendMsg( hWndFormHdl, PAM_clsFRMDETS_LASTREC, 0, 0 )

					Boolean: bNew
					Boolean: bChanged
					Number: nNewOrDetailsOnStartUp
					Window Handle: hWndCallingButton
					String: sFormItemName
				Functions
					Function: FormChildrenLoop
						Description: Performs a loop through the children of the hWndFrmHdl, sending message nPAM_CHILDACTION
								to each child with nMSG_wParam and nMSG_lParam as wParam and lParam to each child.
								The type of children is determined by paramenter nType which should be constanst TYPE_....
								nStopOnReturnValue is the value that a error will be detected on and loop terminated.
								For a case like DATAVAL being sent around then FALSE should be nStopOnReturnValue to force
								each child to trap that message.
						Returns
							Boolean:
						Parameters
							Window Handle: hWndFrmHdl
							Number: nPAM_CHILDACTION
							Number: nMSG_wParam
							Number: nMSG_lParam
							Number: nType
							Number: nStopOnReturnValue
						Static Variables
						Local variables
							Window Handle: hWndChild
							Number: nActionReturn
							Boolean: bError
						Actions
							Call OurWaitCursor( TRUE )
							Set bError = FALSE
							!
							Set hWndChild = SalGetFirstChild( hWndFrmHdl, nType )
							While hWndChild != hWndNULL
								Set nActionReturn = SalSendMsg( hWndChild, nPAM_CHILDACTION, nMSG_wParam, nMSG_lParam )
								If nActionReturn = nStopOnReturnValue
									Set bError = TRUE
									Break
								Else
									Set hWndChild = SalGetNextChild( hWndChild, nType )
							!
							Call OurWaitCursor( FALSE )
							If bError
								Return FALSE
							Else
								Return TRUE
				Message Actions
					On SAM_Create
						Call OurWaitCursor( TRUE )
						Set bSELECTAllowed = TRUE
						Set bINSERTAllowed = TRUE
						Set bUPDATEAllowed = TRUE
						Set bDELETEAllowed = TRUE
						!
						Set sSQLPopHandle = ''
						Set sNAMEPopHandle = ''
						Set sBINDPopHandle = ''
						Set sINTOPopHandle = ''
						!
						Set sSQLInsertHandle = ''
						Set sNAMEInsertHandle = ''
						Set sBINDInsertHandle = ''
						Set sINTOInsertHandle = ''
						!
						Set sSQLUpdateHandle = ''
						Set sNAMEUpdateHandle = ''
						Set sBINDUpdateHandle = ''
						Set sINTOUpdateHandle = ''
						!
						Set sSQLDeleteHandle = ''
						Set sNAMEDeleteHandle = ''
						Set sBINDDeleteHandle = ''
						Set sINTODeleteHandle = ''
						!
						Set bSaveAllowed = TRUE
						Set bDeleteAllowed = TRUE
						Set bClearAllowed = TRUE
						Set bRepopulateAllowed = TRUE
						Set bReportAllowed = FALSE
						Set bFirstRecAllowed = FALSE
						Set bPrevRecAllowed = FALSE
						Set bNextRecAllowed = FALSE
						Set bLastRecAllowed = FALSE
						Set bSaveConfirmation = TRUE
						Set bDeleteConfirmation = TRUE
						Set bClearOnAdd = TRUE
						Set bClearOnSave = FALSE
						Set nNewOrDetailsOnStartUp = FRMDETS_cls_NEWREC
						Set bNew = TRUE
						Set bEdit = FALSE
						Set bChanged = FALSE
						Set hWndCallingButton = hWndNULL
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						If NOT bSaveAllowed
							Call SalSendMsg( pbSave, PAM_clsPB_HIDE, 0, 0 )
						If NOT bDeleteAllowed
							Call SalSendMsg( pbDelete, PAM_clsPB_HIDE, 0, 0 )
						If NOT bClearAllowed
							Call SalSendMsg( pbClear, PAM_clsPB_HIDE, 0, 0 )
						If NOT bRepopulateAllowed
							Call SalSendMsg( pbRePopulate, PAM_clsPB_HIDE, 0, 0 )
						If NOT bReportAllowed
							Call SalSendMsg( pbReport, PAM_clsPB_HIDE, 0, 0 )
						If NOT bFirstRecAllowed
							Call SalSendMsg( pbFirstRec, PAM_clsPB_HIDE, 0, 0 )
						If NOT bPrevRecAllowed
							Call SalSendMsg( pbPrevRec, PAM_clsPB_HIDE, 0, 0 )
						If NOT bNextRecAllowed
							Call SalSendMsg( pbNextRec, PAM_clsPB_HIDE, 0, 0 )
						If NOT bLastRecAllowed
							Call SalSendMsg( pbLastRec, PAM_clsPB_HIDE, 0, 0 )
					On SAM_CreateComplete
						Call SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
						! Call SalInvalidateWindow( hWndForm )
						Call SalGetItemName( hWndForm, sFormItemName )
						Call SalUpdateWindow( hWndForm )
						If IsUserSELECTUser( SqlUser, FALSE )
							If sNAMEPopHandle != ''
								Set nSqlPopHandleNo = SqlHandlesGetReferenceNo( sFormItemName || 'POPHDL' )
								Call haSqlHandles[ nSqlPopHandleNo ].Setup( sSQLPopHandle, sNAMEPopHandle, sBINDPopHandle, sINTOPopHandle )
								! Call SqlVarSetup( haSqlHandles[ nSqlPopHandleNo].hSqlHandle )
								! Call SqlVarSetup( hSqlSelectHandle.hSqlHandle )
						Else
							Set sNAMEPopHandle = ''
							Set bSELECTAllowed = FALSE
						If IsUserINSERTUser( SqlUser, FALSE )
							If sNAMEInsertHandle != ''
								Set nSqlInsertHandleNo = SqlHandlesGetReferenceNo( sFormItemName || 'INSHDL' )
								Call haSqlHandles[ nSqlInsertHandleNo ].Setup( sSQLInsertHandle, sNAMEInsertHandle, sBINDInsertHandle, sINTOInsertHandle )
								! Call SqlVarSetup( haSqlHandles[ nSqlPopHandleNo ].hSqlHandle )
								! Call SqlVarSetup( hSqlInsertHandle.hSqlHandle )
						Else
							Set sNAMEInsertHandle = ''
							Set bINSERTAllowed = FALSE
						If IsUserUPDATEUser( SqlUser, FALSE )
							If sNAMEUpdateHandle != ''
								Set nSqlUpdateHandleNo = SqlHandlesGetReferenceNo( sFormItemName || 'UPDTHDL' )
								Call haSqlHandles[ nSqlUpdateHandleNo ].Setup( sSQLUpdateHandle, sNAMEUpdateHandle, sBINDUpdateHandle, sINTOUpdateHandle )
								! Call SqlVarSetup( haSqlHandles[ nSqlPopHandleNo ].hSqlHandle )
								! Call SqlVarSetup( hSqlUpdateHandle.hSqlHandle )
						Else
							Set sNAMEUpdateHandle = ''
							Set bUPDATEAllowed = FALSE
						If IsUserDELETEUser( SqlUser, FALSE )
							If sNAMEDeleteHandle != ''
								Set nSqlDeleteHandleNo = SqlHandlesGetReferenceNo( sFormItemName || 'DELHDL' )
								Call haSqlHandles[ nSqlDeleteHandleNo ].Setup( sSQLDeleteHandle, sNAMEDeleteHandle, sBINDDeleteHandle, sINTODeleteHandle )
								! Call SqlVarSetup( haSqlHandles[ nSqlPopHandleNo ].hSqlHandle )
								! Call SqlVarSetup( hSqlDeleteHandle.hSqlHandle )
						Else
							Set sNAMEDeleteHandle = ''
							Set bDELETEAllowed = FALSE
						!
						If nNewOrDetailsOnStartUp = FRMDETS_cls_NEWREC OR NOT bSELECTAllowed
							Call SalSendMsg( hWndForm, PAM_cls_INITIALISE, 0, 0 )
							Set bNew = TRUE
							Call SalSendMsg( hWndForm, PAM_clsFRMDETS_CLEAR, 0, 0 )
						Else
							Call SalSendMsg( hWndForm, PAM_clsFRMDETS_REPOPULATE, 0, 0 )
							Set bNew = FALSE
						Call OurWaitCursor( FALSE )
					On PAM_clsFRM_SHOW
						Call SalSendClassMessage( PAM_clsFRM_SHOW, wParam, lParam )
						!
						If nNewOrDetailsOnStartUp = FRMDETS_cls_NEWREC OR NOT bSELECTAllowed
							Call SalSendMsg( hWndForm, PAM_cls_INITIALISE, 0, 0 )
							Set bNew = TRUE
							Call SalSendMsg( hWndForm, PAM_clsFRMDETS_CLEAR, 0, 0 )
						Else
							Call SalSendMsg( hWndForm, PAM_clsFRMDETS_REPOPULATE, 0, 0 )
							Set bNew = FALSE
						Return TRUE
					On SAM_Destroy
						If sNAMEPopHandle != ''
							Call haSqlHandles[ nSqlPopHandleNo ].Disconnect( )
						If sNAMEInsertHandle != ''
							Call haSqlHandles[ nSqlInsertHandleNo ].Disconnect( )
						If sNAMEUpdateHandle != ''
							Call haSqlHandles[ nSqlUpdateHandleNo ].Disconnect( )
						If sNAMEDeleteHandle != ''
							Call haSqlHandles[ nSqlDeleteHandleNo ].Disconnect( )
						Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
					On PAM_cls_EXIT
						If SalSendMsg( hWndForm, PAM_clsFRMDETS_CHECKCHANGES, 0, 0 )
							If bChanged
								Call SalGetItemName( hWndCallingButton, sTmp )
								Call SalPostMsg( SalParentWindow( hWndForm ), PAM_cls_CHILDCHANGED, 0, SalHStringToNumber( sTmp ) )
							Return SalSendClassMessage( PAM_cls_EXIT, wParam, lParam )
						Else
							Return FALSE
					On PAM_cls_REFRESHAFTRCHILDCHANGE
						Return TRUE
					On PAM_cls_CHILDCHANGED
						Call SalShowWindow( hWndForm )
						Call SalBringWindowToTop( hWndForm )
						If SalSendMsg( hWndForm, PAM_cls_REFRESHAFTRCHILDCHANGE, wParam, lParam )
							Call SalSendMsg( hWndForm, PAM_clsFRMDETS_REPOPULATE, 0, 0 )
						Return TRUE
					On PAM_clsFRM_POPFIELDS
						Call SalSendMsg( hWndForm, PAM_clsFRMDETS_POPFIELDS, wParam, lParam )
						Call PopNumber( nNewOrDetailsOnStartUp, TRUE )
						Call PopWndHdl( hWndCallingButton, TRUE )
						Return TRUE
					On PAM_clsFRMDETS_USERACTIONS
						Return UserFormActions( hWndForm, wParam )
					!
					On PAM_clsFRMDETS_POPULATE
						Call OurWaitCursor( TRUE )
						Set bOk = bSELECTAllowed
						If bOk
							If haSqlHandles[ nSqlPopHandleNo ].Execute( )
								If haSqlHandles[ nSqlPopHandleNo ].FetchNext( nInd )
									Call SalSendMsgToChildren( hWndForm, PAM_clsFRMDETS_DISPREC, nInd, 0 )
								Else
									Call SalSendMsg( hWndForm, PAM_clsFRMDETS_NOROWS, 0, 0 )
									Call SalSendMsg( hWndForm, PAM_clsFRMDETS_CLEAR, 0, 0 )
							Else
								Set bOk = FALSE
						Call OurWaitCursor( FALSE )
						Return bOk
					On PAM_clsFRMDETS_REPOPULATE
						Call OurWaitCursor( TRUE )
						Set bOk = bSELECTAllowed
						If bOk
							If bRepopulateAllowed
								If NOT SalSendMsg( hWndForm, PAM_clsFRMDETS_CHECKCHANGES, 0, 0 )
									Set bOk = FALSE
								If bOk
									Set bOk = SalSendMsg( hWndForm, PAM_clsFRMDETS_POPULATE, 0, 0 )
							Else
								Set bOk = FALSE
						Call OurWaitCursor( FALSE )
						Return bOk
					On PAM_clsFRMDETS_CHECKCHANGES
						If bEdit
							If IDYES = SalMessageBox( 'Save Changes first?', sFormHeading, MB_YesNo )
								If NOT SalSendMsg( hWndForm, PAM_clsFRMDETS_SAVE, 0, 0 )
									Return FALSE
						Return TRUE
					On PAM_clsFRMDETS_NOROWS
						Call SalMessageBox( 'No Record Found', sFormHeading, MB_Ok )
					!
					On PAM_clsFRMDETS_SAVE
						Call OurWaitCursor( TRUE )
						Set bSaveOk = TRUE
						If bSaveOk
							If NOT bEdit
								Call SalMessageBox( 'Nothing has been modified!', sFormHeading, MB_Ok )
								Set bSaveOk = FALSE
						If bSaveOk
							If bNew
								Set nSaveType = FRMDETS_cls_NEWREC
								If NOT bINSERTAllowed
									Set bSaveOk = FALSE
							Else
								Set nSaveType = FRMDETS_cls_DISPREC
								If NOT bUPDATEAllowed
									Set bSaveOk = FALSE
							If bSaveConfirmation
								If IDNO = SalMessageBox( 'Are you ready to save your changes?', sFormHeading, MB_YesNo | MB_DefButton1 )
									Set bSaveOk = FALSE
						If bSaveOk
							If NOT FormChildrenLoop( hWndForm, PAM_clsFRMDETS_DATAVAL, nSaveType, 0, FRMDETS_clsChildrenTypes, FALSE )
								Set bSaveOk = FALSE
						If bSaveOk
							If bNew
								If NOT FormChildrenLoop( hWndForm, PAM_clsFRMDETS_CHECKROWNEW, nSaveType, 0, FRMDETS_clsChildrenTypes, FALSE )
									Set bSaveOk = FALSE
							Else
								If NOT FormChildrenLoop( hWndForm, PAM_clsFRMDETS_CHECKROWEDITED, nSaveType, 0, FRMDETS_clsChildrenTypes, FALSE )
									Set bSaveOk = FALSE
						If bSaveOk
							If bNew
								If haSqlHandles[ nSqlInsertHandleNo ].Execute( )
									Call haSqlHandles[ nSqlInsertHandleNo ].Commit( )
									Call SalSendMsgToChildren( hWndForm, PAM_clsFRMDETS_ROWINSERTED, nSaveType, 0 )
									Set bEdit = FALSE
									Set bChanged = TRUE
									If bClearOnAdd
										Call SalSendMsg( hWndForm, PAM_clsFRMDETS_CLEAR, 0, 0 )
								Else
									Set bSaveOk = FALSE
							Else
								If haSqlHandles[ nSqlUpdateHandleNo ].Execute( )
									Call haSqlHandles[ nSqlUpdateHandleNo ].Commit( )
									Call SalSendMsgToChildren( hWndForm, PAM_clsFRMDETS_ROWUPDATED, nSaveType, 0 )
									Set bEdit = FALSE
									Set bChanged = TRUE
									If bClearOnSave
										Call SalSendMsg( hWndForm, PAM_clsFRMDETS_CLEAR, 0, 0 )
								Else
									Set bSaveOk = FALSE
						Call OurWaitCursor( FALSE )
						Return bSaveOk
					On PAM_clsFRMDETS_DELETE
						Call OurWaitCursor( TRUE )
						Set bDeleteOk = bDELETEAllowed
						If bNew
							Call SalSendMsg( pbClear, SAM_Click, 0, 0 )
							Set bDeleteOk = FALSE
						If bDeleteOk
							If bDeleteConfirmation
								If IDNO = SalMessageBox( 'Are you sure you wish to delete?', sFormHeading, MB_YesNo | MB_DefButton2 )
									Set bDeleteOk = FALSE
						If bDeleteOk
							If NOT FormChildrenLoop( hWndForm, PAM_clsFRMDETS_DATAVAL, FRMDETS_cls_DELETE, 0, FRMDETS_clsChildrenTypes, FALSE )
								Set bDeleteOk = FALSE
						If bDeleteOk
							If NOT FormChildrenLoop( hWndForm, PAM_clsFRMDETS_CHECKROWDELETED, FRMDETS_cls_DELETE, 0, FRMDETS_clsChildrenTypes, FALSE )
								Set bDeleteOk = FALSE
						If bDeleteOk
							If haSqlHandles[ nSqlDeleteHandleNo ].Execute( )
								Call haSqlHandles[ nSqlDeleteHandleNo ].Commit( )
								Call SalSendMsgToChildren( hWndForm, PAM_clsFRMDETS_ROWDELETED, FRMDETS_cls_DELETE, 0 )
								Set bEdit = FALSE
								Set bChanged = TRUE
								Call SalSendMsg( hWndForm, PAM_clsFRMDETS_CLEAR, 0, 0 )
							Else
								Set bDeleteOk = FALSE
						Call OurWaitCursor( FALSE )
						Return bDeleteOk
					On PAM_clsFRMDETS_CLEAR
						Call OurWaitCursor( TRUE )
						Set bClearOk = TRUE
						If NOT SalSendMsg( hWndForm, PAM_clsFRMDETS_CHECKCHANGES, 0, 0 )
							Set bClearOk = FALSE
						If bClearOk
							Call SalSendMsgToChildren( hWndForm, PAM_cls_INITIALISE, 0, 0 )
							Call SalSendMsgToChildren( hWndForm, PAM_clsFRMDETS_NEWPREC, 0, 0 )
							Set bNew = TRUE
							Set bEdit = FALSE
						Call OurWaitCursor( FALSE )
						Return bClearOk
					On PAM_clsFRMDETS_REPORT
						Call OurWaitCursor( TRUE )
						Set bOk = TRUE
						Call SalMessageBox( 'This action is not implemented as yet!', sFormHeading, MB_Ok )
						Call OurWaitCursor( FALSE )
						Return bOk
					On PAM_clsFRMDETS_VALIDATE
						Set bEdit = TRUE
						Return TRUE
					!
					On PAM_clsFRMDETS_FIRSTREC
						If SalSendMsg( hWndForm, PAM_clsFRMDETS_CHECKCHANGES, 0, 0 )
							Set bEdit = FALSE
							Return SalSendMsg( hWndCallingButton, PAM_clsFRMDETS_FIRSTREC, 0, 0 )
						Else
							Return FALSE
					On PAM_clsFRMDETS_PREVREC
						If SalSendMsg( hWndForm, PAM_clsFRMDETS_CHECKCHANGES, 0, 0 )
							Set bEdit = FALSE
							Return SalSendMsg( hWndCallingButton, PAM_clsFRMDETS_PREVREC, 0, 0 )
						Else
							Return FALSE
					On PAM_clsFRMDETS_NEXTREC
						If SalSendMsg( hWndForm, PAM_clsFRMDETS_CHECKCHANGES, 0, 0 )
							Set bEdit = FALSE
							Return SalSendMsg( hWndCallingButton, PAM_clsFRMDETS_NEXTREC, 0, 0 )
						Else
							Return FALSE
					On PAM_clsFRMDETS_LASTREC
						If SalSendMsg( hWndForm, PAM_clsFRMDETS_CHECKCHANGES, 0, 0 )
							Set bEdit = FALSE
							Return SalSendMsg( hWndCallingButton, PAM_clsFRMDETS_LASTREC, 0, 0 )
						Else
							Return FALSE

				Property Template:
				Class DLL Name:
				Description:
				Derived From
					Class: clscmbGeneral
				Class Variables
					String: sTmp
					Long String: lsTmp
				Instance Variables
				Functions
				List Initialization
				Message Actions
					! On SAM_Validate
						           Call SalSendMsg( hWndForm, PAM_clsFRMDETS_VALIDATE, wParam, lParam )
						           Return VALIDATE_Ok
					On SAM_SetFocus
						Select Case SalGetDataType( hWndItem )
							Case DT_String
								Set sTmp = MyValue
								Break
							Case DT_LongString
								Set lsTmp = MyValue
								Break
						Return TRUE
					On SAM_KillFocus
						Select Case SalGetDataType( hWndItem )
							Case DT_String
								If sTmp != MyValue
									Call SalSendMsg( hWndForm, PAM_clsFRMDETS_VALIDATE, wParam, lParam )
								Break
							Case DT_LongString
								If lsTmp != MyValue
									Call SalSendMsg( hWndForm, PAM_clsFRMDETS_VALIDATE, wParam, lParam )
								Break
						Return TRUE
					On PAM_clsRB_CLICK
						Call SalSendMsg( hWndForm, PAM_clsFRMDETS_VALIDATE, wParam, lParam )
						Return TRUE
					On PAM_clsFRMDETS_DATAVAL
						Return TRUE
					On PAM_clsFRMDETS_CHECKROWNEW
						Return TRUE
					On PAM_clsFRMDETS_CHECKROWEDITED
						Return TRUE
					On PAM_clsFRMDETS_CHECKROWDELETED
						Return TRUE

					Function: SetLoadAndWait
						Description:
						Returns
							Boolean:
						Parameters
							Boolean: bLoadAndWait
						Static Variables
						Local variables
						Actions
							Set ibLoadAndWait = bLoadAndWait
					Function: SetExecProgram
						Description:
						Returns
							Boolean:
						Parameters
							Boolean: bExecProgram
						Static Variables
						Local variables
						Actions
							Set ibExecProgram = bExecProgram
					Function: StartProgram
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
						Actions
							Call DisplayStartMessage( )
							If NOT __ibDefaultSection
								Call SalGetProfileString( __csAccSectionName, isAppName, '', isProgramExePath, FlemSysIniFileName )
							Else
								Call SalGetProfileString( __csSectionName, isAppName, '', isProgramExePath, FlemSysIniFileName )
							If ibExecProgram
								Call ExecProgram(  )
								Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
							Else If ibLoadAndWait
								Set isProgramExePath = isProgramExePath||' '||isDBName||' '||SqlUser||' '||SqlPassword||' '||isParams
								Call LaunchAppAndWait(  )
								Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
							Else
								Call LaunchApp(  )
							Call ClearStartMessage(  )
							Return TRUE
					Function: DisplayStartMessage
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
						Actions
							Call SalSendMsg( hWndForm, PAM_clsPB_LOADING_START, 0, SalHStringToNumber( isAppName ) )
					Function: ClearStartMessage
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
						Actions
							Call SalSendMsg( hWndForm, PAM_clsPB_LOADING_END, 0, 0 )
				Message Actions
					On SAM_Create
						If NOT __cbInitialized
							If sDatabase = 'LIVE'
								Set __cbLive = TRUE
								Set __csSectionName = IniGeneralLiveSectionName
								Set __csAccSectionName = IniAccountsLiveSectionName
							Else
								Set __cbLive = FALSE
								Set __csSectionName = IniGeneralPlaySectionName
								Set __csAccSectionName = IniAccountsPlaySectionName
							Call SalGetProfileString( __csAccSectionName, 'AccountsUsers', '', __csAccUsers, FlemSysIniFileName )
							Call SalGetProfileString( __csAccSectionName, 'FlemingsFamily', '', __csFamUsers, FlemSysIniFileName )
							Call SalGetProfileString( __csSectionName, 'PriceAdjusters', '', __csPAdjUsers, FlemSysIniFileName )
							Call SalGetProfileString( __csSectionName, 'StockControllers', '', __csSContUsers, FlemSysIniFileName )
							Call SalGetProfileString( __csAccSectionName, 'SystemAdministrators', '', __csSysAdmUsers, FlemSysIniFileName )
							Set __cbInitialized = TRUE
						Set isParams = ''
						Set ibExecProgram = FALSE
						Set inRunMode = Window_Normal
						Set __ibDefaultSection = TRUE
						! If sDatabase = 'LIVE'
							 Set isDBName = 'STOCK'
						! Else
							 Set isDBName = 'STOCKDEV'
						Set isDBName = SqlDatabase
						! do initialize code to get users path and rights etc
			Pushbutton Class: clspbStartProg
				Title:
				Window Location and Size
					Left:  
					Top:   
					Width:  1.8"
					Width Editable? Class Default
					Height: 0.6"
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				List in Tool Palette? Yes
				Property Template:
				Class DLL Name:
				Description:
				Derived From
					Class: clsStartProgram
					Class: clspbGeneral
				Class Variables
				Instance Variables
					Number: __inTimerDelay
				Functions
					Function: GetAppNameFromPath
						Description:
						Returns
							String:
						Parameters
							String: sAppFullName
						Static Variables
						Local variables
							String: sTokens[*]
							Number: nNumTokens
							String: sTmp
							Number: nPos
						Actions
							Set nNumTokens = SalStrTokenize( sAppFullName, '', '\\', sTokens )
							Set sTmp = sTokens[ nNumTokens - 1 ]
							Set nPos = SalStrScan( sTmp, '.' ) 
							If nPos >= 0
								Set sTmp = SalStrLeftX( sTmp, nPos )
							Return SalStrUpperX( sTmp )
				Message Actions
					On SAM_Create
						Set __inTimerDelay = 5000
						! When using clspbStartProg - set the instance variable appearanceonclick = nothing
						Call SalSendClassMessageNamed( clsStartProgram, SAM_Create, wParam, lParam )
						Return SalSendClassMessageNamed( clspbGeneral, SAM_Create, wParam, lParam )
					On SAM_Timer
						!
						If wParam = nTimerId
							! Kill our timer.
							Call SalTimerKill ( hWndItem, nTimerId )
							!
							! Check for the module running in the same process space as the calling app - until it starts
									properly it will be in the same space so we dont want to enable the pb until it has completely started
							If GetModuleHandleA( GetAppNameFromPath( clspbStartProg.isProgramExePath ) )
								!
								! It's still running so set our timer again and wait.
								Call SalTimerSet ( hWndItem, nTimerId, __inTimerDelay )
							Else
								!
								! It's no longer running so stop waiting.
								Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
						Call SalSendClassMessage( SAM_Timer, wParam, lParam )
					On PAM_clsPB_CLICK
						Call SalDisableWindow( hWndItem )
						Call hWndItem.clsStartProgram..StartProgram(  )
						! If the program being started is not an exec program and not a loadandwait then its a loadapp
								so we want to set a timer and only enable the pb when the program has been loaded
						If NOT clspbStartProg.ibExecProgram
							If NOT clspbStartProg.ibLoadAndWait
								Call SalTimerSet ( hWndItem, nTimerId, __inTimerDelay )
						Return TRUE
					On PAM_clsPB_LOADING_END
						! Call SalSendMsg( hWndForm, PAM_clsPB_LOADING_END, wParam, lParam )
						Call SalEnableWindow( hWndItem )
						Call OurWaitCursor( FALSE )

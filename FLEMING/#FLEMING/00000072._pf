				List in Tool Palette? Yes
				Property Template:
				Class DLL Name:
				Description:
				Derived From
					Class: clspbGeneral
				Class Variables
					String: sIniFile
					String: sAppFileName
					String: sAppDescription
					Number: nRunModeReturn
					Window Handle: hWndThisWnd
					String: sTmp
					Number: nTmp
				Instance Variables
					! PUBLIC
					String: sLiveProgramSection
					String: sLiveProgramDescription
					String: sLiveProgramTitle
					String: sLiveProgramDefaultPathNameExt
					!
					String: sPlayProgramSection
					String: sPlayProgramDescription
					String: sPlayProgramTitle
					String: sPlayProgramDefaultPathNameExt
					!
					! sUserTypeRestrictions = NULL, SystemAdministrators, AccountsUsers, SQLConsoleUsers, 
							WinTalkUsers, RepWinUsers, QuestUsers, TeamWinUsers, SqlWinUsers
					String: sUserTypeRestrictions
					Boolean: bLoadAndWait
					Number: nRunMode
					String: sExtraParameterCommandLine
					Number: nTimerDelay
					Number: nTimerId
					!
					Boolean: bStartGuptaApps
					! PRIVATE
					String: sLiveProgramPathNameExt
					String: sPlayProgramPathNameExt
					String: sLiveUsers
					String: sPlayUsers
					Boolean: bAccessGranted
				Functions
					Function: GetAppNameFromPath
						Description:
						Returns
							String:
						Parameters
							String: sAppFullName
						Static Variables
						Local variables
							String: sTokens[*]
							Number: nNumTokens
							String: sTmp
							Number: nPos
						Actions
							Set nNumTokens = SalStrTokenize( sAppFullName, '', '\\', sTokens )
							Set sTmp = sTokens[ nNumTokens - 1 ]
							Set nPos = SalStrScan( sTmp, '.' ) 
							If nPos >= 0
								Set sTmp = SalStrLeftX( sTmp, nPos )
							Return SalStrUpperX( sTmp )
				Message Actions
					On SAM_Create
						Set sIniFile = FlemSysIniFileName
						Set sLiveProgramSection = IniGeneralLiveSectionName
						Set sLiveProgramDescription = ''
						Set sLiveProgramTitle = ''
						Set sLiveProgramDefaultPathNameExt = ''
						Set sLiveProgramPathNameExt = ''
						Set sPlayProgramSection = IniGeneralPlaySectionName
						Set sPlayProgramDescription = ''
						Set sPlayProgramTitle = ''
						Set sPlayProgramDefaultPathNameExt = ''
						Set sPlayProgramPathNameExt = ''
						Set sUserTypeRestrictions = ''
						Set bLoadAndWait = FALSE
						Set nRunMode = Window_Normal
						Set sExtraParameterCommandLine = ''
						Set nTimerDelay = 5000
						! DF 28/4/97 defined in constants now
						! Set nTimerId = 5000
						Set bStartGuptaApps = TRUE
						Set bAccessGranted = TRUE
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Call SalGetProfileString( sLiveProgramSection, sLiveProgramTitle, sLiveProgramDefaultPathNameExt, sLiveProgramPathNameExt, sIniFile )
						Call SalGetProfileString( sPlayProgramSection, sPlayProgramTitle, sPlayProgramDefaultPathNameExt, sPlayProgramPathNameExt, sIniFile )
						If sUserTypeRestrictions != ''
							Call SalGetProfileString( sLiveProgramSection, sUserTypeRestrictions, '', sLiveUsers, sIniFile )
							Call SalGetProfileString( sPlayProgramSection, sUserTypeRestrictions, '', sPlayUsers, sIniFile )
							If SqlDatabase = 'STOCK'
								If NOT SalStrScan( sLiveUsers, SqlUser ) >= 0
									Call SalSendMsg( hWndItem, PAM_clsPB_HIDE, 0, 0 )
									Call SalSendMsg( hWndItem, PAM_clsPB_DISABLE, 0, 0 )
									Set bAccessGranted = FALSE
							Else
								If NOT SalStrScan( sPlayUsers, SqlUser ) >= 0
									Call SalSendMsg( hWndItem, PAM_clsPB_HIDE, 0, 0 )
									Call SalSendMsg( hWndItem, PAM_clsPB_DISABLE, 0, 0 )
									Set bAccessGranted = FALSE
						Return TRUE
					On PAM_clsPB_CLICK
						If bAccessGranted
							Call OurWaitCursor( TRUE )
							If SqlDatabase = 'STOCK'
								Set sAppFileName = sLiveProgramPathNameExt
								Set sAppDescription = sLiveProgramDescription
							Else
								Set sAppFileName = sPlayProgramPathNameExt
								Set sAppDescription = sPlayProgramDescription
							!
							Call SalSendMsg( hWndForm, PAM_clsPB_LOADING_START, 0, SalHStringToNumber( sAppDescription ) )
							If bLoadAndWait
								Set sAppFileName = sAppFileName||' '||SqlDatabase||' '||SqlUser||' '||SqlPassword||' '||sExtraParameterCommandLine
								Call SalPostMsg( hWndItem, PAM_clsPB_LOADING_MINIMIZE, 0, 0 )
								If bStartGuptaApps
									If SalLoadAppAndWait( sAppFileName, nRunMode, nRunModeReturn )
										Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
										Return TRUE
									Else
										Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
										Return FALSE
								Else
									Set nTmp = WinExec( sAppFileName||' '||sExtraParameterCommandLine, SW_SHOW )
									If nTmp >= 32
										Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
										Return TRUE
									Else
										Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
										Return FALSE
							Else
								If bStartGuptaApps
									If SalLoadApp( sAppFileName, SqlDatabase||' '||SqlUser||' '||SqlPassword||' '||sExtraParameterCommandLine )
										!
										! If we've started it set a timer.
										Call SalTimerSet ( hWndItem, nTimerId, nTimerDelay )
										Return TRUE
									Else
										! Had trouble starting it so quit.
										Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
										Return FALSE
								Else
									Set nTmp = WinExec( sAppFileName||' '||sExtraParameterCommandLine, SW_SHOW )
									If nTmp >= 32
										Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
										Return TRUE
									Else
										! Had trouble starting it so quit.
										Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
										Return FALSE
						Else
							Call SalMessageBox( 'Access Denied', 'Warning', MB_Ok )
					! DF 28/4/97 was WM_TIMER
					On SAM_Timer
						!
						! DF 28/4/97
						If wParam = nTimerId
							! Kill our timer.
							Call SalTimerKill ( hWndItem, nTimerId )
							!
							! Check for the module running.
							If GetModuleHandleA( GetAppNameFromPath( sAppFileName ) )
								!
								! It's still running so set our timer again and wait.
								Call SalTimerSet ( hWndItem, nTimerId, nTimerDelay )
							Else
								!
								! It's no longer running so stop waiting.
								Call SalSendMsg( hWndItem, PAM_clsPB_LOADING_END, 0, 0 )
						! DF 28/4/97
						Call SalSendClassMessage( SAM_Timer, wParam, lParam )
					On PAM_clsPB_LOADING_MINIMIZE
						If NOT bLoadAndWait
							Call SalGetWindowText( hWndForm, sTmp, 60 )
							Set hWndThisWnd = FindWindowA( 0, sTmp )
							Call ShowWindow( hWndThisWnd, SW_MINIMIZE )
						Return TRUE
					On PAM_clsPB_LOADING_END
						If NOT bLoadAndWait
							Call SalTimerKill ( hWndItem, nTimerId )
							Call SalGetWindowText( hWndForm, sTmp, 60 )
							Set hWndThisWnd = FindWindowA( 0, sTmp )
							Call ShowWindow( hWndThisWnd, SW_MINIMIZE )
						! Else
							 Call SalGetWindowText( hWndForm, sTmp, 60 )
							 Set hWndThisWnd = FindWindowA( 0, sTmp )
							 Call ShowWindow( hWndThisWnd, SW_RESTORE )
						Call SalSendMsg( hWndForm, PAM_clsPB_LOADING_END, wParam, lParam )
						Call SalSendMsg( hWndItem, PAM_clsPB_ENABLE, 2, 0 )
						Call OurWaitCursor( FALSE )
					On PAM_clsPB_ENABLE
						If wParam = 2
							Return SalSendClassMessage( PAM_clsPB_ENABLE, 0, 0 )
						Else
							Return TRUE
			General Window Class: clsStartProgram
				Description:
				Derived From
				Class Variables
					Boolean: __cbLive
					Boolean: __cbInitialized
					String: __csAccUsers
					String: __csSectionName
					String: __csAccSectionName
					String: __csFamUsers
					String: __csPAdjUsers
					String: __csSContUsers
					String: __csSysAdmUsers
				Instance Variables
					String: isAppName
					String: isDBName
					String: isProgramExePath
					String: isParams
					Boolean: ibLoadAndWait
					Number: inRunMode
					Number: __inRunModeReturn
					Boolean: ibExecProgram
					Boolean: __ibDefaultSection
				Functions
					Function: LaunchApp
						Description:
						Returns
						Parameters
						Static Variables
						Local variables
							Window Handle: hWnd
							Number: nhWnd
							String: sAppName
						Actions
							! Try to find an existing instance of the app
									and bring it to the top
							Set hWnd = SalAppFind( isProgramExePath, FALSE )
							! If we found it
							If hWnd
								! GetLastActivePopup will return the handle of any modal dialogs in use
								Set hWnd = GetLastActivePopup( hWnd )
								Return SalBringWindowToTop( hWnd )
							Else
								! The app was not found, try to load it
								Return SalLoadApp( isProgramExePath, isDBName||' '||SqlUser||' '||SqlPassword||' '||isParams )
					Function: LaunchAppAndWait
						Description:
						Returns
						Parameters
						Static Variables
						Local variables
							Window Handle: hWnd
							Number: nRunModeReturn
						Actions
							! Try to find an existing instance of the app
									and bring it to the top
							Set hWnd = SalAppFind( isProgramExePath, FALSE )
							! If we found it
							If hWnd
								! GetLastActivePopup will return the handle of any modal dialogs in use
								Set hWnd = GetLastActivePopup( hWnd )
								Return SalBringWindowToTop( hWnd )
							Else
								! The app was not found, try to load it
								Return SalLoadAppAndWait( isProgramExePath, inRunMode, __inRunModeReturn )
					Function: ExecProgram
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
							Number: nTmp
						Actions
							Set nTmp = WinExec( isProgramExePath||' '||isParams, SW_SHOW )
							If nTmp >= 32
								Return TRUE
							Else
								Return FALSE
					Function: CloseApp
						Description:
						Returns
						Parameters
							String: sApp
						Static Variables
						Local variables
							Window Handle: hWnd
							Window Handle: hWndChild
						Actions
							! Try to find an existing instance of the app
									and bring it to the top
							Set hWnd = SalAppFind( sApp, FALSE )
							! If we found it
							If hWnd
								! Post it a close message
								! This message must be posted, if you send,
										it screws up Windows
								Call SalPostMsg( hWnd, SAM_Close, 0, 0 )
							Return TRUE
					Function: OnClose
						Description:
						Returns
							Boolean:
						Parameters
							String: sProgName
							Window Handle: hWndCalledFrom
						Static Variables
						Local variables
						Actions
							If not CloseApp( sProgName )
								Return FALSE
							! Post ourselves a close message
							Call SalPostMsg( hWndCalledFrom, PAM_cls_CLOSE, 0, 0  )
					Function: ShutDown
						Description:
						Returns
							Boolean:
						Parameters
							String: sProgName
						Static Variables
						Local variables
						Actions
							! If either of the subsystem apps is still around, don't exit
							If SalAppFind( sProgName, FALSE )
								Return FALSE
							Call SalQuit()
					Function: Enabled
						Description:
						Returns
							Boolean:
						Parameters
							Number: nUserType
						Static Variables
						Local variables
						Actions
							Set __ibDefaultSection = TRUE
							Select Case nUserType
								Case USR_ACCT
									If SalStrScan( __csAccUsers, SqlUser ) >= 0
										Set __ibDefaultSection = FALSE
										Return TRUE
									Else
										Return FALSE
								Case USR_FAMILY
									If SalStrScan( __csFamUsers, SqlUser ) >= 0
										Set __ibDefaultSection = FALSE
										Return TRUE
									Else
										Return FALSE
								Case USR_PRICEADJ
									If SalStrScan( __csPAdjUsers, SqlUser ) >= 0
										Return TRUE
									Else
										Return FALSE
								Case USR_STCKCONTROL
									If SalStrScan( __csSContUsers, SqlUser ) >= 0
										Return TRUE
									Else
										Return FALSE
								Case USR_SYSADM
									If SalStrScan( __csSysAdmUsers, SqlUser ) >= 0
										Set __ibDefaultSection = FALSE
										Return TRUE
									Else
										Return FALSE
								Case USR_GENERAL
									Return TRUE
								Default
									Return TRUE
					Function: SetCreditorDatabase
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
						Actions
							If sDatabase = 'LIVE'
								Set isDBName = 'CREDITOR'
							Else
								Set isDBName = 'CREDDEV'
					Function: SetAppName
						Description:
						Returns
							Boolean:
						Parameters
							String: sAppName
						Static Variables
						Local variables
						Actions
							Set isAppName = sAppName

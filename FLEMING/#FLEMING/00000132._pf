  Days_Of_Credit,
  Comb_Statement 
FROM 
  Customer_Master 
INTO 
  :sGotOrgCustomerType,
  :sGotOrgRegionId,
  :sGotOrgCustName,
  :sGotOrgBusName,
  :sGotOrgCustComments,
  :sGotOrgFNAFlag,

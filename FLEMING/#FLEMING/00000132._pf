.head 3 +  Function: IsORGDUPCustAParent
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nORGCustNo
.head 5 -  Number: nDUPCustNo
.head 5 -  : fcOutputLog
.head 6 -  Class: clsStrLogFile
.head 5 -  Receive Boolean: bResult
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  Number: nInd
.head 5 -  Number: nOurHandleNo
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'IsORGDUPCustAParent' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT 
  Cust_No 
FROM 
  Customer_Master 
WHERE 
  Ass_Cust_No = :nORGCustNo OR 
  Ass_Cust_No = :nDUPCustNo "
.head 7 -  !
.head 7 -  Call haSqlHandles[ nOurHandleNo ].PrepareSetup( sSql )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set bResult = FALSE
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 -  Call fcOutputLog.WriteLogEntry( 'Cannot combine as one of the customers is a parent customer!', hWndForm.lbProgress )
.head 9 -  Set bResult = TRUE
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 3 +  Function: AreORGDUPAssCustNoEqual
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nORGCustNo
.head 5 -  Number: nDUPCustNo
.head 5 -  : fcOutputLog
.head 6 -  Class: clsStrLogFile
.head 5 -  Receive Boolean: bResult
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  Number: nInd
.head 5 -  Number: nOurHandleNo
.head 5 -  Number: nAssCustNo
.head 5 -  Number: nPrevAssCustNo
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'IsORGDUPCustAParent' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT 
  Ass_Cust_No 
FROM 
  Customer_Master 
INTO 
  :nAssCustNo 
WHERE 
  Cust_No = :nORGCustNo OR 
  Cust_No = :nDUPCustNo "
.head 7 -  !
.head 7 -  Call haSqlHandles[ nOurHandleNo ].PrepareSetup( sSql )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set nAssCustNo = NUMBER_Null
.head 7 -  Set nPrevAssCustNo = NUMBER_Null
.head 7 -  Set bResult = TRUE
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 -  Set nPrevAssCustNo = nAssCustNo
.head 9 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 10 +  If NOT nPrevAssCustNo = nAssCustNo
.head 11 -  Set bResult = FALSE
.head 11 -  Call fcOutputLog.WriteLogEntry( 'Cannot combine as the parent customers of do not match!', hWndForm.lbProgress )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 2 -  Window Parameters
.head 2 +  Window Variables
.head 3 -  Boolean: bOk
.head 3 -  Boolean: bResult
.head 3 -  String: sOutputLogFileName
.head 3 -  String: sORGCustName
.head 3 -  : fcOutputLog
.head 4 -  Class: clsStrLogFile
.head 3 -  Number: nListIndex
.head 2 +  Message Actions
.head 3 +  On SAM_CreateComplete
.head 4 -  Call SalSetFocus( dfCustNoOrg )
.head 4 -  Set sOutputLogFileName = OurGetIniFileParameter( 'GENERAL', 'TempStorage', 'C:\\TEMP' ) || '\\CombDupCust.log'
.head 4 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 3 +  On PAM_clsPB_OKACTION
.head 4 -  Call OurWaitCursor( TRUE )
.head 4 -  !
.head 4 +  If IDYES = SalMessageBox( 'This action should be done out of hours or when no other database activity is occouring! Please confirm with database administrators.  Continue?', 'Warning', MB_YesNo | MB_DefButton2 )
.head 5 -  Set bOk = TRUE
.head 5 -  !
.head 5 -  Call fcOutputLog.Setup( sOutputLogFileName, NUMBER_Null, NUMBER_Null )
.head 5 +  If fcOutputLog.Open( )
.head 6 -  Call fcOutputLog.WriteLogEntry( '*', hWndForm.lbProgress )
.head 6 -  Call fcOutputLog.WriteLogEntry( '**********START COMBINATION**********', hWndForm.lbProgress )
.head 6 -  Call fcOutputLog.WriteLogEntry( 'On the ' || DateToStrX( SalDateCurrent(  ) ), hWndForm.lbProgress )
.head 6 -  Call fcOutputLog.WriteLogEntry( '  combining of ORIGINAL Cust_No: ' || SalNumberToStrX( dfCustNoOrg, 0 ) || ' and DUPLICATE Cust_No: ' || SalNumberToStrX( dfCustNoDuplicate, 0 ), hWndForm.lbProgress )
.head 6 -  Call fcOutputLog.WriteLogEntry( '  was performed as follows:-', hWndForm.lbProgress )
.head 5 +  Else
.head 6 -  Set bOk = FALSE
.head 5 -  !
.head 5 +  If bOk
.head 6 +  If SalIsNull( dfCustNoOrg )
.head 7 -  Set bOk = FALSE
.head 7 -  Call SalMessageBox( 'Please enter a Cust_No into the ORIGINAL field!', 'Warning', MB_Ok )
.head 7 -  Call SalSetFocus( dfCustNoOrg )
.head 6 +  If SalIsNull( dfCustNoDuplicate )
.head 7 -  Set bOk = FALSE
.head 7 -  Call SalMessageBox( 'Please enter a Cust_No into the DUPLICATE field!', 'Warning', MB_Ok )
.head 7 -  Call SalSetFocus( dfCustNoDuplicate )
.head 5 +  If bOk
.head 6 -  Call IsORGDUPCustAParent( dfCustNoOrg, dfCustNoDuplicate, fcOutputLog, bResult, SH_cls_Execute )
.head 6 +  If bResult
.head 7 -  Set bOk = FALSE
.head 7 -  Call SalMessageBox( 'Cannot combine as one the customers is a parent customer!', 'Warning', MB_Ok )
.head 5 +  If bOk
.head 6 -  Call AreORGDUPAssCustNoEqual( dfCustNoOrg, dfCustNoDuplicate, fcOutputLog, bResult, SH_cls_Execute )
.head 6 +  If NOT bResult
.head 7 -  Set bOk = FALSE
.head 7 -  Call SalMessageBox( 'Cannot combine as the parent customers of do not match!', 'Warning', MB_Ok )
.head 5 -  ! Starting combining process here
.head 5 +  If bOk
.head 6 +  If CombineCustMasterTable( dfCustNoOrg, sORGCustName, dfCustNoDuplicate, fcOutputLog, SH_cls_Execute )
.head 7 +  If CombineActionReqTable( dfCustNoOrg, dfCustNoDuplicate, fcOutputLog, SH_cls_Execute )
.head 8 +  If CombineAuditTrailTable( dfCustNoOrg, dfCustNoDuplicate, fcOutputLog, SH_cls_Execute )
.head 9 +  If CombineCashApplicationTable( dfCustNoOrg, dfCustNoDuplicate, fcOutputLog, SH_cls_Execute )
.head 10 +  If CombineCashReceiptTable( dfCustNoOrg, dfCustNoDuplicate, fcOutputLog, SH_cls_Execute )
.head 11 +  If CombineCustCancellationTable( dfCustNoOrg, dfCustNoDuplicate, fcOutputLog, SH_cls_Execute )
.head 12 +  If CombineCustOrderTable( dfCustNoOrg, dfCustNoDuplicate, fcOutputLog, SH_cls_Execute )
.head 13 +  If CombineCustPromoTable( dfCustNoOrg, dfCustNoDuplicate, fcOutputLog, SH_cls_Execute )
.head 14 +  If CombineCustOrderHistoryTable( dfCustNoOrg, dfCustNoDuplicate, fcOutputLog, SH_cls_Execute )

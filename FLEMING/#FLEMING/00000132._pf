.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = "SELECT 
  Customer_Type,
  Region_Id,
  Cust_Name,
  Bus_Name,
  Cust_Comments,
  FNA_Flag,
  Cont_Price_Flag,
  Dep_Reqd_Flag,

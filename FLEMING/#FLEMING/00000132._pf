.head 12 -  Call fcOutputLog.WriteLogEntry( 'Duplicate quotations for between Original and Duplicate Customers with discripancies between the Contract Price follows.', hWndForm.lbProgress )
.head 12 -  Set bFirst = FALSE
.head 11 -  Call fcOutputLog.WriteLogEntry( 'Quotations: ' || SalNumberToStrX( nGotYearOfSale, 0 ) || ', ' || 
sGotTreeTypeDesc || ', ' || sGotCultDesc || ', ' || sGotRootDesc || ', ' || SalNumberToStrX( nGotContractPrice, 2 ), hWndForm.lbProgress )
.head 9 +  Else
.head 10 -  Set bOk = FALSE
.head 8 -  !
.head 8 +  If bOk
.head 9 +  While haSqlHandles[ nOurGeneralHandleNo ].FetchNext( nInd ) AND bOk
.head 10 +  If NOT haSqlHandles[ nOurUpdateHandleNo ].Execute( )
.head 11 -  Set bOk = FALSE
.head 8 -  !
.head 8 +  If bOk
.head 9 -  Set sSql = " DELETE FROM Quotation 
WHERE Cust_No = :nDUPCustNo "
.head 9 -  Call haSqlHandles[ nOurDeleteHandleNo ].PrepareSetup( sSql )
.head 9 -  Call SqlVarSetup( haSqlHandles[ nOurDeleteHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 +  If NOT haSqlHandles[ nOurDeleteHandleNo ].Execute( )
.head 10 -  Set bOk = FALSE
.head 8 -  !
.head 8 +  If bOk
.head 9 -  Call fcOutputLog.WriteLogEntry( 'Combining of Quotations Table successfull.', hWndForm.lbProgress )
.head 8 +  Else
.head 9 -  Call fcOutputLog.WriteLogEntry( 'Combining of Quotations Table FAILED.', hWndForm.lbProgress )
.head 7 +  Else
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case SH_cls_Commit
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT haSqlHandles[ nOurUpdateHandleNo ].Commit( )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT haSqlHandles[ nOurDeleteHandleNo ].Commit( )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case SH_cls_Rollback
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT haSqlHandles[ nOurUpdateHandleNo ].Rollback( )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT haSqlHandles[ nOurDeleteHandleNo ].Rollback( )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT haSqlHandles[ nOurGeneralHandleNo ].Disconnect( )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT haSqlHandles[ nOurGenDiscHandleNo ].Disconnect( )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT haSqlHandles[ nOurUpdateHandleNo ].Disconnect( )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT haSqlHandles[ nOurDeleteHandleNo ].Disconnect( )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk

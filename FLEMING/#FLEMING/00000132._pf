  :sGotTreeTypeDesc, 
  :sGotCultDesc, 
  :sGotRootDesc, 
  :nGotContractPrice 
WHERE 
  Q1.Stock_Item_No = Stock_Item.Item_No AND 
  Q1.Cust_No = :nDUPCustNo AND 
  Q2.Cust_No = :nORGCustNo AND 
  Q2.Year_Of_Sale = Q1.Year_Of_Sale AND 
  Q2.Stock_Item_No = Q1.Stock_Item_No AND 
  NOT Q2.Contract_Price = Q1.Contract_Price "

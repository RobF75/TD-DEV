.head 3 +  Function: DeleteDuplicateCustomer
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nDUPCustNo
.head 5 -  : fcOutputLog
.head 6 -  Class: clsStrLogFile
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  Number: nOurHandleNo
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'DeleteDuplicateCustomer' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " DELETE FROM Customer_Master 
WHERE Cust_No = :nDUPCustNo "
.head 7 -  !
.head 7 -  Call haSqlHandles[ nOurHandleNo ].PrepareSetup( sSql )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 -  Call fcOutputLog.WriteLogEntry( 'Duplicate Customer: ' || SalNumberToStrX( nDUPCustNo, 0 ) || ' has been deleted successfully.', hWndForm.lbProgress )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Call fcOutputLog.WriteLogEntry( 'Duplicate Customer: ' || SalNumberToStrX( nDUPCustNo, 0 ) || ' has FAILED to deleted.', hWndForm.lbProgress )
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Commit
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Commit( )
.head 6 +  Case SH_cls_Rollback
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )

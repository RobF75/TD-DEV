  Prev_90YearOrdAmt,
  NPA_Refusal_Flag,
  Bar_Code_Lbls_Reqd,
  Cust_Credit_Limit,
  Credit_Term,
  Cust_AR_Balance,
  Bad_Debt_Flag,
  Perc_Cod,
  COD_Requested_Flag,
  Sv_Chrg_From_Date,
  Override_FrCode,
  Service_Charge,
  Royalty_Owner_code,
  Def_Deliv_Instruct,
  Def_Deliv_type,
  Init_Credit_Term,

.head 9 -  Call fcOutputLog.WriteLogEntry( 'Combining of Customer_Order Table successfull.', hWndForm.lbProgress )
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Call fcOutputLog.WriteLogEntry( 'Combining of Customer_Order Table FAILED.', hWndForm.lbProgress )
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Call fcOutputLog.WriteLogEntry( 'Combining of Customer_Order Table FAILED.', hWndForm.lbProgress )
.head 8 -  Return FALSE

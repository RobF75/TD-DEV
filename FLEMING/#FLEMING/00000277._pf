			Functional Class: fcCreditDebitMatchRecord
				Description: Stores information about a Credit Trans row relating to
						a Debit Trans row
				Derived From
				Class Variables
				Instance Variables
					String: sRefID
					Number: nAmountApplied
					String: sTransUserID
					Date/Time: dtTransSysDT
					Number: nCustNo
					Number: nDRRowNo
				Functions
			Functional Class: fcCustCashAppliedRec
				Description:
				Derived From
				Class Variables
				Instance Variables
					Number: nCustNo
					Number: nAmtApplied
				Functions
			Functional Class: fcCashAppliedToCustomers
				Description:
				Derived From
				Class Variables
				Instance Variables
					: fcaCustCashApplied[*]
						Class: fcCustCashAppliedRec
				Functions
					Function: Setup
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
						Actions
							Set fcaCustCashApplied[ 0 ].nCustNo = NUMBER_Null
							Set fcaCustCashApplied[ 0 ].nAmtApplied = NUMBER_Null
					Function: Insert
						Description:
						Returns
							Boolean:
						Parameters
							Number: nNewCustNo
							Number: nNewAppliedAmt
						Static Variables
						Local variables
							Number: nPos
							Number: nFoundPos
							Number: nFoundAppliedAmt
						Actions
							If Find( nNewCustNo, nFoundPos, nFoundAppliedAmt )
								Set nFoundAppliedAmt = nFoundAppliedAmt + nNewAppliedAmt
								Set fcaCustCashApplied[ nFoundPos ].nAmtApplied = nFoundAppliedAmt
								Return TRUE
							Else
								Set nPos = 0
								While fcaCustCashApplied[ nPos ].nCustNo != NUMBER_Null
									Set nPos = nPos + 1
								Set fcaCustCashApplied[ nPos ].nCustNo = nNewCustNo
								Set fcaCustCashApplied[ nPos ].nAmtApplied = nNewAppliedAmt
								Set nPos = nPos + 1
								Set fcaCustCashApplied[ nPos ].nCustNo = NUMBER_Null
								Set fcaCustCashApplied[ nPos ].nAmtApplied = NUMBER_Null
								Return TRUE
					Function: Find
						Description:
						Returns
							Boolean:
						Parameters
							Number: nFindCustNo
							Receive Number: nFoundPos
							Receive Number: nFoundAppliedAmt
						Static Variables
						Local variables
							Number: nPos
							Boolean: bFound
						Actions
							Set nPos = 0
							Set bFound = FALSE
							Set nFoundPos = NUMBER_Null
							Set nFoundAppliedAmt = NUMBER_Null
							While fcaCustCashApplied[ nPos ].nCustNo != NUMBER_Null AND NOT bFound
								If fcaCustCashApplied[ nPos ].nCustNo = nFindCustNo
									Set nFoundPos = nPos
									Set nFoundAppliedAmt = fcaCustCashApplied[ nPos ].nAmtApplied
									Set bFound = TRUE
								Else
									Set nPos = nPos + 1
							Return bFound
					Function: FetchNext
						Description:
						Returns
							Boolean:
						Parameters
							Receive Number: nFoundCustNo
							Receive Number: nFoundAppliedAmt
							! sActionType = 'RESET_TO_START' OR 'FETCH_NEXT'
							String: sActionType
						Static Variables
							Number: nPos
						Local variables
						Actions
							Set nFoundCustNo = NUMBER_Null
							Set nFoundAppliedAmt = NUMBER_Null
							If sActionType = 'RESET_TO_START'
								Set nPos = 0
								Return TRUE
							Else
								If fcaCustCashApplied[ nPos ].nCustNo = NUMBER_Null
									Return FALSE
								Else
									Set nFoundCustNo = fcaCustCashApplied[ nPos ].nCustNo
									Set nFoundAppliedAmt = fcaCustCashApplied[ nPos ].nAmtApplied
									Set nPos = nPos + 1
									Return TRUE

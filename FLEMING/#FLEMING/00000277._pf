							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
								Call SalSendMsg( hWndForm, PAM_CLICK, wParam, lParam )
							On SAM_SetFocus
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On SAM_Validate
								If colAmtApply > colOrgAmtOuts
									Call SalMessageBox( 'You cannot apply more than the amount outstanding.   Please adjust', 'Cash Receipt', MB_Ok )
									Return VALIDATE_Cancel
								If NOT SalIsNull( hWndItem ) AND colApplied = 'N'
									Call SalTblSetRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_Selected, TRUE )
									Call SalSendMsg( frmReceipt.pbApply, SAM_Click, 0, 0 )
							! On PAM_KILLFOCUSCHECK
								                           If NOT SalIsNull( hWndItem ) AND colApplied = 'N'
									                           Call SalTblSetRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_Selected, TRUE )
									                           Call SalSendMsg( frmReceipt.pbApply, SAM_Click, 0, 0 )
							On PAM_EDITCHECK
								If colApplied = 'Y'
									Call SalTblKillEdit( hWndForm )
								If colTransCode = 'CR'
									Call SalTblKillEdit( hWndForm )
							On PAM_COLOURYOURSELF
								Call SalTblSetCellTextColor( hWndItem, nAppliedColour, TRUE )
							On PAM_COLOURRESET
								Call SalTblSetCellTextColor( hWndItem, COLOR_Default, TRUE )

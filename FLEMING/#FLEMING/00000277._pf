		                           Description: 
		                           Tool Bar 
			                           Contents 
		                           Contents 
			                           Data Field: dfDatabase
				                           Message Actions 
					                           On SAM_Create
						                           If SqlDatabase = 'STOCKDEV'
							                           Set dfDatabase = 'FLEMINGS PLAY SYSTEM'
						                           Else 
							                           Set dfDatabase = ''
			                           Background Text: Invoice No
			                           Data Field: dfInvoiceNo
				                           Message Actions 
					                           On SAM_Create
						                           Call SalSetFocus( hWndItem )
					                           On PAM_QBE
						                           Call PushNumber( dfInvoiceNo )
						                           Call PushString( EQOPERAND )
						                           Call PushString( NUMERICFOLLOWING )
						                           Call PushString( 'REFERENCE_ID' )
						                           Return TRUE
			                           Pushbutton: pbOk
				                           Message Actions 
					                           On SAM_Click
						                           If SalIsNull( dfInvoiceNo )
							                           Call SalMessageBox( 'No Invoice No was entered!  Please enter one first, otherwise Cancel!', 'Warning', MB_Ok )
						                           Else 
							                           Call SalWaitCursor( TRUE )
							                           Call SalDisableWindow( hWndItem )
							                           Call SalSendMsg( frmReceipt.pbClear, SAM_Click, TRUE, 0 )
							                           Call NewGetCustDetailsFromInvNo( dfInvoiceNo, frmReceipt.dfCustNo, frmReceipt.dfCustName, nExecute )
							                           If frmReceipt.dfCustNo > 0
								                           Call SalEndDialog( hWndForm, TRUE )
							                           Else 
								                           Call SalWaitCursor( FALSE )
								                           Call SalMessageBox( 'No Customer was found matching this invoice No!', 'Warning', MB_Ok )
								                           Call SalEnableWindow( hWndItem )
			                           Pushbutton: pbCancel
				                           Message Actions 
					                           On SAM_Click
						                           Call SalWaitCursor( TRUE )
						                           Call SalEndDialog( hWndForm, FALSE )
		                           Functions 
		                           Window Parameters 
		                           Window Variables 
		                           Message Actions 
			                           On SAM_Create
				                           Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
			                           On PAM_CREATECOMPLETE
				                           Call SalWaitCursor( FALSE )

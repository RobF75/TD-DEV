				Pushbutton: pbQCust
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: &Query
					Window Location and Size
						Left:   4.488"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Frminvit.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							If NOT SalSendMsg( hWndForm, PAM_EDITCHECK, 0, 0 )
								Return FALSE
							Call SalWaitCursor( TRUE )
							Call PushWndHdl( hWndForm )
							Call PushNumber( PAM_QBECUST )
							Call BuildWhereQBE(  )
							! Need to prime pushwndhdl again as it is used up in the BuildWhereQBE 
							Call PushNumber( TRUE )
							Call PushWndHdl( hWndItem )
							Call SalDisableWindow( hWndItem )
							Call SalModalDialog( dlgQCustomer, hWndForm )
						On PAM_ENABLE
							! The next line is the standard way of doing a select from a child screen,
									  however in this case we need a multi row selection from the child screen,
									  thats why the PAM_LOOKUP and PAM_READYFORNEXTLOOKUP are 
									  added to this button and the lParam uncommented.
							! If lParam
								                           Call SalSendMsgToChildren( tblSub, PAM_LOOKUPTYPE, 0, 0 )
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )
							If frmReceipt.cmbRcptType = 'CASH'
								Call SalSetFocus( frmReceipt.dfRecptAmt )
							Else
								Call SalSetFocus( frmReceipt.dfDrawer )
						On PAM_LOOKUP
							! This is resetting all of the data that has been primed prior to selecting the customer
							! Call SalSendMsg( pbClear, SAM_Click, TRUE, 0 )
							Call SalSendMsgToChildren( hWndForm, PAM_LOOKUPCUST, 0, 0 )
						On PAM_READYFORNEXTLOOKUP
							! here we dont want a multiple selection
							Return FALSE
				Pushbutton: pbShowRecords
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Show
					Window Location and Size
						Left:   2.988"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Frmcust.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							Call SalWaitCursor( TRUE )
							Call SalDisableWindow( hWndItem )
							If SalIsNull( dfCustNo )
								Call SalWaitCursor( FALSE )
								Call SalMessageBox( 'A Customer No is required before transactions can be shown!', 'Warning', MB_Ok )
								Call SalWaitCursor( TRUE )
								Call SalSetFocus( dfRecptAmt )
							Else
								If rbViewTrans
									If nDepositRowsApplied > 0
										Call SalWaitCursor( FALSE )
										Call SalMessageBox( 'Deposits are Applied but not SAVED!  
												Cannot show transactions!', 'Warning', MB_Ok )
										Call SalWaitCursor( TRUE )
									Else
										Call SalSendMsg( tblTransaction, PAM_POPULATE, 0, 0 )
								Else If rbViewDeposits
									If nTransRowsApplied > 0
										Call SalWaitCursor( FALSE )
										Call SalMessageBox( 'Transactions are Applied but not SAVED!  
												Cannot show Outstanding Deposits!', 'Warning', MB_Ok )
										Call SalWaitCursor( TRUE )
									Else
										Call SalSendMsg( tblOutstandDeposit, PAM_POPULATE, 0, 0 )
							! Else 
								                           If rbViewTrans
									                           If nTransRowsApplied > 0
										                           Call SalWaitCursor( FALSE )
										                           Call SalMessageBox( 'Transactions are Applied but not SAVED!  
												Cannot show transactions!', 'Warning', MB_Ok )
										                           Call SalWaitCursor( TRUE )
									                           Else 
										                           Call SalSendMsg( tblTransaction, PAM_POPULATE, 0, 0 )
								                           Else If rbViewDeposits
									                           If nDepositRowsApplied > 0
										                           Call SalWaitCursor( FALSE )
										                           Call SalMessageBox( 'Outstanding Deposits are Applied but not SAVED!  
												Cannot show Outstanding Deposits!', 'Warning', MB_Ok )
										                           Call SalWaitCursor( TRUE )
									                           Else 
										                           Call SalSendMsg( tblOutstandDeposit, PAM_POPULATE, 0, 0 )
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )
						On PAM_LOOKUPCUST
							Call SalSendMsg( hWndItem, SAM_Click, 0, 0 )
				Pushbutton: pbAddNewDeposit
					Class Child Ref Key: 0

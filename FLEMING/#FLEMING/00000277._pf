			Sql Handle: hSqlTransHistHdl
			Boolean: bTransHistHdlConnected
			Boolean: bTransHistHdlPrepared
			Boolean: bProcRcpt
			Boolean: bProcCshApp
			Date/Time: dtApplyDate
			: CreditDebitMatchRecord[*]
				Class: fcCreditDebitMatchRecord
			Number: nCreditDebitMatchingTrans
			Boolean: bFoundCreditDebitMatch
			Number: nCounter
			Number: nCompCount
			Number: nTotalCredits
			Number: nTotalDebits
			!
			Number: nTotalDepositsUsed
			Number: nTmp
			String: sTmp

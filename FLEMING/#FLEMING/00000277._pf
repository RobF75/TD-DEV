			Data Field: dfCustARBalance
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Data
					Maximum Data Length: Default
					Data Type: Number
					Editable? Yes
				Display Settings
					Window Location and Size
						Left:   Default
						Top:    Default
						Width:  Default
						Width Editable? Yes
						Height: Default
						Height Editable? Yes
					Visible? No
					Border? Yes
					Justify: Left
					Format: Unformatted
					Country: Default
					Font Name: Default
					Font Size: Default
					Font Enhancement: Default
					Text Color: Default
					Background Color: Default
					Input Mask: Unformatted
				Message Actions
					On PAM_UPDATECUST
						Call SalSetFieldEdit( hWndItem, TRUE )
						Call BuildSQL( wParam,hWndItem,'CUSTOMER_MASTER.CUST_AR_BALANCE' )
					On PAM_ADJUSTARBALANCE
						If GetCustARBalance( dfCustNo, dfCustARBalance, nExecute )
							If wParam = nDR
								Set dfCustARBalance = dfCustARBalance + hWndForm.nTransAmount
							Else If wParam = nCR
								Set dfCustARBalance = dfCustARBalance - hWndForm.nTransAmount
							Return TRUE
						Else
							Return FALSE
					On PAM_ADJUSTARBALANCEWROFF
						! If wParam = nDR
							                           Set dfCustARBalance = dfCustARBalance + hWndForm.nTransAmount
						If wParam = nCR
							If frmReceipt.tblTransaction.colAmtOuts > 0
								Set dfCustARBalance = dfCustARBalance - frmReceipt.tblTransaction.colAmtOuts
							Else
								Set dfCustARBalance = dfCustARBalance - frmReceipt.tblTransaction.colTransAmount
						Return TRUE

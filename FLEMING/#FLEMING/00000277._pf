										Call SalMessageBox( 'You cannot writeoff a CR transaction.   Please enter a debit journal through the transaction program', 'Error', MB_Ok )
										Return FALSE
									If NOT SalIsNull( colAmtOuts )
										If colAmtOuts >= nMaxWriteOffAmt 
											Call SalNumberToStr( nMaxWriteOffAmt, 2, sMaxWriteOffAmt )
											If IDOK = SalMessageBox( 'The write off amount is greater then the company default of $' || sMaxWriteOffAmt || '.
													Do you still want to write this amount off.', 'Warning', MB_OkCancel | MB_DefButton2 )
												Set colWriteOff = 'Y'
										Else
											Set colWriteOff = 'Y'
									Else If colTransAmount >= nMaxWriteOffAmt
										Call SalNumberToStr( nMaxWriteOffAmt, 2, sMaxWriteOffAmt )
										If IDOK = SalMessageBox( 'The write off amount is greater then the company default of $' || sMaxWriteOffAmt || '.
												Do you still want to write this amount off.', 'Warning', MB_OkCancel | MB_DefButton2 )
											Set colWriteOff = 'Y'
									Else
										Set colWriteOff = 'Y'
									If colWriteOff = 'Y'
										Call SalTblSetRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_Selected, TRUE )
										Call SalSendMsg( frmReceipt.pbApply, SAM_Click, 0, 0 )
								! Else If colApplied = 'N'
									                           Call SalTblKillEdit( hWndForm )
									                           Call SalMessageBox( 'Please Apply the transaction first, before writing off the outstanding amount!', 'Warning', MB_Ok )
								! Else 
									                           If NOT SalIsNull( colAmtApply )
										                           If colTransAmount - colAmtApply >= nMaxWriteOffAmt
											                           Call SalNumberToStr( nMaxWriteOffAmt, 2, sMaxWriteOffAmt )
											                           If IDOK = SalMessageBox( 'The write off amount is greater then the company default of $' || sMaxWriteOffAmt || '.
													Do you still want to write this amount off.', 'Warning', MB_OkCancel | MB_DefButton2 )
												                           Set colWriteOff = 'Y'
										                           Else 
											                           Set colWriteOff = 'Y'
									                           Else 
										                           Set colWriteOff = 'Y'
							On PAM_ENABLE
								If wParam
									Call SalShowWindow( hWndItem )
								Else
									Call SalHideWindow( hWndItem )
							On PAM_WRITEOFFRESTRICTIONS
								If IsUserAccounts( SqlUser, FALSE )
									Call SalSendMsg( hWndItem, PAM_ENABLE, TRUE, 0 )
								Else
									Call SalSendMsg( hWndItem, PAM_ENABLE, FALSE, 0 )
					Column: colApplied

						Call SalSetFieldEdit( hWndItem, TRUE )
						Call BuildSQL( wParam, hWndItem, 'CHEQUE_DRAWER' )
					! On SAM_SetFocus
						                           Set nFocusIn = nFocusDrawer
					On PAM_LOOKUPCUST
						If SalIsNull( dfDrawer )
							Set dfDrawer = dfCustName 
						If cmbRcptType = 'CASH'
							Set dfDrawer = ''
					On PAM_RESET
						Call SalClearField( hWndItem )
					On PAM_DATAVAL
						If NOT bDataValError
							If cmbRcptType = 'CASH'
								If NOT SalIsNull( hWndItem )
									Set bDataValError = TRUE
									Call SalWaitCursor( FALSE )
									Call SalMessageBox( 'A CASH receipt type is chosen!  
											Cannot have any details in the Drawer field! 
											Please rectify! ', 'Error', MB_Ok )
									Call SalWaitCursor( TRUE )
									Call SalSetFocus( hWndItem )
							! Else If cmbRcptType = 'MONEYORD'
								                           If NOT SalIsNull( hWndItem )
									                           Set bDataValError = TRUE
									                           Call SalWaitCursor( FALSE )
									                           Call SalMessageBox( 'A MONEY ORDER receipt type is chosen!  
											Cannot have any details in the Drawer field! 
											Please rectify! ', 'Error', MB_Ok )
									                           Call SalWaitCursor( TRUE )
									                           Call SalSetFocus( hWndItem )
							Else
								If SalIsNull( hWndItem )
									Set bDataValError = TRUE
									Call SalWaitCursor( FALSE )
									Call SalMessageBox( 'A CHEQUE or MONEYORD receipt type is chosen!  
											Must have details in the Drawer field! 
											Please rectify! ', 'Error', MB_Ok )
									Call SalWaitCursor( TRUE )
									Call SalSetFocus( hWndItem )

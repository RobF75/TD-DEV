.winattr
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title:
				Window Location and Size
					Left:   Default
					Top:    Default
					Width:  Default
					Width Editable? Yes
					Height: Default
					Height Editable? Yes
				Visible? No
				Keyboard Accelerator: Enter
				Font Name: Default
				Font Size: Default
				Font Enhancement: Default
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
.end
				                           Message Actions 
					                           On SAM_Click
						                           Call SalPostMsg( hWndItem, PAM_PROCESSENTER, 0, 0 )
					                           On PAM_PROCESSENTER
						                           Call SalWaitCursor( TRUE )
						                           Select Case nFocusIn
							                           Case nFocusCustNo
								                           If NOT SalSendMsg( hWndForm, PAM_EDITCHECK, 0, 0 )
									                           Return FALSE
								                           If NOT SalIsNull( dfCustNo )
									                           If VerifyCustNoAndGetName( hSqlChckCustHdl, bChckCustHdlConnected, bChckCustHdlPrepared )
										                           If cmbRcptType = 'CHEQUE'
											                           Set dfDrawer = dfCustName
											                           Call SalSetFocus( dfDrawer )
										                           Else 
											                           Call SalSetFocus( dfRecptAmt )
										                           If rbViewTrans
											                           Call SalSendMsg( tblTransaction, PAM_POPULATE, 0, 0 )
										                           Else 
											                           Call SalSendMsg( tblOutstandDeposit, PAM_POPULATE, 0, 0 )
									                           Else 
										                           Call SalWaitCursor( FALSE )
										                           Call SalMessageBox( 'Customer No. does not exist! Please rectify!', 'Warning', MB_Ok )
										                           Call SalWaitCursor( TRUE )
								                           Else 
									                           Call SalSetFocus( dfCustName )
								                           Break 
							                           Case nFocusCustName
								                           If nTransRowsApplied > 0 OR nDepositRowsApplied > 0
									                           If cmbRcptType = 'CHEQUE'
										                           Set dfDrawer = dfCustName
										                           Call SalSetFocus( dfDrawer )
									                           Else 
										                           Call SalSetFocus( dfRecptAmt )
								                           Else 
									                           If NOT SalSendMsg( hWndForm, PAM_EDITCHECK, 0, 0 )
										                           Return FALSE
									                           Call SalSendMsg( pbQCust, SAM_Click, 0, 0 )
									                           If cmbRcptType = 'CHEQUE'
										                           Set dfDrawer = dfCustName
										                           Call SalSetFocus( dfDrawer )
									                           Else 
										                           Call SalSetFocus( dfRecptAmt )
									                           If rbViewTrans
										                           Call SalSendMsg( tblTransaction, PAM_POPULATE, 0, 0 )
									                           Else 
										                           Call SalSendMsg( tblOutstandDeposit, PAM_POPULATE, 0, 0 )
								                           Break 
							                           Case nFocusDrawer
								                           Call SalSetFocus( cmbBank )
								                           Break 
							                           Case nFocusSundry
								                           Call SalSetFocus( mlComments )
								                           Break 
							                           Case nFocusBank
								                           Call SalSetFocus( dfBranch )
								                           Break 
							                           Case nFocusBranch
								                           Call SalSetFocus( dfRecptAmt )
								                           Break 
							                           Case nFocusRecptAmt
								                           If rbViewTrans
									                           Call SalSetFocus( tblTransaction )
									                           Call SalTblFetchRow( tblTransaction, 0 )
									                           Call SalTblSetRowFlags( tblTransaction, 0, ROW_Selected, TRUE )
								                           Else If rbViewDeposits
									                           Call SalSetFocus( tblOutstandDeposit )
									                           Call SalTblFetchRow( tblOutstandDeposit, 0 )
									                           Call SalTblSetRowFlags( tblOutstandDeposit, 0, ROW_Selected, TRUE )
								                           Break 
							                           Case nFocusRcptType
								                           Call SalSetFocus( dfCustNo )
								                           Break 
							                           Case nFocusRbViewTrans
								                           Call SalSetFocus( tblTransaction )
								                           Call SalTblFetchRow( tblTransaction, 0 )
								                           Call SalTblSetRowFlags( tblTransaction, 0, ROW_Selected, TRUE )
								                           Break 
							                           Case nFocusRbViewDeposit
								                           Call SalSetFocus( tblOutstandDeposit )
								                           Call SalTblFetchRow( tblOutstandDeposit, 0 )
								                           Call SalTblSetRowFlags( tblOutstandDeposit, 0, ROW_Selected, TRUE )
								                           Break 
							                           Case nFocusTblTransaction
								                           Set nFocusRow = NUMBER_Null
								                           Set hWndFocusColumn = hWndNULL
								                           Call SalTblQueryFocus( tblTransaction, nFocusRow, hWndFocusColumn )
								                           If hWndFocusColumn = hWndNULL
									                           Call SalSendMsg( pbApply, SAM_Click, 0, 0 )
								                           Else 
									                           Call SalTblKillEdit( tblTransaction )
								                           Break 
							                           Case nFocusTblOutstandDep
								                           Call SalSendMsg( pbApply, SAM_Click, 0, 0 )
								                           Break 
							                           Case nFocusComments
								                           Call SalSetFocus( dfRecptAmt )
								                           Call SalUpdateWindow( hWndForm )
								                           Break 
						                           Call SalWaitCursor( FALSE )
			! Pushbutton: pbHelp

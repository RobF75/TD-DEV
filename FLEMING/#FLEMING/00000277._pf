				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					!
					Boolean: bTablePopulated
					!
					String: sSQLPOPTABLENAME
					String: sORDERBY
					String: sPreBuildWhere
					String: sQueryTmpStr
					String: sCurrentBuildWhere
					Number: nInd
					Number: nRow
					Number: nAppliedColour
				Message Actions
					On PAM_POPULATE
						Call SalSendMsg( frmReceipt.dfDepAmtOuts, PAM_RESET, 0, 0 )
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillAll, PAM_SQL )
						Set bTablePopulated = TRUE
					! On SAM_FetchRow
						                           If SqlFetchRow( hLocalSqlPopTbl, lParam, nInd )
							                           Set frmReceipt.dfDepAmtOuts = frmReceipt.dfDepAmtOuts + colDepAmountReqd
							                           Set colApplied = 'N'
					On SAM_FetchRowDone
						Set frmReceipt.dfDepAmtOuts = frmReceipt.dfDepAmtOuts + colDepAmountReqd
						Set colApplied = 'N'
					On PAM_NOROWS
						Call SalMessageBox( 'No outstanding Deposits were found for this customer!', 'Cash Receipt', MB_Ok )
					On PAM_ENABLE
						If wParam
							Call SalEnableWindow( hWndForm )
							Call SalShowWindow( hWndForm )
							If NOT bTablePopulated AND NOT SalIsNull( frmReceipt.dfCustNo )
								Call SalSendMsg( hWndForm, PAM_POPULATE, 0, 0 )
						Else
							Call SalHideWindow( hWndForm )
							Call SalDisableWindow( hWndForm )
						Call SalSendMsg( frmReceipt.dfDepAmtOuts, PAM_ENABLE, wParam, 0 )
					On PAM_SETROWEDITFLAG
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, wParam )
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_Selected, FALSE )
						Call SalSendMsg( colApplied, PAM_ROWAPPLIED, wParam, 0 )
					On PAM_CLEARAPPLIEDROW
						Call SalTblDeleteRow( hWndForm, lParam, TBL_NoAdjust )
					On PAM_ADDROW
						Call TableAddRowNew( hWndForm, colDepAmountReqd )
						Set colDepYear = frmReceipt.dfYr
						Set colDepDateEntered = SalDateCurrent(  )
						Set colDepDateReqd = SalDateCurrent(  )
						Set colApplied = 'N'
						Set colCompany = frmReceipt.dfRecpCompany
					On PAM_RESET
						Call SalTblReset( hWndForm )
						Set bTablePopulated = FALSE
					On PAM_DATAVAL
						If NOT bDataValError
							Set nRow = TBL_MinRow
							While SalTblFindNextRow( hWndForm, nRow, ROW_New, 0 ) AND NOT bDataValError
								Call SalTblFetchRow( hWndForm, nRow )
								If colApplied != 'Y'
									Set bDataValError = TRUE
									Call SalWaitCursor( FALSE )
									Call ErrorMessage( 'A new deposit must be applied first! 
											Please Rectify!', hWndForm, nRow )
									Call SalWaitCursor( TRUE )
					! On SAM_SetFocus
						                           Set frmReceipt.nFocusIn = nFocusTblOutstandDep
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bTablePopulated = FALSE
						Set nAppliedColour = COLOR_Red
						Set sSQLPOPTABLENAME = ' OUTSTAND_DEPOSIT '
						Set sORDERBY = ' ORDER BY DEP_YEAR_OF_SALE, DEP_DATE_ENTERED '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )

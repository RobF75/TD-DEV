			Function: MySetFocus
				Description:
				Returns
				Parameters
					Number: nFocusIn
				Static Variables
				Local variables
				Actions
					Call SalWaitCursor( TRUE )
					Select Case nFocusIn
						Case nFocusRcptType
							Call SalSetFocus( frmReceipt.cmbRcptType )
							Break
						Case nFocusCustNo
							Call SalSetFocus( frmReceipt.dfCustNo )
							Break
						Case nFocusCustName
							Call SalSetFocus( frmReceipt.dfCustName )
							Break
						Case nFocusDrawer
							Call SalSetFocus( frmReceipt.dfDrawer )
							Break
						Case nFocusSundry
							Call SalSetFocus( frmReceipt.cmbSundryCat )
							Break
						Case nFocusBank
							Call SalSetFocus( frmReceipt.cmbBank )
							Break
						Case nFocusBranch
							Call SalSetFocus( frmReceipt.dfBranch )
							Break
						Case nFocusComments
							Call SalSetFocus( frmReceipt.mlComments )
							Break
						Case nFocusRecptAmt
							Call SalSetFocus( frmReceipt.dfRecptAmt )
							Break
						Case nFocusRbViewTrans
							Call SalSetFocus( frmReceipt.rbViewTrans )
							Break
						Case nFocusRbViewDeposit
							Call SalSetFocus( frmReceipt.rbViewDeposits )
							Break
						Case nFocusTblTransaction
							Call SalSetFocus( frmReceipt.tblTransaction )
							Break
						Case nFocusTblOutstandDep
							Call SalSetFocus( frmReceipt.tblOutstandDeposit )
							Break
					Call SalWaitCursor( FALSE )

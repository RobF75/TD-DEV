								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_WHEREPOPULATE
								Call GetBillCustChildren( frmReceipt.dfCustNo, frmReceipt.naBillCustChildren, nExecute )
								If frmReceipt.naBillCustChildren[0] > 0
									Call MakeNumberList( frmReceipt.naBillCustChildren, 0, ',', '', sQueryTmpStr )
									Set sQueryTmpStr = SalNumberToStrX( frmReceipt.dfCustNo, 0 ) || ',' || sQueryTmpStr
									Set sBuildWhere = ' WHERE Cust_No IN ( ' || sQueryTmpStr || ' ) '
									Call SalShowWindow( colCustNo )
								Else
									Set sBuildWhere = ' WHERE Cust_No = :frmReceipt.dfCustNo '
									Call SalHideWindow( colCustNo )
								! Set sBuildWhere = ' WHERE Cust_No = :frmReceipt.dfCustNo AND Transaction_Code = \'DR\' '

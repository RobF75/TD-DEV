		Functions
			Function: UpdateCustARBalRecord
				Description:
				Returns
					Boolean:
				Parameters
					String: sSQLTABLENAME
					String: sSQLWHERE
					Window Handle: hWndSource
					Number: nPAM_UPDATEMESSAGE
					Number: nPAM_SETVALUESMESSAGE
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					String: sPrevsgSql
					Boolean: bOk
				Actions
					Select Case nActionType
						Case nExecute
							If MyUpdateRecord( hSqlHandle, bHandleConnected, bHandlePrepared, sSQLTABLENAME, sSQLWHERE, hWndSource, nPAM_UPDATEMESSAGE, nPAM_SETVALUESMESSAGE )
								Return TRUE
							Else
								Return FALSE
						Case nCommit
							Set bOk = TRUE
							If bHandleConnected
								Set bOk = SqlCommit( hSqlHandle )
							Return bOk
						Case nRollback
							Set bOk = TRUE
							If bHandleConnected
								Set bOk = SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
								Set bHandlePrepared = TRUE
							Return bOk
						Case nDisconnect
							Set bOk = FALSE
							Set bHandlePrepared = FALSE
							If bHandleConnected
								Set bOk = SqlDisconnect( hSqlHandle )
							Return bOk
						Case nRePrepare
							Set bHandlePrepared = FALSE
							Return TRUE
			Function: GetCustARBalance
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Receive Number: nARBalance
					Number: nExecuteOrDisconnect
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					String: sSql
					Number: nInd
					Number: nGotARBalance
					Boolean: bOk
				Actions
					If nExecuteOrDisconnect != nDisconnect
						If NOT bHandleConnected
							Set bHandleConnected = SqlConnect( hSqlHandle ) 
							If bHandleConnected
								Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
								Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
							Else
								Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
								Return -1
						If NOT bHandlePrepared
							Set sSql = 'SELECT Cust_AR_Balance FROM Customer_Master 
									  INTO :nGotARBalance
									  WHERE Cust_No = :nCustNo '
							If SqlPrepare( hSqlHandle, sSql )
								Set bHandlePrepared = TRUE
							Else
								Set bHandlePrepared = FALSE
						Set nARBalance = NUMBER_Null
						Set nGotARBalance = NUMBER_Null
						If SqlExecute( hSqlHandle )
							Call SqlFetchNext( hSqlHandle, nInd )
							Set nARBalance = nGotARBalance
							Return TRUE
						Else
							Set bHandlePrepared = FALSE
							Return FALSE
					Else
						Set bOk = TRUE
						Set bHandlePrepared = FALSE
						If bHandleConnected
							Set bHandleConnected = FALSE
							Set bOk = SqlDisconnect( hSqlHandle )
						Return bOk
			!
			Function: GetCustomerDetails
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Receive String: sCustName
					Receive String: sBusName
					Receive Boolean: bCustExists
					Number: nExecuteOrDisconnect
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					String: sSql
					Number: nInd
					String: sGotCustName
					String: sGotBusName
					Boolean: bOk
				Actions
					If nExecuteOrDisconnect != nDisconnect
						If NOT bHandleConnected
							Set bHandleConnected = SqlConnect( hSqlHandle ) 
							If bHandleConnected
								Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
								Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
							Else
								Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
								Return -1
						If NOT bHandlePrepared
							Set sSql = 'SELECT Cust_Name, Bus_Name FROM Customer_Master 
									  INTO :sGotCustName, :sGotBusName
									  WHERE Cust_No = :nCustNo '
							If SqlPrepare( hSqlHandle, sSql )
								Set bHandlePrepared = TRUE
							Else
								Set bHandlePrepared = FALSE
						Set sCustName = ''
						Set sGotCustName = ''
						Set sBusName = ''
						Set sGotBusName = ''
						Set bCustExists = FALSE
						If SqlExecute( hSqlHandle )
							If SqlFetchNext( hSqlHandle, nInd )
								Set sCustName = sGotCustName
								Set sBusName = sGotBusName
								Set bCustExists = TRUE
							Return TRUE
						Else
							Set bHandlePrepared = FALSE
							Return FALSE
					Else
						Set bOk = TRUE
						Set bHandlePrepared = FALSE
						If bHandleConnected
							Set bHandleConnected = FALSE
							Set bOk = SqlDisconnect( hSqlHandle )
						Return bOk
			!
			Function: ReceiptUsedAsDeposit
				Description:
				Returns
					Boolean:
				Parameters
					String: sReceiptUserId
					Date/Time: dtReceiptSysDT
					Receive Boolean: bExists
					Number: nActionType
				Static Variables
					: fcOutDepHdl
						Class: hcSqlHandle
					: fcDepHistHdl
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					Number: nInd
					Number: nAmtPaid
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT Dep_Amount_Paid 
									FROM Outstand_Deposit 
									WHERE Receipt_User_Id = :1 AND Rcpt_Sysdatetime = :2 "
							Set sName = 'CHCKRCPTOUTDP2'
							Set sBind = ':sReceiptUserId, :dtReceiptSysDT'
							Set sInto = ':nAmtPaid'
							Call fcOutDepHdl.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOutDepHdl.hSqlHandle )
							!
							Set sSql = " SELECT DepHist_Amt_Paid  
									FROM Deposit_History 
									WHERE Receipt_User_Id = :1 AND Rcpt_Sysdatetime = :2 "
							Set sName = 'CHCKRCPTDPHIST2'
							Set sBind = ':sReceiptUserId, :dtReceiptSysDT'
							Set sInto = ':nAmtPaid'
							Call fcDepHistHdl.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcDepHistHdl.hSqlHandle )
							!
							Set bExists = FALSE
							!
							If fcOutDepHdl.Execute( )
								If fcOutDepHdl.FetchNext( nInd )
									Set bExists = TRUE
									Return TRUE
								Else
									If fcDepHistHdl.Execute( )
										If fcDepHistHdl.FetchNext( nInd )
											Set bExists = TRUE
										Return TRUE
									Else
										Return FALSE
							Else
								Return FALSE
						Case nDisconnect
							Call fcOutDepHdl.Disconnect( )
							Call fcDepHistHdl.Disconnect( )
							Return TRUE
			!
			Function: GetDepositUsed
				Description:
				Returns
					Boolean:
				Parameters
					String: sTransUserId
					Date/Time: dtTransSysDT
					String: sReceiptUserId
					Date/Time: dtReceiptSysDT
					String: sType
					Receive Number: nDepositUsed
					Number: nActionType
				Static Variables
					: fcTransDepHdl
						Class: hcSqlHandle
					: fcTransHistDepHdl
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					Number: nInd
					!
					Boolean: bOk
					!
					Number: nGotDepositUsed
				Actions
					Select Case nActionType
						Case nExecute
							Set nGotDepositUsed = 0
							Set nDepositUsed = 0
							!
							If sType = 'TRANSACTION'
								Set sSql = " SELECT DepHist_Amt_Paid 
										FROM Deposit_History  
										WHERE 
										  Receipt_User_Id = :1 AND 
										  Rcpt_Sysdatetime = :2 AND 
										  Trans_User_Id = :3 AND 
										  Trans_Sysdatetime = :4 "
								Set sName = 'INVUSETRANSDEP'
								Set sBind = ':sReceiptUserId, :dtReceiptSysDT, :sTransUserId, :dtTransSysDT'
								Set sInto = ':nGotDepositUsed'
								!
								Call fcTransDepHdl.Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( fcTransDepHdl.hSqlHandle )
								!
								If fcTransDepHdl.Execute( )
									If fcTransDepHdl.FetchNext( nInd )
										Set nDepositUsed = nGotDepositUsed
									Return TRUE
								Else
									Return FALSE
							Else
								Set sSql = " SELECT DepHist_Amt_Paid 
										FROM Deposit_History  
										WHERE 
										  Receipt_User_Id = :1 AND 
										  Rcpt_Sysdatetime = :2 AND 
										  Trans_Hist_User_Id = :3 AND 
										  Trans_Hist_SysDT = :4 "
								Set sName = 'INVUSETRHISTDEP'
								Set sBind = ':sReceiptUserId, :dtReceiptSysDT, :sTransUserId, :dtTransSysDT'
								Set sInto = ':nGotDepositUsed'
								!
								Call fcTransHistDepHdl.Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( fcTransHistDepHdl.hSqlHandle )
								!
								If fcTransHistDepHdl.Execute( )
									If fcTransHistDepHdl.FetchNext( nInd )
										Set nDepositUsed = nGotDepositUsed
									Return TRUE
								Else
									Return FALSE
						Case nDisconnect
							Call fcTransDepHdl.Disconnect( )
							Call fcTransHistDepHdl.Disconnect( )
							Return TRUE
			!
			Function: GetCRInvoiceTransCred
				Description:
				Returns
					Boolean:
				Parameters
					String: sTransUserId
					Date/Time: dtTransSysDT
					Receive String: sTransRefId
					Receive String: sTransType
					Receive Number: nTransAmount
					Receive Number: nTransAmtOut
					Number: nActionType
				Static Variables
					: fcTransHdl
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					Number: nInd
					!
					String: sGotTransRefId
					String: sGotTransType
					Number: nGotTransAmount
					Number: nGotTransAmtOut
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									TRANSACTION.REFERENCE_ID, 
									TRANSACTION.TRANSACTION_TYPE, 
									TRANSACTION.TRANSACTION_AMOUNT, 
									TRANSACTION.TRANS_AMOUNT_OUTST 
									FROM  
									TRANSACTION  
									WHERE 
									  TRANSACTION.Trans_User_Id = :1 AND
									  TRANSACTION.Trans_SysDatetime = :2 AND 
									  Transaction.Transaction_Code = 'CR' AND 
									  Transaction.Transaction_Type = 'INVOICE' "
							Set sName = 'CRINVTRDEP'
							Set sBind = ':sTransUserId, :dtTransSysDT'
							Set sInto = ':sGotTransRefId, :sGotTransType, :nGotTransAmount, :nGotTransAmtOut'
							!
							Call fcTransHdl.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcTransHdl.hSqlHandle )
							!
							If fcTransHdl.Execute( )
								If fcTransHdl.FetchNext( nInd )
									Set sTransRefId = sGotTransRefId
									Set sTransType = sGotTransType
									Set nTransAmount = nGotTransAmount
									Set nTransAmtOut = nGotTransAmtOut
									Return TRUE
								Else
									Return FALSE
							Else
								Return FALSE
						Case nDisconnect
							Call fcTransHdl.Disconnect( )
							Return TRUE
			Function: GetCRInvoiceTransCredHist
				Description:
				Returns
					Boolean:
				Parameters
					String: sTransUserId
					Date/Time: dtTransSysDT
					Receive String: sTransRefId
					Receive String: sTransType
					Receive Number: nTransAmount
					Receive Number: nTransAmtOut
					Number: nActionType
				Static Variables
					: fcTransHistHdl
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					Number: nInd
					!
					String: sGotTransRefId
					String: sGotTransType
					Number: nGotTransAmount
					Number: nGotTransAmtOut
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									TRANS_HISTORY.HIST_REFERENCE_ID, 
									TRANS_HISTORY.HIST_TRANS_TYPE, 
									TRANS_HISTORY.HIST_TRANS_AMOUNT,
									 TRANS_HISTORY.HIST_AMT_OUTSTAND 
									FROM  
									TRANS_HISTORY  
									 WHERE 
									   TRANS_HISTORY.TRANS_HIST_USER_ID = :1 AND
									   TRANS_HISTORY.TRHIST_SYSDATETIME = :2  AND 
									   TRANS_HISTORY.Hist_Trans_Code = 'CR' AND 
									   TRANS_HISTORY.HIST_TRANS_TYPE = 'INVOICE'"
							Set sName = 'CRINVTRDEPHST'
							Set sBind = ':sTransUserId, :dtTransSysDT'
							Set sInto = ':sGotTransRefId, :sGotTransType, :nGotTransAmount, :nGotTransAmtOut'
							!
							Call fcTransHistHdl.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcTransHistHdl.hSqlHandle )
							!
							If fcTransHistHdl.Execute( )
								If fcTransHistHdl.FetchNext( nInd )
									Set sTransRefId = sGotTransRefId
									Set sTransType = sGotTransType
									Set nTransAmount = nGotTransAmount
									Set nTransAmtOut = nGotTransAmtOut
									Return TRUE
								Else
									Return FALSE
							Else
								Return FALSE
						Case nDisconnect
							Call fcTransHistHdl.Disconnect( )
							Return TRUE
			!
			Function: GetReceiptDepositPaidNotUsed
				Description:
				Returns
					Boolean:
				Parameters
					String: sReceiptUserId
					Date/Time: dtReceiptDT
					Receive Number: nPaidAmount
					Number: nActionType
				Static Variables
					: fcOutHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					Number: nInd
					!
					Number: nGotPaidAmount
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  SUM( Dep_Amount_Paid )
									FROM 
									  Outstand_Deposit 
									WHERE 
									  Receipt_User_Id = :1 AND 
									  Rcpt_Sysdatetime = :2 "
							Set sName = 'GRCPTDPPNUD'
							Set sBind = ':sReceiptUserId, :dtReceiptDT'
							Set sInto = ':nGotPaidAmount'
							!
							Call fcOutHandle.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOutHandle.hSqlHandle )
							!
							Set nPaidAmount = NUMBER_Null
							Set nGotPaidAmount = NUMBER_Null
							!
							If fcOutHandle.Execute( )
								If fcOutHandle.FetchNext( nInd )
									Set nPaidAmount = nGotPaidAmount
									Return TRUE
								Else
									Return FALSE
							Else
								Return FALSE
						Case nDisconnect
							Call fcOutHandle.Disconnect( )
							Return TRUE
			!
			! Function: GetBillingCustomer
				                           Description: 
				                           Returns 
					                           Boolean: 
				                           Parameters 
					                           Number: nCustNo
					                           Receive Number: nBillCustNo
					                           Number: nActionType
				                           Static Variables 
					                           : fcSqlHandle
				                           Local variables 
					                           String: sSql
					                           String: sBind
					                           String: sInto
					                           String: sName
					!
					                           Number: nInd
					!
					                           Number: nGotBillCustNo
				                           Actions 
					                           Select Case nActionType
						                           Case nExecute
							                           Set sSql = " SELECT Ass_Cust_No 
									FROM Customer_Master  
									WHERE 
									  Cust_No = :1 AND "
							                           Set sName = 'GETBILLCST'
							                           Set sBind = ':nCustNo'
							                           Set sInto = ':nGotBillCustNo'
							!
							                           Call fcSqlHandle.Setup( sSql, sName, sBind, sInto )
							                           Call SqlVarSetup( fcSqlHandle.hSqlHandle )
							!
							                           Set nBillCustNo = NUMBER_Null
							                           Set nGotBillCustNo = NUMBER_Null
							!
							                           If fcSqlHandle.Execute( )
								                           If fcSqlHandle.FetchNext( nInd )
									                           Set nBillCustNo = nGotBillCustNo
								                           Return TRUE
							                           Else 
								                           Return FALSE
						                           Case nDisconnect
							                           Return fcSqlHandle.Disconnect( )
			Function: GetBillCustChildren
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Receive Number: naChildrenCustNo[*]
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					!
					Number: nGotChildCustNo
					Number: nPos
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Cust_No
									FROM 
									  Customer_Master
									WHERE 
									  Ass_Cust_No = :1 "
							Set sName = 'GETBLCSTCHILD'
							Set sBind = ':nCustNo'
							Set sInto = ':nGotChildCustNo'
							Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							Set nGotChildCustNo = NUMBER_Null
							Set nPos = 0
							Set naChildrenCustNo[ nPos ] = NUMBER_Null
							!
							If fcOurHandle.Execute( )
								While fcOurHandle.FetchNext( nInd )
									Set naChildrenCustNo[ nPos ] = nGotChildCustNo
									Set nPos = nPos + 1
									Set naChildrenCustNo[ nPos ] = NUMBER_Null
								Return TRUE
							Else
								Return FALSE
						Case nDisconnect
							Return fcOurHandle.Disconnect( )
			!
			Function: GetCustLastChequeDetails
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Receive String: sDrawer
					Receive String: sBank
					Receive String: sBranch
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					!
					String: sGotDrawer
					String: sGotBank
					String: sGotBranch
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Cheque_Drawer,
									  Cheque_Bank, 
									  Cheque_Branch
									FROM 
									  Cash_Receipt
									WHERE  
									  Cust_No = :1
									ORDER BY 
									  Rcpt_Sysdatetime DESC "
							Set sName = 'CSHCSTCHQDETS'
							Set sBind = ':nCustNo'
							Set sInto = ':sGotDrawer, :sGotBank, :sGotBranch'
							Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							Set sDrawer = ''
							Set sBank = ''
							Set sBranch = ''
							!
							Set sGotDrawer = ''
							Set sGotBank = ''
							Set sGotBranch = ''
							!
							If fcOurHandle.Execute( )
								If fcOurHandle.FetchNext( nInd )
									Set sDrawer = sGotDrawer
									Set sBank = sGotBank
									Set sBranch = sGotBranch
								Return TRUE
							Else
								Return FALSE
						Case nDisconnect
							Return fcOurHandle.Disconnect( )
		Window Parameters
		Window Variables
			!
			: structCashAppliedToCustomers

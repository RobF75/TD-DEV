			Boolean: bCompanyMatch
			String: sCompany
		Message Actions
			On SAM_Create
				Set sHelpFileName = 'g:\\apps\\gupta\\help\\qcshrcpt.hlp'
				Set sSqlWhereTransaction = ' WHERE TRANS_USER_ID = :frmReceipt.tblTransaction.colTransUserId AND TRANS_SYSDATETIME = :frmReceipt.tblTransaction.colTransSysDT '
				Set sSqlWhereDeposit = ' WHERE DEP_USER_ID = :frmReceipt.tblOutstandDeposit.colDepUserId AND DEP_SYSDATETIME = :frmReceipt.tblOutstandDeposit.colDepSysDT '
				! Set nFocusIn = nFocusNothing
				!
				Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
				Return SalSendClassMessage( SAM_Create, wParam, lParam )
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
			On PAM_CREATECOMPLETE
				Set bChckCustHdlConnected = FALSE
				Set bChckCustHdlPrepared = FALSE
				Set bWrOffTransHdlConnected = FALSE
				Set bWrOffTransHdlPrepared = FALSE
				Set bSaveTransHdlConnected = FALSE
				Set bSaveTransHdlPrepared = FALSE
				Set bWriteHistHdlConnected = FALSE
				Set bWriteHistHdlPrepared = FALSE
				Set bCshAppWOffHdlConnected = FALSE
				Set bCshAppWOffHdlPrepared = FALSE
				Set bWriteCshRcptHdlConnected = FALSE
				Set bWriteCshRcptHdlPrepared = FALSE
				Set bWriteCashAppHdlConnected = FALSE
				Set bWriteCashAppHdlPrepared = FALSE
				Set bQInvNoHdlConnected = FALSE
				Set bQInvNoHdlPrepared = FALSE
				Set bCmbBankHdlConnected = FALSE
				Set bCmbBankPopulated = FALSE
				Set bCmbSundryHdlConnected = FALSE
				Set bCmbSundryPopulated = FALSE
				Set bCashRcptsHdlConnected = FALSE
				Set bCashRcptsHdlPrepared = FALSE
				!
				Set bEdit = FALSE
				Set nTransRowsApplied = 0
				Set nDepositRowsApplied = 0
				Set nCreditDebitMatchingTrans = 0
				!
				Set dfCurrentDate = SalDateCurrent(  )
				Set dtApplyDate = dfCurrentDate
				Set dfYr = OurDateYear( dfCurrentDate )
				Set nQtr = SalDateQuarter( dfCurrentDate )
				If nQtr = 4
					Set dfYr = dfYr + 1
				Set dtDepositListFromDate = dfCurrentDate
				Set dtDepositListToDate = dfCurrentDate
				Set dfRecptDate = dfCurrentDate
				!
				Call SalSendMsg( hWndForm, PAM_SWITCHTABLETO, nTableTransaction, 0 )
				Call SalMapEnterToTab( TRUE )
				Call SalSetFocus( dfRecptAmt )
				! Call SalModalDialog( dlgApplyDate, hWndForm, dtApplyDate )
			On SAM_Destroy
				If bChckCustHdlConnected
					Call SqlDisconnect( hSqlChckCustHdl )
				If bWrOffTransHdlConnected
					Call SqlDisconnect( hSqlWrOffTransHdl )
				If bSaveTransHdlConnected
					Call SqlDisconnect( hSqlSaveTransHdl )
				If bWriteHistHdlConnected
					Call SqlDisconnect( hSqlWriteHistHdl )
				If bWriteCashAppHdlConnected
					Call SqlDisconnect( hSqlWriteCashAppHdl )
				If bWriteCshRcptHdlConnected
					Call SqlDisconnect( hSqlWriteCshRcptHdl )
				If bSaveDepHdlConnected
					Call SqlDisconnect( hSqlSaveDepHdl )
				If bInsNewDepHdlConnected
					Call SqlDisconnect( hSqlInsNewDepHdl )
				If bInsDepHdlConnected
					Call SqlDisconnect( hSqlInsDepHdl )
				If bQInvNoHdlConnected
					Call SqlDisconnect( hSqlQInvNoHdl )
				If bCmbBankHdlConnected
					Call SqlDisconnect( hSqlCmbBankHdl )
				If bCmbSundryHdlConnected
					Call SqlDisconnect( hSqlCmbSundryHdl )
				If bCshAppWOffHdlConnected
					Call SqlDisconnect( hSqlCshAppWOffHdl )
				If bCashRcptsHdlConnected
					Call SqlDisconnect( hSqlCashRcptsHdl )
				Call GetCustARBalance( 0, dfCustARBalance, nDisconnect )
				Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nDisconnect )
				!
				Call GetCustLastChequeDetails( 0, dfDrawer, cmbBank, dfBranch, nDisconnect )
				!
				! Call NewGetCustDetailsFromInvNo( 0, nTmp, sTmp, nDisconnect )
				Call SalSendMsg( hWndCallProg, PAM_ENABLE, 0, 0 )
				Call CheckForFinishedTrans( 0, '', '', 0, 0, DATETIME_Null, tblTransaction.colDaysToPay, nDisconnect )
				Call UpdtCustDaysOfCredAvg( 0, nDisconnect )
			On SAM_Close
				Call SalSendValidateMsg(  )
				If NOT SalSendMsg( hWndForm, PAM_EDITCHECK, 0, 0 )
					Return FALSE
				If IDCANCEL = SalMessageBox( 'You are about to EXIT the CASH RECEIPTS program, 
						Do you want to do this?', 'Warning', MB_OkCancel )
					Return FALSE
				Call SalWaitCursor( TRUE )
			On PAM_EDITCHECK
				If bEdit
					If NOT ForgetChanges(  )
						Return FALSE
					Else
						Return TRUE
				Else
					Return TRUE
			On PAM_SWITCHTABLETO
				Select Case wParam
					Case nTableTransaction
						Call SalSendMsg( tblOutstandDeposit, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblTransaction, PAM_ENABLE, TRUE, 0 )
						Break
					Case nTableDeposit
						Call SalSendMsg( tblTransaction, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblOutstandDeposit, PAM_ENABLE, TRUE, 0 )
						Break
			On PAM_PRINTDEPOSITLISTING
				Call SalWaitCursor( TRUE )
				If wParam = nBankListing
					Set dfRepListingType = 'BANK'
				Else
					Set dfRepListingType = 'COMPANY'
				!
				Set bPrintDepListing = TRUE
				Set bPrintReconListing = FALSE
				!
				Set sSQLREPTABLENAME = ' Cash_Receipt, Customer_Master '
				! Set sSQLREPWHERE = ' WHERE 
						  Cash_Receipt.Cust_No = Customer_Master.Cust_No(+) AND
						  Receipt_Date BETWEEN :dtDepositListFromDate AND :dtDepositListToDate 
						ORDER BY RECEIPT_TYPE'
				! ORDERING THIS BY RECEIPTDATE SHOULDNT IMPACT THE DAILY BANK LISTINGS
				If sAlphaOrder = 'Y'
					Set sSQLREPWHERE = ' WHERE 
							  Cash_Receipt.Cust_No = Customer_Master.Cust_No(+) AND
							Cash_Receipt.Company = :sCompany and
							  Receipt_Date BETWEEN :dtDepositListFromDate AND :dtDepositListToDate 
							ORDER BY CUSTOMER_Master.Cust_Name'
				Else
					Set sSQLREPWHERE = ' WHERE 
							  Cash_Receipt.Cust_No = Customer_Master.Cust_No(+) AND
							Cash_Receipt.Company = :sCompany and
							  Receipt_Date BETWEEN :dtDepositListFromDate AND :dtDepositListToDate 
							ORDER BY RECEIPT_DATE, RECEIPT_TYPE, CHEQUE_BANK'
				!
				! THE NEXT LINE IS TO ENSURE THE TODATE IS INCLUSIVE IN THE SEARCH CRITERIA - not reqd
						now that we are in 1997
				! Set nYear = OurDateYear( dtDepositListToDate )
				! If nYear > 70
					                           Set nYear = nYear + 1900
				! Else
					                           Set nYear = nYear + 2000
				! Set dtDepositListToDate = SalDateConstruct( nYear, SalDateMonth( dtDepositListToDate ), SalDateDay( dtDepositListToDate ), 23, 59, 59.999999 )
				Set frmReceipt.dfFromDate = dtDepositListFromDate
				Set frmReceipt.dfToDate = dtDepositListToDate
				!
				! Call CallBuildSql( hWndForm, nSELECT, PAM_REPORTFIELDS, '', '' )
				Set sRepInto = 'ListingType, 
						Drawer, 
						Bank, 
						Branch, 
						Amount, 
						CustNo, 
						ReceiptType, 
						CustName, 
						Sundry, 
						SundryAmount, 
						Comments, 
						ChequeTotal, 
						CashTotal, 
						GrandTotal, 
						CatalogTotal, 
						SundryTotal, 
						DepositTotal, 
						DebtorsTotal, 
						ReceiptDate, 
						FromDate, 
						ToDate
						UsedAsDeposit, 
						ChequeNo,
						Company'
				Set sRepBind = ':frmReceipt.dfRepListingType, 
						:frmReceipt.dfRepDrawer, 
						:frmReceipt.dfRepBank, 
						:frmReceipt.dfRepBranch, 
						:frmReceipt.dfRepAmount, 
						:frmReceipt.dfRepCustNo, 
						:frmReceipt.dfRepReceiptType, 
						:frmReceipt.dfRepCustName, 
						:frmReceipt.dfRepSundry, 
						:frmReceipt.dfRepSundryAmount, 
						:frmReceipt.dfRepComments, 
						:frmReceipt.dfRepChequeTotal, 
						:frmReceipt.dfRepCashTotal, 
						:frmReceipt.dfRepGrandTotal, 
						:frmReceipt.dfRepCatalogTotal, 
						:frmReceipt.dfRepSundryTotal, 
						:frmReceipt.dfRepDepositTotal, 
						:frmReceipt.dfRepDebtorsTotal, 
						:frmReceipt.dfReceiptDate, 
						:frmReceipt.dfFromDate, 
						:frmReceipt.dfToDate, 
						:frmReceipt.sUsedAsDeposit, 
						:frmReceipt.dfChqNo,
						:sCompany'
				!
				Set sReportFile =  OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\deplist7.qrp'
				! Set sReportFile = 'g:\\apps\\gupta\\reports\\deplist6.qrp'
				Set nError = 1
				Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, RPT_PrintAll,0,0, nError )
			On PAM_PRINTRECONLISTING
				Call SalWaitCursor( TRUE )
				Set dfRepListingType = 'RECONCILIATION'
				!
				Set bPrintReconListing = TRUE
				Set bPrintDepListing = FALSE
				!
				Set sSQLREPTABLENAME = ' Cash_Receipt, Customer_Master '
				Set sSQLTRANSTABLENAME = ' TRANSACTION '
				Set sSQLTRANSHISTTABLENAME = ' TRANS_HISTORY '
				If bCustomerRec
					Set sSQLREPWHERE = ' WHERE 
							  Cash_Receipt.Cust_No = Customer_Master.Cust_No(+) AND
							CAsh_Receipt.Company = :sCompany and
							  Receipt_Date BETWEEN :dtDepositListFromDate AND :dtDepositListToDate 
							ORDER BY CUST_Name'
					! Set sSQLREPWHERE = ' WHERE 
							  Cash_Receipt.Cust_No = Customer_Master.Cust_No(+) AND
							  Receipt_Date BETWEEN :dtDepositListFromDate AND :dtDepositListToDate 
							ORDER BY CASH_RECEIPT.CUST_NO'
				Else If bCashRec 
					Set sSQLREPWHERE = ' WHERE 
							  Cash_Receipt.Cust_No = Customer_Master.Cust_No(+) AND
							CAsh_Receipt.Company = :sCompany and
							  Receipt_Date BETWEEN :dtDepositListFromDate AND :dtDepositListToDate 
							ORDER BY CASH_RECEIPT.RECEIPT_DATE '
				Set sSQLTRANSWHERE = ' WHERE 
						  TRANSACTION.TRANS_USER_ID = :frmReceipt.tblCashApp.colTransUser AND
						   TRANSACTION.TRANS_SYSDATETIME = :frmReceipt.tblCashApp.colTransDate '
				Set sSQLTRANSHISTWHERE = ' WHERE 
						   TRANS_HISTORY.TRANS_HIST_USER_ID = :frmReceipt.tblCashApp.colTransHistUser AND
						   TRANS_HISTORY.TRHIST_SYSDATETIME = :frmReceipt.tblCashApp.colTransHistDate'
				!
				! THE NEXT LINE IS TO ENSURE THE TODATE IS INCLUSIVE IN THE SEARCH CRITERIA
				Set nYear = OurDateYear( dtDepositListToDate )
				! If nYear > 70
					                           Set nYear = nYear + 1900
				! Else
					                           Set nYear = nYear + 2000
				Set dtDepositListToDate = SalDateConstruct( nYear, SalDateMonth( dtDepositListToDate ), SalDateDay( dtDepositListToDate ), 23, 59, 59.999999 )
				Set frmReceipt.dfFromDate = dtDepositListFromDate
				Set frmReceipt.dfToDate = dtDepositListToDate
				!
				If bCashRec
					Set sRepInto = 'ListingType, 
							Drawer, 
							Bank, 
							Branch, 
							Amount, 
							CustNo, 
							ReceiptType, 
							CustName, 
							Sundry, 
							SundryAmount, 
							Comments, 
							ChequeTotal, 
							CashTotal, 
							ReceiptDateTime, 
							ReceiptDate, 
							FullyApplied, 
							UnappAmt, 
							OutstandDepositPayed, 
							DepositUsed, 
							ReferenceId, 
							TransType, 
							TransAmt, 
							TransAmtOutst, 
							HistRefId, 
							HistTransType, 
							HistTransAmt, 
							HistTransAmtOutst, 
							FromDate, 
							ToDate, 
							DateApplied, 
							AppliedAmt, 
							TotalDepositsUsed,
							Company'
					Set sRepBind = ':frmReceipt.dfRepListingType, 
							:frmReceipt.dfRepDrawer, 
							:frmReceipt.dfRepBank, 
							:frmReceipt.dfRepBranch, 
							:frmReceipt.dfRepAmount, 
							:frmReceipt.dfRepCustNo, 
							:frmReceipt.dfRepReceiptType, 
							:frmReceipt.dfRepCustName, 
							:frmReceipt.dfRepSundry, 
							:frmReceipt.dfRepSundryAmount, 
							:frmReceipt.dfRepComments, 
							:frmReceipt.dfRepChequeTotal, 
							:frmReceipt.dfRepCashTotal, 
							:frmReceipt.dfRecDate, 
							:frmReceipt.dfReceiptDate, 
							:frmReceipt.dfRepFullyApplied, 
							:frmReceipt.dfRepUnappliedAmt, 
							:frmReceipt.dfRepDeposit, 
							:frmReceipt.dfRepDepositUsed, 
							:frmReceipt.dfRefId, 
							:frmReceipt.dfTrType, 
							:frmReceipt.dfTrAmt, 
							:frmReceipt.dfTrAmtOuts, 
							:frmReceipt.dfHistRefId, 
							:frmReceipt.dfHistTransType, 
							:frmReceipt.dfHistTransAmt, 
							:frmReceipt.dfHistTransAmtOuts, 
							:frmReceipt.dfFromDate, 
							:frmReceipt.dfToDate, 
							:frmReceipt.tblCashApp.colDateApplied, 
							:frmReceipt.tblCashApp.colAppAmount, 
							:frmReceipt.nTotalDepositsUsed,
							:sCompany'
					Set sReportFile = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\dayrcon5.qrp'
					! Set sReportFile = 'g:\\apps\\gupta\\reports\\dayrcon4.qrp'
				Else If bCustomerRec
					Call CallBuildSql( hWndForm, nSELECT, PAM_REPORTFIELDS, '', '' )
					Set sRepInto = sColumns
					Set sRepBind = sIntoVars
					Call CallBuildSql( tblCashApp, nSELECT, PAM_REPORTFIELDS, '', '' )
					Set sRepInto = sRepInto||', '||sColumns
					Set sRepBind = sRepBind||', '||sIntoVars
					Set sReportFile = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\deprcon5.qrp'
				Set nError = 1
				Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, RPT_PrintAll,0,0, nError )
			On SAM_ReportStart
				If bPrintDepListing
					If NOT bCashRcptsHdlConnected
						Set bCashRcptsHdlConnected = SqlConnect( hSqlCashRcptsHdl ) 
						If bCashRcptsHdlConnected
							Call SqlSetLockTimeout( hSqlCashRcptsHdl, SQLTIMEOUT )
							Call SqlSetParameter( hSqlCashRcptsHdl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bCashRcptsHdlPrepared
						Call CallBuildSql( hWndForm, nSELECT, PAM_SQLDEPOSITLISTING, sSQLREPTABLENAME, sSQLREPWHERE )
						If SqlPrepare( hSqlCashRcptsHdl, sgSql )
							Set bCashRcptsHdlPrepared = TRUE
						Else
							Set bCashRcptsHdlPrepared = FALSE
					If bCashRcptsHdlPrepared
						If NOT SqlExecute( hSqlCashRcptsHdl )
							Set bCashRcptsHdlPrepared = FALSE
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Could not execute query for cash receipts for this report!  Please contact programmers!', 'Error', MB_Ok )
							Call SalWaitCursor( TRUE )
							Return FALSE
					!
					Return TRUE
				If bPrintReconListing
					If NOT bCashRcptsHdlConnected
						Set bCashRcptsHdlConnected = SqlConnect( hSqlCashRcptsHdl ) 
						If bCashRcptsHdlConnected
							Call SqlSetLockTimeout( hSqlCashRcptsHdl, SQLTIMEOUT )
							Call SqlSetParameter( hSqlCashRcptsHdl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bCashRcptsHdlPrepared
						Call CallBuildSql( hWndForm, nSELECT, PAM_SQLDEPOSITLISTING, sSQLREPTABLENAME, sSQLREPWHERE )
						If SqlPrepare( hSqlCashRcptsHdl, sgSql )
							Set bCashRcptsHdlPrepared = TRUE
						Else
							Set bCashRcptsHdlPrepared = FALSE
					If bCashRcptsHdlPrepared
						If NOT SqlExecute( hSqlCashRcptsHdl )
							Set bCashRcptsHdlPrepared = FALSE
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Could not execute query for cash receipts for this report!  Please contact programmers!', 'Error', MB_Ok )
							Call SalWaitCursor( TRUE )
							Return FALSE
					If NOT bTransHdlConnected
						Set bTransHdlConnected = SqlConnect( hSqlTransHdl ) 
						If bTransHdlConnected
							Call SqlSetLockTimeout( hSqlTransHdl, SQLTIMEOUT )
							Call SqlSetParameter( hSqlTransHdl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bTransHdlPrepared
						Call CallBuildSql( hWndForm, nSELECT, PAM_SQLTRANS, sSQLTRANSTABLENAME, sSQLTRANSWHERE )
						If SqlPrepare( hSqlTransHdl, sgSql )
							Set bTransHdlPrepared = TRUE
						Else
							Set bTransHdlPrepared = FALSE
					If NOT bTransHistHdlConnected
						Set bTransHistHdlConnected = SqlConnect( hSqlTransHistHdl ) 
						If bTransHistHdlConnected
							Call SqlSetLockTimeout( hSqlTransHistHdl, SQLTIMEOUT )
							Call SqlSetParameter( hSqlTransHistHdl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bTransHistHdlPrepared
						Call CallBuildSql( hWndForm, nSELECT, PAM_SQLTRANSHIST, sSQLTRANSHISTTABLENAME, sSQLTRANSHISTWHERE )
						If SqlPrepare( hSqlTransHistHdl, sgSql )
							Set bTransHistHdlPrepared = TRUE
						Else
							Set bTransHistHdlPrepared = FALSE
					!
					Return TRUE
			On SAM_ReportFetchInit
				If bPrintDepListing
					Call SalSendMsgToChildren( hWndForm, PAM_RESETREPORTFIELDS, 0, 0 )
					Return TRUE
				If bPrintReconListing
					Call SalSendMsgToChildren( hWndForm, PAM_RESETREPORTFIELDS, 0, 0 )
					Set nTotalDepositsUsed = 0
					Set bProcRcpt = TRUE
					Set bProcCshApp = FALSE
					Return TRUE
			On SAM_ReportFetchNext
				If bPrintDepListing
					If SqlFetchNext( hSqlCashRcptsHdl, nInd )
						If nInd = FETCH_EOF
							Return FALSE
						! If dfRepReceiptType = 'CHEQUE'
							                           Set dfRepChequeTotal = dfRepChequeTotal + dfRepAmount
						! Else
							                           Set dfRepCashTotal = dfRepCashTotal + dfRepAmount
						If dfRepReceiptType = 'CASH'
							Set dfRepCashTotal = dfRepCashTotal + dfRepAmount
						Else
							Set dfRepChequeTotal = dfRepChequeTotal + dfRepAmount
						Set dfRepGrandTotal = dfRepGrandTotal + dfRepAmount
						Set dfRepUnAppliedTotal = dfRepUnAppliedTotal + dfRepUnappliedAmt
						If dfRepSundry != ''
							Set dfRepSundryAmount = dfRepAmount
							Set dfRepSundryTotal = dfRepSundryTotal + dfRepAmount
							If dfRepSundry = 'CATALOG'
								Set dfRepCatalogTotal = dfRepCatalogTotal + dfRepAmount
						Else
							Set dfRepSundryAmount = 0
						!
						Call ReceiptUsedAsDeposit( dfRecUser, dfRecDate, bExists, nExecute )
						If bExists
							Set sUsedAsDeposit = 'Deposit'
							Set dfRepDepositTotal = dfRepDepositTotal + dfRepAmount
						Else
							Set sUsedAsDeposit = ''
						Return TRUE
					Else
						Return FALSE
				If bPrintReconListing
					Loop
						If bProcRcpt
							If SqlFetchNext( hSqlCashRcptsHdl, nInd )
								If nInd = FETCH_EOF
									Return FALSE
								! If dfRepReceiptType = 'CHEQUE'
									                           Set dfRepChequeTotal = dfRepChequeTotal + dfRepAmount
								! Else
									                           Set dfRepCashTotal = dfRepCashTotal + dfRepAmount
								If dfRepReceiptType = 'CASH'
									Set dfRepCashTotal = dfRepCashTotal + dfRepAmount
								Else
									Set dfRepChequeTotal = dfRepChequeTotal + dfRepAmount
								Set dfRepGrandTotal = dfRepGrandTotal + dfRepAmount
								Set dfRepUnAppliedTotal = dfRepUnAppliedTotal + dfRepUnappliedAmt
								If dfRepSundry != ''
									Set dfRepSundryAmount = dfRepAmount
									Set dfRepSundryTotal = dfRepSundryTotal + dfRepAmount
									If dfRepSundry = 'CATALOG'
										Set dfRepCatalogTotal = dfRepCatalogTotal + dfRepAmount
								Else
									Set dfRepSundryAmount = 0
								!
								Call GetReceiptDepositPaidNotUsed( dfRecUser, dfRecDate, nDepPaidNotUsed, nExecute )
								Set dfRepDepPaidNUsedTotal = dfRepDepPaidNUsedTotal + nDepPaidNotUsed
								!
								Set dfRepDeposit = 0
								Set bAnyCashApp = TRUE
								Call SalSendMsg( frmReceipt.tblCashApp, PAM_POPULATE, 0, 0 )
								Set nCashAppRow = TBL_MinRow
								Set bProcCshApp = TRUE
								Set bProcRcpt = FALSE
								Call SalSendMsgToChildren( frmReceipt, PAM_RESETTRANS, 0, 0 )
								Call SalSendMsgToChildren( frmReceipt, PAM_RESETHIST, 0, 0 )
							Else
								Return FALSE
						If bProcCshApp
							If SalTblFindNextRow( frmReceipt.tblCashApp, nCashAppRow, 0, 0 )
								Call SalTblFetchRow( frmReceipt.tblCashApp, nCashAppRow )
								If NOT SalIsNull( tblCashApp.colTransDate )
									If SqlExecute( hSqlTransHdl )
										Call SqlFetchNext( hSqlTransHdl, nIndTrans )
									If nIndTrans = FETCH_Ok
										!
										Set dfRepDebtorsTotal = dfRepDebtorsTotal + tblCashApp.colAppAmount
										!
										If GetDepositUsed( tblCashApp.colTransUser, tblCashApp.colTransDate, 
												dfRecUser, dfRecDate, 'TRANSACTION', dfRepDepositUsed, nExecute )
											Set nTotalDepositsUsed = nTotalDepositsUsed + dfRepDepositUsed
											Set dfRepDepositTotal = dfRepDepositTotal + dfRepDepositUsed
										!
										Call SalSendMsgToChildren( hWndForm, PAM_RESETHIST, 0, 0 )
								Else If NOT SalIsNull( tblCashApp.colTransHistDate )
									If SqlExecute( hSqlTransHistHdl )
										Call SqlFetchNext( hSqlTransHistHdl, nIndHist )
										If nIndHist = FETCH_Ok
											!
											Set dfRepDebtorsTotal = dfRepDebtorsTotal + tblCashApp.colAppAmount
											!
											If GetDepositUsed( tblCashApp.colTransHistUser, tblCashApp.colTransHistDate, 
													dfRecUser, dfRecDate, 'TRANS_HIST', dfRepDepositUsed, nExecute )
												Set nTotalDepositsUsed = nTotalDepositsUsed + dfRepDepositUsed
												Set dfRepDepositTotal = dfRepDepositTotal + dfRepDepositUsed
											!
											Call SalSendMsgToChildren( hWndForm, PAM_RESETTRANS, 0, 0 )
								Else If NOT SalIsNull( tblCashApp.colTransDateCred )
									! Check for CR Invoices
									If GetCRInvoiceTransCred( tblCashApp.colTransUserCred, tblCashApp.colTransDateCred, frmReceipt.dfRefId, frmReceipt.dfTrType, frmReceipt.dfTrAmt, frmReceipt.dfTrAmtOuts, nExecute )
										!
										Set dfRepDebtorsTotal = dfRepDebtorsTotal + tblCashApp.colAppAmount
										!
										If GetDepositUsed( tblCashApp.colTransUserCred, tblCashApp.colTransDateCred, 
												dfRecUser, dfRecDate, 'TRANSACTION', dfRepDepositUsed, nExecute )
											Set nTotalDepositsUsed = nTotalDepositsUsed + dfRepDepositUsed
											Set dfRepDepositTotal = dfRepDepositTotal + dfRepDepositUsed
										!
										Call SalSendMsgToChildren( hWndForm, PAM_RESETHIST, 0, 0 )
								Else If NOT SalIsNull( tblCashApp.colTransHistDateCred )
									! Check for CR Invoices
									If GetCRInvoiceTransCredHist( tblCashApp.colTransHistUserCred, tblCashApp.colTransHistDateCred, frmReceipt.dfHistRefId, frmReceipt.dfHistTransType, frmReceipt.dfHistTransAmt, frmReceipt.dfHistTransAmtOuts, 
											nExecute )
										!
										Set dfRepDebtorsTotal = dfRepDebtorsTotal + tblCashApp.colAppAmount
										!
										If GetDepositUsed( tblCashApp.colTransHistUserCred, tblCashApp.colTransHistDateCred, 
												dfRecUser, dfRecDate, 'TRANS_HIST', dfRepDepositUsed, nExecute )
											Set nTotalDepositsUsed = nTotalDepositsUsed + dfRepDepositUsed
											Set dfRepDepositTotal = dfRepDepositTotal + dfRepDepositUsed
										!
										Call SalSendMsgToChildren( hWndForm, PAM_RESETTRANS, 0, 0 )
								Return TRUE
							! Need to check if there is no cash application records then still want to return TRUE before falling
									thru so that we pick up any sundry receipts
							If NOT bAnyCashApp
								Set bAnyCashApp = TRUE
								! Now that the report is having to total via the unapplied, sundry and applied amounts - the deposits
										are slipping through because they dont fall into any of the categories - so will use the sundry category
										to store values for deposits in
								If dfRepSundryAmount = 0 
									Set dfRepDeposit = dfRepAmount - dfRepUnappliedAmt
								Set bProcRcpt = TRUE
								Set bProcCshApp = FALSE
								! Else
									                           Set dfRepDeposit = 0
								! Set frmReceipt.tblCashApp.colAppAmount = frmReceipt.dfRepAmount
								Return TRUE
							Call SalSendMsgToChildren( frmReceipt, PAM_RESETTRANS, 0, 0 )
							Call SalSendMsgToChildren( frmReceipt, PAM_RESETHIST, 0, 0 )
							Set bProcRcpt = TRUE
							Set bProcCshApp = FALSE
			On SAM_ReportFinish
				If bPrintDepListing
					Set bCashRcptsHdlConnected = FALSE
					Set bCashRcptsHdlPrepared = FALSE
					Return TRUE
				If bPrintReconListing
					Set bCashRcptsHdlConnected = FALSE
					Set bCashRcptsHdlPrepared = FALSE
					Set bTransHdlConnected = FALSE
					Set bTransHdlPrepared = FALSE
					Set bTransHistHdlConnected = FALSE
					Set bTransHistHdlPrepared = FALSE
					Call GetDepositUsed( '', DATETIME_Null, '', DATETIME_Null, '', dfRepDepositUsed, nDisconnect )
					Call GetCRInvoiceTransCred( '', DATETIME_Null, frmReceipt.dfRefId, frmReceipt.dfTrType, frmReceipt.dfTrAmt, frmReceipt.dfTrAmtOuts, nDisconnect )
					Call GetCRInvoiceTransCredHist( '', DATETIME_Null, frmReceipt.dfHistRefId, frmReceipt.dfHistTransType, frmReceipt.dfHistTransAmt, frmReceipt.dfHistTransAmtOuts, nDisconnect )
					Return TRUE

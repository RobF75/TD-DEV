					Font Enhancement: Default
					Text Color: Default
					Background Color: Default
					Input Mask: Unformatted
				Message Actions
					On PAM_SQL
						Call BuildSQL( wParam, hWndItem, 'CASH_RECEIPT.RECEIPT_AMOUNT' )
					On PAM_INSERTCASHRCPT
						Call SalSetFieldEdit( hWndItem, TRUE )
						Call BuildSQL( wParam, hWndItem, 'RECEIPT_AMOUNT' )
					! On SAM_SetFocus
						                           Set nFocusIn = nFocusRecptAmt
					On SAM_Validate
						Set dfStillToApply = dfRecptAmt
						Return VALIDATE_OkClearFlag
					On PAM_FIELDPROTECT
						If wParam
							Call SalDisableWindow( hWndItem )
							Call SalColorSet( hWndItem, COLOR_IndexWindow, COLOR_LightGray )
						Else
							Call SalEnableWindow( hWndItem )
							Call SalColorSet( hWndItem, COLOR_IndexWindow, COLOR_Default )
					On PAM_RESET
						Call SalClearField( hWndItem )
						Call SalSetFocus( dfRecptAmt )
					On PAM_DATAVAL
						If NOT bDataValError
							If NOT dfRecptAmt > 0
								Set bDataValError = TRUE
								Call SalWaitCursor( FALSE )
								Call SalMessageBox( 'A receipt amount must be entered first! 
										Please rectify! ', 'Error', MB_Ok )
								Call SalWaitCursor( TRUE )
								Call SalSetFocus( hWndItem )
			Group Box: Customer
				Resource Id: 12599

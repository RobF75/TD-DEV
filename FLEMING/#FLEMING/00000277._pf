				Vertical Scroll? Yes
				Font Name: Default
				Font Size: Default
				Font Enhancement: Default
				Text Color: Default
				Background Color: Default
				Input Mask: Unformatted
				List Initialization
					Text: CHEQUE
					Text: CASH
					Text: MONEYORD
				Message Actions
					On SAM_Create
						Set cmbRcptType = 'CHEQUE'
					! On SAM_SetFocus
						                           Set nFocusIn = nFocusRcptType
					On SAM_Validate
						Call SalStrUpper( cmbRcptType, cmbRcptType )
						If cmbRcptType = 'CHEQUE'
							Call PopulateCmbBank( hSqlCmbBankHdl, bCmbBankHdlConnected, bCmbBankPopulated, cmbBank )
							Return VALIDATE_OkClearFlag
						Else If cmbRcptType = 'CASH'
							Return VALIDATE_OkClearFlag
						Else If cmbRcptType = 'MONEYORD'
							Return VALIDATE_OkClearFlag
						Else
							Call SalMessageBox( 'Invalid Receipt Type! Please use the drop down button!', 'Error', MB_Ok )
							Return VALIDATE_Cancel
					On PAM_FIELDPROTECT
						If wParam
							Call SalDisableWindow( hWndItem )
							Call SalColorSet( hWndItem, COLOR_IndexWindow, COLOR_LightGray )
						Else
							Call SalEnableWindow( hWndItem )
							Call SalColorSet( hWndItem, COLOR_IndexWindow, COLOR_Default )
					On PAM_INSERTCASHRCPT
						Call SalSetFieldEdit( hWndItem, TRUE )
						Call BuildSQL( wParam, hWndItem, 'RECEIPT_TYPE' )
					On PAM_RESET
						Call SalClearField( hWndItem )
						Set cmbRcptType = 'CHEQUE'
			Data Field: dfRecptAmt
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Data
					Maximum Data Length: Default
					Data Type: Number
					Editable? Yes

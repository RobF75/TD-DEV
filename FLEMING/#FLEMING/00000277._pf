		Application Actions
			On SAM_AppStartup
				! 15/2/95 Cash Application records written for write offs not having some details set fixed
				! 15/2/95 Amt outstanding of transaction when written off not being set to 0 fixed
				! 15/2/95 Reconciliation development code commented so that compile can occur
				! 20/2/95 bUG IN WRITING off and not setting some fields in the cash application record
						fixed
				! 8/5/95 changed orderby of company bank listing
				! Not showing the unapplied message if sundry is > spaces
				! treating a receipt of money order like a cheque instead of like cash
				! bug where able to apply money to an already paid deposit was fixed 5/9/96 dmf
				!
				If strArgArray[0] = ''
					Set SqlDatabase = 'STOCKDEV'
					Set SqlUser = 'GRAHAM'
					Set SqlPassword = 'GRAHAM'
				Else
					Set SqlDatabase = strArgArray[1]
					Set SqlUser = strArgArray[2]
					Set SqlPassword = strArgArray[3]
				!
				Set bShowSql = FALSE
				Set bghSqlDetail = SqlConnect( hSqlDetail )
				If bghSqlDetail
					Call SqlSetIsolationLevel( hSqlDetail, 'RL')
					Call SqlSetLockTimeout( hSqlDetail, SQLTIMEOUT )
			On SAM_SqlError
				Call SqlExtractArgs( wParam, lParam, hSqlError, nSqlError, nErrorPos )
				! Going to comments the return false line and put in others to do error processing
				! Return FALSE
				Call SqlGetErrorText( nSqlError, sErrmsg )
				Call SalNumberToStr( nSqlError, 0, sNum )
				Call SalMessageBox( sNum || '-' || sErrmsg || '.
						Choose OK to quit.', 'Cash Receipt', MB_Ok | MB_IconStop )
				! Call SalQuit(  )
				Return FALSE
			On SAM_AppExit
				If bghSqlDetail
					Call SqlDisconnect( hSqlDetail )

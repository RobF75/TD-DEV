						! On PAM_PBFOCUSPLACED
							                           Call MySetFocus( nFocusIn )
				Pushbutton: pbApply
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Apply
					Window Location and Size
						Left:   6.088"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Loading.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							! If SalIsNull( dfRecptAmt )
								                           Call SalMessageBox( 'A receipt amount is needed before applying!  Please rectify!', 'Warning', MB_Ok )
								                           Call SalSetFocus( dfRecptAmt )
								                           Return FALSE
							If SalIsNull( dfStillToApply )
								Set dfStillToApply = dfRecptAmt
							Set bCompanyMatch = TRUE
							Set nCompCount = 0
							Set sTransCompany[nCompCount + 1] = STRING_Null
							While SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblTransaction, nRow )
								Set sTransCompany[nCompCount] = frmReceipt.tblTransaction.colCompany
								Set nCompCount = nCompCount +1
								Set sTransCompany[nCompCount + 1] = STRING_Null
							Set nCompCount = 0
							While sTransCompany[nCompCount] != STRING_Null
								If frmReceipt.tblTransaction.colCompany != frmReceipt.dfRecpCompany
									Call SalMessageBox('Paid to Company does not match Transaction Company! Please rectify.','Error', MB_Ok)
									Set bCompanyMatch = FALSE
									Set nCompCount = nCompCount +1
									! Return FALSE
								Else
									Set nCompCount = nCompCount + 1
							If NOT bCompanyMatch
								Return FALSE
							Call SalWaitCursor( TRUE )
							Call SalDisableWindow( hWndItem )
							If rbViewTrans
								Set bHaveAppliedRow = FALSE
								Set nOrgRow = SalTblQueryContext( tblTransaction )
								!
								! Make sure that the total amount of Credit trans selected is less than the
								! total amount of Debit trans (we cant have Credits being allocated into Unapplied cash)
								!
								Set nTotalDebits = 0
								Set nTotalCredits = 0
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( tblTransaction, nRow )
									If frmReceipt.tblTransaction.colTransCode = 'CR'
										Set nTotalCredits = nTotalCredits + frmReceipt.tblTransaction.colAmtOuts
									Else
										Set nTotalDebits = nTotalDebits + frmReceipt.tblTransaction.colAmtOuts
								If nTotalCredits > nTotalDebits
									Call SalMessageBox('Error - You must have enough debit records selected
											to total at least the amount of credits selected','Message',MB_Ok) 
									Call SalEnableWindow( hWndItem )
									Call SalWaitCursor( FALSE )
									Return FALSE
								!
								! Check if there are any CREDITs to take care of
								! All the CREDITs must be done before doing any of the DEBITs
								!
								Set nRow = TBL_MinRow
								! Problem here with this variable that if applied everthing and then clicked writeoff on one of 
										  those rows this variable gets reset to zero and no application record gets written for the 
										  credit note used againsts a invoice.  Jan moved this statement under the pbClear click so
										  that it gets initialized once for each customer. and under the PAM_CREATECOMPLETE to 
										  initialize it in the beginning.
								! Set nCreditDebitMatchingTrans = 0
								!
								Loop Outer
									If NOT SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
										Break Outer
									Call SalTblFetchRow( tblTransaction, nRow )
									Call SalTblSetFocusRow( tblTransaction, nRow)
									!
									! Loop thru the selected rows and try to match the credit (if any) with a debit trans
									!
									If frmReceipt.tblTransaction.colTransCode = 'CR' AND 
											frmReceipt.tblTransaction.colAmtOuts > 0
										!
										! Found a CREDIT trans - save information
										!
										Set nSaveCurrentRow = nRow
										Set nSaveCustNo = frmReceipt.tblTransaction.colCustNo
										Set sSaveRefId =  frmReceipt.tblTransaction.colRefId
										Set nSaveAmtOuts = frmReceipt.tblTransaction.colAmtOuts
										Set sSaveUserId = frmReceipt.tblTransaction.colTransUserId
										Set dtSaveSysDT = frmReceipt.tblTransaction.colTransSysDT
										!
										! Now startat the top and try to find matching DEBIT trans
										!
										Set bFoundCreditDebitMatch = FALSE
										Set bHaveCheckedForAny = FALSE
										Set nRow = TBL_MinRow
										Loop Inner
											If NOT SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
												If bHaveCheckedForAny = TRUE
													Set bHaveCheckedForAny = FALSE
													!
													!
													! Update the still to apply with the remainder of the Credit trans
													! that could not be applied to the Debit trans
													Set dfStillToApply = dfStillToApply + nTempStillToApply
													! Need to now go back to where the credit was and check for any others
													Break Inner
												Else
													Set bHaveCheckedForAny = TRUE
													Set nRow = TBL_MinRow
											Else
												Call SalTblFetchRow( tblTransaction, nRow )
												Call SalTblSetFocusRow( tblTransaction, nRow)
												If frmReceipt.tblTransaction.colTransCode = 'DR'
													!
													! See if we can find a matching selected Debit Record for this Credit
													!
													If ((sSaveRefId =  frmReceipt.tblTransaction.colRefId) OR bHaveCheckedForAny) AND
															frmReceipt.tblTransaction.colAmtOuts > 0 AND 
															frmReceipt.tblTransaction.colCustNo = nSaveCustNo
														Set bFoundCreditDebitMatch = TRUE
														Set nTempAmtApplied = frmReceipt.tblTransaction.colAmtApply
														!
														! Determine how much of the Credit to apply to this Debit trans
														!
														If nSaveAmtOuts >  frmReceipt.tblTransaction.colAmtOuts
															Set frmReceipt.tblTransaction.colAmtApply =  
																	frmReceipt.tblTransaction.colAmtOuts
														Else
															Set frmReceipt.tblTransaction.colAmtApply =  nSaveAmtOuts
														Set nTempStillToApply = nSaveAmtOuts
														!
														! Apply the credit to the found debit
														!
														If ApplyTransRow( frmReceipt.tblTransaction.colTransAmount, 
																  frmReceipt.tblTransaction.colAmtOuts, frmReceipt.tblTransaction.colAmtApply, 
																  nTempStillToApply, frmReceipt.tblTransaction.colAppDate, dtApplyDate )
															Set nTransRowsApplied = nTransRowsApplied + 1
															Set bHaveAppliedRow = TRUE
															!
															! Mark the row as edited but still selected for other processing
															!
															Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
															Call SalTblSetRowFlags( tblTransaction, nRow, ROW_Selected, TRUE )
															Call SalTblSetRowFlags( tblTransaction, nRow, ROW_UserFlag1, TRUE )
															!
															! Readjust the amount applied in case there were previously applied credits
															!
															Set frmReceipt.tblTransaction.colAmtApply =
																	 frmReceipt.tblTransaction.colAmtApply + nTempAmtApplied
															!
															Set nCreditDebitMatchingTrans = nCreditDebitMatchingTrans + 1
															Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].sRefID =
																	frmReceipt.tblTransaction.colRefId
															Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].nAmountApplied =
																	nSaveAmtOuts - nTempStillToApply
															! The following fields are used in the WriteCashAppRecordForCreditDebit routine
																	which is called for DR entries when being done in the save functions - it then must
																	have the credit keys of the transaction stored - and as well the DR row number to be able to
																	match the records with each other
															Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].sTransUserID = sSaveUserId
															Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].dtTransSysDT= dtSaveSysDT
															Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].nDRRowNo = nRow
															! Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].sTransUserID =
																	frmReceipt.tblTransaction.colTransUserId
															! Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].dtTransSysDT=
																	frmReceipt.tblTransaction.colTransSysDT
															Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].nCustNo =
																	frmReceipt.tblTransaction.colCustNo
														!
														!
														! Break Inner
														Set nSaveAmtOuts = nTempStillToApply
														If nSaveAmtOuts = 0
															Break Inner
											!
										Set nRow = nSaveCurrentRow
										Call SalTblFetchRow( tblTransaction, nRow )
										Call SalTblSetFocusRow( tblTransaction, nRow)
										!
										Set frmReceipt.tblTransaction.colAmtApply = frmReceipt.tblTransaction.colAmtOuts - nSaveAmtOuts
										Set frmReceipt.tblTransaction.colAmtOuts = nSaveAmtOuts
										Set frmReceipt.tblTransaction.colAppDate = dtApplyDate
										Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
										!
								!
								! Finished trying to find a partner DEBIT trans (same RefId) so back
								! to where we were in the table before we found this CREDIT
								!
								! Set nRow = nSaveCurrentRow
								! Call SalTblFetchRow( tblTransaction, nRow )
								! Call SalTblSetFocusRow( tblTransaction, nRow)
								!
								! Check to see if a Credit - Debit match was not found so that the amount
								! can be added to the dfStillToApply
								!
								! This is being done when we break out of the loop to apply the credit now
								! Set dfStillToApply = dfStillToApply + nSaveAmtOuts
								! If NOT bFoundCreditDebitMatch
									                           Set dfStillToApply = dfStillToApply + nSaveAmtOuts
								! Else
									!
									! Match found so add Credit record information for this Debit record to the 
									! CreditDebitMatchRecord array for later use by the Save code to 
									! update/create the appropiate Cash App records
									!
									                           Set nCreditDebitMatchingTrans = nCreditDebitMatchingTrans + 1
									                           Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].sRefID =
											frmReceipt.tblTransaction.colRefId
									                           Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].nAmountApplied =
											nSaveAmtOuts - nTempStillToApply
									                           Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].sTransUserID =
											frmReceipt.tblTransaction.colTransUserId
									                           Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].dtTransSysDT=
											frmReceipt.tblTransaction.colTransSysDT
									                           Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].nCustNo =
											frmReceipt.tblTransaction.colCustNo
								! Now process the transactions as normal (ie all DEBIT)
								!
								Set nRow = TBL_MinRow
								Loop
									If NOT SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
										Break
									Call SalTblFetchRow( tblTransaction, nRow )
									Call SalTblSetFocusRow( tblTransaction, nRow )
									! If frmReceipt.tblTransaction.colApplied = 'N'
									! If its being written off we dont need to do any calc checking as we are
											writing it off, we just want it recorded as applied so that we can process
											it in save changes
									If frmReceipt.tblTransaction.colTransCode = 'DR'
										If dfStillToApply > 0
											If frmReceipt.tblTransaction.colAmtOuts = 0
												If NOT SalTblQueryRowFlags( tblTransaction, nRow, ROW_UserFlag1 )
													Call SalMessageBox( 'Cannot apply a line which has no amount outstanding', 'Transactions', MB_Ok )
											Else
												If frmReceipt.tblTransaction.colWriteOff = 'N'
													Set nTempAmtApplied =0
													!
													! If this row has already been modified by a credit save the amount and reset
													! the Amout Apply to NULL 
													!
													If SalTblQueryRowFlags( tblTransaction, nRow, ROW_UserFlag1 )
														Set nTempAmtApplied = frmReceipt.tblTransaction.colAmtApply
														Set frmReceipt.tblTransaction.colAmtApply = NUMBER_Null
													If ApplyTransRow( frmReceipt.tblTransaction.colTransAmount, frmReceipt.tblTransaction.colAmtOuts, 
															  frmReceipt.tblTransaction.colAmtApply, dfStillToApply, frmReceipt.tblTransaction.colAppDate, 
															  dtApplyDate )
														Set nTransRowsApplied = nTransRowsApplied + 1
														! If NOT SalTblQueryRowFlags( tblTransaction, nRow, ROW_UserFlag1 )
															                           Set nTransRowsApplied = nTransRowsApplied + 1
														Set bHaveAppliedRow = TRUE
														Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
													Set frmReceipt.tblTransaction.colAmtApply =
															 frmReceipt.tblTransaction.colAmtApply + nTempAmtApplied
												Else
													Set nTransRowsApplied = nTransRowsApplied + 1
													Set bHaveAppliedRow = TRUE
													Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
									! If frmReceipt.tblTransaction.colTransCode = 'CR'
										                           If frmReceipt.tblTransaction.colAmtOuts > 0
											                           Set frmReceipt.tblTransaction.colAmtApply = frmReceipt.tblTransaction.colAmtOuts
											                           Set frmReceipt.tblTransaction.colAmtOuts = 0
											                           Set frmReceipt.tblTransaction.colAppDate = dtApplyDate
											                           Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
									! Else
										                           If dfStillToApply > 0
											                           If frmReceipt.tblTransaction.colAmtOuts = 0
												                           If NOT SalTblQueryRowFlags( tblTransaction, nRow, ROW_UserFlag1 )
													                           Call SalMessageBox( 'Cannot apply a line which has no amount outstanding', 'Transactions', MB_Ok )
											                           Else 
												                           If frmReceipt.tblTransaction.colWriteOff = 'N'
													                           Set nTempAmtApplied =0
													!
													! If this row has already been modified by a credit save the amount and reset
													! the Amout Apply to NULL 
													!
													                           If SalTblQueryRowFlags( tblTransaction, nRow, ROW_UserFlag1 )
														                           Set nTempAmtApplied = frmReceipt.tblTransaction.colAmtApply
														                           Set frmReceipt.tblTransaction.colAmtApply = NUMBER_Null
													                           If ApplyTransRow( frmReceipt.tblTransaction.colTransAmount, frmReceipt.tblTransaction.colAmtOuts, 
															  frmReceipt.tblTransaction.colAmtApply, dfStillToApply, frmReceipt.tblTransaction.colAppDate, 
															  dtApplyDate )
														                           Set nTransRowsApplied = nTransRowsApplied + 1
														! If NOT SalTblQueryRowFlags( tblTransaction, nRow, ROW_UserFlag1 )
															                           Set nTransRowsApplied = nTransRowsApplied + 1
														                           Set bHaveAppliedRow = TRUE
														                           Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
													                           Set frmReceipt.tblTransaction.colAmtApply =
															 frmReceipt.tblTransaction.colAmtApply + nTempAmtApplied
												                           Else 
													                           Set nTransRowsApplied = nTransRowsApplied + 1
													                           Set bHaveAppliedRow = TRUE
													                           Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
									Call SalTblSetRowFlags( tblTransaction, nRow, ROW_Selected, FALSE )
								If nTransRowsApplied > 0
									Set bEdit = TRUE
									Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, TRUE, 0 )
							Else If rbViewDeposits
								Set bHaveAppliedRow = FALSE
								Set nOrgRow = SalTblQueryContext( tblOutstandDeposit )
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblOutstandDeposit, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( tblOutstandDeposit, nRow )
									Call SalTblSetFocusRow( tblOutstandDeposit, nRow )
									If frmReceipt.tblOutstandDeposit.colOrgAmountPaid = NUMBER_Null
										If frmReceipt.tblOutstandDeposit.colApplied = 'N'
											!
											If ApplyDepositRow( frmReceipt.tblOutstandDeposit.colDepAmountReqd, frmReceipt.tblOutstandDeposit.colDepAmountPaid, 
													  dfStillToApply, frmReceipt.tblOutstandDeposit.colDepPaidDate, dtApplyDate )
												Set nDepositRowsApplied = nDepositRowsApplied + 1
												Set bHaveAppliedRow = TRUE
												Call SalSendMsg( tblOutstandDeposit, PAM_SETROWEDITFLAG, TRUE, nRow )
								! If bHaveAppliedRow
									                           If SalTblFindNextRow( tblOutstandDeposit, nRow, 0, 0 )
										                           Call SalTblFetchRow( tblOutstandDeposit, nRow )
										                           Call SalTblSetRowFlags( tblOutstandDeposit, nRow, ROW_Selected, TRUE )
										                           Call SalTblSetFocusRow( tblOutstandDeposit, nRow )
								! Else 
									                           Call SalTblFetchRow( tblOutstandDeposit, nOrgRow )
									                           Call SalTblSetFocusRow( tblOutstandDeposit, nOrgRow )
								If nDepositRowsApplied > 0
									Set bEdit = TRUE
									Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, TRUE, 0 )
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )
						! On SAM_Click
							! If SalIsNull( dfRecptAmt )
								                           Call SalMessageBox( 'A receipt amount is needed before applying!  Please rectify!', 'Warning', MB_Ok )
								                           Call SalSetFocus( dfRecptAmt )
								                           Return FALSE
							                           If SalIsNull( dfStillToApply )
								                           Set dfStillToApply = dfRecptAmt
							                           Call SalWaitCursor( TRUE )
							                           Call SalDisableWindow( hWndItem )
							                           If rbViewTrans
								                           Set bHaveAppliedRow = FALSE
								                           Set nOrgRow = SalTblQueryContext( tblTransaction )
								!
								! Make sure that the total amount of Credit trans selected is less than the
								! total amount of Debit trans (we cant have Credits being allocated into Unapplied cash)
								!
								                           Set nTotalDebits = 0
								                           Set nTotalCredits = 0
								                           Set nRow = TBL_MinRow
								                           While SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
									                           Call SalTblFetchRow( tblTransaction, nRow )
									                           If frmReceipt.tblTransaction.colTransCode = 'CR'
										                           Set nTotalCredits = nTotalCredits + frmReceipt.tblTransaction.colAmtOuts
									                           Else 
										                           Set nTotalDebits = nTotalDebits + frmReceipt.tblTransaction.colAmtOuts
								                           If nTotalCredits > nTotalDebits
									                           Call SalMessageBox('Error - You must have enough debit records selected
											to total at least the amount of credits selected','Message',MB_Ok) 
									                           Call SalEnableWindow( hWndItem )
									                           Call SalWaitCursor( FALSE )
									                           Return FALSE
								!
								! Check if there are any CREDITs to take care of
								! All the CREDITs must be done before doing any of the DEBITs
								!
								                           Set nRow = TBL_MinRow
								                           Set nCreditDebitMatchingTrans = 0
								!
								                           Loop Outer
									                           If NOT SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
										                           Break Outer
									                           Call SalTblFetchRow( tblTransaction, nRow )
									                           Call SalTblSetFocusRow( tblTransaction, nRow)
									!
									! Loop thru the selected rows and try to match the credit (if any) with a debit trans
									!
									                           If frmReceipt.tblTransaction.colTransCode = 'CR'
										!
										! Found a CREDIT trans - save information
										!
										                           Set nSaveCurrentRow = nRow
										                           Set sSaveRefId =  frmReceipt.tblTransaction.colRefId
										                           Set nSaveAmtOuts = frmReceipt.tblTransaction.colAmtOuts
										!
										! Now startat the top and try to find matching DEBIT trans
										!
										                           Set bFoundCreditDebitMatch = FALSE
										                           Set nRow = TBL_MinRow
										                           Loop Inner
											                           If NOT SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
												                           Break Inner
											                           Call SalTblFetchRow( tblTransaction, nRow )
											                           Call SalTblSetFocusRow( tblTransaction, nRow)
											                           If frmReceipt.tblTransaction.colTransCode = 'DR'
												!
												! See if we can find a matching selected Debit Record for this Credit
												!
												                           If sSaveRefId =  frmReceipt.tblTransaction.colRefId
													                           Set bFoundCreditDebitMatch = TRUE
													                           Set nTempAmtApplied = frmReceipt.tblTransaction.colAmtApply
													!
													! Determine how much of the Credit to apply to this Debit trans
													!
													                           If nSaveAmtOuts >  frmReceipt.tblTransaction.colAmtOuts
														                           Set frmReceipt.tblTransaction.colAmtApply =  
																frmReceipt.tblTransaction.colAmtOuts
													                           Else 
														                           Set frmReceipt.tblTransaction.colAmtApply =  nSaveAmtOuts
													                           Set nTempStillToApply = nSaveAmtOuts
													!
													! Apply the credit to the found debit
													!
													                           If ApplyTransRow( frmReceipt.tblTransaction.colTransAmount, 
															  frmReceipt.tblTransaction.colAmtOuts, frmReceipt.tblTransaction.colAmtApply, 
															  nTempStillToApply, frmReceipt.tblTransaction.colAppDate, dtApplyDate )
														                           Set nTransRowsApplied = nTransRowsApplied + 1
														                           Set bHaveAppliedRow = TRUE
														!
														! Mark the row as edited but still selected for other processing
														!
														                           Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
														                           Call SalTblSetRowFlags( tblTransaction, nRow, ROW_Selected, TRUE )
														                           Call SalTblSetRowFlags( tblTransaction, nRow, ROW_UserFlag1, TRUE )
													!
													! Update the still to apply with the remainder of the Credit trans
													! that could not be applied to the Debit trans
													!
													                           Set dfStillToApply = dfStillToApply + nTempStillToApply
													!
													! Readjust the amount applied in case there were previously applied credits
													!
													                           Set frmReceipt.tblTransaction.colAmtApply =
															 frmReceipt.tblTransaction.colAmtApply + nTempAmtApplied
													                           Break Inner
										!
										! Finished trying to find a partner DEBIT trans (same RefId) so back
										! to where we were in the table before we found this CREDIT
										!
										                           Set nRow = nSaveCurrentRow
										                           Call SalTblFetchRow( tblTransaction, nRow )
										                           Call SalTblSetFocusRow( tblTransaction, nRow)
										!
										! Check to see if a Credit - Debit match was not found so that the amount
										! can be added to the dfStillToApply
										!
										                           If NOT bFoundCreditDebitMatch
											                           Set dfStillToApply = dfStillToApply + nSaveAmtOuts
										                           Else 
											!
											! Match found so add Credit record information for this Debit record to the 
											! CreditDebitMatchRecord array for later use by the Save code to 
											! update/create the appropiate Cash App records
											!
											                           Set nCreditDebitMatchingTrans = nCreditDebitMatchingTrans + 1
											                           Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].sRefID =
													frmReceipt.tblTransaction.colRefId
											                           Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].nAmountApplied =
													nSaveAmtOuts - nTempStillToApply
											                           Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].sTransUserID =
													frmReceipt.tblTransaction.colTransUserId
											                           Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].dtTransSysDT=
													frmReceipt.tblTransaction.colTransSysDT
											                           Set CreditDebitMatchRecord[nCreditDebitMatchingTrans].nCustNo =
													frmReceipt.tblTransaction.colCustNo
								!
								! Now process the transactions as normal (ie all DEBIT)
								!
								                           Set nRow = TBL_MinRow
								                           Loop 
									                           If NOT SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
										                           Break 
									                           Call SalTblFetchRow( tblTransaction, nRow )
									                           Call SalTblSetFocusRow( tblTransaction, nRow )
									! If frmReceipt.tblTransaction.colApplied = 'N'
									! If its being written off we dont need to do any calc checking as we are
											writing it off, we just want it recorded as applied so that we can process
											it in save changes
									                           If frmReceipt.tblTransaction.colTransCode = 'CR'
										                           If frmReceipt.tblTransaction.colAmtOuts > 0
											                           Set frmReceipt.tblTransaction.colAmtApply = frmReceipt.tblTransaction.colAmtOuts
											                           Set frmReceipt.tblTransaction.colAmtOuts = 0
											                           Set frmReceipt.tblTransaction.colAppDate = dtApplyDate
											                           Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
									                           Else 
										                           If dfStillToApply > 0
											                           If frmReceipt.tblTransaction.colAmtOuts = 0
												                           If NOT SalTblQueryRowFlags( tblTransaction, nRow, ROW_UserFlag1 )
													                           Call SalMessageBox( 'Cannot apply a line which has no amount outstanding', 'Transactions', MB_Ok )
											                           Else 
												                           If frmReceipt.tblTransaction.colWriteOff = 'N'
													                           Set nTempAmtApplied =0
													!
													! If this row has already been modified by a credit save the amount and reset
													! the Amout Apply to NULL 
													!
													                           If SalTblQueryRowFlags( tblTransaction, nRow, ROW_UserFlag1 )
														                           Set nTempAmtApplied = frmReceipt.tblTransaction.colAmtApply
														                           Set frmReceipt.tblTransaction.colAmtApply = NUMBER_Null
													                           If ApplyTransRow( frmReceipt.tblTransaction.colTransAmount, frmReceipt.tblTransaction.colAmtOuts, 
															  frmReceipt.tblTransaction.colAmtApply, dfStillToApply, frmReceipt.tblTransaction.colAppDate, 
															  dtApplyDate )
														                           If NOT SalTblQueryRowFlags( tblTransaction, nRow, ROW_UserFlag1 )
															                           Set nTransRowsApplied = nTransRowsApplied + 1
														                           Set bHaveAppliedRow = TRUE
														                           Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
													                           Set frmReceipt.tblTransaction.colAmtApply =
															 frmReceipt.tblTransaction.colAmtApply + nTempAmtApplied
												                           Else 
													                           Set nTransRowsApplied = nTransRowsApplied + 1
													                           Set bHaveAppliedRow = TRUE
													                           Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
									                           Call SalTblSetRowFlags( tblTransaction, nRow, ROW_Selected, FALSE )
								                           If nTransRowsApplied > 0
									                           Set bEdit = TRUE
									                           Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, TRUE, 0 )
							                           Else If rbViewDeposits
								                           Set bHaveAppliedRow = FALSE
								                           Set nOrgRow = SalTblQueryContext( tblOutstandDeposit )
								                           Set nRow = TBL_MinRow
								                           While SalTblFindNextRow( tblOutstandDeposit, nRow, ROW_Selected, 0 )
									                           Call SalTblFetchRow( tblOutstandDeposit, nRow )
									                           Call SalTblSetFocusRow( tblOutstandDeposit, nRow )
									                           If frmReceipt.tblOutstandDeposit.colApplied = 'N'
										!
										                           If ApplyDepositRow( frmReceipt.tblOutstandDeposit.colDepAmountReqd, frmReceipt.tblOutstandDeposit.colDepAmountPaid, 
												  dfStillToApply, frmReceipt.tblOutstandDeposit.colDepPaidDate, dtApplyDate )
											                           Set nDepositRowsApplied = nDepositRowsApplied + 1
											                           Set bHaveAppliedRow = TRUE
											                           Call SalSendMsg( tblOutstandDeposit, PAM_SETROWEDITFLAG, TRUE, nRow )
								! If bHaveAppliedRow
									                           If SalTblFindNextRow( tblOutstandDeposit, nRow, 0, 0 )
										                           Call SalTblFetchRow( tblOutstandDeposit, nRow )
										                           Call SalTblSetRowFlags( tblOutstandDeposit, nRow, ROW_Selected, TRUE )
										                           Call SalTblSetFocusRow( tblOutstandDeposit, nRow )
								! Else 
									                           Call SalTblFetchRow( tblOutstandDeposit, nOrgRow )
									                           Call SalTblSetFocusRow( tblOutstandDeposit, nOrgRow )
								                           If nDepositRowsApplied > 0
									                           Set bEdit = TRUE
									                           Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, TRUE, 0 )
							                           Call SalEnableWindow( hWndItem )
							                           Call SalWaitCursor( FALSE )
				Pushbutton: pbSave
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Save
					Window Location and Size
						Left:   1.188"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Disk.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							! JAN REMOVED ON 15/11/94 BECAUSE MICHELLE NEEDED TO SAVE
									  A CASH RECEIPT WITHOUT APPLYING IT TO ANYTHING
							! If nTransRowsApplied = 0
								                           If nDepositRowsApplied = 0
									                           Call SalMessageBox( 'Nothing has been applied to save?', 'Cash Receipts', MB_Ok )
									                           Return FALSE
							Call SalSendValidateMsg(  )
							If frmReceipt.dfStillToApply > 0
								If cmbSundryCat = ''
									If IDNO = SalMessageBox( 'Do you really wish to save this receipt with unapplied cash?' , 'Cash Receipt', MB_YesNo )
										Return FALSE
							Call SalWaitCursor( TRUE )
							Call SalDisableWindow( hWndItem )
							!
							! NEXT CODE PERFORMS A DATAVAL OF FIELDS WITHOUT NEEDING
									  THE PAM_DATAVAL ON EACH CHILD OF THE WINDOW. WHEN ERROR
									  IS DETECTED JUST SET THE bDataValError variable to TRUE.
							Set bDataValError = FALSE
							Call SalSendMsgToChildren( hWndForm, PAM_DATAVAL, 0, 0 )
							If bDataValError
								Call SalEnableWindow( hWndItem )
								Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, FALSE, 0 )
								Call SalWaitCursor( FALSE )
								Return FALSE
							!
							Set nOrgTransRowsApplied = nTransRowsApplied
							Set nOrgDepositRowsApplied = nDepositRowsApplied
							!
							Set bSaveOk = TRUE
							! Now write out Cash Receipt record
							! Dont understand why tony moved the writing of the cash receipt record to after the transaction and
									deposits had been written as they were then being written without the appropriate cash receipt key
									as it didnt exist at the point of writing the related files 
							!
							Call structCashAppliedToCustomers.Setup( )
							!
							If WriteCashRcptRecord( hSqlWriteCshRcptHdl, bWriteCshRcptHdlConnected, 
									bWriteCshRcptHdlPrepared, ' CASH_RECEIPT ', hWndForm )
								! Might just have unapplied cash we wish to write for this customer - so we
										will need to adjust the ARBalance 
								Set nTransAmount = dfRecptAmt
								Set nTransCode = nCR
								! we dont want to update the ARBalance if we're paying a deposit - will need
										to check logic eg if we are paying a deposit and a transaction with the same
										receipt then the customers AR balance will be screwed up ???
								! If nDepositRowsApplied = 0
									! In case we are paying a sundry and there is no associated cust no
									                           If NOT SalIsNull( dfCustNo )
										                           If SalSendMsg( dfCustARBalance, PAM_ADJUSTARBALANCE, nTransCode, 0 )
											                           If NOT UpdateCustARBalRecord( ' CUSTOMER_MASTER ', 
													' WHERE Cust_No = :frmReceipt.dfCustNo ', hWndForm, PAM_UPDATECUST, 
													0, nExecute )
												                           Set bSaveOk = FALSE
								If nTransRowsApplied > 0
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblTransaction, nRow, 0, 0 )
										Call SalTblFetchRow( tblTransaction, nRow )
										If frmReceipt.tblTransaction.colApplied = 'Y' OR frmReceipt.tblTransaction.colWriteOff = 'Y'
											! At this point we dont want to do savetrans etc.  If we're just writing off
													- check the colAmtApply - if it is null then we are just writing off
											If NOT SalIsNull( frmReceipt.tblTransaction.colAmtApply )
												!
												! We need to first check if this Debit Trans has matching Credit transactions
												!
												If frmReceipt.tblTransaction.colTransCode = 'DR'
													Set bFoundCreditDebitMatch = FALSE
													If nCreditDebitMatchingTrans != 0
														Set nCounter = 0
														Loop
															If nCounter = nCreditDebitMatchingTrans
																Break
															Set nCounter = nCounter + 1
															! If the stored DR row no = a looped row no then the credit details associated with it
																	are to be written against this debit
															If CreditDebitMatchRecord[nCounter].nDRRowNo = nRow
																Set bFoundCreditDebitMatch = TRUE
																If WriteCashAppRecordForCreditDebit( hSqlWriteCashAppCRDRHdl, 
																		bWriteCashAppCRDRHdlConnected, bWriteCashAppCRDRHdlPrepared,
																		CreditDebitMatchRecord[nCounter]  )
																	Set frmReceipt.tblTransaction.colAmtApply = 
																			frmReceipt.tblTransaction.colAmtApply -
																			CreditDebitMatchRecord[nCounter].nAmountApplied
																Else
																	Set bSaveOk = FALSE
																	Call SalMessageBox( 'Error saving information. Contact
																			Programmers (Write CreditDebitCashAppRec)','Message',MB_Ok )
																	Return FALSE
															! If CreditDebitMatchRecord[nCounter].sRefID = frmReceipt.tblTransaction.colRefId
																                           Set bFoundCreditDebitMatch = TRUE
																                           If WriteCashAppRecordForCreditDebit( hSqlWriteCashAppCRDRHdl, 
																		bWriteCashAppCRDRHdlConnected, bWriteCashAppCRDRHdlPrepared,
																		CreditDebitMatchRecord[nCounter]  )
																	                           Set frmReceipt.tblTransaction.colAmtApply = 
																			frmReceipt.tblTransaction.colAmtApply -
																			CreditDebitMatchRecord[nCounter].nAmountApplied
																                           Else 
																	                           Set bSaveOk = FALSE
																	                           Call SalMessageBox( 'Error saving information. Contact
																			Programmers (Write CreditDebitCashAppRec)','Message',MB_Ok )
																	                           Return FALSE
												!
												! Now write out the Trans record (after the Amount applied has been adjusted
												! for any credits also allocated see above)
												!
												Call CheckForFinishedTrans( tblTransaction.colCustNo, 
														tblTransaction.colType, 
														tblTransaction.colTransCode, 
														tblTransaction.colAmtOuts, 
														tblTransaction.colOrgAmtOuts, 
														tblTransaction.colTransDate, 
														tblTransaction.colDaysToPay, nExecute )
												!
												!
												If SaveTransRecord( hSqlSaveTransHdl, bSaveTransHdlConnected, 
														bSaveTransHdlPrepared, ' TRANSACTION ', 
														sSqlWhereTransaction, tblTransaction )
													If UpdtCustDaysOfCredAvg( tblTransaction.colCustNo, nExecute )
														!
														! Write CashApp record which relates the transaction to the cash receipt 
														! if this Debit transaction still has some amount to apply
														!
														If frmReceipt.tblTransaction.colAmtApply > 0 AND
																frmReceipt.tblTransaction.colTransCode = 'DR'
															!
															Call structCashAppliedToCustomers.Insert( frmReceipt.tblTransaction.colCustNo, 
																	frmReceipt.tblTransaction.colAmtApply )
															!
															If WriteCashAppRecord( hSqlWriteCashAppHdl, 
																	bWriteCashAppHdlConnected, bWriteCashAppHdlPrepared,
																	 ' CASH_APPLICATION ' )
																Set nTransRowsApplied = nTransRowsApplied - 1
															Else
																Set bSaveOk = FALSE
													Else
														Set bSaveOk = FALSE
												Else
													Set bSaveOk = FALSE
											If frmReceipt.tblTransaction.colWriteOff = 'Y'
												! If SalSendMsg( dfCustARBalance, PAM_ADJUSTARBALANCEWROFF, nTransCode, 0 )
													                           If UpdateCustARBalRecord( ' CUSTOMER_MASTER ', 
															' WHERE Cust_No = :frmReceipt.dfCustNo ', hWndForm, 
															PAM_UPDATECUST, 0, nExecute )
														                           Call SalSendMsg( frmReceipt.tblTransaction.colAmtOuts, 
																PAM_SETWROFFAMTOUTS, 0, 0 )
														! Set the amt outstanding of the original debit trans = 0 
														                           If SaveTransRecord( hSqlSaveTransHdl, bSaveTransHdlConnected, 
																bSaveTransHdlPrepared, ' TRANSACTION ', sSqlWhereTransaction, tblTransaction )
															! Write the credit transaction
															                           If WriteOffTransRecord( hSqlWrOffTransHdl, bWrOffTransHdlConnected, 
																	bWrOffTransHdlPrepared, ' TRANSACTION ', tblTransaction )
																! Write a cash app record to relate the credit trans to the debit trans
																                           If NOT WriteCashAppTransTrans( hSqlCshAppWOffHdl, 
																		bCshAppWOffHdlConnected, bCshAppWOffHdlPrepared,
																		 ' CASH_APPLICATION ', tblTransaction )
																	                           Set bSaveOk = FALSE
															                           Else 
																                           Set bSaveOk = FALSE
														                           Else 
															                           Set bSaveOk = FALSE
													                           Else 
														                           Set bSaveOk = FALSE
												! Else
													                           Set bSaveOk = FALSE
												Call SalSendMsg( frmReceipt.tblTransaction.colAmtOuts, 
														PAM_SETWROFFAMTOUTS, 0, 0 )
												! Set the amt outstanding of the original debit trans = 0 
												!
												Call CheckForFinishedTrans( tblTransaction.colCustNo, 
														tblTransaction.colType, 
														tblTransaction.colTransCode, 
														tblTransaction.colAmtOuts, 
														tblTransaction.colOrgAmtOuts, 
														tblTransaction.colTransDate, 
														tblTransaction.colDaysToPay, nExecute )
												!
												If SaveTransRecord( hSqlSaveTransHdl, bSaveTransHdlConnected, 
														bSaveTransHdlPrepared, ' TRANSACTION ', sSqlWhereTransaction, tblTransaction )
													If UpdtCustDaysOfCredAvg( tblTransaction.colCustNo, nExecute )
														! Write the credit transaction
														If WriteOffTransRecord( hSqlWrOffTransHdl, bWrOffTransHdlConnected, 
																bWrOffTransHdlPrepared, ' TRANSACTION ', tblTransaction )
															!
															Call structCashAppliedToCustomers.Insert( frmReceipt.tblTransaction.colCustNo, 
																	frmReceipt.tblTransaction.colWrOffAmount )
															!
															! Write a cash app record to relate the credit trans to the debit trans
															If NOT WriteCashAppTransTrans( hSqlCshAppWOffHdl, 
																	bCshAppWOffHdlConnected, bCshAppWOffHdlPrepared,
																	 ' CASH_APPLICATION ', tblTransaction )
																Set bSaveOk = FALSE
														Else
															Set bSaveOk = FALSE
													Else
														Set bSaveOk = FALSE
												Else
													Set bSaveOk = FALSE
								If nDepositRowsApplied > 0
									If bWriteCshRcptHdlConnected
										Call SqlCommit( hSqlWriteCshRcptHdl )
									! Need the key of the cash receipt record for the insert of the deposits
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblOutstandDeposit, nRow, 0, 0 )
										Call SalTblFetchRow( tblOutstandDeposit, nRow )
										If frmReceipt.tblOutstandDeposit.colApplied = 'Y'
											If SalTblQueryRowFlags( tblOutstandDeposit, nRow, ROW_New )
												If InsertDeposit( hSqlInsDepHdl, bInsDepHdlConnected, bInsDepHdlPrepared, ' OUTSTAND_DEPOSIT ', tblOutstandDeposit )
													Set nDepositRowsApplied = nDepositRowsApplied - 1
												Else
													Set bSaveOk = FALSE
											Else
												If UpdateOutstandDeposit( hSqlSaveDepHdl, bSaveDepHdlConnected, bSaveDepHdlPrepared, ' OUTSTAND_DEPOSIT ', sSqlWhereDeposit, tblOutstandDeposit )
													If frmReceipt.tblOutstandDeposit.colDepAmountPaid < frmReceipt.tblOutstandDeposit.colDepAmountReqd
														If InsertNewOutstandDeposit( hSqlInsNewDepHdl, bInsNewDepHdlConnected, bInsNewDepHdlPrepared, ' OUTSTAND_DEPOSIT ', tblOutstandDeposit )
															Set nDepositRowsApplied = nDepositRowsApplied - 1
														Else
															Set bSaveOk = FALSE
													Else
														Set nDepositRowsApplied = nDepositRowsApplied - 1
												Else
													Set bSaveOk = FALSE
							Else
								Set bSaveOk = FALSE
							!
							!
							If bSaveOk
								Call structCashAppliedToCustomers.FetchNext( nFoundCustNo, nFoundAppliedAmt, 'RESET_TO_START' )
								While structCashAppliedToCustomers.FetchNext( nFoundCustNo, nFoundAppliedAmt, 'FETCH_NEXT' )
									Call NewAdjustCustARBalance( nFoundCustNo, nFoundAppliedAmt, nDecrement, nExecute )
								If dfStillToApply > 0
									Call NewAdjustCustARBalance( dfCustNo, dfStillToApply, nDecrement, nExecute )
								Call NewAdjustCustARBalance( 0, 0, nDecrement, nCommit )
								!
								!
								If bWriteCshRcptHdlConnected
									Call SqlCommit( hSqlWriteCshRcptHdl )
								If bWrOffTransHdlConnected
									Call SqlCommit( hSqlWrOffTransHdl )
								If bWriteHistHdlConnected
									Call SqlCommit( hSqlWriteHistHdl )
								If bWriteCashAppHdlConnected
									Call SqlCommit( hSqlWriteCashAppHdl )
								If bWriteCashAppCRDRHdlConnected
									Call SqlCommit( hSqlWriteCashAppCRDRHdl )
								If bSaveTransHdlConnected
									Call SqlCommit( hSqlSaveTransHdl )
								If bSaveDepHdlConnected
									Call SqlCommit( hSqlSaveDepHdl )
								If bInsNewDepHdlConnected
									Call SqlCommit( hSqlInsNewDepHdl )
								If bInsDepHdlConnected
									Call SqlCommit( hSqlInsDepHdl )
								If bCshAppWOffHdlConnected
									Call SqlCommit( hSqlCshAppWOffHdl )
								If nOrgTransRowsApplied > 0
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblTransaction, nRow, 0, 0 )
										Call SalTblFetchRow( tblTransaction, nRow )
										If frmReceipt.tblTransaction.colApplied = 'Y'
											Call SalSendMsg( tblTransaction, PAM_CLEARAPPLIEDROW, 0, nRow )
											Set nRow = nRow - 1
								If nOrgDepositRowsApplied > 0
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblOutstandDeposit, nRow, 0, 0 )
										Call SalTblFetchRow( tblOutstandDeposit, nRow )
										If frmReceipt.tblOutstandDeposit.colApplied = 'Y'
											Call SalSendMsg( tblOutstandDeposit, PAM_CLEARAPPLIEDROW, 0, nRow )
											Set nRow = nRow - 1
								Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nCommit )
								Call UpdtCustDaysOfCredAvg( 0, nCommit )
								Set bEdit = FALSE
								Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, FALSE, 0 )
								Call SalSendMsg( pbClear, SAM_Click, 0, 0 )
							Else
								If bWriteCshRcptHdlConnected
									Call SqlPrepareAndExecute( hSqlWriteCshRcptHdl, 'ROLLBACK' )
									Set bWriteCshRcptHdlPrepared = FALSE
								If bWrOffTransHdlConnected
									Call SqlPrepareAndExecute( hSqlWrOffTransHdl, 'ROLLBACK' )
									Set bWrOffTransHdlPrepared = FALSE
								If bWriteHistHdlConnected
									Call SqlPrepareAndExecute( hSqlWriteHistHdl, 'ROLLBACK' )
									Set bWriteHistHdlPrepared = FALSE
								If bWriteCashAppHdlConnected
									Call SqlPrepareAndExecute( hSqlWriteCashAppHdl, 'ROLLBACK' )
									Set bWriteCashAppHdlPrepared = FALSE
								If bWriteCashAppCRDRHdlConnected
									Call SqlPrepareAndExecute( hSqlWriteCashAppCRDRHdl, 'ROLLBACK' )
									Set bWriteCashAppHdlPrepared = FALSE
								If bSaveTransHdlConnected
									Call SqlPrepareAndExecute( hSqlSaveTransHdl, 'ROLLBACK' )
									Set bSaveTransHdlPrepared = FALSE
								If bSaveDepHdlConnected
									Call SqlPrepareAndExecute( hSqlSaveDepHdl, 'ROLLBACK' )
									Set bSaveDepHdlPrepared = FALSE
								If bInsNewDepHdlConnected
									Call SqlPrepareAndExecute( hSqlInsNewDepHdl, 'ROLLBACK' )
									Set bInsNewDepHdlPrepared = FALSE
								If bInsDepHdlConnected
									Call SqlPrepareAndExecute( hSqlInsDepHdl, 'ROLLBACK' )
									Set bInsDepHdlPrepared = FALSE
								If bCshAppWOffHdlConnected
									Call SqlPrepareAndExecute( hSqlCshAppWOffHdl, 'ROLLBACK' )
									Set bCshAppWOffHdlPrepared = FALSE
								Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nRollback )
								Call UpdtCustDaysOfCredAvg( 0, nRollback )
								Set nTransRowsApplied = nOrgTransRowsApplied
								Set nDepositRowsApplied = nOrgDepositRowsApplied
							!
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )
						! On SAM_Click
							! JAN REMOVED ON 15/11/94 BECAUSE MICHELLE NEEDED TO SAVE
									  A CASH RECEIPT WITHOUT APPLYING IT TO ANYTHING
							! If nTransRowsApplied = 0
								                           If nDepositRowsApplied = 0
									                           Call SalMessageBox( 'Nothing has been applied to save?', 'Cash Receipts', MB_Ok )
									                           Return FALSE
							                           Call SalSendValidateMsg(  )
							                           If frmReceipt.dfStillToApply > 0
								                           If cmbSundryCat = ''
									                           If IDNO = SalMessageBox( 'Do you really wish to save this receipt with unapplied cash?' , 'Cash Receipt', MB_YesNo )
										                           Return FALSE
							                           Call SalWaitCursor( TRUE )
							                           Call SalDisableWindow( hWndItem )
							!
							! NEXT CODE PERFORMS A DATAVAL OF FIELDS WITHOUT NEEDING
									  THE PAM_DATAVAL ON EACH CHILD OF THE WINDOW. WHEN ERROR
									  IS DETECTED JUST SET THE bDataValError variable to TRUE.
							                           Set bDataValError = FALSE
							                           Call SalSendMsgToChildren( hWndForm, PAM_DATAVAL, 0, 0 )
							                           If bDataValError
								                           Call SalEnableWindow( hWndItem )
								                           Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, FALSE, 0 )
								                           Call SalWaitCursor( FALSE )
								                           Return FALSE
							!
							                           Set nOrgTransRowsApplied = nTransRowsApplied
							                           Set nOrgDepositRowsApplied = nDepositRowsApplied
							!
							                           Set bSaveOk = TRUE
							! Might just have unapplied cash we wish to write for this customer - so we
									will need to adjust the ARBalance 
							                           Set nTransAmount = dfRecptAmt
							                           Set nTransCode = nCR
							! we dont want to update the ARBalance if we're paying a deposit - will need
									to check logic eg if we are paying a deposit and a transaction with the same
									receipt then the customers AR balance will be screwed up ???
							                           If nDepositRowsApplied = 0
								! In case we are paying a sundry and there is no associated cust no
								                           If NOT SalIsNull( dfCustNo )
									                           If SalSendMsg( dfCustARBalance, PAM_ADJUSTARBALANCE, nTransCode, 0 )
										                           If NOT UpdateCustARBalRecord( ' CUSTOMER_MASTER ', 
												' WHERE Cust_No = :frmReceipt.dfCustNo ', hWndForm, PAM_UPDATECUST, 
												0, nExecute )
											                           Set bSaveOk = FALSE
							                           If nTransRowsApplied > 0
								                           Set nRow = TBL_MinRow
								                           While SalTblFindNextRow( tblTransaction, nRow, 0, 0 )
									                           Call SalTblFetchRow( tblTransaction, nRow )
									                           If frmReceipt.tblTransaction.colApplied = 'Y'
										! At this point we dont want to do savetrans etc.  If we're just writing off
												- check the colAmtApply - if it is null then we are just writing off
										                           If NOT SalIsNull( frmReceipt.tblTransaction.colAmtApply )
											!
											! We need to first check if this Debit Trans has matching Credit transactions
											!
											                           If frmReceipt.tblTransaction.colTransCode = 'DR'
												                           Set bFoundCreditDebitMatch = FALSE
												                           If nCreditDebitMatchingTrans != 0
													                           Set nCounter = 0
													                           Loop 
														                           If nCounter = nCreditDebitMatchingTrans
															                           Break 
														                           Set nCounter = nCounter + 1
														                           If CreditDebitMatchRecord[nCounter].sRefID = frmReceipt.tblTransaction.colRefId
															                           Set bFoundCreditDebitMatch = TRUE
															                           If WriteCashAppRecordForCreditDebit( hSqlWriteCashAppCRDRHdl, 
																	bWriteCashAppCRDRHdlConnected, bWriteCashAppCRDRHdlPrepared,
																	CreditDebitMatchRecord[nCounter]  )
																                           Set frmReceipt.tblTransaction.colAmtApply = 
																		frmReceipt.tblTransaction.colAmtApply -
																		CreditDebitMatchRecord[nCounter].nAmountApplied
															                           Else 
																                           Set bSaveOk = FALSE
																                           Call SalMessageBox( 'Error saving information. Contact
																		Programmers (Write CreditDebitCashAppRec)','Message',MB_Ok )
																                           Return FALSE
											!
											! Now write out the Trans record (after the Amount applied has been adjusted
											! for any credits also allocated see above)
											!
											                           If SaveTransRecord( hSqlSaveTransHdl, bSaveTransHdlConnected, 
													bSaveTransHdlPrepared, ' TRANSACTION ', 
													sSqlWhereTransaction, tblTransaction )
												!
												! Write CashApp record which relates the transaction to the cash receipt 
												! if this Debit transaction still has some amount to apply
												!
												                           If frmReceipt.tblTransaction.colAmtApply > 0 AND
														frmReceipt.tblTransaction.colTransCode = 'DR'
													                           If WriteCashAppRecord( hSqlWriteCashAppHdl, 
															bWriteCashAppHdlConnected, bWriteCashAppHdlPrepared,
															 ' CASH_APPLICATION ' )
														                           Set nTransRowsApplied = nTransRowsApplied - 1
													                           Else 
														                           Set bSaveOk = FALSE
											                           Else 
												                           Set bSaveOk = FALSE
										                           If frmReceipt.tblTransaction.colWriteOff = 'Y'
											                           If SalSendMsg( dfCustARBalance, PAM_ADJUSTARBALANCEWROFF, nTransCode, 0 )
												                           If UpdateCustARBalRecord( ' CUSTOMER_MASTER ', 
														' WHERE Cust_No = :frmReceipt.dfCustNo ', hWndForm, 
														PAM_UPDATECUST, 0, nExecute )
													                           Call SalSendMsg( frmReceipt.tblTransaction.colAmtOuts, 
															PAM_SETWROFFAMTOUTS, 0, 0 )
													! Set the amt outstanding of the original debit trans = 0 
													                           If SaveTransRecord( hSqlSaveTransHdl, bSaveTransHdlConnected, 
															bSaveTransHdlPrepared, ' TRANSACTION ', sSqlWhereTransaction, tblTransaction )
														! Write the credit transaction
														                           If WriteOffTransRecord( hSqlWrOffTransHdl, bWrOffTransHdlConnected, 
																bWrOffTransHdlPrepared, ' TRANSACTION ', tblTransaction )
															! Write a cash app record to relate the credit trans to the debit trans
															                           If NOT WriteCashAppTransTrans( hSqlCshAppWOffHdl, 
																	bCshAppWOffHdlConnected, bCshAppWOffHdlPrepared,
																	 ' CASH_APPLICATION ', tblTransaction )
																                           Set bSaveOk = FALSE
														                           Else 
															                           Set bSaveOk = FALSE
													                           Else 
														                           Set bSaveOk = FALSE
												                           Else 
													                           Set bSaveOk = FALSE
											                           Else 
												                           Set bSaveOk = FALSE
										! If SaveTransRecord( hSqlSaveTransHdl, bSaveTransHdlConnected, bSaveTransHdlPrepared, ' TRANSACTION ', sSqlWhereTransaction, tblTransaction )
											! WriteCashApprecord relates the transaction to the cash receipt 
											                           If WriteCashAppRecord( hSqlWriteCashAppHdl, bWriteCashAppHdlConnected, bWriteCashAppHdlPrepared, ' CASH_APPLICATION ' )
												                           Set nTransRowsApplied = nTransRowsApplied - 1
												                           If frmReceipt.tblTransaction.colWriteOff = 'Y'
													! Write the credit transaction
													                           If WriteOffTransRecord( hSqlWrOffTransHdl, bWrOffTransHdlConnected, bWrOffTransHdlPrepared, ' TRANSACTION ', tblTransaction )
														! Write a cash app record to relate the credit trans to the debit trans
														                           If NOT WriteCashAppTransTrans( hSqlCshAppWOffHdl, bCshAppWOffHdlConnected, bCshAppWOffHdlPrepared, ' CASH_APPLICATION ', tblTransaction )
															                           Set bSaveOk = FALSE
													                           Else 
														                           Set bSaveOk = FALSE
											                           Else 
												                           Set bSaveOk = FALSE
										! Else 
											                           Set bSaveOk = FALSE
									! If frmReceipt.tblTransaction.colApplied = 'Y'
										! Used to be in here if amt outstanding = 0 then we would remove
												the entry from the transaction table and write it directly to the 
												history table - we now only do this when we do a month end trial
												balance 
										! If frmReceipt.tblTransaction.colAmtOuts = 0
											                           If DeleteTransRecord( hSqlDeleteTransHdl, bDeleteTransHdlConnected, bDeleteTransHdlPrepared, ' TRANSACTION ', sSqlWhereTransaction )
												                           If WriteTransHistoryRecord( hSqlWriteHistHdl, bWriteHistHdlConnected, bWriteHistHdlPrepared, ' TRANS_HISTORY ', tblTransaction )
													                           If WriteCashAppRecord( hSqlWriteCashAppHdl, bWriteCashAppHdlConnected, bWriteCashAppHdlPrepared, ' CASH_APPLICATION ' )
														                           Set nTransRowsApplied = nTransRowsApplied - 1
													                           Else 
														                           Set bSaveOk = FALSE
												                           Else 
													                           Set bSaveOk = FALSE
											                           Else 
												                           Set bSaveOk = FALSE
										! Fix up write off code
										                           If frmReceipt.tblTransaction.colWriteOff = 'Y'
											                           If DeleteTransRecord( hSqlDeleteTransHdl, bDeleteTransHdlConnected, bDeleteTransHdlPrepared, ' TRANSACTION ', sSqlWhereTransaction )
												                           If WriteTransHistWriteOff( hSqlHistWOffHdl, bHistWOffHdlConnected, bHistWOffHdlPrepared, ' TRANS_HISTORY ', tblTransaction )
													                           If WriteCashAppRecord( hSqlWriteCashAppHdl, bWriteCashAppHdlConnected, bWriteCashAppHdlPrepared, ' CASH_APPLICATION ' )
														                           Set nTransRowsApplied = nTransRowsApplied - 1
													                           Else 
														                           Set bSaveOk = FALSE
												                           Else 
													                           Set bSaveOk = FALSE
											                           Else 
												                           Set bSaveOk = FALSE
										                           Else 
											                           If SaveTransRecord( hSqlSaveTransHdl, bSaveTransHdlConnected, bSaveTransHdlPrepared, ' TRANSACTION ', sSqlWhereTransaction, tblTransaction )
												                           If WriteCashAppRecord( hSqlWriteCashAppHdl, bWriteCashAppHdlConnected, bWriteCashAppHdlPrepared, ' CASH_APPLICATION ' )
													                           Set nTransRowsApplied = nTransRowsApplied - 1
												                           Else 
													                           Set bSaveOk = FALSE
											                           Else 
												                           Set bSaveOk = FALSE
							                           If nDepositRowsApplied > 0
								                           If bWriteCshRcptHdlConnected
									                           Call SqlCommit( hSqlWriteCshRcptHdl )
								! Need the key of the cash receipt record for the insert of the deposits
								                           Set nRow = TBL_MinRow
								                           While SalTblFindNextRow( tblOutstandDeposit, nRow, 0, 0 )
									                           Call SalTblFetchRow( tblOutstandDeposit, nRow )
									                           If frmReceipt.tblOutstandDeposit.colApplied = 'Y'
										                           If SalTblQueryRowFlags( tblOutstandDeposit, nRow, ROW_New )
											                           If InsertDeposit( hSqlInsDepHdl, bInsDepHdlConnected, bInsDepHdlPrepared, ' OUTSTAND_DEPOSIT ', tblOutstandDeposit )
												                           Set nDepositRowsApplied = nDepositRowsApplied - 1
											                           Else 
												                           Set bSaveOk = FALSE
										                           Else 
											                           If UpdateOutstandDeposit( hSqlSaveDepHdl, bSaveDepHdlConnected, bSaveDepHdlPrepared, ' OUTSTAND_DEPOSIT ', sSqlWhereDeposit, tblOutstandDeposit )
												                           If frmReceipt.tblOutstandDeposit.colDepAmountPaid < frmReceipt.tblOutstandDeposit.colDepAmountReqd
													                           If InsertNewOutstandDeposit( hSqlInsNewDepHdl, bInsNewDepHdlConnected, bInsNewDepHdlPrepared, ' OUTSTAND_DEPOSIT ', tblOutstandDeposit )
														                           Set nDepositRowsApplied = nDepositRowsApplied - 1
													                           Else 
														                           Set bSaveOk = FALSE
												                           Else 
													                           Set nDepositRowsApplied = nDepositRowsApplied - 1
											                           Else 
												                           Set bSaveOk = FALSE
							! Else 
								                           Set bSaveOk = FALSE
							!
							! Now write out Cash Receipt record
							!
							                           If NOT WriteCashRcptRecord( hSqlWriteCshRcptHdl, bWriteCshRcptHdlConnected, 
									bWriteCshRcptHdlPrepared, ' CASH_RECEIPT ', hWndForm )
								                           Set bSaveOk = FALSE
							!
							                           If bSaveOk
								                           If bWriteCshRcptHdlConnected
									                           Call SqlCommit( hSqlWriteCshRcptHdl )
								                           If bWrOffTransHdlConnected
									                           Call SqlCommit( hSqlWrOffTransHdl )
								                           If bWriteHistHdlConnected
									                           Call SqlCommit( hSqlWriteHistHdl )
								                           If bWriteCashAppHdlConnected
									                           Call SqlCommit( hSqlWriteCashAppHdl )
								                           If bWriteCashAppCRDRHdlConnected
									                           Call SqlCommit( hSqlWriteCashAppCRDRHdl )
								                           If bSaveTransHdlConnected
									                           Call SqlCommit( hSqlSaveTransHdl )
								                           If bSaveDepHdlConnected
									                           Call SqlCommit( hSqlSaveDepHdl )
								                           If bInsNewDepHdlConnected
									                           Call SqlCommit( hSqlInsNewDepHdl )
								                           If bInsDepHdlConnected
									                           Call SqlCommit( hSqlInsDepHdl )
								                           If bCshAppWOffHdlConnected
									                           Call SqlCommit( hSqlCshAppWOffHdl )
								                           If nOrgTransRowsApplied > 0
									                           Set nRow = TBL_MinRow
									                           While SalTblFindNextRow( tblTransaction, nRow, 0, 0 )
										                           Call SalTblFetchRow( tblTransaction, nRow )
										                           If frmReceipt.tblTransaction.colApplied = 'Y'
											                           Call SalSendMsg( tblTransaction, PAM_CLEARAPPLIEDROW, 0, nRow )
											                           Set nRow = nRow - 1
								                           If nOrgDepositRowsApplied > 0
									                           Set nRow = TBL_MinRow
									                           While SalTblFindNextRow( tblOutstandDeposit, nRow, 0, 0 )
										                           Call SalTblFetchRow( tblOutstandDeposit, nRow )
										                           If frmReceipt.tblOutstandDeposit.colApplied = 'Y'
											                           Call SalSendMsg( tblOutstandDeposit, PAM_CLEARAPPLIEDROW, 0, nRow )
											                           Set nRow = nRow - 1
								                           Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nCommit )
								                           Set bEdit = FALSE
								                           Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, FALSE, 0 )
								                           Call SalSendMsg( pbClear, SAM_Click, 0, 0 )
							                           Else 
								                           If bWriteCshRcptHdlConnected
									                           Call SqlPrepareAndExecute( hSqlWriteCshRcptHdl, 'ROLLBACK' )
									                           Set bWriteCshRcptHdlPrepared = FALSE
								                           If bWrOffTransHdlConnected
									                           Call SqlPrepareAndExecute( hSqlWrOffTransHdl, 'ROLLBACK' )
									                           Set bWrOffTransHdlPrepared = FALSE
								                           If bWriteHistHdlConnected
									                           Call SqlPrepareAndExecute( hSqlWriteHistHdl, 'ROLLBACK' )
									                           Set bWriteHistHdlPrepared = FALSE
								                           If bWriteCashAppHdlConnected
									                           Call SqlPrepareAndExecute( hSqlWriteCashAppHdl, 'ROLLBACK' )
									                           Set bWriteCashAppHdlPrepared = FALSE
								                           If bWriteCashAppCRDRHdlConnected
									                           Call SqlPrepareAndExecute( hSqlWriteCashAppCRDRHdl, 'ROLLBACK' )
									                           Set bWriteCashAppHdlPrepared = FALSE
								                           If bSaveTransHdlConnected
									                           Call SqlPrepareAndExecute( hSqlSaveTransHdl, 'ROLLBACK' )
									                           Set bSaveTransHdlPrepared = FALSE
								                           If bSaveDepHdlConnected
									                           Call SqlPrepareAndExecute( hSqlSaveDepHdl, 'ROLLBACK' )
									                           Set bSaveDepHdlPrepared = FALSE
								                           If bInsNewDepHdlConnected
									                           Call SqlPrepareAndExecute( hSqlInsNewDepHdl, 'ROLLBACK' )
									                           Set bInsNewDepHdlPrepared = FALSE
								                           If bInsDepHdlConnected
									                           Call SqlPrepareAndExecute( hSqlInsDepHdl, 'ROLLBACK' )
									                           Set bInsDepHdlPrepared = FALSE
								                           If bCshAppWOffHdlConnected
									                           Call SqlPrepareAndExecute( hSqlCshAppWOffHdl, 'ROLLBACK' )
									                           Set bCshAppWOffHdlPrepared = FALSE
								                           Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nRollback )
								                           Set nTransRowsApplied = nOrgTransRowsApplied
								                           Set nDepositRowsApplied = nOrgDepositRowsApplied
							!
							                           Call SalEnableWindow( hWndItem )
							                           Call SalWaitCursor( FALSE )
				Pushbutton: pbQInvoice
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Query
					Window Location and Size
						Left:   5.088"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: k:\centura\ICONS\INVOICE.ICO
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							If NOT SalSendMsg( hWndForm, PAM_EDITCHECK, 0, 0 )
								Return FALSE
							Call SalWaitCursor( TRUE )
							Call SalDisableWindow( hWndItem )
							If SalModalDialog( dlgQueryCstFrmInvNo, hWndForm )
								Call PopString( dfCustName, TRUE )
								Call PopNumber( dfCustNo, TRUE )
								If cmbRcptType = 'CHEQUE'
									Set dfDrawer = dfCustName
									Call SalSetFocus( dfDrawer )
								Else
									Call SalSetFocus( dfRecptAmt )
								Call SalSendMsg( tblTransaction, PAM_POPULATE, 0, 0 )
							Else
								Call SalEnableWindow( hWndItem )
								Call SalWaitCursor( FALSE )
							! If SalModalDialog( dlgGetInvoiceNo, hWndItem )
								                           If cmbRcptType = 'CHEQUE'
									                           Set dfDrawer = dfCustName
									                           Call SalSetFocus( dfDrawer )
								                           Else 
									                           Call SalSetFocus( dfRecptAmt )
								                           Call SalSendMsg( tblTransaction, PAM_POPULATE, 0, 0 )
							! Else
								                           Call SalEnableWindow( hWndItem )
								                           Call SalWaitCursor( FALSE )
							Call SalEnableWindow( hWndItem )
						! On SAM_KillFocus
							                           Call SalPostMsg( hWndItem, PAM_PBFOCUSPLACED, 0, 0 )
						! On PAM_PBFOCUSPLACED
							                           Call MySetFocus( nFocusIn )
				Pushbutton: pbClear
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Clear
					Window Location and Size
						Left:   0.588"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Maint.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							If NOT wParam
								If NOT SalSendMsg( hWndForm, PAM_EDITCHECK, 0, 0 )
									Return FALSE
							Call SalWaitCursor( TRUE )
							Call SalDisableWindow( hWndItem )
							Set bEdit = FALSE
							Set nTransRowsApplied = 0
							Set nDepositRowsApplied = 0
							Set nCreditDebitMatchingTrans = 0
							Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, FALSE, 0 )
							Call SalSendMsgToChildren( hWndForm, PAM_RESET, 0, 0 )
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )
				Pushbutton: pbUnApply
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Unapply
					Window Location and Size
						Left:   6.688"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Stoplght.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							Call SalWaitCursor( TRUE )
							Call SalDisableWindow( hWndItem )
							If rbViewTrans
								Set bHaveUnAppliedRow = FALSE
								Set nOrgRow = SalTblQueryContext( tblTransaction )
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( tblTransaction, nRow )
									Call SalTblSetFocusRow( tblTransaction, nRow )
									If frmReceipt.tblTransaction.colApplied = 'Y'
										If UnApplyTransRow( frmReceipt.tblTransaction.colTransAmount, frmReceipt.tblTransaction.colAmtOuts,
												  frmReceipt.tblTransaction.colOrgAmtOuts, frmReceipt.tblTransaction.colAmtApply, 
												  dfStillToApply, frmReceipt.tblTransaction.colAppDate, dfRecptAmt )
											Set bHaveUnAppliedRow = TRUE
											Set nTransRowsApplied = nTransRowsApplied - 1
											Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, FALSE, nRow )
											Set bEdit = TRUE
								If bHaveUnAppliedRow
									If SalTblFindNextRow( tblTransaction, nRow, 0, 0 )
										Call SalTblFetchRow( tblTransaction, nRow )
										Call SalTblSetRowFlags( tblTransaction, nRow, ROW_Selected, TRUE )
										Call SalTblSetFocusRow( tblTransaction, nRow )
								Else
									Call SalTblFetchRow( tblTransaction, nOrgRow )
									Call SalTblSetFocusRow( tblTransaction, nOrgRow )
							Else If rbViewDeposits
								Set bHaveUnAppliedRow = FALSE
								Set nOrgRow = SalTblQueryContext( tblOutstandDeposit )
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblOutstandDeposit, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( tblOutstandDeposit, nRow )
									Call SalTblSetFocusRow( tblOutstandDeposit, nRow )
									If frmReceipt.tblOutstandDeposit.colApplied = 'Y'
										If UnApplyDepositRow( frmReceipt.tblOutstandDeposit.colDepAmountPaid, 
												  dfStillToApply, frmReceipt.tblOutstandDeposit.colDepPaidDate, dfRecptAmt )
											Set bHaveUnAppliedRow = TRUE
											Set nDepositRowsApplied = nDepositRowsApplied - 1
											Call SalSendMsg( tblOutstandDeposit, PAM_SETROWEDITFLAG, FALSE, nRow )
											Set bEdit = TRUE
								If bHaveUnAppliedRow
									If SalTblFindNextRow( tblOutstandDeposit, nRow, 0, 0 )
										Call SalTblFetchRow( tblOutstandDeposit, nRow )
										Call SalTblSetRowFlags( tblOutstandDeposit, nRow, ROW_Selected, TRUE )
										Call SalTblSetFocusRow( tblOutstandDeposit, nRow )
								Else
									Call SalTblFetchRow( tblOutstandDeposit, nOrgRow )
									Call SalTblSetFocusRow( tblOutstandDeposit, nOrgRow )
							If nTransRowsApplied <= 0 AND nDepositRowsApplied <= 0
								Set bEdit = FALSE
								Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, FALSE, 0 )
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )
				Pushbutton: pbClearNewDeposit
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Clear Dep
					Window Location and Size
						Left:   2.388"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default

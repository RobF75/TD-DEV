		Named Menus
		Internal Functions
			Function: VerifyCustNoAndGetName
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
				Static Variables
				Local variables
					String: sSql
					Number: nInd
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Set sSql = ' SELECT Cust_Name FROM
								 Customer_Master INTO :frmReceipt.dfCustName WHERE Cust_No = :frmReceipt.dfCustNo '
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					Set frmReceipt.dfCustName = ''
					If SqlExecute( hSqlHandle )
						Call SqlFetchNext( hSqlHandle, nInd )
						If nInd = FETCH_Ok
							Return TRUE
						Else
							Return FALSE
					Else
						Set bHandlePrepared = FALSE
						Return FALSE
			Function: GetCustDetailsFromInvNo
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					Number: nInvNo
				Static Variables
				Local variables
					String: sSql
					Number: nInd
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Set sSql = ' SELECT Transaction.Cust_No, Cust_Name FROM Customer_Master, Transaction 
								INTO :frmReceipt.dfCustNo, :frmReceipt.dfCustName 
								WHERE Transaction.Reference_Id = :nInvNo AND 
								TRANSACTION.CUST_NO = CUSTOMER_MASTER.CUST_NO '
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					Set frmReceipt.dfCustNo = NUMBER_Null
					Set frmReceipt.dfCustName = ''
					If SqlExecute( hSqlHandle )
						Call SqlFetchNext( hSqlHandle, nInd )
						Return TRUE
					Else
						Set bHandlePrepared = FALSE
						Return FALSE
			!
			Function: PopulateCmbBank
				Description:
				Returns
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bCmbPopulated
					Window Handle: hWndSource
				Static Variables
				Local variables
					String: sSql
				Actions
					Call SalWaitCursor( TRUE )
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bCmbPopulated
						Set sSql = 'SELECT DISTINCT Cheque_Bank FROM Cash_Receipt
								WHERE Cheque_Bank IS NOT NULL'
						Call SalListPopulate( hWndSource, hSqlHandle, sSql )
						Set bCmbPopulated = TRUE
					Call SalWaitCursor( FALSE )
			Function: PopulateCmbSundry
				Description:
				Returns
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bCmbPopulated
					Window Handle: hWndSource
				Static Variables
				Local variables
					String: sSql
				Actions
					Call SalWaitCursor( TRUE )
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bCmbPopulated
						Set sSql = 'SELECT DISTINCT Sundry_Catagory FROM Cash_Receipt
								WHERE Sundry_Catagory IS NOT NULL'
						Call SalListPopulate( hWndSource, hSqlHandle, sSql )
						Set bCmbPopulated = TRUE
					Call SalWaitCursor( FALSE )
			!
			! FUNCTIONS TO APPLY AND UNAPPLY TRANSACTIONS
			Function: ApplyTransRow
				Description:
				Returns
					Boolean:
				Parameters
					Number: nColTransAmount
					Receive Number: nColAmtOuts
					Receive Number: nColAmtApply
					Receive Number: ndfStillToApply
					Receive Date/Time: dtColAppDate
					Receive Date/Time: dtApplyDate
				Static Variables
				Local variables
					Number: nTmpAmtOuts
					Number: nTmpStillToApply
					Number: nTmpColApply
				Actions
					Set nTmpAmtOuts = nColAmtOuts
					Set nTmpStillToApply = ndfStillToApply
					If nColAmtApply = NUMBER_Null
						If nColAmtOuts > 0
							Set nTmpColApply = nColAmtOuts
						Else
							Set nTmpColApply = nColTransAmount
						!
						! TS 24/05/95
						! If the Temp Amount to apply is greater than the Still to apply
						! adjust temp amount back to still to apply
						!
						If nTmpColApply > ndfStillToApply
							Set nTmpColApply = ndfStillToApply
					Else
						Set nTmpColApply = nColAmtApply
					If DoTransApply( nColTransAmount, nTmpAmtOuts, nTmpColApply, nTmpStillToApply )
						Set nColAmtOuts = nTmpAmtOuts
						Set ndfStillToApply = nTmpStillToApply
						Set nColAmtApply = nTmpColApply
						If dtColAppDate = DATETIME_Null
							Set dtColAppDate = dtApplyDate
						Else
							Set dtApplyDate = dtColAppDate
						Return TRUE
					Else
						Return FALSE
			Function: DoTransApply
				Description: Apply logic, returns true if we havent over applied
				Returns
					Boolean:
				Parameters
					Number: nColTransAmount
					Receive Number: nColAmtOuts
					Number: nColAmtApply
					Receive Number: ndfStillToApply
				Static Variables
				Local variables
				Actions
					If nColAmtApply > 0
						Set ndfStillToApply = ndfStillToApply - nColAmtApply
						If nColAmtOuts > 0
							Set nColAmtOuts = nColAmtOuts - nColAmtApply
						Else
							Set nColAmtOuts = nColTransAmount - nColAmtApply
					! The else probably wont be run through now, as in the prior call section I have
							set the value of the amt to apply = amt outs or the trans amt
					Else
						If nColAmtOuts > 0
							Set ndfStillToApply = ndfStillToApply - nColAmtOuts
						Else
							Set ndfStillToApply = ndfStillToApply - nColTransAmount
						Set nColAmtOuts = 0
					If ndfStillToApply >= 0
						Return TRUE
					Else
						Return FALSE
			Function: UnApplyTransRow
				Description:
				Returns
					Boolean:
				Parameters
					Number: nColTransAmount
					Receive Number: nColAmtOuts
					Number: nColOrgAmtOuts
					Receive Number: nColAmtApply
					Receive Number: ndfStillToApply
					Receive Date/Time: dtColAppDate
					Number: nAmtReceipt
				Static Variables
				Local variables
					Number: nTmpAmtOuts
					Number: nTmpStillToApply
					Number: nTmpAmtApply
				Actions
					Set nTmpAmtOuts = nColAmtOuts
					Set nTmpStillToApply = ndfStillToApply
					Set nTmpAmtApply = nColAmtApply
					If DoTransUnApply( nColTransAmount, nTmpAmtOuts, nColOrgAmtOuts, nTmpAmtApply, nTmpStillToApply, nAmtReceipt )
						Set nColAmtOuts = nTmpAmtOuts
						Set ndfStillToApply = nTmpStillToApply
						Set nColAmtApply = nTmpAmtApply
						Set dtColAppDate = DATETIME_Null
						Return TRUE
					Else
						Return FALSE
			Function: DoTransUnApply
				Description: Apply logic, returns true if we havent over applied
				Returns
					Boolean:
				Parameters
					Number: nColTransAmount
					Receive Number: nColAmtOuts
					Number: nColOrgAmtOuts
					Receive Number: nColAmtApply
					Receive Number: ndfStillToApply
					Number: nAmtReceipt
				Static Variables
				Local variables
				Actions
					If nColAmtApply > 0
						Set ndfStillToApply = ndfStillToApply + nColAmtApply
						Set nColAmtOuts = nColAmtOuts + nColAmtApply
						Set nColAmtApply = NUMBER_Null
					Else
						If nColOrgAmtOuts > 0
							Set ndfStillToApply = ndfStillToApply + nColOrgAmtOuts
							Set nColAmtOuts = nColOrgAmtOuts
						Else
							Set ndfStillToApply = ndfStillToApply + nColTransAmount
							Set nColAmtOuts = nColTransAmount
					If ndfStillToApply <= nAmtReceipt
						Return TRUE
					Else
						Return FALSE
			!
			! FUNCTIONS TO APPLY AND UNAPPLY DEPOSITS
			Function: ApplyDepositRow
				Description:
				Returns
					Boolean:
				Parameters
					Number: nColDepAmountReqd
					Receive Number: nColDepAmountPaid
					Receive Number: ndfStillToApply
					Receive Date/Time: dtColDepPaidDate
					Receive Date/Time: dtApplyDate
				Static Variables
				Local variables
					Number: nTmpDepAmountPaid
					Number: nTmpStillToApply
				Actions
					Set nTmpDepAmountPaid = nColDepAmountPaid
					Set nTmpStillToApply = ndfStillToApply
					If DoDepositApply( nColDepAmountReqd, nTmpDepAmountPaid, nTmpStillToApply )
						Set nColDepAmountPaid = nTmpDepAmountPaid
						Set ndfStillToApply = nTmpStillToApply
						If dtColDepPaidDate = DATETIME_Null
							Set dtColDepPaidDate = dtApplyDate
						Else
							Set dtApplyDate = dtColDepPaidDate
						Return TRUE
					Else
						Return FALSE
			Function: DoDepositApply
				Description: Apply logic, returns true if we havent over applied
				Returns
					Boolean:
				Parameters
					Number: nColDepAmountReqd
					Receive Number: nTmpDepAmountPaid
					Receive Number: ndfStillToApply
				Static Variables
				Local variables
				Actions
					If NOT nTmpDepAmountPaid > 0
						Set nTmpDepAmountPaid = nColDepAmountReqd
					Set ndfStillToApply = ndfStillToApply - nTmpDepAmountPaid
					If ndfStillToApply >= 0
						Return TRUE
					Else
						Return FALSE
			Function: UnApplyDepositRow
				Description:
				Returns
					Boolean:
				Parameters
					Receive Number: nColDepAmountPaid
					Receive Number: ndfStillToApply
					Receive Date/Time: dtColDepPaidDate
					Number: nAmtReceipt
				Static Variables
				Local variables
					Number: nTmpStillToApply
					Number: nTmpDepAmountPaid
				Actions
					Set nTmpStillToApply = ndfStillToApply
					Set nTmpDepAmountPaid = nColDepAmountPaid
					If DoDepositUnApply( nTmpDepAmountPaid, nTmpStillToApply, nAmtReceipt )
						Set nColDepAmountPaid = nTmpDepAmountPaid
						Set ndfStillToApply = nTmpStillToApply
						Set dtColDepPaidDate = DATETIME_Null
						Return TRUE
					Else
						Return FALSE
			Function: DoDepositUnApply
				Description: Apply logic, returns true if we havent over applied
				Returns
					Boolean:
				Parameters
					Receive Number: nColDepAmountPaid
					Receive Number: ndfStillToApply
					Number: nAmtReceipt
				Static Variables
				Local variables
				Actions
					Set ndfStillToApply = ndfStillToApply + nColDepAmountPaid
					Set nColDepAmountPaid = NUMBER_Null
					If ndfStillToApply <= nAmtReceipt
						Return TRUE
					Else
						Return FALSE
			!
			! FUNCTIONS TO SAVE APPLIED TRANSACTIONS
			Function: SaveTransRecord
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					String: sSQLTABLENAME
					String: sSQLWHERE
					Window Handle: hWndTable
				Static Variables
				Local variables
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Call CallBuildSql( hWndTable, nUPDATE, PAM_UPDATETRANSACTION, sSQLTABLENAME, sSQLWHERE )
						If SqlPrepare( hSqlHandle, sgSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						Return TRUE
					Else
						Set bHandlePrepared = FALSE
						Return FALSE

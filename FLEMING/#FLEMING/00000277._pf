				Pushbutton: pbSaveMaintCR
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Save
					Window Location and Size
						Left:   1.188"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Disk.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							Set bOk = TRUE
							Call MyTableLoop( tblMaintCashReceipts, hWndItem, PAM_ROWACTION, ROW_Edited | ROW_Edited, 0, 'Checking modification restrictions', nLowToHiWithPositioning )
							If bOk
								Call tblMaintCashReceipts.TableSaveChanges()
								Call SalSendMsg( tblMaintCashReceipts, PAM_POPULATE, 0, 0 )
							Else
								Call SalMessageBox( 'Sorry, only receipts in the current month may be modified or deleted.', 'System Message', MB_Ok )
						On PAM_ROWACTION
							If NOT SalDateMonth( tblMaintCashReceipts.colReceiptDate ) = SalDateMonth( SalDateCurrent(  ) )
								Set bOk = FALSE
							Return TRUE
				Pushbutton: pbDeleteMaintCR
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Delete
					Window Location and Size
						Left:   1.788"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Delrec.bmp
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							! Call TableDeleteRows( tblMaintCashReceipts )
							If NOT SalTblAnyRows( tblMaintCashReceipts, ROW_Selected, 0 )
								Call SalMessageBox( 'Please select a record first',
										'System Message', MB_Ok )
								Return FALSE
							!
							If SalDateMonth( tblMaintCashReceipts.colReceiptDate ) = SalDateMonth( SalDateCurrent(  ) )
								Call SalMessageBox( 'Record will have amount set to zero
										and not deleted (for auditing reasons).','System Message', MB_Ok )
								! Just Set the amount to zero and handle as an edited record
								Set tblMaintCashReceipts.colReceiptAmount = 0
								Call SalTblSetRowFlags( tblMaintCashReceipts, SalTblQueryContext( tblMaintCashReceipts ), 
										ROW_Edited, TRUE )
							Else
								Call SalMessageBox( 'Sorry, only receipts in the current month may be modified or deleted.', 'System Message', MB_Ok )
				Pushbutton: pbShowRecords
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Show
					Window Location and Size
						Left:   3.213"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Query.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							Call SalWaitCursor( TRUE )
							Call SalDisableWindow( hWndItem )
							If SalIsNull( dfMaintCRDate )
								Call SalWaitCursor( FALSE )
								Call SalMessageBox( 'A date is required before transactions can be shown!', 'Warning', MB_Ok )
								Call SalWaitCursor( TRUE )
								Call SalSetFocus( dfMaintCRDate )
							Else
								Call SalSendMsg( tblMaintCashReceipts, PAM_POPULATE, 0, 0 )
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )
						On PAM_LOOKUPCUST
							Call SalSendMsg( hWndItem, SAM_Click, 0, 0 )
				!
				Pushbutton: pbPrintCashReceipt
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Receipt
					Window Location and Size
						Left:   4.31"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Print.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							Call SalWaitCursor( TRUE )
							Call SalDisableWindow( hWndItem )
							!
							If SalTblAnyRows( tblMaintCashReceipts, ROW_Selected, 0 )
								Set sFileName = OurGetIniFileParameter( 'ACCOUNTS', 'PrintCashReceipts', '' )
								Set sFileName = sFileName || ' ' || SqlDatabase || ' ' || SqlUser || ' ' || SqlPassword || ' ' || tblMaintCashReceipts.colRowID
								Call SalLoadAppAndWait( sFileName, Window_Minimized, nReturn )
							Else
								Call SalMessageBox( 'Please select a receipt first.', 'NOTE', MB_Ok )
							!
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )

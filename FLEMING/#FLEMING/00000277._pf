							If IDNO = SalMessageBox( 'Are you ready to update the modified rows?',
									'System Message', MB_YesNo|MB_IconExclamation )
								Return FALSE
							Call SalWaitCursor( TRUE )
							!
							! Check if any rows edited and apply changes
							!
							If SalTblAnyRows( hWndForm, ROW_Edited, 0 )
								If NOT SqlConnect( hSqlExtra )
									Call SalMessageBox( 'Error connecting in TableSaveChanges.
											Contact Programmers','System Message',MB_Ok )
									Return FALSE
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( hWndForm, nRow, ROW_Edited, 0 )
									Call SalTblFetchRow( hWndForm, nRow )
									!
									! Check if User has changed the Receipt amount
									!
									If colReceiptAmount != colReceiptAmountOriginal
										!
										! User has changed the Receipt amount
										!
										If colCustomerNo = NUMBER_Null
											!
											! No Customer Number so just update the Cash Receipt table - (done lower down)
											!
											Set nNewAmountUnApplied = colAmountUnapplied
											Set sFullyApplied = 'Y'
											! the receipt amount is set via the column and the update
										Else
											If colReceiptAmount < colReceiptAmountOriginal
												!
												! User has lowered the receipt amount
												!
												Set nAmountLowered = colReceiptAmountOriginal - colReceiptAmount
												If colAmountUnapplied = 0
													!
													! There is none unapplied so just need to modify the Transaction
													! and Cash_Application tables then reduce the amount unapplied
													! Set mode to reducing the amount applied
													!
													Set nMode = 0
													Call ModifyCashAppilcationRecords(nAmountLowered, nMode, 
															colUserID, colSysDateTime )
													! Set sFullyApplied = 'Y'
												Else If ( nAmountLowered > colAmountUnapplied) 
													!
													! Amount lowered is more than the amount previously unapplied
													! need to reduce the amount unapplied then modify the Transaction
													! and Cash_Application tables
													!
													! First reduce the Amount_UnApplied 
													!
													Set nAmountLowered = nAmountLowered - colAmountUnapplied
													Set nNewAmountUnApplied = 0
													Set sFullyApplied = 'Y'
													!
													! Now we need to modify the Transaction and Cash_Application tables with
															  the Real Amount Lowered (ie After taking off the old Amount_UnApplied)
													! Set mode to reducing the amount applied
													!
													Set nMode = 0
													Call ModifyCashAppilcationRecords(nAmountLowered, nMode, 
															colUserID, colSysDateTime )
												Else
													!
													! Only lower the amount to Amount_Unapplied
													!
													Set nNewAmountUnApplied = colAmountUnapplied - nAmountLowered
													Set nAmountLowered = 0
													! Need to check as we may only be lowering by the amount unapplied so then we want
															set the fully applied flag = Y
													If nNewAmountUnApplied = 0
														Set sFullyApplied = 'Y'
													Else
														Set sFullyApplied = 'N'
											Else
												!
												! User has raised the receipt amount
												!
												Set nAmountRaised = colReceiptAmount - colReceiptAmountOriginal
												If colAmountUnapplied != 0
													!
													! Only raised the amount to Amount_Unapplied
													!
													Set nNewAmountUnApplied = colAmountUnapplied + nAmountRaised
													Set sFullyApplied = 'N'
												Else
													!
													! No amount unapplied so first modify the Transaction and 
													! Cash_Application tables then increase the amount unapplied
													!
													! Set mode to increasing the amount applied
													!
													Set nMode = 1
													Call ModifyCashAppilcationRecords(nAmountRaised, nMode, 
															colUserID, colSysDateTime )
													!
													! Now apply the remainder of the receipt to Amount_UnApplied
													!
													Set nNewAmountUnApplied = nAmountRaised
													! If nNewAmountUnApplied > 0
														                           Set sFullyApplied = 'N'
													! Else
														                           Set sFullyApplied = 'Y'
									!
									! If we havent finished processing all the changes then we need to check the deposits to see if
											they have money applied to them
									If nAmountLowered != 0
										Call ModifyDepositRecords( nAmountLowered, 0, colUserID, colSysDateTime )
										Call SalTblSetRowFlags( hWndForm, nRow, ROW_UnusedFlag2, TRUE )
										Set nNewAmountUnApplied = 0
									Else If nAmountRaised != 0
										Call ModifyDepositRecords( nAmountRaised, 1, colUserID, colSysDateTime )
										Call SalTblSetRowFlags( hWndForm, nRow, ROW_UnusedFlag2, TRUE )
										Set nNewAmountUnApplied = 0
									If nNewAmountUnApplied > 0
										Set sFullyApplied = 'N'
									Else
										Set sFullyApplied = 'Y'
									! Now update the columns in the Cash_Receipt Table
									!
									Call SqlPrepareAndExecute( hSqlExtra, '
											UPDATE 
											  CASH_RECEIPT
											SET
											  RECEIPT_AMOUNT = :colReceiptAmount,
											  AMOUNT_UNAPPLIED = :nNewAmountUnApplied,
											  FULLY_APPLIED_FLAG = :sFullyApplied,
											  CHEQUE_DRAWER = :colChequeDrawer ,
											  CHEQUE_BANK = :colChequBank , 
											  CHEQUE_BRANCH = :colChequeBranch ,
											 CHEQUE_NO = :colChqNo ,
											  SUNDRY_CATAGORY = :colSundryCat ,
											  RECEIPT_COMMENTS = :colReceiptComments 
											WHERE
											  Receipt_User_Id = :colUserID AND 
											  Rcpt_Sysdatetime = :colSysDateTime' )
									Call SqlCommit( hSqlExtra )
									If UpdtCustDaysOfCredAvg( colCustNo, nExecute )
										Call UpdtCustDaysOfCredAvg( 0, nCommit )
								Call SqlDisconnect( hSqlExtra )
							! If SalTblAnyRows( hWndForm, ROW_Edited, 0 )
								                           If NOT SqlConnect( hSqlExtra )
									                           Call SalMessageBox( 'Error connecting in TableSaveChanges.
											Contact Programmers','System Message',MB_Ok )
									                           Return FALSE
								                           Set nRow = TBL_MinRow
								                           While SalTblFindNextRow( hWndForm, nRow, ROW_Edited, 0 )
									                           Call SalTblFetchRow( hWndForm, nRow )
									!
									! Check if User has changed the Receipt amount
									!
									                           If colReceiptAmount != colReceiptAmountOriginal
										!
										! User has changed the Receipt amount
										!
										                           If colCustomerNo = NUMBER_Null
											!
											! No Customer Number so just update the Cash Receipt table - (done lower down)
											!
											                           Set nNewAmountUnApplied = colAmountUnapplied
											! the receipt amount is set via the column and the update
										                           Else 
											                           If colReceiptAmount < colReceiptAmountOriginal
												!
												! User has lowered the receipt amount
												!
												                           Set nAmountLowered = colReceiptAmountOriginal - colReceiptAmount
												                           If colAmountUnapplied = 0
													!
													! There is none unapplied so just need to modify the Transaction
													! and Cash_Application tables then reduce the amount unapplied
													! Set mode to reducing the amount applied
													!
													                           Set nMode = 0
													                           Call ModifyCashAppilcationRecords(nAmountLowered, nMode, 
															colUserID, colSysDateTime )
													                           Set sFullyApplied = 'Y'
												                           Else If ( nAmountLowered > colAmountUnapplied) 
													!
													! Amount lowered is more than the amount previously unapplied
													! need to reduce the amount unapplied then modify the Transaction
													! and Cash_Application tables
													!
													! First reduce the Amount_UnApplied 
													!
													                           Set nAmountLowered = nAmountLowered - colAmountUnapplied
													                           Set nNewAmountUnApplied = 0
													                           Set sFullyApplied = 'Y'
													!
													! Now we need to modify the Transaction and Cash_Application tables with
															  the Real Amount Lowered (ie After taking off the old Amount_UnApplied)
													! Set mode to reducing the amount applied
													!
													                           Set nMode = 0
													                           Call ModifyCashAppilcationRecords(nAmountLowered, nMode, 
															colUserID, colSysDateTime )
												                           Else 
													!
													! Only lower the amount to Amount_Unapplied
													!
													                           Set nNewAmountUnApplied = colAmountUnapplied - nAmountLowered
													! Need to check as we may only be lowering by the amount unapplied so then we want
															set the fully applied flag = Y
													                           If nNewAmountUnApplied = 0
														                           Set sFullyApplied = 'Y'
													                           Else 
														                           Set sFullyApplied = 'N'
											                           Else 
												!
												! User has raised the receipt amount
												!
												                           Set nAmountRaised = colReceiptAmount - colReceiptAmountOriginal
												                           If colAmountUnapplied != 0
													!
													! Only raised the amount to Amount_Unapplied
													!
													                           Set nNewAmountUnApplied = colAmountUnapplied + nAmountRaised
													                           Set sFullyApplied = 'N'
												                           Else 
													!
													! No amount unapplied so first modify the Transaction and 
													! Cash_Application tables then increase the amount unapplied
													!
													! Set mode to increasing the amount applied
													!
													                           Set nMode = 1
													                           Call ModifyCashAppilcationRecords(nAmountRaised, nMode, 
															colUserID, colSysDateTime )
													!
													! Now apply the remainder of the receipt to Amount_UnApplied
													!
													                           Set nNewAmountUnApplied = nAmountRaised
													                           If nNewAmountUnApplied > 0
														                           Set sFullyApplied = 'N'
													                           Else 
														                           Set sFullyApplied = 'Y'
									!
									! Now update the columns in the Cash_Receipt Table
									!
									                           Call SqlPrepareAndExecute( hSqlExtra, '
											UPDATE 
											  CASH_RECEIPT
											SET
											  RECEIPT_AMOUNT = :colReceiptAmount,
											  AMOUNT_UNAPPLIED = :nNewAmountUnApplied,
											  FULLY_APPLIED_FLAG = :sFullyApplied,
											  CHEQUE_DRAWER = :colChequeDrawer ,
											  CHEQUE_BANK = :colChequBank , 
											  CHEQUE_BRANCH = :colChequeBranch ,
											  SUNDRY_CATAGORY = :colSundryCat ,
											  RECEIPT_COMMENTS = :colReceiptComments 
											WHERE
											  ROWID = :colRowID' )
									                           Call SqlCommit( hSqlExtra )
								                           Call SqlDisconnect( hSqlExtra )
							!
							! Unmark rows
							!
							Set nRow = TBL_MinRow
							While SalTblFindNextRow( hWndForm, nRow, ROW_Edited|ROW_MarkDeleted, 0 )
								Call SalTblFetchRow( hWndForm, nRow )
								If NOT SalTblQueryRowFlags( hWndForm, nRow, ROW_UnusedFlag2 )
									Call NewAdjustCustARBalance( colCustNo, colReceiptAmountOriginal, nIncrement, nExecute )
									Call NewAdjustCustARBalance( colCustNo, colReceiptAmount, nDecrement, nExecute )
									Call NewAdjustCustARBalance( 0, 0, nIncrement, nCommit )
									Call NewAdjustCustARBalance( 0, 0, nDecrement, nCommit )
								Call SalTblSetRowFlags( hWndForm, nRow, ROW_Edited, FALSE )
								Call SalTblSetRowFlags( hWndForm, nRow, ROW_UnusedFlag2, FALSE )
								If SalTblQueryRowFlags( hWndForm, nRow, ROW_MarkDeleted )
									Call SalTblDeleteRow( hWndForm, nRow, TBL_Adjust )
									Set nRow = nRow - 1
							Call SalTblKillEdit( hWndForm )
							Call SalWaitCursor( FALSE )
							Return TRUE
					Function: ModifyCashAppilcationRecords
						Description: Modifies the Cash Application table then call ModifyTransactionRecord
								nMode determines whether we are reducing or incresing records
								nMode = 0 We are reducing the amount applied
								nMode = 1 We are increasing the amount applied
						Returns
							Boolean:
						Parameters
							! Number: nModifyAmount
							Receive Number: nModifyAmount
							Number: nMode
							String: sUser
							Date/Time: dtDateTime
						Static Variables
						Local variables
							String: sTransUser
							String: sApplicUserId
							Date/Time: dtApplicSysDT
							Date/Time: dtTransDateTime
							Number: nAppliedAmount
							Number: nAmountChanged
							Sql Handle: hSql
							Sql Handle: hSqlTransaction
							Sql Handle: hSqlUpdate
							Number: nReturn
							Number: nNewAppliedAmount
							String: sSqlCashApplicationSelect
							String: sSqlCashApplicationUpdate
						Actions
							Set sSqlCashApplicationSelect = '
									SELECT 
									  Applic_User_Id, Applic_Sysdatetime, TRANS_USER_ID, TRANS_SYSDATETIME,  APPLIED_AMOUNT
									FROM
									  CASH_APPLICATION 
									INTO
									  :sApplicUserId, :dtApplicSysDT, :sTransUser, :dtTransDateTime, :nAppliedAmount 
									WHERE
									  RECEIPT_USER_ID = :sUser AND
									  RECEIPT_SYSDATETIM = :dtDateTime '
							Set sSqlCashApplicationUpdate = '
									UPDATE 
									  CASH_APPLICATION
									SET
									  APPLIED_AMOUNT = :nNewAppliedAmount
									WHERE
									  Applic_User_Id = :sApplicUserId AND 
									  Applic_Sysdatetime = :dtApplicSysDT '
							If nMode = 0
								! If recuding then order records youngest first
								Set sSqlCashApplicationSelect = sSqlCashApplicationSelect || ' 
										ORDER BY
										  APPLIC_SYSDATETIME DESC'
							Else
								! If increasing then order records oldest first
								Set sSqlCashApplicationSelect = sSqlCashApplicationSelect || ' 
										ORDER BY
										  APPLIC_SYSDATETIME ASC'
							If NOT SqlConnect( hSql )
								Call SalMessageBox( 'Error connecting in ModifyCashAppilcationRecords.
										Contact Programmers','System Message',MB_Ok )
								Return FALSE
							Call SqlSetParameter( hSql, DBP_PRESERVE, TRUE, ''  )
							If NOT SqlConnect( hSqlTransaction )
								Call SalMessageBox( 'Error connecting (TRANS)  in ModifyCashAppilcationRecords.
										Contact Programmers','System Message',MB_Ok )
								Return FALSE
							If NOT SqlConnect( hSqlUpdate )
								Call SalMessageBox( 'Error connecting (UPDATE)  in ModifyCashAppilcationRecords.
										Contact Programmers','System Message',MB_Ok )
								Return FALSE
							If NOT SqlPrepareAndExecute( hSql, sSqlCashApplicationSelect )
								Call SalMessageBox( 'Error Prep&Exec (SELECT) in ModifyCashAppilcationRecords.
										Contact Programmers','System Message',MB_Ok )
								Return FALSE
							Loop
								! Fetch each Cash_app record
								If NOT SqlFetchNext( hSql, nReturn )
									Break
								Call ModifyTransactionRecord( sTransUser, dtTransDateTime, nAppliedAmount, 
										nMode, nModifyAmount, nAmountChanged, hSqlTransaction )
								! Update the Cash_App record
								If nMode = 0
									Set nNewAppliedAmount = nAppliedAmount - nAmountChanged
								Else
									Set nNewAppliedAmount = nAppliedAmount + nAmountChanged
								If NOT SqlPrepareAndExecute( hSqlUpdate, sSqlCashApplicationUpdate )
									Call SalMessageBox( 'Error Prep&Exec (UPDATE)  in ModifyCashAppilcationRecords.
											Contact Programmers','System Message',MB_Ok )
									Return FALSE
								Call SqlCommit( hSqlUpdate )
								If nModifyAmount = 0
									Break
							Call SqlCommit( hSql )
							Call SqlDisconnect( hSql )
							Call SqlDisconnect( hSqlUpdate )
							Call SqlDisconnect( hSqlTransaction )
							Return TRUE
					Function: ModifyDepositRecords
						Description: Modifies the Deposit Record
								nMode determines whether we are reducing or incresing records
								nMode = 0 We are reducing the amount 
								nMode = 1 We are increasing the amount 
						Returns
							Boolean:
						Parameters
							Number: nModifyAmount
							Number: nMode
							String: sUser
							Date/Time: dtDateTime
						Static Variables
						Local variables
							String: sRowID
							Date/Time: dtPaidDate
							Date/Time: dtNewDateTime
							String: sNewUser
							Number: nAppliedAmount
							Number: nAmountChanged
							Sql Handle: hSql
							Sql Handle: hSqlUpdate
							Number: nReturn
							Number: nNewAppliedAmount
							String: sSqlDepositSelect
							String: sSqlDepositUpdate
							!
							String: sDepUserId
							Date/Time: dtDepSysDT
						Actions
							Set sSqlDepositSelect = '
									SELECT 
									  Dep_User_Id, Dep_Sysdatetime, DEP_AMOUNT_PAID, DEPOSIT_PAID_DATE 
									FROM
									  OUTSTAND_DEPOSIT
									WHERE
									  RECEIPT_USER_ID = :sUser AND
									  RCPT_SYSDATETIME = :dtDateTime
									INTO
									  :sDepUserId, :dtDepSysDT, :nAppliedAmount, :dtPaidDate'
							! Set sSqlDepositUpdate = '
									UPDATE 
									  OUTSTAND_DEPOSIT
									SET
									  DEP_AMOUNT_PAID = :nNewAppliedAmount,
									 DEPOSIT_PAID_DATE = :dtPaidDate  
									WHERE
									  Dep_User_Id = :sDepUserId AND 
									  Dep_Sysdatetime = :dtDepSysDT '
							! If we are deleting a cash receipt which has been used as a deposit then we wish to set the receipt keys
									on the deposit records to NULL also
							Set sSqlDepositUpdate = '
									UPDATE 
									  OUTSTAND_DEPOSIT
									SET
									  DEP_AMOUNT_PAID = :nNewAppliedAmount,
									 DEPOSIT_PAID_DATE = :dtPaidDate,
									 RECEIPT_USER_ID = :sNewUser,
									  RCPT_SYSDATETIME = :dtNewDateTime  
									WHERE
									  Dep_User_Id = :sDepUserId AND 
									  Dep_Sysdatetime = :dtDepSysDT '
							If NOT SqlConnect( hSql )
								Call SalMessageBox( 'Error connecting in ModifyDepositRecords.
										Contact Programmers','System Message',MB_Ok )
								Return FALSE
							Call SqlSetParameter( hSql, DBP_PRESERVE, TRUE, ''  )
							If NOT SqlConnect( hSqlUpdate )
								Call SalMessageBox( 'Error connecting (UPDATE)  in ModifyCashAppilcationRecords.
										Contact Programmers','System Message',MB_Ok )
								Return FALSE
							If NOT SqlPrepareAndExecute( hSql, sSqlDepositSelect )
								Call SalMessageBox( 'Error Prep&Exec (SELECT) in ModifyDepositRecords.
										Contact Programmers','System Message',MB_Ok )
								Return FALSE
							Loop
								! Fetch each Deposit record
								If NOT SqlFetchNext( hSql, nReturn )
									Break
								Set sNewUser = sUser
								Set dtNewDateTime = dtDateTime
								If nMode = 0
									If nAppliedAmount < nModifyAmount
										Set nModifyAmount = nModifyAmount - nAppliedAmount
										Set nAmountChanged = nAppliedAmount
									Else
										Set nAmountChanged = nModifyAmount
										Set nModifyAmount = 0
									Set nNewAppliedAmount = nAppliedAmount - nAmountChanged
									If nNewAppliedAmount = 0
										Set dtPaidDate = DATETIME_Null
										Set nNewAppliedAmount = NUMBER_Null
										Set sNewUser = ''
										Set dtNewDateTime = DATETIME_Null
								Else
									Set nAmountChanged = nModifyAmount
									Set nModifyAmount = 0
									Set nNewAppliedAmount = nAppliedAmount + nAmountChanged
								If NOT SqlPrepareAndExecute( hSqlUpdate, sSqlDepositUpdate )
									Call SalMessageBox( 'Error Prep&Exec (UPDATE)  in ModifyDepositRecords.
											Contact Programmers','System Message',MB_Ok )
									Return FALSE
								Call SqlCommit( hSqlUpdate )
								If nModifyAmount = 0
									Break
							Call SqlCommit( hSql )
							Call SqlDisconnect( hSql )
							Call SqlDisconnect( hSqlUpdate )
							Return TRUE
					! Function: ModifyCashAppilcationRecords
						                           Description: Modifies the Cash Application table then call ModifyTransactionRecord
								nMode determines whether we are reducing or incresing records
								nMode = 0 We are reducing the amount applied
								nMode = 1 We are increasing the amount applied
						                           Returns 
							                           Boolean: 
						                           Parameters 
							                           Number: nModifyAmount
							                           Number: nMode
							                           String: sUser
							                           Date/Time: dtDateTime
						                           Static Variables 
						                           Local variables 
							                           String: sTransUser
							                           String: sRowID
							                           Date/Time: dtTransDateTime
							                           Number: nAppliedAmount
							                           Number: nAmountChanged
							                           Sql Handle: hSql
							                           Sql Handle: hSqlTransaction
							                           Sql Handle: hSqlUpdate
							                           Number: nReturn
							                           Number: nNewAppliedAmount
							                           String: sSqlCashApplicationSelect
							                           String: sSqlCashApplicationUpdate
						                           Actions 
							                           Set sSqlCashApplicationSelect = '
									SELECT 
									  ROWID, TRANS_USER_ID, TRANS_SYSDATETIME,  APPLIED_AMOUNT
									FROM
									  CASH_APPLICATION
									WHERE
									  RECEIPT_USER_ID = :sUser AND
									  RECEIPT_SYSDATETIM = :dtDateTime
									INTO
									  :sRowID, :sTransUser, :dtTransDateTime, :nAppliedAmount'
							                           Set sSqlCashApplicationUpdate = '
									UPDATE 
									  CASH_APPLICATION
									SET
									  APPLIED_AMOUNT = :nNewAppliedAmount
									WHERE
									  ROWID = :sRowID'
							                           If nMode = 0
								! If recuding then order records youngest first
								                           Set sSqlCashApplicationSelect = sSqlCashApplicationSelect || ' 
										ORDER BY
										  APPLIC_SYSDATETIME DESC'
							                           Else 
								! If increasing then order records oldest first
								                           Set sSqlCashApplicationSelect = sSqlCashApplicationSelect || ' 
										ORDER BY
										  APPLIC_SYSDATETIME ASC'
							                           If NOT SqlConnect( hSql )
								                           Call SalMessageBox( 'Error connecting in ModifyCashAppilcationRecords.
										Contact Programmers','System Message',MB_Ok )
								                           Return FALSE
							                           Call SqlSetParameter( hSql, DBP_PRESERVE, TRUE, ''  )
							                           If NOT SqlConnect( hSqlTransaction )
								                           Call SalMessageBox( 'Error connecting (TRANS)  in ModifyCashAppilcationRecords.
										Contact Programmers','System Message',MB_Ok )
								                           Return FALSE
							                           If NOT SqlConnect( hSqlUpdate )
								                           Call SalMessageBox( 'Error connecting (UPDATE)  in ModifyCashAppilcationRecords.
										Contact Programmers','System Message',MB_Ok )
								                           Return FALSE
							                           If NOT SqlPrepareAndExecute( hSql, sSqlCashApplicationSelect )
								                           Call SalMessageBox( 'Error Prep&Exec (SELECT) in ModifyCashAppilcationRecords.
										Contact Programmers','System Message',MB_Ok )
								                           Return FALSE
							                           Loop 
								! Fetch each Cash_app record
								                           If NOT SqlFetchNext( hSql, nReturn )
									                           Break 
								                           Call ModifyTransactionRecord( sTransUser, dtTransDateTime, nAppliedAmount, 
										nMode, nModifyAmount, nAmountChanged, hSqlTransaction )
								                           If nModifyAmount = 0
									                           Break 
							! Update the Cash_App record
							                           If nMode = 0
								                           Set nNewAppliedAmount = nAppliedAmount - nAmountChanged
							                           Else 
								                           Set nNewAppliedAmount = nAppliedAmount + nAmountChanged
							                           If NOT SqlPrepareAndExecute( hSql, sSqlCashApplicationUpdate )
								                           Call SalMessageBox( 'Error Prep&Exec (UPDATE)  in ModifyCashAppilcationRecords.
										Contact Programmers','System Message',MB_Ok )
								                           Return FALSE
							                           Call SqlCommit( hSql )
							                           Call SqlCommit( hSqlUpdate )
							                           Call SqlDisconnect( hSql )
							                           Call SqlDisconnect( hSqlUpdate )
							                           Call SqlDisconnect( hSqlTransaction )
							                           Return TRUE
					Function: ModifyTransactionRecord
						Description: Modify a Transaction table record
						Returns
							Boolean:
						Parameters
							String: sTransUser
							Date/Time: dtTransDateTime
							Number: nAppliedAmount
							Number: nMode
							Receive Number: nModifyAmount
							Receive Number: nAmountChanged
							Sql Handle: hSql
						Static Variables
						Local variables
							String: sSqlTransactionSelect
							String: sSqlTransactionUpdate
							String: sRowID
							Number: nReturn
							Number: nTransAmountOutstanding
							Number: nTransAmountOriginal
							Number: nNewTransAmountOutstanding
							String: sTransType
							String: sTransCode
							Number: nCustNo
							Date/Time: dtTransDate
							Number: nDaysToPay
						Actions
							! Select the Transaction record that matches the Cash_App record
							Set sSqlTransactionSelect = '
									SELECT 
									  TRANSACTION_AMOUNT, 
									  TRANS_AMOUNT_OUTST, 
									  TRANSACTION_TYPE, 
									  TRANSACTION_CODE, 
									  CUST_NO, 
									  TRANSACTION_DATE, 
									  DAYS_TO_PAY   
									FROM
									  TRANSACTION
									WHERE
									  TRANS_USER_ID = :sTransUser AND
									  TRANS_SYSDATETIME = :dtTransDateTime
									INTO
									  :nTransAmountOriginal, :nTransAmountOutstanding, :sTransType, :sTransCode, :nCustNo, :dtTransDate, :nDaysToPay'
							If NOT SqlPrepareAndExecute( hSql, sSqlTransactionSelect )
								Call SalMessageBox( 'Error Prep&Exec in (SELECT) ModifyTransactionRecord.
										Contact Programmers','System Message',MB_Ok )
								Return FALSE
							If NOT SqlFetchNext( hSql, nReturn )
								! Should have been a matching record in Transaction table
								Call SalMessageBox( 'Error Fetching in ModifyTransactionRecord.
										Contact Programmers','System Message',MB_Ok )
								Return FALSE
							! Calculate modification to this record's AmountOutstanding and  update nModifyAmount
							If nMode = 0
								! We are reducing the amount so this increases the outstanding 
										amount (upto the original applied amount for this receipt)
								If nModifyAmount > nAppliedAmount
									! There is more amount to reduce than the total of this invoice so just reduce it to the orginal
									Set nAmountChanged = nAppliedAmount
								Else
									! All the amount can go back on this transaction
									Set nAmountChanged = nModifyAmount
								Set nNewTransAmountOutstanding =  nTransAmountOutstanding + nAmountChanged
							! If nMode = 0 dmf changed this on 6/6/95 
								! We are reducing the amount so this increases the outstanding 
										amount (upto the original amount)
								                           If nModifyAmount > ( nTransAmountOriginal - nTransAmountOutstanding)
									! There is more amount to reduce than the total of this invoice so just reduce it to the orginal
									                           Set nAmountChanged = nTransAmountOriginal - nTransAmountOutstanding
									                           Set nNewTransAmountOutstanding = nTransAmountOriginal
								                           Else 
									! All the amount can go back on this transaction
									                           Set nAmountChanged = nModifyAmount
									                           Set nNewTransAmountOutstanding =  nTransAmountOutstanding + nAmountChanged
							Else
								! We are increasing the amount so this reduces the outstanding amount (down to zero)
								If nModifyAmount > nTransAmountOutstanding
									! There is more amount to increase than the total outstanding of this 
											invoice so just reduce it to zero
									Set nAmountChanged =  nTransAmountOutstanding
									Set nNewTransAmountOutstanding = 0
								Else
									! All the amount can go on reducing this transaction
									Set nAmountChanged = nModifyAmount
									Set nNewTransAmountOutstanding =  nTransAmountOutstanding - nAmountChanged
							! Update the Modify amount for the next transaction
							Set nModifyAmount = nModifyAmount - nAmountChanged
							!
							If sTransType = 'INVOICE' AND sTransCode = 'DR' AND nTransAmountOriginal = nNewTransAmountOutstanding
								Set nDaysToPay = NUMBER_Null
							Else
								Call CheckForFinishedTrans( nCustNo, sTransType, sTransCode, 0, 0, dtTransDate, nDaysToPay, nExecute )
							!
							! Update Transaction record with the new amount
							Set sSqlTransactionUpdate = '
									UPDATE 
									  TRANSACTION
									SET
									  TRANS_AMOUNT_OUTST = :nNewTransAmountOutstanding, 
									  DAYS_TO_PAY = :nDaysToPay 
									WHERE
									  TRANS_USER_ID = :sTransUser AND
									  TRANS_SYSDATETIME = :dtTransDateTime'
							If NOT SqlPrepareAndExecute( hSql, sSqlTransactionUpdate )
								Call SalMessageBox( 'Error Prep&Exec (UPDATE)  in ModifyTransactionRecord.
										Contact Programmers','System Message',MB_Ok )
								Return FALSE
							Call SqlCommit( hSql )
							Return TRUE
				Window Variables
					String: sSqlMaintCRSelect
					String: sSqlMaintCRName
					String: sSqlMaintCRBind
					String: sSqlMaintCRInto
					: hSqlMaintCRSelect
						Class: hcSqlHandle
					Boolean: bSunConnected
					Boolean: bSundryPopulated
					Sql Handle: hSqlCmbSundryHdl
					String: sFullyApplied
					Number: nTmp
				Message Actions
					On PAM_SETSGSQL
						Set sSqlMaintCRSelect = 'SELECT 
								  Customer_Master.Cust_No, Customer_Master.Cust_Name, Cheque_Drawer, Cheque_Bank, 
								  Cheque_Branch, Receipt_Amount, 
								Cash_Receipt.Company, Receipt_Amount, 
								   Sundry_Catagory, Cheque_No, 
								  Receipt_Comments, Fully_Applied_Flag, Amount_Unapplied,
								  Customer_Master.Cust_No, Cash_Receipt.ROWID,
								  Cash_Receipt.Receipt_User_Id, Cash_Receipt.Rcpt_Sysdatetime, Cash_Receipt.Receipt_Date 
								FROM  
								  Cash_Receipt, Customer_Master  
								WHERE 
								  Cash_Receipt.Cust_No = Customer_Master.Cust_No(+) AND
								  Receipt_Date= :1
								ORDER BY 
								  CUSTOMER_MASTER.CUST_NAME'
						! Set sSqlMaintCRSelect = 'SELECT 
								  Customer_Master.Cust_No, Customer_Master.Cust_Name, Cheque_Drawer, Cheque_Bank, 
								  Cheque_Branch, Receipt_Amount, Receipt_Amount, 
								   Sundry_Catagory, Receipt_Comments, Fully_Applied_Flag, Amount_Unapplied,
								  Customer_Master.Cust_No, Cash_Receipt.ROWID,
								  Cash_Receipt.Receipt_User_Id, Cash_Receipt.Rcpt_Sysdatetime
								FROM  
								  Cash_Receipt, Customer_Master  
								WHERE 
								  Cash_Receipt.Cust_No = Customer_Master.Cust_No(+) AND
								  Receipt_Date= :1
								ORDER BY 
								  RECEIPT_DATE, RECEIPT_TYPE, CHEQUE_BANK'
						Set sSqlMaintCRBind = ':frmReceiptMaintenance.dfMaintCRDate'
						Set sSqlMaintCRInto = ':frmReceiptMaintenance.tblMaintCashReceipts.colCustNo, 
								:frmReceiptMaintenance.tblMaintCashReceipts.colCustName, 
								:frmReceiptMaintenance.tblMaintCashReceipts.colChequeDrawer, 
								:frmReceiptMaintenance.tblMaintCashReceipts.colChequBank, 
								:frmReceiptMaintenance.tblMaintCashReceipts.colChequeBranch,
								:frmReceiptMaintenance.tblMaintCashReceipts.colReceiptAmount,  
								:frmReceiptMaintenance.tblMaintCashReceipts.colCompany,  
								:frmReceiptMaintenance.tblMaintCashReceipts.colReceiptAmountOriginal, 
								:frmReceiptMaintenance.tblMaintCashReceipts.colSundryCat, 
								:frmReceiptMaintenance.tblMaintCashReceipts.colChqNo, 
								:frmReceiptMaintenance.tblMaintCashReceipts.colReceiptComments,
								:frmReceiptMaintenance.tblMaintCashReceipts.colFullyAppied, 
								:frmReceiptMaintenance.tblMaintCashReceipts.colAmountUnapplied, 
								:frmReceiptMaintenance.tblMaintCashReceipts.colCustomerNo, 
								:frmReceiptMaintenance.tblMaintCashReceipts.colRowID,
								:frmReceiptMaintenance.tblMaintCashReceipts.colUserID, 
								:frmReceiptMaintenance.tblMaintCashReceipts.colSysDateTime, 
								:frmReceiptMaintenance.tblMaintCashReceipts.colReceiptDate'
						Call hSqlMaintCRSelect.Setup(sSqlMaintCRSelect, 'MAINTCRC2',
								sSqlMaintCRBind, sSqlMaintCRInto)
						Call SqlVarSetup( hSqlMaintCRSelect.hSqlHandle)
					On PAM_POPULATE
						Call SalWaitCursor( TRUE )
						Call hSqlMaintCRSelect.Execute()
						Call hSqlMaintCRSelect.TablePopulate( hWndForm,TBL_FillAll)
						! Call hSqlMaintCRSelect.TablePopulate( hWndForm,TBL_FillNormal)
						Call SalWaitCursor( FALSE )
					On SAM_Create
						Call SalSendMsg( hWndForm, PAM_SETSGSQL, 0, 0 )
						Call hSqlMaintCRSelect.Connect()
					On SAM_Close
						Call hSqlMaintCRSelect.Disconnect()
					On PAM_DELETEROWS
						Call TableDeleteRows( hWndForm )
					On SAM_Destroy
						Call NewAdjustCustARBalance( 0, 0, nIncrement, nDisconnect )
						Call NewAdjustCustARBalance( 0, 0, nDecrement, nDisconnect )
						Call UpdtCustDaysOfCredAvg( 0, nDisconnect )
						Call CheckForFinishedTrans( 0, '', '', 0, 0, DATETIME_Null, nTmp, nDisconnect )

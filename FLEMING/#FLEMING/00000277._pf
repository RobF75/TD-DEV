			Boolean: bHaveAppliedRow
			Boolean: bHaveUnAppliedRow
			Number: nTransRowsApplied
			Number: nDepositRowsApplied
			Number: nOrgTransRowsApplied
			Number: nOrgDepositRowsApplied
			!
			Number: nTransAmount
			Number: nTransCode
			Boolean: bDataValError
			!
			! DEPOSIT LISTING REPORT VARIABLES
			Date/Time: dtDepositListToDate
			Date/Time: dtDepositListFromDate
			Boolean: bPrintDepListing
			Boolean: bPrintReconListing
			String: sReportFile
			String: sRepInto
			String: sRepBind
			String: sSQLREPTABLENAME
			String: sSQLTRANSTABLENAME
			String: sSQLTRANSHISTTABLENAME
			String: sSQLREPWHERE
			String: sSQLTRANSHISTWHERE
			String: sSQLTRANSWHERE
			Number: nError
			Number: nInd
			Number: nYear
			String: sDepositFromDate
			String: sDepositToDate
			!
			String: sUsedAsDeposit
			!
			String: sSqlCashRcpts
			Sql Handle: hSqlCashRcptsHdl
			Boolean: bCashRcptsHdlConnected
			Boolean: bCashRcptsHdlPrepared
			Sql Handle: hSqlTransHdl
			Boolean: bTransHdlConnected

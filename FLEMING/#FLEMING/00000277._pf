			Function: WriteCashAppRecord
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					String: sSQLTABLENAME
				Static Variables
				Local variables
					String: sSql
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						! Set sSql = ' INSERT INTO ' || sSQLTABLENAME || ' ( Applic_User_Id, 
								Applic_Sysdatetime, Trans_User_Id, Trans_Sysdatetime, Receipt_User_Id, 
								Receipt_Sysdatetim, Date_Applied, 
								Applied_Amount, Applied_By, Cust_No ) 
								VALUES ( USER, SYSDATETIME, :frmReceipt.dfTransUserId, :frmReceipt.dfTransSysDT,
								:frmReceipt.dfRcptUser, :frmReceipt.dfRcptDtTime, :frmReceipt.tblTransaction.colAppDate,
								:frmReceipt.tblTransaction.colAmtApply, USER, :frmReceipt.dfCustNo ) '
						Set sSql = ' INSERT INTO ' || sSQLTABLENAME || ' ( Applic_User_Id, 
								Applic_Sysdatetime, Trans_User_Id, Trans_Sysdatetime, Receipt_User_Id, 
								Receipt_Sysdatetim, Date_Applied, 
								Applied_Amount, Applied_By, Cust_No ) 
								VALUES ( USER, SYSDATETIME, :frmReceipt.dfTransUserId, :frmReceipt.dfTransSysDT,
								:frmReceipt.dfRcptUser, :frmReceipt.dfRcptDtTime, :frmReceipt.tblTransaction.colAppDate,
								:frmReceipt.tblTransaction.colAmtApply, USER, :frmReceipt.tblTransaction.colCustNo ) '
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					! If frmReceipt.tblTransaction.colAmtOuts = 0 OR frmReceipt.tblTransaction.colWriteOff = 'Y'
						                           Set frmReceipt.dfTransUserId = ''
						                           Set frmReceipt.dfTransSysDT = DATETIME_Null
						! Set frmReceipt.dfTransHistUserId = frmReceipt.tblTransaction.colTransUserId
						! Set frmReceipt.dfTransHistSysDT = frmReceipt.tblTransaction.colTransSysDT
					! Else 
						                           Set frmReceipt.dfTransUserId = frmReceipt.tblTransaction.colTransUserId
						                           Set frmReceipt.dfTransSysDT = frmReceipt.tblTransaction.colTransSysDT
						! Set frmReceipt.dfTransHistUserId = ''
						! Set frmReceipt.dfTransHistSysDT = DATETIME_Null
					Set frmReceipt.dfTransUserId = frmReceipt.tblTransaction.colTransUserId
					Set frmReceipt.dfTransSysDT = frmReceipt.tblTransaction.colTransSysDT
					If SqlExecute( hSqlHandle )
						Return TRUE
					Else
						Set bHandlePrepared = FALSE
						Return FALSE
			Function: WriteCashAppRecordForCreditDebit
				Description: Write a Cash App record linking a Credit Trans and a Debit Trans TS 31/05/95
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					: MatchRecord
						Class: fcCreditDebitMatchRecord
				Static Variables
				Local variables
					String: sSql
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Set sSql = ' 
								INSERT INTO 
								     CASH_APPLICATION 
								     ( Applic_User_Id, Applic_Sysdatetime, Trans_User_Id, Trans_Sysdatetime, 
								       Trans_User_Id_Cred, Trans_Sysdate_Cred, Date_Applied, 
								       Applied_Amount, Applied_By, Cust_No ) 
								VALUES 
								     ( USER, SYSDATETIME, :frmReceipt.tblTransaction.colTransUserId, 
								       :frmReceipt.tblTransaction.colTransSysDT, :MatchRecord.sTransUserID, 
								       :MatchRecord.dtTransSysDT, :frmReceipt.tblTransaction.colAppDate, 
								       :MatchRecord.nAmountApplied, USER, :MatchRecord.nCustNo ) '
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
							Return FALSE
					If SqlExecute( hSqlHandle )
						Return TRUE
					Else
						Set bHandlePrepared = FALSE
						Return FALSE

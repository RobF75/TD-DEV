		Message Actions
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
			On SAM_Close
				If SalTblAnyRows( tblMaintCashReceipts, ROW_Edited | ROW_MarkDeleted, 0 )
					If IDYES = SalMessageBox( 'Information has changed. Do you want
							chages saved before exiting ?','System Message', MB_YesNo  )
						Call SalSendMsg( pbSaveMaintCR, SAM_Click, 0, 0 )
				Call SalDestroyWindow( hWndForm )
			On SAM_CreateComplete
				Call SalSendMsg( pbShowRecords, SAM_Click, 0, 0 )
				Call SalDisableWindow( SalParentWindow( hWndForm ) )
			On SAM_Destroy
				Call SalEnableWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )

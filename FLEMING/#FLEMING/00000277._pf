							On PAM_SETNEWDEPOSITVALUES
								Set colCompany = frmReceipt.dfRecpCompany
							On SAM_Click
								If MyValue = 'Z'
									Set frmReceipt.dfCompany = 'ZEE SWEET'
								Else
									Set frmReceipt.dfCompany = 'FLEMINGS'

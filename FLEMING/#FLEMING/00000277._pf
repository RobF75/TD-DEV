					Input Mask: Unformatted
				Message Actions
					On PAM_SQL
						Call BuildSQL( wParam,hWndItem,'CASH_RECEIPT.CHEQUE_BRANCH' )
					On PAM_INSERTCASHRCPT
						Call SalStrUpper( dfBranch, dfBranch )
						Call SalSetFieldEdit( hWndItem, TRUE )
						Call BuildSQL( wParam, hWndItem, 'CHEQUE_BRANCH' )
					! On SAM_SetFocus
						                           Set nFocusIn = nFocusBranch
					On PAM_RESET
						Call SalClearField( hWndItem )
					On PAM_DATAVAL
						If NOT bDataValError
							If cmbRcptType = 'CASH'
								If NOT SalIsNull( hWndItem )
									Set bDataValError = TRUE
									Call SalWaitCursor( FALSE )
									Call SalMessageBox( 'A CASH receipt type is chosen!  
											Cannot have any details in the Branch field! 
											Please rectify! ', 'Error', MB_Ok )
									Call SalWaitCursor( TRUE )
									Call SalSetFocus( hWndItem )
							! Else If cmbRcptType = 'MONEYORD'
								                           If NOT SalIsNull( hWndItem )
									                           Set bDataValError = TRUE
									                           Call SalWaitCursor( FALSE )
									                           Call SalMessageBox( 'A MONEY ORDER receipt type is chosen!  
											Cannot have any details in the Branch field! 
											Please rectify! ', 'Error', MB_Ok )
									                           Call SalWaitCursor( TRUE )
									                           Call SalSetFocus( hWndItem )
							Else
								If SalIsNull( hWndItem )
									Call SalWaitCursor( FALSE )
									If IDNO = SalMessageBox( 'A CHEQUE or MONEYORD receipt type is chosen!  
											Would you like to leave the Branch field empty! ', 'Warning', MB_YesNo | MB_DefButton2 )
										Set bDataValError = TRUE
										Call SalSetFocus( hWndItem )
									Call SalWaitCursor( TRUE )

			Data Field: dfCustNo
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Data
					Maximum Data Length: Default
					Data Type: Number
					Editable? Yes
				Display Settings
					Window Location and Size
						Left:   0.85"
						Top:    1.333"
						Width:  0.925"
						Width Editable? Yes
						Height: 0.25"
						Height Editable? Yes
					Visible? Yes
					Border? Yes
					Justify: Left
					Format: Unformatted
					Country: Default
					Font Name: Default
					Font Size: Default
					Font Enhancement: Default
					Text Color: Default
					Background Color: Default
					Input Mask: Unformatted
				Message Actions
					On PAM_SQL
						Call BuildSQL( wParam, hWndItem, 'CASH_RECEIPT.CUST_NO' )
					On PAM_INSERTCASHRCPT
						Call SalSetFieldEdit( hWndItem, TRUE )
						Call BuildSQL( wParam, hWndItem, 'CUST_NO' )
					On PAM_QBECUST
						If NOT SalIsNull( hWndItem )
							Call PushNumber( dfCustNo )
							Call PushString( EQOPERAND )
							Call PushString( NUMERICFOLLOWING )
							Call PushString( 'CUST_NO' )
							Return TRUE
					On PAM_LOOKUPCUST
						Call PopNumber( dfCustNo, TRUE )
						If cmbRcptType = 'CHEQUE'
							Call GetCustLastChequeDetails( dfCustNo, dfDrawer, cmbBank, dfBranch, nExecute )
						!
					! On SAM_SetFocus
						                           Set nFocusIn = nFocusCustNo
					On SAM_Validate
						If NOT SalIsNull( hWndItem )
							If GetCustomerDetails( dfCustNo, sCustName, sBusName, bCustExists, nExecute )
								If bCustExists
									Call PushString( sBusName )
									Call PushString( sCustName )
									Call PushNumber( dfCustNo )
									Call SalSendMsgToChildren( hWndForm, PAM_LOOKUPCUST, 0, 0 )
									!
									!
									!
									Return TRUE
								Else
									Call SalClearField( hWndItem )
									Call SalMessageBox( 'Customer No. does not exists! Please use the Query button.', 'Warning', MB_Ok )
						Return VALIDATE_Ok
					On PAM_FIELDPROTECT
						If wParam
							Call SalDisableWindow( hWndItem )
							Call SalColorSet( hWndItem, COLOR_IndexWindow, COLOR_LightGray )
						Else
							Call SalEnableWindow( hWndItem )
							Call SalColorSet( hWndItem, COLOR_IndexWindow, COLOR_Default )
					On PAM_RESET
						Call SalClearField( hWndItem )
						! Call SalSetFocus( hWndItem )
					On PAM_DATAVAL
						If NOT bDataValError
							If cmbSundryCat = ''
								If NOT dfCustNo > 0
									Set bDataValError = TRUE
									Call SalWaitCursor( FALSE )
									Call SalMessageBox( 'A Customer No. must be entered first! 
											Please rectify! ', 'Error', MB_Ok )
									Call SalWaitCursor( TRUE )
									Call SalSetFocus( hWndItem )
			Data Field: dfCustName
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:

.head 6 -  Set hWndActivateButton = hWndNULL
.head 6 -  Call SalSendClassMessage( SAM_Create, wParam, lParam )
.head 6 +  If NOT bAddAllowed
.head 7 -  Call SalSendMsg( pbAddRows, PAM_clsPB_HIDE, 0, 0 )
.head 6 +  If NOT bSaveAllowed
.head 7 -  Call SalSendMsg( pbSaveRows, PAM_clsPB_HIDE, 0, 0 )
.head 6 +  If NOT bDeleteAllowed
.head 7 -  Call SalSendMsg( pbDeleteRows, PAM_clsPB_HIDE, 0, 0 )
.head 6 +  If NOT bClearSelectAllowed
.head 7 -  Call SalSendMsg( pbClearRows, PAM_clsPB_HIDE, 0, 0 )
.head 6 +  If NOT bQueryAllowed
.head 7 -  Call SalSendMsg( pbQuery, PAM_clsPB_HIDE, 0, 0 )
.head 6 +  If NOT bRepopulateAllowed
.head 7 -  Call SalSendMsg( pbRePopulate, PAM_clsPB_HIDE, 0, 0 )
.head 5 +  On SAM_CreateComplete
.head 6 -  ! Set pbClearRows.hWndChildTable = hWndChildTable
.head 6 -  ! Set pbAddRows.hWndChildTable = hWndChildTable
.head 6 -  ! Set pbSaveRows.hWndChildTable = hWndChildTable
.head 6 -  ! Set pbQuery.hWndChildTable = hWndChildTable
.head 6 -  ! Set pbDeleteRows.hWndChildTable = hWndChildTable
.head 6 -  ! Set pbUnDeleteRows.hWndChildTable = hWndChildTable
.head 6 -  ! Set pbRePopulate.hWndChildTable = hWndChildTable
.head 6 -  ! Set pbTableReport.hWndChildTable = hWndChildTable
.head 6 -  ! Set pbOrderTable.hWndChildTable = hWndChildTable
.head 6 +  If nPopOrQueryOnStartUp = TBL_cls_PopulateOnStartUp
.head 7 -  Call SalSendMsg( hWndChildTable, PAM_clsTBL_POPULATE, 0, 0 )
.head 6 +  Else If nPopOrQueryOnStartUp = TBL_cls_QueryOnStartUp
.head 7 -  Call SalSendMsg( hWndChildTable, PAM_clsTBL_QUERY, 0, 0 )
.head 6 -  Call SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 6 -  Call SalSetFocus( hWndChildTable )
.head 6 -  ! Call OurWaitCursor( FALSE )
.head 5 +  On WM_RBUTTONUP
.head 6 -  Set hMenu = CreatePopupMenu(  )
.head 6 +  If bClearSelectAllowed
.head 7 -  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_ClearMenuId, 'Clear' )
.head 6 +  If bAddAllowed
.head 7 -  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_AddMenuId, 'Add' )
.head 6 +  If bSaveAllowed
.head 7 -  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_SaveMenuId, 'Save' )
.head 6 +  If bDeleteAllowed
.head 7 -  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_DeleteMenuId, 'Delete' )
.head 6 +  If bUnDeleteAllowed
.head 7 -  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_UnDeleteMenuId, 'UnDelete' )
.head 6 +  If bRepopulateAllowed
.head 7 -  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_RepopMenuId, 'Repop Table' )
.head 6 +  If bQueryAllowed
.head 7 -  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_QueryMenuId, 'Query' )
.head 6 +  If bOrderAllowed
.head 7 -  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_OrderMenuId, 'Sort Table' )
.head 6 +  If bReportAllowed
.head 7 -  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_ReportMenuId, 'Table Report' )
.head 6 +  If bMoveRowUpOneAllowed
.head 7 -  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_UpMenuId, 'Move Row Up One' )
.head 6 +  If bMoveRowDownOneAllowed
.head 7 -  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_DownMenuId, 'Move Row Down One' )
.head 6 +  If bZoomTableAllowed
.head 7 -  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_ZoomMenuId, 'Zoom Table' )
.head 6 -  ! wParam is normally 0, unless the wm_rbuttonup key is trapped in clsTableGeneral then we are setting
it to TRUE
.head 6 -  Set nX= SalNumberLow( lParam )
.head 6 -  Set nY=SalNumberHigh( lParam )
.head 6 -  Set hWndFocus = SalNumberToWindowHandle( wParam )
.head 6 -  ! Then the user pressed the wm_rbuttonup key in a table and we want to get its cursor pos
.head 6 +  If SalGetType( hWndFocus ) = TYPE_ChildTable
.head 7 -  Call MapWindowPoints( hWndFocus, hWndForm, nX, nY, 1 )
.head 6 -  Call ClientToScreen(hWndForm,nX,nY)
.head 6 -  Call TrackPopupMenu( hMenu, 0x0002, nX, nY, 0, hWndForm, '' )
.head 5 +  On WM_COMMAND
.head 6 -  Set nMenu = SalNumberHigh( wParam )
.head 6 +  If nMenu = 0
.head 7 +  If lParam = TPM_LeftButton
.head 8 -  Set nSelectedMenu = SalNumberLow( wParam )
.head 8 +  If nSelectedMenu = TBL_cls_ClearMenuId
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_ClearRow, GEN_CommingFromPopUp )
.head 8 +  Else If nSelectedMenu = TBL_cls_AddMenuId
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_AddRow, GEN_CommingFromPopUp )
.head 8 +  Else If nSelectedMenu = TBL_cls_SaveMenuId
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_SaveRow, GEN_CommingFromPopUp )
.head 8 +  Else If nSelectedMenu = TBL_cls_DeleteMenuId
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_DeleteRow, GEN_CommingFromPopUp )
.head 8 +  Else If nSelectedMenu = TBL_cls_UnDeleteMenuId
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_UnDeleteRow, GEN_CommingFromPopUp )
.head 8 +  Else If nSelectedMenu = TBL_cls_RepopMenuId
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_RePopTable, GEN_CommingFromPopUp )
.head 8 +  Else If nSelectedMenu = TBL_cls_QueryMenuId
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_Query, GEN_CommingFromPopUp )
.head 8 +  Else If nSelectedMenu = TBL_cls_OrderMenuId
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_OrderTable, GEN_CommingFromPopUp )
.head 8 +  Else If nSelectedMenu = TBL_cls_ReportMenuId
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_TableReport, GEN_CommingFromPopUp )
.head 8 +  Else If nSelectedMenu = TBL_cls_UpMenuId
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_MoveUpOne, GEN_CommingFromPopUp )
.head 8 +  Else If nSelectedMenu = TBL_cls_DownMenuId
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_MoveDownOne, GEN_CommingFromPopUp )
.head 8 +  Else If nSelectedMenu = TBL_cls_ZoomMenuId
.head 9 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_ZoomTable, GEN_CommingFromPopUp )
.head 5 +  On PAM_cls_EXIT
.head 6 +  If SalSendMsg( hWndChildTable, PAM_clsTBL_CHECKCHANGES, 0, 0 )
.head 7 +  If SalSendMsg( hWndChildTable, PAM_clsTBL_ISTABLECHANGED, 0, 0 )
.head 8 -  Call SalGetItemName( hWndActivateButton, sTmp )
.head 8 -  Call SalPostMsg( SalParentWindow( hWndForm ), PAM_cls_CHILDCHANGED, 0, SalHStringToNumber( sTmp ) )
.head 7 -  Return SalSendClassMessage( PAM_cls_EXIT, wParam, lParam )
.head 6 +  Else

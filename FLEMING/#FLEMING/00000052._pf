.head 6 +  If bOrderAllowed
.head 7 -  Set nChoice = nChoice | TBL_cls_OrderTable
.head 6 +  If bMoveRowDownOneAllowed
.head 7 -  Set nChoice = nChoice | TBL_cls_MoveDownOne
.head 6 +  If bMoveRowUpOneAllowed
.head 7 -  Set nChoice = nChoice | TBL_cls_MoveUpOne
.head 6 +  If bZoomTableAllowed
.head 7 -  Set nChoice = nChoice | TBL_cls_ZoomTable
.head 6 -  Set nChoice2 = SalSendMsg( hWndChildTable, PAM_clsTBL_ALLOWEDACTIONS, wParam, lParam )
.head 6 +  If nChoice2 > 0
.head 7 -  Set nChoice = nChoice | nChoice2
.head 6 -  Return nChoice

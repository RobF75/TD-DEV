.head 6 -  Call SalShowWindow( hWndForm )
.head 6 -  Call SalBringWindowToTop( hWndForm )
.head 6 +  If SalSendMsg( hWndForm, PAM_cls_REFRESHAFTRCHILDCHANGE, wParam, lParam )
.head 7 -  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_RePopTable, TBL_cls_ChildChanged )
.head 6 -  Return TRUE
.head 5 +  On PAM_clsTBL_USERACTIONS
.head 6 -  Return UserTableActions( hWndChildTable, wParam, lParam )
.head 5 +  On PAM_clsTBL_ALLOWEDACTIONS
.head 6 -  Set nChoice = 0
.head 6 +  If bAddAllowed
.head 7 -  Set nChoice = nChoice | TBL_cls_AddRow
.head 6 +  If bSaveAllowed
.head 7 -  Set nChoice = nChoice | TBL_cls_SaveRow
.head 6 +  If bDeleteAllowed
.head 7 -  Set nChoice = nChoice | TBL_cls_DeleteRow
.head 6 +  If bUnDeleteAllowed

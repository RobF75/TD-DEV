.head 10 -  Set sSQLPopHandle = " SELECT 
  Customer_Master.Cust_No, 
  Cust_Name, 
  Order_Date_Time, 
  Ord_Date, 
  Ordered_Amount, 
  Conf_Amt, 
  Subs_Ok_Flag, 
  Pull_Sheet_Issued, 
  Invoiced_Flag, 
  Invoiced_Date, 
  Sale_Cat, 
  @IF( @ISNA( Batch_Location_Id ), 'N', 'Y' ), 
  Batch_Location_Id, 
  Batch_Year_Of_Sale 
FROM 
  Cust_Order_History, 
  Customer_Master  
WHERE 
  Cust_Order_History.Cust_No = Customer_Master.Cust_No AND 
  Stock_Item_No = :1 AND 
  Year_Of_Sale = :2 AND 
  ( NOT Invoiced_Flag = 'Y' OR Invoiced_Flag IS NULL ) 
ORDER BY Ord_Date, Order_Date_Time "

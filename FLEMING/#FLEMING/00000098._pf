		  Description: 
		  Named Menus 
		  Menu 
		  Tool Bar 
			  Contents 
		  Contents 
		  Functions 
		  Window Parameters 
			  String: sLabelFile
		  Window Variables 
			  File Handle: hOutFile
			  String: sInputLine
			  Number: nLength
			  Number: nFileSize
			  Number: nTotalBytesRead
			  Number: nBytesRead
		  Message Actions 
			  On PAM_cls_SETINSTANCEVARS
				  Set sReportFileNameNoPath = 'barcode.qrp'
				  Set sReportBind = ':frmPrintBarcodeLabels.sInputLine'
				  Set sReportInto = 'sInputLine'
			  On SAM_ReportStart
				  Return SalFileOpen( hOutFile, sLabelFile, OF_Read | OF_Binary )
			  On SAM_ReportFetchInit
				  Call SalFileSeek( hOutFile, 0, FILE_SeekEnd )
				  Set nFileSize = SalFileTell( hOutFile )
				  Call SalFileSeek( hOutFile, 0, FILE_SeekBegin )
				!
				  Set nLength = 100
				  Set nTotalBytesRead = 0
				  Return TRUE
			  On SAM_ReportFetchNext
				  If nTotalBytesRead < nFileSize
					  Set nBytesRead = SalFileRead( hOutFile, sInputLine, nLength )
					  Set nTotalBytesRead = nTotalBytesRead + nBytesRead
					  Return TRUE
				  Else 
					  Return FALSE
			  On SAM_ReportFinish
				  Call SalFileClose( hOutFile )
				  Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )

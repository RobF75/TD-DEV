	! Our Dialog Box: dlgPrintLabelsDetails
		  Description: 
		  Tool Bar 
			  Contents 
		  Contents 
			  Background Text: Season
			  Custom Control: cSeasonYear
				  Message Actions 
					  On PAM_SETINSTANCEVARS
						  Set cSeasonYear.bEditable = TRUE
			  Radio Button: rbFieldCount
				  Message Actions 
			  Radio Button: rbBarCode
				  Message Actions 
			  Radio Button: rbHeelGround
				  Message Actions 
					  On SAM_Create
						  Set rbHeelGround = TRUE
			  Pushbutton: pbOk
				  Message Actions 
					  On PAM_CLICK
						  If rbFieldCount
							  Set sLabelUse = 'FC'
						  Else If rbBarCode
							  Set sLabelUse = 'BC'
						  Else 
							  Set sLabelUse = 'HG'
						!
						  Set bOk = TRUE
						  Set nPos = 0
						  Set naItemNos[ nPos ] = NUMBER_Null
						  Set naQuantities[ nPos ] = NUMBER_Null
						  Call MyTableLoop( tblSelectedItems, hWndItem, PAM_ROWACTION, 0, 0, 'Collecting Quantites', nLowToHi )
						!
						  If bOk 
							  Call PrintStockItemsLabels( nCustNo, sCustName, naItemNos, naQuantities, sLabelUse, sTMPFILE, nExecute )
						  Else 
							  Call SalMessageBox( 'Please make sure that all quantites are greater than zero first!', 'Warning', MB_Ok )
					  On PAM_ROWACTION
						  If tblSelectedItems.colQuantity <= 0
							  Set bOk = FALSE
						  Set naItemNos[ nPos ] = tblSelectedItems.colItemNo
						  Set naQuantities[ nPos ] = tblSelectedItems.colQuantity
						  Set nPos = nPos + 1
						  Set naItemNos[ nPos ] = NUMBER_Null
						  Set naQuantities[ nPos ] = NUMBER_Null
						  Return TRUE
			  Child Table: tblSelectedItems
				  Contents 
					  Column: colItemNo
						  List Values 
						  Message Actions 
					  Column: colTreeType
						  List Values 
						  Message Actions 
					  Column: colCultDesc
						  List Values 
						  Message Actions 
					  Column: colRootDesc
						  List Values 
						  Message Actions 
					  Column: colQuantity
						  List Values 
						  Message Actions 
				  Functions 
				  Window Variables 
					  Number: nTotalRows
				  Message Actions 
					  On PAM_SETTABLELOOPTOTALROWS
						  Call PushNumber( nTotalRows )
						  Return TRUE
		  Functions 
		  Window Parameters 
			  Number: nCustNo
			  String: sCustName
			! NULL TERMINATED LIST OF item numbers
			  Number: naItemNos[*]
			! NULL TERMINATED LIST OF item numbers
			  Number: naQuantities[*]
			  Boolean: bEditQuantitiesAllowed
		  Window Variables 
			  Number: nPos
			  Number: nRow
			  String: sTmp
			  String: sLabelId
			  String: sLabelUse
			  Boolean: bSelectedQuantities
		  Message Actions 
			  On PAM_SETINSTANCEVARS
				  Set sDatabase = SqlDatabase
			  On SAM_CreateComplete
				  If naQuantities[ 0 ] = NUMBER_Null
					  Set bSelectedQuantities = FALSE
				  Else 
					  Set bSelectedQuantities = TRUE
				!
				  Set nPos = 0
				  Set tblSelectedItems.nTotalRows = 0
				  While naItemNos[ nPos ] != NUMBER_Null
					!
					  Set nRow = SalTblInsertRow( tblSelectedItems, TBL_MaxRow )
					  Call SalTblSetContext( tblSelectedItems, nRow )
					  Call SalTblSetRowFlags( tblSelectedItems, nRow, ROW_HideMarks, TRUE )
					  Set tblSelectedItems.nTotalRows = tblSelectedItems.nTotalRows + 1
					  Set tblSelectedItems.colItemNo = naItemNos[ nPos ]
					  Call GetItemFullBasicDetails( naItemNos[ nPos ], tblSelectedItems.colTreeType, sTmp, tblSelectedItems.colCultDesc, sTmp, tblSelectedItems.colRootDesc, nExecute )
					  If bSelectedQuantities
						  Set tblSelectedItems.colQuantity = naQuantities[ nPos ]
					!
					  Set nPos = nPos + 1
				!
				  If NOT bEditQuantitiesAllowed AND bSelectedQuantities
					  Call SalTblSetColumnFlags( tblSelectedItems.colQuantity, COL_Editable, FALSE )
				  Call SalWaitCursor( FALSE )
			  On SAM_Destroy
				  Call PrintStockItemsLabels( nCustNo, sCustName, naItemNos, naQuantities, '', '', nDisconnect )
				  Call GetItemFullBasicDetails(0, tblSelectedItems.colTreeType, sTmp, tblSelectedItems.colCultDesc, sTmp, tblSelectedItems.colRootDesc, nDisconnect )

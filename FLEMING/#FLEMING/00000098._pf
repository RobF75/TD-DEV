		Named Menus
		Internal Functions
			Function: PrintLabels
				Description: Given a stock item no, label Id and how many labels this prints labels to the bar code printer
						on the com port
						hWndTable is the handle that will receive the PAM_clsLABELS_GETFIELDDATA message with the
						wParam as nItemNo and lParam as HString ( use SalNumberToHString to extract the string )
						  To Return a value alway Call PushString( ... ) If number comvert to string and MUST 
						  RETURN TRUE
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					String: sLabelId
					Number: nHowMany
					Number: nLocId
					Window Handle: hWndTable
					Number: nActionType
				Static Variables
				Local variables
					String: sTmpFileName
				Actions
					Select Case nActionType
						Case SH_cls_Execute
							! Set sTmpFileName = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'C:\\TEMP' ) || '\\label.tmp'
							Set sTmpFileName = GetNextBCQueueFileName(  )
							Call GenerateLabelFile( 0, '', nItemNo, sLabelId, nHowMany, nLocId, hWndTable, sTmpFileName, 'CREATE/OVERWRITE', SH_cls_Execute )
							! Call OutputLabelFile( sTmpFileName )
							Return TRUE
						Case SH_cls_Disconnect
							Return GenerateLabelFile( 0, '', 0, '', 0, 0, hWndNULL, '', '', SH_cls_Disconnect )
			Function: GetNextBCQueueFileName
				Description:
				Returns
					String:
				Parameters
				Static Variables
				Local variables
					Number: nNumQueueFiles
					String: sQueuePath
					String: saQueuelFiles[*]
					Number: naQueueSizes[*]
					Date/Time: dtaQueueTimeStamps[*]
					Number: naQueueAttributes[*]
				Actions
					Set sQueuePath = OurGetIniFileParameter( 'GENERAL', 'BCLabelsPath', 'C:\\TEMP' )
					Set nNumQueueFiles = VisDosEnumFileInfo( sQueuePath || '\\*.bcl', FA_Standard, saQueuelFiles, naQueueSizes, dtaQueueTimeStamps, naQueueAttributes )
					If nNumQueueFiles < 0
						Set nNumQueueFiles = 0
					Return sQueuePath||'\\'||SalStrRightX( SqlUser, 3 )||SalNumberToStrX( nNumQueueFiles+1, 0 )||'.bcl'
			Function: PrintStockItemsLabels
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					String: sCustName
					! naItemNos is a NUMBER_Null terminated array and naQuantities is also and must match the positioning
							  of naItemNos with the quantites
					Number: naItemNos[*]
					Number: naQuantities[*]
					! sLabelUse = 'FC' or 'HG' or 'BC'
					String: sLabelUse
					Number: nActionType
				Static Variables
				Local variables
					String: sLabelFile
					!
					Number: nPos
					Boolean: bFirst
					Boolean: bNoLabelId
					!
					String: sLabelId
					Number: nTotalCount
					: fcMeter
						Class: clsMeterBar
					!
					String: sShortCustName
				Actions
					Select Case nActionType
						Case SH_cls_Execute
							! Set sLabelFile = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'C:\\TEMP' ) || '\\label.tmp'
							Set sLabelFile = GetNextBCQueueFileName(  )
							!
							Set nPos = 0
							While naItemNos[ nPos ] != NUMBER_Null
								Set nPos = nPos + 1
							Set nTotalCount = nPos
							!
							Call fcMeter.Setup( 'Generating Labels', nTotalCount )
							!
							Set bNoLabelId = FALSE
							Set bFirst = TRUE
							Set nPos = 0
							While naItemNos[ nPos ] != NUMBER_Null
								Call GetStockItemLabelIdForUse( naItemNos[ nPos ], sLabelUse, sLabelId, SH_cls_Execute )
								!
								If sLabelId = ''
									Set bNoLabelId = TRUE
								Else
									If bFirst
										If sLabelUse = 'BC'
											If SalStrLength( sCustName ) > 33
												Set sShortCustName = SalStrLeftX( sCustName, 33 )
											Else
												Set sShortCustName = sCustName
											Call GenerateLabelFile( nCustNo, sShortCustName, 0, 'BCHEAD', 1, 0, hWndNULL, sLabelFile, 'CREATE/OVERWRITE', SH_cls_Execute )
											Call GenerateLabelFile( nCustNo, sCustName, naItemNos[ nPos ], sLabelId, naQuantities[ nPos ], 0, hWndNULL, sLabelFile, 'APPEND', SH_cls_Execute )
										Else
											Call GenerateLabelFile( nCustNo, sCustName, naItemNos[ nPos ], sLabelId, naQuantities[ nPos ], 0, hWndNULL, sLabelFile, 'CREATE/OVERWRITE', SH_cls_Execute )
										Set bFirst = FALSE
									Else
										Call GenerateLabelFile( nCustNo, sCustName, naItemNos[ nPos ], sLabelId, naQuantities[ nPos ], 0, hWndNULL, sLabelFile, 'APPEND', SH_cls_Execute )
								Set nPos = nPos + 1
								!
								Call fcMeter.Increment( 1 )
							! Call OutputLabelFile( sLabelFile )
							!
							If bNoLabelId
								Call SalMessageBox( 'One or More of your selected stock items did not print, due to no label being setup for it.', 'Warning', MB_Ok )
							Call fcMeter.End( )
							Return TRUE
						Case SH_cls_Disconnect
							Call GetStockItemLabelIdForUse( 0, '', sLabelId, SH_cls_Disconnect )
							Call GenerateLabelFile( 0, '', 0, '', 0, 0, hWndNULL, '', '', SH_cls_Disconnect )
							Return TRUE
			Function: CheckLabelPrePrinted
				Description:
				Returns
					Boolean:
				Parameters
					String: sLabelId
					Receive Boolean: bPrePrinted
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					Number: nInd
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'LBLPREPRNTED' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT Preprinted 
									FROM Labels
									WHERE Label_Id = :1 AND Preprinted = 'Y' " 
							Set sName = 'LBLPREPRNTED'
							Set sBind = ':sLabelId'
							Set sInto = ''
							!
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set bPrePrinted = FALSE
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set bPrePrinted = TRUE
								Else
									Set bPrePrinted = FALSE
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: CheckLabelHasPicture
				Description:
				Returns
					Boolean:
				Parameters
					String: sLabelId
					Receive Boolean: bHasPicture
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					Number: nInd
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'LBLHASPIC' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT Field_Type 
									FROM Label_Fields
									WHERE Label_Id = :1  AND Field_Type = 'P' " 
							Set sName = 'LBLHASPIC'
							Set sBind = ':sLabelId'
							Set sInto = ''
							!
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set bHasPicture = FALSE
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set bHasPicture = TRUE
								Else
									Set bHasPicture = FALSE
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: GetStockItemLabelIdForUse
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					String: sLabelUse
					Receive String: sLabelId
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					Number: nInd
					String: sGotLabelId
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'STCKUSELBLID' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT Label_Id 
									FROM Stock_Labels
									WHERE Stock_Item_No = :1 AND Stock_Label_Use = :2 " 
							Set sName = 'STCKUSELBLID'
							Set sBind = ':nItemNo, :sLabelUse'
							Set sInto = ':sGotLabelId'
							!
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set sLabelId = ''
							Set sGotLabelId = ''
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								Call haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
								Set sLabelId = sGotLabelId
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: GenerateLabelFile
				Description: Given a stock item no, label Id and how many labels this prints labels to the bar code printer
						on the com port
						hWndTable is the handle that will receive the PAM_clsLabels_GETFIELDDATA message with the
						wParam as nItemNo and lParam as HString ( use SalNumberToHString to extract the string )
						  To Return a value alway Call PushString( ... ) If number comvert to string and MUST 
						  RETURN TRUE
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					String: sCustName
					Number: nItemNo
					String: sLabelId
					Number: nHowMany
					Number: nLocId
					Window Handle: hWndTable
					String: sLabelFile
					! sLabelFileTreatment = 'CREATE/OVERWRITE OR APPEND'
					String: sLabelFileTreatment
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					String: sHeadTemp
					!
					Number: nInd
					Number: nTmp
					!
					Boolean: bExists
					!
					String: sFormat
					String: sFormatChar
					String: sType
					Long String: sLiteral
					String: sPicFile
					String: sDataDesc
					Number: nOffSet
					Long String: sLabelFormat
					Long String: lsImage
					String: sStartText
					String: sCarrRet
					String: sItemNo
					String: sMany
					Number: nFilesize
					! -------------------------
					String: sSOH
					String: sSTX
					String: sETX
					String: sCR
					String: sESC
					!
					Boolean: bFirstPicture
					Boolean: bFirstFieldFetched
					Boolean: bOk
					!
					String: saLabelPics[*]
					Number: nNumLabelPics
					!
					Number: nLength
					String: sPicName
					String: sPrioSpacesString
					File Handle: hOutFile
					File Handle: hRecFile
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'LBLFIELDS' )
					Select Case nActionType
						Case SH_cls_Execute
							Call SalWaitCursor( TRUE )
							!
							Set sSql = " SELECT 
									  Field_Format_Char, 
									  Field_Type, 
									  Field_Literal, 
									  Field_Picture_File, 
									  Field_Data_Desc 
									FROM 
									  Label_Fields 
									WHERE 
									  Label_Id = :1 "
							Set sName = 'LBLFIELDS'
							Set sBind = ':sLabelId'
							Set sInto = ':sFormatChar, :sType, :sLiteral, :sPicFile, :sDataDesc'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set sSOH = ' '
							Set sSTX = ' '
							Set sETX = ' '
							Set sCR = ' '
							Set sESC = ' '
							! Call CStructPutByte( sSOH, 0, 1 )
							Set sSOH = SalNumberToChar( 1 )
							! Call CStructPutByte( sSTX, 0, 2 )
							Set sSTX = SalNumberToChar( 2 )
							! Call CStructPutByte( sETX, 0, 3 )
							Set sETX = SalNumberToChar( 3 )
							! Call CStructPutByte( sCR, 0, 13 )
							Set sCR = SalNumberToChar( 13 )
							! Call CStructPutByte( sESC, 0, 27 )
							Set sESC = SalNumberToChar( 27 )
							Set nNumLabelPics = 0
							If sLabelFileTreatment = 'APPEND'
								If NOT SalFileOpen( hOutFile, sLabelFile, OF_Append | OF_ReadWrite | OF_Binary )
									Call SalWaitCursor( FALSE )
									Return FALSE
							Else
								If NOT SalFileOpen( hOutFile, sLabelFile, OF_Create | OF_ReadWrite | OF_Binary )
									Call SalWaitCursor( FALSE )
									Return FALSE
							!
							Set sLabelFormat = sSOH || 'D' || sCR || 
									sSTX || 'qB' || sCR || sSTX || 'M3000' || 
									sCR || sSTX || 'RY' || sCR || 
									sSTX || 's' || sCR || sSTX || 'f110' || 
									sCR || sSTX || 'O0103' || sCR || 
									sSTX || 'V0' || sCR
							! Set sLabelFormat = sSOH || 'D' || sCR || sSTX || 'qB' || sCR || sSTX || 'M3000' || sCR || sSTX || 'RY' || sCR || sSTX || 's' || sCR || sSTX || 'f110' || sCR || sSTX || 'O0103' || sCR || sSTX || 'V0' || sCR || 'c0994' || sCR
							Set nLength = SalStrLength( sLabelFormat )
							Call SalFileWrite( hOutFile, sLabelFormat, nLength )
							!
							Call CheckLabelPrePrinted( sLabelId, bExists, SH_cls_Execute )
							If bExists
								Call SalMessageBox( 'Your selection is of a label which is
										preprinted', 'Labels Use', MB_Ok )
								Call SalWaitCursor( FALSE )
								Return FALSE
							Else
								If sLabelId = 'BCODE' OR sLabelId = 'BCHEAD'
									! Want to get the number as multiples of 2
									If nHowMany > 2
										Set nHowMany = nHowMany/2 + 0.5
									Else
										Set nHowMany = 1
									Set nHowMany = SalNumberTruncate( nHowMany, 5, 0 )
									Set sMany = SalFmtFormatNumber( nHowMany, '0000' )
								Else
									! Want to get the number as multiples of 3
									Set nHowMany = nHowMany/4 + 0.9
									Set nHowMany = SalNumberTruncate( nHowMany, 5, 0 )
									Set sMany = SalFmtFormatNumber( nHowMany, '0000' )
							!
							If NOT haSqlHandles[ nOurHandleNo ].Execute( )
								Call SalWaitCursor( FALSE )
								Return FALSE
							!
							Set bFirstFieldFetched = FALSE
							Call CheckLabelHasPicture( sLabelId, bExists, SH_cls_Execute )
							If bExists
								Set bFirstPicture = TRUE
								While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									If sType = 'P'
										Call ExtractPicName( sPicFile, sPicName )
										If NOT PicIsLoaded( sPicFile, saLabelPics, nNumLabelPics )
											If SalFileOpen( hRecFile, sPicFile, OF_Read | OF_Binary )
												If bFirstPicture
													Set sLabelFormat = sSTX || 'IBI' || sPicName || sCR
													Set bFirstPicture = FALSE
												Else
													Set sLabelFormat = sCR || sSOH || 'D' || sCR || sSTX || 'IBI' || sPicName || sCR
												Call SalFileWrite( hOutFile, sLabelFormat, SalStrLength( sLabelFormat ) )
												Call SalFileSeek( hRecFile, 0, FILE_SeekEnd )
												Set nFilesize = SalFileTell( hRecFile )
												Call SalFileSeek( hRecFile, 0, FILE_SeekBegin )
												Set lsImage = ''
												Call SalFileRead( hRecFile, lsImage, nFilesize )
												Call SalFileWrite( hOutFile, lsImage, nFilesize )
												Call SalFileClose( hRecFile )
												Set nNumLabelPics = nNumLabelPics + 1
												Set saLabelPics[ nNumLabelPics ] = sPicFile
								If haSqlHandles[ nOurHandleNo ].FetchRow( 0, nInd )
									Set bFirstFieldFetched = TRUE
							!
							Call ExtractLabelDataFields( nCustNo, sCustName, sLabelId, nItemNo, nLocId, '', sFormat, 'EXTRACT_LABEL_DATA_FIELDS', SH_cls_Execute )
							!
							Set sHeadTemp = OurGetIniFileParameter( 'GENERAL', 'BarcodePrinterHeadTemp', '10' )
							Set sLabelFormat = sCR || sSTX || 'L' || 
									sCR || 'D11' || sCR || 'PK' || 
									sCR || 'SM' || sCR || 'H' || sHeadTemp || 
									sCR || 'z' || sCR || 'Q' || sMany || 
									sCR 
							Set nLength = SalStrLength( sLabelFormat )
							Call SalFileWrite( hOutFile, sLabelFormat, nLength )
							!
							Set bOk = TRUE
							While bOk 
								If bFirstFieldFetched
									Set bFirstFieldFetched = FALSE
								Else
									Set bOk = haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
								If bOk
									If SalStrScan( sLabelId, 'LBL%' ) >= 0
										Set sLabelFormat = SalNumberToStrX( SalStrToNumber( SalStrMidX( sFormatChar, 7, 4 ) ) + LABELSTARTOFFSET, 0 )
										Call StringStartPad( sLabelFormat, '0', 4 )
										Set sFormatChar = SalStrLeftX( sFormatChar, 7 ) || sLabelFormat || SalStrMidX( sFormatChar, 11, 4 )
									!
									Set sLabelFormat = sFormatChar
									Call SalFileWrite( hOutFile, sLabelFormat, SalStrLength( sLabelFormat ) )
									If sType = 'L'
										Set sLabelFormat = SalStrLeftX( sLiteral, SalStrLength( sLiteral ) ) || sCR
										Call SalFileWrite( hOutFile, sLabelFormat, SalStrLength( sLabelFormat ) )
									Else If sType = 'B'
										Set sItemNo = SalFmtFormatNumber( nItemNo, '00000' )
										Set sLabelFormat = '9317036' || sItemNo || sCR
										Call SalFileWrite( hOutFile, sLabelFormat, SalStrLength( sLabelFormat ) )
									Else If sType = 'D'
										If SalSendMsg( hWndTable, PAM_clsLABELS_GETFIELDDATA, nItemNo, SalHStringToNumber( sDataDesc ) )
											Call PopString( sFormat, TRUE )
										Else
											Call ExtractLabelDataFields( nCustNo, sCustName, '', 0, 0, sDataDesc, sFormat, 'LOCAL_LOOKUP', SH_cls_Execute )
										Call ReplaceAtCharToRegisteredChar( sFormat )
										Set sLabelFormat = sFormat || sCR
										Call SalFileWrite( hOutFile, sLabelFormat, SalStrLength( sLabelFormat ) )
									Else If sType = 'P'
										Call ExtractPicName( sPicFile, sPicName )
										Set sLabelFormat = sPicName || sCR
										Call SalFileWrite( hOutFile, sLabelFormat, SalStrLength( sLabelFormat ) )
							!
							Set sLabelFormat = 'E' || sCR
							Call SalFileWrite( hOutFile, sLabelFormat, SalStrLength( sLabelFormat ) )
							Call SalFileClose( hOutFile )
							!
							Call SalWaitCursor( FALSE )
							Return TRUE
						Case SH_cls_Disconnect
							Call CheckLabelPrePrinted( '', bExists, SH_cls_Disconnect )
							Call CheckLabelHasPicture( '', bExists, SH_cls_Disconnect )
							Call ExtractLabelDataFields( 0, '', '', 0, 0, '', sFormat, '', SH_cls_Disconnect )
							Call haSqlHandles[ nOurHandleNo ].Disconnect( )
							Return TRUE
			Function: ExtractLabelDataFields
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					String: sCustName
					String: sLabelId
					Number: nItemNo
					Number: nLocId
					String: sDataField
					Receive String: sDataFieldValue
					! sMethod = 'EXTRACT_LABEL_DATA_FIELDS' OR 'LOCAL_LOOKUP'
					String: sMethod
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
					! bellow arrays are NULL terminated
					String: saDataDesc[*]
					String: saFieldValue[*]
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					Number: nInd
					Number: nFieldCount
					String: sGotDataDesc
					String: sGotFieldValue
					Boolean: bFound
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'LBLDATAFIELDS' )
					Select Case nActionType
						Case SH_cls_Execute
							If sMethod = 'EXTRACT_LABEL_DATA_FIELDS'
								!
								Set nFieldCount = 0
								Set saDataDesc[ 0 ] = ''
								Set saFieldValue[ 0 ] = ''
								!
								Set sSql = " SELECT DISTINCT 
										  Field_Data_Desc 
										FROM 
										  Label_Fields 
										WHERE 
										  Label_Id = :1 AND Field_Type = 'D' "
								Set sName = 'LBLDATAFIELDS'
								Set sBind = ':sLabelId'
								Set sInto = ':sGotDataDesc'
								Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
								!
								If haSqlHandles[ nOurHandleNo ].Execute( )
									While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
										Call GetFieldValue( nCustNo, sCustName, nItemNo, nLocId, sGotDataDesc, sGotFieldValue, SH_cls_Execute )
										Set saDataDesc[ nFieldCount ] = sGotDataDesc
										Set saFieldValue[ nFieldCount ] = sGotFieldValue
										Set nFieldCount = nFieldCount + 1
										Set saDataDesc[ nFieldCount ] = ''
										Set saFieldValue[ nFieldCount ] = ''
									Return TRUE
								Else
									Return FALSE
							Else
								Set sDataFieldValue = ''
								Set bFound = FALSE
								Set nFieldCount = 0
								While saDataDesc[ nFieldCount ] != '' AND NOT bFound
									If saDataDesc[ nFieldCount ] = sDataField
										Set sDataFieldValue = saFieldValue[ nFieldCount ]
										Set bFound = TRUE
									Else
										Set nFieldCount = nFieldCount + 1
								Return bFound
						Case SH_cls_Disconnect
							Call GetFieldValue( 0, '', 0, 0, '', sGotFieldValue, SH_cls_Disconnect )
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			! Function: OutputLabelFile
				  Description: 
				  Returns 
					  Boolean: 
				  Parameters 
					  String: sLabelFile
				  Static Variables 
				  Local variables 
					  File Handle: hOutFile
					  Window Handle: hWndPrinterDC
					  String: strBuffer
					  Number: nLength
					  Number: nReturn
					  Number: nBytesRead
					  Number: nTotalBytesRead
					  Long String: sLabelFormat
					  String: sLength
					  Number: nFileSize
				  Actions 
					  Call SalWaitCursor( TRUE )
					  If NOT SalFileOpen( hOutFile, sLabelFile, OF_Read | OF_Binary )
						  Call SalWaitCursor( FALSE )
						  Return FALSE
					!
					  Call SalFileSeek( hOutFile, 0, FILE_SeekEnd )
					  Set nFileSize = SalFileTell( hOutFile )
					  Call SalFileSeek( hOutFile, 0, FILE_SeekBegin )
					!
					! Direct printing to Barcode using a DC (device context)
					! Refer to the Microsoft SDK manuals
					!
					! Set hWndPrinterDC = CreateDC( 'EPSON9', 'Epson DFX-5000 Barcode','LPT3',0 )
					  If hWndPrinterDC = hWndNULL
						  Call SalMessageBox('Create DC failed','Message',MB_Ok)
						  Call SalWaitCursor( FALSE )
						  Return FALSE
					  Set strBuffer = sLabelFile
					  Set nLength = SalStrLength(strBuffer)
					! Set nReturn = Escape(hWndPrinterDC, 10, nLength+1, strBuffer,0)
					!
					  Set nLength = 100
					! Set nLength = 4500
					!
					  Set nTotalBytesRead = 0
					  While nTotalBytesRead < nFileSize
						  Set nBytesRead = SalFileRead( hOutFile, sLabelFormat, nLength )
						  Set nTotalBytesRead = nTotalBytesRead + nBytesRead
						  Set sLength = '00'
						  Call CStructPutWord( sLength, 0, nBytesRead )
						  Set sLabelFormat = sLength || sLabelFormat
						! Set nReturn = Escape(hWndPrinterDC, 19, nBytesRead, sLabelFormat,0)
					!
					  Call SalFileClose( hOutFile )
					!
					  Set nLength = SalStrLength(strBuffer)
					! Set nReturn = Escape(hWndPrinterDC, 11, nLength, strBuffer,0)
					! If NOT DeleteDC(hWndPrinterDC)
						  Call SalMessageBox('Delete DC failed','Message',MB_Ok)
						  Call SalWaitCursor( FALSE )
						  Return FALSE
					! Else
						  Call SalWaitCursor( FALSE )
						  Return TRUE
			! Function: OutputLabelFile
				  Description: 
				  Returns 
					  Boolean: 
				  Parameters 
					  String: sLabelFile
				  Static Variables 
				  Local variables 
					  File Handle: hOutFile
					  Window Handle: hWndPrinterDC
					  String: strBuffer
					  Number: nLength
					  Number: nReturn
					  Number: nBytesRead
					  Number: nTotalBytesRead
					  Long String: sLabelFormat
					  String: sLength
					  Number: nFileSize
				  Actions 
					  Call SalWaitCursor( TRUE )
					  If NOT SalFileOpen( hOutFile, sLabelFile, OF_Read | OF_Binary )
						  Call SalWaitCursor( FALSE )
						  Return FALSE
					!
					  Call SalFileSeek( hOutFile, 0, FILE_SeekEnd )
					  Set nFileSize = SalFileTell( hOutFile )
					  Call SalFileSeek( hOutFile, 0, FILE_SeekBegin )
					!
					! Direct printing to Barcode using a DC (device context)
					! Refer to the Microsoft SDK manuals
					!
					  Set hWndPrinterDC = CreateDCA( '', 'Epson DFX-5000 Barcode','',0 )
					  If hWndPrinterDC = hWndNULL
						  Call SalMessageBox('Create DC failed','Message',MB_Ok)
						  Call SalWaitCursor( FALSE )
						  Return FALSE
					  Set strBuffer = sLabelFile
					  Set nLength = SalStrLength(strBuffer)
					  Set nReturn = Escape(hWndPrinterDC, 10, nLength+1, strBuffer,0)
					!
					  Set nLength = 100
					! Set nLength = 4500
					!
					  Set nTotalBytesRead = 0
					  While nTotalBytesRead < nFileSize
						  Set nBytesRead = SalFileRead( hOutFile, sLabelFormat, nLength )
						  Set nTotalBytesRead = nTotalBytesRead + nBytesRead
						  Set sLength = '00'
						  Call CStructPutWord( sLength, 0, nBytesRead )
						  Set sLabelFormat = sLength || sLabelFormat
						  Set nReturn = Escape(hWndPrinterDC, 19, nBytesRead, sLabelFormat,0)
					!
					  Call SalFileClose( hOutFile )
					!
					  Set nLength = SalStrLength(strBuffer)
					  Set nReturn = Escape(hWndPrinterDC, 11, nLength, strBuffer,0)
					  If NOT DeleteDC(hWndPrinterDC)
						  Call SalMessageBox('Delete DC failed','Message',MB_Ok)
						  Call SalWaitCursor( FALSE )
						  Return FALSE
					  Else 
						  Call SalWaitCursor( FALSE )
						  Return TRUE
			! make new version of OutputLabelFile which uses k:\centura\reports\barcode.qrp with sInputLine as only RepVar
					 and linked to a new printer Generic Text only Barcode with continuos paper no page breaks. 
			! Function: OutputLabelFile
				  Description: 
				  Returns 
				  Parameters 
					  String: sLabelFile
				  Static Variables 
				  Local variables 
				  Actions 
					  Call SalWaitCursor( TRUE )
					  Call SalCreateWindow( frmPrintBarcodeLabels, hWndForm, sLabelFile )
					  Call SalWaitCursor( FALSE )
			!
			! Function: OutputLabelFile
				  Description: 
				  Returns 
					  Boolean: 
				  Parameters 
					  String: sLabelFile
				  Static Variables 
				  Local variables 
					  File Handle: hOutFile
					  Window Handle: hWndPrinterDC
					  Number: nLength
					  Number: nBytesRead
					  Number: nBytesWritten
					  Number: nTotalBytesRead
					  Long String: sLabelFormat
					  Number: nFileSize
				  Actions 
					  Call SalWaitCursor( TRUE )
					  If NOT SalFileOpen( hOutFile, sLabelFile, OF_Read | OF_Binary )
						  Call SalWaitCursor( FALSE )
						  Return FALSE
					!
					  Call SalFileSeek( hOutFile, 0, FILE_SeekEnd )
					  Set nFileSize = SalFileTell( hOutFile )
					  Call SalFileSeek( hOutFile, 0, FILE_SeekBegin )
					!
					! Direct printing to Barcode using a DC (device context)
					! Refer to the Microsoft SDK manuals
					!
					  Set hWndPrinterDC = CreateFileA( '\\FLEMING-1\BARCODE', GENERIC_WRITE, 0, NUMBER_Null, OPEN_EXISTING, 0, NUMBER_Null )
					  If hWndPrinterDC = hWndNULL
						  Call SalMessageBox('Create DC failed','Message',MB_Ok)
						  Call SalWaitCursor( FALSE )
						  Return FALSE
					!
					  Set nLength = 100
					! Set nLength = 4500
					!
					  Set nTotalBytesRead = 0
					  While nTotalBytesRead < nFileSize
						  Set nBytesRead = SalFileRead( hOutFile, sLabelFormat, nLength )
						  Set nTotalBytesRead = nTotalBytesRead + nBytesRead
						  Call WriteFile( hWndPrinterDC, sLabelFormat, nBytesRead, nBytesWritten, 0 )
					!
					  Call SalFileClose( hOutFile )
					!
					  If NOT CloseHandle( hWndPrinterDC )
						  Call SalMessageBox('Delete DC failed','Message',MB_Ok)
						  Call SalWaitCursor( FALSE )
						  Return FALSE
					  Else 
						  Call SalWaitCursor( FALSE )
						  Return TRUE
			! Function: OutputLabelFile
				  Description: 
				  Returns 
					  Boolean: 
				  Parameters 
					  String: sLabelFile
				  Static Variables 
				  Local variables 
					  File Handle: hOutFile
					  Window Handle: hWndPrinterDC
					  String: sPrinterName
					  Number: nLength
					  Number: nBytesRead
					  Number: nBytesWritten
					  Number: nReturn
					  Number: nTotalBytesRead
					  Long String: sLabelFormat
					  Number: nFileSize
				  Actions 
					  Call SalWaitCursor( TRUE )
					  If NOT SalFileOpen( hOutFile, sLabelFile, OF_Read | OF_Binary )
						  Call SalWaitCursor( FALSE )
						  Return FALSE
					!
					  Call SalFileSeek( hOutFile, 0, FILE_SeekEnd )
					  Set nFileSize = SalFileTell( hOutFile )
					  Call SalFileSeek( hOutFile, 0, FILE_SeekBegin )
					!
					! Direct printing to Barcode using a DC (device context)
					! Refer to the Microsoft SDK manuals
					!
					  Set sPrinterName = 'Epson DFX-5000 Barcode'
					  If NOT OpenPrinterA( sPrinterName, hWndPrinterDC, 0 )
						  Call SalMessageBox('Opening Printer failed.','Message',MB_Ok)
						  Call SalWaitCursor( FALSE )
						  Return FALSE
					!
					  Set nLength = 100
					! Set nLength = 4500
					!
					  Set nTotalBytesRead = 0
					  While nTotalBytesRead < nFileSize
						  Set nBytesRead = SalFileRead( hOutFile, sLabelFormat, nLength )
						  Set nTotalBytesRead = nTotalBytesRead + nBytesRead
						  Set nReturn = WritePrinter( hWndPrinterDC, sLabelFormat, nBytesRead, nBytesWritten )
					!
					  Call SalFileClose( hOutFile )
					!
					  If NOT ClosePrinter( hWndPrinterDC )
						  Call SalMessageBox('Closing Printer failed','Message',MB_Ok)
						  Call SalWaitCursor( FALSE )
						  Return FALSE
					  Else 
						  Call SalWaitCursor( FALSE )
						  Return TRUE
			Function: GetFieldValue
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					String: sCustName
					Number: nItemNo
					Number: nLocId
					String: sDataDesc
					Receive String: sFieldValue
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					Number: nOurHandleNo
					!
					Number: nInd
					String: sTable
					Boolean: bNumber
					Number: nOffSet
					String: sGotFieldValue
					Number: nGotFieldValue
					String: sPrioSpacesString
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetFieldValue' )
					Select Case nActionType
						Case SH_cls_Execute
							Call SalStrLeft( sDataDesc, SalStrScan( sDataDesc, '.' ), sTable )
							Set bNumber = FALSE
							Set nOffSet = NUMBER_Null
							If sTable = 'CULTIVAR'
								If sDataDesc = 'CULTIVAR.CV_LABEL_LINE_1'
									Set sSql = 'SELECT '||sDataDesc||', CV_LL1_OFFSET '||' 
											FROM Stock_Item, Cultivar 
											INTO :sGotFieldValue, :nOffSet
											WHERE 
											  Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Cultivar_Id = Cultivar.Cult_Id'
								Else If sDataDesc = 'CULTIVAR.CV_LABEL_LINE_2'
									Set sSql = 'SELECT '||sDataDesc||', CV_LL2_OFFSET '||' 
											FROM Stock_Item, Cultivar 
											INTO :sGotFieldValue, :nOffSet
											WHERE 
											  Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Cultivar_Id = Cultivar.Cult_Id'
								Else If sDataDesc = 'CULTIVAR.CV_LABEL_LINE_3'
									Set sSql = 'SELECT '||sDataDesc||', CV_LL3_OFFSET '||' 
											FROM Stock_Item, Cultivar 
											INTO :sGotFieldValue, :nOffSet
											WHERE 
											  Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Cultivar_Id = Cultivar.Cult_Id'
								Else If sDataDesc = 'CULTIVAR.CV_LABEL_LINE_4'
									Set sSql = 'SELECT '||sDataDesc||', CV_LL4_OFFSET '||' 
											FROM Stock_Item, Cultivar 
											INTO :sGotFieldValue, :nOffSet
											WHERE 
											  Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Cultivar_Id = Cultivar.Cult_Id'
								Else If sDataDesc = 'CULTIVAR.CV_LABEL_LINE_5'
									Set sSql = 'SELECT '||sDataDesc||', CV_LL5_OFFSET '||' 
											FROM Stock_Item, Cultivar 
											INTO :sGotFieldValue, :nOffSet
											WHERE 
											  Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Cultivar_Id = Cultivar.Cult_Id'
								Else If sDataDesc = 'CULTIVAR.VARIETY'
									Set sSql = 'SELECT Variety 
											FROM Stock_Item 
											INTO :sGotFieldValue 
											WHERE 
											  Stock_Item.Item_No = :nItemNo '
								Else If sDataDesc = 'CULTIVAR.CULT_DESC'
									Set sSql = 'SELECT Cult_Desc 
											FROM Stock_Item 
											INTO :sGotFieldValue 
											WHERE 
											  Stock_Item.Item_No = :nItemNo '
								Else
									Set sSql = 'SELECT '||sDataDesc||
											' FROM Stock_Item, Cultivar 
											INTO :sGotFieldValue 
											WHERE 
											  Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Cultivar_Id = Cultivar.Cult_Id'
							Else If sTable = 'ROOTSTOCK'
								If sDataDesc = 'ROOTSTOCK.RT_LABEL_LINE_1'
									Set sSql = 'SELECT '||sDataDesc||', RT_LL1_OFFSET '||' 
											FROM Stock_Item, Rootstock 
											INTO :sGotFieldValue, :nOffSet
											WHERE 
											  Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Rootstock_Id = Rootstock.Root_Id'
								Else If sDataDesc = 'ROOTSTOCK.RT_LABEL_LINE_2'
									Set sSql = 'SELECT '||sDataDesc||', RT_LL2_OFFSET '||' 
											FROM Stock_Item, Rootstock 
											INTO :sGotFieldValue, :nOffSet
											WHERE 
											  Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Rootstock_Id = Rootstock.Root_Id'
								Else If sDataDesc = 'ROOTSTOCK.RT_LABEL_LINE_3'
									Set sSql = 'SELECT '||sDataDesc||', RT_LL3_OFFSET '||' 
											FROM Stock_Item, Rootstock 
											INTO :sGotFieldValue, :nOffSet
											WHERE 
											  Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Rootstock_Id = Rootstock.Root_Id'
								Else If sDataDesc = 'ROOTSTOCK.RT_LABEL_LINE_4'
									Set sSql = 'SELECT '||sDataDesc||', RT_LL4_OFFSET '||' 
											FROM Stock_Item, Rootstock 
											INTO :sGotFieldValue, :nOffSet
											WHERE 
											  Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Rootstock_Id = Rootstock.Root_Id'
								Else If sDataDesc = 'ROOTSTOCK.RT_LABEL_LINE_5'
									Set sSql = 'SELECT '||sDataDesc||', RT_LL5_OFFSET '||' 
											FROM Stock_Item, Rootstock 
											INTO :sGotFieldValue, :nOffSet
											WHERE 
											  Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Rootstock_Id = Rootstock.Root_Id'
								Else If sDataDesc = 'ROOTSTOCK.ROOT_DESC'
									Set sSql = 'SELECT Root_Desc
											FROM Stock_Item 
											INTO :sGotFieldValue 
											WHERE 
											  Stock_Item.Item_No = :nItemNo'
								Else
									Set sSql = 'SELECT '||sDataDesc||
											' FROM Stock_Item, Rootstock 
											INTO :sGotFieldValue 
											WHERE 
											  Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Rootstock_Id = Rootstock.Root_Id'
							Else If sTable = 'FARM_MASTER'
								Set sSql = 'SELECT '||sDataDesc||
										' FROM Farm_Master, Location 
										INTO :sGotFieldValue
										WHERE 
										  Farm_Master.Farm_Name = Location.Farm_Name AND Location.Location_Id = :nLocId'
							Else If sTable = 'LOCATION'
								If sDataDesc = 'LOCATION.ROW#' OR sDataDesc = 'LOCATION.SEQ#'
									Set bNumber = TRUE
									Set sSql = 'SELECT '||sDataDesc||
											' FROM Location 
											INTO :nGotFieldValue
											WHERE 
											  Location_Id = :nLocId'
								Else
									Set sSql = 'SELECT '||sDataDesc||
											' FROM Location 
											INTO :sGotFieldValue
											WHERE 
											  Location_Id = :nLocId'
							Else If sTable = 'STOCK_ITEM'
								If sDataDesc = 'STOCK_ITEM.ITEM_NO'
									Set sSql = 'SELECT '||sDataDesc||
											' FROM Stock_Item 
											INTO :nGotFieldValue
											WHERE Item_No = :nItemNo'
									Set nGotFieldValue = nItemNo
									Set bNumber = TRUE
								Else
									Set sSql = 'SELECT '||sDataDesc||
											' FROM Stock_Item 
											INTO :sGotFieldValue
											WHERE Item_No = :nItemNo'
							Else If sTable = 'TREE_TYPE'
								Set sSql = 'SELECT '||sDataDesc||
										' FROM Stock_Item, Tree_Type 
										INTO :sGotFieldValue
										WHERE Stock_Item.Item_No = :nItemNo AND 
										Stock_Item.Tree_Type = Tree_Type.Tree_Type '
							Else If sTable = 'CUSTOMER_MASTER'
								If sDataDesc = 'CUSTOMER_MASTER.CUST_NO'
									Set sFieldValue = SalNumberToStrX( nCustNo, 0 )
									Return TRUE
								Else If sDataDesc = 'CUSTOMER_MASTER.CUST_NAME'
									Set sFieldValue = sCustName
									Return TRUE
								Else
									Set sSql = 'SELECT '||sDataDesc||
											' FROM Customer_Master 
											INTO :sGotFieldValue
											WHERE Cust_No = :nCustNo '
							Else
								Call SalMessageBox( 'Undefined lookup table for datafield. Error retrieving Data', 'Labels', MB_Ok )
								Return FALSE
							!
							Call haSqlHandles[ nOurHandleNo ].RePrepare( )
							Call haSqlHandles[ nOurHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set sFieldValue = ''
							Set sGotFieldValue = ''
							!
							If haSqlHandles[ nOurHandleNo ].PrepareAndExecute( )
								Call haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
								If nOffSet > 0
									Set sPrioSpacesString = ''
									Call SalStrRepeat( ' ', nOffSet, sPrioSpacesString )
									Set sGotFieldValue = sPrioSpacesString || sGotFieldValue
								If bNumber
									Set sGotFieldValue = SalNumberToStrX( nGotFieldValue, 0 )
								Set sFieldValue = sGotFieldValue
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: ReplaceAtCharToRegisteredChar
				Description:
				Returns
				Parameters
					Receive String: sFormatString
				Static Variables
				Local variables
					String: sRegisteredMark
				Actions
					Set sRegisteredMark = ' '
					! Call CStructPutByte( sRegisteredMark, 0, 169 )
					Set sRegisteredMark = SalNumberToChar( 169 )
					!
					Call StringReplace( sFormatString, '@', sRegisteredMark )
			Function: PicIsLoaded
				Description: Checks if the picture file has been loaded before into the saLabelPics array.
				Returns
					Boolean:
				Parameters
					String: sPicFileName
					String: saLabelPics[*]
					Number: nNumLabelPics
				Static Variables
				Local variables
					Number: nCount
					Boolean: bFound
				Actions
					If nNumLabelPics > 0
						Set nCount = 1
						While ( nCount <= nNumLabelPics AND NOT bFound ) 
							If saLabelPics[ nCount ] = sPicFileName
								Set bFound = TRUE
							Else
								Set nCount = nCount + 1
						If bFound
							Return TRUE
						Else
							Return FALSE
					Else
						Return FALSE
			Function: ExtractPicName
				Description: ! The next blocked code extracts the flem3 part of a filename f:\apps\ezilabl\flem3.img
						NOTE must specify full drive:\\path\\filename.extension eg f:\apps\ezilabl\flem3.img
						NOTE This will extract the name regardless of the file extension'
				Returns
					Boolean:
				Parameters
					String: sPicFile
					Receive String: sPicName
				Static Variables
				Local variables
					Number: nDotPos
					Number: nBackSlashPos
				Actions
					Set nDotPos = FindCharInFileNameFromEnd( sPicFile, '.' )
					Set nBackSlashPos = FindCharInFileNameFromEnd( sPicFile, '\\' )
					If nDotPos >= 0 AND nBackSlashPos >= 0
						Set sPicName = SalStrMidX( sPicFile, nBackSlashPos+1, nDotPos - nBackSlashPos - 1 )
						Return TRUE
					Else
						Set sPicName = ''
						Return FALSE
			Function: FindCharInFileNameFromEnd
				Description: Returns a positive integer representing the seach character and -1 for not found
				Returns
					Number:
				Parameters
					String: sPicFile
					String: sFindChar
				Static Variables
				Local variables
					Number: nPos
					Boolean: bFound
				Actions
					Set bFound = FALSE
					Set nPos = SalStrLength( sPicFile ) - 1
					While nPos >= 0 AND NOT bFound
						If SalStrMidX( sPicFile, nPos, 1 ) = sFindChar
							Set bFound = TRUE
						Else
							Set nPos = nPos - 1
					If bFound
						Return nPos
					Else
						Return -1

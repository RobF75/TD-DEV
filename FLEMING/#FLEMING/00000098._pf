							! On SAM_Validate
								  Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, FALSE )
								  Return VALIDATE_OkClearFlag
							On SAM_AnyEdit
								Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, FALSE )
				Functions
				Window Variables
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set sSQLPopHandle = " SELECT  
								  Stock_Labels.Label_Id, 
								  Labels.Label_Desc, 
								  Stock_Labels.Stock_Label_Use 
								FROM   
								  Stock_Labels, Labels   
								WHERE 
								  Stock_Labels.Stock_Item_No = :1 AND 
								  Stock_Labels.Label_Id = Labels.Label_Id "
						Set sNAMEPopHandle = 'POPPRSTCKLBLS'
						Set sBINDPopHandle = ':hWndParent.nItemNo'
						Set sINTOPopHandle = ':hWndForm.colLabelId, :hWndForm.colLabelDesc, :hWndForm.colLabelUse'
						!
						Set sSQLRefreshHandle = " SELECT  
								  Stock_Labels.Label_Id, 
								  Labels.Label_Desc, 
								  Stock_Labels.Stock_Label_Use 
								FROM   
								  Stock_Labels, Labels   
								WHERE 
								  Stock_Labels.Stock_Item_No = :1 AND 
								  Stock_Labels.Label_Id = :2 AND 
								  Stock_Labels.Label_Id = Labels.Label_Id "
						Set sNAMERefreshHandle = 'REFPRSTCKLBLS'
						Set sBINDRefreshHandle = ':hWndParent.nItemNo, :hWndForm.colLabelId'
						Set sINTORefreshHandle = ':hWndForm.colLabelId, :hWndForm.colLabelDesc, :hWndForm.colLabelUse'
						!
						Set sSQLInsertHandle = ''
						Set sNAMEInsertHandle = ''
						Set sBINDInsertHandle = ''
						Set sINTOInsertHandle = ''
						!
						Set sSQLUpdateHandle = ''
						Set sNAMEUpdateHandle = ''
						Set sBINDUpdateHandle = ''
						Set sINTOUpdateHandle = ''
						!
						Set sSQLDeleteHandle = ''
						Set sNAMEDeleteHandle = ''
						Set sBINDDeleteHandle = ''
						Set sINTODeleteHandle = ''
						!
						Set bAddAllowed = FALSE
						Set bSaveAllowed = FALSE
						Set bDeleteAllowed = FALSE
						Set bUnDeleteAllowed = FALSE
						Set bRepopulateAllowed = TRUE
						Set bClearSelectAllowed = TRUE
						Set bQueryAllowed = FALSE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = FALSE
						!
						Set bSelectFirstRow = FALSE
					On PAM_clsLABELS_PRINTLABEL
						If colQuantity > 0
							Call PrintLabels( hWndParent.nItemNo, colLabelId, colQuantity, NUMBER_Null, hWndNULL, SH_cls_Execute )
							Set hWndParent.bPrinted = TRUE
						Return TRUE
					On SAM_Destroy
						Call PrintLabels( 0, '', 0, 0, hWndNULL, SH_cls_Disconnect )
						Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

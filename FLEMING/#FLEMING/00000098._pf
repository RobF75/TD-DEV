		  Description: 
		  Tool Bar 
			  Contents 
		  Contents 
			  Data Field: dfItemNo
				  Message Actions 
			  Child Table: tblLbl
				  Contents 
					  Column: colWhere
						  List Values 
						  Message Actions 
							  On PAM_WHEREPOPULATE
								  Set sBuildWhere = ' WHERE STOCK_LABELS.STOCK_ITEM_NO = :dlgLbl.dfItemNo
										AND STOCK_LABELS.LABEL_ID = LABELS.LABEL_ID' 
					  Column: colMany
						  List Values 
						  Message Actions 
					  Column: colLabId
						  List Values 
						  Message Actions 
							  On PAM_SQL
								  Call BuildSQL(  wParam, hWndItem, 'STOCK_LABELS.LABEL_ID' )
					  Column: colLabDesc
						  List Values 
						  Message Actions 
							  On PAM_SQL
								  Call BuildSQL(  wParam, hWndItem, 'LABELS.LABEL_DESC' )
					  Column: colUse
						  List Values 
						  Message Actions 
							  On PAM_SQL
								  Call BuildSQL(  wParam, hWndItem, 'STOCK_LABELS.STOCK_LABEL_USE' )
					  Column: colRowId
						  List Values 
						  Message Actions 
							  On PAM_SQL
								  Call BuildSQL( wParam, hWndItem, 'STOCK_LABELS.ROWID' )
				  Functions 
				  Window Variables 
					  Sql Handle: hLocalSqlPopTbl
					  Boolean: bLocalSqlPopTbl
					  String: sSQLTABLENAME
					  String: sORDERBY
					  String: sCurrentBuildWhere
				  Message Actions 
					  On PAM_POPULATE
						  Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
					  On PAM_REPOPULATE
						  Call TableRePopulate( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLTABLENAME, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
					  On SAM_Create
						  Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						  If bLocalSqlPopTbl
							  Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							  Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						  Else 
							  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							  Return FALSE
						  Set sSQLTABLENAME = ' STOCK_LABELS, LABELS '
						  Set sORDERBY = ''
					  On SAM_Destroy
						  If bLocalSqlPopTbl
							  Call SqlDisconnect( hLocalSqlPopTbl )
			  Pushbutton: pbPrint
				  Message Actions 
					  On SAM_Click
						  If NOT SalTblAnyRows( tblLbl, ROW_Edited, 0 )
							  Call SalMessageBox( 'How many would you like?', 'Error', MB_Ok )
						  Else 
							! Call PrintLabels( dfItemNo, dlgLbl.tblLbl.colLabId, dlgLbl.tblLbl.colMany, 0, hWndNULL )
							  Call NewPrintLabels( dfItemNo, dlgLbl.tblLbl.colLabId, dlgLbl.tblLbl.colMany, 0, hWndNULL, nExecute )
							  Call SalEndDialog( hWndForm, 0 )
			  Pushbutton: pbCancel
				  Message Actions 
					  On SAM_Click
						  Call SalWaitCursor( TRUE )
						  Call SalEndDialog( hWndForm, 0 )
			  Pushbutton: pbHelp
				  Message Actions 
					  On SAM_Click
						  Call ActivateHelp( sHelpFileName )
			  Frame 
		  Functions 
		  Window Parameters 
		  Window Variables 
			  String: sHelpFileName
		  Message Actions 
			  On SAM_Create
				  Set sHelpFileName = 'g:\\apps\\gupta\\help\\lbl.hlp'
				  Call SalPostMsg(  hWndForm, PAM_CREATECOMPLETE, 0, 0 ) 
			  On PAM_CREATECOMPLETE
				  Call PopNumber( dfItemNo, TRUE )
				  Call SalSendMsg( tblLbl, PAM_POPULATE, 0, 0 ) 
			  On SAM_Destroy
				  Call SalWaitCursor( FALSE )
			  On SAM_Close
				  Call SalWaitCursor( TRUE )

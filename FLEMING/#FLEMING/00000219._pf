		Application Actions
			On SAM_AppStartup
				If strArgArray[0] = ''
					Set SqlDatabase = 'STOCKDEV'
					Set SqlUser = 'JAN'
					Set SqlPassword = 'JAN'
				Else
					Set SqlDatabase = strArgArray[1]
					Set SqlUser = strArgArray[2]
					Set SqlPassword = strArgArray[3]
				!
				! Set strArgArray[4] = 'DCAAAAAAAEAAAAAAJDKKAAAAAAAAAACMNOAEAAAA'
				!
				Call CheckProgramExistance( 'Generate Cash Receipt', TRUE )
				!
				Call SqlHandlesSetup(  )
				Call SalCreateWindow( frmPrintCashReceipts, hWndNULL, strArgArray[4] )
			On SAM_AppExit
				Call SqlHandlesDisconnectClose(  )

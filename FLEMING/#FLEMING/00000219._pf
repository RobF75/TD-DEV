			Contents
		Contents
		Functions
			Function: MakeRcpCSVLine
				Description:
				Returns
					String:
				Parameters
				Static Variables
				Local variables
				Actions
					Return NumberField( frmPrintCashReceipts.nCustNo, 0 ) || 
							StringField( frmPrintCashReceipts.sCustName ) || 
							StringField( frmPrintCashReceipts.sBusAddrLine1 ) || 
							StringField( frmPrintCashReceipts.sBusAddrLine2 ) || 
							StringField( frmPrintCashReceipts.sBusAddrLine3 ) || 
							StringField( frmPrintCashReceipts.sBusAddrLine4 ) || 
							StringField( frmPrintCashReceipts.sBusAddrLine5 ) || 
							DateField( frmPrintCashReceipts.dtReceiptDate ) || 
							StringField( frmPrintCashReceipts.sReceiptType ) || 
							NumberField( frmPrintCashReceipts.nReceiptAmount, 2 ) || 
							NumberField( frmPrintCashReceipts.nChequeNo, 0 ) || 
							StringField( frmPrintCashReceipts.sChequeDrawer ) || 
							StringField( frmPrintCashReceipts.sChequeBank ) || 
							StringField( frmPrintCashReceipts.sChequeBranch )
		Window Parameters
			String: sROWID
		Window Variables
			String: sBusName
			Date/Time: dtAddressDT
			String: sAddrType
			String: sAddressLine1
			String: sAddressLine2
			String: sSuburb
			String: sPostcode
			String: sState
			String: sCountry
			String: sAreaCode
			String: sPhoneNo
			String: sAreaCodeFax
			String: sFaxNo
			String: sComments
			String: sMeetId
			String: sMainAddressFlag
			Boolean: bFirst
			: fcCSVFile
				Class: clsStrFileHandle
			Boolean: bCSVFileOpen
			String: sCSVFile
			!
			! REPORT FIELDS
			Number: nCustNo
			String: sCustName
			String: sBusAddrLine1
			String: sBusAddrLine2
			String: sBusAddrLine3
			String: sBusAddrLine4
			String: sBusAddrLine5
			String: sBusAddrLine6
			Date/Time: dtReceiptDate
			String: sReceiptType
			Number: nReceiptAmount
			Number: nChequeNo
			String: sChequeDrawer
			String: sChequeBank
			String: sChequeBranch
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set sReportFileNameNoPath = 'cshrcpt3.qrp'
				Set sReportBind = ':frmPrintCashReceipts.nCustNo,
						:frmPrintCashReceipts.sCustName,
						:frmPrintCashReceipts.sBusAddrLine1,
						:frmPrintCashReceipts.sBusAddrLine2,
						:frmPrintCashReceipts.sBusAddrLine3,
						:frmPrintCashReceipts.sBusAddrLine4,
						:frmPrintCashReceipts.sBusAddrLine5, 
						:frmPrintCashReceipts.sBusAddrLine6, 
						:frmPrintCashReceipts.dtReceiptDate,
						:frmPrintCashReceipts.sReceiptType,
						:frmPrintCashReceipts.nReceiptAmount,
						:frmPrintCashReceipts.nChequeNo,
						:frmPrintCashReceipts.sChequeDrawer,
						:frmPrintCashReceipts.sChequeBank,
						:frmPrintCashReceipts.sChequeBranch'
				Set sReportInto = 'nCustNo, 
						sCustName, 
						sBusAddrLine1,
						sBusAddrLine2, 
						sBusAddrLine3,
						sBusAddrLine4,
						sBusAddrLine5,
						sBusAddrLine6,
						dtReceiptDate,
						sReceiptType, 
						nReceiptAmount, 
						nChequeNo, 
						sChequeDrawer, 
						sChequeBank, 
						sChequeBranch'
				Set sReportType = 'PRINT'
				!
				Set sReportSql = "  SELECT 
						  Cash_Receipt.Cust_No, 
						  Customer_Master.Cust_Name, 
						  Cash_Receipt.Receipt_Date, 
						  Cash_Receipt.Receipt_Type, 
						  Cash_Receipt.Receipt_Amount, 
						  Cash_Receipt.Cheque_No, 
						  Cash_Receipt.Cheque_Drawer, 
						  Cash_Receipt.Cheque_Bank, 
						  Cash_Receipt.Cheque_Branch 
						FROM 
						  Cash_Receipt, 
						  Customer_Master 
						INTO 
						  :frmPrintCashReceipts.nCustNo,
						  :frmPrintCashReceipts.sCustName,
						  :frmPrintCashReceipts.dtReceiptDate,
						  :frmPrintCashReceipts.sReceiptType,
						  :frmPrintCashReceipts.nReceiptAmount,
						  :frmPrintCashReceipts.nChequeNo,
						  :frmPrintCashReceipts.sChequeDrawer,
						  :frmPrintCashReceipts.sChequeBank,
						  :frmPrintCashReceipts.sChequeBranch
						WHERE 
						  Cash_Receipt.ROWID = :frmPrintCashReceipts.sROWID AND 
						  Cash_Receipt.Cust_No = Customer_Master.Cust_No "
			On PAM_clsFRM_REPORTFETCHINIT
				Set bFirst = TRUE
				Return TRUE
			On PAM_clsFRM_REPORTFETCHNEXT
				If bFirst
					Set bFirst = FALSE
					!
					Set sCSVFile = OurGetIniFileParameter( 'ACCOUNTS', 'RcptsCSVPath', 'c:\\temp' ) || '\\' || MakeCustRcpCSVFileName( nCustNo, SalDateYear( SalDateCurrent(  ) ), sReportFileNameNoPath )
					Call fcCSVFile.Setup( sCSVFile, NUMBER_Null, NUMBER_Null )
					Set bCSVFileOpen = fcCSVFile.Open( )
					!
					Call GetBusAddress( nCustNo, dtAddressDT, sAddrType, sAddressLine1, sAddressLine2, sSuburb, sPostcode,
							sState, sCountry, sAreaCode, sPhoneNo, sAreaCodeFax, sFaxNo, sComments, sMeetId, sMainAddressFlag, SH_cls_Execute )
					Call FixLineSpaceAddress( '', sCustName, sBusName, sAddressLine1, sAddressLine2, sSuburb, sState, 
							sPostcode, sBusAddrLine1, sBusAddrLine2, sBusAddrLine3, sBusAddrLine4, sBusAddrLine5, sBusAddrLine6 )
				If bCSVFileOpen
					Call fcCSVFile.Write( MakeRcpCSVLine( ) )
				Return TRUE
			On PAM_clsFRM_REPORTFINISH
				If bCSVFileOpen
					Call fcCSVFile.Close( )
					Set bCSVFileOpen = FALSE
				Return TRUE
			On SAM_Destroy
				Call GetBusAddress( 0, dtAddressDT, sAddrType, sAddressLine1, sAddressLine2, sSuburb, sPostcode,
						sState, sCountry, sAreaCode, sPhoneNo, sAreaCodeFax, sFaxNo, sComments, sMeetId, sMainAddressFlag, SH_cls_Disconnect )
				Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

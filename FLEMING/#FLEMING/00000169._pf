.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetCustOnLoadAddress' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT 
  Deliv_Addr_DT
FROM 
  Load_Customers 
WHERE 
  Load_Id = :1 AND Cust_No = :2 "
.head 7 -  Set sName = 'GCSTLDDADRDT'
.head 7 -  Set sBind = ':sLoadId, :nCustNo'
.head 7 -  Set sInto = ':dtDelivAddrDT'
.head 7 -  !
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set dtDelivAddrDT = DATETIME_Null

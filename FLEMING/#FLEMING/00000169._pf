.head 4 -  !
.head 4 -  Set sLoadCustCommaList = ''
.head 4 -  Call ReadStrArrayListFromFile( sSelectedCustFileName, sSelectedCustNos )
.head 4 -  Call MakeStringList( sSelectedCustNos, ',', '', sLoadCustCommaList )
.head 4 -  !
.head 4 +  If sSelectionType = 'LOAD'
.head 5 -  Set sReportSql = "SELECT DISTINCT 
  Customer_Master.Cust_No,
  Customer_Master.Cust_Name,
  Stock_Item.Variety,
  Customer_Order.Conf_Amt 
FROM
  Customer_Order,
  Stock_Item,
  Customer_Master 
INTO 
  :frmHostPlantsReport.nCustNo,
  :frmHostPlantsReport.sCustName,
  :frmHostPlantsReport.sVariety,
  :frmHostPlantsReport.nAmount
WHERE
  Customer_Order.Stock_Item_no = Stock_Item.Item_No AND
  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
  (
    Stock_Item.Cult_Desc LIKE '%Apple%' OR
    Stock_Item.Cult_Desc LIKE '%Malus%' OR
    Stock_Item.Cult_Desc LIKE '%Pyrus%' OR
    Stock_Item.Cult_Desc LIKE '%Pear%' OR
    Stock_Item.Cult_Desc LIKE '%Crataegus%' OR
    Stock_Item.Cult_Desc LIKE '%HawthORn%' OR
    Stock_Item.Cult_Desc LIKE '%Amelanchier%' OR
    Stock_Item.Cult_Desc LIKE '%Chaenomeles%' OR
    Stock_Item.Cult_Desc LIKE '%SORbus%' OR
    Stock_Item.Cult_Desc LIKE '%Rowan%' OR
    Stock_Item.Cult_Desc LIKE '%Spiraea%' OR
    Stock_Item.Cult_Desc LIKE '%Ballerina%' OR
    Stock_Item.Cult_Desc LIKE '%Quince%' OR
    Stock_Item.Cult_Desc LIKE '%Kerria%' OR
    Stock_Item.Cult_Desc LIKE '%Photinia%' OR
    Stock_Item.Cult_Desc LIKE '%Raphiolepis%' OR
    Stock_Item.Cult_Desc LIKE '%Medlar%' OR
    Stock_Item.Cult_Desc LIKE '%Nashi%' 
  ) AND 
  Customer_Order.Year_Of_Sale = :frmHostPlantsReport.nYear AND 
  Customer_Order.Load_Id = :frmHostPlantsReport.sLoadId AND
  Customer_Order.Conf_Amt > 0 "
.head 4 +  Else
.head 5 -  Set sReportSql = "SELECT DISTINCT 
  Customer_Master.Cust_No,
  Customer_Master.Cust_Name,
  Stock_Item.Variety,
  Customer_Order.Conf_Amt 
FROM
  Customer_Order,
  Stock_Item,
  Customer_Master 
INTO 
  :frmHostPlantsReport.nCustNo,
  :frmHostPlantsReport.sCustName,
  :frmHostPlantsReport.sVariety,
  :frmHostPlantsReport.nAmount 
WHERE
  Customer_Order.Stock_Item_no = Stock_Item.Item_No AND
  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
  (
    Stock_Item.Cult_Desc LIKE '%Apple%' OR
    Stock_Item.Cult_Desc LIKE '%Malus%' OR
    Stock_Item.Cult_Desc LIKE '%Pyrus%' OR
    Stock_Item.Cult_Desc LIKE '%Pear%' OR
    Stock_Item.Cult_Desc LIKE '%Crataegus%' OR
    Stock_Item.Cult_Desc LIKE '%HawthORn%' OR
    Stock_Item.Cult_Desc LIKE '%Amelanchier%' OR
    Stock_Item.Cult_Desc LIKE '%Chaenomeles%' OR
    Stock_Item.Cult_Desc LIKE '%SORbus%' OR
    Stock_Item.Cult_Desc LIKE '%Rowan%' OR
    Stock_Item.Cult_Desc LIKE '%Spiraea%' OR
    Stock_Item.Cult_Desc LIKE '%Ballerina%' OR
    Stock_Item.Cult_Desc LIKE '%Quince%' OR
    Stock_Item.Cult_Desc LIKE '%Kerria%' OR
    Stock_Item.Cult_Desc LIKE '%Photinia%' OR
    Stock_Item.Cult_Desc LIKE '%Raphiolepis%' OR
    Stock_Item.Cult_Desc LIKE '%Medlar%' OR
    Stock_Item.Cult_Desc LIKE '%Nashi%' 
  ) AND 
  Customer_Order.Year_Of_Sale = :frmHostPlantsReport.nYear AND 
  Customer_Order.Load_Id = :frmHostPlantsReport.sLoadId AND
  Customer_Order.Conf_Amt > 0 AND 
  Customer_Order.Cust_No IN ( " || sLoadCustCommaList || " ) "
.head 3 +  On PAM_clsFRM_REPORTSTART
.head 4 -  Set nYear = WhichSeasonYear( SalDateCurrent(  ) )
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFETCHINIT
.head 4 -  Set nLastCustNo = NUMBER_Null
.head 4 -  Set sLastSuburb = ''
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFETCHNEXT
.head 4 +  If nLastCustNo = nCustNo
.head 5 -  Set sSuburb = sLastSuburb
.head 4 +  Else
.head 5 -  Call GetCustOnLoadAddress( sLoadId,
nCustNo,
nYear,
sTmp,
sTmp,
sTmp,
sSuburb,
sTmp,
sTmp,
sTmp,
sTmp,
sTmp,
sTmp,
sTmp,
sTmp,
sTmp,
sTmp,
SH_cls_Execute )
.head 5 -  Set nLastCustNo = nCustNo
.head 5 -  Set sLastSuburb = sSuburb
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFINISH
.head 4 -  Call GetCustOnLoadAddress( '',
0,
0,
sTmp,
sTmp,
sTmp,
sSuburb,
sTmp,
sTmp,
sTmp,
sTmp,
sTmp,
sTmp,
sTmp,
sTmp,
sTmp,
sTmp,
SH_cls_Disconnect )
.head 4 -  Return TRUE

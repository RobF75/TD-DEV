			Contents
		Contents
		Functions
		Window Parameters
		Window Variables
			Number: nYear
			! REPORT COLUMNS
			String: sVarietyType
			String: sUpperVariety
			String: sUpperCultDesc
			String: sUpperRootDesc
			String: sVariety
			String: sTreeTypeDesc
			String: sCultDesc
			String: sRootDesc
			String: sFarmName
			Number: nRowNo
			Number: nSeqNo
			Number: nBudCount
			Number: nFirstCount
			Number: nSecondCount
			Number: nForwardOrders
			Date/Time: dtEstSaleDate
			String: sNotForSale
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set sReportFileNameNoPath = 'PotsAlpha3.qrp'
				Set sReportBind = ':frmPotsAlpha.sVarietyType, 
						  :frmPotsAlpha.sUpperVariety, 
						  :frmPotsAlpha.sUpperCultDesc, 
						  :frmPotsAlpha.sUpperRootDesc, 
						  :frmPotsAlpha.sVariety, 
						  :frmPotsAlpha.sTreeTypeDesc, 
						  :frmPotsAlpha.sCultDesc, 
						  :frmPotsAlpha.sRootDesc, 
						  :frmPotsAlpha.sFarmName, 
						  :frmPotsAlpha.nRowNo, 
						  :frmPotsAlpha.nSeqNo, 
						  :frmPotsAlpha.nBudCount, 
						  :frmPotsAlpha.nFirstCount, 
						  :frmPotsAlpha.nSecondCount, 
						  :frmPotsAlpha.nForwardOrders, 
						  :frmPotsAlpha.dtEstSaleDate, 
						  :frmPotsAlpha.sNotForSale'
				Set sReportInto = 'sVarietyType, 
						  sUpperVariety, 
						  sUpperCultDesc, 
						  sUpperRootDesc, 
						  sVariety, 
						  sTreeTypeDesc, 
						  sCultDesc, 
						  sRootDesc
						  sFarmName, 
						  nRowNo, 
						  nSeqNo, 
						  nBudCount, 
						  nFirstCount, 
						  nSecondCount, 
						  nForwardOrders, 
						  dtEstSaleDate, 
						  sNotForSale'
				Set sReportType = 'VIEW'
				!
				Set sReportSql = "SELECT 
						  Stock_Item.Variety_Type, 
						  @UPPER( Stock_Item.Variety ), 
						  @UPPER( Stock_Item.Cult_Desc ), 
						  @UPPER( Stock_Item.Root_Desc ), 
						  Stock_Item.Variety, 
						  Stock_Item.Tree_Type_Desc, 
						  Stock_Item.Cult_Desc, 
						  Stock_Item.Root_Desc, 
						  Location.Farm_Name, 
						  Location.Row#, 
						  Location.Seq#, 
						  Growing_Sale.Beg_Count, 
						  Growing_Sale.First_Count, 
						  Growing_Sale.Second_Count, 
						  Growing_Sale.Forward_Orders, 
						  Growing_Sale.Est_Sale_Date, 
						  Growing_Sale.Not_For_Sale 
						FROM 
						  Stock_Item, 
						  Growing_Sale, 
						  Location 
						INTO 
						  :frmPotsAlpha.sVarietyType, 
						  :frmPotsAlpha.sUpperVariety, 
						  :frmPotsAlpha.sUpperCultDesc, 
						  :frmPotsAlpha.sUpperRootDesc, 
						  :frmPotsAlpha.sVariety, 
						  :frmPotsAlpha.sTreeTypeDesc, 
						  :frmPotsAlpha.sCultDesc, 
						  :frmPotsAlpha.sRootDesc, 
						  :frmPotsAlpha.sFarmName, 
						  :frmPotsAlpha.nRowNo, 
						  :frmPotsAlpha.nSeqNo, 
						  :frmPotsAlpha.nBudCount, 
						  :frmPotsAlpha.nFirstCount, 
						  :frmPotsAlpha.nSecondCount, 
						  :frmPotsAlpha.nForwardOrders, 
						  :frmPotsAlpha.dtEstSaleDate, 
						  :frmPotsAlpha.sNotForSale 
						WHERE 
						  Stock_Item.Item_No = Growing_Sale.Stock_Item_No AND 
						  Stock_Item.Stock_Type = 'C' AND  
						  Growing_Sale.Year_Of_Sale >= :frmPotsAlpha.nYear AND 
						  Growing_Sale.Location_Id = Location.Location_Id AND 
						  Location.Farm_Name LIKE 'C%' 
						ORDER BY 
						  1,2,3,4,6,9,10,11 "
			On PAM_clsFRM_REPORTSTART
				Set nYear = WhichSeasonYear( SalDateCurrent(  ) )
				Return TRUE

			On SAM_Create
				Set sHelpFileName = 'f:\\apps\\gupta\\stock\\qcustnpa.hlp'
				Call SalPostMsg( hWndForm,PAM_CREATECOMPLETE,0,0 )
			On SAM_Destroy
				Call SalSendMsg( hWndCallProg, PAM_ENABLE,0,0 )
			On SAM_Activate
				Return SalSendMsgToChildren( hWndForm, PAM_ACTIVATE, wParam, lParam )
			On PAM_CREATECOMPLETE
				Set dfCurrDate = SalDateCurrent(  )
				If SalModalDialog( dlgInitialCustomer, hWndForm )
					Call SalSendMsg( tblQCust, PAM_POPULATE, 0, 0 )
				Else
					Call SalDestroyWindow( hWndForm )

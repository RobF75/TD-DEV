		Functions
		Window Parameters
		Window Variables
			Window Handle: hWndPushbutton
			Window Handle: hWndParent
			Boolean: bShowQueryOk
			Boolean: bNextPbEnabled
			Boolean: bPrevPbEnabled
			Number: nLocalRow
			String: sHelpFileName
		Message Actions
			On SAM_Create
				Set sHelpFileName = 'f:\\apps\\gupta\\stock\\recvnpa.hlp'
				Set dfCurrDate = SalDateCurrent(  )
				! Set dfCurrYr = OurDateYear( dfCurrDate )
				Call PopWndHdl( hWndPushbutton, TRUE )
				Call PopWndHdl( hWndParent, TRUE )
				Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE,0,0 )
			On PAM_CREATECOMPLETE
				Call PopNumber( dfCustNo, TRUE )
				Call PopString( dfCustName, TRUE )
				Set dfCurrYr = cSeasonYear.GetSeasonYear( )
				Call SalSendMsg( tblOrders, PAM_POPULATE, 0, 0 )
			On SAM_Destroy
				Call SalShowWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				Call SalSendMsg( hWndPushbutton, PAM_ENABLE, 0, 0 )
			On SAM_Activate
				Return SalSendMsgToChildren( hWndForm, PAM_ACTIVATE, wParam, lParam )
			On SAM_Close
				If NOT TableForgetChanges( tblOrders, frmReceiveNPAs.tblOrders.bEdit )
					Return FALSE
				Call SalWaitCursor( TRUE )

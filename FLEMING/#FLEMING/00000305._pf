				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						If NOT TableForgetChanges( tblOrders, frmReceiveNPAs.tblOrders.bEdit )
							Return FALSE
						Call SalWaitCursor( TRUE )
						Call SalHideWindow( hWndItem )
						Call SalSendMsg( pbQueryOk, PAM_ENABLE, 0, 0 )
						Call SalSendMsg( tblOrders, PAM_RESET, 0, 0 )
						Set bShowQueryOk = TRUE
						Call SalSendMsgToChildren( hWndForm, PAM_QUERYDISABLE, TRUE, 0 )
						Call SalWaitCursor( FALSE )
					On PAM_ENABLE
						Call SalWaitCursor( TRUE )
						Call SalShowWindow( hWndItem )
						Set bShowQueryOk = FALSE
						Call SalSendMsgToChildren( hWndForm, PAM_QUERYDISABLE, FALSE, 0 )
						Call SalWaitCursor( FALSE )

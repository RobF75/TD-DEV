				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					String: sSQLTABLEPOPNAME
					String: sORDERBY
					String: sInitialWhere
					String: sQueryTmpStr
					String: sCurrentBuildWhere
				Message Actions
					On PAM_POPULATE
						Set sInitialWhere = sBuildWhere
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLTABLEPOPNAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_REPOPULATE
						Call TableRePopulate( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLTABLEPOPNAME, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_SEARCH
						Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLTABLEPOPNAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_RESET
						Call TableReset( hWndForm, colCustNo )
					On PAM_NOROWS
						Call SalMessageBox( 'No rows were found', 'Customer & Address Query', MB_Ok )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, 10 )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set sInitialWhere = ''
						Set sSQLTABLEPOPNAME = ' CUSTOMER_MASTER '
						Set sORDERBY = ' ORDER BY CUST_NAME, BUS_NAME '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )

				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					Sql Handle: hLocalSqlDoTbl
					Boolean: bLocalSqlDoTbl
					Sql Handle: hLocalSqlExtra
					Boolean: bLocalSqlExtra
					String: sSQLTABLENAME
					String: sSQLTABLEPOPNAME
					String: sORDERBY
					String: sWHEREROWID
					!
					Boolean: bExists
					Boolean: bEdit
					Boolean: bFound
					Number: nInd
					String: sSqlNPACultExists
					String: sSqlNPARootExists
					String: sSqlExtrasCult
					String: sQueryTmpStr
					String: sCurrentBuildWhere
				Message Actions
					On PAM_POPULATE
						If frmReceiveNPAs.dfCurrYr < WhichSeasonYear( SalDateCurrent(  ) ) AND frmReceiveNPAs.dfCurrYr != 77 AND NOT bForceCurrentOrderFile
							Set sSQLTABLEPOPNAME = ' CUST_ORDER_HISTORY, STOCK_ITEM '
							Set sSQLTABLENAME = ' CUST_ORDER_HISTORY '
						Else
							Set sSQLTABLEPOPNAME = ' CUSTOMER_ORDER, STOCK_ITEM '
							Set sSQLTABLENAME = ' CUSTOMER_ORDER '
						Set bFound = FALSE
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLTABLEPOPNAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_REPOPULATE
						Set bFound = FALSE
						Call TableRePopulate( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLTABLEPOPNAME, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_SEARCH
						If frmReceiveNPAs.dfCurrYr < WhichSeasonYear( SalDateCurrent(  ) ) AND frmReceiveNPAs.dfCurrYr != 77 AND NOT bForceCurrentOrderFile
							Set sSQLTABLEPOPNAME = ' CUST_ORDER_HISTORY, STOCK_ITEM '
							Set sSQLTABLENAME = ' CUST_ORDER_HISTORY '
						Else
							Set sSQLTABLEPOPNAME = ' CUSTOMER_ORDER, STOCK_ITEM '
							Set sSQLTABLENAME = ' CUSTOMER_ORDER '
						Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLTABLEPOPNAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					! denormalising data - the sam fetch row here was checking if the cult or rootstock
							was NPA reqd if not it was deleting the row from the table - these shouldnt have
							been appearing anyway cos the where column specifies where NPA sent = y
					! On SAM_FetchRow
						 If SqlFetchRow( hLocalSqlPopTbl, lParam, nInd )
							 If SqlExists( sSqlNPACultExists, bExists )
								 If bExists
									 Call MySqlPrepExecFetch( hLocalSqlExtra, sSqlExtrasCult, nInd )
									 Set bFound = TRUE	
								 Else If SqlExists( sSqlNPARootExists, bExists )
									 If bExists
										 Call MySqlPrepExecFetch( hLocalSqlExtra, sSqlExtrasCult, nInd )
										 Set bFound = TRUE	
									 Else 
										 Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
										 Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
					On PAM_RESET
						Call TableReset( hWndForm, colYr )
					On PAM_DONTREFRESHROWID
						Return TRUE
					On PAM_NOROWS
						If NOT bFound
							Call SalMessageBox( 'No SENT NPAs were found in this customers orders.', 'Receive Customer NPA', MB_Ok )
					On PAM_WRITEINSERTSUPDATES
						Call TableSaveChanges( hWndForm, hLocalSqlDoTbl, 'Receive NPAs', sSQLTABLENAME, sWHEREROWID, bEdit, TRUE )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, 10 )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bLocalSqlDoTbl = SqlConnect( hLocalSqlDoTbl ) 
						If bLocalSqlDoTbl
							Call SqlSetLockTimeout( hLocalSqlDoTbl, 10 )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bLocalSqlExtra = SqlConnect( hLocalSqlExtra ) 
						If bLocalSqlExtra
							Call SqlSetLockTimeout( hLocalSqlExtra, 10 )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bEdit = FALSE
						Set sSQLTABLEPOPNAME = ' CUSTOMER_ORDER, STOCK_ITEM '
						Set sSQLTABLENAME = ' CUSTOMER_ORDER '
						Set sWHEREROWID = ' WHERE 
								  Cust_No = :frmReceiveNPAs.tblOrders.colCustNo AND 
								  Order_Date_Time = :frmReceiveNPAs.tblOrders.colOrderDateTime '
						Set sORDERBY = ' ORDER BY ORDER_DATE_TIME '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
						If bLocalSqlDoTbl
							Call SqlDisconnect( hLocalSqlDoTbl )
						If bLocalSqlExtra
							Call SqlDisconnect( hLocalSqlExtra )

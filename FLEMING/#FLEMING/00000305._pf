			Pushbutton: pbQuery
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Query - F7
				Window Location and Size
					Left:   2.25"
					Top:    4.635"
					Width:  1.1"
					Width Editable? Yes
					Height: 0.292"

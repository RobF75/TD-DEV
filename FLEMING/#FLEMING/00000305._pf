			Pushbutton: pbReceiveNPA
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Received NPAs from -  F10
				Window Location and Size
					Left:   1.913"
					Top:    4.708"
					Width:  3.25"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: F10
				Font Name: Default
				Font Size: Default
				Font Enhancement: Italic
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						If NOT SalTblAnyRows( tblQCust, ROW_Selected, 0 )
							Call SalMessageBox( 'No Customer selected', 'Query Customer', MB_Ok )
							Return FALSE
						Call SalWaitCursor( TRUE )
						Set bNoNPARequired = FALSE
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( tblQCust, nRow, ROW_Selected, 0 )
							Call SalTblFetchRow( tblQCust, nRow )
							Set sSqlExists = 'SELECT Customer_Type.NPA_Required 
									FROM Customer_Master, Customer_Type 
									WHERE Customer_Master.Cust_No = :frmQCust.tblQCust.colCustNo AND 
									  Customer_Master.Customer_Type = Customer_Type.Cust_Type AND
									  Customer_Type.NPA_Required = \'Y\''
							If SqlExists( sSqlExists, bExists )
								If NOT bExists
									Call SalTblSetRowFlags( tblQCust, nRow, ROW_Selected, FALSE )
									Set bNoNPARequired = TRUE
						If NOT SalTblAnyRows( tblQCust, ROW_Selected, 0 )
							Call SalMessageBox( 'Your selected customers are all flagged as NOT Requiring NPAs.  Please select some other Customer!', 'Query Customer', MB_Ok )
							Call SalWaitCursor( FALSE )
							Return FALSE
						If bNoNPARequired
							Call SalMessageBox( ' One or More of your selected customers were flagged as NOT Requiring NPAs.  These will not appear in the Receive NPAs table when your moving between selected customers with PREVIOUS / NEXT buttons.', 'Warning', MB_Ok )
						!
						Set nRow = TBL_MinRow
						Call SalTblFindNextRow( tblQCust, nRow, ROW_Selected, 0 )
						Call SalTblFetchRow( tblQCust, nRow )
						!
						Call PushWndHdl ( tblQCust )
						Call PushWndHdl ( hWndItem )
						Call SalSendMsg( hWndItem, PAM_SENDDATATOCHILD, 0, 0 )
						Call SalDisableWindow ( hWndItem ) 
						Set hWndCalled = SalCreateWindow( frmReceiveNPAs, hWndForm )
					On PAM_SENDDATATOCHILD
						Call PushNumber( frmQCust.tblQCust.colCustNo )
						Call PushString( frmQCust.tblQCust.colCustName )
						Return TRUE
					On PAM_ENABLE
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
					On PAM_QUERYDISABLE
						If wParam
							Call SalDisableWindow( hWndItem )
						Else
							Call SalEnableWindow( hWndItem )

.head 5 +  Message Actions
.head 6 +  On PAM_clsPB_CLICK
.head 7 +  If rbSelectedItems
.head 8 -  Set sItemType = 'SELECTED'
.head 8 +  If SalSendMsg( tblSelectedItems, PAM_clsPRITMINV_GETSELECTEDITEMS, 0, 0 )
.head 9 -  Call PopString( sSelectedItemNoList, TRUE )
.head 8 +  Else
.head 9 -  Call SalMessageBox( 'Please select some items first, or choose All Items.', 'Warning', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Set sItemType = 'ALL'
.head 7 -  !
.head 7 +  If rbView
.head 8 -  Set sReportType = 'VIEW'
.head 7 +  Else
.head 8 -  Set sReportType = 'PRINT'
.head 7 -  !
.head 7 +  If rbSimple
.head 8 -  Set sInventoryType = 'SIMPLE'
.head 7 +  Else If rbComplex
.head 8 -  Set sInventoryType = 'COMPLEX'
.head 7 +  Else
.head 8 -  Set sInventoryType = 'BASIC'
.head 7 +  If hWndReport = hWndNULL
.head 8 -  Set hWndReport = SalCreateWindow( frmPrintAssignedInventory, hWndForm, sSelectedItemNoList, 
ccSeasonYear.GetSeasonYear( ), sItemType, sReportType, sInventoryType )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Call SalMessageBox( 'Please close down your first report!', 'Warning', MB_Ok )
.head 8 -  Return FALSE

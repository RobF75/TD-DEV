.head 4 -  Set sReportType = sReportPrintOrView
.head 3 +  On SAM_ReportStart
.head 4 +  If sItemType = 'ALL'
.head 5 -  Set sSql = "SELECT 
  Stock_Item.Item_No, 
  @UPPER( Stock_Item.Variety_Type ), 
  @UPPER( Stock_Item.Variety ), 
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Generic_Stock_Item, 
  Stock_Item.CV_Non_Prop_Flag, 
  Stock_Item.RT_Non_Prop_Flag, 
  Stock_Item.CV_Not_Sale_Flag, 
  Stock_Item.RT_Not_Sale_Flag, 
  Stock_Item_Sale.Tot_Avail, 
  Stock_Item_Sale.Amt_Graded, 
  Stock_Item_Sale.Amt_Growing, 
  Stock_Item_Sale.Est_Avail_Count, 
  Stock_Item_Sale.Amt_Shipped, 
  Stock_Item_Sale.Amt_Subs_Shipped, 
  Stock_Item_Sale.Amt_On_Order, 
  Stock_Item_Sale.On_Ord_As_Subs, 
  Stock_Item_Sale.Sold_Out_Flag, 
  Stock_Item_Sale.Stock_Item_Comment, 
  Stock_Item.GC_Reserve, 
  Stock_Item_Sale.Total_Graded
FROM 
  Stock_Item,
  Stock_Item_Sale 
INTO 
  :frmPrintAssignedInventory.nItemNo, 
  :frmPrintAssignedInventory.sUpperVarietyType,
  :frmPrintAssignedInventory.sUpperVariety,
  :frmPrintAssignedInventory.sUpperCultDesc,
  :frmPrintAssignedInventory.sUpperRootDesc, 
  :frmPrintAssignedInventory.sTreeType,
  :frmPrintAssignedInventory.sCultDesc,
  :frmPrintAssignedInventory.sRootDesc,
  :frmPrintAssignedInventory.sGeneric,
  :frmPrintAssignedInventory.sCVNPAFlag,
  :frmPrintAssignedInventory.sRTNPAFlag,
  :frmPrintAssignedInventory.sCVNotSaleFlag, 
  :frmPrintAssignedInventory.sRTNotSaleFlag, 
  :frmPrintAssignedInventory.nOnHand,
  :frmPrintAssignedInventory.nGraded,
  :frmPrintAssignedInventory.nGrowing,
  :frmPrintAssignedInventory.nEstGrowing,
  :frmPrintAssignedInventory.nShipped,
  :frmPrintAssignedInventory.nShippedAsSubs,
  :frmPrintAssignedInventory.nOnOrder,
  :frmPrintAssignedInventory.nOnOrdAsSubs,
  :frmPrintAssignedInventory.sSoldOutFlag,
  :frmPrintAssignedInventory.sComments,
  :frmPrintAssignedInventory.nGCReserve,
  :frmPrintAssignedInventory.nTotalGraded 
 WHERE 
   NOT Stock_Item.Stock_Type = 'C' AND 
   Stock_Item.Item_No = Stock_Item_Sale.Stock_Item_No AND 
   Stock_Item_Sale.Year_Of_Sale = :frmPrintAssignedInventory.nYear AND 
   NOT ( Amt_Growing = 0 AND Amt_Graded = 0 AND 
             Amt_Shipped = 0 AND Amt_Subs_Shipped = 0 AND 
             Amt_On_Order = 0 AND On_Ord_As_Subs = 0 ) 
ORDER BY 2,3,9,4,5,6,1"
.head 4 +  Else
.head 5 -  Set sSql = 'SELECT 
  Stock_Item.Item_No, 
  @UPPER( Stock_Item.Variety_Type ), 
  @UPPER( Stock_Item.Variety ), 
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Generic_Stock_Item, 
  Stock_Item.CV_Non_Prop_Flag, 
  Stock_Item.RT_Non_Prop_Flag, 
  Stock_Item.CV_Not_Sale_Flag, 
  Stock_Item.RT_Not_Sale_Flag, 
  Stock_Item_Sale.Tot_Avail, 
  Stock_Item_Sale.Amt_Graded, 
  Stock_Item_Sale.Amt_Growing, 
  Stock_Item_Sale.Est_Avail_Count, 
  Stock_Item_Sale.Amt_Shipped, 
  Stock_Item_Sale.Amt_Subs_Shipped, 
  Stock_Item_Sale.Amt_On_Order, 
  Stock_Item_Sale.On_Ord_As_Subs, 
  Stock_Item_Sale.Sold_Out_Flag, 
  Stock_Item_Sale.Stock_Item_Comment, 
  Stock_Item.GC_Reserve, 
  Stock_Item_Sale.Total_Graded
FROM 
  Stock_Item,
  Stock_Item_Sale 
INTO 
  :frmPrintAssignedInventory.nItemNo, 
  :frmPrintAssignedInventory.sUpperVarietyType,
  :frmPrintAssignedInventory.sUpperVariety,
  :frmPrintAssignedInventory.sUpperCultDesc,
  :frmPrintAssignedInventory.sUpperRootDesc, 
  :frmPrintAssignedInventory.sTreeType,
  :frmPrintAssignedInventory.sCultDesc,
  :frmPrintAssignedInventory.sRootDesc,
  :frmPrintAssignedInventory.sGeneric,
  :frmPrintAssignedInventory.sCVNPAFlag,
  :frmPrintAssignedInventory.sRTNPAFlag,
  :frmPrintAssignedInventory.sCVNotSaleFlag, 
  :frmPrintAssignedInventory.sRTNotSaleFlag, 
  :frmPrintAssignedInventory.nOnHand,
  :frmPrintAssignedInventory.nGraded,
  :frmPrintAssignedInventory.nGrowing,
  :frmPrintAssignedInventory.nEstGrowing,
  :frmPrintAssignedInventory.nShipped,
  :frmPrintAssignedInventory.nShippedAsSubs,
  :frmPrintAssignedInventory.nOnOrder,
  :frmPrintAssignedInventory.nOnOrdAsSubs,
  :frmPrintAssignedInventory.sSoldOutFlag,
  :frmPrintAssignedInventory.sComments,
  :frmPrintAssignedInventory.nGCReserve,
  :frmPrintAssignedInventory.nTotalGraded 
 WHERE 
   Stock_Item.Item_No IN ( ' || sSelectedItemNoList || ' ) AND 
   Stock_Item.Item_No = Stock_Item_Sale.Stock_Item_No AND 
   Stock_Item_Sale.Year_Of_Sale = :frmPrintAssignedInventory.nYear  AND 
   NOT ( Amt_Growing = 0 AND Amt_Graded = 0 AND 
             Amt_Shipped = 0 AND Amt_Subs_Shipped = 0 AND 
             Amt_On_Order = 0 AND On_Ord_As_Subs = 0 ) 
ORDER BY 2,3,9,4,5,6,1'
.head 4 -  Call fcSqlHandle.PrepareSetup( sSql )
.head 4 -  Call SqlVarSetup( fcSqlHandle.hSqlHandle )
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchInit
.head 4 -  Call fcSqlHandle.PrepareAndExecute( )
.head 4 -  Set sCurrentCultVariety = ''
.head 4 -  Set nBreakTotGrowing = 0
.head 4 -  Set nBreakTotEstGrow = 0
.head 4 -  Set nBreakTotOnOrder = 0
.head 4 -  Set nBreakTotShip = 0
.head 4 -  Set nTotalGrowing = 0
.head 4 -  Set nTotalEstGrow = 0
.head 4 -  Set nTotalOnOrder = 0
.head 4 -  Set nTotalShip = 0
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchNext
.head 4 +  If fcSqlHandle.FetchNext( nInd )
.head 5 -  !
.head 5 -  Call CalculateSubstitutes( nItemNo, nYear, nSubs, SH_cls_Execute )
.head 5 -  Set nAvail = nSubs + nOnHand
.head 5 -  !
.head 5 +  If sGeneric = 'Y' OR sGeneric = 'y'
.head 6 -  Set sGeneric = 'Gen'
.head 5 +  Else
.head 6 -  Set sGeneric = ' '
.head 5 -  !
.head 5 +  If sCVNPAFlag = 'Y' OR sCVNPAFlag = 'y'
.head 6 -  Set sCVNPAFlag = '*'
.head 5 +  Else
.head 6 -  Set sCVNPAFlag = ' '
.head 5 -  !
.head 5 +  If sRTNPAFlag = 'Y' OR sRTNPAFlag = 'y'
.head 6 -  Set sRTNPAFlag = '*'
.head 5 +  Else
.head 6 -  Set sRTNPAFlag = ' '
.head 5 -  !
.head 5 +  If sSoldOutFlag = 'N' OR sRTNPAFlag = 'n'
.head 6 -  Set sSoldOutFlag = ' '
.head 5 -  !
.head 5 +  If sCVNotSaleFlag = 'Y' OR sCVNotSaleFlag = 'y'
.head 6 -  Set sNotSale = 'Y'
.head 5 +  Else If sRTNotSaleFlag = 'Y' OR sRTNotSaleFlag = 'y'
.head 6 -  Set sNotSale = 'Y'
.head 5 +  Else
.head 6 -  Set sNotSale = ' '
.head 5 -  !
.head 5 +  If sUpperVariety = sCurrentCultVariety
.head 6 -  Set nBreakTotGrowing = nBreakTotGrowing + nGrowing
.head 6 -  Set nBreakTotEstGrow = nBreakTotEstGrow + nEstGrowing
.head 6 -  Set nBreakTotOnOrder = nBreakTotOnOrder + nOnOrder
.head 6 -  Set nBreakTotShip = nBreakTotShip + nShipped
.head 5 +  Else
.head 6 -  Set sCurrentCultVariety = sUpperVariety
.head 6 -  Set nBreakTotGrowing = nGrowing
.head 6 -  Set nBreakTotEstGrow = nEstGrowing
.head 6 -  Set nBreakTotOnOrder = nOnOrder
.head 6 -  Set nBreakTotShip = nShipped
.head 5 -  Set nTotalGrowing = nTotalGrowing + nGrowing
.head 5 -  Set nTotalEstGrow = nTotalEstGrow + nEstGrowing
.head 5 -  Set nTotalOnOrder = nTotalOnOrder + nOnOrder
.head 5 -  Set nTotalShip = nTotalShip + nShipped
.head 5 -  !
.head 5 -  ! Call GetItemTotalBudCount( nItemNo, nYear, nItemTotalBudCount, SH_cls_Execute )
.head 5 -  Call GetItemTotalBFSCounts( nItemNo, nYear, nItemTotalBudCount, nItemTotalFirstCount, nItemTotalSecondCount, SH_cls_Execute )
.head 5 +  If NOT sGeneric = 'Y'
.head 6 -  Call CalcItemsGCAvailORAvail(  nItemNo, nYear, nGCAvail, nORAvail, SH_cls_Execute )
.head 5 -  !
.head 5 -  Return TRUE
.head 4 +  Else
.head 5 -  Return FALSE
.head 3 +  On SAM_ReportFinish
.head 4 -  Call fcSqlHandle.Disconnect( )
.head 4 -  Call CalculateSubstitutes( 0, 0, nSubs, SH_cls_Disconnect )
.head 4 -  ! Call GetItemTotalBudCount( 0, 0, nItemTotalBudCount, SH_cls_Disconnect )
.head 4 -  Call GetItemTotalBFSCounts( 0, 0, nItemTotalBudCount, nItemTotalFirstCount, nItemTotalSecondCount, SH_cls_Disconnect )
.head 4 -  Call CalcItemsGCAvailORAvail(  0, 0, nGCAvail, nORAvail, SH_cls_Disconnect )
.head 4 -  Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )

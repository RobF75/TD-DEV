.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT 
  Substitutes.Substitute_Item_No, 
  Substitutes.Sub_Up_To_Max, 
  Stock_Item_Sale.Tot_Avail 
FROM 
  Substitutes,  
  Stock_Item_Sale 
WHERE 
   Substitutes.Stock_Item_No = :1 AND 
   Substitutes.Substitute_Item_No = Stock_Item_Sale.Stock_Item_No AND 
   Stock_Item_Sale.Year_Of_Sale = :2 
ORDER BY 
  Substitutes.Subs_Priority "
.head 7 -  Set sName = 'GETGENSBITMS2'
.head 7 -  Set sBind = ':nGenItemNo, :nYear'
.head 7 -  Set sInto = ':nGotSubItemNo, :nGotSubUpToMax, :nGotSubTotAvail'
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set nGCAvail = NUMBER_Null
.head 7 -  Set nORAvail = NUMBER_Null
.head 7 -  !
.head 7 -  Set nGotSubItemNo = NUMBER_Null
.head 7 -  Set nGotSubUpToMax = NUMBER_Null
.head 7 -  Set nGotSubTotAvail = NUMBER_Null
.head 7 -  !
.head 7 +  If CalcItemsGenGCReserve( nItemNo, nYear, nGenItemNo, nGenGCReserve, SH_cls_Execute )
.head 8 +  If nGenItemNo > 0
.head 9 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 10 -  Set bFound = FALSE
.head 10 +  While haSqlHandles[ nOurHandleNo ].FetchNext( nInd ) AND NOT bFound
.head 11 +  If nGotSubUpToMax > 0
.head 12 +  If nGotSubTotAvail > nGotSubUpToMax
.head 13 +  If nGenGCReserve > nGotSubUpToMax
.head 14 -  Set nGCAvail = nGotSubUpToMax
.head 13 +  Else
.head 14 -  Set nGCAvail = nGenGCReserve
.head 13 -  Set nORAvail = nGotSubTotAvail - nGCAvail
.head 12 +  Else
.head 13 -  Set nGCAvail = nGotSubTotAvail
.head 13 -  Set nORAvail = 0
.head 11 +  Else
.head 12 +  If nGenGCReserve > nGotSubTotAvail
.head 13 -  Set nGCAvail = nGotSubTotAvail
.head 13 -  Set nORAvail = 0
.head 12 +  Else
.head 13 -  Set nGCAvail = nGenGCReserve
.head 13 -  Set nORAvail = nGotSubTotAvail - nGenGCReserve
.head 11 -  !
.head 11 -  Set nGenGCReserve = nGenGCReserve - nGCAvail
.head 11 -  !
.head 11 +  If nGotSubItemNo = nItemNo
.head 12 +  If nGenGCReserve+nGCAvail <= 0
.head 13 -  Set nGCAvail = NUMBER_Null
.head 13 -  Set nORAvail = NUMBER_Null
.head 12 -  Set bFound = TRUE
.head 11 -  !
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Else
.head 9 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect

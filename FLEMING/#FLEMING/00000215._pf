.head 6 +  Else
.head 7 -  Set sItemNoList = sItemNoList || ', ' || SalNumberToStrX( colItemNo, 0 ) 
.head 6 +  If nSelectedItemYear = NUMBER_Null
.head 7 -  Set nSelectedItemYear = colYear
.head 6 -  Return TRUE

.head 7 +  If NOT CalcItemsGenGCReserve( 0, 0, nGenItemNo, nGenGCReserve, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk

.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETITMGNITM2' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT 
  T2.Item_No, 
  T2.GC_Reserve - 
  ( Stock_Item_Sale.Amt_On_Order + 
    Stock_Item_Sale.On_Ord_As_Subs + 
    Stock_Item_Sale.Amt_Shipped + Amt_Subs_Shipped )
FROM 
  Stock_Item T1, 
  Substitutes,  
  Stock_Item T2, 
  Stock_Item_Sale  
WHERE 
   T1.Item_No = :1 AND  
   ( T1.Generic_Stock_Item = 'N' OR 
   T1.Generic_Stock_Item IS NULL ) AND 
   T1.Item_No = Substitutes.Substitute_Item_No AND 
   Substitutes.Stock_Item_No = T2.Item_No  AND 
   Substitutes.Stock_Item_No = Stock_Item_Sale.Stock_Item_No AND 
   Stock_Item_Sale.Year_Of_Sale = :2 "
.head 7 -  Set sName = 'GETITMGNITM2'
.head 7 -  Set sBind = ':nItemNo, :nYear'
.head 7 -  Set sInto = ':nGotGenItemNo, :nGotGenGCReserve'
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set nGenItemNo = NUMBER_Null
.head 7 -  Set nGenGCReserve = NUMBER_Null
.head 7 -  Set nGotGenItemNo = NUMBER_Null
.head 7 -  Set nGotGenGCReserve = NUMBER_Null
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 -  Set nGenItemNo = nGotGenItemNo
.head 9 -  Set nGenGCReserve = nGotGenGCReserve
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )

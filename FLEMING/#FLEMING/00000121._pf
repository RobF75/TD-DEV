		Functions
			Function: ExtractFileNumber
				Description:
				Returns
					Number:
				Parameters
					String: sBCFileName
				Static Variables
				Local variables
					String: sNum
					String: sChar
					Number: nPos
				Actions
					Set sNum = ''
					Set nPos = SalStrLength( sBCFileName ) - 1
					While nPos >= 0
						Set sChar = SalStrMidX( sBCFileName, nPos, 1 )
						If sChar = '0' OR 
								sChar = '1' OR 
								sChar = '2' OR 
								sChar = '3' OR 
								sChar = '4' OR 
								sChar = '5' OR 
								sChar = '6' OR 
								sChar = '7' OR 
								sChar = '8' OR 
								sChar = '9'
							Set sNum = sChar || sNum
						Set nPos = nPos - 1
					If sNum = ''
						Return 0
					Else
						Return SalStrToNumber( sNum )
		Window Parameters
		Window Variables
			Boolean: bStarted
			Number: nNumQueueFiles
			String: sQueuePath
			String: saQueuelFiles[*]
			Number: naQueueSizes[*]
			Date/Time: dtaQueueTimeStamps[*]
			Number: naQueueAttributes[*]
			!
			Number: nPos
			Number: nRow
			!
			String: sTmp
		Message Actions
			On SAM_CreateComplete
				Call SalTblSetTableFlags( hWndForm, TBL_Flag_SuppressRowLines, TRUE )
				Call SalTblSetTableFlags( hWndForm, TBL_Flag_SuppressLastColLine, TRUE )
				Call SalSendMsg( hWndForm, PAM_clsTBL_POPULATE, 0, 0 )
			On PAM_clsTBL_POPULATE
				Call SalTblReset( hWndForm )
				Set sQueuePath = OurGetIniFileParameter( 'GENERAL', 'BCLabelsPath', 'C:\TEMP' )
				Set nNumQueueFiles = VisDosEnumFileInfo( sQueuePath || '\\*.bcl', FA_Standard, saQueuelFiles, naQueueSizes, dtaQueueTimeStamps, naQueueAttributes )
				Set nPos = 0
				While nPos < nNumQueueFiles
					Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
					Call SalTblSetContext( hWndForm, nRow )
					Call SalTblSetRowFlags( hWndForm, nRow, ROW_HideMarks, TRUE )
					!
					Set colFullPathFileName = SalStrLowerX( sQueuePath || '\\' || saQueuelFiles[ nPos ] )
					Set colNoPathFileName = saQueuelFiles[ nPos ]
					Set colStatus = 'Paused'
					Set colSize = naQueueSizes[ nPos ]
					Set colGeneratedAt = dtaQueueTimeStamps[ nPos ]
					!
					Set colExtractedNumber = ExtractFileNumber( colNoPathFileName )
					!
					Set nPos = nPos + 1
				!
				Call SalTblSortRows( hWndForm, 1, TBL_SortIncreasing )
				!
				If nNumQueueFiles < 0
					Set nNumQueueFiles = 0
				Call SalStatusSetText( hWndForm, SalNumberToStrX( nNumQueueFiles, 0 )||' jobs in queue' )
				Set bStarted = TRUE
			On PAM_clsTBL_ROWACTION
				If wParam = 1
					Set sTmp = OurGetIniFileParameter( 'GENERAL', 'NPrint', 'C:\\TEMP' )||' '||colFullPathFileName||' q=barcode nb nt nff'
					Call WinExec( sTmp, 0 )
					Call SalPause( 1200 )
				Set sTmp = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'C:\\TEMP' )||'\\'||colNoPathFileName
				If VisFileCopy( colFullPathFileName, sTmp )
					Call VisFileDelete( colFullPathFileName )
				Return TRUE

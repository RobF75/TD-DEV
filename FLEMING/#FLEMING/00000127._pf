  Q1.Cust_No = :nDUPCustNo AND 
  NOT EXISTS 
  (
    SELECT 
      Q2.Sys_Date_Time 
    FROM 
      Quotation Q2
    WHERE 
      Q2.Cust_No = :nORGCustNo AND 
      Q2.Year_Of_Sale = Q1.Year_Of_Sale AND 
      Q2.Stock_Item_No = Q1.Stock_Item_No
  ) "

.head 5 +    Select Case nActionType
.head 6 +    Case SH_cls_Execute
.head 7 -    Set sSql = "SELECT 
  Customer_Type,
  Region_Id,
  Cust_Name,
  Bus_Name,
  Cust_Comments,
  FNA_Flag,
  Cont_Price_Flag,
  Dep_Reqd_Flag,
  COD_Flag,
  Dont_Sell_Flag,
  Mailing_List_Flag,
  Ass_Cust_No,
  ACN_No,
  Prev_93YearOrdAmt,
  Prev_92YearOrdAmt,
  Prev_91YearOrdAmt,
  Prev_90YearOrdAmt,
  NPA_Refusal_Flag,
  Bar_Code_Lbls_Reqd,
  Cust_Credit_Limit,
  Credit_Term,
  Cust_AR_Balance,
  Bad_Debt_Flag,
  Perc_Cod,
  COD_Requested_Flag,
  Sv_Chrg_From_Date,
  Override_FrCode,
  Service_Charge,
  Royalty_Owner_code,
  Def_Deliv_Instruct,
  Def_Deliv_type,
  Init_Credit_Term,
  Order_Notes,
  Label_Notes,
  Load_Notes,
  Closed_Account,
  Credit_Stop,
  Purch_Ord_No_Reqd,
  Invoice_Notes,
  Send_Org_Inv,
  Pay_Bef_Despatch,
  With_Debt_Collect,
  Accnt_Open_Date,
  Accnt_Close_Date,
  Added_By,
  Days_Of_Credit,
  Comb_Statement 
FROM 
  Customer_Master 
INTO 
  :sGotOrgCustomerType,
  :sGotOrgRegionId,
  :sGotOrgCustName,
  :sGotOrgBusName,
  :sGotOrgCustComments,
  :sGotOrgFNAFlag,
  :sGotOrgContPriceFlag,
  :sGotOrgDepReqdFlag,
  :sGotOrgCODFlag,
  :sGotOrgDontSellFlag,
  :sGotOrgMailingListFlag,
  :nGotOrgAssCustNo,

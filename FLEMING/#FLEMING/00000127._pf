.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Call SalSendClassMessage( PAM_cls_SETINSTANCEVARS, wParam, lParam )
.head 6 -  Set sSQLPopHandle = 'SELECT 
  Trans_User_Id,
  Trans_Sysdatetime,
  Cust_No,
  Reference_Id,
  Transaction_Type,
  Transaction_Amount,
  Transaction_Date,
  Transaction_By,
  Trans_Amount_Outst,
  Label_Charges,
  Postal_Charges,
  Rail_Charges,
  Freight_Charges,
  Transaction_Notes,
  Trans_Credit_Units,
  Transaction_Code,
  Credit_note_no,
  Royalties,
  Days_To_Pay
FROM 
  Transaction 
WHERE 
  Cust_No = :1'
.head 6 -  Set sNAMEPopHandle = 'POPDBTRANS'
.head 6 -  Set sBINDPopHandle = ':mdiCashAppDebug.dfCustNo'
.head 6 -  Set sINTOPopHandle = ':mdiCashAppDebug.tblTransaction.colTransUserId,
:mdiCashAppDebug.tblTransaction.colTransSysDT,
:mdiCashAppDebug.tblTransaction.colCustNo,
:mdiCashAppDebug.tblTransaction.colReferenceId,
:mdiCashAppDebug.tblTransaction.colTransType,
:mdiCashAppDebug.tblTransaction.colTransAmount,
:mdiCashAppDebug.tblTransaction.colTransDate,
:mdiCashAppDebug.tblTransaction.colTransBy,
:mdiCashAppDebug.tblTransaction.colTransAmtOutstand,

  :nGotOrgPrev93YearOrdAmt,
  :nGotOrgPrev92YearOrdAmt,
  :nGotOrgPrev91YearOrdAmt,
  :nGotOrgPrev90YearOrdAmt,
  :sGotOrgNPARefusalFlag,
  :sGotOrgBarCodeLblsReqd,
  :nGotOrgCustCreditLimit,
  :nGotOrgCreditTerm,
  :nGotOrgCustARBalance,
  :sGotOrgBadDebtFlag,

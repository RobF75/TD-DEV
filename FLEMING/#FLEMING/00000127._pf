  :dtGotOrgAccntOpenDate,
  :dtGotOrgAccntCloseDate,
  :sGotOrgAddedBy,
  :nGotOrgDaysOfCredit,
  :sGotOrgCombStatement
WHERE 
  Cust_No = :nORGCustNo "

.head 5 +  Function: ExtractSELECTPart
.head 6 -  Description: 
.head 6 -  Returns 
.head 6 +  Parameters 
.head 7 -  String: sSqlStatement
.head 7 -  Receive String: sSELECTPart
.head 6 -  Static Variables 
.head 6 -  Local variables 
.head 6 +  Actions 
.head 7 -  Set sSELECTPart = SalStrLeftX( sSqlStatement, StringScan( sSqlStatement, 'FROM', TRUE ) )
.head 5 +  Function: ExtractFROMPart
.head 6 -  Description: 
.head 6 -  Returns 
.head 6 +  Parameters 
.head 7 -  String: sSqlStatement
.head 7 -  Receive String: sFROMPart
.head 6 -  Static Variables 
.head 6 +  Local variables 
.head 7 -  Number: nFromStart
.head 7 -  Number: nWhereStart
.head 7 -  Number: nOrderStart
.head 6 +  Actions 
.head 7 -  Set nFromStart = StringScan( sSqlStatement, 'FROM', TRUE )
.head 7 -  Set nWhereStart = StringScan( sSqlStatement, 'WHERE', TRUE )
.head 7 +  If nWhereStart = -1
.head 8 -  Set nOrderStart = StringScan( sSqlStatement, 'ORDER BY', TRUE )
.head 8 +  If nOrderStart = -1
.head 9 -  Set nOrderStart = StringScan( sSqlStatement, 'GROUP BY', TRUE )
.head 9 +  If nOrderStart = -1
.head 10 -  Set sFROMPart = SalStrRightX( sSqlStatement, SalStrLength( sSqlStatement ) - nFromStart )
.head 9 +  Else 
.head 10 -  Set sFROMPart = SalStrMidX( sSqlStatement, nFromStart, nOrderStart - nFromStart )
.head 8 +  Else 
.head 9 -  Set sFROMPart = SalStrMidX( sSqlStatement, nFromStart, nOrderStart - nFromStart )
.head 7 +  Else 
.head 8 -  Set sFROMPart = SalStrMidX( sSqlStatement, nFromStart, nWhereStart - nFromStart )
.head 5 +  Function: ExtractWHEREPart
.head 6 -  Description: 
.head 6 -  Returns 
.head 6 +  Parameters 
.head 7 -  String: sSqlStatement
.head 7 -  Receive String: sWHEREPart
.head 6 -  Static Variables 
.head 6 +  Local variables 
.head 7 -  Number: nWhereStart
.head 7 -  Number: nOrderStart
.head 6 +  Actions 
.head 7 -  Set nWhereStart = StringScan( sSqlStatement, 'WHERE', TRUE )
.head 7 +  If nWhereStart = -1
.head 8 -  Set sWHEREPart = ''

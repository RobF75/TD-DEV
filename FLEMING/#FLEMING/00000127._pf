.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Call SalSendClassMessage( PAM_cls_SETINSTANCEVARS, wParam, lParam )
.head 6 -  Set sSQLPopHandle = 'SELECT 
  DISTINCT Cash_Application.Cust_No 
FROM 
  Cash_Application
WHERE 
  NOT Cash_Application.Receipt_User_Id IS NULL AND 
  NOT Cash_Application.Receipt_Sysdatetim IS NULL AND  
  NOT EXISTS 
  (
    SELECT 
      Cash_Receipt.Rcpt_Sysdatetime 
    FROM 
      Cash_Receipt 
    WHERE 
        Cash_Receipt.Receipt_User_Id = Cash_Application.Receipt_User_Id AND 
        Cash_Receipt.Rcpt_Sysdatetime = Cash_Application.Receipt_Sysdatetim
  ) '
.head 6 -  Set sNAMEPopHandle = 'POPCAUMRCPT'

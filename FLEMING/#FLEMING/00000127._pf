.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = "SELECT 
  Cash_Application.Trans_User_Id, 
  Cash_Application.Trans_Sysdatetime 
FROM 
  Cash_Application
WHERE 
  Cash_Application.Cust_No = :1 AND 
  NOT Cash_Application.Trans_User_Id IS NULL AND 
  NOT Cash_Application.Trans_Sysdatetime IS NULL AND  
  NOT EXISTS 
  (
    SELECT 
      Transaction.Trans_Sysdatetime 
    FROM 
      Transaction 
    WHERE 
        Transaction.Trans_User_Id = Cash_Application.Trans_User_Id AND 

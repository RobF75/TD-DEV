				Message Actions
					On SAM_Create
						Call OurWaitCursor( TRUE )
						Set hWndChildTable = hWndNULL
						Set bAddAllowed = FALSE
						Set bSaveAllowed = FALSE
						Set bDeleteAllowed = FALSE
						Set bUnDeleteAllowed = FALSE
						Set bClearSelectAllowed = TRUE
						Set bQueryAllowed = FALSE
						Set bRepopulateAllowed = TRUE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = FALSE
						Set bMoveRowUpOneAllowed = FALSE
						Set bMoveRowDownOneAllowed = FALSE
						Set bZoomTableAllowed = FALSE
						Set nPopOrQueryOnStartUp = TBL_cls_PopulateOnStartUp
						Set hWndActivateButton = hWndNULL
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						If NOT bAddAllowed
							Call SalSendMsg( hWndForm, PAM_clsFRM_ADDHIDE, 0, 0 )
						If NOT bSaveAllowed
							Call SalSendMsg( hWndForm, PAM_clsFRM_SAVEHIDE, 0, 0 )
						If NOT bDeleteAllowed
							Call SalSendMsg( hWndForm, PAM_clsFRM_DELHIDE, 0, 0 )
						If NOT bClearSelectAllowed
							Call SalSendMsg( hWndForm, PAM_clsFRM_CLEARHIDE, 0, 0 )
						If NOT bQueryAllowed
							Call SalSendMsg( hWndForm, PAM_clsFRM_QRYHIDE, 0, 0 )
						If NOT bRepopulateAllowed
							Call SalSendMsg( hWndForm, PAM_clsFRM_REPOPHIDE, 0, 0 )
					On SAM_CreateComplete
						If nPopOrQueryOnStartUp = TBL_cls_PopulateOnStartUp
							Call SalSendMsg( hWndChildTable, PAM_clsTBL_POPULATE, 0, 0 )
						Else If nPopOrQueryOnStartUp = TBL_cls_QueryOnStartUp
							Call SalSendMsg( hWndChildTable, PAM_clsTBL_QUERY, 0, 0 )
						Call SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
						Call SalSetFocus( hWndChildTable )
						Call OurWaitCursor( FALSE )
					! On WM_RBUTTONUP
						  Set hMenu = CreatePopupMenu(  )
						  If bClearSelectAllowed
							  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_ClearMenuId, 'Clear' )
						  If bAddAllowed
							  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_AddMenuId, 'Add' )
						  If bSaveAllowed
							  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_SaveMenuId, 'Save' )
						  If bDeleteAllowed
							  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_DeleteMenuId, 'Delete' )
						  If bUnDeleteAllowed
							  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_UnDeleteMenuId, 'UnDelete' )
						  If bRepopulateAllowed
							  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_RepopMenuId, 'Repop Table' )
						  If bQueryAllowed
							  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_QueryMenuId, 'Query' )
						  If bOrderAllowed
							  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_OrderMenuId, 'Sort Table' )
						  If bReportAllowed
							  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_ReportMenuId, 'Table Report' )
						  If bMoveRowUpOneAllowed
							  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_UpMenuId, 'Move Row Up One' )
						  If bMoveRowDownOneAllowed
							  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_DownMenuId, 'Move Row Down One' )
						  If bZoomTableAllowed
							  Call InsertMenuA( hMenu, 0xFFFFFFFF, MF_BYPOSITION, TBL_cls_ZoomMenuId, 'Zoom Table' )
						! wParam is normally 0, unless the wm_rbuttonup key is trapped in clsTableGeneral then we are setting
								it to TRUE
						  Set nX= SalNumberLow( lParam )
						  Set nY=SalNumberHigh( lParam )
						  Set hWndFocus = SalNumberToWindowHandle( wParam )
						! Then the user pressed the wm_rbuttonup key in a table and we want to get its cursor pos
						  If SalGetType( hWndFocus ) = TYPE_ChildTable
							  Call MapWindowPoints( hWndFocus, hWndForm, nX, nY, 1 )
						  Call ClientToScreen(hWndForm,nX,nY)
						  Call TrackPopupMenu( hMenu, 0x0002, nX, nY, 0, hWndForm, '' )
					! On WM_COMMAND
						  Set nMenu = SalNumberHigh( wParam )
						  If nMenu = 0
							  If lParam = TPM_LeftButton
								  Set nSelectedMenu = SalNumberLow( wParam )
								  If nSelectedMenu = TBL_cls_ClearMenuId
									  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_ClearRow, GEN_CommingFromPopUp )
								  Else If nSelectedMenu = TBL_cls_AddMenuId
									  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_AddRow, GEN_CommingFromPopUp )
								  Else If nSelectedMenu = TBL_cls_SaveMenuId
									  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_SaveRow, GEN_CommingFromPopUp )
								  Else If nSelectedMenu = TBL_cls_DeleteMenuId
									  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_DeleteRow, GEN_CommingFromPopUp )
								  Else If nSelectedMenu = TBL_cls_UnDeleteMenuId
									  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_UnDeleteRow, GEN_CommingFromPopUp )
								  Else If nSelectedMenu = TBL_cls_RepopMenuId
									  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_RePopTable, GEN_CommingFromPopUp )
								  Else If nSelectedMenu = TBL_cls_QueryMenuId
									  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_Query, GEN_CommingFromPopUp )
								  Else If nSelectedMenu = TBL_cls_OrderMenuId
									  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_OrderTable, GEN_CommingFromPopUp )
								  Else If nSelectedMenu = TBL_cls_ReportMenuId
									  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_TableReport, GEN_CommingFromPopUp )
								  Else If nSelectedMenu = TBL_cls_UpMenuId
									  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_MoveUpOne, GEN_CommingFromPopUp )
								  Else If nSelectedMenu = TBL_cls_DownMenuId
									  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_MoveDownOne, GEN_CommingFromPopUp )
								  Else If nSelectedMenu = TBL_cls_ZoomMenuId
									  Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_ZoomTable, GEN_CommingFromPopUp )
					On PAM_cls_EXIT
						! For mdi stuff - some forms may not have hWndChildTable - so check if hWndChildTable is null
						If hWndChildTable = hWndNULL
							Return TRUE
						If SalSendMsg( hWndChildTable, PAM_clsTBL_CHECKCHANGES, 0, 0 )
							If SalSendMsg( hWndChildTable, PAM_clsTBL_ISTABLECHANGED, 0, 0 )
								Call SalGetItemName( hWndActivateButton, sTmp )
								Call SalPostMsg( SalParentWindow( hWndForm ), PAM_cls_CHILDCHANGED, 0, SalHStringToNumber( sTmp ) )
							Set nReturn = SalSendClassMessage( PAM_cls_EXIT, wParam, lParam )
							Return nReturn
						Else
							Return FALSE
					On PAM_cls_REFRESHAFTRCHILDCHANGE
						Return TRUE
					On PAM_cls_CHILDCHANGED
						Call SalShowWindow( hWndForm )
						Call SalBringWindowToTop( hWndForm )
						If SalSendMsg( hWndForm, PAM_cls_REFRESHAFTRCHILDCHANGE, wParam, lParam )
							Call SalSendMsg( hWndForm, PAM_clsTBL_USERACTIONS, TBL_cls_RePopTable, TBL_cls_ChildChanged )
						Return TRUE
					On PAM_clsTBL_USERACTIONS
						Return UserTableActions( hWndChildTable, wParam, lParam )
					On PAM_clsTBL_ALLOWEDACTIONS
						Set nChoice = 0
						If bAddAllowed
							Set nChoice = nChoice | TBL_cls_AddRow
						If bSaveAllowed
							Set nChoice = nChoice | TBL_cls_SaveRow
						If bDeleteAllowed
							Set nChoice = nChoice | TBL_cls_DeleteRow
						If bUnDeleteAllowed
							Set nChoice = nChoice | TBL_cls_UnDeleteRow
						If bRepopulateAllowed
							Set nChoice = nChoice | TBL_cls_RePopTable
						If bClearSelectAllowed
							Set nChoice = nChoice | TBL_cls_ClearRow
						If bQueryAllowed
							Set nChoice = nChoice | TBL_cls_Query
						If bReportAllowed
							Set nChoice = nChoice | TBL_cls_TableReport
						If bOrderAllowed
							Set nChoice = nChoice | TBL_cls_OrderTable
						If bMoveRowDownOneAllowed
							Set nChoice = nChoice | TBL_cls_MoveDownOne
						If bMoveRowUpOneAllowed
							Set nChoice = nChoice | TBL_cls_MoveUpOne
						If bZoomTableAllowed
							Set nChoice = nChoice | TBL_cls_ZoomTable
						Set nChoice2 = SalSendMsg( hWndChildTable, PAM_clsTBL_ALLOWEDACTIONS, wParam, lParam )
						If nChoice2 > 0
							Set nChoice = nChoice | nChoice2
						Return nChoice
					!
					On PAM_clsPB_GETFIRSTREC
						If NOT SalSendMsg( hWndChildTable, PAM_clsTBL_CHECKCHANGES, 0, 0 )
							Return FALSE
						If SalSendMsg( hWndActivateButton, PAM_clsACTIVATE_FIRSTREC, 0, 0 )
							Return SalSendMsg( hWndForm, SAM_CreateComplete, 0, 0 )
						Else
							Return FALSE
					On PAM_clsPB_GETPREVREC
						If NOT SalSendMsg( hWndChildTable, PAM_clsTBL_CHECKCHANGES, 0, 0 )
							Return FALSE
						If SalSendMsg( hWndActivateButton, PAM_clsACTIVATE_PREVREC, 0, 0 )
							Return SalSendMsg( hWndForm, SAM_CreateComplete, 0, 0 )
						Else
							Return FALSE
					On PAM_clsPB_GETNEXTREC
						If NOT SalSendMsg( hWndChildTable, PAM_clsTBL_CHECKCHANGES, 0, 0 )
							Return FALSE
						If SalSendMsg( hWndActivateButton, PAM_clsACTIVATE_NEXTREC, 0, 0 )
							Return SalSendMsg( hWndForm, SAM_CreateComplete, 0, 0 )
						Else
							Return FALSE
					On PAM_clsPB_GETLASTREC
						If NOT SalSendMsg( hWndChildTable, PAM_clsTBL_CHECKCHANGES, 0, 0 )
							Return FALSE
						If SalSendMsg( hWndActivateButton, PAM_clsACTIVATE_LASTREC, 0, 0 )
							Return SalSendMsg( hWndForm, SAM_CreateComplete, 0, 0 )
						Else
							Return FALSE

			! ToolTip Classes
			General Window Class: clsToolTipWindow
				Description:
				Derived From
				Class Variables
					Window Handle: hWndToolTip
				Instance Variables
					Number: m_nX
					Number: m_nY
					Boolean: m_bWait
					Boolean: m_bShowing
					!
					String: m_sTip
					String: m_sStatusText
				Functions
					Function: SetTip
						Description:
						Returns
						Parameters
							String: sText
						Static Variables
						Local variables
						Actions
							Set m_sTip = sText
					Function: SetStatusText
						Description:
						Returns
						Parameters
							String: sText
						Static Variables
						Local variables
						Actions
							Set m_sStatusText = sText
					!
					Function: GetTip
						Description:
						Returns
							String:
						Parameters
						Static Variables
						Local variables
							String: sTemplate
							Number: nPosition
						Actions
							Return m_sTip
					Function: GetStatusText
						Description:
						Returns
							String:
						Parameters
						Static Variables
						Local variables
						Actions
							Return m_sStatusText
				Message Actions
					On WM_SETCURSOR
						! The tool tip should only display if the item is on the 
								active window.
								
								Unfortunately, Centura does some squirrely things with the
								window handle of forms with tool bars, this code is too
								confusing to write.  We'll pop up the tool tip whether this
								is the active window or not.
								
								If you do try to figure this out, you will need to test with 
								a dialog box, an MDI window with multiple children and tool
								bars, and a form window with and without tool bars.
						If NOT m_bWait
							!
							! Set the timer if not already set, initial wait is 1 sec.
							! Changed this to 500 instead of 1000
							!
							Call SalTimerSet( hWndItem, nToolTimer, 500 )
							Set m_bWait = TRUE
					On SAM_Timer
						If wParam = nToolTimer
							Call GetCursorPos( m_nX, m_nY )
							!
							If hWndItem = WindowFromPoint( m_nX, m_nY )
								If NOT m_bShowing
									!
									If GetTip() != STRING_Null
										! Insure the Tip window is open
										If Not IsWindow( hWndToolTip )
											If IsWindow( hWndMDI )
												Set hWndToolTip = SalCreateWindow( dlgToolTip, hWndMDI )
											Else
												Set hWndToolTip = SalCreateWindow( dlgToolTip, hWndForm )
										!
										! Cursor still in window -- show the tip (once)
										If IsWindow( hWndToolTip )
											!
											Call hWndToolTip.dlgToolTip.ShowTip( GetTip() )
										!
										Set m_bShowing = TRUE
									!
									If GetStatusText() != STRING_Null
										If IsWindow( hWndForm )
											Call SalStatusSetText( hWndForm, GetStatusText() )
										Else If IsWindow( hWndMDI )
											Call SalStatusSetText( hWndMDI, GetStatusText() )
									!
									! Decrease timer interval to 5 ms
									Call SalTimerSet( hWndItem, nToolTimer, 5 )
							Else
								!
								! Cursor not in window any more -- clear (hide) the tip
								If m_bShowing AND IsWindow( hWndToolTip )
									!
									Call hWndToolTip.dlgToolTip.HideTip()
								Set m_bShowing = FALSE
								!
								If GetStatusText() != STRING_Null
									If IsWindow( hWndForm )
										Call SalStatusSetText( hWndForm, STRING_Null )
									Else If IsWindow( hWndMDI )
										Call SalStatusSetText( hWndMDI, STRING_Null )
								!
								! Kill the timer
								Call SalTimerKill( hWndItem, nToolTimer )
								Set m_bWait = FALSE
					On SAM_Destroy
						If m_bShowing
							If IsWindow (hWndToolTip)
								Call dlgToolTip.HideTip()
							Else
								Set m_bShowing = FALSE
								Set hWndToolTip = hWndNULL
							!
							If GetStatusText() != STRING_Null
								Call SalStatusSetText( hWndMDI, STRING_Null )
							!
						If m_bWait
							Call SalTimerKill( hWndItem, nToolTimer )

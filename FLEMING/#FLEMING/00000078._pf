			Contents
		Contents
		Functions
			Function: ShowTip
				Description: Displays the tool tip window.
						Calculates the size and position of the window.
						Draws the appropriate tip text on the window.
				Returns
				Parameters
					String: sText
				Static Variables
				Local variables
					Number: nCursorX
					Number: nCursorY
					Number: nScreenWidth
					Number: nScreenHeight
					!
					Number: nWindowX
					Number: nWindowY
					Number: nWindowWidth
					Number: nWindowHeight
					!
					Number: hDC
					Number: nTextLength
					Number: nTextWidth
					Number: nTextHeight
					!
					Number: nRectLeft
					Number: nRectTop
					Number: nRectRight
					Number: nRectBottom
					!
				Actions
					! Get the string size for sizing the window by the text
					Set nTextLength = SalStrLength( sText )
					!
					! Get a device context, and make the background transparent
					Set hDC = GetDC( hWndForm )
					Call SetBkMode( hDC, TRANSPARENT )
					!
					! Select the font into the device context
					Call SelectObject( hDC, SalSendMsg( hWndForm, WM_GETFONT, 0, 0 ) )
					!
					! Call DrawText to determine width and height of text
					Call DrawTextA( 
								hDC, 
								sText, 
								nTextLength,
								nRectLeft, nRectTop, nTextWidth, nTextHeight,
								DT_CALCRECT )
					!
					! Move dialog to cursor position plus some
					Call GetCursorPos( nCursorX, nCursorY )
					Set nWindowWidth = nTextWidth + 5
					Set nWindowHeight = nTextHeight + 5
					Set nScreenWidth = GetDeviceCaps( hDC, HORZRES )
					Set nScreenHeight = GetDeviceCaps( hDC, VERTRES )
					!
					Set nWindowX = nCursorX - 2
					If ( nWindowX + nWindowWidth ) > nScreenWidth
						Set nWindowX = nScreenWidth - nWindowWidth
					!
					Set nWindowY = nCursorY + 18
					If ( nWindowY + nWindowHeight ) > nScreenHeight
						Set nWindowY = nCursorY - nWindowHeight - 18
					!
					! SetWindowPos uses, X, Y, Width, and Height
					Call SetWindowPos( 
								hWndForm,
								SalNumberToWindowHandle( HWND_TOPMOST ),
								nWindowX, nWindowY, nWindowWidth, nWindowHeight,
								SWP_NOACTIVATE | SWP_NOOWNERZORDER | SWP_FRAMECHANGED )
					!
					Call ShowWindow( hWndForm, SW_SHOWNOACTIVATE )
					!
					! Draw the tooltip text on the background of the dialog 
					Set nRectLeft = 1
					Set nRectTop = 1
					Set nRectRight = nRectLeft + nTextWidth
					Set nRectBottom = nRectTop + nTextHeight
					!
					Call DrawTextA( 
								hDC, 
								sText, 
								nTextLength,
								nRectLeft, nRectTop, nRectRight, nRectBottom,
								DT_LEFT )
					!
					Call ReleaseDC ( hWndForm, hDC )
					!
			Function: HideTip
				Description: Hides the tool tip window.
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Call SalHideWindow( hWndForm )
		Window Parameters
		Window Variables
		Message Actions
			On WM_NCCREATE
				! Turns off the dialog caption
				Call SetWindowLongA( hWndItem, GWL_STYLE, GetWindowLongA( hWndItem, GWL_STYLE) & (0xFFFFFFFF - WS_DLGFRAME ) )
				! Removes the frame, and keeps the tooltip off the taskbar.
				Call SetWindowLongA( hWndItem, GWL_EXSTYLE, GetWindowLongA( hWndItem, GWL_EXSTYLE) & (0xFFFFFFFF - WS_EX_DLGMODALFRAME) | WS_EX_TOOLWINDOW )
			On SAM_Create
				Call SalHideWindow( hWndForm )

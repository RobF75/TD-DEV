				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set pbPickItems.hWndPickIntoTable = tblSelectedItems
					On PAM_cls_SETFIELDS
						! Call pbPickItems.SetStockItemsFields( SalStrToNumber( cYear.GetNumber( ) ), '', '', '' )
						Call pbPickItems.SetStockItemsFields( ccSeasonYear.GetSeasonYear( ), '', '', '' )
						Return TRUE
					On PAM_cls_GETFIELDS
						Call pbPickItems.GetStockItemsFields( tblSelectedItems.colItemNo, 
								tblSelectedItems.colYear, 
								tblSelectedItems.colTreeType, 
								tblSelectedItems.colTreeTypeDesc, 
								sTmp, 
								tblSelectedItems.colCultDesc, 
								sTmp, 
								tblSelectedItems.colRootDesc, 
								nTmp, nTmp  )
						!
						Set nTmp = SalTblQueryContext( tblSelectedItems )
						Call SalTblSetRowFlags( tblSelectedItems, nTmp, ROW_Selected, TRUE )
						Call SalTblSetRowFlags( tblSelectedItems, nTmp, ROW_HideMarks, TRUE )
						Return TRUE

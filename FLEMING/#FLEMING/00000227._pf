.head 5 +  Message Actions
.head 6 +  On PAM_clsPB_CLICK
.head 7 +  If rbSelectedPromos
.head 8 -  Set sPromoType = 'SELECTED'
.head 8 +  If SalSendMsg( tblSelectedPromos, PAM_clsPRTPROMO_GETSELPROMOIDS, 0, 0 )
.head 9 -  Call PopString( sSelectedPromoIdList, TRUE )
.head 8 +  Else
.head 9 -  Call SalMessageBox( 'Please select some Promos first, or choose All.', 'Warning', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Set sPromoType = 'ALL'
.head 7 -  !
.head 7 +  If rbView
.head 8 -  Set sReportType = 'VIEW'
.head 7 +  Else
.head 8 -  Set sReportType = 'PRINT'
.head 7 -  !
.head 7 +  If hWndReport = hWndNULL
.head 8 -  Set hWndReport = SalCreateWindow( frmPrintPromoOrderedBy, hWndForm, sSelectedPromoIdList, 
ccSeasonYear.GetSeasonYear( ), sPromoType, sReportType )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Call SalMessageBox( 'Please close down your first report!', 'Warning', MB_Ok )
.head 8 -  Return FALSE

		Functions
		Window Parameters
		Window Variables
			Window Handle: hWndPushbutton
			Boolean: bShowQueryOk
			Boolean: bSelect
			Number: nRow
			String: sUse
			String: sHelpFileName
			String: sPreEntryWhere
		Message Actions
			On SAM_Create
				Set sHelpFileName = 'f:\\apps\\gupta\\stock\\qitem.hlp'
				Set bSelect = FALSE
				Call PopWndHdl( hWndPushbutton, TRUE )
				Call PopString( dfLabelDesc, TRUE )
				Call PopString( dfLabelId, TRUE )
				Call SalPostMsg( dlgQItem, PAM_CREATECOMPLETE, 0, 0 )
			On PAM_CREATECOMPLETE
				Set sBuildWhere = ''
				If nContinue = SalModalDialog( dlgInitialQItem, hWndForm )
					Call SalStrRight( sBuildWhere, SalStrLength( sBuildWhere ) - SalStrLength( ' WHERE ' ), sBuildWhere )
					! If sBuildWhere != ''
						    Set sPreEntryWhere = WHORDBYCULT || ' AND ' || sBuildWhere
					! Else 
						    Set sPreEntryWhere = WHORDBYCULT
					If sBuildWhere != ''
						Set sPreEntryWhere = ' WHERE '||sBuildWhere
					Else
						Set sPreEntryWhere = ''
					Call SalSendMsg( tblItem, PAM_POPULATE, 0, 0 )
				Else
					Call SalDestroyWindow( hWndForm )
			On SAM_Destroy
				Call SalSendMsg( hWndPushbutton, PAM_ENABLE, 0, bSelect )
			On SAM_Close
				Call SalWaitCursor( TRUE )

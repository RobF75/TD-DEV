				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Print
				Window Location and Size
					Left:   0.288"
					Top:    4.0"
					Width:  1.2"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes

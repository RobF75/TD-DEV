			Function: LoseLabelEdit
				Description: Ask the user if they want their changes saved prior to doing other
						functions
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					If IDYES = SalMessageBox( 'Your current changes have not been saved.
							Would you like them saved to the database?', 'Labels',
							MB_IconAsterisk|MB_YesNo  )
						If bgNew
							Call AddLabel(  )
						Else
							Call SaveLabel(  )
			! Function: MyCenter
				    Description: Center a string to given character width
				    Returns
					    String:
				    Parameters
					    String: sInputString
					    Number: nWidth
				    Local variables
					    Number: nInputStringWidth
					    Number: nMidWidth
					    Number: nMidInputStringWidth
					    Number: nPrecedingSpaces
					    String: sCenteredString
				    Actions
					    Set nInputStringWidth = SalStrLength( sInputString )
					    If nInputStringWidth >= nWidth
						    Return sInputString
					    Else
						    Set nMidWidth = nWidth / 2
						    Set nMidWidth = SalNumberTruncate( nMidWidth, 2, 0 )
						    Set nMidInputStringWidth = nInputStringWidth / 2
						    Set nMidInputStringWidth = SalNumberTruncate( nMidInputStringWidth, 2, 0 )
						    Set nPrecedingSpaces = nMidWidth - nMidInputStringWidth
						    Set sCenteredString = ''
						    Call SalStrRepeat( ' ', nPrecedingSpaces, sCenteredString )
						    Set sCenteredString = sCenteredString || sInputString
						    Return sCenteredString
			Function: AddLabelAgainstAllStock
				Description: Adds a label Id and use against all the stock items.
				Returns
					Boolean:
				Parameters
					String: sLabelId
					String: sUse
				Static Variables
				Local variables
					Sql Handle: hSqlItemNo
					Boolean: bSqlItemNo
					Sql Handle: hSqlInsert
					Boolean: bSqlInsert
					Boolean: bExists
					String: sSql
					String: sSqlInsert
					Number: nInd
					Number: nMinItemNo
					Number: nMaxItemNo
					Number: nItemNo
				Actions
					Set bSqlItemNo = SqlConnect( hSqlItemNo ) 
					If bSqlItemNo
						Call SqlSetLockTimeout( hSqlItemNo, 10 )
					Else
						Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						Return FALSE
					Set bSqlInsert = SqlConnect( hSqlInsert ) 
					If bSqlInsert
						Call SqlSetLockTimeout( hSqlInsert, 10 )
					Else
						Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						Return FALSE
					!
					Set sSql = ' SELECT Item_No INTO :nItemNo FROM Stock_Item '
					If SqlPrepare( hSqlItemNo, sSql )
						If NOT SqlExecute( hSqlItemNo )
							Call SalMessageBox( 'SqlExecute failed in AddLabelAgainstAllStock( ), Note that not all stock items were assigned your label.', 'Error', MB_Ok )
							If bSqlItemNo
								Call SqlDisconnect( hSqlItemNo )
							If bSqlInsert
								Call SqlDisconnect( hSqlInsert )
							Return FALSE
					Else
						Call SalMessageBox( 'SqlPrepare failed in AddLabelAgainstAllStock( ), Note that not all stock items were assigned your label.', 'Error', MB_Ok )
						If bSqlItemNo
							Call SqlDisconnect( hSqlItemNo )
						If bSqlInsert
							Call SqlDisconnect( hSqlInsert )
						Return FALSE
					Set sSql = ' SELECT Stock_Item_No FROM Stock_Labels WHERE Stock_Item_No = :nItemNo AND Label_Id = :sLabelId AND Stock_Label_Use = :sUse '
					Set sSqlInsert = ' INSERT INTO Stock_Labels VALUES ( :nItemNo, :sLabelId, :sUse ) '
					If NOT SqlPrepare( hSqlInsert, sSqlInsert )
						Call SalMessageBox( 'SqlExists failed in AddLabelAgainstAllStock( ), Note that not all stock items were assigned your label.', 'Error', MB_Ok )
						If bSqlItemNo
							Call SqlDisconnect( hSqlItemNo )
						If bSqlInsert
							Call SqlDisconnect( hSqlInsert )
						Return FALSE
					If SqlFetchNext( hSqlItemNo, nInd )
						While nInd != FETCH_EOF
							If SqlExists( sSql, bExists )
								If NOT bExists
									If NOT SqlExecute( hSqlInsert )
										Call SalMessageBox( 'SqlExists failed in AddLabelAgainstAllStock( ), Note that not all stock items were assigned your label.', 'Error', MB_Ok )
										If bSqlItemNo
											Call SqlDisconnect( hSqlItemNo )
										If bSqlInsert
											Call SqlDisconnect( hSqlInsert )
										Return FALSE
								Call SqlFetchNext( hSqlItemNo, nInd )
							Else
								Call SalMessageBox( 'SqlExists failed in AddLabelAgainstAllStock( ), Note that not all stock items were assigned your label.', 'Error', MB_Ok )
								If bSqlItemNo
									Call SqlDisconnect( hSqlItemNo )
								If bSqlInsert
									Call SqlDisconnect( hSqlInsert )
								Return FALSE
					Else
						Call SalMessageBox( 'SqlFetchNext failed in AddLabelAgainstAllStock( ), Note that not all stock items were assigned your label.', 'Error', MB_Ok )
						If bSqlItemNo
							Call SqlDisconnect( hSqlItemNo )
						If bSqlInsert
							Call SqlDisconnect( hSqlInsert )
						Return FALSE
					Call SqlCommit( hSqlInsert )
					If bSqlItemNo
						Call SqlDisconnect( hSqlItemNo )
					If bSqlInsert
						Call SqlDisconnect( hSqlInsert )
					Return TRUE

				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						If NOT SalTblAnyRows( frmLabFields.tblField,ROW_Selected, 0 )
							Call SalMessageBox( 'No rows selected', 'Label Fields', MB_Ok )
							Return FALSE
						Else
							Call SalWaitCursor( TRUE )
							Call PushWndHdl (hWndItem)
							Call PushString( frmLabFields.dfLabelId )
							Call PushString( frmLabFields.dfLabDesc )
							Set ngRow = TBL_MinRow
							Call SalTblFindNextRow( frmLabFields.tblField, ngRow, ROW_Selected, 0 )
							Call SalTblFetchRow( frmLabFields.tblField, ngRow )
							Call PushNumber( frmLabFields.tblField.colNo )
							Call SalDisableWindow ( hWndItem ) 
							Call PushNumber( PAM_DETREC )
							Set hWndFldDets = SalCreateWindow( frmFldDets, frmLabFields )
					On PAM_ENABLE
						Call SalEnableWindow( hWndItem )
						! As this message is only ever sent when returning from addition/possible modif
								of orders then we need to repopulate when we've returned 
						! If bgSearch
							    Call SalPostMsg(frmLabFields.tblField, PAM_SEARCH, 0, 0 )
						! Else 
						Call SalPostMsg(frmLabFields.tblField, PAM_POPULATE, 0, 0 )
					On PAM_QUERYDISABLE
						If wParam
							Call SalDisableWindow( hWndItem )
						Else
							Call SalEnableWindow( hWndItem )

				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						If SalTblAnyRows( hWndForm.tblField, ROW_Edited|ROW_New|
								ROW_MarkDeleted, 0 )
							If NOT ForgetChanges(  )
								Return FALSE
						Call SalTblReset(frmLabFields.tblField )
						Call SalSendMsgToChildren( frmLabFields.tblField, PAM_ALLOWENTRY, 0, 0 )
						Set ngRow = 0
						Set ngRow = SalTblInsertRow( frmLabFields.tblField, ngRow )
						Call SalTblSetFocusCell( frmLabFields.tblField, ngRow, frmLabFields.tblField.colNo, -1,-1)
						Call SalSendMsg( frmLabFields.pbOk, PAM_ENABLE,0,0 )
						Call SalHideWindow( hWndItem )
						Set bShowQueryOk = TRUE
						Call SalSendMsgToChildren( hWndForm, PAM_QUERYDISABLE, TRUE, 0 )
					On PAM_ENABLE
						Call SalShowWindow( hWndItem )

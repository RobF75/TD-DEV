				Functions
				Window Variables
					String: sSql
					Boolean: bExists
					Number: nInd
					!
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					String: sSQLPOPTABLENAME
					String: sORDERBY
					String: sCurrentBuildWhere
					String: sQueryTmpStr
				Message Actions
					On PAM_POPULATE
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_REPOPULATE
						Call TableRePopulate( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_SEARCH
						Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set sSQLPOPTABLENAME = ' STOCK_LABELS, STOCK_ITEM'
						! Set sSQLPOPTABLENAME = ' STOCK_LABELS, STOCK_ITEM, CULTIVAR'
						Set sORDERBY = ' ORDER BY 1,2,3,4,5 '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
					On PAM_ADDROW
						Call SalTblQueryFocus(hWndForm, ngRow, hWndCol )
						Set ngRow = SalTblInsertRow( hWndForm, ngRow )
						Set bgNew = TRUE
						Call SalSendMsgToChildren( frmUsed.tblUsed, PAM_ALLOWENTRY, 0, 0 )
					On PAM_NOROWS
						Call SalMessageBox( 'No rows match the search criteria',
								 'Labels Used', MB_Ok )
					On PAM_WRITEINSERTSUPDATES
						Set bOk = FALSE
						If IDNO = SalMessageBox( 'Are you ready to insert/update/delete the selected rows?',
								'Label Used', MB_YesNo|MB_IconExclamation )
							Return FALSE
						Set ngRow = TBL_MinRow
						If NOT TableDataVal( hWndForm )
							Return FALSE
						Set ngRow = TBL_MinRow
						While SalTblFindNextRow( hWndForm, ngRow, ROW_New, 0 )
							Call SalTblFetchRow( hWndForm, ngRow )
							Call CallBuildSql( hWndForm,nINSERT, PAM_INSERTUPDATE, STKLBL, '' )
							Set bOk = SqlImmediate( sgSql )
							If bOk
								Call SqlClearImmediate(  )
								Call SalTblSetRowFlags( hWndForm, ngRow, ROW_New|ROW_Edited, FALSE )
								Set bgNew = FALSE
							Else
								Call SqlClearImmediate(  )
								Call SqlImmediate( 'commit' )
								Call SqlClearImmediate(  )
								Return FALSE
						Call SqlImmediate( 'commit' )
						Call SqlClearImmediate(  )
						When SqlError
							Call PushString( STKLBL )
							Call PushWndHdl( hWndForm )
							Call WhenSqlError(  )
							Call WhenUpdSqlError(  )
						Set ngRow = TBL_MinRow
						While SalTblFindNextRow( hWndForm, ngRow, ROW_Edited, 0 )
							Call SalTblFetchRow( hWndForm, ngRow )
							Call CallBuildSql( hWndForm,nUPDATE, PAM_INSERTUPDATE, STKLBL,
									 WHERESLCOLROWID )
							Set bOk = SqlImmediate( sgSql )
							If bOk
								Call SqlClearImmediate(  )
								Call SalTblSetRowFlags( hWndForm, ngRow, ROW_Edited, FALSE )
							Else
								Call SqlClearImmediate(  )
								Call SqlImmediate( 'commit' )
								Call SqlClearImmediate(  )
								Return FALSE
						Call SqlImmediate( 'commit' )
						Call SqlClearImmediate(  )
						When SqlError
							Call PushString( STKLBL )
							Call PushWndHdl( hWndForm )
							Call WhenSqlError(  )
							Call WhenDelSqlError(  )
						If SalTblAnyRows( hWndForm,ROW_MarkDeleted,0 )
							Call SqlPrepare( frmUsed.hLocalSqlDoTbl, 'DELETE FROM STOCK_LABELS WHERE
									ROWID = :frmUsed.tblUsed.colRowId' )
							Set bOk = FALSE
							Set bOk = SalTblDoDeletes( hWndForm, frmUsed.hLocalSqlDoTbl,
									ROW_MarkDeleted )
							Call SqlImmediate( 'commit' )
							Call SqlClearImmediate(  )
						If bOk 
							Call SalSendMsg(  hWndForm, PAM_POPULATE, 0, 0 ) 
							Call SalMessageBox( 'Row(s) updated.', 'Labels Used',
									MB_Ok|MB_IconAsterisk )
							Return TRUE
					On PAM_DELETEROWS
						If SalTblAnyRows( hWndForm, ROW_Selected,0 )
							Set ngRow = TBL_MinRow
							While SalTblFindNextRow( hWndForm, ngRow, ROW_Selected, 0 )
								Call SalTblSetRowFlags( hWndForm,ngRow, ROW_MarkDeleted, TRUE )
								Call SalTblSetRowFlags( hWndForm, ngRow, ROW_Edited|ROW_New, FALSE )
					On PAM_UNDELETEROWS
						If SalTblAnyRows( hWndForm, ROW_Selected,0 )
							Set ngRow = TBL_MinRow
							While SalTblFindNextRow( hWndForm, ngRow, ROW_Selected, 0 )
								Call SalTblSetRowFlags( hWndForm, ngRow, ROW_MarkDeleted, FALSE )
					On PAM_RESET
						Call SalTblReset( frmUsed.tblUsed )
						Set ngRow = 0
						Set ngRow = SalTblInsertRow(  frmUsed.tblUsed, ngRow )
						Call SalSendMsgToChildren( frmUsed.tblUsed, PAM_ALLOWENTRY, 0, 0 )
						Call SalTblSetFocusCell(  frmUsed.tblUsed, ngRow, colTreeTypeDesc, -1, -1 )
					! On PAM_POPULATE
						    Call SalWaitCursor( TRUE )
						! set an sqlStatement
						    Call CallBuildSql( hWndForm,nSELECT, PAM_SQL, STKSTKLBLCULT, WHERELBL )
						    Call SalTblPopulate( hWndForm, frmUsed.hLocalSqlPopTbl, sgSql, TBL_FillNormal )
						    Call SalSendMsgToChildren( hWndForm, PAM_DISALLOWENTRY, 0, 0 )
						    Call SalWaitCursor( FALSE )
					! On PAM_SEARCH
						    Call PushWndHdl( frmUsed.tblUsed )
						    Call PushNumber( PAM_QBE )
						    Call BuildWhereQBE(  )
						    Call PushString( 'ORDER BY 2,3,1' )
						    Call AddOrderByToWhere(  )
						    Set bgSearch = TRUE
						    Call CallBuildSql( hWndForm,nSELECT, PAM_SQL, STKSTKLBLCULT, sBuildWhere )
						    Call SalTblPopulate( frmUsed.tblUsed, frmUsed.hLocalSqlSrchTbl, sgSql, TBL_FillNormal )
						    Call SqlGetResultSetCount( frmUsed.hLocalSqlSrchTbl, ngCount )
						    If ngCount = 0
							    Call SalPostMsg( frmUsed.tblUsed, PAM_NOROWS, 0, 0 )
						    Call SalSendMsg( frmUsed.pbQuery, PAM_ENABLE, 0, 0 )
						    Call SalSendMsgToChildren( frmUsed.tblUsed, PAM_DISALLOWENTRY, 0, 0 )
						    Call SalSendMsgToChildren( frmUsed, PAM_HIDE, 0, 0 )

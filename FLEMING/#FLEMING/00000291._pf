			Pushbutton: pbDetField
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: D&etails - F2
				Window Location and Size
					Left:   1.688"
					Top:    3.74"
					Width:  1.2"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes

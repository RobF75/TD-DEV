					Call PopString( hWndForm.dfLabelDesc, TRUE )
					Call PopString( hWndForm.dfLabelId, TRUE )
					Call PopNumber( hWndForm.dfNo, TRUE )
					Call CallBuildSql( hWndForm, nSELECT, PAM_SQL, LABELFIELDS,LABELFIELDSALL )
					! set an sqlStatement
					If SqlImmediate( sgSql )
						Call SqlClearImmediate(  )
						Set bgNew = FALSE
						Call SalSendMsgToChildren( hWndForm,PAM_DISPREC,0,0 )
						Set bgEdit = FALSE
					Else
						Call SqlClearImmediate(  )
						Call SalMessageBox( 'Record Not Found','No Record', MB_Ok )
					Call SqlClearImmediate(  )
			Function: ClearLabel
				Description: Clear the screen and reset field defaults
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Call InitTopLevelWindow( hWndForm )
					Call SalSetFocus( frmLabDets.dfLabelId )
					Set bgNew = TRUE

				Message Actions
					On SAM_Click
						! If NOT bgNew
							    Call SalMessageBox( 'Can only select a stock item for a new record.   
									If you wish to changed the stock item please delete, and then add', 'Labels Used'
									, MB_Ok )
							    Return FALSE
						Call SalWaitCursor( TRUE )
						Set bgSelect = FALSE
						Call PushWndHdl( hWndItem )
						Call PushString( dfLabelId )
						Call PushString( dfLabDesc )
						Call SalDisableWindow( hWndItem )
						Call SalWaitCursor( TRUE )
						Call SalModalDialog( dlgQItem, frmUsed )
					On PAM_ENABLE
						Call SalTblSetFocusCell( frmUsed.tblUsed, SalTblQueryContext( tblUsed ), frmUsed.tblUsed.colUse, -1, -1 )
						If NOT lParam
							Call SalSendMsg( tblUsed, PAM_POPULATE, 0, 0 )
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
					On PAM_LOOKUP
						Call SalSendMsgToChildren( tblUsed, PAM_LOOKUPITEM, 0, 0 )
					On PAM_READYFORNEXTLOOKUP
						Call SalSendMsg( tblUsed, PAM_ADDROW, 0, 0 )
					On PAM_QUERYDISABLE
						If wParam
							Call SalDisableWindow( hWndItem )
						Else
							Call SalEnableWindow( hWndItem )

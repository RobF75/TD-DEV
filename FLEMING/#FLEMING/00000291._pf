		Functions
		Window Parameters
		Window Variables
			Window Handle: hWndPushbutton
			!
			Sql Handle: hLocalSqlA
			Boolean: bLocalSqlA
			Sql Handle: hLocalSqlB
			Boolean: bLocalSqlB
		Message Actions
			On PAM_ADDREC
				Call ClearLabDets(  )
				Call SalWaitCursor( FALSE )
			On SAM_Create
				Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
				If bLocalSqlA
					Call SqlSetIsolationLevel( hLocalSqlA, 'RL' )
					Call SqlSetLockTimeout( hLocalSqlA, 10 )
				Else
					Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
					Return FALSE
				Set bLocalSqlB = SqlConnect( hLocalSqlB ) 
				If bLocalSqlB
					Call SqlSetIsolationLevel( hLocalSqlB, 'RL' )
					Call SqlSetLockTimeout( hLocalSqlB, 10 )
				Else
					Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
					Return FALSE
				Call PopWndHdl( hWndPushbutton, TRUE )
				Call SalSendMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
			On SAM_Destroy
				If bLocalSqlA
					Call SqlDisconnect( hLocalSqlA )
				If bLocalSqlB
					Call SqlDisconnect( hLocalSqlB )
				Call SalSendMsg( hWndPushbutton,PAM_ENABLE,0,0 )
				Set hWndLab = hWndNULL
			On SAM_Close
				If bgEdit
					If NOT ForgetChanges(  )
						Return FALSE
				Call SalWaitCursor( TRUE )
			On PAM_CREATECOMPLETE
				Call PopNumber( ngMessNo, TRUE )
				Set hWndForm.dfCurrDate = SalDateCurrent(  )
				! Want to pass from the prior form whether the user is adding or displaying
				Call SalSendMsg( hWndForm, ngMessNo, 0, 0 )
			On PAM_DETREC
				Set bgEdit = FALSE
				Call DetLab(  )
				Call SalWaitCursor( FALSE )

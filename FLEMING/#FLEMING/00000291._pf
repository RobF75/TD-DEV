			Function: ClearFields
				Description: Clear the screen and reset field defaults
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Call InitTopLevelWindow( hWndForm )
					Call PopString( hWndForm.dfLabelDesc, TRUE )
					Call PopString( hWndForm.dfLabelId, TRUE )
					Call PopNumber( hWndForm.dfNo, TRUE )
					Set hWndForm.dfNo = hWndForm.dfNo + 1
					Call SalSetFieldEdit( hWndForm.dfNo, TRUE )
					Call SalSetFocus( frmFldDets.dfNo )

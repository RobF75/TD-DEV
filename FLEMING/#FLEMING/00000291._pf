								    Return TRUE
				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
				Message Actions
					On PAM_POPULATE
						Call SalWaitCursor( TRUE )
						Set dlgQItem.sPreEntryWhere = dlgQItem.sPreEntryWhere || ' ORDER BY 2,3,4,1 '
						Call CallBuildSql( hWndForm,nSELECT, PAM_SQL, SI, dlgQItem.sPreEntryWhere )
						! Call CallBuildSql( hWndForm,nSELECT, PAM_SQL, SICV, dlgQItem.sPreEntryWhere )
						Call SalTblPopulate( hWndForm, hLocalSqlPopTbl, sgSql, TBL_FillNormal )
						Call SalWaitCursor( FALSE )
					On PAM_SEARCH
						Call PushWndHdl( dlgQItem.tblItem )
						Call PushNumber( PAM_QBE )
						Call BuildWhereQBE(  )
						! Need to add an order by statement to the sBuildWhere
						Call PushString( ' ORDER BY 2,3,4,1 ' )
						Call AddOrderByToWhere(  )
						Set bgSearch = TRUE
						Call CallBuildSql( hWndForm,nSELECT, PAM_SQL, SI, sBuildWhere )
						! Call CallBuildSql( hWndForm,nSELECT, PAM_SQL, SICV, sBuildWhere )
						Call SalTblPopulate( hWndForm, hLocalSqlPopTbl, sgSql, TBL_FillNormal )
						Call SqlGetResultSetCount( hLocalSqlPopTbl, ngCount )
						If ngCount = 0
							Call SalPostMsg( dlgQItem.tblItem, PAM_NOROWS, 0, 0 )
						Call SalSendMsg( dlgQItem.pbQuery, PAM_ENABLE, 0, 0 )
						Call SalSendMsgToChildren( dlgQItem.tblItem, PAM_DISALLOWENTRY, 0, 0 )
						Call SalSendMsgToChildren( dlgQItem, PAM_HIDE, 0, 0 )
					On SAM_DoubleClick
						Call SalSendMsg( dlgQItem.pbSelect, SAM_Click, 0, 0 )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, 10 )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
			Pushbutton: pbSelect
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: S&elect
				Window Location and Size
					Left:   0.588"
					Top:    3.656"
					Width:  0.9"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: (none)
				Font Name: Default
				Font Size: Default
				Font Enhancement: Italic
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						If NOT SalTblAnyRows( tblItem, ROW_Selected, 0 )
							Call SalMessageBox( 'Record Not Selected', 'Error', MB_Ok )
							Return FALSE
						Else
							Call SalWaitCursor( TRUE )
							Set bSelect = TRUE
							Call SalSendMsg( hWndPushbutton, PAM_READYFORNEXTLOOKUP, 0, 0 )
							Set nRow = TBL_MaxRow
							While SalTblFindPrevRow( tblItem, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblItem, nRow )
								Call SalTblSetRowFlags( tblItem, nRow, ROW_Selected, FALSE )
								Call PushNumber( dlgQItem.tblItem.colItemNo )
								Call PushString( dlgQItem.tblItem.colRootDesc )
								Call PushString( dlgQItem.tblItem.colCultdesc )
								Call PushString( dlgQItem.tblItem.colTreeTypeDesc )
								Call SalSendMsg( hWndPushbutton, PAM_LOOKUP, 0, 0 )
								If SalTblAnyRows( tblItem, ROW_Selected, 0 )
									Call SalSendMsg( hWndPushbutton, PAM_READYFORNEXTLOOKUP, 0, 0 )
							Call SalEndDialog( hWndForm, 0 )
					On PAM_ENABLE
						Call SalEnableWindow( dlgQItem.pbSelect )
					On PAM_DISABLE
						Call SalDisableWindow( dlgQItem.pbSelect )
					On PAM_QUERYDISABLE
						If wParam
							Call SalDisableWindow( hWndItem )
						Else
							Call SalEnableWindow( hWndItem )

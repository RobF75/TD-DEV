				Functions
				Window Variables
				Message Actions
					On PAM_POPULATE
						Call SalWaitCursor( TRUE )
						Set bgSearch = FALSE
						Call CallBuildSql( hWndForm,nSELECT, PAM_SQL, LABELFIELDS, LABELFIELDID )
						Call SalTblPopulate( frmLabFields.tblField, frmLabFields.hLocalSqlPopTbl, sgSql, TBL_FillNormal )
						! Count the rows returned and post a message to the next pb in frmLabFields 
						Call SqlGetResultSetCount( frmLabFields.hLocalSqlPopTbl, ngCount )
						If ngCount = 0
							Set bgNext = FALSE
							Call SalSendMsg( frmLabFields.tblField, PAM_NOROWS, 0, 0 )
						Call SalWaitCursor( FALSE )
					On PAM_WRITEINSERTSUPDATES
						! Find and delete the rows
						When SqlError
							Call PushString( LABELFIELDS )
							Call PushWndHdl( frmLabFields.tblField )
							Call WhenSqlError(  )
							Call WhenDelSqlError(  )
						If SalTblAnyRows( hWndForm,ROW_Selected,0 )
							Set ngRow = TBL_MinRow
							While SalTblFindNextRow( frmLabFields.tblField, ngRow, ROW_Selected, 0 )
								Call SalTblFetchRow( frmLabFields.tblField, ngRow )
								Set sgSql = 'DELETE FROM LABEL_FIELDS WHERE ROWID
										 = :hWndForm.colRowId'
								If SqlOK( frmLabFields.hLocalSqlDoTbl, sgSql)
									Call SalTblSetRowFlags( frmLabFields.tblField, ngRow, ROW_Selected, FALSE )
									Call SqlCommit( frmLabFields.hLocalSqlDoTbl )
									Set bOk = TRUE
								Else
									Call SqlImmediate( 'commit' )
									Call SqlClearImmediate(  )
									Set bOk = FALSE
						If bOk 
							Call SqlImmediate( 'commit' )
							Call SqlClearImmediate(  )
							Call SalSendMsg( frmLabFields.tblField, PAM_POPULATE, 0, 0 ) 
							Call SalMessageBox( 'Row(s) deleted.', 'Customer Orders',
									MB_Ok|MB_IconAsterisk )
							Return TRUE
					On PAM_SEARCH
						Set bgSearch = TRUE
						Call PushWndHdl( frmLabFields )
						Call PushWndHdl( frmLabFields.tblField )
						Call PushNumber( PAM_QBE )
						Call BuildWhereQBE(  )
						! Need to add an order by statement to the sBuildWhere
						Call PushString( ORDBYFIELDNO )
						Call AddOrderByToWhere(  )
						Call CallBuildSql( hWndForm,nSELECT, PAM_SQL, LABELFIELDS, sBuildWhere )
						Call SalTblPopulate( frmLabFields.tblField, frmLabFields.hLocalSqlSrchTbl, sgSql, TBL_FillNormal )
						Call SalSendMsg( frmLabFields.pbOk, PAM_HIDE, 0, 0 )
						Call SalSendMsg( frmLabFields.pbQuery, PAM_ENABLE, 0, 0 )
						Call SalSendMsgToChildren( hWndForm, PAM_DISALLOWENTRY, 0, 0 )
						! Count the rows returned and post a message to the next pb in frmLabFields
						Call SqlGetResultSetCount( frmLabFields.hLocalSqlSrchTbl, ngCount )
						If ngCount = 0
							Set bgNext = FALSE
							Call SalPostMsg( frmLabFields.tblField, PAM_NOROWS, 0, 0 )
					On PAM_NOROWS
						Call SalMessageBox( 'No rows match the selections.','Label Fields',
								MB_Ok|MB_IconAsterisk )
					On SAM_Create
						Call SalSendMsgToChildren( hWndForm, PAM_DISALLOWENTRY, 0, 0 )
						Set hWndTbl = hWndForm

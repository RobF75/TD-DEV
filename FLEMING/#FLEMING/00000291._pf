							On PAM_DISALLOWENTRY
								Call SalTblSetColumnFlags( hWndItem, COL_Editable, FALSE )
							On PAM_QBE
								Call PushNumber( colNo )
								If SalIsNull( hWndItem )
									Call PushString(GTOPERAND )
								Else
									Call PushString(EQOPERAND )
								Call PushString( NUMERICFOLLOWING )
								Call PushString( 'LABEL_FIELDS.FIELD_NO' )
								Return TRUE

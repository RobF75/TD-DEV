		Named Menus
		Internal Functions
			Function: SelectLabel
				Description: User selects a label from the table and pops the label id
						creates the frmLabelDets screen                                         
				Returns
				Parameters
				Static Variables
				Local variables
					Window Handle: hWndSource
				Actions
					Call PopWndHdl( hWndSource, TRUE )
					Set ngRow = TBL_MinRow
					Call SalTblFindNextRow( hWndSource, ngRow, ROW_Selected, 0 )
					Call SalTblFetchRow( hWndSource, ngRow )
					Call PushString( hWndSource.colLabelId )
					Call PushWndHdl (hWndItem)
					Call SalDisableWindow ( hWndItem ) 
					Call PushNumber( PAM_DETREC )
					Set hWndLab = SalCreateWindow( frmLabDets, hWndSource )
			! Function: QueryLabels
				    Description: To allow the populated table to accept input and then the OK button to
						appear to signal the end of the query requirements 
				    Returns
				    Parameters
					    Window Handle: hWndSource
				    Local variables
					    Window Handle: hWndSource
				    Actions
					    Call SalShowWindow( hWndSource.pbOk )
					    Call SalSendMsgToChildren( hWndSource, PAM_RESET, 0, 0 )
					    Set bShowQueryOk = TRUE
					    Call SalSendMsgToChildren( hWndSource, PAM_QUERYDISABLE, TRUE, 0 )
			! Function: QueryUse
				    Description: To allow the populated table to accept input and then the OK button to
						appear to signal the end of the query requirements 
				    Returns
				    Parameters
				    Local variables
					    Window Handle: hWndSource
				    Actions
					    Call PopWndHdl( hWndSource, TRUE )
					    Call SalShowWindow( hWndSource.pbOk )
					    Call SalSendMsgToChildren( hWndSource, PAM_RESET, 0, 0 )
					    Set bShowQueryOk = TRUE
					    Call SalSendMsgToChildren( hWndForm, PAM_QUERYDISABLE, TRUE, 0 )
			Function: ListFields
				Description: To prime the various fields associated with the query screen called from
						and pass the information to display a table of the label fields
				Returns
				Parameters
				Static Variables
				Local variables
					Window Handle: hWndSource
				Actions
					Call PopWndHdl( hWndSource, TRUE )
					Set ngRow = TBL_MinRow
					Call SalTblFindNextRow( hWndSource, ngRow, ROW_Selected, 0 )
					Call SalTblFetchRow( hWndSource, ngRow )
					Call PushString( hWndSource.colLabelId )
					Call PushString( hWndSource.colLabDesc )
					Call PushWndHdl (hWndItem)
					Call SalDisableWindow ( hWndItem ) 
					Set hWndLab = SalCreateWindow( frmLabFields, hWndSource )
			Function: AddLabel
				Description: To add a record into table Labels
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Set hWndChild = SalGetFirstChild( hWndForm, TYPE_DataField )
					While NOT hWndChild = hWndNULL 
						If NOT SalSendMsg( hWndChild, PAM_DATAVAL, 0, 0 )
							Return FALSE
						Set hWndChild = SalGetNextChild( hWndChild, TYPE_DataField )
					Set bgEdit = FALSE
					Call CallBuildSql( hWndForm,nINSERT, PAM_SQL, LABELS, '' )
					If SqlOK( frmLabDets.hLocalSqlB,sgSql )
						Call SqlCommit( frmLabDets.hLocalSqlB )
						! On addition of an order we wish to clear the screen and reset it 
						Call SalMessageBox( 'Record Added Successfully','Add OK', MB_Ok )
						Call ClearLabel (  )
					Else
						Call SalMessageBox ('Record Addition Unsuccessful','Add Error', MB_RetryCancel )
						Call SqlImmediate( 'rollback'  )
						Call SqlClearImmediate(  )
						! Need to reset fields and allow
						Return FALSE
			Function: SaveLabel
				Description: Save the changes done to a label record
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Set bgEdit = FALSE
					Set hWndChild = SalGetFirstChild( hWndForm, TYPE_DataField )
					While NOT hWndChild = hWndNULL 
						If NOT SalSendMsg( hWndChild, PAM_DATAVAL, 0, 0 )
							Return FALSE
						Set hWndChild = SalGetNextChild( hWndChild, TYPE_DataField )
					Call CallBuildSql( hWndForm, nUPDATE, PAM_SQL, LABELS, LABELID )
					If SqlOK( frmLabDets.hLocalSqlB,sgSql )
						Call SqlCommit( frmLabDets.hLocalSqlB )
						! On modification of an order we wish to redisplay it
						Call SalMessageBox( 'Record Modified Successfully','Add OK', MB_Ok )
					Else
						Call SalMessageBox ('Record Modification Unsuccessful','Add Error',
								 MB_RetryCancel )
						! Need to reset fields and allow
						Call SqlImmediate( 'rollback' )
						Call SqlClearImmediate(  )
						Return FALSE
			Function: AddFields
				Description: To add a record into table Label Fields
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Set hWndChild = SalGetFirstChild( hWndForm, TYPE_DataField )
					While NOT hWndChild = hWndNULL 
						If NOT SalSendMsg( hWndChild, PAM_DATAVAL, 0, 0 )
							Return FALSE
						Set hWndChild = SalGetNextChild( hWndChild, TYPE_DataField )
					Set bgEdit = FALSE
					Call CallBuildSql( hWndForm,nINSERT, PAM_SQL, LABELFIELDS, LABELFIELDID )
					If SqlOK( frmFldDets.hLocalSqlB,sgSql )
						Call SqlCommit( frmFldDets.hLocalSqlB )
						! On addition of an order we wish to clear the screen and reset it 
						Call SalMessageBox( 'Record Added Successfully','Add OK', MB_Ok )
						! Need to prime this for the clear fields int function
						Call PushString( hWndForm.dfLabelId )
						Call PushString( hWndForm.dfLabelDesc )
						Call PushNumber( hWndForm.dfNo )
						Call ClearFields (  )
					Else
						Call SalMessageBox ('Record Addition Unsuccessful','Add Error', MB_RetryCancel )
						Call SqlImmediate( 'rollback'  )
						Call SqlClearImmediate(  )
						! Need to reset fields and allow
						Return FALSE
			Function: SaveFields
				Description: Save the changes done to a label fields record
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Set bgEdit = FALSE
					Set hWndChild = SalGetFirstChild( hWndForm, TYPE_DataField )
					While NOT hWndChild = hWndNULL 
						If NOT SalSendMsg( hWndChild, PAM_DATAVAL, 0, 0 )
							Return FALSE
						Set hWndChild = SalGetNextChild( hWndChild, TYPE_DataField )
					Call CallBuildSql( hWndForm, nUPDATE, PAM_SQL, LABELFIELDS, LABELFIELDIDNO )
					If SqlOK( frmFldDets.hLocalSqlB,sgSql )
						Call SqlCommit( frmFldDets.hLocalSqlB )
						! On modification of an order we wish to redisplay it
						Call SalMessageBox( 'Record Modified Successfully','Add OK', MB_Ok )
					Else
						Call SalMessageBox ('Record Modification Unsuccessful','Add Error',
								 MB_RetryCancel )
						! Need to reset fields and allow
						Call SqlImmediate( 'rollback' )
						Call SqlClearImmediate(  )
						Return FALSE
			Function: DetLab
				Description: Fetch the selected label and display
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Set bgNew = FALSE
					Call PopString( hWndForm.dfLabelId, TRUE )
					Call CallBuildSql( hWndForm, nSELECT, PAM_SQL, LABELS,LABELID )
					! set an sqlStatement
					If SqlImmediate( sgSql )
						Call SqlClearImmediate(  )
						Set bgNew = FALSE
						Call SalSendMsgToChildren( hWndForm,PAM_DISPREC,0,0 )
						Set bgEdit = FALSE
					Else
						Call SqlClearImmediate(  )
						Call SalMessageBox( 'Record Not Found','No Record', MB_Ok )
					Call SqlClearImmediate(  )
			Function: DetFields
				Description: Fetch the selected label fields and display

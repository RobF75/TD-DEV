				Functions
				Window Variables
				Message Actions
					On PAM_POPULATE
						Call SalWaitCursor( TRUE )
						Call CallBuildSql( hWndForm,nSELECT, PAM_SQL, LABELS, ORDBYLABELDESC )
						Call SalTblPopulate( hWndForm, frmLabels.hLocalSqlPopTbl, sgSql, TBL_FillNormal )
						Call SalSendMsgToChildren( hWndForm, PAM_DISALLOWENTRY, 0, 0 )
						Call SalWaitCursor( FALSE )
					On PAM_SEARCH
						Call PushWndHdl( frmLabels.tblLabels )
						Call PushNumber( PAM_QBE )
						Call BuildWhereQBE(  )
						! Need to add an order by statement to the sBuildWhere
						Call PushString( ORDBYLABELDESC )
						Call AddOrderByToWhere(  )
						Set bgSearch = TRUE
						Call CallBuildSql( hWndForm,nSELECT, PAM_SQL, LABELS, sBuildWhere )
						Call SalTblPopulate( frmLabels.tblLabels, frmLabels.hLocalSqlSrchTbl, sgSql, TBL_FillNormal )
						Call SqlGetResultSetCount( frmLabels.hLocalSqlSrchTbl, ngCount )
						If ngCount = 0
							Call SalPostMsg( frmLabels.tblLabels, PAM_NOROWS, 0, 0 )
						Call SalSendMsg( frmLabels.pbQuery, PAM_ENABLE, 0, 0 )
						Call SalSendMsgToChildren( frmLabels.tblLabels, PAM_DISALLOWENTRY, 0, 0 )
						Call SalSendMsgToChildren( frmLabels, PAM_HIDE, 0, 0 )
					On PAM_RESET
						Call SalTblReset( frmLabels.tblLabels )
						Set ngRow = 0
						Set ngRow = SalTblInsertRow(  frmLabels.tblLabels, ngRow )
						Call SalSendMsgToChildren( frmLabels.tblLabels, PAM_ALLOWENTRY, 0, 0 )
						Call SalTblSetFocusCell(  frmLabels.tblLabels, ngRow, colLabelId, -1, -1 )
					On PAM_WRITEINSERTSUPDATES
						Set bOk = FALSE
						When SqlError
							Call PushString( LABELS )
							Call PushWndHdl( frmLabels.tblLabels )
							Call WhenSqlError(  )
							Call WhenDelSqlError(  )
						If SalTblAnyRows( hWndForm,ROW_MarkDeleted,0 )
							Call SqlPrepare( frmLabels.hLocalSqlDoTbl, 'DELETE FROM LABELS WHERE
									ROWID = :hWndForm.colRowId' )
							Set bOk = FALSE
							Set bOk = SalTblDoDeletes( hWndForm, frmLabels.hLocalSqlDoTbl,
									ROW_MarkDeleted )
						If bOk 
							Call SqlImmediate( 'commit' )
							Call SqlClearImmediate(  )
							Call SalSendMsg( hWndForm, PAM_POPULATE, 0, 0 ) 
							Call SalMessageBox( 'Row(s) deleted.', 'Labels',
									MB_Ok|MB_IconAsterisk )
							Call SalSendMsg( frmLabels.pbOkDelete, PAM_HIDE, 0, 0 )
							Return TRUE
					On PAM_DELETEROWS
						If SalTblAnyRows( hWndForm, ROW_Selected,0 )
							Call SalSendMsg( frmLabels.pbOkDelete, PAM_ENABLE, 0, 0 )
							Set ngRow = TBL_MinRow
							While SalTblFindNextRow( hWndForm, ngRow, ROW_Selected, 0 )
								Call SalTblSetRowFlags( hWndForm,ngRow, ROW_MarkDeleted, TRUE )
								Call SalTblSetRowFlags( hWndForm, ngRow, ROW_Edited|ROW_New, FALSE )
					On PAM_UNDELETEROWS
						If SalTblAnyRows( hWndForm, ROW_Selected,0 )
							Set ngRow = TBL_MinRow
							While SalTblFindNextRow( hWndForm, ngRow, ROW_Selected, 0 )
								Call SalTblSetRowFlags( hWndForm, ngRow, ROW_MarkDeleted, FALSE )
					On PAM_NOROWS
						Call SalMessageBox( 'No rows match the search criteria',
								 'Labels', MB_Ok )

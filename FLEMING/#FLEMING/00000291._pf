				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						If NOT SalTblAnyRows( frmUsed.tblUsed, ROW_Selected, 0 )
							Call SalMessageBox( 'Please select a stock item first', 'Label Use', MB_Ok )
							Return FALSE
						Call SalWaitCursor( TRUE )
						Set ngRow = TBL_MinRow
						Call SalTblFindNextRow( frmUsed.tblUsed, ngRow, ROW_Selected, 0 )
						Call SalTblFetchRow( frmUsed.tblUsed, ngRow )
						Set frmUsed.dfItemNo = frmUsed.tblUsed.colItemNo
						Call PushWndHdl( hWndItem )
						Call SalDisableWindow( hWndItem )
						Set bgSelect = FALSE
						Call SalModalDialog( dlgMany, frmUsed )
					On PAM_ENABLE
						Call SalEnableWindow( hWndItem )
						If bgSelect
							Call PopNumber( dfHowMany, TRUE )
							Call PrintLabels( frmUsed.tblUsed.colItemNo, dfLabelId, dfHowMany, 0, hWndNULL, nExecute )
						Call SalWaitCursor( FALSE )
					On PAM_QUERYDISABLE
						If wParam
							Call SalDisableWindow( hWndItem )
						Else
							Call SalEnableWindow( hWndItem )

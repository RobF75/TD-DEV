				Message Actions
					On SAM_Click
						If SalIsNull( dlgMany.dfHowMany )
							Call SalMessageBox( 'Please enter the amount of labels you wish printed',
									 'How Many', MB_Ok )
							Return FALSE
						Call SalWaitCursor( TRUE )
						Set bgSelect = TRUE
						Call PushNumber( dlgMany.dfHowMany )
						Call SalEndDialog( dlgMany, 0 )

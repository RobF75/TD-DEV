		Functions
		Window Parameters
		Window Variables
			Window Handle: hWndPushbutton
			Boolean: bShowQueryOk
			!
			Sql Handle: hLocalSqlPopTbl
			Boolean: bLocalSqlPopTbl
			Sql Handle: hLocalSqlSrchTbl
			Boolean: bLocalSqlSrchTbl
			Sql Handle: hLocalSqlDoTbl
			Boolean: bLocalSqlDoTbl
		Message Actions
			On SAM_Create
				Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
				If bLocalSqlPopTbl
					Call SqlSetIsolationLevel( hLocalSqlPopTbl, 'RL' )
					Call SqlSetLockTimeout( hLocalSqlPopTbl, 10 )
					Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
				Else
					Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
					Return FALSE
				Set bLocalSqlSrchTbl = SqlConnect( hLocalSqlSrchTbl ) 
				If bLocalSqlSrchTbl
					Call SqlSetIsolationLevel( hLocalSqlSrchTbl, 'RL' )
					Call SqlSetLockTimeout( hLocalSqlSrchTbl, 10 )
					Call SqlSetParameter( hLocalSqlSrchTbl, DBP_PRESERVE, TRUE, ''  )
				Else
					Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
					Return FALSE
				Set bLocalSqlDoTbl = SqlConnect( hLocalSqlDoTbl ) 
				If bLocalSqlDoTbl
					Call SqlSetIsolationLevel( hLocalSqlDoTbl, 'RL' )
					Call SqlSetLockTimeout( hLocalSqlDoTbl, 10 )
				Else
					Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
					Return FALSE
				Set bShowQueryOk = FALSE
				Call PopWndHdl( hWndPushbutton, TRUE )
				Call SalSendMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
			On PAM_CREATECOMPLETE
				Call PopString( hWndForm.dfLabDesc,TRUE )
				Call PopString( hWndForm.dfLabelId,TRUE )
				Set hWndForm.dfCurrDate = SalDateCurrent(  )
				Call SalSetFocus( hWndForm.pbQuery )
				Call SalSendMsg( hWndForm.pbOk, PAM_HIDE, 0, 0 )
				Call SalSendMsg( hWndForm.tblField, PAM_POPULATE, 0, 0 )
			On SAM_Destroy
				If bLocalSqlPopTbl
					Call SqlDisconnect( hLocalSqlPopTbl )
				If bLocalSqlSrchTbl
					Call SqlDisconnect( hLocalSqlSrchTbl )
				If bLocalSqlDoTbl
					Call SqlDisconnect( hLocalSqlDoTbl )
				Call SalSendMsg( hWndPushbutton,PAM_ENABLE,0,0 )
				Set hWndField = hWndNULL
			On SAM_Close
				If SalTblAnyRows( hWndForm.tblField, ROW_Edited|ROW_New|
						ROW_MarkDeleted, 0 )
					If NOT ForgetChanges(  )
						Return FALSE
				Call SalWaitCursor( TRUE )

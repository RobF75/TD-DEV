			System
			User
				! PAM_Messages in here can only go in range SAM_User + 5200 -> 5299
				Number: PAM_LOOKUPITEM = SAM_User + 5200
				!
				String: LABELS = 'LABELS'
				! String: STKSTKLBLCULT = ' STOCK_LABELS, STOCK_ITEM, CULTIVAR'
				String: STKLBL = ' STOCK_LABELS '
				String: LABELFIELDS = 'LABEL_FIELDS'
				String: LABELID = ' WHERE LABELS.LABEL_ID = :hWndForm.dfLabelId'
				String: LABELFIELDSID = ' WHERE LABEL_FIELDS.LABEL_ID = :hWndForm.dfLabelId'
				String: LABELFIELDSALL = ' WHERE LABEL_FIELDS.LABEL_ID = 
						:frmFldDets.dfLabelId AND LABEL_FIELDS.FIELD_NO = :frmFldDets.dfNo'
				String: SI = ' STOCK_ITEM'
				! String: SICV = ' STOCK_ITEM, CULTIVAR'
				! String: WHERELBL = ' WHERE STOCK_LABELS.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND 
						 STOCK_ITEM.CULTIVAR_ID = CULTIVAR.CULT_ID(+) AND 
						 STOCK_LABELS.LABEL_ID = :frmUsed.dfLabelId ORDER BY 2,3,1'
				! String: WHORDBYCULT = ' WHERE CULTIVAR.CULT_ID(+) = STOCK_ITEM.CULTIVAR_ID '
				! String: ORDBYCULT = ' ORDER BY 2'
				String: LABELFIELDIDORD = ' WHERE LABEL_FIELDS.LABEL_ID = :hWndForm.dfLabelId
						ORDER BY LABEL_FIELDS.FIELD_NO'
				String: WHERESLCOLROWID = ' WHERE STOCK_LABELS.ROWID = 
						:frmUser.tblUsed.colRowId' 
				String: LABELFIELDID = ' WHERE LABEL_FIELDS.LABEL_ID = :frmLabFields.dfLabelId'
				String: WHERELABID = ' WHERE LABEL_FIELDS.LABEL_ID = :frmUsed.dfLabelId'
				String: LABELFIELDIDNO = ' WHERE LABEL_FIELDS.LABEL_ID
						 = :hWndForm.dfLabelId AND LABEL_FIELDS.FIELD_NO = :hWndForm.dfNo'
				String: ORDBYLABELDESC = ' ORDER BY LABELS.LABEL_DESC'
				String: ORDBYFIELDNO = ' ORDER BY LABEL_FIELDS.FIELD_NO'
				! String: sCarrRet = '
						'
				! Help file names for forms and dialogs
				String: sFrmQLabelHelpFileName = 'g:\\apps\\gupta\\help\\label.hlp'
				String: sFrmLabDetsHelpFileName = 'g:\\apps\\gupta\\help\\labeldet.hlp' 
				String: sFrmFldDetsHelpFileName = 'g:\\apps\\gupta\\help\\fields.hlp' 
				String: sFrmFieldHelpFileName =  'g:\\apps\\gupta\\help\\labelfld.hlp' 
				String: sFrmItemHelpFileName =  'g:\\apps\\gupta\\help\\lblitem.hlp' 
				String: sLblUseHelpFileName = 'g:\\apps\\gupta\\help\\lbluse.hlp'
				!
				Number: nExit = 10
				Number: nContinue = 11

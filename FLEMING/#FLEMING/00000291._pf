				List Initialization
					Text: L
					Text: D
					Text: B
					Text: P
				Message Actions
					On PAM_NEWREC
						Set cmbType = 'L'
						Call SalSetFieldEdit( hWndItem, TRUE )
					On PAM_SQL
						Call BuildSQL( wParam,hWndItem,'LABEL_FIELDS.FIELD_TYPE' )
					On PAM_DATAVAL
						If SalIsNull( hWndItem )
							Call SalMessageBox( 'Please enter the field type first', 'Field Details', MB_Ok )
							Return FALSE
						Else If cmbType = 'D'
							Return TRUE
						Else If cmbType = 'B'
							Return TRUE
						Else If cmbType = 'L'
							Return TRUE
						Else If cmbType = 'P'
							Return TRUE
						Else
							Call SalMessageBox( 'Please enter a valid field type first', 'Field Details', MB_Ok )
							Return FALSE
					On SAM_Validate
						Set bgEdit = TRUE
						Call SalStrUpper( cmbType, cmbType )
						Call SalSetFieldEdit( hWndItem, TRUE )

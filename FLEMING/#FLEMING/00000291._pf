							On PAM_DATAVAL
								Set sSql = 'SELECT Stock_Item_No FROM Stock_Labels WHERE 
										Stock_Item_No = :frmUsed.tblUsed.colItemNo AND 
										Label_Id = :frmUsed.dfLabelId AND 
										Stock_Label_Use = :frmUsed.tblUsed.colUse '
								If SqlExists( sSql, bExists )
									If bExists
										Call ErrorMessage( 'This stock item and label use already exists in this table!', hWndForm, MB_Ok )
										Return FALSE
								Return TRUE

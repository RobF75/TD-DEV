							Call SalMessageBox( 'Enter a Y or N for Preprinted', 'Labels',
									MB_Ok | MB_IconStop )
							Call SalSetFocus( hWndItem )
							Return FALSE
						Else If dfPreprinted = 'Y'
							Call SalSetFieldEdit( hWndItem, TRUE )
							Return TRUE
						Else If dfPreprinted = 'N'
							Call SalSetFieldEdit( hWndItem, TRUE )
							Return TRUE
						Else
							Call SalMessageBox( 'A Valid response for Preprinted is Y or N', 'Labels',
									 MB_Ok )
							Return FALSE
					On PAM_NEWREC
						Set dfPreprinted = 'N'

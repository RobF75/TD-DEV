.head 6 +  Message Actions
.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 -  Set sSQLPopHandle = ' SELECT 
  Royalty_Payable.Roy_Instance#, 
  Royalty_Payable.Cultivar_Id, 
  Cultivar.Cult_Desc, 
  Royalty_Payable.Rootstock_Id,  
  Royalty_Payable.Amount_Payable, 
  Royalty_Payable.Payment_Due_Date
FROM 
  Royalty_Payable, 
  Cultivar 
WHERE 
  Royalty_Payable.Royalty_Owner_Id = :1 AND 
  Royalty_Payable.Cultivar_Id = Cultivar.Cult_Id(+)  
ORDER BY 
  Royalty_Payable.Roy_Instance# '
.head 8 -  Set sNAMEPopHandle = 'OWNPATENT'
.head 8 -  Set sBINDPopHandle = ':hWndParent.dfOwnerId'
.head 8 -  Set sINTOPopHandle = ':clsfrmOwnersPatents.tblOwnerPatents.colRoyInstanceNo, 
:clsfrmOwnersPatents.tblOwnerPatents.colCultId, 
:clsfrmOwnersPatents.tblOwnerPatents.colCultDesc, 
:clsfrmOwnersPatents.tblOwnerPatents.colRootId,  
:clsfrmOwnersPatents.tblOwnerPatents.colAmtPayable, 
:clsfrmOwnersPatents.tblOwnerPatents.colPayDueDate'
.head 8 -  !
.head 8 -  Set sSQLRefreshHandle = ' SELECT 
  Royalty_Payable.Cultivar_Id, 
  Cultivar.Cult_Desc, 
  Royalty_Payable.Rootstock_Id,  
  Royalty_Payable.Amount_Payable, 
  Royalty_Payable.Payment_Due_Date
FROM 
  Royalty_Payable, 
  Cultivar 
WHERE 
  Royalty_Payable.Royalty_Owner_Id = :1 AND 
  Royalty_Payable.Roy_Instance# = :2 AND 
  Royalty_Payable.Cultivar_Id = Cultivar.Cult_Id(+) '
.head 8 -  Set sNAMERefreshHandle = 'REFOWNPATENT'
.head 8 -  Set sBINDRefreshHandle = ':hWndParent.dfOwnerId, 
:clsfrmOwnersPatents.tblOwnerPatents.colRoyInstanceNo'
.head 8 -  Set sINTORefreshHandle = ':clsfrmOwnersPatents.tblOwnerPatents.colCultId, 
:clsfrmOwnersPatents.tblOwnerPatents.colCultDesc, 
:clsfrmOwnersPatents.tblOwnerPatents.colRootId,  
:clsfrmOwnersPatents.tblOwnerPatents.colAmtPayable, 
:clsfrmOwnersPatents.tblOwnerPatents.colPayDueDate'
.head 8 -  !
.head 8 -  Set bAddAllowed = FALSE
.head 8 -  Set bSaveAllowed = FALSE
.head 8 -  Set bDeleteAllowed = FALSE
.head 8 -  Set bUnDeleteAllowed = FALSE
.head 8 -  Set bRepopulateAllowed = TRUE
.head 8 -  Set bClearSelectAllowed = TRUE
.head 8 -  Set bQueryAllowed = TRUE
.head 8 -  Set bReportAllowed = FALSE
.head 8 -  Set bOrderAllowed = TRUE
.head 8 -  !
.head 8 -  Set sQueryDialogName = 'dlgQueryOwnerPatents'
.head 7 +  On SAM_FetchRowDone
.head 8 +  If colRootId != ''
.head 9 -  Call ExtractRootstockDescription( colRootId, colRootDesc, SH_cls_Execute )
.head 8 -  Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
.head 7 +  On SAM_Destroy
.head 8 -  Call ExtractRootstockDescription( '', colRootDesc, SH_cls_Disconnect )
.head 8 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

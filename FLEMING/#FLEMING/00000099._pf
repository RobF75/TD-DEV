.head 4 +  Message Actions 
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sSQLPopHandle = ' SELECT 
  Royalty_Payable.Roy_Instance#, 
  Royalty_Payable.Cultivar_Id, 
  Cultivar.Cult_Desc, 
  Royalty_Payable.Rootstock_Id,  
  Royalty_Payable.Amount_Payable, 
  Royalty_Payable.Payment_Due_Date
FROM 
  Royalty_Payable, 
  Cultivar 
WHERE 
  Royalty_Payable.Royalty_Owner_Id = :1 AND 
  Royalty_Payable.Cultivar_Id = Cultivar.Cult_Id(+)  
ORDER BY 
  Royalty_Payable.Roy_Instance# '
.head 6 -  Set sNAMEPopHandle = 'OWNPATENT'
.head 6 -  Set sBINDPopHandle = ':hWndParent.dfOwnerId'
.head 6 -  Set sINTOPopHandle = ':hWndForm.colRoyInstanceNo, 
:hWndForm.colCultId, 
:hWndForm.colCultDesc, 
:hWndForm.colRootId,  
:hWndForm.colAmtPayable, 
:hWndForm.colPayDueDate'
.head 6 -  !
.head 6 -  Set sSQLRefreshHandle = ' SELECT 
  Royalty_Payable.Cultivar_Id, 
  Cultivar.Cult_Desc, 
  Royalty_Payable.Rootstock_Id,  
  Royalty_Payable.Amount_Payable, 
  Royalty_Payable.Payment_Due_Date
FROM 
  Royalty_Payable, 
  Cultivar 
WHERE 
  Royalty_Payable.Royalty_Owner_Id = :1 AND 
  Royalty_Payable.Roy_Instance# = :2 AND 
  Royalty_Payable.Cultivar_Id = Cultivar.Cult_Id(+) '
.head 6 -  Set sNAMERefreshHandle = 'REFOWNPATENT'
.head 6 -  Set sBINDRefreshHandle = ':hWndParent.dfOwnerId, 
:hWndForm.colRoyInstanceNo'
.head 6 -  Set sINTORefreshHandle = ':hWndForm.colCultId, 
:hWndForm.colCultDesc, 
:hWndForm.colRootId,  
:hWndForm.colAmtPayable, 
:hWndForm.colPayDueDate'
.head 6 -  !
.head 6 -  Set bAddAllowed = FALSE
.head 6 -  Set bSaveAllowed = FALSE
.head 6 -  Set bDeleteAllowed = FALSE
.head 6 -  Set bUnDeleteAllowed = FALSE
.head 6 -  Set bRepopulateAllowed = TRUE
.head 6 -  Set bClearSelectAllowed = TRUE
.head 6 -  Set bQueryAllowed = TRUE
.head 6 -  Set bReportAllowed = FALSE
.head 6 -  Set bOrderAllowed = TRUE
.head 6 -  !
.head 6 -  Set sQueryDialogName = 'dlgQueryOwnerPatents'
.head 5 +  On SAM_FetchRowDone
.head 6 +  If colRootId != ''
.head 7 -  Call ExtractRootstockDescription( colRootId, colRootDesc, SH_cls_Execute )
.head 6 -  Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
.head 5 +  On SAM_Destroy
.head 6 -  Call ExtractRootstockDescription( '', colRootDesc, SH_cls_Disconnect )
.head 6 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

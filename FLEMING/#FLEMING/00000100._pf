.head 6 +  Case SH_cls_Commit
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT NewDeductFromStockItemSale( 0, 0, 0, 0, '', '', 0, 0, SH_cls_Commit )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT NewDeleteFromSub( 0, 0, 0, 0, '', SH_cls_Commit )
.head 8 -  Set bOk = FALSE

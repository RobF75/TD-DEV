.head 6 +  Case SH_cls_Rollback
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT NewDeductFromStockItemSale( 0, 0, 0, 0, '', '', 0, 0, SH_cls_Rollback )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT NewDeleteFromSub( 0, 0, 0, 0, '', SH_cls_Rollback )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT GetGenericStockItemFlag( 0, sGenericFlag, SH_cls_Disconnect )

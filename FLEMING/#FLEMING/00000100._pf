.head 6 +  Case SH_cls_Execute
.head 7 +  If GetGenericStockItemFlag( nItemNo, sGenericFlag, SH_cls_Execute )
.head 8 +  If NewDeductFromStockItemSale( nItemNo, nYear, nOrdAmt, nConfAmt, sAllocFlag, sGenericFlag, nBatchLocId, nBatchYear, SH_cls_Execute )
.head 9 +  If nSubsItemNo > 0

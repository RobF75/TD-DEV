.head 2 +  Message Actions
.head 3 +  On SAM_Create
.head 4 -  Call SalSetWindowText( hWndForm, sFieldName || ' ZOOM ' )
.head 4 -  Set dfZoom = SalNumberToHString( nStrFieldValue )
.head 4 -  !
.head 4 +  If SalIsWindowEnabled( hWndParent )
.head 5 -  Call SalEnableWindow( dfZoom )
.head 4 +  Else
.head 5 -  Call SalDisableWindow( dfZoom )
.head 4 -  Call SalSetMaxDataLength( dfZoom, SalGetMaxDataLength( hWndParent ) )
.head 4 -  Call SalFontGet( hWndParent, sFontName, nFontSize, nFontEnhancements )
.head 4 -  Call SalFontSet( dfZoom, sFontName, nFontSize, nFontEnhancements )
.head 4 -  Call SalFmtSetFormat( dfZoom, SalFmtGetFormat( hWndParent ) )
.head 4 -  !
.head 4 -  Return SalSendClassMessage( SAM_Create, wParam, lParam )
.head 3 +  On PAM_clsPB_OKACTION
.head 4 -  Call SalSendMsg( hWndParent, PAM_clsDF_ZOOMEND, 0, SalHStringToNumber( dfZoom ) )
.head 4 -  Return SalSendMsg( pbExit, SAM_Click, TRUE, 0 )

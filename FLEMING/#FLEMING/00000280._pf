							On PAM_SQL
								Call BuildSQL(  wParam,hWndItem,'CUST_PROMO.YEAR_OF_ORDER' )
							On PAM_INSERT
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'CUST_PROMO.YEAR_OF_ORDER' )
							On PAM_UPDATE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'CUST_PROMO.YEAR_OF_ORDER' )
							On PAM_QBE
								If NOT SalIsNull( hWndItem )
									Call PushNumber( colYear )
								Else
									Call PushNumber( frmCustPromotions.dfYr )
								Call PushString( EQOPERAND )
								Call PushString( NUMERICFOLLOWING )
								Call PushString( 'CUST_PROMO.YEAR_OF_ORDER' )
								Return TRUE
							On PAM_DATAVAL
								If SalIsNull( hWndItem )
									Set colYear = frmCustPromotions.dfYr
									Call SalSetFieldEdit( hWndItem, TRUE )
								Return TRUE
							On PAM_INITIALIZE
								Set colYear = frmCustPromotions.dfYr
								Call SalSetFieldEdit( hWndItem, TRUE )

		Named Menus
		Internal Functions
			Function: FixFCRPMissingFromRoyaltiesPaid
				Description:
				Returns
					Boolean:
				Parameters
					Date/Time: dtInvFromDate
					Date/Time: dtInvToDate
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nSqlHandleNo
					!
					Window Handle: hWndMeter
					!
					Number: nCustNo
					Date/Time: dtOrderDT
					String: sCustName
					Number: nItemNo
					String: sCultId
					String: sRootId
					String: sSaleCat
					Date/Time: dtInvDate
					Number: nInvNo
					Number: nConfAmt
					String: sTreeType
					String: sTreeTypeDesc
					String: sCultDesc
					String: sRootDesc
					!
					String: saRoyOwnerIds[*]
					Number: naRoyOwnerAmt[*]
					!
					String: saRoyOwnerIdsCults[*]
					Number: naRoyOwnerAmtCults[*]
					String: saRoyOwnerIdsRoots[*]
					Number: naRoyOwnerAmtRoots[*]
					!
					Number: nCultRoy
					Number: nRootRoy
					Boolean: bOk
					Number: nCount
					Number: nTotalCount
					Boolean: bExists
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'FixFCRPMissingFromRoyaltiesPaid' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Customer_Order.Cust_No, 
									  Customer_Order.Order_Date_Time, 
									  Customer_Master.Cust_Name, 
									  Customer_Order.Stock_Item_No, 
									  Stock_Item.Cultivar_Id, 
									  Stock_Item.Rootstock_Id, 
									  Customer_Order.Sale_Cat, 
									  Customer_Order.Invoiced_Date, 
									  Customer_Order.Invoice_No, 
									  Customer_Order.Conf_Amt, 
									  Stock_Item.Tree_Type, 
									  Stock_Item.Type_Description, 
									  Stock_Item.Cult_Desc, 
									  Stock_Item.Root_Desc 
									FROM 
									  Customer_Order, 
									  Customer_Master, 
									  Stock_Item 
									WHERE 
									  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									  Customer_Order.Invoiced_Flag = 'Y' AND 
									  Customer_Order.Invoiced_Date BETWEEN :1 AND :2 AND 
									  Customer_Order.Sale_Cat IN ( 'FC', 'RP' )
									UNION ALL
									SELECT 
									  Cust_Order_History.Cust_No, 
									  Cust_Order_History.Order_Date_Time, 
									  Customer_Master.Cust_Name, 
									  Cust_Order_History.Stock_Item_No, 
									  Stock_Item.Cultivar_Id, 
									  Stock_Item.Rootstock_Id, 
									  Cust_Order_History.Sale_Cat, 
									  Cust_Order_History.Invoiced_Date, 
									  Cust_Order_History.Invoice_No, 
									  Cust_Order_History.Conf_Amt, 
									  Stock_Item.Tree_Type, 
									  Stock_Item.Type_Description, 
									  Stock_Item.Cult_Desc, 
									  Stock_Item.Root_Desc 
									FROM 
									  Cust_Order_History, 
									  Customer_Master, 
									  Stock_Item 
									WHERE 
									  Cust_Order_History.Cust_No = Customer_Master.Cust_No AND 
									  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
									  Cust_Order_History.Invoiced_Flag = 'Y' AND 
									  Cust_Order_History.Invoiced_Date BETWEEN :1 AND :2 AND 
									  Cust_Order_History.Sale_Cat IN ( 'FC', 'RP' ) "
							Set sName = 'FIXFCRPROYMISS'
							Set sBind = ':dtInvFromDate, :dtInvToDate'
							Set sInto = ':nCustNo, 
									:dtOrderDT, 
									:sCustName, 
									:nItemNo, 
									:sCultId, 
									:sRootId, 
									:sSaleCat, 
									:dtInvDate, 
									:nInvNo, 
									:nConfAmt, 
									:sTreeType, 
									:sTreeTypeDesc, 
									:sCultDesc, 
									:sRootDesc'
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set nCustNo = NUMBER_Null
							Set dtOrderDT = DATETIME_Null
							Set sCustName = ''
							Set nItemNo = NUMBER_Null
							Set sCultId = ''
							Set sRootId = ''
							Set sSaleCat = ''
							Set dtInvDate = DATETIME_Null
							Set nInvNo = NUMBER_Null
							Set nConfAmt = NUMBER_Null
							Set sTreeType = ''
							Set sTreeTypeDesc = ''
							Set sCultDesc = ''
							Set sRootDesc = ''
							!
							Set saRoyOwnerIds[ 0 ] = ''
							Set naRoyOwnerAmt[ 0 ] = NUMBER_Null
							Set saRoyOwnerIdsCults[ 0 ] = ''
							Set naRoyOwnerAmtCults[ 0 ] = NUMBER_Null
							Set saRoyOwnerIdsRoots[ 0 ] = ''
							Set naRoyOwnerAmtRoots[ 0 ] = NUMBER_Null
							!
							Set bOk = TRUE
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								Call haSqlHandles[ nSqlHandleNo ].ResultSetCount( nTotalCount )
								Set nCount = 0
								If nTotalCount >= nNumRowsToMeter
									Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Fixing FC, RP missing from Royalties paid file.', nTotalCount )
								While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd ) AND bOk
									If sCultId != ''
										Call CalcCultivarRoyalty( nCustNo, sCultId, nItemNo, nCultRoy, nExecute )
									If sRootId != ''
										Call CalcRootstockRoyalty( nCustNo, sRootId, nItemNo, nRootRoy, nExecute )
									!
									If nCultRoy > 0 OR nRootRoy > 0
										Call ExistsOrderInRoyaltiesPaid( nCustNo, dtOrderDT, bExists, nExecute )
										If NOT bExists
											If nRootRoy > 0
												If UpdtRoyaltyOwnerTotal( nCustNo, nItemNo, 0, nROY_CreditRoy, sRootId, nROY_RootstockId, saRoyOwnerIdsRoots, naRoyOwnerAmtRoots, nExecute )
													Call UpdtRoyaltyOwnerTotal( 0, 0, 0, 0, '', 0, saRoyOwnerIdsRoots, naRoyOwnerAmtRoots, nCommit )
													Call WriteOrderRoyaltiesPaid( nROY_RootstockId, sCultId, sRootId, nCustNo, sCustName, 
															dtInvDate, nInvNo, nConfAmt, sSaleCat, sTreeType, sTreeTypeDesc, sCultDesc, sRootDesc, 
															nItemNo, dtOrderDT, saRoyOwnerIdsRoots, naRoyOwnerAmtRoots, nExecute )
												Else
													Set bOk = FALSE
											If nCultRoy > 0
												If UpdtRoyaltyOwnerTotal( nCustNo, nItemNo, 0, nROY_CreditRoy, sCultId, nROY_CultivarId, saRoyOwnerIdsCults, naRoyOwnerAmtCults, nExecute )
													Call UpdtRoyaltyOwnerTotal( 0, 0, 0, 0, '', 0, saRoyOwnerIdsCults, naRoyOwnerAmtCults, nCommit )
													Call WriteOrderRoyaltiesPaid( nROY_CultivarId, sCultId, sRootId, nCustNo, sCustName, 
															dtInvDate, nInvNo, nConfAmt, sSaleCat, sTreeType, sTreeTypeDesc, sCultDesc, sRootDesc, 
															nItemNo, dtOrderDT, saRoyOwnerIdsCults, naRoyOwnerAmtCults, nExecute )
												Else
													Set bOk = FALSE
									!
									Set nCount = nCount + 1
									Call SalSendMsg( hWndMeter, PAM_SETPROGRESS, 0, nCount )
								Call SalSendMsg( hWndMeter, PAM_END, 0, 0 )
							Else
								Set bOk = FALSE
							Return bOk
						Case nDisconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nSqlHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT  CalcCultivarRoyalty( 0, '', 0, nCultRoy, nDisconnect )
								Set bOk = FALSE
							If NOT  CalcRootstockRoyalty( 0, '', 0, nRootRoy, nDisconnect )
								Set bOk = FALSE
							If NOT UpdtRoyaltyOwnerTotal( 0, 0, 0, 0, '', 0, saRoyOwnerIds, naRoyOwnerAmt, nDisconnect )
								Set bOk = FALSE
							If NOT WriteOrderRoyaltiesPaid( 0, '', '', 0, '', DATETIME_Null, 0, 0, '', '', '', '', '', 0, DATETIME_Null, saRoyOwnerIds, naRoyOwnerAmt, nDisconnect )
								Set bOk = FALSE
							If NOT ExistsOrderInRoyaltiesPaid( 0, DATETIME_Null, bExists, nDisconnect )
								Set bOk = FALSE
							Return bOk
			Function: FixZamMissingFromRoyaltiesPaid
				Description:
				Returns
					Boolean:
				Parameters
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nSqlHandleNo
					!
					Window Handle: hWndMeter
					!
					Number: nCustNo
					Date/Time: dtOrderDT
					String: sCustName
					Number: nItemNo
					String: sCultId
					String: sRootId
					String: sSaleCat
					Date/Time: dtInvDate
					Number: nInvNo
					Number: nConfAmt
					String: sTreeType
					String: sTreeTypeDesc
					String: sCultDesc
					String: sRootDesc
					!
					String: saRoyOwnerIds[*]
					Number: naRoyOwnerAmt[*]
					!
					String: saRoyOwnerIdsCults[*]
					Number: naRoyOwnerAmtCults[*]
					String: saRoyOwnerIdsRoots[*]
					Number: naRoyOwnerAmtRoots[*]
					!
					Number: nCultRoy
					Number: nRootRoy
					Boolean: bOk
					Number: nCount
					Number: nTotalCount
					Boolean: bExists
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'FixNewZamMissingFromRoyaltiesPaid' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Customer_Order.Cust_No, 
									  Customer_Order.Order_Date_Time, 
									  Customer_Master.Cust_Name, 
									  Customer_Order.Stock_Item_No, 
									  Stock_Item.Cultivar_Id, 
									  Stock_Item.Rootstock_Id, 
									  Customer_Order.Sale_Cat, 
									  Customer_Order.Invoiced_Date, 
									  Customer_Order.Invoice_No, 
									  Customer_Order.Conf_Amt, 
									  Stock_Item.Tree_Type, 
									  Stock_Item.Type_Description, 
									  Stock_Item.Cult_Desc, 
									  Stock_Item.Root_Desc 
									FROM 
									  Customer_Order, 
									  Customer_Master, 
									  Stock_Item 
									WHERE 
									  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									  Customer_Order.Invoiced_Flag = 'Y' AND 
									  Customer_Order.Invoiced_Date < 1998-12-16 AND 
									  Customer_Order.Year_Of_Sale = 1998 AND  
									  Customer_Order.Stock_Item_NO IN ( 9448,6918,6928,12770 ) "
							Set sName = 'FIXNWZMROYMISS'
							Set sBind = ''
							Set sInto = ':nCustNo, 
									:dtOrderDT, 
									:sCustName, 
									:nItemNo, 
									:sCultId, 
									:sRootId, 
									:sSaleCat, 
									:dtInvDate, 
									:nInvNo, 
									:nConfAmt, 
									:sTreeType, 
									:sTreeTypeDesc, 
									:sCultDesc, 
									:sRootDesc'
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set nCustNo = NUMBER_Null
							Set dtOrderDT = DATETIME_Null
							Set sCustName = ''
							Set nItemNo = NUMBER_Null
							Set sCultId = ''
							Set sRootId = ''
							Set sSaleCat = ''
							Set dtInvDate = DATETIME_Null
							Set nInvNo = NUMBER_Null
							Set nConfAmt = NUMBER_Null
							Set sTreeType = ''
							Set sTreeTypeDesc = ''
							Set sCultDesc = ''
							Set sRootDesc = ''
							!
							Set saRoyOwnerIds[ 0 ] = ''
							Set naRoyOwnerAmt[ 0 ] = NUMBER_Null
							Set saRoyOwnerIdsCults[ 0 ] = ''
							Set naRoyOwnerAmtCults[ 0 ] = NUMBER_Null
							Set saRoyOwnerIdsRoots[ 0 ] = ''
							Set naRoyOwnerAmtRoots[ 0 ] = NUMBER_Null
							!
							Set bOk = TRUE
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								Call haSqlHandles[ nSqlHandleNo ].ResultSetCount( nTotalCount )
								Set nCount = 0
								If nTotalCount >= nNumRowsToMeter
									Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Fixing Newzam missing from Royalties paid file.', nTotalCount )
								While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd ) AND bOk
									If sCultId != ''
										Call CalcCultivarRoyalty( nCustNo, sCultId, nItemNo, nCultRoy, nExecute )
									If sRootId != ''
										Call CalcRootstockRoyalty( nCustNo, sRootId, nItemNo, nRootRoy, nExecute )
									!
									If nCultRoy > 0 OR nRootRoy > 0
										Call ExistsOrderInRoyaltiesPaid( nCustNo, dtOrderDT, bExists, nExecute )
										If NOT bExists
											If nRootRoy > 0
												If UpdtRoyaltyOwnerTotal( nCustNo, nItemNo, 0, nROY_CreditRoy, sRootId, nROY_RootstockId, saRoyOwnerIdsRoots, naRoyOwnerAmtRoots, nExecute )
													Call UpdtRoyaltyOwnerTotal( 0, 0, 0, 0, '', 0, saRoyOwnerIdsRoots, naRoyOwnerAmtRoots, nCommit )
													Call WriteOrderRoyaltiesPaid( nROY_RootstockId, sCultId, sRootId, nCustNo, sCustName, 
															dtInvDate, nInvNo, nConfAmt, sSaleCat, sTreeType, sTreeTypeDesc, sCultDesc, sRootDesc, 
															nItemNo, dtOrderDT, saRoyOwnerIdsRoots, naRoyOwnerAmtRoots, nExecute )
												Else
													Set bOk = FALSE
											If nCultRoy > 0
												If UpdtRoyaltyOwnerTotal( nCustNo, nItemNo, 0, nROY_CreditRoy, sCultId, nROY_CultivarId, saRoyOwnerIdsCults, naRoyOwnerAmtCults, nExecute )
													Call UpdtRoyaltyOwnerTotal( 0, 0, 0, 0, '', 0, saRoyOwnerIdsCults, naRoyOwnerAmtCults, nCommit )
													Call WriteOrderRoyaltiesPaid( nROY_CultivarId, sCultId, sRootId, nCustNo, sCustName, 
															dtInvDate, nInvNo, nConfAmt, sSaleCat, sTreeType, sTreeTypeDesc, sCultDesc, sRootDesc, 
															nItemNo, dtOrderDT, saRoyOwnerIdsCults, naRoyOwnerAmtCults, nExecute )
												Else
													Set bOk = FALSE
									!
									Set nCount = nCount + 1
									Call SalSendMsg( hWndMeter, PAM_SETPROGRESS, 0, nCount )
								Call SalSendMsg( hWndMeter, PAM_END, 0, 0 )
							Else
								Set bOk = FALSE
							Return bOk
						Case nDisconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nSqlHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT  CalcCultivarRoyalty( 0, '', 0, nCultRoy, nDisconnect )
								Set bOk = FALSE
							If NOT  CalcRootstockRoyalty( 0, '', 0, nRootRoy, nDisconnect )
								Set bOk = FALSE
							If NOT UpdtRoyaltyOwnerTotal( 0, 0, 0, 0, '', 0, saRoyOwnerIds, naRoyOwnerAmt, nDisconnect )
								Set bOk = FALSE
							If NOT WriteOrderRoyaltiesPaid( 0, '', '', 0, '', DATETIME_Null, 0, 0, '', '', '', '', '', 0, DATETIME_Null, saRoyOwnerIds, naRoyOwnerAmt, nDisconnect )
								Set bOk = FALSE
							If NOT ExistsOrderInRoyaltiesPaid( 0, DATETIME_Null, bExists, nDisconnect )
								Set bOk = FALSE
							Return bOk
			Function: ExistsOrderInRoyaltiesPaid
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Date/Time: dtOrderDT
					Receive Boolean: bExists
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nSqlHandleNo
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'ExistsOrderInRoyaltiesPaid' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									    Paid_Date_Time 
									FROM 
									  Royalties_Paid 
									WHERE 
									  Cust_No = :1 AND 
									  Order_Date_Time = :2 "
							Set sName = 'EXISTSORDINRPAID'
							Set sBind = ':nCustNo, :dtOrderDT'
							Set sInto = ''
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set bExists = FALSE
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									Set bExists = TRUE
								Return TRUE
							Else
								Return FALSE
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			!
			! The next 3 functions are for keeping selected rows on frmOrders.tblOrder
			Function: InitialiseSelectedRowsArray
				Description:
				Returns
				Parameters
					Receive Date/Time: dtSelectedRowOrdDTArray[*]
					Receive Number: nLastSelectedRowOrdDT
					Window Handle: hWndTable
					Receive Boolean: bTurnOffCheckToSelectRow
				Static Variables
				Local variables
					Number: nRow
					Number: nCount
					Boolean: bFinish
				Actions
					If nLastSelectedRowOrdDT > -1
						Set bTurnOffCheckToSelectRow = TRUE
						Set bFinish = FALSE
						Set nCount = -1
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( hWndTable, nRow, 0, 0 ) AND NOT bFinish
							Call SalTblFetchRow( hWndTable, nRow )
							If CheckToSelectRow( dtSelectedRowOrdDTArray, nLastSelectedRowOrdDT, hWndTable.colOrderDateTime, hWndTable, nRow )
								Set nCount = nCount + 1
							If nCount >= nLastSelectedRowOrdDT
								Set bFinish = TRUE
					!
					Set nLastSelectedRowOrdDT = -1
					Set nRow = TBL_MinRow
					While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
						Call SalTblFetchRow( hWndTable, nRow )
						Set nLastSelectedRowOrdDT = nLastSelectedRowOrdDT + 1
						Set dtSelectedRowOrdDTArray[ nLastSelectedRowOrdDT ] = hWndTable.colOrderDateTime
					Set bTurnOffCheckToSelectRow = FALSE
			Function: CheckToSelectRow
				Description:
				Returns
					Boolean:
				Parameters
					Date/Time: dtSelectedRowOrdDTArray[*]
					Number: nLastSelectedRowOrdDT
					Date/Time: dtColDateTime
					Window Handle: hWndTable
					Number: nRow
				Static Variables
				Local variables
					Number: nCount
					Boolean: bFound
				Actions
					Set bFound = FALSE
					Set nCount = 0
					While nCount <= nLastSelectedRowOrdDT AND NOT bFound
						If dtSelectedRowOrdDTArray[ nCount ] = dtColDateTime
							Set bFound = TRUE
							If NOT SalTblQueryRowFlags( hWndTable, nRow, ROW_Selected )
								Call SalTblSetFocusRow( hWndTable, nRow )
								Call SalTblSetContext( hWndTable, nRow )
								Call SalTblSetRowFlags( hWndTable, nRow, ROW_Selected, TRUE )
						Set nCount = nCount + 1
					If bFound
						Return TRUE
					Else
						Return FALSE
			Function: ForceBackEndToSelectToReset
				Description: Because the rows are selected on SAM_FetchRow if on table 
						click the user select new rows or modifies,  This functions brings
						back the backend result set rows so that they can be selected
						before reseting the nLastSelectedRowOrdDT counter of the 
						rows that are being remembered.  So that next time pulling,
						invoicing etc. is run we have the rows selected in the table and
						we can correctly reset the remembered rows.
				Returns
				Parameters
					Window Handle: hWndTable
					Receive Number: nLastSelectedRowOrdDT
				Static Variables
				Local variables
					Number: nRow
					Number: nOriginalRowContext
				Actions
					If nLastSelectedRowOrdDT > -1
						Call SalWaitCursor( TRUE )
						Set nOriginalRowContext = SalTblQueryContext( hWndTable )
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( hWndTable, nRow, 0, 0 )
							Call SalTblFetchRow( hWndTable, nRow )
						Call SalTblFetchRow( hWndTable, nOriginalRowContext )
						Set nLastSelectedRowOrdDT = -1
						Call SalWaitCursor( FALSE )
			!
			Function: AssignOrdersToHardCodeLoads
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Window Handle: hWndTable
					Number: nLoadType
				Static Variables
				Local variables
					Sql Handle: hSqlUpdateHdl
					Boolean: bSqlUpdateHdlConnected
					Boolean: bSqlUpdateHdlPrepared
					!
					String: sLoadId
					String: sSqlUpdate
					Number: nRow
					Boolean: bPulled
				Actions
					Call SalWaitCursor( TRUE )
					Call SalSendMsg( hWndTable, PAM_REMEMBERSELECTEDROWS, 0, 0 )
					Set sLoadId = ''
					!
					Select Case nLoadType
						Case nCustInvLoad
							Set sLoadId = 'CUSTINV'
							Break
						Case nPickupLoad
							Set sLoadId = 'PICKUPS'
							Break
						Case nRailLoad
							Set sLoadId = GetCustRailMailLoadId( nCustNo, nLoadType )
							Break
						Case nMailLoad
							Set sLoadId = GetCustRailMailLoadId( nCustNo, nLoadType )
					If sLoadId != ''
						Call UpdateLoadCustomers( sLoadId, nCustNo )
						Set bPulled = FALSE
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
							Call SalTblFetchRow( hWndTable, nRow )
							If hWndTable.colPullFlag != 'Y'
								Call UpdtCustOrdLoadId( hSqlUpdateHdl, bSqlUpdateHdlConnected, bSqlUpdateHdlPrepared, sLoadId, nCustNo, hWndTable )
							Else
								Set bPulled = TRUE
						Call SalSendMsg( hWndTable, PAM_REPOPULATE, 0, 0 )
						Call SalWaitCursor( FALSE )
						If bPulled
							Call SalMessageBox( 'One or more selected orders could not be assigned because they were pulled!', 'NOTE', MB_Ok )
					Else
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'Error Occured in Obtaining the correct Load_Id to Use! Order Have not been Assigned!', 'Error', MB_Ok )
			Function: GetCustRailMailLoadId
				Description:
				Returns
					String:
				Parameters
					Number: nCustNo
					Number: nLoadType
				Static Variables
				Local variables
					Sql Handle: hSqlHandle
					Boolean: bSqlHandle
					String: sLoadIdLike
					String: sLoadId
					String: sSql
					Number: nInd
				Actions
					Set bSqlHandle = SqlConnect( hSqlHandle ) 
					If bSqlHandle
						Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
					Else
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						Call SalWaitCursor( TRUE )
						Return ''
					!
					Set sLoadId = ''
					Select Case nLoadType
						Case nRailLoad
							Set sLoadIdLike = 'RAIL%'
							Break
						Case nMailLoad
							Set sLoadIdLike = 'MAIL%'
							Break
						Default
							Set sLoadIdLike = ''
					Set sSql = 'SELECT Region_Load.Load_Id FROM Region_Load, Customer_Master 
							INTO :sLoadId WHERE Customer_Master.Cust_No = :nCustNo AND 
							Customer_Master.Region_Id = Region_Load.Region_Id AND 
							Region_Load.Load_Id LIKE :sLoadIdLike '
					If SqlPrepareAndExecute( hSqlHandle, sSql )
						Call SqlFetchNext( hSqlHandle, nInd )
						If bSqlHandle
							Call SqlDisconnect( hSqlHandle )
						Return sLoadId
					Else
						If bSqlHandle
							Call SqlDisconnect( hSqlHandle )
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'Error occured in GetCustRailMailLoadId( ), no Load Id was retrieved, Please Contact programmers! ', 'Error', MB_Ok )
						Call SalWaitCursor( TRUE )
						Return ''
			Function: UpdtCustOrdLoadId
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					String: sLoadId
					Number: nCustNo
					Window Handle: hWndTable
				Static Variables
				Local variables
					String: sSqlUpdate
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Call SalWaitCursor( TRUE )
							Return FALSE
					If NOT bHandlePrepared
						Set sSqlUpdate = 'UPDATE Customer_Order SET Load_Id = :sLoadId WHERE Cust_No = :nCustNo AND Order_Date_Time = :hWndTable.colOrderDateTime '
						If SqlPrepare( hSqlHandle, sSqlUpdate )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						Call SqlCommit( hSqlHandle )
						Return TRUE
					Else
						Set bHandlePrepared = FALSE
						Call SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'Error occured in updating a order line! A order line per this message was not updated!', 'Error', MB_Ok )
						Call SalWaitCursor( TRUE )
					Return FALSE
			Function: UpdateLoadCustomers
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nCustNo
				Static Variables
				Local variables
					Sql Handle: hSqlHandle
					Boolean: bSqlHandle
					!
					String: sSql
					Number: nInd
					Number: nSeqNo
					!
					Boolean: bCustOnLoad
				Actions
					Set bSqlHandle = SqlConnect( hSqlHandle ) 
					If bSqlHandle
						Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
					Else
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						Call SalWaitCursor( TRUE )
						Return FALSE
					!
					Set sSql = 'SELECT Sequence_No FROM Load_Customers WHERE Load_Id = :sLoadId AND Cust_No = :nCustNo '
					If SqlPrepareAndExecute( hSqlHandle, sSql )
						Call SqlFetchNext( hSqlHandle, nInd )
						If nInd = FETCH_Ok
							Set bCustOnLoad = TRUE
						Else
							Set bCustOnLoad = FALSE
					Else
						If bSqlHandle
							Call SqlDisconnect( hSqlHandle )
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'SqlPrepareAndExecute had a error in UpdateLoadCustomers( ), Please contact Programmers.', 'Error', MB_Ok )
						Call SalWaitCursor( TRUE )
						Return FALSE
					!
					If NOT bCustOnLoad
						Set nSeqNo = NUMBER_Null
						Set sSql = 'SELECT Max( Sequence_No ) FROM Load_Customers INTO :nSeqNo WHERE Load_Id = :sLoadId '
						If SqlPrepareAndExecute( hSqlHandle, sSql )
							Call SqlFetchNext( hSqlHandle, nInd )
						Else
							If bSqlHandle
								Call SqlDisconnect( hSqlHandle )
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'SqlPrepareAndExecute had a error in UpdateLoadCustomers( ), Please contact Programmers.', 'Error', MB_Ok )
							Call SalWaitCursor( TRUE )
							Return FALSE
						If nSeqNo = NUMBER_Null
							Set nSeqNo = 5
						Else
							Set nSeqNo = nSeqNo + 5
						!
						Set sSql = 'INSERT INTO Load_Customers ( Load_Id, Sequence_No, Cust_No, Cust_Cont_Flag, Load_Order_Type, Cust_Pulled_Flag, Cust_Inv_Flag ) 
								VALUES ( :sLoadId, :nSeqNo, :nCustNo, \'N\', \'S\', \'N\', \'N\' ) '
						If SqlPrepareAndExecute( hSqlHandle, sSql )
							Call SqlCommit( hSqlHandle )
						Else
							Call SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
							If bSqlHandle
								Call SqlDisconnect( hSqlHandle )
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Error occured in updating Load_Customers! This customers was not put against the Load!', 'Error', MB_Ok )
							Call SalWaitCursor( TRUE )
							Return FALSE
					If bSqlHandle
						Call SqlDisconnect( hSqlHandle )
					Return TRUE
			!
			Function: CustDepositReqd
				Description: Check the Deposit_reqd flag of Customer_Master for the given cust_no
						and return FALSE if the customer isnt required to pay a deposit or 
						if the customer is required to pay a deposit and has already done so
						for the year in question.  A TRUE return means that we need to get
						deposit details for this customer.
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Number: nYear
				Static Variables
				Local variables
					String: sTmpDepReqd
					Number: nItemNo
					Number: nAmtReqd
				Actions
					Set sTmpDepReqd = ''
					Set sgSql = 'SELECT Dep_Reqd_Flag FROM Customer_Master INTO :sTmpDepReqd WHERE 
							  Cust_No = :nCustNo'
					If SqlImmediate( sgSql )
						Call SqlClearImmediate(  )
						If sTmpDepReqd != 'Y'
							Return FALSE
					Else
						Call SqlClearImmediate(  )
						Return FALSE
					Set nItemNo = 0
					Set sgSql = 'SELECT Stock_Item_No FROM Customer_Order INTO :nItemNo WHERE 
							  Cust_No = :nCustNo AND Year_Of_Sale = :nYear AND INVOICED_FLAG = \'N\''
					If SqlImmediate( sgSql )
						Call SqlClearImmediate(  )
						If nItemNo = 0
							Return FALSE
					Else
						Call SqlClearImmediate(  )
						Return FALSE
					Set nAmtReqd = 0
					Set sgSql =  'SELECT Dep_Amount_Reqd FROM Outstand_Deposit INTO
							 :nAmtReqd WHERE Cust_No = :nCustNo AND Dep_Year_Of_Sale = :nYear'
					If SqlImmediate( sgSql )
						Call SqlClearImmediate(  )
						If nAmtReqd = 0
							Return TRUE
						Else
							Return FALSE
					Else
						Call SqlClearImmediate(  )
						Return FALSE
			!
			! Function: GetExtraBitsForAllCust 
				                                                                                                                                                   Description: To prime the shipping date, ship via and all those extra bits
						 for All customers acknowledgement report 
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   Window Handle: hWndTable
					                                                                                                                                                   Number: nCustNo
					                                                                                                                                                   Number: nAckYear
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Sql Handle: hSqlHandle
					                                                                                                                                                   Boolean: bSqlHandle
					                                                                                                                                                   String: sSql
					                                                                                                                                                   Number: nInd
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set bSqlHandle = SqlConnect( hSqlHandle ) 
					                                                                                                                                                   If bSqlHandle
						                                                                                                                                                   Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   Call CallBuildSql( hWndTable, nSELECT, PAM_SQL2, ' TRANSPORT_METHOD, LOAD, CUSTOMER_ORDER', 
							' WHERE CUSTOMER_ORDER.CUST_NO = :nCustNo AND
							CUSTOMER_ORDER.YEAR_OF_SALE = :nAckYear AND
							CUSTOMER_ORDER.LOAD_ID = LOAD.LOAD_ID AND
							LOAD.TRANSPORT_ID = TRANSPORT_METHOD.TRANSPORT_ID' )
					                                                                                                                                                   If SqlPrepare( hSqlHandle, sgSql )
						                                                                                                                                                   If SqlExecute( hSqlHandle )
							                                                                                                                                                   Call SqlFetchNext( hSqlHandle, nInd )
						                                                                                                                                                   Else 
							                                                                                                                                                   Call SalMessageBox( 'SqlExecute had a error in function GetExtraBitsForAllCust.  Please contact programmers.', 'Error', MB_Ok )
							                                                                                                                                                   If bSqlHandle
								                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
							                                                                                                                                                   Return FALSE
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'SqlPrepare had a error in function GetExtraBitsForAllCust.  Please contact programmers.', 'Error', MB_Ok )
						                                                                                                                                                   If bSqlHandle
							                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   If bSqlHandle
						                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
					                                                                                                                                                   Return TRUE
			!
			! Function: HasCustAnyUnAckments
				                                                                                                                                                   Description: 
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   Number: nCustNo
					                                                                                                                                                   Number: nAckYear
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Sql Handle: hSqlHandle
					                                                                                                                                                   Boolean: bSqlHandle
					                                                                                                                                                   String: sTmpAck
					                                                                                                                                                   String: sSql
					                                                                                                                                                   Number: nInd
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set bSqlHandle = SqlConnect( hSqlHandle ) 
					                                                                                                                                                   If bSqlHandle
						                                                                                                                                                   Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   Set sTmpAck = ''
					                                                                                                                                                   Set sSql = 'select distinct ack_flag 
							from customer_order
							into :sTmpAck
							where cust_no = :nCustNo and ack_flag = \'N\' and
							year_of_sale = :nAckYear'
					                                                                                                                                                   If SqlPrepare( hSqlHandle, sSql )
						                                                                                                                                                   If SqlExecute( hSqlHandle )
							                                                                                                                                                   Call SqlFetchNext( hSqlHandle, nInd )
						                                                                                                                                                   Else 
							                                                                                                                                                   Call SalMessageBox( 'SqlExecute had a error in function HasCustAnyUnAckments.  Please contact programmers.', 'Error', MB_Ok )
							                                                                                                                                                   If bSqlHandle
								                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
							                                                                                                                                                   Return FALSE
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'SqlPrepare had a error in function HasCustAnyUnAckments.  Please contact programmers.', 'Error', MB_Ok )
						                                                                                                                                                   If bSqlHandle
							                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   If sTmpAck != ''
						                                                                                                                                                   If bSqlHandle
							                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
						                                                                                                                                                   Return TRUE
					                                                                                                                                                   If bSqlHandle
						                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
					                                                                                                                                                   Return FALSE
			! Function: HasCustAnyUnConfirms
				                                                                                                                                                   Description: 
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   Number: nCustNo
					                                                                                                                                                   Number: nYear
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Sql Handle: hSqlHandle
					                                                                                                                                                   Boolean: bSqlHandle
					                                                                                                                                                   String: sSql
					                                                                                                                                                   Number: nInd
					                                                                                                                                                   String: sTmpConf
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set bSqlHandle = SqlConnect( hSqlHandle ) 
					                                                                                                                                                   If bSqlHandle
						                                                                                                                                                   Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   Set sTmpConf = ''
					                                                                                                                                                   Set sSql = 'select distinct conf_flag 
							from customer_order
							into :sTmpConf
							where cust_no = :nCustNo and conf_flag = \'N\' and
							year_of_sale = :nYear'
					                                                                                                                                                   If SqlPrepare( hSqlHandle, sSql )
						                                                                                                                                                   If SqlExecute( hSqlHandle )
							                                                                                                                                                   Call SqlFetchNext( hSqlHandle, nInd )
						                                                                                                                                                   Else 
							                                                                                                                                                   Call SalMessageBox( 'SqlExecute had a error in function HasCustAnyUnConfirms.  Please contact programmers.', 'Error', MB_Ok )
							                                                                                                                                                   If bSqlHandle
								                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
							                                                                                                                                                   Return FALSE
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'SqlPrepare had a error in function HasCustAnyUnConfirms.  Please contact programmers.', 'Error', MB_Ok )
						                                                                                                                                                   If bSqlHandle
							                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   If sTmpConf != ''
						                                                                                                                                                   If bSqlHandle
							                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
						                                                                                                                                                   Return TRUE
					                                                                                                                                                   If bSqlHandle
						                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
					                                                                                                                                                   Return FALSE
			! Function: GetItemisedAckForCust
				                                                                                                                                                   Description: 
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   String: sTmpItemisedAck
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set sTmpItemisedAck = ''
					                                                                                                                                                   Set sgSql = 'SELECT Customer_Type.Itemised_Ack 
							FROM Customer_Type, Customer_Master
							INTO :sTmpItemisedAck 
							WHERE Customer_Master.Cust_No = :frmOrders.dfCustNo AND
							Customer_Master.Customer_Type = Customer_Type.Cust_Type'
					                                                                                                                                                   If SqlImmediate( sgSql )
						                                                                                                                                                   Call SqlClearImmediate(  )
						                                                                                                                                                   If sTmpItemisedAck = 'Y'
							                                                                                                                                                   Return TRUE
						                                                                                                                                                   Else 
							                                                                                                                                                   Return FALSE
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SqlClearImmediate(  )
						                                                                                                                                                   Return FALSE
			!
			! Function: CalculateMessageLegend
				                                                                                                                                                   Description: 
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   Boolean: bUseStockItemCount
					                                                                                                                                                   Window Handle: hWndTable
					                                                                                                                                                   Number: nYear
					                                                                                                                                                   Receive String: sMessageLegend[1:*]
					                                                                                                                                                   Receive Number: nLastArrayEntry
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Sql Handle: hSqlHandle
					                                                                                                                                                   Boolean: bSqlHandle
					                                                                                                                                                   String: sSql
					                                                                                                                                                   Number: nInd
					                                                                                                                                                   String: sTreeTypeMessage
					                                                                                                                                                   Number: nLegendNo
					                                                                                                                                                   Number: nAmount
					                                                                                                                                                   Boolean: bStockCountMessageTaken
					                                                                                                                                                   Boolean: bCalculateLegend
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set bSqlHandle = SqlConnect( hSqlHandle ) 
					                                                                                                                                                   If bSqlHandle
						                                                                                                                                                   Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   Set bStockCountMessageTaken = FALSE
					                                                                                                                                                   If bUseStockItemCount
						                                                                                                                                                   Set bCalculateLegend = FALSE
						! Get amount of trees ordered by customer, if we have a confirmed amount
								use it ever ordered amount
						                                                                                                                                                   If NOT SalIsNull( hWndTable.colConfAmt )
							                                                                                                                                                   Set nAmount = hWndTable.colConfAmt
						                                                                                                                                                   Else 
							                                                                                                                                                   Set nAmount = hWndTable.colOrdAmt
						! If the order was substituted then check the availability of the substitute only
								else availability of the ordered stock item.
						                                                                                                                                                   If hWndTable.colSubsItemNo != NUMBER_Null 
							                                                                                                                                                   If NOT AvailabilityOk(  hWndTable.colSubsItemNo, nYear, nAmount )
								                                                                                                                                                   Set sSql = 'SELECT Ack_Count_message FROM Tree_Type
										INTO :sTreeTypeMessage
										WHERE Tree_Type = :hWndTable.colType'
								                                                                                                                                                   Call SqlPrepare( hSqlHandle, sSql )
								                                                                                                                                                   Call SqlExecute( hSqlHandle )
								                                                                                                                                                   Call SqlFetchNext( hSqlHandle, nInd )
								                                                                                                                                                   If NOT sTreeTypeMessage = ''
									                                                                                                                                                   Set bStockCountMessageTaken = TRUE
									                                                                                                                                                   Set bCalculateLegend = TRUE
						                                                                                                                                                   Else 
							                                                                                                                                                   If NOT AvailabilityOk(  hWndTable.colItemNo, nYear, nAmount )
								                                                                                                                                                   Set sSql = 'SELECT Ack_Count_message FROM Tree_Type
										INTO :sTreeTypeMessage
										WHERE Tree_Type = :hWndTable.colType'
								                                                                                                                                                   Call SqlPrepare( hSqlHandle, sSql )
								                                                                                                                                                   Call SqlExecute( hSqlHandle )
								                                                                                                                                                   Call SqlFetchNext( hSqlHandle, nInd )
								                                                                                                                                                   If NOT sTreeTypeMessage = ''
									                                                                                                                                                   Set bStockCountMessageTaken = TRUE
									                                                                                                                                                   Set bCalculateLegend = TRUE
					! Always print the general message IF we have one
					                                                                                                                                                   If NOT bStockCountMessageTaken
						                                                                                                                                                   Set sSql = 'SELECT Ack_Gen_message FROM Tree_Type
								INTO :sTreeTypeMessage
								WHERE Tree_Type = :hWndTable.colType'
						                                                                                                                                                   Call SqlPrepare( hSqlHandle, sSql )
						                                                                                                                                                   Call SqlExecute( hSqlHandle )
						                                                                                                                                                   Call SqlFetchNext( hSqlHandle, nInd )
						                                                                                                                                                   If NOT sTreeTypeMessage = ''
							                                                                                                                                                   Set bCalculateLegend = TRUE
					                                                                                                                                                   If bCalculateLegend
						                                                                                                                                                   Set nLegendNo = GetMessageLegendNo ( sTreeTypeMessage, sMessageLegend, nLastArrayEntry )
						                                                                                                                                                   If nLegendNo > 0
							                                                                                                                                                   Set hWndTable.colAvailability = nLegendNo
						                                                                                                                                                   Else 
							                                                                                                                                                   Call AddMessageToLegend( sTreeTypeMessage, hWndTable, sMessageLegend, nLastArrayEntry )
					                                                                                                                                                   If bSqlHandle
						                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
			! Function: AvailabilityOk
				                                                                                                                                                   Description: To compare the passed in ordered amount of the passed in stock Item
						against the total availability of the stock item in the stock_item_Sale
						file.  If availability Ok, ie: total availability - ordered amount isnt less 
						than the threshold (20 or so) then it returns true else false
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   Number: nItemNo
					                                                                                                                                                   Number: nYear
					                                                                                                                                                   Number: nOrderedAmount
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Sql Handle: hSqlHandle
					                                                                                                                                                   Boolean: bSqlHandle
					                                                                                                                                                   String: sSql
					                                                                                                                                                   Number: nInd
					                                                                                                                                                   Number: nAvailThreshold
					                                                                                                                                                   Number: nTotalAvail
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set bSqlHandle = SqlConnect( hSqlHandle ) 
					                                                                                                                                                   If bSqlHandle
						                                                                                                                                                   Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						                                                                                                                                                   Return FALSE
					! INSTEAD OF CHECKING THE MIMINUM OF 20 - WE NOW NEED TO DO SOME
							SPECIAL PROCESSING IF THE TOTAL AVAILABLE IS LESS THAN 0.
							INSTEAD OF JUST PRINTING THE MESSAGE OF SUBJECT TO LIFTING EG THE 
							STOCK COUNT MESSAGE(I THINK), WE NEED TO FETCH ALL CUSTOMERS WHO
							HAVE ORDERED THIS STOCK ITEM BY ORDER DATE AND THEN WORK DOWN
							FROM THE GROWING COUNT MINUS EACH PERSONS ORDER AMT UNTIL WE 
							HIT THE CUSTOMER THAT WE ARE CURRENTLY DOING AN ACKNOWLEDGEMENT
							FOR - IF HIS ORDER HASNT SENT THE TOTAL AVAIL(DYNAMICALLY BEING CALCULATED
							DOWN BELOW ZERO THEN HE GETS THE OK MESSAGE - IF IT IS NEGATIVE EG WHEN
							HE ORDERED THAT STOCK ITEM WAS ALREADY AT  -100 THEN HE HAS TO
							GET THE MESSAGE THAT ITS SUBJECT TO LIFTING   
					! Change this figure if we need to change the minimum availability before 
							printing the Ack_Count_message.
					                                                                                                                                                   Set nAvailThreshold = 20
					                                                                                                                                                   Set nTotalAvail = 0
					                                                                                                                                                   Set sSql = 'SELECT Tot_Avail FROM Stock_Item_Sale INTO :nTotalAvail
							WHERE Stock_Item_No = :nItemNo AND Year_Of_Sale = :nYear'
					                                                                                                                                                   If SqlPrepare( hSqlHandle, sSql )
						                                                                                                                                                   If SqlExecute( hSqlHandle )
							                                                                                                                                                   Call SqlFetchNext( hSqlHandle, nInd )
						                                                                                                                                                   Else 
							                                                                                                                                                   Call SalMessageBox( 'SqlExecute had a error in function AvailabilityOk.  Please contact programmers.', 'Error', MB_Ok )
							                                                                                                                                                   If bSqlHandle
								                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
							                                                                                                                                                   Return FALSE
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'SqlPrepare had a error in function AvailabilityOk.  Please contact programmers.', 'Error', MB_Ok )
						                                                                                                                                                   If bSqlHandle
							                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
						                                                                                                                                                   Return FALSE
					! THE FOLLOWING CHECK IS WRONG ANYWAY - THE TOTAL AVAILABLE FOR
							A STOCK ITEM ALREADY HAS THE ORDERED AMOUNT TAKEN OFF IT FOR THE
							CUSTOMER - WHAT YOU ARE DOING HERE IS CHECKING AGAIN BY TAKING
							THE AMOUNT OFF AGAIN - YOU ONLY NEED TO CHECK IF THE TOTAL AVAILABLE
							IS GREATER THAN ZERO - IF IT IS - WE HAVE THE STOCK AVAILABLE FOR THE
							CUSTOMER
					                                                                                                                                                   If nTotalAvail - nOrderedAmount < nAvailThreshold
						                                                                                                                                                   If bSqlHandle
							                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   Else 
						                                                                                                                                                   If bSqlHandle
							                                                                                                                                                   Call SqlDisconnect( hSqlHandle )
						                                                                                                                                                   Return TRUE
			! Function: GetMessageLegendNo
				                                                                                                                                                   Description: 
				                                                                                                                                                   Returns 
					                                                                                                                                                   Number: 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   String: sTreeTypeMessage
					                                                                                                                                                   String: sMessageLegend[1:*]
					                                                                                                                                                   Number: nLastArrayEntry
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Number: nCurrentPos
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set nCurrentPos = 1
					                                                                                                                                                   While nCurrentPos < nLastArrayEntry
						                                                                                                                                                   If sMessageLegend[ nCurrentPos ] = sTreeTypeMessage
							                                                                                                                                                   Return nCurrentPos 
						                                                                                                                                                   Set nCurrentPos = nCurrentPos + 1
					                                                                                                                                                   Return 0
			! Function: AddMessageToLegend
				                                                                                                                                                   Description: 
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   String: sTreeTypeMessage
					                                                                                                                                                   Window Handle: hWndTable
					                                                                                                                                                   Receive String: sMessageLegend[1:*]
					                                                                                                                                                   Receive Number: nLastArrayEntry
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
				                                                                                                                                                   Actions 
					! because sMessageLegend start from 1:*
					                                                                                                                                                   Set sMessageLegend[ nLastArrayEntry ] = sTreeTypeMessage
					                                                                                                                                                   Set hWndTable.colAvailability = nLastArrayEntry
					                                                                                                                                                   Set nLastArrayEntry = nLastArrayEntry + 1
			! Function: SendMessages
				                                                                                                                                                   Description: Sends messages one by one to the reportwindows
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   Window Handle: hWndFrmTbl
					                                                                                                                                                   Window Handle: hWndTable
					                                                                                                                                                   String: sMessageLegend[1:*]
					                                                                                                                                                   Number: nLastArrayEntry
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Number: nInc
				                                                                                                                                                   Actions 
					                                                                                                                                                   Call SalTblSetFlagsAnyRows( hWndFrmTbl, ROW_Selected, FALSE, 0, 0 )
					                                                                                                                                                   Call SalTblFetchRow( hWndFrmTbl, 0 )
					                                                                                                                                                   Call SalSendMsgToChildren( hWndFrmTbl, PAM_INITIALIZE, 0, 0 )
					                                                                                                                                                   Call SalTblSetRowFlags( hWndFrmTbl, 0, ROW_Selected, TRUE )
					                                                                                                                                                   Set hWndTable.colTTMessage = '       '
					                                                                                                                                                   Set nInc = 1
					                                                                                                                                                   While nInc < nLastArrayEntry
						                                                                                                                                                   Call SalTblFetchRow( hWndFrmTbl, nInc )
						                                                                                                                                                   If NOT SalTblSetContext( hWndFrmTbl, nInc )
							                                                                                                                                                   Call SalTblInsertRow( hWndFrmTbl, nInc )
						                                                                                                                                                   Call SalSendMsgToChildren( hWndFrmTbl, PAM_INITIALIZE, 0, 0 )
						                                                                                                                                                   Call SalTblSetRowFlags( hWndFrmTbl, nInc, ROW_Selected, TRUE )
						                                                                                                                                                   Set hWndTable.colTTMessage = sMessageLegend[nInc]
						                                                                                                                                                   Set hWndTable.colAvailability = nInc
						                                                                                                                                                   Set nInc = nInc + 1
			!
			! Function: GetTreeType
				                                                                                                                                                   Description: Due to the time difference when doing a query with tree type desc as
						part of the select statement will get the tree type for each individual
						record as we go
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set sgSql = 'SELECT TREE_TYPE_DESC FROM TREE_TYPE
							 INTO :frmOrders.tblOrder.colTypeDesc WHERE TREE_TYPE = :frmOrders.tblOrder.colType'
					                                                                                                                                                   Call SqlImmediate( sgSql )
					                                                                                                                                                   Call SqlClearImmediate(  )
			! Function: SetMessage
				                                                                                                                                                   Description: To set the Message field on frmCustomer if an associated 
						company exists in Customer master 
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Boolean: bLocalSqlA
					                                                                                                                                                   Sql Handle: hLocalSqlA
				                                                                                                                                                   Actions 
					! LOCAL SQL HANDLE CONNECTION, DISCONNECTS are on exit pointS
					                                                                                                                                                   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					                                                                                                                                                   If bLocalSqlA
						                                                                                                                                                   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						                                                                                                                                                   Return FALSE
					!
					                                                                                                                                                   Set sgSql = 'SELECT CUST_NO  FROM CUSTOMER_MASTER
							 INTO :hWndForm.dfAsscustno
							WHERE ASS_CUST_NO = :hWndForm.dfCustno'
					                                                                                                                                                   If SqlOK( hLocalSqlA,sgSql )
						                                                                                                                                                   If SqlFetchNext( hLocalSqlA,ngFetch )
							                                                                                                                                                   Set hWndForm.dfMessage = 'Use F10 to see child Customers'
					                                                                                                                                                   If bLocalSqlA
						                                                                                                                                                   Call SqlDisconnect( hLocalSqlA )
			! Function: ClearCust 
				                                                                                                                                                   Description: Clear the screen and reset field defaults
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
				                                                                                                                                                   Actions 
					                                                                                                                                                   Call SalWaitCursor( TRUE )
					                                                                                                                                                   Call InitTopLevelWindow( hWndForm )
					                                                                                                                                                   Call SalEnableWindow( frmCustomer.dfCustno )
					                                                                                                                                                   Call SalSetFocus( frmCustomer.dfCustno )
					! Set date again
					                                                                                                                                                   Set hWndForm.dfCurrentDate = SalDateCurrent(  )
					                                                                                                                                                   Set bgNew = TRUE
					                                                                                                                                                   Set bgEdit = FALSE
					                                                                                                                                                   Call SalSendMsgToChildren( hWndForm, PAM_NEWREC,0,0 )
					                                                                                                                                                   Call SalWaitCursor( FALSE )
			!
			Function: TableInsert
				Description: To insert all new rows in one hit - saltbldoinserts should
						 do it but doesnt when key is date/time as well
				Returns
				Parameters
				Static Variables
				Local variables
					Long String: sTableDecl
				Actions
					Call PopWndHdl( hWndTbl, TRUE )
					Call PopString( sTableDecl, TRUE )
					Set ngRow = TBL_MinRow
					While SalTblFindNextRow( hWndTbl, ngRow, ROW_New, 0 )
						Call SalTblFetchRow( hWndTbl, ngRow )
						Call SalSendMsgToChildren( hWndTbl, PAM_SETEDIT, 0, 0 )
						Call CallBuildSql( hWndTbl,nINSERT, PAM_SQL, sTableDecl, '' )
						Set bOk = SqlImmediate( sgSql )
						If bOk
							Call SqlClearImmediate(  )
							Call SalTblSetRowFlags( hWndTbl, ngRow, ROW_New, FALSE )
							Call SalTblSetRowFlags( hWndTbl, ngRow, ROW_Edited, FALSE )
						Else
							Call SqlClearImmediate(  )
							Return FALSE
			! Function: NumLoadToRegionLeft
				                                                                                                                                                   Description: To check if a customer order has been added and has not been 
						assigned a load yet, if there is only one more load to their region
						left to display a warning if it has already been pulled 
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Boolean: bLocalSqlA
					                                                                                                                                                   Sql Handle: hLocalSqlA
				                                                                                                                                                   Actions 
					! LOCAL SQL HANDLE CONNECTION, DISCONNECT ARE on exit pointS
					                                                                                                                                                   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					                                                                                                                                                   If bLocalSqlA
						                                                                                                                                                   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						                                                                                                                                                   Return FALSE
					!
					                                                                                                                                                   Set ngArray = 0
					                                                                                                                                                   Call SalQueryArrayBounds( sgLoadId, ngMin, ngMax )
					                                                                                                                                                   While ngArray <= ngMax
						                                                                                                                                                   Set sgLoadId[ngArray] = ' '
						                                                                                                                                                   Set sgPulled[ngArray] = ' '
						                                                                                                                                                   Set ngArray = ngArray + 1
					                                                                                                                                                   Call SalSetArrayBounds( sgLoadId, AC_Dynamic, AC_Dynamic )
					                                                                                                                                                   Set ngArray = 0
					! I think this should have the shipping date as part of the where clause also
					                                                                                                                                                   Set sgSql = 'SELECT LOAD.LOAD_ID,LOAD_PULLED_FLAG FROM 
							CUSTOMER_MASTER,REGION_LOAD,LOAD INTO
							 :sgLoadId[ngArray], :sgPulled[ngArray] WHERE
							 CUSTOMER_MASTER.CUST_NO = :frmOrderDets.dfCustNo AND
							REGION_LOAD.REGION_ID = CUSTOMER_MASTER.REGION_ID AND 
							LOAD.LOAD_ID = REGION_LOAD.LOAD_ID'
					                                                                                                                                                   If NOT SqlOK( hLocalSqlA, sgSql )
						                                                                                                                                                   If bLocalSqlA
							                                                                                                                                                   Call SqlDisconnect( hLocalSqlA )
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   While SqlFetchNext( hLocalSqlA, ngFetch )
						                                                                                                                                                   Set ngArray = ngArray + 1
					                                                                                                                                                   Set ngArray = 0
					                                                                                                                                                   Call SalQueryArrayBounds( sgLoadId, ngMin, ngMax )
					                                                                                                                                                   If ngMax = ngMin
						                                                                                                                                                   If sgPulled[ngMin] = 'Y'
							                                                                                                                                                   Call SalMessageBox( 'The last load for this region has been
									pulled.   Please notify despatch to see if it can be included on this load still',
									 'Loads for this Order', MB_Ok )
					                                                                                                                                                   If bLocalSqlA
						                                                                                                                                                   Call SqlDisconnect( hLocalSqlA )
			! Function: AddDeposit
				                                                                                                                                                   Description: Add the deposit required record to the outstanding deposit table 
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Boolean: bLocalSqlA
					                                                                                                                                                   Sql Handle: hLocalSqlA
				                                                                                                                                                   Actions 
					! LOCAL SQL HANDLE CONNECTION, DISCONNECT are on exit pointS
					                                                                                                                                                   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					                                                                                                                                                   If bLocalSqlA
						                                                                                                                                                   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						                                                                                                                                                   Return FALSE
					!
					                                                                                                                                                   Call SalSendMsgToChildren( dlgDeposit, PAM_SETEDIT, 0, 0 )
					                                                                                                                                                   Call CallBuildSql( dlgDeposit, nINSERT, PAM_SQL, OUTSTAND_DEPOSIT, '' )
					                                                                                                                                                   If MySqlPrepExec( hLocalSqlA, sgSql )
						                                                                                                                                                   Call SqlCommit( hLocalSqlA )
					                                                                                                                                                   Else 
						                                                                                                                                                   Call MySqlPrepExec( hLocalSqlA, 'rollback' )
					! If NOT SqlOK( hLocalSqlA, sgSql )
						! Can only be because it is trying to add one for the same date/time so try again
						                                                                                                                                                   Call SqlImmediate( sgSql )
						                                                                                                                                                   Call SqlClearImmediate(  )
					                                                                                                                                                   If bLocalSqlA
						                                                                                                                                                   Call SqlDisconnect( hLocalSqlA )
					                                                                                                                                                   Call SalEndDialog( dlgDeposit, TRUE )
			! Function: IfCustTypeUsed 
				                                                                                                                                                   Description: Dont allow the deletion of a customer type if customers exist that use that
						type, TRUE returned if it is used, FALSE if it is not
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Number: nCustno
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set ngRow = TBL_MinRow
					                                                                                                                                                   While SalTblFindNextRow( dlgCusttype.tblCusttype, ngRow, ROW_MarkDeleted, 0 )
						                                                                                                                                                   Call SalTblFetchRow( dlgCusttype.tblCusttype, ngRow )
						                                                                                                                                                   Set nCustno = 0
						                                                                                                                                                   Set sgSql = 'SELECT CUSTOMER_MASTER.CUST_NO FROM
								 CUSTOMER_MASTER INTO :nCustno
								 WHERE CUSTOMER_MASTER.CUSTOMER_TYPE = :dlgCusttype.tblCusttype.colCusttype'
						                                                                                                                                                   Call SqlImmediate( sgSql )
						                                                                                                                                                   Call SqlClearImmediate(  )
						                                                                                                                                                   If nCustno != 0
							                                                                                                                                                   Call ErrorMessage( ' Sorry, this customer type is in user by a customer.  You cannot delete it until the customer is amended with another customer type.  ', dlgCusttype.tblCusttype, ngRow )
							! Call SalMessageBox( 'Sorry, this customer type is in use by a customer.  You cannot
									delete it until the customer is amended with another customer type', 'Customer Type',
									 MB_Ok )
							                                                                                                                                                   Return TRUE
							                                                                                                                                                   Break 
					                                                                                                                                                   Return FALSE
			! Function: SetTableValues
				                                                                                                                                                   Description: To send a message to all children in a table to set their values 
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Number: nConfAmt
					                                                                                                                                                   Number: nOrdAmt
				                                                                                                                                                   Actions 
					! Send message to columns to calculate and display summaries or set values
					                                                                                                                                                   Set ngConfTotal = 0
					                                                                                                                                                   Set ngOrdTotal = 0
					                                                                                                                                                   Set nConfAmt = 0
					                                                                                                                                                   Set nOrdAmt = 0
					                                                                                                                                                   Call SalTblQueryScroll( hWndForm, ngPos, ngMinRange, ngMaxRange )
					                                                                                                                                                   Set ngRow = ngMinRange
					                                                                                                                                                   While ngRow <= ngMaxRange 
						                                                                                                                                                   Call SalTblFetchRow( hWndForm, ngRow )
						                                                                                                                                                   Call SalSendMsgToChildren( hWndForm, PAM_SETVALUES, 0, 0 )
						                                                                                                                                                   Loop 
							                                                                                                                                                   If PopNumber( nConfAmt, FALSE )
								                                                                                                                                                   Set ngConfTotal = ngConfTotal + nConfAmt
								                                                                                                                                                   Call PopNumber( nOrdAmt, FALSE )
								                                                                                                                                                   Set ngOrdTotal = ngOrdTotal + nOrdAmt
							                                                                                                                                                   Else 
								                                                                                                                                                   Break 
						                                                                                                                                                   Set ngRow = ngRow + 1
					                                                                                                                                                   Call SalTblFetchRow( hWndForm, TBL_MinSplitRow )
					                                                                                                                                                   Call SalSendMsgToChildren( hWndForm, PAM_SUMTOTALS, 0, 0 )
					                                                                                                                                                   Call SalTblSetRowFlags( hWndForm, TBL_MinSplitRow, ROW_New|
							ROW_Edited, FALSE )
			! Function: UpdatePulledFlag
				                                                                                                                                                   Description: To update the pulled flag for a customer once his pull sheet has been 
						printed
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Boolean: bLocalSqlA
					                                                                                                                                                   Sql Handle: hLocalSqlA
				                                                                                                                                                   Actions 
					! LOCAL SQL HANDLE CONNECTION, DISCONNECT are on exit pointS
					                                                                                                                                                   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					                                                                                                                                                   If bLocalSqlA
						                                                                                                                                                   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						                                                                                                                                                   Return FALSE
					!
					                                                                                                                                                   Set sgSql = 'UPDATE CUSTOMER_ORDER SET PULL_SHEET_ISSUED = \'Y\',
							PULL_SHEET_DATE = SYSDATETIME, PULL_SHEET_BY = USER WHERE
							CUSTOMER_ORDER.ROWID = :frmOrders.tblOrder.colRowId'
					                                                                                                                                                   If NOT SqlOK( hLocalSqlA, sgSql )
						                                                                                                                                                   Call SalMessageBox( 'Am unable to update the pulled flag for this order.
								   Please do so manually', 'Pull Order for Customer', MB_Ok )
					                                                                                                                                                   Call SqlCommit( hLocalSqlA )
					                                                                                                                                                   If bLocalSqlA
						                                                                                                                                                   Call SqlDisconnect( hLocalSqlA )
			! Function: UnpullSelected
				                                                                                                                                                   Description: For every row that is selected that has been pulled, unpull the flags
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Boolean: bLocalSqlA
					                                                                                                                                                   Sql Handle: hLocalSqlA
				                                                                                                                                                   Actions 
					!
					                                                                                                                                                   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					                                                                                                                                                   If bLocalSqlA
						                                                                                                                                                   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
						                                                                                                                                                   Call SqlSetParameter( hLocalSqlA, DBP_PRESERVE, TRUE, ''  )
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   Set ngRow = -1
					                                                                                                                                                   Set sgSql = 'UPDATE CUSTOMER_ORDER SET PULL_SHEET_ISSUED = \'N\',
							PULL_SHEET_DATE = :frmOrders.tblOrder.colPullDate, PULL_SHEET_BY = \' \' WHERE
							CUSTOMER_ORDER.ROWID = :frmOrders.tblOrder.colRowId'
					                                                                                                                                                   Call SqlPrepare( hLocalSqlA, sgSql )
					                                                                                                                                                   While SalTblFindNextRow( frmOrders.tblOrder, ngRow, ROW_Selected, 0 )
						                                                                                                                                                   Call SalTblFetchRow( frmOrders.tblOrder, ngRow )
						                                                                                                                                                   If frmOrders.tblOrder.colPullFlag != 'Y'
							                                                                                                                                                   If bLocalSqlA
								                                                                                                                                                   Call SqlDisconnect( hLocalSqlA )
							                                                                                                                                                   Call SalMessageBox( 'One of the selected rows for unpulling has
									not been pulled yet', 'Unpull Selected Order', MB_Ok )
							                                                                                                                                                   Return FALSE
						                                                                                                                                                   Else If frmOrders.tblOrder.colInvFlag = 'Y'
							                                                                                                                                                   If bLocalSqlA
								                                                                                                                                                   Call SqlDisconnect( hLocalSqlA )
							                                                                                                                                                   Call ErrorMessage( 'One of the selected rows for unpulling has been invoiced! This row cannot be unpulled!', frmOrders.tblOrder, ngRow )
							                                                                                                                                                   Return FALSE
						                                                                                                                                                   Set frmOrders.tblOrder.colPullDate = DATETIME_Null
						                                                                                                                                                   If SqlExecute( hLocalSqlA )
							                                                                                                                                                   Call SqlCommit( hLocalSqlA )
						                                                                                                                                                   Else 
							                                                                                                                                                   Call SqlPrepareAndExecute( hLocalSqlA, 'ROLLBACK' )
							                                                                                                                                                   Call SalMessageBox( 'Am unable to update the pulled flag for this order.
									   Please contact programmers', 'Unpull Order for Customer', MB_Ok )
					                                                                                                                                                   If bLocalSqlA
						                                                                                                                                                   Call SqlDisconnect( hLocalSqlA )
			! Function: StoreSelectedRowNumbers
				                                                                                                                                                   Description: Because the user is selecting rows to invoice and part of the processing
						when finished with those is to repopulate the table with POS items, when the 
						user wishes to print we need to repopulate for the stock item orders
						and reset the rows selected
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set ngRowSelected[ngArrayInc] = ngRow + 1
					                                                                                                                                                   Set ngArrayInc = ngArrayInc + 1
			! Function: ResetSelectedRowNumbers
				                                                                                                                                                   Description: To reset which rows were selected in the invoicing process
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Number: nArrayCount
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set nArrayCount = SalQueryArrayBounds( ngRowSelected, ngMinRange, ngMaxRange )
					                                                                                                                                                   Set ngArrayInc = ngMinRange
					                                                                                                                                                   While ngArrayInc <= ngMaxRange
						! To take care of the instance where there are no entries and ngMax and ngMin
								are = 0
						! If nArrayCount != 0
							                                                                                                                                                   Call SalTblSetRowFlags( frmOrders.tblOrder, ngRowSelected[ngArrayInc], ROW_Selected, TRUE )
						                                                                                                                                                   If ngRowSelected[ngArrayInc] != 0
							                                                                                                                                                   Call SalTblSetRowFlags( frmOrders.tblOrder, (ngRowSelected[ngArrayInc] - 1), ROW_Selected, TRUE )
						                                                                                                                                                   Set ngArrayInc = ngArrayInc + 1
			! Function: ClearSelectedArray
				                                                                                                                                                   Description: To clear the given array 
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Number: nClearArrayInc
					                                                                                                                                                   Number: nArrayCount
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set nArrayCount = SalQueryArrayBounds( ngRowSelected, ngMinRange, ngMaxRange )
					                                                                                                                                                   Set nClearArrayInc = ngMinRange
					                                                                                                                                                   While nClearArrayInc <= ngMaxRange
						                                                                                                                                                   Set ngRowSelected[nClearArrayInc] = NUMBER_Null
						                                                                                                                                                   Set nClearArrayInc = nClearArrayInc + 1
					                                                                                                                                                   Set ngArrayInc = 0
					! Call SalSetArrayBounds( ngRowSelected, AC_Dynamic, AC_Dynamic )
			! Function: POSFreightCharge
				                                                                                                                                                   Description: If no stock items have been purchased then need to calculate the
						applicable freight charge for the POS and add it to the customers
						freight charge
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Boolean: bLocalSqlA
					                                                                                                                                                   Sql Handle: hLocalSqlA
				                                                                                                                                                   Actions 
					! LOCAL SQL HANDLE CONNECTION, DISCONNECT ARE on exit pointS
					                                                                                                                                                   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					                                                                                                                                                   If bLocalSqlA
						                                                                                                                                                   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					                                                                                                                                                   Else 
						                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						                                                                                                                                                   Return FALSE
					!
					                                                                                                                                                   Set sgSql = 'SELECT PRICE_BREAK.AMOUNT, PRICE_BREAK.NO_TREES FROM
							FREIGHT_CHARGE,PRICE_BREAK INTO :ngPercAmt, :ngNoTrees WHERE
							FREIGHT_CODE = :frmOrders.tblOrder.colPOSFrCode AND PRICE_BREAK.PRICE_BREAK_ID
							= FREIGHT_CHARGE.PRICE_BREAK_ID ORDER BY FREIGHT_BRK_LEVEL'
					                                                                                                                                                   If NOT SqlOK( hLocalSqlA, sgSql )
						                                                                                                                                                   If bLocalSqlA
							                                                                                                                                                   Call SqlDisconnect( hLocalSqlA )
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   While SqlFetchNext( hLocalSqlA, ngFetch )
						                                                                                                                                                   If ngFetch = FETCH_EOF
							                                                                                                                                                   If bLocalSqlA
								                                                                                                                                                   Call SqlDisconnect( hLocalSqlA )
							                                                                                                                                                   Return FALSE
						                                                                                                                                                   If frmOrders.tblOrder.colConfAmt <= ngNoTrees
							                                                                                                                                                   Set frmOrders.dfDelCharge = frmOrders.dfDelCharge + ngPercAmt
							                                                                                                                                                   If bLocalSqlA
								                                                                                                                                                   Call SqlDisconnect( hLocalSqlA )
							                                                                                                                                                   Return TRUE
					                                                                                                                                                   If bLocalSqlA
						                                                                                                                                                   Call SqlDisconnect( hLocalSqlA )
			Function: OrderGoAhead
				Description: If the customer has stops for any reason of orders being placed then we
						want error messages to appear
				Returns
					Boolean:
				Parameters
				Static Variables
				Local variables
				Actions
					If frmOrders.dfDontSell = 'Y'
						Call SalMessageBox( 'This Customer is flagged as DONT SELL TO!,
								You need authorisation from the office manager before continuing to add the order?
								Please note any comments from customer details before requesting
								the authorisation.', 'Warning', MB_Ok )
						Return FALSE
					If frmOrders.dfCredStop = 'Y'
						If frmOrders.dfCusttype = 'GCP'
							Call SalMessageBox( 'This Customer is to be REFERED to John Danks!,
									Please advise Accounts Payable. Orders to be punched with a hold date', 'Warning', MB_Ok )
							Call SalMessageBox( 'Advise Accounts     NOW!!!!', 'Warning', MB_Ok )
						Else
							Call SalMessageBox( 'This Customer is flagged as CREDIT STOP!,
									You need to refer to Accounts Payable re releasing this customer from Credit Stop status.', 'Warning', MB_Ok )
							Return FALSE
					If frmOrders.dfClAcc = 'Y'
						Call SalMessageBox( 'This Customer is flagged as a CLOSED ACCOUNT!,
								You need to refer to Accounts Payable re this customer.', 'Warning', MB_Ok )
						Return FALSE
					If frmOrders.dfCusttype = 'OPP'
						If IDCANCEL = SalMessageBox( 'This customer is an OPPOSITION customer, do you still want to accept this order?', 'Warning', MB_OkCancel )
							Return FALSE
					Else If frmOrders.dfCusttype = 'BAD'
						Call SalMessageBox( 'This customer is a BAD DEBT customer, please contact accounts', 'Warning', MB_Ok )
						Return FALSE
					Else If frmOrders.dfCusttype = 'BOR'
						Call SalMessageBox( 'This customer is a BAD DEBT customer, please contact Accounts', 'Warning', MB_Ok )
						Return FALSE
					If frmOrders.dfBadDebt = 'Y'
						Call SalMessageBox( 'This customer is a BAD DEBT customer, please contact accounts', 'Warning', MB_Ok )
						Return FALSE
					If frmOrders.dfCredLimit > 0
						If frmOrders.dfAR > frmOrders.dfCredLimit
							Call SalMessageBox( 'This customer has exceeded his credit limit.   Please contact accounts
									to OK any further orders and increasing his Credit Limit' , 'Warning', MB_Ok )
							Return FALSE
					Return TRUE
			!

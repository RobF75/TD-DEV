			String: sHelpFileName
		Message Actions
			On SAM_Create
				Set bEnablePromoFrmSelectPb = FALSE
				Set sHelpFileName = 'g:\\apps\\gupta\\help\\custprom.hlp'
				Set nReturnType = nReturnNormal
				Call PopWndHdl( hWndPushbutton, TRUE )
			On SAM_CreateComplete
				Set dfCurrentDate = SalDateCurrent(  )
				Call PopNumber( dfYr, TRUE )
				Call PopNumber( dfCustno, TRUE )
				Call PopString( dfCustname, TRUE )
				Call SalSendMsg( frmCustPromotions.tblPromo, PAM_POPULATE, 0, 0 )
				!
				Call SalHideWindow( SalParentWindow( hWndForm ) )
			On SAM_Destroy
				Call SalShowWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				Call SalSendMsg( hWndPushbutton, PAM_ENABLE, 0, nReturnType )
			On SAM_Close
				If NOT TableForgetChanges( frmCustPromotions.tblPromo, frmCustPromotions.tblPromo.bEdit )
					Return FALSE
				If IDYES = SalMessageBox( 'Would you like to return to query another Customer ?', 'NOTE', MB_YesNo | MB_DefButton2 )
					Set nReturnType = nReturnToQCust
				Call SalWaitCursor( TRUE )
			On PAM_REPOPULATE
				Call SalSendMsg( tblPromo, PAM_POPULATE, 0, 0 )

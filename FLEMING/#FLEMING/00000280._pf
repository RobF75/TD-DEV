						Message Actions
				Class Variables
				Instance Variables
					Number: nRow
					Number: nCustNos[*]
					Number: nNumCust
					String: sFileName
					String: sCounts
					String: sForceItemisedAck
					String: sReportParameters
					Number: nReturn
					Number: nType
					Number: nYear
					Boolean: bCounts
					Boolean: bForceItemisedAck
					Window Handle: hWndTable
				Functions
					Function: CustomerReports
						Description: Runs the Acknowledgement and Confirmations Reports
								GF: 23/6/98 Added the function to run Production Royalty
								Contracts & now Testing Agreements
						Returns
						Parameters
							Window Handle: hWndCurrent
							String: sType
						Static Variables
						Local variables
							Number: nCustNo
							String: sTreeTypes
						Actions
							Call SalWaitCursor( TRUE )
							If sType = 'NPA'
								Call PopNumber( nYear, TRUE )
								Call PopNumber( nType, TRUE )
								Set bCounts = TRUE
								Set sTreeTypes = ''
							Else If sType = 'PRC'
								Call PopNumber( nYear, TRUE )
								Call PopNumber( nType, TRUE )
								Set bCounts = TRUE
								Set sTreeTypes = ''
							Else If sType = 'TA'
								Call PopNumber( nYear, TRUE )
								Call PopNumber( nType, TRUE )
								Set bCounts = TRUE
								Set sTreeTypes = ''
							Else If sType = 'CONF'
								Call PopNumber( nYear, TRUE )
								Call PopString( sTreeTypes, TRUE )
								Call PopNumber( nType, TRUE )
								Set bCounts = TRUE
							Else
								Call PopNumber( nYear, TRUE )
								Call PopString( sTreeTypes, TRUE )
								Call PopNumber( nType, TRUE )
								Call PopNumber( bCounts, TRUE )
								Call PopNumber( bForceItemisedAck, TRUE )
							!
							Set nNumCust = 0
							!
							If nType = nSelectedCustomers
								Set hWndTable = hWndCurrent
								Set nRow = TBL_MinRow
								Set sFileName = 'C:\\TEMP\\CUSTOMER.TMP'
								While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( hWndTable, nRow )
									Set nNumCust = nNumCust + 1
									Set nCustNos[nNumCust-1] = hWndTable.colCustNo
								Set nCustNos[nNumCust] = NUMBER_Null
								If NOT WriteNumArrayListToFile( sFileName, nCustNos )
									Call SalMessageBox( 'Error occurred in Acknowledgements.
											Contact programmers','System Message',MB_Ok )
									Return FALSE
							Else If nType = nAllCustomers
								Set nNumCust = 0
								Set sFileName = 'BLANK'
							Else If nType = nOrchardists OR nType = nGardenCentres
								Set nNumCust = 0
								Set sFileName = 'BLANK'
							Else
								! Just selecting the current customer in frmOrder
								Set nNumCust = 1
								Set nCustNo = hWndCurrent.dfCustNo
								Set sFileName = 'ONECUST'
							If bCounts
								Set sCounts = ' 1 '
							Else
								Set sCounts = ' 0 '
							If bForceItemisedAck
								Set sForceItemisedAck = ' 1 '
							Else
								Set sForceItemisedAck = ' 0 '
							Set sReportParameters = OurGetIniFileParameter( 'GENERAL', 'CustomerReports', '' )||' '
									||SqlDatabase || ' ' || SqlUser || ' ' || 
									SqlPassword || ' ' || sFileName || ' ' || SalNumberToStrX( nNumCust, 0 ) || ' ' || 
									SalNumberToStrX( nCustNo, 0 ) || ' ' || 
									SalNumberToStrX( nYear, 0 ) || sCounts || SalNumberToStrX( nType, 0  ) || ' ' || sType || ' ' || sTreeTypes || ' ' || sForceItemisedAck
							! If SqlDatabase = 'STOCK'
								                                                                                                                                                   Set sReportParameters = 'G:\\APPS\\GUPTA\\STOCK\\CUSTREP.EXE ' || SqlDatabase || ' ' || SqlUser || ' ' || 
										SqlPassword || ' ' || sFileName || ' ' || SalNumberToStrX( nNumCust, 0 ) || ' ' || 
										SalNumberToStrX( nCustNo, 0 ) || ' ' || 
										SalNumberToStrX( nYear, 0 ) || sCounts || SalNumberToStrX( nType, 0  ) || ' ' || sType || ' ' || sTreeTypes || ' ' || sForceItemisedAck
							! Else
								                                                                                                                                                   Set sReportParameters = 'G:\\APPS\\GUPTA\\STOCKDEV\\CUSTREP.EXE ' || SqlDatabase || ' ' || SqlUser || ' ' || 
										SqlPassword || ' ' || sFileName || ' ' || SalNumberToStrX( nNumCust, 0 ) || ' ' || 
										SalNumberToStrX( nCustNo, 0 ) || ' ' || 
										SalNumberToStrX( nYear, 0 ) || sCounts || SalNumberToStrX( nType, 0  ) || ' ' || sType || ' ' || sTreeTypes || ' ' || sForceItemisedAck
							Call SalLoadAppAndWait(sReportParameters, Window_Maximized, nReturn)
							If sType = 'NPA'
								Call SalSendMsg( hWndCurrent, PAM_REPORTFINISHED, nNPAs, 0 )
							If sType = 'PRC'
								Call SalSendMsg( hWndCurrent, PAM_REPORTFINISHED, nPRCs, 0 )
							If sType = 'TA'
								Call SalSendMsg( hWndCurrent, PAM_REPORTFINISHED, nTAs, 0 )
							Else If sType = 'CONF'
								Call SalSendMsg( hWndCurrent, PAM_REPORTFINISHED, nConfirmations, 0 )
							Else
								Call SalSendMsg( hWndCurrent, PAM_REPORTFINISHED, nAcknowledgments, 0 )
				Message Actions

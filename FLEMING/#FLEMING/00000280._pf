							! On PAM_EXTENDPRICES
								                                                                                                                                                   If NOT bgPOS
									                                                                                                                                                   If bgUpdateFiles
										                                                                                                                                                   If SalIsNull( colLoad )
											                                                                                                                                                   Call SalMessageBox( 'An order included for invoicing is not

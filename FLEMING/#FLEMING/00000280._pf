				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					String: sORDERBY
					String: sLocalBuildWhere
					String: sQueryTmpStr
					String: sCurrentBuildWhere
					String: sSqlQCustomerContactSelect
				Message Actions
					On PAM_POPULATE
						Call PopString( sLocalBuildWhere, TRUE )
						If sLocalBuildWhere = ''
							Set sLocalBuildWhere = ' '
						Else
							Set sLocalBuildWhere = ' AND ' || sLocalBuildWhere
						Call SalSendMsg( hWndForm, PAM_REPOPULATE, 0 ,0  )
					On PAM_REPOPULATE
						Set sSqlQCustomerContactSelect = '
								SELECT 
								  CUSTOMER_MASTER.CUST_NO, CUSTOMER_MASTER.CUST_NAME, CUSTOMER_MASTER.BUS_NAME, 
								  CUSTOMER_CONTACTS.WRK_PHONE_CODE, CUSTOMER_CONTACTS.CONTACT_WORK_PHONE, 
								  CUSTOMER_CONTACTS.CONTACT_SURNAME, CUSTOMER_MASTER.CUSTOMER_TYPE 
								FROM  
								  CUSTOMER_MASTER, CUSTOMER_CONTACTS
								INTO 
								  :frmQCustomer.tblQCustCont.colCustNo, :frmQCustomer.tblQCustCont.colCustName, 
								  :frmQCustomer.tblQCustCont.colBusName, :frmQCustomer.tblQCustCont.colACode, 
								  :frmQCustomer.tblQCustCont.colPhNo, :frmQCustomer.tblQCustCont.colSurname, 
								  :frmQCustomer.tblQCustCont.colCustType 
								 WHERE 
								  CUSTOMER_MASTER.CUST_NO = CUSTOMER_CONTACTS.CUST_NO 
								' || sLocalBuildWhere || sORDERBY
						Call SalTblReset( hWndForm )
						Call SalTblPopulate( hWndForm, hLocalSqlPopTbl, sSqlQCustomerContactSelect, TBL_FillNormal )
						Call SalTblFetchRow( hWndForm, 0 )
						Call SalTblSetRowFlags( hWndForm, 0, ROW_Selected, TRUE )
					On PAM_RESET
						Call TableReset( hWndForm, colCustNo )
					On PAM_ENABLE
						If wParam
							Call SalShowWindow( hWndForm )
						Else
							Call SalHideWindow( hWndForm )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set sORDERBY = ' ORDER BY 2,1 '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )

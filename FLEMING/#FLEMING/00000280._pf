				Functions
					Function: GetEstAvailDate2
						Description:
						Returns
							Boolean:
						Parameters
							Number: nLocationId
							Number: nYear
							Receive Date/Time: dtEstAvailDate
							Number: nActionType
						Static Variables
							: fcOurHandle
								Class: hcSqlHandle
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nInd
							!
							Date/Time: dtGotEstAvailDate
						Actions
							Select Case nActionType
								Case nExecute
									Set sSql = " SELECT 
											  Est_Sale_Date
											FROM 
											  Growing_Sale
											WHERE 
											  Location_Id = :1 AND 
											  Year_Of_Sale = :2 AND 
											 Stock_Item_no = :3 "
									Set sName = 'ORDFUTAVAILDT2'
									Set sBind = ':nLocationId, :nYear, :frmOrders.tblOrder.colItemNo'
									Set sInto = ':dtGotEstAvailDate'
									Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( fcOurHandle.hSqlHandle )
									!
									Set dtEstAvailDate = DATETIME_Null
									Set dtGotEstAvailDate = DATETIME_Null
									!
									If fcOurHandle.Execute( )
										If fcOurHandle.FetchNext( nInd )
											Set dtEstAvailDate = dtGotEstAvailDate
										Return TRUE
									Else
										Return FALSE
								Case nDisconnect
									Return fcOurHandle.Disconnect( )
					Function: GetLocationFarmRowSeq
						Description:
						Returns
							Boolean:
						Parameters
							Number: nLocationId
							Receive String: sFarmName
							Receive Number: nRowNo
							Receive Number: nSeqNo
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nInd
							!
							Number: nSqlHandleNo
							!
							String: sGotFarmName
							Number: nGotRowNo
							Number: nGotSeqNo
						Actions
							Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetLocationFarmRowSeq' )
							Select Case nActionType
								Case nExecute
									Set sSql = " SELECT 
											  Farm_Name, 
											  Row#, 
											  Seq# 
											FROM 
											  Location 
											WHERE 
											  Location_Id = :1 "
									Set sName = 'GTCOLOCFRMRSQ'
									Set sBind = ':nLocationId'
									Set sInto = ':sGotFarmName, :nGotRowNo, :nGotSeqNo'
									Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
									!
									Set sFarmName = ''
									Set sGotFarmName = ''
									Set nRowNo = NUMBER_Null
									Set nSeqNo = NUMBER_Null
									Set nGotRowNo = NUMBER_Null
									Set nGotSeqNo = NUMBER_Null
									!
									If haSqlHandles[ nSqlHandleNo ].Execute( )
										If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
											Set sFarmName = sGotFarmName
											Set nRowNo = nGotRowNo
											Set nSeqNo = nGotSeqNo
										Return TRUE
									Else
										Return FALSE
								Case nDisconnect
									Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
				Window Variables
					: hSqlPopTable
						Class: hcSqlHandle
					! hcSqlHandle: hSqlPopPOSTable
.winattr class :
						Class: hcSqlHandle
.end
					: hSqlSearchTable
						Class: hcSqlHandle
					Window Handle: hWndReport
					!
					String: sSql
					String: sQueryBuildWhere
					String: sRepopBuildWhere
					String: sName
					String: sBind
					String: sInto
					!
					String: sCVNotSaleFlag
					String: sRTNotSaleFlag
					!
					Date/Time: dtSelectedRowOrdDTArray[*]
					String: sSqlTemp
					Number: nLastSelectedRowOrdDT
					Boolean: bTurnOffCheckToSelectRow
					!
					! Sql Handle: hLocalSqlPopTbl
					! Boolean: bLocalSqlPopTbl
					Sql Handle: hLocalSqlDoTbl
					Boolean: bLocalSqlDoTbl
					! Sql Handle: hLocalSqlExtra
					! Boolean: bLocalSqlExtra
					!
					! Sql Handle: hSqlHdlRootDesc
					! Boolean: bHdlRootDescConnected
					! Boolean: bHdlRootDescPrepared
					! Number: nNoNPAs
					!
					! Number: nInd
					Boolean: bEdit
					Boolean: bNoRowsFound
					String: sPopTableNames
					String: sSQLPOPTABLENAME
					String: sSQLHISTPOPTABLENAME
					String: sSQLTABLENAME
					String: sSQLWHEREROWID
					String: sORDERBY
					String: sRoyOwner
					Number: nRoy
					Number: nRow
					Number: nYr
					! Number: nPOSFreightCharge
					! String: sCalcTotals
					! String: sCalcHistTotals
					! String: sSqlExtra
					String: sQueryTmpStr
					String: sCurrentBuildWhere
					Boolean: bFetchRowAllowed
					!
					String: sReportFileName
					Boolean: bReportTableSelectedRowsOnly
					Number: nReportTableRow
					String: sRepInto
					String: sRepBind
					Number: nError
					!
					String: sCustName
				Message Actions
					On PAM_POPULATE
						! If bgPOS
							! Call CallBuildSql( hWndForm, nSELECT, PAM_POSSQL,
									 CUSTPOSPOS, WHORDPOSPRINTINV )
							! Call SalTblPopulate( hWndForm, hLocalSqlPopTbl, sgSql, TBL_FillAll )
							                                                                                                                                                   Call SalTblReset( hWndForm )
							                                                                                                                                                   Call hSqlPopPOSTable.Execute( )
							                                                                                                                                                   Call hSqlPopPOSTable.TablePopulate( hWndForm, TBL_FillAll )
							                                                                                                                                                   Call SalTblFetchRow( hWndForm, 0 )
						! Else
						! When SqlError
							                                                                                                                                                   Return FALSE
						! If NOT SqlRetrieve( hLocalSqlPopTbl, 'SYSADM.ORDER', sSqlOrderBind, sSqlOrderInto )
							                                                                                                                                                   Set sSqlTemp = sSqlOrderSelect || sSqlOrderFrom || 
									' WHERE ' || sSqlOrderWhere || sSqlOrderOrderBy
							                                                                                                                                                   If NOT SqlStore( hLocalSqlPopTbl, 'SYSADM.ORDER', sSqlTemp )
								                                                                                                                                                   Call SalMessageBox( 'Failed to store ORDER select statement','System Message',
										MB_Ok )
								                                                                                                                                                   Return FALSE
							                                                                                                                                                   Call SqlRetrieve( hLocalSqlPopTbl, 'SYSADM.ORDER', sSqlOrderBind, sSqlOrderInto )
						! If NOT SqlExecute( hLocalSqlPopTbl )
							                                                                                                                                                   Call SalMessageBox( 'Failed to execute ORDER select statement','System Message',
									MB_Ok )
							                                                                                                                                                   Return FALSE
						! Call SalTblPopulate( hWndForm, hLocalSqlPopTbl, '', TBL_FillNormal )
						! Call SqlCommit( hLocalSqlPopTbl )
						!
						Call SalTblReset( hWndForm )
						Call SalSendMsgToChildren( hWndForm, PAM_SETCOLUMNCOLOR, 0, COLOR_Default )
						Call hSqlPopTable.Execute( )
						Call hSqlPopTable.TablePopulate( hWndForm, TBL_FillAll )
						Call SalTblFetchRow( hWndForm, 0 )
						Call hSqlPopTable.Commit( )
						!
						Call SalTblSetLockedColumns( hWndForm, 6 )
						Call SalSendMsg( hWndForm, PAM_CALCTOTALS, 0, 0 )
						Call SalWaitCursor( FALSE )
						! The following getresultsetcount is used in pulling and invoicing   
						! If bgInv
							                                                                                                                                                   Set nRow = TBL_MinRow
							                                                                                                                                                   While SalTblFindNextRow( hWndForm, nRow, 0, 0 )
								                                                                                                                                                   Call SalTblFetchRow( hWndForm, nRow )
							! Call SqlGetResultSetCount( hLocalSqlPopTbl, ngCount2 )
							! If NOT bgPOS
								                                                                                                                                                   Set ngCount2 = nLastSelectedRowOrdDT + 1
							                                                                                                                                                   If bgPOS
								                                                                                                                                                   Call hSqlPopPOSTable.ResultSetCount( ngCount2 )
							                                                                                                                                                   Else 
								                                                                                                                                                   Call hSqlPopTable.ResultSetCount( ngCount2 )
								                                                                                                                                                   Set ngCount2 = nLastSelectedRowOrdDT + 1
					On PAM_SEARCH
						Call SalWaitCursor( TRUE )
						! Set sSqlOrderBuildWhere = sSqlDefaultOrderBuildWhere
						Set sQueryBuildWhere = ''
						Call SalSendMsgToChildren( hWndForm, PAM_QBE, 0, 0 )
						Call SalSendMsg( hWndForm, PAM_REPOPULATE, 0, 0 )
					On PAM_REPOPULATE
						! If bgPOS
							                                                                                                                                                   Call SalSendMsg( hWndForm, PAM_POPULATE, 0, 0 )
						! Else
						! If colYr < WhichSeasonYear( SalDateCurrent(  ) ) AND NOT colYr = 77 AND NOT colYr = NUMBER_Null
							                                                                                                                                                   If frmOrders.rbBareRootOrders
								                                                                                                                                                   Set sSqlTemp = sSqlOrderSelect || sSqlOrderFromHist || 
										' WHERE ' || sSqlBareRootOrderBuildWhere || sSqlOrderOrderBy || ' INTO ' || sSqlOrderInto
							                                                                                                                                                   Else If frmOrders.rbContOrders
								                                                                                                                                                   Set sSqlTemp = sSqlOrderSelect || sSqlOrderFromHist || 
										' WHERE ' || sSqlContOrderBuildWhere || sSqlOrderOrderBy || ' INTO ' || sSqlOrderInto
							                                                                                                                                                   Else 
								                                                                                                                                                   Set sSqlTemp = sSqlOrderSelect || sSqlOrderFromHist || 
										' WHERE ' || sSqlOrderBuildWhere || sSqlOrderOrderBy || ' INTO ' || sSqlOrderInto
						! Dani 28/12/95 
						! If dfYr < WhichSeasonYear( SalDateCurrent(  ) ) AND NOT dfYr = 77 AND NOT dfYr = NUMBER_Null
							                                                                                                                                                   If frmOrders.rbBareRootOrders
								                                                                                                                                                   Set sSqlTemp = sSqlOrderSelect || sSqlOrderFromHist || 
										' WHERE ' || sSqlBareRootOrderBuildWhere || sSqlOrderOrderBy || ' INTO ' || sSqlOrderInto
							                                                                                                                                                   Else If frmOrders.rbContOrders
								                                                                                                                                                   Set sSqlTemp = sSqlOrderSelect || sSqlOrderFromHist || 
										' WHERE ' || sSqlContOrderBuildWhere || sSqlOrderOrderBy || ' INTO ' || sSqlOrderInto
							                                                                                                                                                   Else 
								                                                                                                                                                   Set sSqlTemp = sSqlOrderSelect || sSqlOrderFromHist || 
										' WHERE ' || sSqlOrderBuildWhere || sSqlOrderOrderBy || ' INTO ' || sSqlOrderInto
						! Else
							                                                                                                                                                   If frmOrders.rbBareRootOrders
								                                                                                                                                                   Set sSqlTemp = sSqlOrderSelect || sSqlOrderFrom ||
										' WHERE ' || sSqlBareRootOrderBuildWhere || sSqlOrderOrderBy || ' INTO ' || sSqlOrderInto
							                                                                                                                                                   Else If frmOrders.rbContOrders
								                                                                                                                                                   Set sSqlTemp = sSqlOrderSelect || sSqlOrderFrom ||
										' WHERE ' || sSqlContOrderBuildWhere || sSqlOrderOrderBy || ' INTO ' || sSqlOrderInto
							                                                                                                                                                   Else 
								                                                                                                                                                   Set sSqlTemp = sSqlOrderSelect || sSqlOrderFrom ||
										' WHERE ' || sSqlOrderBuildWhere || sSqlOrderOrderBy || ' INTO ' || sSqlOrderInto
						If frmOrders.rbBareRootOrders
							Set sRepopBuildWhere = sSqlBareRootOrderBuildWhere || ' ' || sQueryBuildWhere
						Else If frmOrders.rbContOrders
							Set sRepopBuildWhere = sSqlContOrderBuildWhere || ' ' || sQueryBuildWhere
						Else
							Set sRepopBuildWhere = sSqlOrderBuildWhere || ' ' || sQueryBuildWhere
						!
						If dfYr < WhichSeasonYear( SalDateCurrent(  ) ) AND NOT dfYr = 77 AND NOT dfYr = NUMBER_Null AND NOT bForceCurrentOrderFile
							Set sSqlTemp = sSqlOrderSelect || sSqlOrderFromHist || 
									' WHERE ' || sRepopBuildWhere || sSqlOrderOrderBy || ' INTO ' || sSqlOrderInto
						Else
							Set sSqlTemp = sSqlOrderSelect || sSqlOrderFrom ||
									' WHERE ' || sRepopBuildWhere || sSqlOrderOrderBy || ' INTO ' || sSqlOrderInto
						! If NOT SalTblPopulate( hWndForm, hLocalSqlPopTbl, sSqlTemp, TBL_FillNormal )
							                                                                                                                                                   Call SalMessageBox( 'Table Populate failed','System Error', MB_Ok )
						Call SalTblReset( hWndForm )
						Call SalSendMsgToChildren( hWndForm, PAM_SETCOLUMNCOLOR, 0, COLOR_Default )
						If NOT SalTblPopulate( hWndForm, hSqlSearchTable.hSqlHandle, sSqlTemp, TBL_FillAll )
							Call SalMessageBox( 'Table Populate failed','System Error', MB_Ok )
						! Call SqlCommit( hLocalSqlPopTbl )
						Call hSqlSearchTable.Commit( )
						If TableEmpty( hWndForm )
							Call SalWaitCursor( FALSE )
							Call SalSendMsg( hWndForm, PAM_NOROWS, 0, 0 )
						Else
							Call SalSetFocus( hWndForm )
							! Call SalTblSetRowFlags( hWndForm, 0, ROW_Selected, TRUE )
							Call SalTblFetchRow( hWndForm, 0 )
						Call SalTblSetLockedColumns( hWndForm, 6 )
						Call SalSendMsg( hWndForm, PAM_CALCTOTALS, 0, 0 )
						Call SalWaitCursor( FALSE )
					On PAM_SHOWALLOBTCHLOC
						If NOT SalIsNull( colBatchLocationId )
							Call GetLocationFarmRowSeq( colBatchLocationId, colBatchFarmName, colBatchRowNo, colBatchSeqNo, nExecute )
						Return TRUE
					On PAM_CALCTOTALS
						If bNoRowsFound
							Set bNoRowsFound = FALSE
						Else
							If colYr < WhichSeasonYear( SalDateCurrent(  ) ) AND NOT colYr = 77 AND NOT colYr = NUMBER_Null AND NOT bForceCurrentOrderFile
								If frmOrders.rbBareRootOrders
									Call MySumOrdConfHistory( frmOrders.dfCustNo, colYr, 'BARE_ROOTED', frmOrders.dfTotalConfAmt, frmOrders.dfTotalOrdAmt, nExecute )
								Else If frmOrders.rbContOrders
									Call MySumOrdConfHistory( frmOrders.dfCustNo, colYr, 'CONTAINERISED', frmOrders.dfTotalConfAmt, frmOrders.dfTotalOrdAmt, nExecute )
								Else
									Call MySumOrdConfHistory( frmOrders.dfCustNo, colYr, 'ALL', frmOrders.dfTotalConfAmt, frmOrders.dfTotalOrdAmt, nExecute )
							Else
								If frmOrders.rbBareRootOrders
									Call MySumOrdConf( frmOrders.dfCustNo, colYr, 'BARE_ROOTED', frmOrders.dfTotalConfAmt, frmOrders.dfTotalOrdAmt, nExecute )
								Else If frmOrders.rbContOrders
									Call MySumOrdConf( frmOrders.dfCustNo, colYr, 'CONTAINERISED', frmOrders.dfTotalConfAmt, frmOrders.dfTotalOrdAmt, nExecute )
								Else
									Call MySumOrdConf( frmOrders.dfCustNo, colYr, 'ALL', frmOrders.dfTotalConfAmt, frmOrders.dfTotalOrdAmt, nExecute )
					On PAM_RESET
						Set frmOrders.dfTotalConfAmt = NUMBER_Null
						Set frmOrders.dfTotalOrdAmt = NUMBER_Null
						Set nLastSelectedRowOrdDT = -1
						Call TableReset( hWndForm, colYr )
					On PAM_TABLEBUGREFRESH
						! The reason for this message is that when we have sent PAM_REMEMBERSELECTEDROWS
								  after when we return, for some unknow reason ( bug probably ) a random number
								  of sam_fetchrow messages are sent to the table before our new call of saltblpopulate
								  is called.  These fetchrows result in command not executed errors for the sqlfetchrow( )
								  function.  This prevents the messages, the fetch_rows are still sent but nothing
								  is done under them
						Set frmOrders.dfTotalConfAmt = NUMBER_Null
						Set frmOrders.dfTotalOrdAmt = NUMBER_Null
						Set bFetchRowAllowed = FALSE
						Call SalTblReset( hWndForm )
						Set bFetchRowAllowed = TRUE
					On PAM_NOROWS
						Call SalMessageBox( 'No rows match the search criteria', 'Customer Orders', MB_Ok )
						Set bNoRowsFound = TRUE
					On PAM_WRITEINSERTSUPDATES
						If colYr < WhichSeasonYear( SalDateCurrent(  ) ) AND NOT colYr = 77 AND NOT colYr = NUMBER_Null AND NOT bForceCurrentOrderFile
							Set sSQLTABLENAME = ' CUST_ORDER_HISTORY '
						Else
							Set sSQLTABLENAME = ' CUSTOMER_ORDER '
						!
						Call TableSaveChanges( hWndForm, hLocalSqlDoTbl, 'Customer Orders', sSQLTABLENAME, sSQLWHEREROWID, bEdit, TRUE )
					On PAM_DONTREFRESHROWID
						Return TRUE
					On SAM_FetchRowDone
						If frmOrders.tblOrder.colRootNPAflag = 'Y' OR frmOrders.tblOrder.colCultNPAflag = 'Y'
							If frmOrders.tblOrder.colNPARcd = 'N'
								If frmOrders.tblOrder.colConfAmt > 0
									If frmOrders.tblOrder.colSaleCat != 'RP'
										Set frmOrders.tblOrder.colNPANeeded = 'Y'
						If nLastSelectedRowOrdDT > -1
							If NOT bTurnOffCheckToSelectRow
								Call CheckToSelectRow( dtSelectedRowOrdDTArray, nLastSelectedRowOrdDT, colOrderDateTime, hWndForm, lParam )
						! TS 7/4/95 Now done in the SELECT statement -  If NOT SalIsNull( colCreditedAmount )
							                                                                                                                                                   Set colAlreadyCredited = 'Y'
						! Dani reput in as select wouldnt retrieve this happily as it wants to bring back a numeric in the @if
						! If NOT SalIsNull( colCreditedAmount )
							                                                                                                                                                   Set colAlreadyCredited = 'Y'
						!
						Set colCustno = frmOrders.dfCustNo
						!
						If colFutureOrder = 'Y'
							Call GetEstAvailDate2( colBatchLocationId, colBatchYearOfSale, colFutureOrderDate, nExecute )
							Set colSeason = GetSeason( colFutureOrderDate )
							Call SalSendMsgToChildren( hWndForm, PAM_SETCOLUMNCOLOR, 0, GetSeasonColor( colSeason ) )
							If NOT SalIsNull( colFutureOrderDate )
								Set colSeason = colSeason || ' ' || SalNumberToStrX( SalDateYear( colFutureOrderDate ), 0 )
					On PAM_REMEMBERSELECTEDROWS
						Call InitialiseSelectedRowsArray( dtSelectedRowOrdDTArray, nLastSelectedRowOrdDT, hWndForm, bTurnOffCheckToSelectRow )
					On WM_LBUTTONDOWN
						If wParam = MK_LBUTTON OR wParam = MK_LBUTTON + MK_SHIFT
							Call ForceBackEndToSelectToReset( hWndForm, nLastSelectedRowOrdDT )
					On WM_RBUTTONDOWN
						If wParam = MK_RBUTTON OR wParam = MK_LBUTTON + MK_SHIFT
							Call ForceBackEndToSelectToReset( hWndForm, nLastSelectedRowOrdDT )
					On SAM_Create
						Set sSql = sSqlOrderSelect || sSqlOrderFrom || ' WHERE ' || sSqlOrderWhere || sSqlOrderOrderBy
						Set sName = 'ORDER'
						Set sBind = sSqlOrderBind
						Set sInto = sSqlOrderInto
						Call hSqlPopTable.Setup( sSql, sName, sBind, sInto )
						!
						! If TRUE
							! Set sSql = " SELECT 
									 PROMO.PROMO_DESC, 
									 CUST_PROMO.NO_UNITS, 
									 CUST_PROMO.PROMO_INV_FLAG, 
									 CUST_PROMO.PROMO_INVOICE_NO, 
									 CUST_PROMO.PROMO_INV_DATE, 
									 CUST_PROMO.PROMO_INVOICED_BY, 
									 CUST_PROMO.PROMO_SENT_FLAG, 
									 CUST_PROMO.OVERRIDE_PRICE, 
									 PROMO.PROMO_BASE_PRICE, 
									 PROMO.FREIGHT_CODE, 
									 CUST_PROMO.ROWID, 
									 CUST_PROMO.OVERRIDE_PERCENT, 
									 PROMO.FREE_OVER_COUNT, 
									 CUST_PROMO.PROMO_DT_STAMP 
									FROM  
									 CUST_PROMO, 
									 PROMO 
									WHERE 
									 CUST_PROMO.CUST_NO = :1 AND 
									 CUST_PROMO.PROMO_SENT_FLAG != 'Y' AND 
									 CUST_PROMO.PROMO_PULL_FLAG = 'Y' AND 
									 CUST_PROMO.YEAR_OF_ORDER = :2 AND
									 PROMO.PROMO_ID = CUST_PROMO.PROMO_ID"
						! Set sName = 'ORDERPOS'
						! Set sBind = ':frmOrders.dfCustNo, :frmOrders.dfYr'
						! Set sInto = ':frmOrders.tblOrder.colCultdesc, 
								 :frmOrders.tblOrder.colConfAmt, 
								 :frmOrders.tblOrder.colInvFlag, 
								 :frmOrders.tblOrder.colInvNo, 
								 :frmOrders.tblOrder.colInvDate, 
								 :frmOrders.tblOrder.colInvBy, 
								 :frmOrders.tblOrder.colPromoSent, 
								 :frmOrders.tblOrder.colContractPrice, 
								 :frmOrders.tblOrder.colStockItemPrice, 
								 :frmOrders.tblOrder.colPOSFrCode, 
								 :frmOrders.tblOrder.colRowId, 
								 :frmOrders.tblOrder.colPOSPerc, 
								 :frmOrders.tblOrder.colPOSFreeOver, 
								 :frmOrders.tblOrder.colPromoDateTime'
						! Call hSqlPopPOSTable.Setup( sSql, sName, sBind, sInto )
						!
						Call hSqlSearchTable.Connect( )
						!
						!
						! Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						! If bLocalSqlPopTbl
							                                                                                                                                                   Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							                                                                                                                                                   Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						! Else
							                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							                                                                                                                                                   Return FALSE
						Set bLocalSqlDoTbl = SqlConnect( hLocalSqlDoTbl ) 
						If bLocalSqlDoTbl
							Call SqlSetLockTimeout( hLocalSqlDoTbl, SQLTIMEOUT )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						! Set bLocalSqlExtra = SqlConnect( hLocalSqlExtra ) 
						! If bLocalSqlExtra
							                                                                                                                                                   Call SqlSetLockTimeout( hLocalSqlExtra, SQLTIMEOUT )
						! Else
							                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							                                                                                                                                                   Return FALSE
						Set bEdit = FALSE
						Set bNoRowsFound = FALSE
						Set sSQLPOPTABLENAME = 'CUSTOMER_ORDER, STOCK_ITEM'
						Set sSQLHISTPOPTABLENAME = 'CUST_ORDER_HISTORY, STOCK_ITEM'
						Set sSQLTABLENAME = ' CUSTOMER_ORDER '
						! Set sSQLWHEREROWID = ' WHERE ROWID = :frmOrders.tblOrder.colRowId '
						Set sSQLWHEREROWID = ' WHERE CUST_NO = :frmOrders.dfCustNo AND 
								ORDER_DATE_TIME = :frmOrders.tblOrder.colOrderDateTime '
						Set sORDERBY = '  ORDER BY 5,4,7'
						! Set sCalcTotals = 'SELECT sum(Customer_order.conf_amt), 
								sum(Customer_order.ordered_amount) FROM Customer_Order INTO :frmOrders.dfTotalConfAmt, :frmOrders.dfTotalOrdAmt WHERE CUSTOMER_ORDER.CUST_NO = :frmOrders.dfCustNo
								 AND CUSTOMER_ORDER.YEAR_OF_SALE = :frmOrders.tblOrder.nYr'
						! Set sCalcHistTotals = 'SELECT sum(conf_amt), 
								sum(ordered_amount) FROM Cust_Order_History INTO :frmOrders.dfTotalConfAmt, :frmOrders.dfTotalOrdAmt WHERE CUST_NO = :frmOrders.dfCustNo
								 AND YEAR_OF_SALE = :frmOrders.tblOrder.nYr'
						Set nLastSelectedRowOrdDT = -1
						Set bTurnOffCheckToSelectRow = FALSE
						Set bFetchRowAllowed = TRUE
					On SAM_Destroy
						Call hSqlPopTable.Disconnect( )
						! Call hSqlPopPOSTable.Disconnect( )
						Call hSqlSearchTable.Disconnect( )
						Call GetEstAvailDate( 0, 0, colFutureOrderDate, nDisconnect )
						Call GetLocationFarmRowSeq( 0, colBatchFarmName, colBatchRowNo, colBatchSeqNo, nDisconnect )
						!
						!
						!
						! If bLocalSqlPopTbl
							                                                                                                                                                   Call SqlDisconnect( hLocalSqlPopTbl )
						If bLocalSqlDoTbl
							Call SqlDisconnect( hLocalSqlDoTbl )
						! If bLocalSqlExtra
							                                                                                                                                                   Call SqlDisconnect( hLocalSqlExtra )
						! If bHdlRootDescConnected
							                                                                                                                                                   Call SqlDisconnect( hSqlHdlRootDesc )
					! TS 4/4/95 On PAM_CREATECOMPLETE
						                                                                                                                                                   Call SalSendMsg( colWhere, PAM_WHEREPOPULATE, 0, 0 )
						                                                                                                                                                   Set sCurrentBuildWhere = sBuildWhere
					!
					On PAM_PRINTFULLTABLEREPORT
						Call SalWaitCursor( TRUE )
						Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\tblOrdr2.qrp'
						Set nError = 1
						Set sRepInto = 'CUST_NO, CUST_NAME, YEAR_OF_SALE, 
								ORD_DATE, TREE_TYPE_DESC, STOCK_ITEM.CULT_DESC, 
								ROOT_ID, ORD_AMT, CONF_AMT'
						Set sRepBind = ':frmOrders.dfCustNo, :frmOrders.dfCustName, 
								:frmOrders.tblOrder.colYr, :frmOrders.tblOrder.colOrdDate,
								:frmOrders.tblOrder.colTreeTypeDesc, :frmOrders.tblOrder.colCultdesc,
								:frmOrders.tblOrder.colRootId, :frmOrders.tblOrder.colOrdAmt, 
								:frmOrders.tblOrder.colConfAmt'
						Set hWndReport = SalReportPrint( hWndForm, sReportFileName, sRepBind, sRepInto, 1, RPT_PrintAll | RPT_PrintDraft, 0, 0, nError )
						Call SalWaitCursor( FALSE )
					On SAM_ReportStart
						Return TRUE
					On SAM_ReportFetchInit
						Return TableReportFetchInit( hWndForm, nReportTableRow, bReportTableSelectedRowsOnly )
					On SAM_ReportFetchNext
						Return TableReportFetchNext( hWndForm, nReportTableRow, bReportTableSelectedRowsOnly )
					On SAM_ReportFinish
						Return TRUE
			!

				Pushbutton: pbPrintPulls
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Pull
					Window Location and Size
						Left:   6.588"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Letters.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_CLICK
							Set bFirstLoadId = TRUE
							! Set sLoadId = STRING_Null
							Set bRowSelected = FALSE
							Set nCustNos[0] = dfCustNo
							Set nCustNos[1] = NUMBER_Null
							Set nCount = 0
							If MyTableLoop( tblOrder, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Checking Pull sheet criteria!', nHiToLowWithPositioning )
								If bRowSelected
									Call SalSendMsg( tblOrder, PAM_REMEMBERSELECTEDROWS, 0, 0 )
									! Set sLoadId = STRING_Null
									Call SalCreateWindow( frmPrintPullSheets, hWndForm, sLoadId, nCustNos, dtaOrdDT, nYear, nSelectedCustOrdOnLoad )
								Else
									Call SalMessageBox( 'No Orders selected to pull', 'Customer Order', MB_Ok )
						On PAM_ROWACTION
							Set bRowSelected = TRUE
							If bFirstLoadId
								If SalIsNull( tblOrder.colLoad )
									Call SalMessageBox( 'This order has not been assigned to a load! Cannot Pull!', 'Pull Sheets', MB_Ok )
									Return FALSE
								Else
									Set sLoadId = tblOrder.colLoad
									Set bFirstLoadId = FALSE
							Else
								If tblOrder.colLoad != sLoadId
									Call SalMessageBox( 'This order has been assigned to a different load! Cannot Pull!', 'Pull Sheets', MB_Ok )
									Return FALSE
							If NOT tblOrder.colConfAmt > 0
								Call SalMessageBox( 'Sorry, there is an order selected that is either Null or zero confirmed amount! Cannot Pull', 'Pull Sheets', MB_Ok )
								Return FALSE
							Set nYear = tblOrder.colYr
							Set dtaOrdDT[ nCount ] = tblOrder.colOrderDateTime
							Set nCount = nCount + 1
							Set dtaOrdDT[ nCount ] = DATETIME_Null
							Return TRUE
				Pushbutton: pbInvoice
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Invoice
					Window Location and Size
						Left:   7.188"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: F:\PUBLIC\ICONS\INVOICE.ICO
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_CLICK
							Call SalSendMsg( frmOrders.tblOrder, PAM_REMEMBERSELECTEDROWS, 0, 0 )
							Set bDifferentLoadId = FALSE
							Set bOrderNotPulled = FALSE
							Set bOrderInvoiced = FALSE
							Set nCount = 0
							Set dtaOrdDT[ nCount ] = DATETIME_Null
							Set sLastLoadId = ''
							Set nInvYear = NUMBER_Null
							Call MyTableLoop( tblOrder, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Collecting Orders', nLowToHi )
							If bDifferentLoadId
								If IDNO = SalMessageBox( 'One or More orders are on different loads then the rest! Invoice VIEW ( No final run ) allowed ONLY! Continue?', 'Invoice Warning', MB_YesNo|MB_DefButton2 )
									Return FALSE
							If bOrderNotPulled
								If IDNO = SalMessageBox( 'One or More orders are not pulled! Invoice VIEW ( No final run ) allowed ONLY! Continue?', 'Invoice Warning', MB_YesNo|MB_DefButton2 )
									Return FALSE
							If bOrderInvoiced
								Call SalMessageBox( 'One or More orders are already INVOICED! Please rectify!', 'Invoice Warning', MB_Ok )
								Return FALSE
							!
							If SalModalDialog( dlgObtainInvoiceDate, hWndForm )
								Call PopDateTime( dtInvDate, TRUE )
								If nInvYear = NUMBER_Null
									Set nInvYear = cSeasonYear.GetSeasonYear( )
								If bDifferentLoadId OR bOrderNotPulled
									Set sLastLoadId = ''
									Set naPRCCustomers[0] = NUMBER_Null
									If bNormalInvoice and bPRCInvoice
										If SalCreateWindow( TblPrintInvoices, hWndForm, dtInvDate, dfCustNo, dtaOrdDT, nInvYear, sLastLoadId, 'CUSTOMERVIEWONLY' , naPRCCustomers, 'F' )
											! Call SalMessageBox('Continue to Run Zee Sweet Invoices', 'Message', MB_Ok)
											! Call SalCreateWindow( TblPrintZeeInvoices, hWndForm, dtInvDate, dfCustNo, dtaOrdDT, nInvYear, sLastLoadId, 'CUSTOMERVIEWONLY', naPRCCustomers )
										Else
											Call SalMessageBox('Error with first invoice','Error',MB_Ok)
									Else If bNormalInvoice
										If NOT SalCreateWindow( TblPrintInvoices, hWndForm, dtInvDate, dfCustNo, dtaOrdDT, nInvYear, sLastLoadId, 'CUSTOMERVIEWONLY' , naPRCCustomers , 'F')
											Call SalMessageBox('Error with Fleming invoice','Error',MB_Ok)
									Else If bPRCInvoice
										If NOT SalCreateWindow( TblPrintInvoices, hWndForm, dtInvDate, dfCustNo, dtaOrdDT, nInvYear, sLastLoadId, 'CUSTOMERVIEWONLY', naPRCCustomers, 'Z' )
											Call SalMessageBox('Error with ZEE invoice','Error',MB_Ok)
								Else
									Set naPRCCustomers[0] = bPRCInvoice
									If bNormalInvoice and bPRCInvoice
										If SalCreateWindow( TblPrintInvoices, hWndForm, dtInvDate, dfCustNo, dtaOrdDT, nInvYear, sLastLoadId, 'CUSTOMER' , naPRCCustomers, 'F' )
											! Call SalMessageBox('Continue to Run Zee Sweet Invoices', 'Message', MB_Ok)
											! Call SalCreateWindow( TblPrintZeeInvoices, hWndForm, dtInvDate, dfCustNo, dtaOrdDT, nInvYear, sLastLoadId, 'CUSTOMER', naPRCCustomers )
										Else
											Call SalMessageBox('Error with first invoice','Error',MB_Ok)
									Else If bNormalInvoice
										If NOT SalCreateWindow( TblPrintInvoices, hWndForm, dtInvDate, dfCustNo, dtaOrdDT, nInvYear, sLastLoadId, 'CUSTOMER' , naPRCCustomers, 'F' )
											Call SalMessageBox('Error with Fleming invoice','Error',MB_Ok)
									Else If bPRCInvoice
										If NOT SalCreateWindow( TblPrintInvoices, hWndForm, dtInvDate, dfCustNo, dtaOrdDT, nInvYear, sLastLoadId, 'CUSTOMER', naPRCCustomers, 'Z' )
											Call SalMessageBox('Error with ZEE invoice','Error',MB_Ok)
									Set bPRCInvoice = FALSE
									Set bPRCInvoice = FALSE
						On PAM_ROWACTION
							!
							If nInvYear = NUMBER_Null
								Set nInvYear = tblOrder.colYr
							!
							If sLastLoadId = ''
								Set sLastLoadId = tblOrder.colLoad
							Else If sLastLoadId != tblOrder.colLoad
								Set bDifferentLoadId = TRUE
							!
							If tblOrder.colPullFlag != 'Y'
								Set bOrderNotPulled = TRUE
							If tblOrder.colInvFlag = 'Y'
								Set bOrderInvoiced = TRUE
							!
							If tblOrder.colPRC = 'Y'
								Set bPRCInvoice = TRUE
							Else
								Set bNormalInvoice = TRUE
							!
							Set dtaOrdDT[ nCount ] = tblOrder.colOrderDateTime
							Set nCount = nCount + 1
							Set dtaOrdDT[ nCount ] = DATETIME_Null
							Return TRUE
						On PAM_QUERYDISABLE
							If wParam
								Call SalDisableWindow( hWndItem )
							Else
								Call SalEnableWindow( hWndItem )

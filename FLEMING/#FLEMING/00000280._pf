						                                                                                                                                                   Menu Item Name: 
				Menu Item: &Generate Credit Note
					Resource Id: 8266
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when:
						Checked when:
					Menu Actions
						! If VALIDATE_Cancel =  SalSendValidateMsg(  )
							                                                                                                                                                   Return FALSE
						! Call SalWaitCursor( TRUE )
						! Set bError = FALSE
						! Set nInvNoForCreditNote = NUMBER_Null
						! Set frmQCustomer.nRow = TBL_MinRow
						! While SalTblFindNextRow( tblOrder, frmQCustomer.nRow, ROW_UnusedFlag1, 0 )
							                                                                                                                                                   Call SalTblFetchRow( tblOrder, frmQCustomer.nRow )
							                                                                                                                                                   If nInvNoForCreditNote = NUMBER_Null
								                                                                                                                                                   Set nInvNoForCreditNote = tblOrder.colInvNo
							                                                                                                                                                   Else If nInvNoForCreditNote != tblOrder.colInvNo
								                                                                                                                                                   Call SalTblSetRowFlags( tblOrder, frmQCustomer.nRow, ROW_Selected, TRUE )
								                                                                                                                                                   Call SalTblScroll( tblOrder, frmQCustomer.nRow, hWndNULL, TBL_AutoScroll )
								                                                                                                                                                   Call SalWaitCursor( FALSE )
								                                                                                                                                                   Call SalMessageBox( 'The selected row does not have the same invoice No. as the other items!  Please rectify!', 'Warning', MB_Ok )
								                                                                                                                                                   Set bError = TRUE
								                                                                                                                                                   Break 
						! If NOT bError
							                                                                                                                                                   If tblOrder.sPopTableNames = tblOrder.sSQLHISTPOPTABLENAME
								                                                                                                                                                   Set frmOrders.bCurrentOrder = FALSE
							                                                                                                                                                   Else 
								                                                                                                                                                   Set frmOrders.bCurrentOrder = TRUE
							                                                                                                                                                   Call SalCreateWindow( frmGenCreditNote, hWndForm, dfCustNo, dfCustName, tblOrder, frmOrders.bCurrentOrder )
						! Call SalSetFocus( frmOrders.pbClear )
						! Call SalWaitCursor( FALSE )
						If VALIDATE_Cancel =  SalSendValidateMsg(  )
							Return FALSE
						Call SalWaitCursor( TRUE )
						Call SalSendMsg( pbPrintCrNote, SAM_Click, 0, 0 )
						Call SalWaitCursor( FALSE )

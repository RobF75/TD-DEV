				                                                                                                                                                   Message Actions 
					                                                                                                                                                   On PAM_EXTENDPRICES
						                                                                                                                                                   If wParam = nUseStoredTotals
							                                                                                                                                                   Set dfDelCharge = NUMBER_Null
							                                                                                                                                                   Set dfDelCharge = tblInvoiceTotals.colDelCharge
							                                                                                                                                                   Set dfTotInvoice = 0
							                                                                                                                                                   Set dfTotInvoice = ngTotAmt + dfDelCharge
						                                                                                                                                                   Else 
							! If NOT bgNilSI
								                                                                                                                                                   Set dfDelCharge = ngSITotal * (dfDelPerc/100)
							! Else 
								                                                                                                                                                   Set dfDelCharge = NUMBER_Null
							                                                                                                                                                   If bgNilSI
								                                                                                                                                                   Set dfDelCharge = NUMBER_Null
							                                                                                                                                                   Set dfTotInvoice = 0
							                                                                                                                                                   Set dfTotInvoice = ngTotAmt + dfDelCharge
						                                                                                                                                                   Set dfDelivCharge = dfDelCharge
					                                                                                                                                                   On PAM_SETTRANSEDIT
						                                                                                                                                                   Call SalSetFieldEdit( hWndItem, TRUE )
					                                                                                                                                                   On PAM_TRANSSQL
						                                                                                                                                                   Call BuildSQL(  wParam,hWndItem,'TRANSACTION.FREIGHT_CHARGES' )
					                                                                                                                                                   On PAM_REFRESH
						                                                                                                                                                   Set dfDelCharge = NUMBER_Null
						                                                                                                                                                   Set dfDelivCharge = NUMBER_Null
			! dfDelCharge is the field that is being accumulated but dfDelivCharge is the field that gets the 
					  value only on the last page with the totals. NOTE dfDelivCharge is a local variable
			! Data Field: dfPackPerc

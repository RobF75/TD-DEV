								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL(  wParam,hWndItem,'CUST_PROMO.CUST_NO' )
							On PAM_INSERT
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'CUST_PROMO.CUST_NO' )
							On PAM_RENEWROWID
								Call PushString( ':frmCustPromotions.tblPromo.colCustNo' )
								Call PushString( EQOPERAND )
								Call PushString( STRINGHDLFOLLOWING )
								Call PushString( 'CUST_PROMO.CUST_NO' )
								Return TRUE
							On PAM_DATAVAL
								Return TRUE
							On PAM_CHECKROWNEW
								Set colCustNo = frmCustPromotions.dfCustno
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE
					Column: colPromoId
						Class Child Ref Key: 0

								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							! On PAM_SETVALUES
								                                                                                                                                                   Call PushNumber( colConfAmt )
							! On PAM_SUMTOTALS
								                                                                                                                                                   Set colConfAmt = ngConfTotal
								                                                                                                                                                   Return VALIDATE_Ok
							On PAM_CANORDERBY
								Call PushNumber( 9 )
								Call SalTblGetColumnTitle( hWndItem, sQueryTmpStr, 30 )
								Call PushString( sQueryTmpStr )
								Return TRUE
							! On PAM_EXTENDPRICES
								                                                                                                                                                   If NOT bgPOS
									                                                                                                                                                   If SalIsNull( colConfAmt )
										                                                                                                                                                   Call SalMessageBox( 'An order included for invoicing does not
												have a confirmed amount ', 'Invoicing', MB_Ok )
										! If an order does not have a confirmed amount then it shouldnt be
												included in the loads invoice 
										! Set nMySendMsgError = TRUE
										! Return nMySendMsgError
								! The commented ngOrdTotal summation is correct being under if NOT bgPOS
										but the AS400 calculates it out for POS stuff as well - for this year we will also
										do it wrongly
								! We dont want to work out label charges on trees which are HP or FC or RP
										so we need to only accumulate the label used ngOrdTotal if the saletype is
										NM - note though that we still need to accumulate it for POS for this year only  
								                                                                                                                                                   If bgPOS
									                                                                                                                                                   Set ngOrdTotal = ngOrdTotal + colConfAmt
								                                                                                                                                                   Else 
									! If (colSaleType = 'NM' OR colSaleType = 'CS')
										                                                                                                                                                   Set ngOrdTotal = ngOrdTotal + colConfAmt
									                                                                                                                                                   If (colSaleCat = 'NM' OR colSaleCat = 'CS')
										                                                                                                                                                   Set ngOrdTotal = ngOrdTotal + colConfAmt
								                                                                                                                                                   Set nMySendMsgError = FALSE
								                                                                                                                                                   Return nMySendMsgError
							! On PAM_POSSQL
								                                                                                                                                                   Call BuildSQL(  wParam,hWndItem,'CUST_PROMO.NO_UNITS' )
							On PAM_DATAVAL
								Return TRUE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE
							On PAM_SETCOLUMNCOLOR
								! wParam = back ground color
								! lParam = text color
								If wParam != 0
									Call SalColorSet( hWndItem, COLOR_IndexWindow, wParam )
								If lParam != 0
									Call SalColorSet( hWndItem, COLOR_IndexCellText, lParam )
								Return TRUE
					Column: colSaleCat
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Sale Cat
						Visible? Yes
						Editable? Yes
						Maximum Data Length: 2
						Data Type: String
						Justify: Center
						Width:  0.775"
						Width Editable? Yes
						Format: Uppercase
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_UPDATE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'SALE_CAT' )
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On PAM_EDITCHECK
								! Editable is only allowed when not on row_new, ie any time other than for queries
								If SalTblQueryRowFlags( hWndForm, lParam, ROW_New ) OR frmOrders.tblOrder.colInvFlag = 'Y'
									Call SalTblKillEdit( hWndForm )
							On PAM_DATAVAL
								If colSaleCat = 'NM'
									Return TRUE
								Else If colSaleCat = 'RP'
									Return TRUE
								Else If colSaleCat = 'FC'
									Return TRUE
								Else If colSaleCat = 'CS'
									Return TRUE
								Else If colSaleCat = 'HP'
									Return TRUE
								Else
									Call SalMessageBox( 'The valid Sale Type are RP, FC, NM, CS and HP only!', 'Warning', MB_Ok )
									Return FALSE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								If GetItemNotSaleFlags( colItemNo, sCVNotSaleFlag, sRTNotSaleFlag, nExecute )
									If sCVNotSaleFlag = 'Y' OR sRTNotSaleFlag = 'Y'
										If NOT tblOrder.colSaleCat = 'FC'
											Call SalMessageBox( 'This order cannot be modified!  It is a Not for Sale item and the order must be less than 5 trees and free of charge.', 'Warning', MB_Ok )
											Return FALSE
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE
							On PAM_SETCOLUMNCOLOR
								! wParam = back ground color
								! lParam = text color
								If wParam != 0
									Call SalColorSet( hWndItem, COLOR_IndexWindow, wParam )
								If lParam != 0
									Call SalColorSet( hWndItem, COLOR_IndexCellText, lParam )
								Return TRUE
					! aColumn: colTTMessage
						                                                                                                                                                   List Values 
						                                                                                                                                                   Message Actions 
							                                                                                                                                                   On SAM_Create
								                                                                                                                                                   Set colTTMessage = ''
							                                                                                                                                                   On PAM_DATAVAL

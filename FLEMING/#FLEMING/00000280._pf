			Boolean: bNormalInvoice
		Message Actions
			On SAM_Create
				Call SalSendClassMessage( SAM_Create, wParam, lParam )
				! Set bSqlCheckHdl = SqlConnect( hSqlCheckHdl ) 
				! If bSqlCheckHdl
					                                                                                                                                                   Call SqlSetLockTimeout( hSqlCheckHdl, SQLTIMEOUT )
				! Else
					                                                                                                                                                   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
					                                                                                                                                                   Return FALSE
				! Set bHdlNPAConnected = FALSE
				! Set bHdlNPAPrepared = FALSE
				Set sHelpFileName = 'g:\\apps\\gupta\\help\\orders.hlp'
				Set nAddShowOrdFirst = nShowOrdersFirst
				Set nReturnType = nReturnNormal
				Call PopWndHdl( hWndParentTable, TRUE )
				Call PopWndHdl( hWndPushbutton, TRUE )
				Call SalSendMsg( hWndForm, PAM_SETSQL, 0, 0 )
			On PAM_REPOPULATE
				Call SalSendMsg( frmOrders.tblOrder, PAM_REPOPULATE, 0, 0 )
			On PAM_ORDERMSGNOTIFY
				If lParam = ORDERMSG_StockLevelsL20
					Return ORDERMSG_StockLevelsL20Cont
				Else
					Return FALSE
			On PAM_INVOICECOMPLETE
				Call SalMessageBox('Continue to Run Zee Sweet Invoices', 'Message', MB_Ok)
				Call SalCreateWindow( TblPrintInvoices, hWndForm, dtInvDate, dfCustNo, dtaOrdDT, nInvYear, sLastLoadId, 'CUSTOMER', naPRCCustomers, 'Z' )
			On SAM_CreateComplete
				Call PopString( sDisplayOrderType, TRUE )
				Call PopString( dfCustType,TRUE )
				Call PopString( dfBusName,TRUE )
				Call PopString( dfCustName,TRUE )
				Set tblOrder.sCustName = dfCustName
				Call PopNumber( dfCustNo, TRUE )
				Call PopNumber( nAddShowOrdFirst, TRUE )
				Set dfYr = cSeasonYear.GetSeasonYear( )
				Set nQtr = SalDateQuarter( dfCurrentDate )
				Set frmOrders.tblOrder.nYr = dfYr
				Set bPRCInvoice = FALSE
				Set bNormalInvoice = FALSE
				! All of the customer checking is now in its own routine
				Call SalWaitCursor( TRUE )
				Call GetCustomerChecks( frmOrders.dfCustNo, nExecute )
				!
				! If SalModalDialog( dlgGetDisplayOrdersType, hWndForm )
					                                                                                                                                                   Call PopString( sDisplayOrderType, TRUE )
				! Else
					                                                                                                                                                   Set sDisplayOrderType = 'ALL'
				If sDisplayOrderType = 'CONTAINERISED'
					Set rbContOrders = TRUE
				Else If sDisplayOrderType = 'BARE_ROOTED' 
					Set rbBareRootOrders = TRUE
				Else
					Set rbAllOrders = TRUE
					Set sDisplayOrderType = 'ALL'
				!
				If nAddShowOrdFirst = nAddOrdersFirst
					Call SalPostMsg( pbAdd, SAM_Click, 0, 0 )
					Call SalSendMsg( frmOrders.tblOrder, PAM_CREATECOMPLETE, 0, 0 )
				Else If nAddShowOrdFirst = nPOSOrdersFirst
					Call SalPostMsg( pbPromotions, SAM_Click, 0, 0 )
					Call SalSendMsg( frmOrders.tblOrder, PAM_CREATECOMPLETE, 0, 0 )
				Else
					Call SalSendMsg( frmOrders.tblOrder, PAM_REPOPULATE, 0, 0 )
					! Call SalSendMsg( frmOrders.tblOrder, PAM_POPULATE, 0, 0 )
				Call SalDisableWindow( SalParentWindow( hWndForm ))
			On SAM_Destroy
				Call SalEnableWindow( SalParentWindow( hWndForm ))
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				!
				! Call GetShipAddress( 0, 0, dtTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, 
						sTmp, sTmp, sTmp, bPickUpAddress, nDisconnect )
				! Call GetBusAddress( 0, dtTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, 
						sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, nExecute )
				! Call MyLabelCharges( '', 0, frmOrders.dfPackPerc, nDisconnect )
				! Call MyCheckForPOS( 0, 0, bgPOSExists, nDisconnect )
				! Call POSFreightCharge( '', 0, tblOrder.nPOSFreightCharge, nDisconnect )
				! Call NewMyProcessDeposit( hWndNULL, 0, 0, frmOrders.dfDeposit, nDisconnect )
				! Call NewCultivarRoyalty( 0, '', tblOrder.colCultRoy, nDisconnect )
				! Call NewRootstockRoyalty( 0, '', tblOrder.colRootRoy, nDisconnect )
				! Call NewGetTreeTypeDescription( '', tblOrder.colTypeDesc, nDisconnect )
				! Call MyFreightCharges( hWndNULL, 0, hWndNULL, 0, nDisconnect )
				! Call MyUpdateOrderForInvoice( hWndNULL, 0, 0, 0, 0, nDisconnect )
				! Call New2UpdateRoyaltyOwnerTotal( 0, 0, 0, '', 0, nDisconnect )
				! Call NewUpdateInvoiceTotalsToFile( hWndNULL, 0, nDisconnect )
				! Call NewUpdateLoadCustInvFlag( '', 0, '', nDisconnect )
				! Call GetCustExtras( 0, dfCODCust, dfCusttype, dfFNA, dfFMN, dfLabCode, dfRegion, nDisconnect )
				! Call CheckCustNPANotRecd( 0, bExists, nDisconnect )
				! Call MyGetLoadType( 0, '', sLoadType, nDisconnect )
				! Call GetLoadExtras( 0, tblOrder.colFreightCode, tblOrder.colTranspId, nDisconnect )
				! Call MySumOrdConf( 0, 0, ngTotTrees, ngTotTreesOrd, nDisconnect )
				!
				!
				! If bSqlCheckHdl
					                                                                                                                                                   Call SqlDisconnect( hSqlCheckHdl )
				! If bHdlCultRoyConnected
					                                                                                                                                                   Call SqlDisconnect( hSqlHdlCultRoy )
				! If bHdlRootRoyConnected
					                                                                                                                                                   Call SqlDisconnect( hSqlHdlRootRoy )
				! If bHdlFNARoyConnected
					                                                                                                                                                   Call SqlDisconnect( hSqlHdlFNARoy )
				! If bHdlDepAmtConnected
					                                                                                                                                                   Call SqlDisconnect( hSqlHdlDepAmt )
				! If bHdlAmtUnAplidConnected
					                                                                                                                                                   Call SqlDisconnect( hSqlHdlAmtUnAplid )
				! If bHdlNPAConnected
					                                                                                                                                                   Call SqlDisconnect( hSqlNPAHdl )
				! Call GetBusAddressHdlNewLogic( 0, hWndNULL, 0, nDisconnect )
				! Call GetShipAddressHdlNewLogic( 0, 0, hWndNULL, 0, bPickUpAddress, nDisconnect )
				! Call UpdateRoyaltyOwnerTotal( 0, 0, 0, '', '', nDisconnect )
				! Call GetCustARBalance( 0, dfCustARBalance, nDisconnect )
				! Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nDisconnect )
				! Call UpdateLoadCustInvFlag( '', 0, '', nDisconnect )
				!
				Call NewDeleteOrder( 0, DATETIME_Null, '', '', nDisconnect )
				Call UnInvInvNo( 0, 0, nDisconnect )
				Call SalSendMsg( hWndPushbutton, PAM_ENABLE, 0, nReturnType )
			On SAM_Close
				If NOT TableForgetChanges( frmOrders.tblOrder, frmOrders.tblOrder.bEdit )
					Return FALSE
				If CustDepositReqd( dfCustNo, dfYr )
					Call SalSendMsg( pbDeposit, SAM_Click, 0, 0 )
				Call SalWaitCursor( TRUE )
			! On PAM_PRINTINV
				                                                                                                                                                   Set bgInv = TRUE
				                                                                                                                                                   Set bgPOS = FALSE
				                                                                                                                                                   Set bgPull = FALSE
				                                                                                                                                                   Set bgPrintAckments = FALSE
				                                                                                                                                                   Set bPrintNPAs = FALSE
				                                                                                                                                                   Set bgReportFinish = FALSE
				                                                                                                                                                   Set bgUpdateFiles = FALSE
				                                                                                                                                                   Set bFilesUpdated = FALSE
				!
				                                                                                                                                                   Set sLastLoadId = ''
				                                                                                                                                                   Set bError = FALSE
				                                                                                                                                                   Set bNotSameLoad = FALSE
				                                                                                                                                                   Set ngRow = TBL_MinRow
				                                                                                                                                                   While SalTblFindNextRow( frmOrders.tblOrder, ngRow, ROW_Selected, 0 )
					                                                                                                                                                   Call SalTblFetchRow( frmOrders.tblOrder, ngRow )
					                                                                                                                                                   If frmOrders.tblOrder.colStockItemPrice = NUMBER_Null
						                                                                                                                                                   If NOT frmOrders.tblOrder.colSaleCat = 'FC' AND NOT frmOrders.tblOrder.colSaleCat = 'RP'
							                                                                                                                                                   If frmOrders.tblOrder.colContractPrice = NUMBER_Null
								                                                                                                                                                   Set bError = TRUE
								                                                                                                                                                   Call SalMessageBox( frmOrders.tblOrder.colType || ' ' || frmOrders.tblOrder.colCultdesc || ' / ' || 
										frmOrders.tblOrder.colRootDesc || 'does not have a base price! 
										Please correct before proceeding with the invoice!', 'Warning', MB_Ok )
					                                                                                                                                                   If sLastLoadId = ''
						                                                                                                                                                   Set sLastLoadId = frmOrders.tblOrder.colLoad
					                                                                                                                                                   Else 
						                                                                                                                                                   If frmOrders.tblOrder.colLoad != sLastLoadId
							                                                                                                                                                   Set bError = TRUE
							                                                                                                                                                   Set bNotSameLoad = TRUE
				                                                                                                                                                   If bError
					                                                                                                                                                   If bNotSameLoad
						                                                                                                                                                   Call SalMessageBox( 'NOT ALL the selected orders belong to the SAME LOAD! Please correct!', 'Warning', MB_Ok )
					                                                                                                                                                   Return FALSE
				!
				!
				                                                                                                                                                   Call GetCustExtras( dfCustNo, dfCODCust, dfCusttype, dfFNA, dfFMN, dfLabCode, dfRegion, nExecute )
				                                                                                                                                                   Call CheckCustNPANotRecd( dfCustNo, bExists, nExecute )
				                                                                                                                                                   If bExists
					                                                                                                                                                   Set dfNPAOutstanding = 'Y'
				                                                                                                                                                   Else 
					                                                                                                                                                   Set dfNPAOutstanding = 'N'
				!
				!
				                                                                                                                                                   Set sgRepInto = 'bgUpdate,CUST_NO, CUST_NAME, BUS_NAME, COD_FLAG, NPA_FLAG,
						SHIP_ADD_1, SHIP_ADD_2, SHIP_SUBURB, SHIP_STATE, SHIP_POSTCODE, SHIP_AREACODE, 
						SHIP_PHONE,BUS_ADD_1, BUS_ADD_2, BUS_SUBURB, BUS_STATE, 
						BUS_POSTCODE, BUS_AREACODE, BUS_PHONE, 
						GROSS_AMT, DEL_CHARGE, PACKING_CHARGE, LABEL_CHARGE, SUB_TOTAL, 
						DEPOSIT_PAID, TOTAL_INVOICE,TREE_TYPE, CULT_DESC, ROOT_ID, CONF_AMT, TRANSP_DESC, 
						INV_NO, INV_DATE, PURCHASE_ORDER_NO, PRICE_PER_UNIT, EXTENDED_PRICE, 
						EXTENDED_ROYALTY, SALE_TYPE'
				                                                                                                                                                   Set sgRepBind = ':bgUpdateFiles,:frmOrders.dfCustNo, :frmOrders.dfCustName, 
						:frmOrders.dfBusName, :frmOrders.dfCODCust, 
						:frmOrders.dfNPAOutstanding, :frmOrders.dfSHAdd1, :frmOrders.dfSHAdd2, :frmOrders.dfSHSuburb, 
						:frmOrders.dfSHState, :frmOrders.dfSHPostcode, :frmOrders.dfSHACode, :frmOrders.dfSHPhoneNo,
						:frmOrders.dfPOAdd1, :frmOrders.dfPOAdd2,:frmOrders.dfPOSuburb, :frmOrders.dfPOState, 
						:frmOrders.dfPOPostcode, :frmOrders.dfPOACode, :frmOrders.dfPOPhoneNo, :frmOrders.dfGrossAmt, 
						:frmOrders.dfDelivCharge, :frmOrders.dfPackCharge, :frmOrders.dfLabCharge, 
						:frmOrders.dfSubTotal, :frmOrders.dfDeposit, :frmOrders.dfTotInvoice,:frmOrders.tblOrder.colTypeDesc, 
						:frmOrders.tblOrder.colCultdesc,:frmOrders.tblOrder.colRootDesc, :frmOrders.tblOrder.colConfAmt, 
						:frmOrders.tblOrder.colTranspDesc, :frmOrders.tblOrder.colInvNo, :frmOrders.tblOrder.colInvDate, 
						:frmOrders.tblOrder.colPurchOrdNo,:frmOrders.tblOrder.colContractPrice, :frmOrders.tblOrder.colExtPrice, 
						:frmOrders.tblOrder.colExtRoyalty, :frmOrders.tblOrder.colSaleCat'
				                                                                                                                                                   Set sgReportFile = 'g:\\apps\\gupta\\reports\\invjan2.qrp'
				                                                                                                                                                   Set ngError = 1
				                                                                                                                                                   Call SalCreateWindow( frmReportPrint, hWndForm )
				                                                                                                                                                   Call SalCreateWindow( tblInvoiceTotals, hWndForm )
				                                                                                                                                                   Set hWndInv = SalReportView( hWndForm,frmReportPrint,sgReportFile,sgRepBind,sgRepInto,ngError )
			On PAM_ROWACTION
				If tblOrder.colInvFlag = 'Y'
					Call SalMessageBox( 'Can NOT UNpull this order, as they are already invoiced!', 'Warning', MB_Ok )
				Else If tblOrder.colPullFlag = 'N'
					Call SalMessageBox( 'Order is NOT pulled! No need to UNpull.', 'Warning', MB_Ok )
				Else
					Call JanUnPullCustOrder( dfCustNo, tblOrder.colOrderDateTime, nExecute )
				Return TRUE
			! On SAM_ReportStart
				                                                                                                                                                   If bgInv
					                                                                                                                                                   Set bgLookupTransp = FALSE
					                                                                                                                                                   Return TRUE
			! On SAM_ReportFetchInit
				                                                                                                                                                   If bgInv
					                                                                                                                                                   Set ngCountRecs = 0
					                                                                                                                                                   If bgUpdateFiles
						                                                                                                                                                   Call SalMessageBox( 'PLEASE Ensure the invoice paper is in the LISTING printer,
								and the RED line on the printing head matches with the physical top of the page!
								ie: the fold OR ensure that your print queue is set to OFF!' , 'NOTE', MB_Ok | MB_IconQuestion )
					                                                                                                                                                   Set sLoadId = ''
					! If bgUpdateFiles = TRUE
						                                                                                                                                                   Set bgPOS = FALSE
						                                                                                                                                                   Call SalSendMsg( frmOrders.tblOrder, PAM_POPULATE, 0, 0 )
						                                                                                                                                                   Call ResetSelectedRowNumbers (  )
						                                                                                                                                                   Set ngCount2 = ngArrayInc
					                                                                                                                                                   Set bgPOS = FALSE
					                                                                                                                                                   Call SalSendMsg( frmOrders.tblOrder, PAM_POPULATE, 0, 0 )
					                                                                                                                                                   If bgUpdateFiles
						                                                                                                                                                   Set ngRow = TBL_MinRow
						                                                                                                                                                   While SalTblFindNextRow( frmOrders.tblOrder, ngRow, ROW_Selected, 0 )
							                                                                                                                                                   Call SalTblFetchRow( frmOrders.tblOrder, ngRow )
							                                                                                                                                                   If frmOrders.tblOrder.colPullFlag != 'Y'
								                                                                                                                                                   Call SalMessageBox( 'Sorry, there is an order selected that has not been pulled', 'Error', MB_Ok )
								                                                                                                                                                   Call SalWaitCursor( FALSE )
								                                                                                                                                                   Return FALSE
					! Call ResetSelectedRowNumbers (  )
					! Set ngCount2 = ngArrayInc
					                                                                                                                                                   If NOT PrintInvoice(  )
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   Return TRUE
			! On SAM_ReportFetchNext
				                                                                                                                                                   If bgInv
					                                                                                                                                                   If SalTblFindNextRow( frmOrders.tblOrder, ngTRow, ROW_Selected, 0 )
						                                                                                                                                                   Call SalTblFetchRow( frmOrders.tblOrder, ngTRow )
						                                                                                                                                                   Set ngCountRecs = ngCountRecs + 1
						                                                                                                                                                   If NOT bgPOS
							! Call GetTreeType(  )
							                                                                                                                                                   Call NewGetTreeTypeDescription( tblOrder.colType, tblOrder.colTypeDesc, nExecute )
							!
							                                                                                                                                                   Call SalSendMsgToChildren( frmOrders.tblOrder, PAM_ROYALTY, 0, 0 )
							                                                                                                                                                   If frmOrders.tblOrder.colLoad != sLoadId
								                                                                                                                                                   Set sLoadId = frmOrders.tblOrder.colLoad
								! If GetLoadType(frmOrders.dfCustNo, frmOrders.tblOrder.colLoad) = 'F'
									                                                                                                                                                   Set bgPOSExists = FALSE
								! Else
									                                                                                                                                                   If bgPOSExists
										                                                                                                                                                   If GetLoadType(frmOrders.dfCustNo, frmOrders.tblOrder.colLoad) = 'S'
											                                                                                                                                                   If IDNO = SalMessageBox( 'POS. exists for this customer. Do you want to send it? ', 'Invoicing', MB_YesNo | MB_DefButton1 )
												                                                                                                                                                   Set bgPOSExists = FALSE
								!
								!
								! Lower 3 Lines removed to NOT ask user if to send POS but send as soon as possible
								! Call MyGetLoadType( dfCustNo, tblOrder.colLoad, sLoadType, nExecute )
								! If sLoadType = 'F'
									                                                                                                                                                   Set bgPOSExists = FALSE
								! Else
									                                                                                                                                                   If bgPOSExists
										                                                                                                                                                   Call MyGetLoadType( dfCustNo, tblOrder.colLoad, sLoadType, nExecute )
										                                                                                                                                                   If sLoadType = 'S'
											                                                                                                                                                   If IDNO = SalMessageBox( 'POS. exists for this customer. Do you want to send it? ', 'Invoicing', MB_YesNo | MB_DefButton1 )
												                                                                                                                                                   Set bgPOSExists = FALSE
								!
								!
								!
							! Call SalNumberToStr( frmOrders.dfCustNo, 0, sCustno )
							! Set frmOrders.tblOrder.sSqlExtra = 'SELECT LOAD_CUSTOMERS.FREIGHT_CODE,
									LOAD.TRANSPORT_ID FROM LOAD_CUSTOMERS, LOAD INTO
									:frmOrders.tblOrder.colFreightCode, :frmOrders.tblOrder.colTranspId
									 WHERE LOAD_CUSTOMERS.LOAD_ID = \''||frmOrders.tblOrder.colLoad||'\' AND
									 LOAD_CUSTOMERS.CUST_NO = \''||sCustno||'\'  AND 
									LOAD.LOAD_ID = LOAD_CUSTOMERS.LOAD_ID'
							! Call MySqlPrepExecFetch( frmOrders.tblOrder.hLocalSqlExtra, frmOrders.tblOrder.sSqlExtra, nInd )
							                                                                                                                                                   Call GetLoadExtras( dfCustNo, tblOrder.colFreightCode, tblOrder.colTranspId, nExecute )
						!
						! Call FreightCharges( frmOrders.tblOrder, frmOrders.dfCustNo, frmOrders.tblOrder.colFreightCode, frmOrders.tblOrder.colYr )
						                                                                                                                                                   Call MyFreightCharges( tblOrder, dfCustNo, tblOrder.colFreightCode, tblOrder.colYr, nExecute )
						!
						                                                                                                                                                   Call OurSendMsgToChildren(  frmOrders.tblOrder, PAM_EXTENDPRICES, 0, 0 )
						                                                                                                                                                   If nMySendMsgError
							                                                                                                                                                   Set bOk = FALSE
							                                                                                                                                                   Return FALSE
						                                                                                                                                                   If bgUpdateFiles = TRUE
							! Dont need to worry about bgPOS in this section as it never will be
							! If NOT UpdateOrderForInvoice( frmOrders.tblOrder, frmOrders.tblOrder.colItemNo,
									 frmOrders.tblOrder.colSubsItemNo, frmOrders.tblOrder.colYr, frmOrders.tblOrder.colConfAmt, CUSTORDROWIDORD )
								                                                                                                                                                   Set bFilesUpdated = FALSE
								                                                                                                                                                   Return FALSE
							                                                                                                                                                   If NOT MyUpdateOrderForInvoice( tblOrder, tblOrder.colItemNo,
									 tblOrder.colSubsItemNo, tblOrder.colYr, tblOrder.colConfAmt, nExecute )
								                                                                                                                                                   Set bFilesUpdated = FALSE
								                                                                                                                                                   Return FALSE
							                                                                                                                                                   Else If frmOrders.tblOrder.colExtPrice != 0
								                                                                                                                                                   If frmOrders.tblOrder.colRootRoy != 0
									! If UpdateRoyaltyOwnerTotal( frmOrders.dfCustNo, frmOrders.tblOrder.colConfAmt, nCreditRoy, 'ROOTSTOCK_ID', 'frmOrders.tblOrder.colRootId', nExecute )
										                                                                                                                                                   Call UpdateRoyaltyOwnerTotal( 0, 0, 0, '', '', nCommit )
									! Else
										                                                                                                                                                   Call UpdateRoyaltyOwnerTotal( 0, 0, 0, '', '', nRollback )
									                                                                                                                                                   If New2UpdateRoyaltyOwnerTotal( dfCustNo, tblOrder.colConfAmt, nCreditRoy, frmOrders.tblOrder.colRootId, nRootstockId, nExecute )
										                                                                                                                                                   Call New2UpdateRoyaltyOwnerTotal( 0, 0, 0, '', 0, nCommit )
								                                                                                                                                                   If frmOrders.tblOrder.colCultRoy != 0
									! If UpdateRoyaltyOwnerTotal( frmOrders.dfCustNo, frmOrders.tblOrder.colConfAmt, nCreditRoy, 'CULTIVAR_ID', 'frmOrders.tblOrder.colCultId', nExecute )
										                                                                                                                                                   Call UpdateRoyaltyOwnerTotal( 0, 0, 0, '', '', nCommit )
									! Else
										                                                                                                                                                   Call UpdateRoyaltyOwnerTotal( 0, 0, 0, '', '', nRollback )
									                                                                                                                                                   If New2UpdateRoyaltyOwnerTotal( dfCustNo, tblOrder.colConfAmt, nCreditRoy, tblOrder.colCultId, nCultivarId, nExecute )
										                                                                                                                                                   Call New2UpdateRoyaltyOwnerTotal( 0, 0, 0, '', 0, nCommit )
						! Set ngRow = ngTRow
						! If NOT SalTblFindNextRow( frmOrders.tblOrder, ngRow, ROW_Selected, 0 )
							! Havent set the context so we are still processing the row required
							                                                                                                                                                   If bgPOSExists
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   Else
								                                                                                                                                                   Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, 0, 0 )
								                                                                                                                                                   If bgUpdateFiles = TRUE
									                                                                                                                                                   If NOT UpdateInvoiceTotalsToFile( frmOrders, frmOrders.dfDeposit )
										                                                                                                                                                   Return FALSE
						                                                                                                                                                   If ngCountRecs = ngCount2
							! Havent set the context so we are still processing the row required
							                                                                                                                                                   If bgPOSExists
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   Else 
								                                                                                                                                                   If SalSendMsg( tblInvoiceTotals, PAM_LOOKUPCUST, 0, frmOrders.dfCustNo )
									                                                                                                                                                   Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, nUseStoredTotals, 0 )
								                                                                                                                                                   Else 
									                                                                                                                                                   Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, 0, 0 )
									                                                                                                                                                   Call PushNumber( frmOrders.dfCustNo )
									                                                                                                                                                   Call PushNumber( frmOrders.dfDelCharge )
									                                                                                                                                                   Call PushNumber( frmOrders.dfPackCharge )
									                                                                                                                                                   Call PushNumber( frmOrders.dfLabCharge )
									                                                                                                                                                   Call SalSendMsg( tblInvoiceTotals, PAM_ADDROW, 0, 0 )
								! Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, 0, 0 )
								                                                                                                                                                   If bgUpdateFiles = TRUE
									! If NOT UpdateInvoiceTotalsToFile( frmOrders, frmOrders.dfDeposit )
										                                                                                                                                                   Set bFilesUpdated = FALSE
										                                                                                                                                                   Return FALSE
									! Call UpdateLoadCustInvFlag( frmOrders.tblOrder.colLoad, frmOrders.dfCustNo, 'Y', nExecute )
									                                                                                                                                                   If NOT NewUpdateInvoiceTotalsToFile( frmOrders, dfDeposit, nExecute )
										                                                                                                                                                   Set bFilesUpdated = FALSE
										                                                                                                                                                   Return FALSE
									                                                                                                                                                   Call NewUpdateLoadCustInvFlag( tblOrder.colLoad, dfCustNo, 'Y', nExecute )
						                                                                                                                                                   Return TRUE
					                                                                                                                                                   Else If bgPOS = FALSE
						! If POS stuff doesnt exist then no point doing first POS record should just go
								to nextinvrecord
						                                                                                                                                                   If bgPOSExists
							                                                                                                                                                   Set bgPOS = TRUE
							                                                                                                                                                   If FirstPOSRecord(  )
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   Else 
								                                                                                                                                                   Return FALSE
						                                                                                                                                                   Else 
							                                                                                                                                                   If bgUpdateFiles = TRUE
								                                                                                                                                                   Set bgUpdateFiles = FALSE
							                                                                                                                                                   Return FALSE
					! if bgPOS = true - we need to be  processing in here as the prior saltblfindnextrow
							is for row selected which POS are not
					                                                                                                                                                   Else If bgPOS = TRUE
						                                                                                                                                                   If SalTblFindNextRow( frmOrders.tblOrder, ngTRow, 0, 0 )
							                                                                                                                                                   Call SalTblFetchRow( frmOrders.tblOrder, ngTRow )
							!
							                                                                                                                                                   Call OurSendMsgToChildren(  frmOrders.tblOrder, PAM_EXTENDPRICES, 0, 0 )
							                                                                                                                                                   If nMySendMsgError
								                                                                                                                                                   Set bOk = FALSE
								                                                                                                                                                   Return FALSE
							                                                                                                                                                   If bgUpdateFiles = TRUE
								! If NOT UpdateOrderForInvoice( frmOrders.tblOrder, frmOrders.tblOrder.colItemNo,
										 frmOrders.tblOrder.colSubsItemNo, frmOrders.tblOrder.colYr, frmOrders.tblOrder.colConfAmt, CUSTORDROWIDPOS )
									                                                                                                                                                   Set bFilesUpdated = FALSE
									                                                                                                                                                   Return FALSE
								                                                                                                                                                   If NOT MyUpdateOrderForInvoice( tblOrder, tblOrder.colItemNo,
										 tblOrder.colSubsItemNo, tblOrder.colYr, tblOrder.colConfAmt, nExecute )
									                                                                                                                                                   Set bFilesUpdated = FALSE
									                                                                                                                                                   Return FALSE
							                                                                                                                                                   Set ngRow = ngTRow
							! Need to know if we're processing the last row selected or not
							                                                                                                                                                   If NOT SalTblFindNextRow( frmOrders.tblOrder, ngRow, 0, 0 )
								! Havent set the context so we are still processing the row required
								! If bgPOS
									                                                                                                                                                   Set bgPOS = FALSE
									                                                                                                                                                   Set bgPOSExists = FALSE
								!
								                                                                                                                                                   If SalSendMsg( tblInvoiceTotals, PAM_LOOKUPCUST, 0, frmOrders.dfCustNo )
									                                                                                                                                                   Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, nUseStoredTotals, 0 )
								                                                                                                                                                   Else 
									                                                                                                                                                   Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, 0, 0 )
									                                                                                                                                                   Call PushNumber( frmOrders.dfCustNo )
									                                                                                                                                                   Call PushNumber( frmOrders.dfDelCharge )
									                                                                                                                                                   Call PushNumber( frmOrders.dfPackCharge )
									                                                                                                                                                   Call PushNumber( frmOrders.dfLabCharge )
									                                                                                                                                                   Call SalSendMsg( tblInvoiceTotals, PAM_ADDROW, 0, 0 )
								! Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, 0, 0 )
								                                                                                                                                                   If bgUpdateFiles = TRUE
									! If NOT UpdateInvoiceTotalsToFile( frmOrders, frmOrders.dfDeposit )
										                                                                                                                                                   Set bFilesUpdated = FALSE
										                                                                                                                                                   Return FALSE
									! Call UpdateLoadCustInvFlag( frmOrders.tblOrder.colLoad, frmOrders.dfCustNo, 'Y', nExecute )
									                                                                                                                                                   If NOT NewUpdateInvoiceTotalsToFile( frmOrders, dfDeposit, nExecute )
										                                                                                                                                                   Set bFilesUpdated = FALSE
										                                                                                                                                                   Return FALSE
									                                                                                                                                                   Call NewUpdateLoadCustInvFlag( tblOrder.colLoad, dfCustNo, 'Y', nExecute )
							                                                                                                                                                   Return TRUE
						                                                                                                                                                   Else 
							                                                                                                                                                   If bgUpdateFiles = TRUE
								                                                                                                                                                   Set bgUpdateFiles = FALSE
							                                                                                                                                                   Return FALSE
					                                                                                                                                                   Else 
						                                                                                                                                                   If bgUpdateFiles = TRUE
							                                                                                                                                                   Set bgUpdateFiles = FALSE
						                                                                                                                                                   Return FALSE
			! On SAM_ReportFinish
				                                                                                                                                                   If bgInv
					                                                                                                                                                   Call SalSendMsg( tblInvoiceTotals, PAM_CLOSE, 0, 0 )
					                                                                                                                                                   Set frmOrders.tblOrder.bTurnOffCheckToSelectRow = FALSE
					                                                                                                                                                   Set bgInv = FALSE
					                                                                                                                                                   Set bgPOS = FALSE
					                                                                                                                                                   Call SalPostMsg( hWndForm , PAM_REPORTFINISHED, nInvoice, 0 )
			On PAM_REPORTFINISHED
				If wParam = nPullSheet OR wParam = nInvoice OR wParam = nAcknowledgments OR 
						   wParam = nConfirmations OR wParam = nNPAs
					Call SalPostMsg( tblOrder, PAM_REPOPULATE, 0, 0 )
			On PAM_SETSQL
				If TRUE
					Set sSqlOrderSelect = 'SELECT 
							    YEAR_OF_SALE, 
							    ORD_DATE, 
							    STOCK_ITEM.TREE_TYPE_DESC, 
							    STOCK_ITEM.CULTIVAR_ID, 
							    STOCK_ITEM.CULT_DESC, 
							    STOCK_ITEM.ROOTSTOCK_ID, 
							    STOCK_ITEM.ROOT_DESC, 
							    ORDERED_AMOUNT, 
							    CONF_AMT, 
							    SALE_CAT, 
							    LOAD_ID, 
							    PULL_SHEET_ISSUED, 
							    PULL_SHEET_DATE, 
							    INVOICED_FLAG, 
							    INVOICE_NO, 
							    INVOICED_DATE, 
							    ACK_FLAG, 
							    ALLOC_FLAG, 
							    CONF_FLAG, 
							    NPA_SENT_FLAG, 
							    NPA_RECD_FLAG, 
							    SUBS_OK_FLAG, 
							    CONT_PRICE_FLAG, 
							    CONTRACT_PRICE, 
							    CUSTOM_BUD_FLAG, 
							    SPEC_REQUIREMENT, 
							    TRIALPACK_SENTFLAG, 
							    TRIALPACK_RECDFLAG, 
							    ORDER_DATE_TIME, 
							    STOCK_ITEM_NO, 
							    HOLD_ORDER_DATE, 
							    PURCHASE_ORDER_NO,
							    ORDER_BOOK_NO, 
							    CREDIT_NOTE_NO, 
							    NO_TREES_CREDITED, 
							    CREDITED_AMOUNT, 
							    RETURN_TO_INV, 
							    CR_BASE_PRICE_ONLY, 
							    @IF(CREDITED_AMOUNT,\'Y\',\'\'), 
							    @UPPER(STOCK_ITEM.VARIETY), 
							    @UPPER(STOCK_ITEM.CULT_DESC), 
							    @UPPER(STOCK_ITEM.ROOT_DESC),
							    STOCK_ITEM.VARIETY_TYPE, 
							    STOCK_ITEM.CV_NON_PROP_FLAG, 
							    STOCK_ITEM.RT_NON_PROP_FLAG, 
							    ORDER_COMMENTS, 
							    SUBS_ITEM_NO, 
							    @IF(@ISNA( BATCH_LOCATION_ID ), \'N\', \'Y\' ), 
							    BATCH_LOCATION_ID, 
							    BATCH_YEAR_OF_SALE,
							    stock_item.prod_royalty,
							prc_recd_flag,
							prc_sent_flag '
				Set sSqlOrderWhere = 'CUSTOMER_ORDER.CUST_NO = :1
						  AND CUSTOMER_ORDER.YEAR_OF_SALE = :2
						  AND CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO '  
				!
				Set sSqlOrderBuildWhere =  'CUST_NO = :frmOrders.dfCustNo
						  AND YEAR_OF_SALE =:frmOrders.dfYr
						  AND STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO '  
				Set sSqlBareRootOrderBuildWhere =  "CUST_NO = :frmOrders.dfCustNo
						  AND YEAR_OF_SALE =:frmOrders.dfYr
						  AND STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND 
						  NOT Stock_Item.Tree_Type LIKE 'C%' "  
				Set sSqlContOrderBuildWhere =  "CUST_NO = :frmOrders.dfCustNo
						  AND YEAR_OF_SALE =:frmOrders.dfYr
						  AND STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO  AND 
						  Stock_Item.Tree_Type LIKE 'C%' "  
				!
				Set sSqlDefaultOrderBuildWhere =  sSqlOrderBuildWhere
				Set sSqlOrderFrom = ',CUSTOMER_ORDER.ROWID 
						FROM CUSTOMER_ORDER, STOCK_ITEM'
				Set sSqlOrderFromHist = ',CUST_ORDER_HISTORY.ROWID 
						FROM CUST_ORDER_HISTORY, STOCK_ITEM'
				Set sSqlOrderOrderBy = ' ORDER BY 43,40,41,4,3 '
				Set sSqlOrderBind = ':frmOrders.dfCustNo, :frmOrders.dfYr'
				If TRUE
					Set sSqlOrderInto =  ':frmOrders.tblOrder.colYr, 
							    :frmOrders.tblOrder.colOrdDate, 
							    :frmOrders.tblOrder.colTreeTypeDesc, 
							    :frmOrders.tblOrder.colCultId, 
							    :frmOrders.tblOrder.colCultdesc, 
							    :frmOrders.tblOrder.colRootId, 
							    :frmOrders.tblOrder.colRootDesc, 
							    :frmOrders.tblOrder.colOrdAmt, 
							    :frmOrders.tblOrder.colConfAmt, 
							    :frmOrders.tblOrder.colSaleCat, 
							    :frmOrders.tblOrder.colLoad, 
							    :frmOrders.tblOrder.colPullFlag, 
							    :frmOrders.tblOrder.colPullDate, 
							    :frmOrders.tblOrder.colInvFlag, 
							    :frmOrders.tblOrder.colInvNo, 
							    :frmOrders.tblOrder.colInvDate, 
							    :frmOrders.tblOrder.colAck, 
							    :frmOrders.tblOrder.colAlloc, 
							    :frmOrders.tblOrder.colConf, 
							    :frmOrders.tblOrder.colNPASnt, 
							    :frmOrders.tblOrder.colNPARcd, 
							    :frmOrders.tblOrder.colSubs, 
							    :frmOrders.tblOrder.colContPriceFlag, 
							    :frmOrders.tblOrder.colContractPrice, 
							    :frmOrders.tblOrder.colCustomBudFlag, 
							    :frmOrders.tblOrder.colSpecReq, 
							    :frmOrders.tblOrder.colTrialpackSnt, 
							    :frmOrders.tblOrder.colTrialpackRcd, 
							    :frmOrders.tblOrder.colOrderDateTime, 
							    :frmOrders.tblOrder.colItemNo, 
							    :frmOrders.tblOrder.colHoldOrdDate, 
							    :frmOrders.tblOrder.colPurchOrdNo,
							    :frmOrders.tblOrder.colOrderBookNo,  
							    :frmOrders.tblOrder.colCreditNoteNo, 
							    :frmOrders.tblOrder.colNoTreesCredited, 
							    :frmOrders.tblOrder.colCreditedAmount, 
							    :frmOrders.tblOrder.colReturnToInv, 
							    :frmOrders.tblOrder.colBasePriceOnly, 
							    :frmOrders.tblOrder.colAlreadyCredited, 
							    :frmOrders.tblOrder.colVariety, 
							    :frmOrders.tblOrder.colUpperCultDesc, 
							    :frmOrders.tblOrder.colUpperRootDesc, 
							    :frmOrders.tblOrder.colVarietyType, 
							    :frmOrders.tblOrder.colCultNPAflag, 
							    :frmOrders.tblOrder.colRootNPAflag, 
							    :frmOrders.tblOrder.colOrdComm, 
							    :frmOrders.tblOrder.colSubsItemNo,
							    :frmOrders.tblOrder.colFutureOrder, 
							    :frmOrders.tblOrder.colBatchLocationId, 
							    :frmOrders.tblOrder.colBatchYearOfSale,
							   :frmOrders.tblOrder.colPRC,
							:frmOrders.tblOrder.colPRCSnt,
							:frmOrders.tblOrder.colPRCRcd' 
			On SAM_Activate
				Return SalSendMsgToChildren( hWndForm, PAM_ACTIVATE, wParam, lParam )
			! On PAM_FORWARDGROWLOCATION
				                                                                                                                                                   If tblOrder.colBatchLocationId > 0
					                                                                                                                                                   Call PushNumber( tblOrder.colBatchLocationId )
					                                                                                                                                                   Return TRUE
				                                                                                                                                                   Else 
					                                                                                                                                                   Return FALSE

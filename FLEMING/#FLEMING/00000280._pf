				Pushbutton: pbCancOrd
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Delete
					Window Location and Size
						Left:   1.188"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: F4
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Delrec.bmp
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							Call SalWaitCursor( FALSE )
							Call SalDisableWindow( hWndItem )
							If NOT SalTblAnyRows( tblOrder,ROW_Selected, 0 )
								Call SalWaitCursor( FALSE )
								Call SalMessageBox( 'No rows selected', 'Customer Orders', MB_Ok )
								Call SalEnableWindow( hWndItem )
							Else
								If tblOrder.colYr < cSeasonYear.GetSeasonYear( ) AND NOT tblOrder.colYr = 77 AND NOT tblOrder.colYr = NUMBER_Null
									Call SalWaitCursor( FALSE )
									Call SalMessageBox( 'This Order has been rolled over to order history.  Cannot cancel this order! ', 'Warning', MB_Ok )
									Call SalEnableWindow( hWndItem )
									Return FALSE
								If SalModalDialog( dlgCancelReason, hWndForm )
									Call SalWaitCursor( TRUE )
									Call PopString(sCancelOrderBookNo, TRUE )
									Call PopString( sReason, TRUE )
									Set frmQCustomer.nRow = TBL_MinRow
									While SalTblFindNextRow( tblOrder, frmQCustomer.nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( tblOrder, frmQCustomer.nRow )
										If tblOrder.colInvFlag = 'Y'
											Call SalWaitCursor( FALSE )
											Call ErrorMessage( 'This selected order cannot be deleted, as it is invoiced! ', tblOrder, frmQCustomer.nRow )
											Call SalWaitCursor( TRUE )
										Else If tblOrder.colPullFlag = 'Y'
											Call SalWaitCursor( FALSE )
											Call ErrorMessage( 'This selected order cannot be deleted, as it is Pulled! ', tblOrder, frmQCustomer.nRow )
											Call SalWaitCursor( TRUE )
										Else
											If NewDeleteOrder( dfCustNo, tblOrder.colOrderDateTime, sReason, sCancelOrderBookNo, nExecute )
												Call SalTblDeleteRow( tblOrder, frmQCustomer.nRow, TBL_Adjust )
												Set frmQCustomer.nRow = frmQCustomer.nRow - 1
									Call SalWaitCursor( FALSE )
								Call SalWaitCursor( FALSE )
								Call SalEnableWindow( hWndItem )
						On PAM_QUERYDISABLE
							If wParam
								Call SalDisableWindow( hWndItem )
							Else
								Call SalEnableWindow( hWndItem )
				Pushbutton: pbSave

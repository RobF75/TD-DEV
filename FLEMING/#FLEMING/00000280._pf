				                                                                                                                                                   Message Actions 
					                                                                                                                                                   On PAM_EXTENDPRICES
						                                                                                                                                                   If wParam = nUseStoredTotals
							                                                                                                                                                   Set dfPackCharge = tblInvoiceTotals.colPackCharge
							                                                                                                                                                   Set dfTotInvoice = dfTotInvoice + dfPackCharge
						                                                                                                                                                   Else 
							                                                                                                                                                   Set dfPackCharge = ngSITotal * (dfPackPerc/100)
							                                                                                                                                                   Set dfTotInvoice = dfTotInvoice + dfPackCharge
					                                                                                                                                                   On PAM_REFRESH
						                                                                                                                                                   Set dfPackCharge = NUMBER_Null
					                                                                                                                                                   On PAM_SETTRANSEDIT
						                                                                                                                                                   Call SalSetFieldEdit( hWndItem, TRUE )
					                                                                                                                                                   On PAM_TRANSSQL
						                                                                                                                                                   Call BuildSQL(  wParam,hWndItem,'TRANSACTION.RAIL_CHARGES' )
			! Data Field: dfLabCharge
.winattr
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Data
					Maximum Data Length: Default
					Data Type: Number
					Editable? Yes
				Display Settings
					Window Location and Size
						Left:   Default
						Top:    Default
						Width:  Default
						Width Editable? Yes
						Height: Default
						Height Editable? Yes
					Visible? No
					Border? Yes
					Justify: Left
					Format: Unformatted
					Country: Default
					Font Name: Default
					Font Size: Default
					Font Enhancement: Default
					Text Color: Default
					Background Color: Default
					Input Mask: Unformatted
.end
				                                                                                                                                                   Message Actions 
					                                                                                                                                                   On PAM_EXTENDPRICES
						                                                                                                                                                   If wParam = nUseStoredTotals
							                                                                                                                                                   Set dfLabCharge = tblInvoiceTotals.colLabelCharge
							                                                                                                                                                   Set dfTotInvoice = dfTotInvoice + dfLabCharge
						                                                                                                                                                   Else 
							! ngOrdTotal is the total of confirmed amounts on tblOrder - it is not the ordered
									amount total but the confirmed amount total
							                                                                                                                                                   Set dfLabCharge = ngOrdTotal * (dfLabperTree)
							                                                                                                                                                   Set dfTotInvoice = dfTotInvoice + dfLabCharge
					                                                                                                                                                   On PAM_REFRESH
						                                                                                                                                                   Set dfLabCharge = NUMBER_Null
					                                                                                                                                                   On PAM_SETTRANSEDIT
						                                                                                                                                                   Call SalSetFieldEdit( hWndItem, TRUE )
					                                                                                                                                                   On PAM_TRANSSQL
						                                                                                                                                                   Call BuildSQL(  wParam,hWndItem,'TRANSACTION.LABEL_CHARGES' )
			! Data Field: dfLabperTree

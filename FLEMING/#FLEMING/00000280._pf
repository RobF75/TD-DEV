		Functions
			Function: GetCustomerChecks
				Description: To process various checks on a customer
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					String: sSql
					Number: nInd
					Boolean: bOk
					!
				Actions
					Select Case nActionType
						Case nExecute
							If NOT bHandleConnected
								Set bHandleConnected = SqlConnect( hSqlHandle ) 
								If bHandleConnected
									Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
									Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
								Else
									Call SalWaitCursor( FALSE )
									Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									Return FALSE
							If NOT bHandlePrepared
								Set sSql = ' SELECT NPA_Refusal_Flag, Dont_Sell_Flag, Credit_Stop, 
										Closed_Account, Bad_Debt_Flag, Order_Notes, Cust_AR_Balance, Cust_Credit_Limit,
										Customer_Type, Cont_Price_Flag    
										 FROM Customer_Master 
										INTO :frmOrders.dfNPARef, :frmOrders.dfDontSell, :frmOrders.dfCredStop, 
										:frmOrders.dfClAcc, :frmOrders.dfBadDebt, :frmOrders.dfOrderNotes, :frmOrders.dfAR,
										:frmOrders.dfCredLimit, :frmOrders.dfCusttype, :frmOrders.dfContPrice     
										WHERE 
										 Cust_No = :frmOrders.dfCustNo '
								If SqlPrepare( hSqlHandle, sSql )
									Set bHandlePrepared = TRUE
								Else
									Set bHandlePrepared = FALSE
							!
							If SqlExecute( hSqlHandle )
								If SqlFetchNext( hSqlHandle, nInd )
									If nInd = FETCH_Ok
										If frmOrders.dfNPARef = 'Y' 
											Call CheckNPAOrderedItems( dfCustNo, dfCustName, dfBusName )
										If frmOrders.dfDontSell = 'Y'
											Call SalMessageBox( 'This Customer is flagged as DONT SELL TO!,
													You need authorisation from the office manager before continuing to add the order?
													Please note any comments from customer details before requesting
													the authorisation.', 'Warning', MB_OkCancel | MB_IconQuestion )
										If frmOrders.dfCredStop = 'Y'
											If frmOrders.dfCusttype = 'GCP'
												Call SalMessageBox( 'This Customer is to be REFERED to John Danks!,
														Please advise Accounts Payable before processing any orders.', 'Warning', MB_Ok )
											Else
												Call SalMessageBox( 'This Customer is flagged as CREDIT STOP!,
														You need to refer to Accounts Payable re releasing this customer from Credit Stop status.', 'Warning', MB_Ok )
										If frmOrders.dfClAcc = 'Y'
											Call SalMessageBox( 'This Customer is flagged as a CLOSED ACCOUNT!,
													You need to refer to Accounts Payable re this customer.', 'Warning', MB_Ok )
										If frmOrders.dfContPrice = 'Y'
											Call SalMessageBox( 'This Customer is flagged as requiring contract prices.   Please
													 obtain the prices applicable before adding any orders. ', 'Warning', MB_Ok )
										If frmOrders.dfCusttype = 'OPP'
											Call SalMessageBox( 'This customer is an OPPOSITION customer, do you still want to accept this order?', 'Warning', MB_Ok )
										Else If frmOrders.dfCusttype = 'BAD'
											Call SalMessageBox( 'This customer is a BAD DEBT customer, please contact accounts', 'Warning', MB_Ok )
										Else If frmOrders.dfCusttype = 'BOR'
											Call SalMessageBox( 'This customer is a BAD DEBT customer, please contact Accounts', 'Warning', MB_Ok )
										If frmOrders.dfBadDebt = 'Y'
											Call SalMessageBox( 'This customer is a BAD DEBT customer, please contact accounts', 'Warning', MB_Ok )
										If frmOrders.dfCredLimit > 0
											If frmOrders.dfAR > frmOrders.dfCredLimit
												Call SalMessageBox( 'This customer has exceeded his credit limit.   Please contact accounts
														to OK any further orders and increasing his Credit Limit' , 'Warning', MB_Ok )
										If frmOrders.dfOrderNotes != ''
											Call SalModalDialog( dlgPopUpNotes, hWndForm, frmOrders.dfCustNo, 'Order Notes', frmOrders.dfOrderNotes, '' )
										Return TRUE
								Else
									Call SalWaitCursor( FALSE )
									Call SalMessageBox( 'Have been unable to retrieve the required customer extra information',
											 'Customer Details', MB_Ok )
									Return FALSE
							Else
								Set bHandlePrepared = FALSE
								Call SalWaitCursor( FALSE )
								Call SalMessageBox( 'Have been unable to retrieve the required customer extra information',
										 'Customer Details', MB_Ok )
								Return FALSE
						Case nDisconnect
							Set bOk = TRUE
							Set bHandlePrepared = FALSE
							If bHandleConnected
								Set bHandleConnected = FALSE
								If NOT SqlDisconnect( hSqlHandle )
									Set bOk = FALSE
							Return bOk
						Case nRePrepare
							Set bHandlePrepared = FALSE
							Return TRUE
			!
			! Function: GetCustExtras
				                                                                                                                                                   Description: 
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   Number: nCustNo
					                                                                                                                                                   Receive String: sCODCust
					                                                                                                                                                   Receive String: sCustType
					                                                                                                                                                   Receive String: sFNAFlag
					                                                                                                                                                   Receive String: sFMNFlag
					                                                                                                                                                   Receive String: sLabCode
					                                                                                                                                                   Receive String: sRegion
					                                                                                                                                                   Number: nActionType
				                                                                                                                                                   Static Variables 
					                                                                                                                                                   : fcOurHandle
				                                                                                                                                                   Local variables 
					                                                                                                                                                   String: sSql
					                                                                                                                                                   String: sBind
					                                                                                                                                                   String: sInto
					                                                                                                                                                   String: sName
					!
					                                                                                                                                                   String: sGotCODCust
					                                                                                                                                                   String: sGotCustType
					                                                                                                                                                   String: sGotFNAFlag
					                                                                                                                                                   String: sGotFMNFlag
					                                                                                                                                                   String: sGotLabCode
					                                                                                                                                                   String: sGotRegion
					!
					                                                                                                                                                   Number: nInd
				                                                                                                                                                   Actions 
					                                                                                                                                                   Select Case nActionType
						                                                                                                                                                   Case nExecute
							                                                                                                                                                   Set sSql = " SELECT 
									  Customer_Master.COD_Flag, Customer_Master.Customer_Type, 
									  Customer_Type.FNA_Roy_Payable, Customer_Type.FMN_Roy_Payable, 
									  Customer_Type.Label_Charge_Code, Customer_Master.Region_Id 
									FROM  
									  Customer_Master, Customer_Type
									WHERE 
									  Cust_No = :1 AND
									  Customer_Master.Customer_Type = Customer_Type.Cust_Type "
							                                                                                                                                                   Set sName = 'CUSTEXTINV'
							                                                                                                                                                   Set sBind = ':nCustNo'
							                                                                                                                                                   Set sInto = ':sGotCODCust, :sGotCustType, :sGotFNAFlag, :sGotFMNFlag, :sGotLabCode, :sGotRegion'
							!
							                                                                                                                                                   Set sCODCust = ''
							                                                                                                                                                   Set sCustType = ''
							                                                                                                                                                   Set sFNAFlag = ''
							                                                                                                                                                   Set sFMNFlag = ''
							                                                                                                                                                   Set sLabCode = ''
							                                                                                                                                                   Set sRegion = ''
							!
							                                                                                                                                                   Set sGotCODCust = ''
							                                                                                                                                                   Set sGotCustType = ''
							                                                                                                                                                   Set sGotFNAFlag = ''
							                                                                                                                                                   Set sGotFMNFlag = ''
							                                                                                                                                                   Set sGotLabCode = ''
							                                                                                                                                                   Set sGotRegion = ''
							!
							                                                                                                                                                   Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							                                                                                                                                                   Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							                                                                                                                                                   If fcOurHandle.Execute( )
								                                                                                                                                                   Call fcOurHandle.FetchNext( nInd )
								                                                                                                                                                   Set sCODCust = sGotCODCust
								                                                                                                                                                   Set sCustType = sGotCustType
								                                                                                                                                                   Set sFNAFlag = sGotFNAFlag
								                                                                                                                                                   Set sFMNFlag = sGotFMNFlag
								                                                                                                                                                   Set sLabCode = sGotLabCode
								                                                                                                                                                   Set sRegion = sGotRegion
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   Else 
								                                                                                                                                                   Return FALSE
						! Case nCommit
							                                                                                                                                                   Return fcOurHandle.Commit( )
						! Case nRollback
							                                                                                                                                                   Return fcOurHandle.Rollback( )
						                                                                                                                                                   Case nDisconnect
							                                                                                                                                                   Return fcOurHandle.Disconnect( )
			! Function: CheckCustNPANotRecd
				                                                                                                                                                   Description: 
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   Number: nCustNo
					                                                                                                                                                   Receive Boolean: bExists
					                                                                                                                                                   Number: nActionType
				                                                                                                                                                   Static Variables 
					                                                                                                                                                   : fcOurHandle
				                                                                                                                                                   Local variables 
					                                                                                                                                                   String: sSql
					                                                                                                                                                   String: sBind
					                                                                                                                                                   String: sInto
					                                                                                                                                                   String: sName
					!
					                                                                                                                                                   Number: nInd
				                                                                                                                                                   Actions 
					                                                                                                                                                   Select Case nActionType
						                                                                                                                                                   Case nExecute
							                                                                                                                                                   Set sSql = "  SELECT DISTINCT NPA_Recd_Flag
									  FROM Customer_Order 
									  WHERE 
									    Cust_No = :1 AND 
									    NOT NPA_Recd_Flag = 'Y' AND 
									    Conf_Amt IS NOT NULL"
							                                                                                                                                                   Set sName = 'CUSTNPANOTRECD'
							                                                                                                                                                   Set sBind = ':nCustNo'
							                                                                                                                                                   Set sInto = ''
							!
							                                                                                                                                                   Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							                                                                                                                                                   Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							                                                                                                                                                   Set bExists = FALSE
							!
							                                                                                                                                                   If fcOurHandle.Execute( )
								                                                                                                                                                   If fcOurHandle.FetchNext( nInd )
									                                                                                                                                                   Set bExists = TRUE
								                                                                                                                                                   Else 
									                                                                                                                                                   Set bExists = FALSE
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   Else 
								                                                                                                                                                   Return FALSE
						! Case nCommit
							                                                                                                                                                   Return fcOurHandle.Commit( )
						! Case nRollback
							                                                                                                                                                   Return fcOurHandle.Rollback( )
						                                                                                                                                                   Case nDisconnect
							                                                                                                                                                   Return fcOurHandle.Disconnect( )
			! Function: MyGetLoadType
				                                                                                                                                                   Description: Need to check for the customer what type of load it is that is being 
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   Number: nCustNo
					                                                                                                                                                   String: sLoadId
					                                                                                                                                                   Receive String: sLoadType
					                                                                                                                                                   Number: nActionType
				                                                                                                                                                   Static Variables 
					                                                                                                                                                   : fcOurHandle
				                                                                                                                                                   Local variables 
					                                                                                                                                                   String: sSql
					                                                                                                                                                   String: sBind
					                                                                                                                                                   String: sInto
					                                                                                                                                                   String: sName
					!
					                                                                                                                                                   String: sGotLoadType
					                                                                                                                                                   Number: nInd
				                                                                                                                                                   Actions 
					                                                                                                                                                   Select Case nActionType
						                                                                                                                                                   Case nExecute
							                                                                                                                                                   Set sSql = " SELECT Load_Order_Type 
									FROM Load_Customers
									WHERE Load_Customers.Cust_No = :1 AND
									  Load_Customers.Load_Id = :2 "
							                                                                                                                                                   Set sName = 'LOADORDTYPE'
							                                                                                                                                                   Set sBind = ':nCustNo, :sLoadId'
							                                                                                                                                                   Set sInto = ':sGotLoadType'
							!
							                                                                                                                                                   Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							                                                                                                                                                   Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							                                                                                                                                                   Set sLoadType = ''
							                                                                                                                                                   Set sGotLoadType = ''
							!
							                                                                                                                                                   If fcOurHandle.Execute( )
								                                                                                                                                                   Call fcOurHandle.FetchNext( nInd )
								                                                                                                                                                   Set sLoadType = sGotLoadType
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   Else 
								                                                                                                                                                   Return FALSE
						! Case nCommit
							                                                                                                                                                   Return fcOurHandle.Commit( )
						! Case nRollback
							                                                                                                                                                   Return fcOurHandle.Rollback( )
						                                                                                                                                                   Case nDisconnect
							                                                                                                                                                   Return fcOurHandle.Disconnect( )
			!
			! Function: GetLoadExtras
				                                                                                                                                                   Description: 
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   Number: nCustNo
					                                                                                                                                                   Receive String: sFreightCode
					                                                                                                                                                   Receive String: sTranspId
					                                                                                                                                                   Number: nActionType
				                                                                                                                                                   Static Variables 
					                                                                                                                                                   : fcOurHandle
				                                                                                                                                                   Local variables 
					                                                                                                                                                   String: sSql
					                                                                                                                                                   String: sBind
					                                                                                                                                                   String: sInto
					                                                                                                                                                   String: sName
					!
					                                                                                                                                                   String: sGotFreightCode
					                                                                                                                                                   String: sGotTranspId
					!
					                                                                                                                                                   Number: nInd
				                                                                                                                                                   Actions 
					                                                                                                                                                   Select Case nActionType
						                                                                                                                                                   Case nExecute
							                                                                                                                                                   Set sSql = " SELECT Load_Customers.Freight_Code,
									Load.Transport_Id 
									FROM Load_Customers, Load 
									WHERE 
									Load_Customers.Load_Id = :1 AND
									Load_Customers.Cust_No = :2 AND 
									Load.Load_Id = Load_Customers.Load_Id "
							                                                                                                                                                   Set sName = 'LOADEXTRS'
							                                                                                                                                                   Set sBind = ':sLoadId, :nCustNo'
							                                                                                                                                                   Set sInto = ':sGotFreightCode, :sGotTranspId'
							!
							                                                                                                                                                   Set sFreightCode = ''
							                                                                                                                                                   Set sTranspId = ''
							!
							                                                                                                                                                   Set sGotFreightCode = ''
							                                                                                                                                                   Set sGotTranspId = ''
							!
							                                                                                                                                                   Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							                                                                                                                                                   Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							                                                                                                                                                   If fcOurHandle.Execute( )
								                                                                                                                                                   Call fcOurHandle.FetchNext( nInd )
								                                                                                                                                                   Set sFreightCode = sGotFreightCode
								                                                                                                                                                   Set sTranspId = sGotTranspId
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   Else 
								                                                                                                                                                   Return FALSE
						! Case nCommit
							                                                                                                                                                   Return fcOurHandle.Commit( )
						! Case nRollback
							                                                                                                                                                   Return fcOurHandle.Rollback( )
						                                                                                                                                                   Case nDisconnect
							                                                                                                                                                   Return fcOurHandle.Disconnect( )
			!
			!
			! Function: PrintInvoice
				                                                                                                                                                   Description: To physically print the invoice for the customer
						 we process the orders that have been selected for that customer
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
					                                                                                                                                                   Boolean: bPickUpAddress
					                                                                                                                                                   String: sBindVars
					                                                                                                                                                   String: sIntoVars
					                                                                                                                                                   String: sTmp
				                                                                                                                                                   Actions 
					                                                                                                                                                   Set ngSITotal = 0
					                                                                                                                                                   Set ngRoyTot = 0
					                                                                                                                                                   Set ngOrdTotal = 0
					                                                                                                                                                   Set ngTotAmt = 0
					                                                                                                                                                   Set frmOrders.dfTotRoyalties = 0
					!
					! Call GetShipAddressHdlNewLogic( frmOrders.dfCustNo, frmOrders.dfYr, frmOrders, PAM_SHIPADDRESS, bPickUpAddress, nExecute )
					! Set sIntoVars = 'ADD_ADDED_DT, ADDRESS_1, ADDRESS_2, SUBURB, STATE, POSTCODE, AREA_CODE, 
							PHONE_NO, CUSTOMER_ADDRESS.FAX_NO'
					! Set sBindVars = ':frmOrders.dfSHDTime, :frmOrders.dfSHAdd1, :frmOrders.dfSHAdd2, :frmOrders.dfSHSuburb, 
							:frmOrders.dfSHState, :frmOrders.dfSHPostcode, :frmOrders.dfSHACode, :frmOrders.dfSHPhoneNo, 
							:frmOrders.dfSHFaxNo'
					! Call GetShipAddressBindNewLogic( frmOrders.dfCustNo, frmOrders.tblOrder.colYr, 
							sIntoVars, sBindVars, bPickUpAddress, nExecute )
					!
					                                                                                                                                                   Call GetShipAddress( frmOrders.dfCustNo, frmOrders.tblOrder.colYr, frmOrders.dfSHDTime, 
							sTmp, frmOrders.dfSHAdd1, frmOrders.dfSHAdd2, frmOrders.dfSHSuburb, frmOrders.dfSHPostcode, 
							frmOrders.dfSHState, sTmp, frmOrders.dfSHACode, frmOrders.dfSHPhoneNo, sTmp, frmOrders.dfSHFaxNo, 
							sTmp, sTmp, sTmp, bPickUpAddress, nExecute )
					                                                                                                                                                   If bPickUpAddress
						                                                                                                                                                   Set frmOrders.dfSHAdd1 = sPICKUPADDRESSLINE1
						                                                                                                                                                   Set frmOrders.dfSHAdd2 = sPICKUPADDRESSLINE2
					!
					! Call GetBusAddressHdlNewLogic( frmOrders.dfCustNo, frmOrders, PAM_BUSADDRESS, nExecute )
					! Set sIntoVars = 'ADD_ADDED_DT, ADDRESS_1, ADDRESS_2, SUBURB, STATE, POSTCODE, 
							AREA_CODE, PHONE_NO'
					! Set sBindVars = ':frmOrders.dfPODTime, :frmOrders.dfPOAdd1, :frmOrders.dfPOAdd2, :frmOrders.dfPOSuburb, 
							:frmOrders.dfPOState, :frmOrders.dfPOPostcode, :frmOrders.dfPOACode, :frmOrders.dfPOPhoneNo'
					! Call GetBusAddressBindNewLogic( frmOrders.dfCustNo, sIntoVars, sBindVars,  nExecute )
					!
					                                                                                                                                                   Call GetBusAddress( 
							frmOrders.dfCustNo, 
							frmOrders.dfPODTime, 
							sTmp, 
							frmOrders.dfPOAdd1, 
							frmOrders.dfPOAdd2, 
							frmOrders.dfPOSuburb, 
							frmOrders.dfPOPostcode, 
							frmOrders.dfPOState, 
							sTmp, 
							frmOrders.dfPOACode, 
							frmOrders.dfPOPhoneNo, 
							sTmp, 
							sTmp, 
							sTmp, 
							sTmp, 
							sTmp, 
							nExecute )
					!
					!
					! Because the orders selected may all be on different loads we need to calculate
							the freight charge on an order basis and not a load basis 
					! Call FreightCharges(  )
					! Need to reset the cumulated fields on frmOrders
					                                                                                                                                                   Call SalSendMsgToChildren( frmOrders, PAM_REFRESH, 0, 0 )
					! Call SumOrdConf( frmOrders.dfCustNo, frmOrders.dfYr )
					!
					                                                                                                                                                   Call MySumOrdConf( dfCustNo, dfYr, ngTotTrees, ngTotTreesOrd, nExecute )
					!
					                                                                                                                                                   If frmOrders.dfLabCode != ''
						! Set frmOrders.dfLabperTree = LabelCharges( frmOrders.dfLabCode )
						                                                                                                                                                   Call MyLabelCharges( frmOrders.dfLabCode, ngTotTreesOrd, frmOrders.dfLabperTree, nExecute )
					                                                                                                                                                   If frmOrders.dfPackCode != ''
						! Set frmOrders.dfPackPerc = LabelCharges( frmOrders.dfPackCode )
						                                                                                                                                                   Call MyLabelCharges( frmOrders.dfPackCode, ngTotTreesOrd, frmOrders.dfPackPerc, nExecute )
					!
					! Call MyProcessDeposit( frmOrders.hSqlHdlDepAmt, frmOrders.bHdlDepAmtConnected, frmOrders.bHdlDepAmtPrepared, 
							frmOrders.hSqlHdlAmtUnAplid, frmOrders.bHdlAmtUnAplidConnected, frmOrders.bHdlAmtUnAplidPrepared, 
							frmOrders, frmOrders.dfCustNo, frmOrders.dfYr, frmOrders.dfDeposit )
					                                                                                                                                                   Call NewMyProcessDeposit( frmOrders, frmOrders.dfCustNo, frmOrders.dfYr, frmOrders.dfDeposit, nExecute )
					! Call CheckForPOS( frmOrders.dfCustNo, frmOrders.dfYr )
					                                                                                                                                                   Call MyCheckForPOS( frmOrders.dfCustNo, frmOrders.dfYr, bgPOSExists, nExecute )
					                                                                                                                                                   Set ngTRow = TBL_MinRow
					! Set bgNilSI = FALSE
					                                                                                                                                                   Return TRUE
			! Function: FirstPOSRecord
				                                                                                                                                                   Description: To set up the first POS record for a customer after their stock item orders
						have been processed
				                                                                                                                                                   Returns 
				                                                                                                                                                   Parameters 
				                                                                                                                                                   Static Variables 
				                                                                                                                                                   Local variables 
				                                                                                                                                                   Actions 
					                                                                                                                                                   Call SalSendMsg( frmOrders.tblOrder, PAM_POPULATE, 0, 0 )
					! eg no rows fit the selection
					                                                                                                                                                   If ngCount2 = 0
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   Set ngTRow = TBL_MinRow
					                                                                                                                                                   Call SalTblFindNextRow( frmOrders.tblOrder, ngTRow, 0, 0 )
					                                                                                                                                                   Call SalTblFetchRow( frmOrders.tblOrder, ngTRow )
					!
					                                                                                                                                                   Call OurSendMsgToChildren(  frmOrders.tblOrder, PAM_EXTENDPRICES, 0, 0 )
					                                                                                                                                                   If nMySendMsgError
						                                                                                                                                                   Set bOk = FALSE
						                                                                                                                                                   Return FALSE
					                                                                                                                                                   If bgUpdateFiles = TRUE
						! If NOT UpdateOrderForInvoice( frmOrders.tblOrder, frmOrders.tblOrder.colItemNo,
								 frmOrders.tblOrder.colSubsItemNo, frmOrders.tblOrder.colYr, frmOrders.tblOrder.colConfAmt, CUSTORDROWIDPOS )
							                                                                                                                                                   Set frmOrders.bFilesUpdated = FALSE
							                                                                                                                                                   Return FALSE
						                                                                                                                                                   If NOT MyUpdateOrderForInvoice( frmOrders.tblOrder, frmOrders.tblOrder.colItemNo,
								 frmOrders.tblOrder.colSubsItemNo, frmOrders.tblOrder.colYr, frmOrders.tblOrder.colConfAmt, nExecute )
							                                                                                                                                                   Set frmOrders.bFilesUpdated = FALSE
							                                                                                                                                                   Return FALSE
					                                                                                                                                                   If ngTRow = ngCount2 - 1
						!
						                                                                                                                                                   If SalSendMsg( tblInvoiceTotals, PAM_LOOKUPCUST, 0, frmOrders.dfCustNo )
							                                                                                                                                                   Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, nUseStoredTotals, 0 )
						                                                                                                                                                   Else 
							                                                                                                                                                   Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, 0, 0 )
							                                                                                                                                                   Call PushNumber( frmOrders.dfCustNo )
							                                                                                                                                                   Call PushNumber( frmOrders.dfDelCharge )
							                                                                                                                                                   Call PushNumber( frmOrders.dfPackCharge )
							                                                                                                                                                   Call PushNumber( frmOrders.dfLabCharge )
							                                                                                                                                                   Call SalSendMsg( tblInvoiceTotals, PAM_ADDROW, 0, 0 )
						! Call SalSendMsgToChildren( frmOrders, PAM_EXTENDPRICES, 0, 0 )
						                                                                                                                                                   If bgUpdateFiles = TRUE
							! If NOT UpdateInvoiceTotalsToFile( frmOrders, frmOrders.dfDeposit )
								                                                                                                                                                   Set bOk = FALSE
								                                                                                                                                                   Set frmOrders.bFilesUpdated = FALSE
								                                                                                                                                                   Return FALSE
							! Call UpdateLoadCustInvFlag( frmOrders.tblOrder.colLoad, frmOrders.dfCustNo, 'Y', nExecute )
							                                                                                                                                                   If NOT NewUpdateInvoiceTotalsToFile( frmOrders, frmOrders.dfDeposit, nExecute )
								                                                                                                                                                   Set bOk = FALSE
								                                                                                                                                                   Set frmOrders.bFilesUpdated = FALSE
								                                                                                                                                                   Return FALSE
							                                                                                                                                                   Call NewUpdateLoadCustInvFlag( frmOrders.tblOrder.colLoad, frmOrders.dfCustNo, 'Y', nExecute )
					                                                                                                                                                   Return TRUE
			!
			Function: MySumOrdConf
				Description: To sum the ordered and confirmed values as label charges require these
						and freight charges is now done on an order basis not a customer basis
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Number: nYear
					! sDisplayOrderType = 'ALL' OR 'BARE_ROOTED' OR 'CONTAINERISED'
					String: sDisplayOrderType
					Receive Number: nTotalConfAmt
					Receive Number: nTotalOrdAmt
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
					: fcOurBareHandle
						Class: hcSqlHandle
					: fcOurContHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					Number: nGotTotalConfAmt
					Number: nGotTotalOrdAmt
					Number: nInd
				Actions
					Select Case nActionType
						Case nExecute
							If sDisplayOrderType = 'CONTAINERISED'
								Set sSql = " SELECT Sum( Conf_Amt ), Sum( Ordered_Amount ) 
										FROM Customer_Order, Stock_Item
										WHERE Cust_No = :1 AND Year_Of_Sale = :2 AND 
										Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
										Stock_Item.Tree_Type LIKE 'C%' "
								Set sName = 'SUMCNTCNFAMT'
								Set sBind = ':nCustNo, :nYear'
								Set sInto = ':nGotTotalConfAmt, :nGotTotalOrdAmt'
								Call fcOurContHandle.Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( fcOurContHandle.hSqlHandle )
								!
								Set nTotalConfAmt = 0
								Set nTotalOrdAmt = 0
								!
								Set nGotTotalConfAmt = 0
								Set nGotTotalOrdAmt = 0
								!
								If fcOurContHandle.Execute( )
									Call fcOurContHandle.FetchNext( nInd )
									Set nTotalConfAmt = nGotTotalConfAmt
									Set nTotalOrdAmt = nGotTotalOrdAmt
									Return TRUE
								Else
									Return FALSE
							Else If sDisplayOrderType = 'BARE_ROOTED' 
								Set sSql = " SELECT Sum( Conf_Amt ), Sum( Ordered_Amount ) 
										FROM Customer_Order, Stock_Item  
										WHERE Cust_No = :1 AND Year_Of_Sale = :2 AND 
										Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
										NOT Stock_Item.Tree_Type LIKE 'C%' "
								Set sName = 'SUMBARECNFAMT'
								Set sBind = ':nCustNo, :nYear'
								Set sInto = ':nGotTotalConfAmt, :nGotTotalOrdAmt'
								Call fcOurBareHandle.Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( fcOurBareHandle.hSqlHandle )
								!
								Set nTotalConfAmt = 0
								Set nTotalOrdAmt = 0
								!
								Set nGotTotalConfAmt = 0
								Set nGotTotalOrdAmt = 0
								!
								If fcOurBareHandle.Execute( )
									Call fcOurBareHandle.FetchNext( nInd )
									Set nTotalConfAmt = nGotTotalConfAmt
									Set nTotalOrdAmt = nGotTotalOrdAmt
									Return TRUE
								Else
									Return FALSE
							Else
								Set sSql = " SELECT Sum( Conf_Amt ), Sum( Ordered_Amount ) 
										FROM Customer_Order 
										WHERE Cust_No = :1 AND Year_Of_Sale = :2 "
								Set sName = 'SUMCONFORDAMT'
								Set sBind = ':nCustNo, :nYear'
								Set sInto = ':nGotTotalConfAmt, :nGotTotalOrdAmt'
								Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( fcOurHandle.hSqlHandle )
								!
								Set nTotalConfAmt = 0
								Set nTotalOrdAmt = 0
								!
								Set nGotTotalConfAmt = 0
								Set nGotTotalOrdAmt = 0
								!
								If fcOurHandle.Execute( )
									Call fcOurHandle.FetchNext( nInd )
									Set nTotalConfAmt = nGotTotalConfAmt
									Set nTotalOrdAmt = nGotTotalOrdAmt
									Return TRUE
								Else
									Return FALSE
						! Case nCommit
							                                                                                                                                                   Return fcOurHandle.Commit( )
						! Case nRollback
							                                                                                                                                                   Return fcOurHandle.Rollback( )
						Case nDisconnect
							Call fcOurHandle.Disconnect( )
							Call fcOurBareHandle.Disconnect( )
							Call fcOurContHandle.Disconnect( )
							Return TRUE
			Function: MySumOrdConfHistory
				Description: To sum the ordered and confirmed values as label charges require these
						and freight charges is now done on an order basis not a customer basis
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Number: nYear
					! sDisplayOrderType = 'ALL' OR 'BARE_ROOTED' OR 'CONTAINERISED'
					String: sDisplayOrderType
					Receive Number: nTotalConfAmt
					Receive Number: nTotalOrdAmt
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
					: fcOurBareHandle
						Class: hcSqlHandle
					: fcOurContHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					Number: nGotTotalConfAmt
					Number: nGotTotalOrdAmt
					Number: nInd
				Actions
					Select Case nActionType
						Case nExecute
							If sDisplayOrderType = 'CONTAINERISED'
								Set sSql = " SELECT Sum( Conf_Amt ), Sum( Ordered_Amount ) 
										FROM Cust_Order_History, Stock_Item
										WHERE Cust_No = :1 AND Year_Of_Sale = :2 AND 
										Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
										Stock_Item.Tree_Type LIKE 'C%' "
								Set sName = 'SCNTCNFAMTHST'
								Set sBind = ':nCustNo, :nYear'
								Set sInto = ':nGotTotalConfAmt, :nGotTotalOrdAmt'
								Call fcOurContHandle.Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( fcOurContHandle.hSqlHandle )
								!
								Set nTotalConfAmt = 0
								Set nTotalOrdAmt = 0
								!
								Set nGotTotalConfAmt = 0
								Set nGotTotalOrdAmt = 0
								!
								If fcOurContHandle.Execute( )
									Call fcOurContHandle.FetchNext( nInd )
									Set nTotalConfAmt = nGotTotalConfAmt
									Set nTotalOrdAmt = nGotTotalOrdAmt
									Return TRUE
								Else
									Return FALSE
							Else If sDisplayOrderType = 'BARE_ROOTED' 
								Set sSql = " SELECT Sum( Conf_Amt ), Sum( Ordered_Amount ) 
										FROM Cust_Order_History, Stock_Item  
										WHERE Cust_No = :1 AND Year_Of_Sale = :2 AND 
										Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
										NOT Stock_Item.Tree_Type LIKE 'C%' "
								Set sName = 'SBARECNFAMTHST'
								Set sBind = ':nCustNo, :nYear'
								Set sInto = ':nGotTotalConfAmt, :nGotTotalOrdAmt'
								Call fcOurBareHandle.Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( fcOurBareHandle.hSqlHandle )
								!
								Set nTotalConfAmt = 0
								Set nTotalOrdAmt = 0
								!
								Set nGotTotalConfAmt = 0
								Set nGotTotalOrdAmt = 0
								!
								If fcOurBareHandle.Execute( )
									Call fcOurBareHandle.FetchNext( nInd )
									Set nTotalConfAmt = nGotTotalConfAmt
									Set nTotalOrdAmt = nGotTotalOrdAmt
									Return TRUE
								Else
									Return FALSE
							Else
								Set sSql = " SELECT Sum( Conf_Amt ), Sum( Ordered_Amount ) 
										FROM Cust_Order_History
										WHERE Cust_No = :1 AND Year_Of_Sale = :2 "
								Set sName = 'SMCNFORDAMTHIST'
								Set sBind = ':nCustNo, :nYear'
								Set sInto = ':nGotTotalConfAmt, :nGotTotalOrdAmt'
								Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( fcOurHandle.hSqlHandle )
								!
								Set nTotalConfAmt = 0
								Set nTotalOrdAmt = 0
								!
								Set nGotTotalConfAmt = 0
								Set nGotTotalOrdAmt = 0
								!
								If fcOurHandle.Execute( )
									Call fcOurHandle.FetchNext( nInd )
									Set nTotalConfAmt = nGotTotalConfAmt
									Set nTotalOrdAmt = nGotTotalOrdAmt
									Return TRUE
								Else
									Return FALSE
						! Case nCommit
							                                                                                                                                                   Return fcOurHandle.Commit( )
						! Case nRollback
							                                                                                                                                                   Return fcOurHandle.Rollback( )
						Case nDisconnect
							Call fcOurHandle.Disconnect( )
							Call fcOurBareHandle.Disconnect( )
							Call fcOurContHandle.Disconnect( )
							Return TRUE
			! Function: CheckCustNeedPRC
				                                                                              Description: 
				                                                                              Returns 
					                                                                              Boolean: 
				                                                                              Parameters 
					                                                                              Number: nCustNo
					                                                                              Number: nYear
					                                                                              Receive Boolean: bNeedPRC
					                                                                              Number: nActionType
				                                                                              Static Variables 
				                                                                              Local variables 
					                                                                              String: sSql
					                                                                              String: sBind
					                                                                              String: sInto
					                                                                              String: sName
					                                                                              Number: nInd
					                                                                              Number: nSqlHandleNo
				                                                                              Actions 
					                                                                              Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CheckCustNeedPRC' )
					                                                                              Select Case nActionType
						                                                                              Case nExecute
							                                                                              Set sSql = " SELECT 
									  Customer_Order.Cust_No 
									FROM 
									  Customer_Order, 
									  Stock_Item, 
									  Customer_Master
									WHERE 
									  Customer_Order.Cust_No = :1 AND 
									  Customer_Order.Year_Of_Sale = :2 AND 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
									   Customer_Order.Conf_Amt > 0 AND
									   Stock_Item.Prod_Royalty = 'Y' AND 
									  ( NOT Customer_Order.PRC_Recd_Flag = 'Y' OR 
									    Customer_Order.PRC_Recd_Flag IS NULL ) AND
									  NOT Customer_Order.Sale_Cat = 'RP' "
							                                                                              Set sName = 'IVCSTCHKNDPRC'
							                                                                              Set sBind = ':nCustNo, :nYear'
							                                                                              Set sInto = ''
							                                                                              Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							                                                                              Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							                                                                              Set bNeedPRC = FALSE
							!
							                                                                              If haSqlHandles[ nSqlHandleNo ].Execute( )
								                                                                              If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									                                                                              Set bNeedPRC = TRUE
								! Return TRUE
							                                                                              Else 
								                                                                              Set bNeedPRC = FALSE
							                                                                              Return bNeedPRC
						                                                                              Case nDisconnect
							                                                                              Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			! Function: MySumOrdConfHistory
				                                                                                                                                                   Description: To sum the ordered and confirmed values as label charges require these
						and freight charges is now done on an order basis not a customer basis
				                                                                                                                                                   Returns 
					                                                                                                                                                   Boolean: 
				                                                                                                                                                   Parameters 
					                                                                                                                                                   Number: nCustNo
					                                                                                                                                                   Number: nYear
					                                                                                                                                                   Receive Number: nTotalConfAmt
					                                                                                                                                                   Receive Number: nTotalOrdAmt
					                                                                                                                                                   Number: nActionType
				                                                                                                                                                   Static Variables 
					                                                                                                                                                   : fcOurHandle
				                                                                                                                                                   Local variables 
					                                                                                                                                                   String: sSql
					                                                                                                                                                   String: sBind
					                                                                                                                                                   String: sInto
					                                                                                                                                                   String: sName
					!
					                                                                                                                                                   Number: nGotTotalConfAmt
					                                                                                                                                                   Number: nGotTotalOrdAmt
					                                                                                                                                                   Number: nInd
				                                                                                                                                                   Actions 
					                                                                                                                                                   Select Case nActionType
						                                                                                                                                                   Case nExecute
							                                                                                                                                                   Set sSql = " SELECT Sum( Conf_Amt ), Sum( Ordered_Amount ) 
									FROM Cust_Order_History
									WHERE Cust_No = :1 AND Year_Of_Sale = :2 "
							                                                                                                                                                   Set sName = 'SMCNFORDAMTHIST'
							                                                                                                                                                   Set sBind = ':nCustNo, :nYear'
							                                                                                                                                                   Set sInto = ':nGotTotalConfAmt, :nGotTotalOrdAmt'
							!
							                                                                                                                                                   Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							                                                                                                                                                   Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							                                                                                                                                                   Set nTotalConfAmt = 0
							                                                                                                                                                   Set nTotalOrdAmt = 0
							!
							                                                                                                                                                   Set nGotTotalConfAmt = 0
							                                                                                                                                                   Set nGotTotalOrdAmt = 0
							!
							                                                                                                                                                   If fcOurHandle.Execute( )
								                                                                                                                                                   Call fcOurHandle.FetchNext( nInd )
								                                                                                                                                                   Set nTotalConfAmt = nGotTotalConfAmt
								                                                                                                                                                   Set nTotalOrdAmt = nGotTotalOrdAmt
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   Else 
								                                                                                                                                                   Return FALSE
						! Case nCommit
							                                                                                                                                                   Return fcOurHandle.Commit( )
						! Case nRollback
							                                                                                                                                                   Return fcOurHandle.Rollback( )
						                                                                                                                                                   Case nDisconnect
							                                                                                                                                                   Return fcOurHandle.Disconnect( )
		Window Parameters
		Window Variables
			Date/Time: dtTmp
			String: sTmp
			Number: nTmp
			!
			Date/Time: dtInvDate
			Number: nInvYear
			Boolean: bDifferentLoadId
			Boolean: bOrderNotPulled
			Boolean: bOrderInvoiced
			!
			! sDisplayOrderType = 'ALL' OR 'BARE_ROOTED' OR 'CONTAINERISED'
			String: sDisplayOrderType
			!
			Number: naItemNos[*]
			Number: naQuantities[*]
			!
			Boolean: bNotSameLoad
			Boolean: bFirstLoadId
			Boolean: bRowSelected
			Date/Time: dtaOrdDT[*]
			Number: nCount
			Number: nRow
			!
			String: sLoadType
			String: sLastLoadId
			String: sPurchOrdNo
			!
			String: sSqlOrderSelect
			String: sSqlOrderWhere
			String: sSqlOrderBuildWhere
			String: sSqlBareRootOrderBuildWhere
			String: sSqlContOrderBuildWhere
			String: sSqlDefaultOrderBuildWhere
			String: sSqlOrderOrderBy
			String: sSqlOrderBind
			String: sSqlOrderInto
			String: sSqlOrderFrom
			String: sSqlOrderFromHist
			! --------------------------------------
			String: dfDontSell
			String: dfNPARef
			String: dfCredStop
			String: dfClAcc
			String: dfContPrice
			String: dfBadDebt
			String: dfOrderNotes
			Number: dfAR

					Font Size: Default
					Font Enhancement: Italic
					Picture File Name:
					Picture Transparent Color: None
					Image Style: Single
					Text Color: Default
					Background Color: Default
					Message Actions
						On SAM_Click
							Call SalWaitCursor( TRUE )
							Call PushWndHdl( hWndItem )
							! Select Case nWhichTableActive
								                                                                                                                                                   Case nCustomerTbl
									                                                                                                                                                   Break 
									                                                                                                                                                   Call PushWndHdl( frmQCustomer.tblQCustomer )
									                                                                                                                                                   Call PushString( frmQCustomer.tblQCustomer.sCurrentBuildWhere )
								                                                                                                                                                   Case nCustAddrTbl
									                                                                                                                                                   Call PushWndHdl( frmQCustomer.tblQCustAddr )
									                                                                                                                                                   Call PushString( frmQCustomer.tblQCustAddr.sCurrentBuildWhere )
									                                                                                                                                                   Break 
								                                                                                                                                                   Case nCustContTbl
									                                                                                                                                                   Call PushWndHdl( frmQCustomer.tblQCustCont )
									                                                                                                                                                   Call PushString( frmQCustomer.tblQCustCont.sCurrentBuildWhere )
							Call PushWndHdl( frmOrders.tblOrder )
							Call PushString( sSqlOrderOrderBy )
							Call SalDisableWindow( hWndItem )
							Call SalModalDialog( dlgTblOrderBy, hWndForm )
						On PAM_ENABLE
							If wParam
								! TS 3/5/95 Call PopString( frmOrders.tblOrder.sCurrentBuildWhere, TRUE )
								Call PopString( sSqlOrderOrderBy, TRUE )
								Call SalSendMsg( frmOrders.tblOrder, PAM_REPOPULATE, 0, 0 )
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )
						On PAM_QUERYDISABLE
							If wParam
								Call SalDisableWindow( hWndItem )
							Else
								Call SalEnableWindow( hWndItem )
				Pushbutton: pbPrintLblPulls
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: OurPushbuttonClass
					Property Template:
					Class DLL Name:
					Title: Print Pulls
					Window Location and Size
						Left:   4.275"
						Top:    4.063"
						Width:  1.013"
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? No
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name:
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_CLICK
							If CheckCustomersNotes( dfCustNo, 'Label Notes', nExecute )
								Set bFirstLoadId = TRUE
								Set sLoadId = ''
								Set bRowSelected = FALSE
								Set nCustNos[0] = dfCustNo
								Set nCustNos[1] = NUMBER_Null
								! Default the year to the current year just in case POS is required and no rows are selected 
								Set nYear = frmOrders.tblOrder.nYr
								Set nCount = 0
								If MyTableLoop( tblOrder, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Checking Pull sheet criteria!', nLowToHiWithPositioning )
									Call SalSendMsg( tblOrder, PAM_REMEMBERSELECTEDROWS, 0, 0 )
									Call SalCreateWindow( frmPullLabels, hWndForm, sLoadId, nCustNos, dtaOrdDT, nYear, '', nSelectedCustOrd )
								Else
									! If NOT bRowSelected
										                                                                                                                                                   Call SalMessageBox( 'No Orders to have label pull sheets printed have been selected ', 'Customer Order', MB_Ok )
									Call SalCreateWindow( frmPullLabels, hWndForm, sLoadId, nCustNos, dtaOrdDT, nYear, '', nSelectedCustOrd )
						On PAM_ROWACTION
							Set bRowSelected = TRUE
							Set sLoadId = tblOrder.colLoad
							Set nYear = tblOrder.colYr
							Set dtaOrdDT[ nCount ] = tblOrder.colOrderDateTime
							Set nCount = nCount + 1
							Set dtaOrdDT[ nCount ] = DATETIME_Null
							Return TRUE
				Pushbutton: pbPrintCrNote
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: OurPushbuttonClass
					Property Template:
					Class DLL Name:
					Title:
					Window Location and Size
						Left:   Default
						Top:    Default
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? No
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name:
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_CLICK
							If SalTblAnyRows( tblOrder, ROW_UnusedFlag1, 0 )
								If dfYr < WhichSeasonYear( SalDateCurrent(  ) ) AND NOT dfYr = 77 AND NOT dfYr = NUMBER_Null
									Set sTmp = 'STOCK_HISTORY'
								Else
									Set sTmp = 'STOCK_CURRENT'
							Else
								Set sTmp = 'MISCONLY'
							Call SalModalDialog( dlgGenCreditNote, hWndForm, dfCustNo, dfCustName, hWndItem, sTmp )
						On PAM_FETCH_CRNOTE_INIT
							Set nRow = TBL_MinRow
							Return TRUE
						On PAM_FETCH_CRNOTE_NEXT
							If SalTblFindNextRow( tblOrder, nRow, ROW_UnusedFlag1, 0 )
								Call SalTblFetchRow( tblOrder, nRow )
								!
								Call PushDateTime( tblOrder.colOrderDateTime )
								Call PushNumber( tblOrder.colNoTreesCredited )
								Call PushNumber( tblOrder.colCreditedAmount )
								Call PushString( tblOrder.colReturnToInv )
								Call PushNumber( tblOrder.colInvNo )
								Call PushDateTime( tblOrder.colInvDate )
								Call PushString( tblOrder.colBasePriceOnly )
								!
								Return TRUE
							Else
								Return FALSE
				!

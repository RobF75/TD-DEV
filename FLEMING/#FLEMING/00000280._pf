						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL(  wParam,hWndItem,'CUST_PROMO.PROMO_ID' )
							On PAM_INSERT
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'CUST_PROMO.PROMO_ID' )
							On PAM_UPDATE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'CUST_PROMO.PROMO_ID' )
							On PAM_DATAVAL
								If SalIsNull( hWndItem )
									Call ErrorMessage( ' Please select a Promotions first.', hWndForm, ngRow )
									Return FALSE
								Return TRUE
							On PAM_LOOKUPPROMO
								Call PopString( colPromoId, TRUE )
								Set bEdit = TRUE
								Call SalSetFieldEdit( hWndItem, TRUE )
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE
					Column: colYear
						Class Child Ref Key: 0

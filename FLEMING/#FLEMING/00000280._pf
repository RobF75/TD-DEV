				                                                                                                                                                   Message Actions 
					                                                                                                                                                   On PAM_EXTENDPRICES
						                                                                                                                                                   Set dfSubTotal = 0
						                                                                                                                                                   Set dfSubTotal = ngTotAmt + dfDelCharge
						                                                                                                                                                   Set dfSubTotal = dfSubTotal + dfPackCharge
						                                                                                                                                                   Set dfSubTotal = dfSubTotal + dfLabCharge
					                                                                                                                                                   On PAM_SETTRANSEDIT
						                                                                                                                                                   Call SalSetFieldEdit( hWndItem, TRUE )
					                                                                                                                                                   On PAM_REFRESH
						                                                                                                                                                   Set dfSubTotal = NUMBER_Null
					                                                                                                                                                   On PAM_TRANSSQL
						                                                                                                                                                   Call BuildSQL(  wParam,hWndItem,'TRANSACTION.TRANSACTION_AMOUNT' )
			! Data Field: dfDeposit
.winattr
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Data
					Maximum Data Length: Default
					Data Type: Number
					Editable? Yes

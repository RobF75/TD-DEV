								Call PushString( sQueryTmpStr )
								Return TRUE
							! On PAM_SUMTOTALS
								                                                                                                                                                   Set colOrdAmt = ngOrdTotal
								                                                                                                                                                   Return VALIDATE_Ok
							On PAM_QBE
								If NOT SalIsNull( hWndItem )
									Set sQueryBuildWhere = sQueryBuildWhere || ' AND ORDERED_AMOUNT = :colOrdAmt '
									Return TRUE
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On PAM_EDITCHECK

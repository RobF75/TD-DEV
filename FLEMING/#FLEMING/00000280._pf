			Data Field: dfToCustName
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Data
					Maximum Data Length: 60
					Data Type: String
					Editable? Yes
				Display Settings
					Window Location and Size
						Left:   2.288"
						Top:    0.99"
						Width:  4.025"
						Width Editable? Yes
						Height: 0.25"
						Height Editable? Yes
					Visible? Yes
					Border? Yes
					Justify: Left
					Format: Unformatted
					Country: Default
					Font Name: Default
					Font Size: Default
					Font Enhancement: Default
					Text Color: Dark Blue
					Background Color: White
					Input Mask: Unformatted
				Message Actions
					On PAM_QBECUST
						If NOT SalIsNull( hWndItem )
							Set sQueryTmpStr = dfToCustName
							Call SalStrUpper( sQueryTmpStr, sQueryTmpStr )
							Call MyStrReplace( sQueryTmpStr, '\'', '_' )
							Set sQueryTmpStr = '%'||sQueryTmpStr||'%'
							Call PushString( sQueryTmpStr )
							Call PushString( LIKEOPERAND )
							Call PushString( STRINGFOLLOWING )
							Call PushString( '@UPPER(CUST_NAME)' )
							Return TRUE
					On PAM_LOOKUPCUST
						Call PopString( dfToCustName, TRUE )

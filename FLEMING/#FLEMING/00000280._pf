			Pushbutton: pbPrintCrNote
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title:
				Window Location and Size
					Left:   Default
					Top:    Default
					Width:  Class Default
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? No
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalTblAnyRows( tblPromo, ROW_UnusedFlag1, 0 )
							Set sTmp = 'POS'
						Else
							Set sTmp = 'MISCONLY'
						Call SalModalDialog( dlgGenCreditNote, hWndForm, dfCustno, dfCustname, hWndItem, sTmp )
					On PAM_FETCH_CRNOTE_INIT
						Set nRow = TBL_MinRow
						Return TRUE
					On PAM_FETCH_CRNOTE_NEXT
						If SalTblFindNextRow( tblPromo, nRow, ROW_UnusedFlag1, 0 )
							Call SalTblFetchRow( tblPromo, nRow )
							!
							Call PushDateTime( tblPromo.colPromoDTStamp )
							Call PushNumber( tblPromo.colNoItemsCredited )
							Call PushNumber( tblPromo.colCreditedAmount )
							Call PushString( 'N' )
							Call PushNumber( tblPromo.colInvNo )
							Call PushDateTime( tblPromo.colInvDate )
							Call PushString( 'N' )
							!
							Return TRUE
						Else
							Return FALSE

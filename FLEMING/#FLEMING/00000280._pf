				Message Actions
					On SAM_Click
						Call SalWaitCursor( TRUE )
						Set bEnablePromoFrmSelectPb = FALSE
						Call SalTblQueryFocus( frmCustPromotions.tblPromo, nRow, hWndCol )
						If frmCustPromotions.tblPromo.colInvNo > 0
							Call SalMessageBox( 'Sorry, you cannot pick over the promo for a line that is already invoiced', 'Error', MB_Ok )
							Call SalWaitCursor( FALSE )
							Return FALSE
						If SalTblQueryRowFlags( frmCustPromotions.tblPromo, nRow, ROW_Selected )
							Set bEnablePromoFrmSelectPb = TRUE
						Else
							Call SalSendMsg( hWndCol, PAM_ENABLECHILDSELECTPB, nRow, 0 )
						Call PushNumber( bEnablePromoFrmSelectPb )
						Call PushWndHdl( frmCustPromotions.tblPromo )
						Call PushNumber( PAM_QBEPROMO )
						Call BuildWhereQBE(  )
						Call PushWndHdl ( hWndItem )
						Call SalDisableWindow ( hWndItem ) 
						Set hWndCalled = SalCreateWindow( frmPromo, hWndForm )
					On PAM_ENABLE
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
					On PAM_LOOKUP
						Call SalSendMsgToChildren( frmCustPromotions.tblPromo, PAM_LOOKUPPROMO, 0, 0 )
					On PAM_READYFORNEXTLOOKUP
						Call SalSendMsg( frmCustPromotions.tblPromo, PAM_ADDROW, 0, 0 )
					On PAM_QUERYDISABLE
						If wParam
							Call SalDisableWindow( hWndItem )
						Else
							Call SalEnableWindow( hWndItem )

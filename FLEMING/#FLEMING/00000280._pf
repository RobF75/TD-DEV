							On PAM_QBE
								If NOT SalIsNull( hWndItem )
									Set sQueryTmpStr = colPromoDesc||'%'
									Call PushString( sQueryTmpStr )
									Call PushString( LIKEOPERAND )
									Call PushString( STRINGFOLLOWING )
									Call PushString( 'PROMO.PROMO_DESC' )
									Return TRUE
							On PAM_DATAVAL
								Return TRUE
							On PAM_QBEPROMO
								If NOT SalIsNull( hWndItem )
									Set sQueryTmpStr = colPromoDesc||'%'
									Call PushString( sQueryTmpStr )
									Call PushString( LIKEOPERAND )
									Call PushString( STRINGFOLLOWING )
									Call PushString( 'PROMO.PROMO_DESC' )
									Return TRUE
							On PAM_LOOKUPPROMO
								Call PopString( colPromoDesc, TRUE )
								Set bEdit = TRUE
								Call SalSetFieldEdit( hWndItem, TRUE )
							On PAM_ENABLECHILDSELECTPB
								Set frmCustPromotions.bEnablePromoFrmSelectPb = TRUE

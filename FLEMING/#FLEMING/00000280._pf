		Functions
			Function: AddDeposit
				Description: Add the deposit required record to the outstanding deposit table 
				Returns
				Parameters
				Static Variables
				Local variables
					Boolean: bLocalSqlA
					Sql Handle: hLocalSqlA
				Actions
					! LOCAL SQL HANDLE CONNECTION, DISCONNECT are on exit pointS
					Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					If bLocalSqlA
						Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					Else
						Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						Return FALSE
					!
					Call SalSendMsgToChildren( dlgDeposit, PAM_SETEDIT, 0, 0 )
					Call CallBuildSql( dlgDeposit, nINSERT, PAM_SQL, OUTSTAND_DEPOSIT, '' )
					If MySqlPrepExec( hLocalSqlA, sgSql )
						Call SqlCommit( hLocalSqlA )
					! If NOT SqlOK( hLocalSqlA, sgSql )
						! Can only be because it is trying to add one for the same date/time so try again
						                                                                                                                                                   Call SqlImmediate( sgSql )
						                                                                                                                                                   Call SqlClearImmediate(  )
					If bLocalSqlA
						Call SqlDisconnect( hLocalSqlA )
					Call SalEndDialog( dlgDeposit, TRUE )
		Window Parameters
		Window Variables
		Message Actions
			On SAM_CreateComplete
				Call PopNumber( dfYr, TRUE )
				Set dfReqdDate = SalDateCurrent(  )
				Call SalSetFocus( dfDepReqd )
				Call SalWaitCursor( FALSE )

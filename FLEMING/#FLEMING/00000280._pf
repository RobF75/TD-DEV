		Functions
			! The next 5 functions are used for order transfer from one customer to another
			Function: ReadCustOrder
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					Receive Number: nInd
					Window Handle: hWndTable
					String: sSQLTABLENAME
					String: sSqlWhere
				Static Variables
				Local variables
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Call SalWaitCursor( TRUE )
							Return FALSE
					If NOT bHandlePrepared
						Call CallBuildSql( hWndTable, nSELECT, PAM_SQL, sSQLTABLENAME, sSqlWhere )
						If SqlPrepare( hSqlHandle, sgSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						Call SqlFetchNext( hSqlHandle, nInd )
						Return TRUE
					Else
						Set bHandlePrepared = FALSE
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'Error occured in retrieving a order line! ', 'Error', MB_Ok )
						Call SalWaitCursor( TRUE )
						Return FALSE
			Function: InsertCustOrder
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					Window Handle: hWndTable
					String: sSQLTABLENAME
					String: sOrderType
				Static Variables
				Local variables
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Call SalWaitCursor( TRUE )
							Return FALSE
					If NOT bHandlePrepared
						If sOrderType = 'POS'
							Call CallBuildSql( hWndTable, nINSERT, PAM_INSERTPOS, sSQLTABLENAME, '' )
						Else
							Call CallBuildSql( hWndTable, nINSERT, PAM_INSERT, sSQLTABLENAME, '' )
						If SqlPrepare( hSqlHandle, sgSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						Return TRUE
					Else
						Set bHandlePrepared = FALSE
						Call SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'Error occured in inserting a order line! ', 'Error', MB_Ok )
						Call SalWaitCursor( TRUE )
						Return FALSE
			Function: DeleteCustOrder
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					Window Handle: hWndTable
					String: sSQLTABLENAME
					String: sSqlWhere
				Static Variables
				Local variables
					String: sSql
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Call SalWaitCursor( TRUE )
							Return FALSE
					If NOT bHandlePrepared
						Set sSql = 'DELETE FROM ' || sSQLTABLENAME || sSqlWhere
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						Return TRUE
					Else
						Set bHandlePrepared = FALSE
						Return FALSE
			Function: GetNextOrder
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					Receive Number: nInd
					Window Handle: hWndTable
					String: sSQLTABLENAME
					String: sSqlWhere
					String: sOrderType
				Static Variables
				Local variables
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Call SalWaitCursor( TRUE )
							Return FALSE
					If NOT bHandlePrepared
						If sOrderType = 'POS'
							Call CallBuildSql( hWndTable, nSELECT, PAM_SQLPOS, sSQLTABLENAME, sSqlWhere )
						Else
							Call CallBuildSql( hWndTable, nSELECT, PAM_SQL, sSQLTABLENAME, sSqlWhere )
						If SqlPrepare( hSqlHandle, sgSql )
							Set bHandlePrepared = TRUE
							If NOT SqlExecute( hSqlHandle )
								Set bHandlePrepared = FALSE
								Call SalWaitCursor( FALSE )
								Call SalMessageBox( 'Error occured in retrieving all order lines! ', 'Error', MB_Ok )
								Call SalWaitCursor( TRUE )
								Return FALSE
						Else
							Set bHandlePrepared = FALSE
					Call SqlFetchNext( hSqlHandle, nInd )
					If nInd = FETCH_Ok
						Return TRUE
					Else If nInd = FETCH_EOF
						Return FALSE
					Else
						Set bHandlePrepared = FALSE
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'Error occured in retrieving a order line! ', 'Error', MB_Ok )
						Call SalWaitCursor( TRUE )
						Return FALSE
			Function: GetNoCustOrderLines
				Description:
				Returns
					Number:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Number: nCustNo
					String: sSQLTABLENAME
					Window Handle: hWndTable
					String: sTransferType
					String: sPOSOrders
					Number: nYear
				Static Variables
				Local variables
					String: sSql
					Number: nNoOrders
					Number: nRow
					Number: nInd
				Actions
					Set nNoOrders = NUMBER_Null
					If sTransferType = 'SELECTED' AND sPOSOrders != 'POS'
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
							Set nNoOrders = nNoOrders + 1
						Return nNoOrders
					Else
						If NOT bHandleConnected
							Set bHandleConnected = SqlConnect( hSqlHandle ) 
							If bHandleConnected
								Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
								Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
							Else
								Call SalWaitCursor( FALSE )
								Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
								Call SalWaitCursor( TRUE )
								Return -1
						If sPOSOrders = 'POS' AND sTransferType = 'SELECTED'
							Set sSql = 'SELECT Count(*) FROM ' || sSQLTABLENAME || ' INTO :nNoOrders WHERE Cust_No = :nCustNo AND Year_Of_Order = :nYear '
						Else
							Set sSql = 'SELECT Count(*) FROM ' || sSQLTABLENAME || ' INTO :nNoOrders WHERE Cust_No = :nCustNo '
						If SqlPrepare( hSqlHandle, sSql )
							If SqlExecute( hSqlHandle )
								Call SqlFetchNext( hSqlHandle, nInd )
								If nInd = FETCH_Ok
									Return nNoOrders
								Else If nInd = FETCH_EOF
									Return 0
								Else
									Return -1
							Else
								Call SalWaitCursor( FALSE )
								Call SalMessageBox( 'Error occured in retrieving a count of order lines! ', 'Error', MB_Ok )
								Call SalWaitCursor( TRUE )
								Return -1
						Else
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Error occured in Preparing count order order lines statement! ', 'Error', MB_Ok )
							Call SalWaitCursor( TRUE )
							Return -1
		Window Parameters
		Window Variables
			Sql Handle: hSqlNoOrdersHdl
			Boolean: bSqlNoOrdersHdlConnected
			Boolean: bSqlNoOrdersHdlPrepared
			!
			Window Handle: hWndPushbutton
			Window Handle: hWndOrdTable
			Boolean: bEnableQCustDlgSelectPb
			String: sQueryTmpStr
			String: sHelpFileName
			String: sSql
			String: sSqlWhere
			String: sSqlWhereAll
			String: sSqlWherePOS
			String: sSqlWhereAllPOS
			String: sSqlWherePOSDT
			String: sSQLTABLECUSTORDER
			String: sSQLTABLECUSTPROMO
			Boolean: bEdit
			Boolean: bNextOrder
			Boolean: bTransferRunning
			Number: nRow
			Number: nInd
			!
			Sql Handle: hSqlReadHdl
			Boolean: bSqlReadHdlConnected
			Boolean: bSqlReadHdlPrepared
			!
			Sql Handle: hSqlWriteHdl
			Boolean: bSqlWriteHdlConnected
			Boolean: bSqlWriteHdlPrepared
			!
			Sql Handle: hSqlDeleteHdl
			Boolean: bSqlDeleteHdlConnected
			Boolean: bSqlDeleteHdlPrepared
		Message Actions
			On SAM_Create
				Set sHelpFileName = ''
				Set bEdit = FALSE
				Set bTransferRunning = FALSE
				Set bSqlReadHdlConnected = FALSE
				Set bSqlReadHdlPrepared = FALSE
				Set bSqlWriteHdlConnected = FALSE
				Set bSqlWriteHdlPrepared = FALSE
				Set bSqlDeleteHdlConnected = FALSE
				Set bSqlDeleteHdlPrepared = FALSE
				Set bSqlNoOrdersHdlConnected = FALSE
				Set bSqlNoOrdersHdlPrepared = FALSE
				Set sSQLTABLECUSTORDER = ' Customer_Order '
				Set sSQLTABLECUSTPROMO = ' Cust_Promo '
				Call PopWndHdl( hWndPushbutton, TRUE )
				Call PopWndHdl( hWndOrdTable, TRUE )
				Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
			On PAM_CREATECOMPLETE
				Call PopNumber( dfTransferYear, TRUE )
				Call PopNumber( dfFromCustNo, TRUE )
				If SalTblAnyRows( hWndOrdTable, ROW_Selected, 0 )
					Set rbSelectedOrders = TRUE
					Set cbTransferPOS = FALSE
				Else
					Set rbAllOrders = TRUE
					Set cbTransferPOS = TRUE
				Call SalWaitCursor( FALSE )
			On SAM_Close
				Call SalWaitCursor( TRUE )
			On SAM_Destroy
				If bSqlReadHdlConnected
					Call SqlDisconnect( hSqlReadHdl )
				If bSqlWriteHdlConnected
					Call SqlDisconnect( hSqlWriteHdl )
				If bSqlDeleteHdlConnected
					Call SqlDisconnect( hSqlDeleteHdl )
				If bSqlNoOrdersHdlConnected
					Call SqlDisconnect( hSqlNoOrdersHdl )
				Call SalSendMsg( hWndPushbutton, PAM_ENABLE, bEdit, 0 )
			On PAM_RESETPREPAREDHDLS
				Set bSqlReadHdlPrepared = FALSE
				Set bSqlWriteHdlPrepared = FALSE
				Set bSqlDeleteHdlPrepared = FALSE

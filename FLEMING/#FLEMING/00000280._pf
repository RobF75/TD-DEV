		Functions
		Window Parameters
		Window Variables
			Window Handle: hWndPushbutton
			Boolean: bShowQueryOk
			Boolean: bEnablePromoFrmSelectPb
			Boolean: bSelect
			Number: nRow
			String: sHelpFileName
		Message Actions
			On SAM_Create
				Set bSelect = FALSE
				Set sHelpFileName = 'g:\\apps\\gupta\\help\\prcustpr.hlp'
				Call PopNumber( bEnablePromoFrmSelectPb, TRUE )
				Call PopWndHdl( hWndPushbutton, TRUE )
			On SAM_CreateComplete
				Set dfCurrentDate = SalDateCurrent(  )
				Call SalSendMsg( frmPromo.tblPromotions, PAM_POPULATE, 0, 0 )
				Call SalHideWindow( SalParentWindow( hWndForm ) )
			On SAM_Destroy
				Call SalShowWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				Call SalSendMsg( hWndPushbutton, PAM_ENABLE, 0, bSelect )
			On SAM_Close
				If NOT TableForgetChanges( frmPromo.tblPromotions, frmPromo.tblPromotions.bEdit )
					Return FALSE
				Call SalWaitCursor( TRUE )

						List Values
						Message Actions
							On PAM_WHEREPOPULATE
								Set sBuildWhere = ' WHERE CUST_NO = :frmCustPromotions.dfCustno 
										AND CUST_PROMO.PROMO_ID = PROMO.PROMO_ID  AND 
										YEAR_OF_ORDER = :frmCustPromotions.dfYr '
							On PAM_QBE
								Call PushString( NOTHINGFOLLOWING )
								Call PushString( ' CUST_NO = :frmCustPromotions.dfCustno 
										AND CUST_PROMO.PROMO_ID = PROMO.PROMO_ID ' )
							On PAM_DATAVAL
								Return TRUE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE
					Column: colCustNo
						Class Child Ref Key: 0

			Pushbutton: pbQCustomer
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Query Customer - F7
				Window Location and Size
					Left:   4.388"
					Top:    1.323"
					Width:  1.9"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: F7
				Font Name: Default
				Font Size: Default
				Font Enhancement: Italic
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						Call SalWaitCursor( TRUE )
						Set bEnableQCustDlgSelectPb = TRUE
						Call PushWndHdl( hWndForm )
						Call PushNumber( PAM_QBECUST )
						Call BuildWhereQBE(  )
						! Need to prime pushwndhdl again as it is used up in the BuildWhereQBE 
						Call PushNumber( bEnableQCustDlgSelectPb )
						Call PushWndHdl( hWndItem )
						Call SalDisableWindow( hWndItem )
						Call SalModalDialog( dlgQCustomer, hWndForm )
					On PAM_ENABLE
						! The next line is the standard way of doing a select from a child screen,
								  however in this case we need a multi row selection from the child screen,
								  thats why the PAM_LOOKUP and PAM_READYFORNEXTLOOKUP are 
								  added to this button and the lParam uncommented.
						! If lParam
							                                                                                                                                                   Call SalSendMsgToChildren( tblSub, PAM_LOOKUPTYPE, 0, 0 )
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
					On PAM_LOOKUP
						Call SalSendMsgToChildren( hWndForm, PAM_LOOKUPCUST, 0, 0 )
					On PAM_READYFORNEXTLOOKUP
						! here we dont want a multiple selection
						Return FALSE
			Pushbutton: pbOkTransfer
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &OK TRANSFER - Enter
				Window Location and Size
					Left:   0.088"
					Top:    2.74"
					Width:  4.4"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: Enter
				Font Name: Default
				Font Size: Default
				Font Enhancement: Italic
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						If rbSelectedOrders
							If NOT SalTblAnyRows( hWndOrdTable, ROW_Selected, 0 )
								Call SalMessageBox( 'No Orders were selected on the order screen!', 'Warning', MB_Ok )
								Return FALSE
						If SalIsNull( dfFromCustNo )
							Call SalMessageBox( 'The From Customer No. field is empty! Please rectify!', 'Warning', MB_Ok )
							Return FALSE
						If SalIsNull( dfToCustNo )
							Call SalMessageBox( 'The To Customer No. field is empty! Please rectify!', 'Warning', MB_Ok )
							Call SalSetFocus( dfToCustNo )
							Return FALSE
						Call SalWaitCursor( TRUE )
						Call SalDisableWindow( hWndItem )
						If rbSelectedOrders
							Set dfOrdersToGo = GetNoCustOrderLines( hSqlNoOrdersHdl, bSqlNoOrdersHdlConnected, dfFromCustNo, sSQLTABLECUSTORDER, hWndOrdTable, 'SELECTED', 'TREES', dfTransferYear )
						Else
							Set dfOrdersToGo = GetNoCustOrderLines( hSqlNoOrdersHdl, bSqlNoOrdersHdlConnected, dfFromCustNo, sSQLTABLECUSTORDER, hWndOrdTable, 'ALL', 'TREES', 0 )
						When SqlError
							Call MyOnTimeOutRePreparedHandles( hWndForm )
						Set bTransferRunning = TRUE
						Call SalSendMsgToChildren( hWndForm, PAM_ENABLE, 0, 0 )
						Call SalWaitCursor( TRUE )
						Call SalSendMsg( pbCancel, PAM_YIELDENABLE, 0, 0 )
						!
						Set sSqlWhere = ' WHERE Cust_No = :dlgTransferOrders.dfCustNo AND Order_Date_Time = :dlgTransferOrders.dfOrderDateTime AND Invoice_No IS NULL '
						Set sSqlWhereAll = ' WHERE Cust_No = :dlgTransferOrders.dfCustNo  AND Invoice_No IS NULL '
						Set sSqlWherePOS = ' WHERE Cust_No = :dlgTransferOrders.dfPOSCustNo AND Year_Of_Order = :dlgTransferOrders.dfPOSYearOfOrder AND Promo_Invoice_No IS NULL '
						Set sSqlWhereAllPOS = ' WHERE Cust_No = :dlgTransferOrders.dfPOSCustNo  AND Promo_Invoice_No IS NULL '
						Set sSqlWherePOSDT = ' WHERE Cust_No = :dlgTransferOrders.dfPOSCustNo AND Promo_DT_Stamp = :dlgTransferOrders.dfPOSPromoDT  AND Promo_Invoice_No IS NULL '
						!
						If NOT rbPOSOrdersOnly
							Set bNextOrder = TRUE
							If rbSelectedOrders
								Set nRow = TBL_MinRow
							While bNextOrder
								If rbSelectedOrders
									If SalTblFindNextRow( hWndOrdTable, nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( hWndOrdTable, nRow )
										Set dfCustNo = dfFromCustNo
										Set dfOrderDateTime = hWndOrdTable.colOrderDateTime
										If NOT ReadCustOrder( hSqlReadHdl, bSqlReadHdlConnected, bSqlReadHdlPrepared, nInd, hWndForm, sSQLTABLECUSTORDER, sSqlWhere )
											Set bNextOrder = FALSE
									Else
										Set bNextOrder = FALSE
								Else
									Set dfCustNo = dfFromCustNo
									If NOT GetNextOrder( hSqlReadHdl, bSqlReadHdlConnected, bSqlReadHdlPrepared, nInd, hWndForm, sSQLTABLECUSTORDER, sSqlWhereAll, 'TREES' )
										Set bNextOrder = FALSE
								If bNextOrder
									If nInd = FETCH_Ok
										Set dfCustNo = dfToCustNo
										If InsertCustOrder( hSqlWriteHdl, bSqlWriteHdlConnected, bSqlWriteHdlPrepared, hWndForm, sSQLTABLECUSTORDER, 'TREES' )
											Set dfCustNo = dfFromCustNo
											If DeleteCustOrder( hSqlDeleteHdl, bSqlDeleteHdlConnected, bSqlDeleteHdlPrepared, hWndForm, sSQLTABLECUSTORDER, sSqlWhere )
												Call SqlCommit( hSqlWriteHdl )
												Call SqlCommit( hSqlDeleteHdl )
											Else
												Call SqlPrepareAndExecute( hSqlWriteHdl, 'ROLLBACK' )
												Call SqlPrepareAndExecute( hSqlDeleteHdl, 'ROLLBACK' )
												Call SalWaitCursor( FALSE )
												Call SalMessageBox( 'Error occured in removing a order line! ', 'Error', MB_Ok )
												Call SalWaitCursor( TRUE )
											Set bEdit = TRUE
											Set dfOrdersToGo = dfOrdersToGo - 1
									If NOT bTransferRunning
										Set bNextOrder = FALSE
										Call SalSendMsgToChildren( hWndForm, PAM_DISABLE, 0, 0 )
										Call SalPostMsg( pbCancel, SAM_Click, 0, 0 )
						If cbTransferPOS
							Set bSqlReadHdlPrepared = FALSE
							Set bSqlWriteHdlPrepared = FALSE
							Set bSqlDeleteHdlPrepared = FALSE
							!
							If rbSelectedOrders
								Set dfOrdersToGo = GetNoCustOrderLines( hSqlNoOrdersHdl, bSqlNoOrdersHdlConnected, dfFromCustNo, sSQLTABLECUSTPROMO, hWndOrdTable, 'SELECTED', 'POS', dfTransferYear )
							Else
								Set dfOrdersToGo = GetNoCustOrderLines( hSqlNoOrdersHdl, bSqlNoOrdersHdlConnected, dfFromCustNo, sSQLTABLECUSTPROMO, hWndOrdTable, 'ALL', 'POS', 0 )
							Set bNextOrder = TRUE
							While bNextOrder
								Set dfPOSCustNo = dfFromCustNo
								Set dfPOSYearOfOrder = dfTransferYear
								If rbSelectedOrders
									If NOT GetNextOrder( hSqlReadHdl, bSqlReadHdlConnected, bSqlReadHdlPrepared, nInd, hWndForm, sSQLTABLECUSTPROMO, sSqlWherePOS, 'POS' )
										Set bNextOrder = FALSE
								Else
									If NOT GetNextOrder( hSqlReadHdl, bSqlReadHdlConnected, bSqlReadHdlPrepared, nInd, hWndForm, sSQLTABLECUSTPROMO, sSqlWhereAllPOS, 'POS' )
										Set bNextOrder = FALSE
								If bNextOrder
									If nInd = FETCH_Ok
										Set dfPOSCustNo = dfToCustNo
										If InsertCustOrder( hSqlWriteHdl, bSqlWriteHdlConnected, bSqlWriteHdlPrepared, hWndForm, sSQLTABLECUSTPROMO, 'POS' )
											Set dfPOSCustNo = dfFromCustNo
											If DeleteCustOrder( hSqlDeleteHdl, bSqlDeleteHdlConnected, bSqlDeleteHdlPrepared, hWndForm, sSQLTABLECUSTPROMO, sSqlWherePOSDT )
												Call SqlCommit( hSqlWriteHdl )
												Call SqlCommit( hSqlDeleteHdl )
											Else
												Call SqlPrepareAndExecute( hSqlWriteHdl, 'ROLLBACK' )
												Call SqlPrepareAndExecute( hSqlDeleteHdl, 'ROLLBACK' )
												Call SalWaitCursor( FALSE )
												Call SalMessageBox( 'Error occured in removing a order line! ', 'Error', MB_Ok )
												Call SalWaitCursor( TRUE )
											Set bEdit = TRUE
											Set dfOrdersToGo = dfOrdersToGo - 1
									If NOT bTransferRunning
										Set bNextOrder = FALSE
										Call SalSendMsgToChildren( hWndForm, PAM_DISABLE, 0, 0 )
										Call SalPostMsg( pbCancel, SAM_Click, 0, 0 )
						Set bTransferRunning = FALSE
						Call SalSendMsgToChildren( hWndForm, PAM_DISABLE, 0, 0 )
						Call SalPostMsg( pbCancel, SAM_Click, 0, 0 )
						Call SalEnableWindow( hWndItem )
			Pushbutton: pbCancel

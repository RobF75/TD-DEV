			Contents
				Pushbutton: pbClear
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Clear
					Window Location and Size
						Left:   0.588"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: F3
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Maint.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_CLICK
							Select Case nWhichTableActive
								Case nCustomerTbl
									Call ClearSelections( frmQCustomer.tblQCustomer )
									Break
								Case nCustAddrTbl
									Call ClearSelections( frmQCustomer.tblQCustAddr )
									Break
								Case nCustContTbl
									Call ClearSelections( frmQCustomer.tblQCustCont )
						On PAM_QUERYDISABLE
							If wParam
								Call SalDisableWindow( hWndItem )
							Else
								Call SalEnableWindow( hWndItem )
						On PAM_SETINSTANCEVARS
							Set pbClear.nAppearanceOnClick =nDisable
							Set pbClear.nAppearanceOnDisplayRec = nEnable
							Set pbClear.nAppearanceOnNewRec =nEnable
				Pushbutton: pbDetails
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Detail
					Window Location and Size
						Left:   6.588"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: F2
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Frminvit.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_CLICK
							Select Case nWhichTableActive
								Case nCustomerTbl
									If NOT SalTblAnyRows( frmQCustomer.tblQCustomer, ROW_Selected, 0 )
										Call SalMessageBox( 'No Customer selected', 'Query Customer', MB_Ok )
										Return FALSE
									Call SalWaitCursor( TRUE )
									Set frmQCustomer.nRow = TBL_MinRow
									Call SalTblFindNextRow( frmQCustomer.tblQCustomer, frmQCustomer.nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( frmQCustomer.tblQCustomer, frmQCustomer.nRow )
									Call SalSendMsg( hWndItem, PAM_SENDDATATOCHILD, 0, 0 )
									Call PushWndHdl ( hWndItem)
									Call PushWndHdl( frmQCustomer.tblQCustomer )
									Call SalDisableWindow ( hWndItem ) 
									Call SalCreateWindow( frmCustTab, hWndForm )
									Break
								Case nCustAddrTbl
									If NOT SalTblAnyRows( frmQCustomer.tblQCustAddr, ROW_Selected, 0 )
										Call SalMessageBox( 'No Customer selected', 'Query Customer Address', MB_Ok )
										Return FALSE
									Call SalWaitCursor( TRUE )
									Set frmQCustomer.nRow = TBL_MinRow
									Call SalTblFindNextRow( frmQCustomer.tblQCustAddr, frmQCustomer.nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( frmQCustomer.tblQCustAddr, frmQCustomer.nRow )
									Call SalSendMsg( hWndItem, PAM_SENDDATATOCHILD, 0, 0 )
									Call PushWndHdl ( hWndItem)
									Call PushWndHdl( frmQCustomer.tblQCustAddr )
									Call SalDisableWindow ( hWndItem ) 
									Call SalCreateWindow( frmCustTab, hWndForm )
									Break
								Case nCustContTbl
									If NOT SalTblAnyRows( frmQCustomer.tblQCustCont, ROW_Selected, 0 )
										Call SalMessageBox( 'No Customer selected', 'Query Customer Contacts', MB_Ok )
										Return FALSE
									Call SalWaitCursor( TRUE )
									Set frmQCustomer.nRow = TBL_MinRow
									Call SalTblFindNextRow( frmQCustomer.tblQCustCont, frmQCustomer.nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( frmQCustomer.tblQCustCont, frmQCustomer.nRow )
									Call SalSendMsg( hWndItem, PAM_SENDDATATOCHILD, 0, 0 )
									Call PushWndHdl ( hWndItem)
									Call PushWndHdl( frmQCustomer.tblQCustCont )
									Call SalDisableWindow ( hWndItem ) 
									Call SalCreateWindow( frmCustTab, hWndForm )
						On PAM_ENABLE
							If wParam
								Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
							Else
								If lParam = nReturnToQCust
									Call SalPostMsg( pbQGeneral, SAM_Click, 0, 0 )
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )
						On PAM_SENDDATATOCHILD
							Select Case nWhichTableActive
								Case nCustomerTbl
									Call PushNumber( frmQCustomer.tblQCustomer.colCustNo )
									Call PushNumber( PAM_DETREC )
									Return TRUE
								Case nCustAddrTbl
									Call PushNumber( frmQCustomer.tblQCustAddr.colCustNo )
									Call PushNumber( PAM_DETREC )
									Return TRUE
								Case nCustContTbl
									Call PushNumber( frmQCustomer.tblQCustCont.colCustNo )
									Call PushNumber( PAM_DETREC )
									Return TRUE
						On PAM_QUERYDISABLE
							If wParam
								Call SalDisableWindow( hWndItem )
							Else
								Call SalEnableWindow( hWndItem )
						On PAM_SETINSTANCEVARS
							Set pbDetails.nAppearanceOnClick =nDisable
							Set pbDetails.nAppearanceOnDisplayRec = nEnable
							Set pbDetails.nAppearanceOnNewRec =nEnable
				Pushbutton: pbAdd
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Add
					Window Location and Size
						Left:   1.188"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: F6
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Fmtstr.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On SAM_Click
							Call SalWaitCursor( TRUE )
							Call PushNumber( PAM_ADDREC )
							Call PushWndHdl( hWndItem )
							Select Case nWhichTableActive
								Case nCustomerTbl
									Call PushWndHdl( frmQCustomer.tblQCustomer )
									Break
								Case nCustAddrTbl
									Call PushWndHdl( frmQCustomer.tblQCustAddr )
									Break
								Case nCustContTbl
									Call PushWndHdl( frmQCustomer.tblQCustCont )
									Break
								Default
									Call PushWndHdl( hWndNULL )
							Call SalDisableWindow( hWndItem )
							Call SalCreateWindow( frmCustTab, hWndForm )
						On PAM_ENABLE
							If wParam OR nWhichTableActive = nAddNewCust
								! Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
								Call SalPostMsg( pbQGeneral, SAM_Click, 0, 0 )
							Else
								If lParam = nReturnToQCust
									Call SalPostMsg( pbQGeneral, SAM_Click, 0, 0 )
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )
						On PAM_QUERYDISABLE
							If wParam
								Call SalDisableWindow( hWndItem )
							Else
								Call SalEnableWindow( hWndItem )
						On PAM_SETINSTANCEVARS
							Set pbAdd.nAppearanceOnClick =nDisable
							Set pbAdd.nAppearanceOnDisplayRec = nEnable
							Set pbAdd.nAppearanceOnNewRec =nEnable
				Pushbutton: pbQGeneral
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Query
					Window Location and Size
						Left:   7.188"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: F7
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\Query3.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_CLICK
							Call SalWaitCursor( FALSE )
							Set nOldTableActive = nWhichTableActive
							Set nWhichTableActive = SalModalDialog( dlgInitialQCustomer, hWndForm )
							Call SalWaitCursor( TRUE )
							Select Case nWhichTableActive
								Case nCustomerTbl
									If NOT sBuildWhere = ''
										Set sBuildWhere = ' WHERE ' || sBuildWhere
									Else
										Set sBuildWhere = ' '
									Call PushString( sBuildWhere )
									Call SalSendMsg( dfQueryTypeHeading, PAM_REFRESH, 0, 0 )
									Call SalSendMsg( frmQCustomer.tblQCustomer, PAM_ENABLE, TRUE, 0 )
									Call SalSendMsg( frmQCustomer.tblQCustAddr, PAM_ENABLE, FALSE, 0 )
									Call SalSendMsg( frmQCustomer.tblQCustCont, PAM_ENABLE, FALSE, 0 )
									Call SalSendMsg( frmQCustomer.tblQCustomer, PAM_POPULATE, 0, 0 )
									Call SalSetFocus( frmQCustomer.tblQCustomer )
									Set bFirstCreateComplete = FALSE
									! Set nOldTableActive = nWhichTableActive
									Set frmQCustomer.hWndTable = tblQCustomer
									Break
								Case nCustAddrTbl
									Call PushString( sBuildWhere )
									Call SalSendMsg( dfQueryTypeHeading, PAM_REFRESH, 0, 0 )
									Call SalSendMsg( frmQCustomer.tblQCustomer, PAM_ENABLE, FALSE, 0 )
									Call SalSendMsg( frmQCustomer.tblQCustAddr, PAM_ENABLE, TRUE, 0 )
									Call SalSendMsg( frmQCustomer.tblQCustCont, PAM_ENABLE, FALSE, 0 )
									Call SalSendMsg( frmQCustomer.tblQCustAddr, PAM_POPULATE, 0, 0 )
									Call SalSetFocus( frmQCustomer.tblQCustAddr )
									Set bFirstCreateComplete = FALSE
									! Set nOldTableActive = nWhichTableActive
									Set frmQCustomer.hWndTable = tblQCustAddr
									Break
								Case nCustContTbl
									Call PushString( sBuildWhere )
									Call SalSendMsg( dfQueryTypeHeading, PAM_REFRESH, 0, 0 )
									Call SalSendMsg( frmQCustomer.tblQCustomer, PAM_ENABLE, FALSE, 0 )
									Call SalSendMsg( frmQCustomer.tblQCustAddr, PAM_ENABLE, FALSE, 0 )
									Call SalSendMsg( frmQCustomer.tblQCustCont, PAM_ENABLE, TRUE, 0 )
									Call SalSendMsg( frmQCustomer.tblQCustCont, PAM_POPULATE, 0, 0 )
									Call SalSetFocus( frmQCustomer.tblQCustCont )
									Set bFirstCreateComplete = FALSE
									! Set nOldTableActive = nWhichTableActive
									Set frmQCustomer.hWndTable = tblQCustCont
									Break
								Case nAddNewCust
									Call SalPostMsg( pbAdd, SAM_Click, 0, 0 )
									Set bFirstCreateComplete = FALSE
									! Set nOldTableActive = nWhichTableActive
									Set nWhichTableActive = nOldTableActive
									Break
								Default nCancel
									If bFirstCreateComplete
										Call SalDestroyWindow( hWndForm )
									Else
										Set bFirstCreateComplete = FALSE
										Set nWhichTableActive = nOldTableActive
										Call SalWaitCursor( FALSE )
							Call SalWaitCursor( FALSE )
						On PAM_SETINSTANCEVARS
							Set pbQGeneral.nAppearanceOnClick =nDisable
							Set pbQGeneral.nAppearanceOnDisplayRec = nEnable
							Set pbQGeneral.nAppearanceOnNewRec =nEnable

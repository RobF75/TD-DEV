			Contents
				Pushbutton: pbDetOrd
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: OurFormDetailsPbClass
					Property Template:
					Class DLL Name:
					Title: Detail
					Window Location and Size
						Left:   5.388"
						Top:    -0.01"
						Width:  0.6"
						Width Editable? Class Default
						Height: 0.58"
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: F2
					Font Name: Arial
					Font Size: 8
					Font Enhancement: Bold
					Picture File Name: C:\CENTURA\ICONS\Frminvit.ico
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_SETINSTANCEVARS
							Set pbDetOrd.sFormName = 'frmOrderDetails'
							Set pbDetOrd.hWndTable = tblOrder
							Set pbDetOrd.nPAMActionMessage = PAM_DETREC
							Set pbDetOrd.sHeading = 'Customer Order'
						On SAM_Click
							If NOT SalTblAnyRows( frmOrders.tblOrder, ROW_Selected, 0 )
								Call SalMessageBox( 'No rows selected', 'Orders', MB_Ok )
								Return FALSE
							Set nCount = TBL_MinRow
							If SalTblFindNextRow( tblOrder, nCount, ROW_Selected, 0 )
								Call SalTblSetFocusRow( tblOrder, nCount )
							Call SalSendClassMessage( SAM_Click, wParam, lParam )
						On PAM_STARTDETAILSFORM
							If tblOrder.colYr < cSeasonYear.GetSeasonYear( ) AND NOT tblOrder.colYr = 77 AND NOT tblOrder.colYr = NUMBER_Null
								Call SalWaitCursor( FALSE )
								Call SalMessageBox( 'This Order has been rolled over to order history.  Cannot show full details! ', 'Warning', MB_Ok )
								Call SalWaitCursor( TRUE )
								Return FALSE
							Call SalSendClassMessage( PAM_STARTDETAILSFORM, wParam, lParam )
						On PAM_PUSHFIELDS
							Call PushNumber( dfCustNo )
							Call PushDateTime( tblOrder.colOrderDateTime )
							Call PushString( dfCustName )
							Call PushString( dfCustType )
							Return TRUE
						On PAM_RETURN
							If lParam = nReturnToQCust
								Call SalPostMsg( pbExit, SAM_Click, 0, nReturnToQCust )
							Else If wParam
								Call SalInvalidateWindow( hWndForm )
								Call SalSendMsg( frmOrders.tblOrder, PAM_TABLEBUGREFRESH, 0, 0 )
								Call SalSendMsg( frmOrders.tblOrder, PAM_REPOPULATE, 0, 0 )
							Call SalSendClassMessage( PAM_RETURN, wParam, lParam )
						On PAM_QUERYDISABLE
							If wParam
								Call SalDisableWindow( hWndItem )
							Else
								Call SalEnableWindow( hWndItem )
				Pushbutton: pbAdd
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: OurFormDetailsPbClass
					Property Template:
					Class DLL Name:
					Title: Add
					Window Location and Size
						Left:   2.388"
						Top:    -0.01"
						Width:  0.6"
						Width Editable? Class Default
						Height: 0.58"
						Height Editable? Class Default

				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					Sql Handle: hLocalSqlDoTbl
					Boolean: bLocalSqlDoTbl
					String: sSQLPOPTABLENAME
					String: sSQLTABLENAME
					String: sSQLWHEREROWID
					String: sORDERBY
					String: sSql
					Boolean: bEdit
					Boolean: bExists
					Number: nInd
					String: sQueryTmpStr
					String: sCurrentBuildWhere
				Message Actions
					On PAM_POPULATE
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillNormal, PAM_SQL )
					On PAM_SEARCH
						Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_DELETEROWS
						Call TableDeleteRows( hWndForm )
					On PAM_UNDELETEROWS
						Call TableUnDeleteRows( hWndForm )
					On PAM_ADDROW
						Call TableAddRowNew( hWndForm, colPromoDesc )
						Set colYear = frmCustPromotions.dfYr
						Set colNoUnits = 1
						Set colSentFlag = 'N'
					On PAM_WRITEINSERTSUPDATES
						Call TableSaveChanges( hWndForm, hLocalSqlDoTbl, 'Promotional', sSQLTABLENAME, sSQLWHEREROWID, bEdit, TRUE )
					On PAM_NOROWS
						Call SalMessageBox( 'No rows were found.', 'Promotional', MB_Ok|MB_IconAsterisk )
					On PAM_RESET
						Call TableReset( hWndForm, colYear )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bLocalSqlDoTbl = SqlConnect( hLocalSqlDoTbl ) 
						If bLocalSqlDoTbl
							Call SqlSetLockTimeout( hLocalSqlDoTbl, SQLTIMEOUT )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bEdit = FALSE
						Set sSQLPOPTABLENAME = ' CUST_PROMO, PROMO '
						Set sSQLTABLENAME = ' CUST_PROMO '
						Set sSQLWHEREROWID = ' WHERE ROWID = :frmCustPromotions.tblPromo.colRowId '
						Set sORDERBY = 'ORDER BY PROMO.PROMO_DESC'
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
						If bLocalSqlDoTbl
							Call SqlDisconnect( hLocalSqlDoTbl )

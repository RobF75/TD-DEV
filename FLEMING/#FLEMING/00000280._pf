				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					String: sORDERBY
					String: sLocalBuildWhere
					String: sQueryTmpStr
					String: sCurrentBuildWhere
					String: sSqlQCustomerSelect
				Message Actions
					On PAM_POPULATE
						Call PopString( sLocalBuildWhere, TRUE )
						If sLocalBuildWhere = ''
							Set sLocalBuildWhere = ' '
						Call SalSendMsg( hWndForm, PAM_REPOPULATE, 0 ,0  )
					On PAM_REPOPULATE
						Set sSqlQCustomerSelect = '
								SELECT 
								  CUSTOMER_MASTER.CUST_NO,  CUSTOMER_MASTER.CUST_NAME , 
								  CUSTOMER_MASTER.BUS_NAME, CUSTOMER_MASTER.CUSTOMER_TYPE, 
								  CUSTOMER_MASTER.REGION_ID 
								FROM  
								  CUSTOMER_MASTER  
								INTO 
								  :frmQCustomer.tblQCustomer.colCustNo, 
								  :frmQCustomer.tblQCustomer.colCustName, 
								  :frmQCustomer.tblQCustomer.colBusName, 
								  :frmQCustomer.tblQCustomer.colCustType, 
								  :frmQCustomer.tblQCustomer.colCustRegion
								' || sLocalBuildWhere || sORDERBY
						Call SalTblReset( hWndForm )
						Call SalTblPopulate( hWndForm, hLocalSqlPopTbl, sSqlQCustomerSelect, TBL_FillNormal )
						Call SalTblFetchRow( hWndForm, 0 )
						Call SalTblSetRowFlags( hWndForm, 0, ROW_Selected, TRUE )
					On PAM_RESET
						Call TableReset( hWndForm, colCustNo )
					On PAM_NOROWS
						Call SalMessageBox( 'No rows match the search criteria', 'Customer Query', MB_Ok )
					On PAM_ENABLE
						If wParam
							Call SalShowWindow( hWndForm )
						Else
							Call SalHideWindow( hWndForm )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set sORDERBY = ' ORDER BY 2,1 '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )

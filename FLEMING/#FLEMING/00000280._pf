				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						! send message pam_qaddresscheck to hWndForm children, and if some return
								false then then confirm with user if they have clicked the right button. 
						Set hWndChild = SalGetFirstChild( hWndForm, TYPE_DataField )
						While NOT hWndChild = hWndNULL 
							If NOT SalSendMsg( hWndChild, PAM_QADDRESSCHECK, 0, 0 )
								If IDCANCEL = SalMessageBox( 'You have clicked the QUERY ADDRESS button, any other details other than Customer No or Customer Name and Address details are not applicable!  Do you still want to continue! ', 'NOTE', MB_OkCancel | MB_IconQuestion )
									Return FALSE
								Else
									Break
							Set hWndChild = SalGetNextChild( hWndChild, TYPE_DataField )
						Call PushWndHdl( hWndForm )
						Call PushNumber( PAM_QBEADDRESS )
						Call BuildWhereQBE(  )
						Set sBuildWhere = StripWhereFromSQL( sBuildWhere ) 
						Call SalEndDialog( hWndForm, nCustAddrTbl )

						On PAM_ENABLE
							If wParam
								Select Case nWhichTableActive
									Case nCustomerTbl
										Call PopString( frmQCustomer.tblQCustomer.sORDERBY, TRUE )
										Call SalSendMsg( frmQCustomer.tblQCustomer, PAM_REPOPULATE, 0, 0 )
										Break
									Case nCustAddrTbl
										Call PopString( frmQCustomer.tblQCustAddr.sORDERBY, TRUE )
										Call SalSendMsg( frmQCustomer.tblQCustAddr, PAM_REPOPULATE, 0, 0 )
										Break
									Case nCustContTbl
										Call PopString( frmQCustomer.tblQCustCont.sORDERBY, TRUE )
										Call SalSendMsg( frmQCustomer.tblQCustCont, PAM_REPOPULATE, 0, 0 )
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )
						On PAM_QUERYDISABLE
							If wParam
								Call SalDisableWindow( hWndItem )
							Else
								Call SalEnableWindow( hWndItem )
				Pushbutton: pbLoads
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Loads
					Window Location and Size
						Left:   4.188"
						Top:    -0.01"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: F:\PUBLIC\ICONS\ROAD.ICO
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_CLICK
							Select Case nWhichTableActive
								Case nCustomerTbl
									If NOT SalTblAnyRows( frmQCustomer.tblQCustomer, ROW_Selected, 0 )
										Call SalMessageBox( 'No Customer selected', 'Query Customer', MB_Ok )
										Return FALSE
									Call SalWaitCursor( TRUE )
									Call PushNumber( frmQCustomer.tblQCustomer.colCustNo )
									Call PushWndHdl( hWndItem )
									Call PushString( 'FULLDETAILS' )
									Call SalDisableWindow ( hWndItem ) 
									Call SalModalDialog( dlgLoad, hWndForm )
									Break
								Case nCustAddrTbl
									If NOT SalTblAnyRows( frmQCustomer.tblQCustAddr, ROW_Selected, 0 )
										Call SalMessageBox( 'No Customer selected', 'Query Customer Address', MB_Ok )
										Return FALSE
									Call SalWaitCursor( TRUE )
									Call PushNumber( frmQCustomer.tblQCustAddr.colCustNo )
									Call PushWndHdl( hWndItem )
									Call PushString( 'FULLDETAILS' )
									Call SalDisableWindow ( hWndItem ) 
									Call SalModalDialog( dlgLoad, hWndForm )
									Break
								Case nCustContTbl
									If NOT SalTblAnyRows( frmQCustomer.tblQCustCont, ROW_Selected, 0 )
										Call SalMessageBox( 'No Customer selected', 'Query Customer Contacts', MB_Ok )
										Return FALSE
									Call SalWaitCursor( TRUE )
									Call PushNumber( frmQCustomer.tblQCustCont.colCustNo )
									Call PushWndHdl( hWndItem )
									Call PushString( 'FULLDETAILS' )
									Call SalDisableWindow ( hWndItem ) 
									Call SalModalDialog( dlgLoad, hWndForm )
						On PAM_ENABLE
							If lParam = nReturnToQCust
								Call SalPostMsg( pbQGeneral, SAM_Click, 0, 0 )
							Call SalEnableWindow( hWndItem )
							Call SalWaitCursor( FALSE )
						On PAM_SETINSTANCEVARS
							Set pbLoads.nAppearanceOnClick =nDisable
							Set pbLoads.nAppearanceOnDisplayRec = nEnable
							Set pbLoads.nAppearanceOnNewRec =nEnable
						On PAM_QUERYDISABLE
							If wParam
								Call SalDisableWindow( hWndItem )
							Else
								Call SalEnableWindow( hWndItem )
				!
				Pushbutton: pbPrintAddrLabels
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class:
					Property Template:
					Class DLL Name:
					Title:
					Window Location and Size
						Left:   Default
						Top:    Default
						Width:  Default
						Width Editable? Yes
						Height: Default
						Height Editable? Yes
					Visible? No
					Keyboard Accelerator: (none)
					Font Name: Default
					Font Size: Default
					Font Enhancement: Default
					Picture File Name: C:\CENTURA\ICONS\Labels.ico
					Picture Transparent Color: None
					Image Style: Single
					Text Color: Default
					Background Color: Default
					Message Actions
						On SAM_Click
							Set nPos = 0
							Set nCustNos[ nPos ] = NUMBER_Null
							Set sStringListFileName = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', '' ) || '\\addrlbl.csv'
							Set nYear = WhichSeasonYear( SalDateCurrent(  ) )
							!
							If SalSendMsg( hWndItem, PAM_SETVALUES, 0, 0 )
								Call WriteNumArrayListToFile( sStringListFileName, nCustNos )
								Set sParameterLine = SqlDatabase || ' ' || SqlUser || ' ' || SqlPassword || ' ' || sStringListFileName || ' ' || 'CUSTOMER_MASTER' || ' ' || SalNumberToStrX( nYear, 0 )
								Call SalLoadApp( OurGetIniFileParameter( 'GENERAL', 'AddressLbl', '' ), sParameterLine )
								! If SqlDatabase = 'STOCK'
									                                                                                                                                                   Call SalLoadApp( 'G:\\APPS\\GUPTA\\FLEMLIVE\\ADDRLBL.EXE', sParameterLine  )
								! Else
									                                                                                                                                                   Call SalLoadApp( 'G:\\APPS\\GUPTA\\FLEMDEV\\ADDRLBLD.EXE', sParameterLine )
							Else
								Return FALSE
						On PAM_SETVALUES
							!
							Select Case nWhichTableActive
								Case nCustomerTbl
									Set hWndCurrentTable = tblQCustomer
									Break
								Case nCustAddrTbl
									Set hWndCurrentTable = tblQCustAddr
									Break
								Case nCustContTbl
									Set hWndCurrentTable = tblQCustCont
							!
							Set nPos = 0
							Set bOk = TRUE
							If SalTblAnyRows( hWndCurrentTable, ROW_Selected, 0 )
								Call MyTableLoop( hWndCurrentTable, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Fetching Selected Customers', nLowToHi )
							Else
								If IDYES = SalMessageBox( 'Do you wish to print for ALL showing customers', 'Address Labels', MB_YesNo | MB_DefButton2 )
									Call MyTableLoop( hWndCurrentTable, hWndItem, PAM_ROWACTION, 0, 0, 'Fetching Selected Customers', nLowToHi )
								Else
									Set bOk = FALSE
							Return bOk
						On PAM_ROWACTION
							Set nCustNos[ nPos ] = hWndCurrentTable.colCustNo
							Set nPos = nPos + 1
							Set nCustNos[ nPos ] = NUMBER_Null
							Return TRUE
				!

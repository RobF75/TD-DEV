								Return TRUE
					Column: colCustType
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Cust Type
						Visible? Yes
						Editable? No
						Maximum Data Length: 3
						Data Type: String
						Justify: Center
						Width:  0.85"
						Width Editable? Yes
						Format: Uppercase
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL( wParam,hWndItem,'CUSTOMER_MASTER.CUSTOMER_TYPE' )
							On PAM_QBE
								If NOT SalIsNull( hWndItem )
									Set sQueryTmpStr = colCustType||'%'
									Call PushString( sQueryTmpStr )
									Call PushString( LIKEOPERAND )
									Call PushString( STRINGFOLLOWING )
									Call PushString( 'CUSTOMER_MASTER.CUSTOMER_TYPE' )
									Return TRUE
							On PAM_CANORDERBY
								Call PushNumber( 9 )
								Call SalTblGetColumnTitle( hWndItem, sQueryTmpStr, 30 )
								Call PushString( sQueryTmpStr )
								Return TRUE
				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					String: sORDERBY
					String: sLocalBuildWhere
					String: sQueryTmpStr
					String: sCurrentBuildWhere
					String: sSqlQCustomerAddressSelect
				Message Actions
					On PAM_POPULATE
						Call PopString( sLocalBuildWhere, TRUE )
						If sLocalBuildWhere = ''
							Set sLocalBuildWhere = ' '
						Else
							Set sLocalBuildWhere = ' AND ' || sLocalBuildWhere
						Call SalSendMsg( hWndForm, PAM_REPOPULATE, 0 ,0  )
					On PAM_REPOPULATE
						Set sSqlQCustomerAddressSelect = '
								SELECT 
								  CUSTOMER_MASTER.CUST_NO, CUSTOMER_MASTER.CUST_NAME, CUSTOMER_MASTER.BUS_NAME, 
								  CUSTOMER_ADDRESS.AREA_CODE, CUSTOMER_ADDRESS.PHONE_NO, CUSTOMER_ADDRESS.ADDRESS_TYPE, 
								  CUSTOMER_ADDRESS.SUBURB, CUSTOMER_ADDRESS.POSTCODE, CUSTOMER_MASTER.CUSTOMER_TYPE 
								FROM  
								  CUSTOMER_MASTER, CUSTOMER_ADDRESS
								INTO 
								  :frmQCustomer.tblQCustAddr.colCustNo, :frmQCustomer.tblQCustAddr.colCustName, 
								  :frmQCustomer.tblQCustAddr.colBusName, :frmQCustomer.tblQCustAddr.colACode, 
								  :frmQCustomer.tblQCustAddr.colPhNo, :frmQCustomer.tblQCustAddr.colAddType, 
								  :frmQCustomer.tblQCustAddr.colSuburb, :frmQCustomer.tblQCustAddr.colPostcode, 
								  :frmQCustomer.tblQCustAddr.colCustType
								WHERE 
								  CUSTOMER_MASTER.CUST_NO = CUSTOMER_ADDRESS.CUST_NO 
								' || sLocalBuildWhere || sORDERBY
						Call SalTblReset( hWndForm )
						Call SalTblPopulate( hWndForm, hLocalSqlPopTbl, sSqlQCustomerAddressSelect, TBL_FillNormal )
						Call SalTblFetchRow( hWndForm, 0 )
						Call SalTblSetRowFlags( hWndForm, 0, ROW_Selected, TRUE )
					On PAM_RESET
						Call TableReset( hWndForm, colCustNo )
					On PAM_ENABLE
						If wParam
							Call SalShowWindow( hWndForm )
						Else
							Call SalHideWindow( hWndForm )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set sORDERBY = ' ORDER BY 2,1,6 '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
						Call GetMeetAddress( hWndForm, PAM_MEETADDRESS, nDisconnect )

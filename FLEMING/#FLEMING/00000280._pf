				                                                                                                                                                   Message Actions 
					                                                                                                                                                   On PAM_EXTENDPRICES
						! If dfTotInvoice < dfDeposit
							                                                                                                                                                   Set dfDeposit = dfTotInvoice
					                                                                                                                                                   On PAM_DEPHISTSQL
						                                                                                                                                                   Call SalSetFieldEdit( hWndItem, TRUE )
						                                                                                                                                                   Call BuildSQL( wParam, hWndItem, 'DEPOSIT_HISTORY.DEPHIST_AMT_PAID' )
						                                                                                                                                                   Call BuildSQL( wParam, hWndItem, 'DEPOSIT_HISTORY.DEPHIST_AMT_REQD' )
					                                                                                                                                                   On PAM_REFRESH
						                                                                                                                                                   Set dfDeposit = NUMBER_Null
			! Data Field: dfTotInvoice
.winattr
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Data
					Maximum Data Length: Default
					Data Type: Number
					Editable? Yes
				Display Settings
					Window Location and Size
						Left:   Default
						Top:    Default

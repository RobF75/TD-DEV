			Pushbutton: pbSelect
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: S&elect
				Window Location and Size
					Left:   0.388"
					Top:    4.24"
					Width:  1.2"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: (none)
				Font Name: Default
				Font Size: Default
				Font Enhancement: Italic
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						If NOT SalTblAnyRows( frmPromo.tblPromotions, ROW_Selected, 0 )
							Call SalMessageBox( 'Record Not Selected', 'Error', MB_Ok )
						Else
							If bEnablePromoFrmSelectPb
								Call SalWaitCursor( TRUE )
								Set bSelect = TRUE
								Set nRow = TBL_MaxRow
								While SalTblFindPrevRow( frmPromo.tblPromotions, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( frmPromo.tblPromotions, nRow )
									Call SalTblSetRowFlags( frmPromo.tblPromotions, nRow, ROW_Selected, FALSE )
									Call PushString( frmPromo.tblPromotions.colPromoDesc )
									Call PushString( frmPromo.tblPromotions.colPromoId )
									Call PushNumber( frmPromo.tblPromotions.colBasePercent )
									Call PushNumber( frmPromo.tblPromotions.colBasePrice )
									Call SalSendMsg( hWndPushbutton, PAM_LOOKUP, 0, 0 )
									If SalTblAnyRows( frmPromo.tblPromotions, ROW_Selected, 0 )
										Call SalSendMsg( hWndPushbutton, PAM_READYFORNEXTLOOKUP, 0, 0 )
								Call SalDestroyWindow( hWndForm )
					On SAM_Create
						If NOT bEnablePromoFrmSelectPb
							Call SalDisableWindow( hWndItem )
					On PAM_QUERYDISABLE
						If wParam
							Call SalDisableWindow( hWndItem )
						Else
							Call SalEnableWindow( hWndItem )

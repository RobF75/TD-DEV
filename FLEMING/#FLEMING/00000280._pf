					Column: colNoTreesCredited
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: No Trees Credited
						Visible? Yes
						Editable? Yes
						Maximum Data Length: Default
						Data Type: Number
						Justify: Center
						Width:  1.4"
						Width Editable? Yes
						Format: #0
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_UPDATE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'NO_TREES_CREDITED' )
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On SAM_SetFocus
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On PAM_EDITCHECK
								If colInvFlag != 'Y'
									Call SalTblKillEdit( hWndForm )
									Return FALSE
								Else If colAlreadyCredited = 'Y'
									Call SalTblKillEdit( hWndForm )
									Return FALSE
								Else If colSaleCat = 'FC'
									Call SalTblKillEdit( hWndForm )
									Return FALSE
								Else If colSaleCat = 'RP'
									Call SalTblKillEdit( hWndForm )
									Return FALSE
							On SAM_Validate
								If colNoTreesCredited > colConfAmt
									Call SalMessageBox( 'Number of trees being credited is greater then the Conf. Amt.!  Please rectify!', 'Warning', MB_Ok )
									Return VALIDATE_Cancel
								Else If SalIsNull( hWndItem ) AND SalIsNull( colCreditedAmount )
									Call SalTblSetRowFlags( hWndForm, lParam, ROW_UnusedFlag1, FALSE )
									Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, FALSE )
									Set colReturnToInv = 'N'
									Return VALIDATE_OkClearFlag
								Else
									Call SalTblSetRowFlags( hWndForm, lParam, ROW_UnusedFlag1, TRUE )
									Return VALIDATE_Ok
							On PAM_DATAVAL
								If SalIsNull( colCreditNoteNo ) AND NOT SalIsNull( hWndItem )
									Call ErrorMessage( 'To change this field, please produce a credit note!', hWndForm, ngRow )
									Return FALSE
								Return TRUE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE
							On PAM_SETCOLUMNCOLOR
								! wParam = back ground color
								! lParam = text color
								If wParam != 0
									Call SalColorSet( hWndItem, COLOR_IndexWindow, wParam )
								If lParam != 0
									Call SalColorSet( hWndItem, COLOR_IndexCellText, lParam )
								Return TRUE

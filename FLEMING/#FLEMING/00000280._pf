				Menu Item: &Bar Code Order Entry
					Resource Id: 8875
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when: bShowQueryOk = FALSE
						Checked when:
					Menu Actions
						If NOT OrderGoAhead(  )
							Return FALSE
						Call SalWaitCursor( TRUE )
						If SalModalDialog( dlgGetBarCodeOrderDetails, hWndForm, dfCustNo )
							Call SalWaitCursor( TRUE )
							Call PopString( sPurchOrdNo, TRUE )
							Call PopDateTime( dtOrderDate, TRUE )
							Call PopString( sAllocating, TRUE )
							Call PopNumber( nYear, TRUE )
							Call PopNumber( nCustNo, TRUE )
							If nCustNo != dfCustNo
								Call SalMessageBox( 'Sorry you can only enter bar code entries for the customer whose
										summary screen is showing', 'Bar Code Order Entry', MB_Ok )
								Call SalWaitCursor( FALSE )
								Return FALSE
							Call SalCreateWindow( frmBarCodeOrderEntry, hWndForm, dfCustNo, nYear, dtOrderDate, sAllocating, sPurchOrdNo )
						Call SalWaitCursor( FALSE )
					Menu Item Name:
				Menu Item: &Garden Centre Order Form - Manual
					Resource Id: 8876
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when: bShowQueryOk = FALSE
						Checked when:
					Menu Actions
						If NOT OrderGoAhead(  )
							Return FALSE
						Call SalWaitCursor( TRUE )
						If SalModalDialog( dlgGetOrderDetails, hWndForm, dfCustNo )
							Call SalWaitCursor( TRUE )
							Call PopString( sPurchOrdNo, TRUE )
							Call PopNumber( nYear, TRUE )
							Call PopNumber( nCustNo, TRUE )
							Call PopDateTime( dtOrderDate, TRUE )
							If nCustNo != dfCustNo
								Call SalMessageBox( 'Sorry you can only enter manual garden centre order entries for the customer whose
										summary screen is showing', 'Garden Centre Order Form', MB_Ok )
								Call SalWaitCursor( FALSE )
								Return FALSE
							Call SalCreateWindow( frmGardenCentreOrdFrm, hWndForm, dfCustNo, nYear, dtOrderDate, sPurchOrdNo )
						Call SalWaitCursor( FALSE )
					Menu Item Name:
			Popup Menu: &Reports
				Resource Id: 1341
				Enabled when:
				Status Text:
				Menu Item Name:
				Menu Item: &Full
					Resource Id: 1342
					Keyboard Accelerator: (none)
					Status Text:

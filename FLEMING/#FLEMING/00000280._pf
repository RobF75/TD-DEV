				                                                                                                                                                   Message Actions 
					                                                                                                                                                   On PAM_UPDATECUST
						                                                                                                                                                   Call SalSetFieldEdit( hWndItem, TRUE )
						                                                                                                                                                   Call BuildSQL( wParam,hWndItem,'CUSTOMER_MASTER.CUST_AR_BALANCE' )
					! Adjustarbalance is sent to this field on a row new in tbltransaction so colTransAmount
							does apply whereas in all other instances we should be checking if something 
							exists in colAmtOuts
					                                                                                                                                                   On PAM_ADJUSTARBALANCE
						! If GetCustARBalance( dfCustNo, dfCustARBalance, nExecute )
							                                                                                                                                                   Set dfCustARBalance = dfCustARBalance + dfTotInvoice
							                                                                                                                                                   Return TRUE
						! Else
							                                                                                                                                                   Return FALSE
						                                                                                                                                                   Call PushNumber( dfTotInvoice )
						                                                                                                                                                   Call PushNumber( dfCustNo )
						                                                                                                                                                   Return TRUE

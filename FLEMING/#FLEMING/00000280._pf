									Set sQueryTmpStr = colSentFlag||'%'
									Call PushString( sQueryTmpStr )
									Call PushString( EQOPERAND )
									Call PushString( NUMERICFOLLOWING )
									Call PushString( 'CUST_PROMO.PROMO_INVOICE_NO' )
									Return TRUE
							On PAM_DATAVAL
								Return TRUE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								If colInvNo > 0
									Call SalMessageBox( 'Sorry, you cannot delete this row as it has been invoiced', 'Error', MB_Ok )
									Return FALSE
								Else
									Return TRUE
					Column: colInvDate

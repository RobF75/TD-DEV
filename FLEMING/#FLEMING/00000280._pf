					Menu Item Name:
				Menu Item: &Cancel Invoice
					Resource Id: 28272
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when: bShowQueryOk = FALSE
						Checked when:
					Menu Actions
						If IsUserAccounts( SqlUser, TRUE )
							If SalModalDialog( dlgGetInvoiceNo, hWndForm )
								Call PopNumber( nInvoiceNo, TRUE )
								! We shouldnt need to get the year because each order line has the invoice
										no as part of it - so just using the invoice no will be enough - although as
										a further check we should use the customer no as part of the query to get the
										order lines as well, just in case the invoice no is not unique!! 
								! If SalModalDialog( dlgGetYear, hWndForm )
									                                                                                                                                                   Call PopNumber( nYear, TRUE )
								! Call NewUnInvoice( dfCustNo, nYear,  nInvoiceNo, nExecute )
								!
								If VerifyInvoiceForCust( dfCustNo, nInvoiceNo, nExecute )
									Call UnInvInvNo( dfCustNo, nInvoiceNo, nExecute )
								Call SalSendMsg( tblOrder, PAM_REPOPULATE, 0, 0 )
					Menu Item Name:

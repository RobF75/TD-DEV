					Menu Item Name:
				Menu Item: &Labels
					Resource Id: 61980
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when:
						Checked when:
					Menu Actions
						Set nTmp = 0
						Set naItemNos[ nTmp] = NUMBER_Null
						Set naQuantities[ nTmp ] = NUMBER_Null
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( tblOrder, nRow, ROW_Selected, 0 )
							Call SalTblFetchRow( tblOrder, nRow )
							If tblOrder.colConfAmt > 0
								Set naItemNos[ nTmp ] = tblOrder.colItemNo
								Set naQuantities[ nTmp ] = tblOrder.colConfAmt
								Set nTmp = nTmp + 1
								Set naItemNos[ nTmp ] = NUMBER_Null
								Set naQuantities[ nTmp ] = NUMBER_Null
							Else If tblOrder.colOrdAmt > 0
								Set naItemNos[ nTmp ] = tblOrder.colItemNo
								Set naQuantities[ nTmp ] = tblOrder.colOrdAmt
								Set nTmp = nTmp + 1
								Set naItemNos[ nTmp ] = NUMBER_Null
								Set naQuantities[ nTmp ] = NUMBER_Null
						!
						If nTmp = 0
							Call SalMessageBox( 'No rows selected', 'Customer Orders', MB_Ok )
							Return FALSE
						Else
							Call SalModalDialog( dlgPrintLabelsDetails, hWndForm, dfCustNo, dfCustName, naItemNos, naQuantities, FALSE )

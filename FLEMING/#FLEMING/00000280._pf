.end
				                                                                                                                                                   Message Actions 
					                                                                                                                                                   On PAM_EXTENDPRICES
						! Set dfTotInvoice = 0
						! Set dfTotInvoice = ngTotAmt + dfDelCharge
						! Set dfTotInvoice = dfTotInvoice + dfPackCharge
						! Set dfTotInvoice = dfTotInvoice + dfLabCharge
						                                                                                                                                                   Set dfTotInvoice = dfTotInvoice - dfDeposit
					                                                                                                                                                   On PAM_REFRESH
						                                                                                                                                                   Set dfTotInvoice = NUMBER_Null
					                                                                                                                                                   On PAM_SETTRANSEDIT
						                                                                                                                                                   Call SalSetFieldEdit( hWndItem, TRUE )
					                                                                                                                                                   On PAM_TRANSSQL
						                                                                                                                                                   Call BuildSQL(  wParam,hWndItem,'TRANSACTION.TRANS_AMOUNT_OUTST' )
					                                                                                                                                                   On PAM_GIVETOTINVVALUE
						                                                                                                                                                   Call PushNumber( dfTotInvoice )

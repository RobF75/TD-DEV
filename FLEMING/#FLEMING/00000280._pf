					Column: colContractPrice
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Cont. Price
						Visible? Yes
						Editable? Yes
						Maximum Data Length: Default
						Data Type: Number
						Justify: Center
						Width:  0.913"
						Width Editable? Yes
						Format: Currency
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_UPDATE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'CONTRACT_PRICE' )
							On SAM_Validate
								If NOT SalIsNull( hWndItem )
									Set colContPriceFlag = 'Y'
									Call SalSetFieldEdit( colContPriceFlag, TRUE )
								Else
									Set colContPriceFlag = 'N'
									Call SalSetFieldEdit( colContPriceFlag, TRUE )
							! On PAM_POSSQL
								                                                                                                                                                   Call BuildSQL(  wParam,hWndItem,'CUST_PROMO.OVERRIDE_PRICE' )
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On PAM_EDITCHECK
								! Editable is only allowed when not on row_new, ie any time other than for queries
								If SalTblQueryRowFlags( hWndForm, lParam, ROW_New ) OR frmOrders.tblOrder.colInvFlag = 'Y'
									Call SalTblKillEdit( hWndForm )
							On PAM_DATAVAL
								Return TRUE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE
							On PAM_SETCOLUMNCOLOR
								! wParam = back ground color
								! lParam = text color
								If wParam != 0
									Call SalColorSet( hWndItem, COLOR_IndexWindow, wParam )
								If lParam != 0
									Call SalColorSet( hWndItem, COLOR_IndexCellText, lParam )
								Return TRUE
					! aColumn: colStockItemPrice
						                                                                                                                                                   List Values 
						                                                                                                                                                   Message Actions 
							                                                                                                                                                   On PAM_EXTENDPRICES
								! eg the overide price is not zero or a value, and the stockitem base price
										is null then flag a message
								! If NOT bgPOS
									                                                                                                                                                   If SalIsNull( colContractPrice )
										                                                                                                                                                   If SalIsNull( colStockItemPrice )
											                                                                                                                                                   If NOT colSaleCat = 'RP' AND NOT colSaleCat = 'FC'
												                                                                                                                                                   Call SalMessageBox( 'The Stock Item '||colCultdesc||' / '||colRootDesc||' does not
														 have a base price for Cust.No.'||SalNumberToStrX( frmOrders.dfCustNo, 0 ), 'Invoicing', MB_Ok )
											                                                                                                                                                   Set nMySendMsgError = TRUE
											                                                                                                                                                   Return nMySendMsgError
										                                                                                                                                                   Else 
											                                                                                                                                                   Set colContractPrice = colStockItemPrice
											                                                                                                                                                   Set nMySendMsgError = FALSE
											                                                                                                                                                   Return nMySendMsgError
									                                                                                                                                                   Set nMySendMsgError = FALSE
									                                                                                                                                                   Return nMySendMsgError
								                                                                                                                                                   If NOT bgPOS
									                                                                                                                                                   If SalIsNull( colContractPrice )
										                                                                                                                                                   If SalIsNull( colStockItemPrice )
											                                                                                                                                                   If NOT colSaleCat = 'RP' AND NOT colSaleCat = 'FC'
												                                                                                                                                                   Call SalMessageBox( 'The Stock Item '||colCultdesc||' / '||colRootDesc||' does not
														 have a base price for Cust.No.'||SalNumberToStrX( frmOrders.dfCustNo, 0 ), 'Invoicing', MB_Ok )
												                                                                                                                                                   Set nMySendMsgError = TRUE
												                                                                                                                                                   Return nMySendMsgError
										                                                                                                                                                   Else 
											                                                                                                                                                   Set colContractPrice = colStockItemPrice
											                                                                                                                                                   Set nMySendMsgError = FALSE
											                                                                                                                                                   Return nMySendMsgError
									                                                                                                                                                   Set nMySendMsgError = FALSE
									                                                                                                                                                   Return nMySendMsgError
							                                                                                                                                                   On PAM_POSSQL
								                                                                                                                                                   Call BuildSQL(  wParam,hWndItem,'PROMO.PROMO_BASE_PRICE' )
							                                                                                                                                                   On PAM_DATAVAL
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   On PAM_CHECKROWNEW
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   On PAM_CHECKROWEDITED
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   On PAM_CHECKROWDELETED
								                                                                                                                                                   Return TRUE
					! aColumn: colExtPrice
						                                                                                                                                                   List Values 
						                                                                                                                                                   Message Actions 
							                                                                                                                                                   On PAM_EXTENDPRICES
								                                                                                                                                                   If bgPOS
									                                                                                                                                                   If NOT SalIsNull( colPOSPerc )
										                                                                                                                                                   Set colExtPrice = colPOSPerc*ngSITotal
										                                                                                                                                                   Set ngTotAmt = ngTotAmt + colExtPrice
										                                                                                                                                                   Set nMySendMsgError = FALSE
										                                                                                                                                                   Return nMySendMsgError
									                                                                                                                                                   Else If (SalIsNull( colContractPrice ) OR colContractPrice = 0)
										                                                                                                                                                   Set colExtPrice = 0
										                                                                                                                                                   Set nMySendMsgError = FALSE
										                                                                                                                                                   Return nMySendMsgError
									                                                                                                                                                   Else If NOT SalIsNull( colPOSFreeOver )
										                                                                                                                                                   If ngTotTreesOrd > colPOSFreeOver
											                                                                                                                                                   Set colContractPrice = 0
											                                                                                                                                                   Set colExtPrice = 0
											                                                                                                                                                   Set nMySendMsgError = FALSE
											                                                                                                                                                   Return nMySendMsgError
								                                                                                                                                                   Set colExtPrice = colContractPrice*colConfAmt
								! At this point we need to check the sale type - if it is RP -replacement or
										FC - free of charge set the Ext Price = 0, if HP - (half price) then halve the 
										ext price - CS -consignment should be checked for in the select statement
										so that it is not even included
								                                                                                                                                                   If colSaleCat = 'RP' 
									                                                                                                                                                   Set colExtPrice = 0
									! addition on 22/5/95 dmf
									                                                                                                                                                   Set colContractPrice = 0
								                                                                                                                                                   Else If colSaleCat = 'FC'
									                                                                                                                                                   Set colExtPrice = 0
									! addition on 22/5/95 dmf
									                                                                                                                                                   Set colContractPrice = 0
								                                                                                                                                                   Else If colSaleCat = 'HP'
									                                                                                                                                                   Set colExtPrice = colExtPrice/2
								! If colSaleType = 'RP' 
									                                                                                                                                                   Set colExtPrice = 0
								! Else If colSaleType = 'FC'
									                                                                                                                                                   Set colExtPrice = 0
								! Else If colSaleType = 'HP'
									                                                                                                                                                   Set colExtPrice = colExtPrice/2
								                                                                                                                                                   Set ngTotAmt = ngTotAmt + colExtPrice
								! temporarily coding that freight charges calculate on POS as well as
										the AS400 calculates this out incorrectly - change for 95
								! If NOT bgPOS
									                                                                                                                                                   Set ngSITotal = ngSITotal + colExtPrice
								                                                                                                                                                   Set ngSITotal = ngSITotal + colExtPrice
								                                                                                                                                                   Set nMySendMsgError = FALSE
								                                                                                                                                                   Return nMySendMsgError
							                                                                                                                                                   On PAM_DATAVAL
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   On PAM_CHECKROWNEW
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   On PAM_CHECKROWEDITED
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   On PAM_CHECKROWDELETED
								                                                                                                                                                   Return TRUE
					! aColumn: colExtRoyalty
						                                                                                                                                                   List Values 
						                                                                                                                                                   Message Actions 
							                                                                                                                                                   On PAM_EXTENDPRICES
								                                                                                                                                                   Set colExtRoyalty = 0
								! If the override price is set to zero deliberately then we dont wish to charge
										the tree at the royalty prices, we want it all to be zero
								                                                                                                                                                   If colExtPrice = 0
									                                                                                                                                                   Set nMySendMsgError = FALSE
									                                                                                                                                                   Return nMySendMsgError
								                                                                                                                                                   If colRootRoy !=NUMBER_Null
									                                                                                                                                                   Set colExtRoyalty = colRootRoy*colConfAmt
								                                                                                                                                                   If colCultRoy != NUMBER_Null
									                                                                                                                                                   Set colExtRoyalty = colExtRoyalty +colCultRoy*colConfAmt
								                                                                                                                                                   Set ngRoyTot = ngRoyTot + colExtRoyalty
								                                                                                                                                                   Set ngTotAmt = ngTotAmt + colExtRoyalty
								                                                                                                                                                   Set nMySendMsgError = FALSE
								                                                                                                                                                   Set frmOrders.dfTotRoyalties = frmOrders.dfTotRoyalties + colExtRoyalty
								                                                                                                                                                   Return nMySendMsgError
							                                                                                                                                                   On PAM_DATAVAL
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   On PAM_CHECKROWNEW
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   On PAM_CHECKROWEDITED
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   On PAM_CHECKROWDELETED
								                                                                                                                                                   Return TRUE
					! aColumn: colPOSFrCode
						                                                                                                                                                   List Values 
						                                                                                                                                                   Message Actions 
							                                                                                                                                                   On PAM_POSSQL
								                                                                                                                                                   Call BuildSQL(  wParam,hWndItem,'PROMO.FREIGHT_CODE' )
							                                                                                                                                                   On PAM_EXTENDPRICES
								                                                                                                                                                   If bgNilSI = TRUE
									                                                                                                                                                   If NOT SalIsNull( colPOSFrCode )
										! Call POSFreightCharge( )
										                                                                                                                                                   If POSFreightCharge( colPOSFrCode, colConfAmt, nPOSFreightCharge, nExecute )
											                                                                                                                                                   Set frmOrders.dfDelCharge = frmOrders.dfDelCharge + nPOSFreightCharge
								                                                                                                                                                   Set nMySendMsgError = FALSE
								                                                                                                                                                   Return nMySendMsgError
							                                                                                                                                                   On PAM_DATAVAL
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   On PAM_CHECKROWNEW
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   On PAM_CHECKROWEDITED
								                                                                                                                                                   Return TRUE
							                                                                                                                                                   On PAM_CHECKROWDELETED
								                                                                                                                                                   Return TRUE
					Column: colCustomBudFlag

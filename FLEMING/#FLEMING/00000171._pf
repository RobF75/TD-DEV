				Functions
					Function: MonthFromAndToDates
						Description:
						Returns
						Parameters
							Number: nMonth
							Receive Date/Time: dtFromDate
							Receive Date/Time: dtToDate
						Static Variables
						Local variables
						Actions
							Set dtFromDate = SalDateConstruct( SalDateYear( SalDateCurrent(  ) ), nMonth, 1, 0, 0, 0 )
							Set dtToDate = DateMonthEnd( dtFromDate )
					Function: CalcActualInvoiced
						Description:
						Returns
							Boolean:
						Parameters
							Date/Time: dtFromDate
							Date/Time: dtToDate
							Receive Number: nInvoiced
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nInvTransHandleNo
							Number: nCredTransHandleNo
							Number: nInvHistTransHandleNo
							Number: nCredHistTransHandleNo
							Number: nInd
							Boolean: bOk
							!
							Number: nGotInvTrans
							Number: nGotCredTrans
							Number: nGotInvHistTrans
							Number: nGotCredHistTrans
						Actions
							Set nInvTransHandleNo = SqlHandlesGetReferenceNo( 'CalcActualInvoicedInvTrans' )
							Set nCredTransHandleNo = SqlHandlesGetReferenceNo( 'CalcActualInvoicedCredTrans' )
							Set nInvHistTransHandleNo = SqlHandlesGetReferenceNo( 'CalcActualInvoicedInvHistTrans' )
							Set nCredHistTransHandleNo = SqlHandlesGetReferenceNo( 'CalcActualInvoicedCredHistTrans' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = "SELECT 
											  SUM( Transaction_Amount ) 
											FROM 
											  Transaction 
											WHERE 
											  Transaction_Type = 'INVOICE' AND 
											  Transaction_Code = 'DR' AND 
											  Transaction_Date BETWEEN :1 AND :2 "
									Set sName = 'INVFIGINVTRANS'
									Set sBind = ':dtFromDate, :dtToDate'
									Set sInto = ':nGotInvTrans'
									Call haSqlHandles[ nInvTransHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nInvTransHandleNo ].hSqlHandle )
									!
									Set sSql = "SELECT 
											  SUM( Transaction_Amount ) 
											FROM 
											  Transaction 
											WHERE 
											  Transaction_Type = 'CREDNOTE' AND 
											  Transaction_Code = 'CR' AND 
											  Transaction_Date BETWEEN :1 AND :2 "
									Set sName = 'INVFIGCREDTRANS'
									Set sBind = ':dtFromDate, :dtToDate'
									Set sInto = ':nGotCredTrans'
									Call haSqlHandles[ nCredTransHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nCredTransHandleNo ].hSqlHandle )
									!
									Set sSql = "SELECT 
											  SUM( Hist_Trans_Amount ) 
											FROM 
											  Trans_History 
											WHERE 
											  Hist_Trans_Type = 'INVOICE' AND 
											  Hist_Trans_Code = 'DR' AND 
											  Hist_Trans_Date BETWEEN :1 AND :2"
									Set sName = 'INVFIGINVHTRNS'
									Set sBind = ':dtFromDate, :dtToDate'
									Set sInto = ':nGotInvHistTrans'
									Call haSqlHandles[ nInvHistTransHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nInvHistTransHandleNo ].hSqlHandle )
									!
									Set sSql = "SELECT 
											  SUM( Hist_Trans_Amount ) 
											FROM 
											  Trans_History 
											WHERE 
											  Hist_Trans_Type = 'CREDNOTE' AND 
											  Hist_Trans_Code = 'CR' AND 
											  Hist_Trans_Date BETWEEN :1 AND :2 "
									Set sName = 'INVFIGCREDHTRNS'
									Set sBind = ':dtFromDate, :dtToDate'
									Set sInto = ':nGotCredHistTrans'
									Call haSqlHandles[ nCredHistTransHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nCredHistTransHandleNo ].hSqlHandle )
									!
									Set nInvoiced = NUMBER_Null
									Set nGotInvTrans = NUMBER_Null
									Set nGotCredTrans = NUMBER_Null
									Set nGotInvHistTrans = NUMBER_Null
									Set nGotCredHistTrans = NUMBER_Null
									!
									Set bOk = TRUE
									If bOk
										If haSqlHandles[ nInvTransHandleNo ].Execute( )
											If haSqlHandles[ nInvTransHandleNo ].FetchNext( nInd )
										Else
											Set bOk = FALSE
									If bOk
										If haSqlHandles[ nCredTransHandleNo ].Execute( )
											If haSqlHandles[ nCredTransHandleNo ].FetchNext( nInd )
										Else
											Set bOk = FALSE
									If bOk
										If haSqlHandles[ nInvHistTransHandleNo ].Execute( )
											If haSqlHandles[ nInvHistTransHandleNo ].FetchNext( nInd )
										Else
											Set bOk = FALSE
									If bOk
										If haSqlHandles[ nCredHistTransHandleNo ].Execute( )
											If haSqlHandles[ nCredHistTransHandleNo ].FetchNext( nInd )
										Else
											Set bOk = FALSE
									!
									If bOk
										Set nInvoiced = nGotInvTrans + nGotInvHistTrans - nGotCredTrans - nGotCredHistTrans
										Return TRUE
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Set bOk = TRUE
									If NOT haSqlHandles[ nInvTransHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT haSqlHandles[ nCredTransHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT haSqlHandles[ nInvHistTransHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT haSqlHandles[ nCredHistTransHandleNo ].Disconnect( )
										Set bOk = FALSE
									Return bOk
					Function: CalcEstimateInvoiced
						Description:
						Returns
							Boolean:
						Parameters
							Date/Time: dtFromDate
							Date/Time: dtToDate
							String: sStockTypeDesc
							Receive Number: nInvoiced
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nAllHandleNo
							Number: nStockTypeHandleNo
							Number: nInd
							Boolean: bOk
							!
							String: sStockType
							Number: nGotInvoiced
						Actions
							Set nAllHandleNo = SqlHandlesGetReferenceNo( 'CalcEstimateInvoicedAll' )
							Set nStockTypeHandleNo = SqlHandlesGetReferenceNo( 'CalcEstimateInvoicedStockType' )
							Select Case nActionType
								Case SH_cls_Execute
									Set nInvoiced = NUMBER_Null
									Set nGotInvoiced = NUMBER_Null
									!
									If sStockTypeDesc = 'Bare & Cont'
										Set sSql = "SELECT 
												  SUM( Customer_Order.Conf_Amt * Stock_Item.Base_Price ) 
												FROM 
												  Customer_Order, 
												  Stock_Item, 
												  Load 
												WHERE 
												  Customer_Order.Load_Id = Load.Load_Id AND 
												  ( NOT Customer_Order.Invoiced_Flag = 'Y' OR 
												    Customer_Order.Invoiced_Flag IS NULL ) AND 
												  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
												  Load.Shipping_Date BETWEEN :1 AND :2  "
										Set sName = 'INVFIGESTINVSTP'
										Set sBind = ':dtFromDate, :dtToDate'
										Set sInto = ':nGotInvoiced'
										Call haSqlHandles[ nAllHandleNo ].Setup( sSql, sName, sBind, sInto )
										Call SqlVarSetup( haSqlHandles[ nAllHandleNo ].hSqlHandle )
										!
										If haSqlHandles[ nAllHandleNo ].Execute( )
											If haSqlHandles[ nAllHandleNo ].FetchNext( nInd )
												Set nInvoiced = nGotInvoiced
											Return TRUE
										Else
											Return FALSE
									Else
										Set sSql = "SELECT 
												  SUM( Customer_Order.Conf_Amt * Stock_Item.Base_Price ) 
												FROM 
												  Customer_Order, 
												  Stock_Item, 
												  Load 
												WHERE 
												  Customer_Order.Load_Id = Load.Load_Id AND 
												  ( NOT Customer_Order.Invoiced_Flag = 'Y' OR 
												    Customer_Order.Invoiced_Flag IS NULL ) AND 
												  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
												  Load.Shipping_Date BETWEEN :1 AND :2 AND 
												  Stock_Item.Stock_Type = :3 "
										Set sName = 'INVFIGSTINVSTP'
										Set sBind = ':dtFromDate, :dtToDate, :sStockType'
										Set sInto = ':nGotInvoiced'
										Call haSqlHandles[ nStockTypeHandleNo ].Setup( sSql, sName, sBind, sInto )
										Call SqlVarSetup( haSqlHandles[ nStockTypeHandleNo ].hSqlHandle )
										!
										If sStockTypeDesc = 'Bare'
											Set sStockType = 'B'
										Else
											Set sStockType = 'C'
										!
										If haSqlHandles[ nStockTypeHandleNo ].Execute( )
											If haSqlHandles[ nStockTypeHandleNo ].FetchNext( nInd )
												Set nInvoiced = nGotInvoiced
											Return TRUE
										Else
											Return FALSE
								Case SH_cls_Disconnect
									Set bOk = TRUE
									If NOT haSqlHandles[ nAllHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT haSqlHandles[ nStockTypeHandleNo ].Disconnect( )
										Set bOk = FALSE
									Return bOk
					Function: CalcCatagoryInvoiced
						Description:
						Returns
							Boolean:
						Parameters
							Date/Time: dtFromDate
							Date/Time: dtToDate
							String: sStockTypeDesc
							Receive Number: nInvoiced
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nAllHandleNo
							Number: nStockTypeHandleNo
							Number: nInd
							Boolean: bOk
							!
							String: sStockType
							Number: nGotInvoiced
						Actions
							Set nAllHandleNo = SqlHandlesGetReferenceNo( 'CalcCatagoryInvoicedAll' )
							Set nStockTypeHandleNo = SqlHandlesGetReferenceNo( 'CalcCatagoryInvoicedStockType' )
							Select Case nActionType
								Case SH_cls_Execute
									Set nInvoiced = NUMBER_Null
									Set nGotInvoiced = NUMBER_Null
									!
									If sStockTypeDesc = 'Bare & Cont'
										Set sSql = " SELECT 
												  SUM( Customer_Order.Conf_Amt * @IF(@ISNA( Customer_Order.Invoice_Tree_Price ), Stock_Item.Base_Price, Customer_Order.Invoice_Tree_Price ) ) 
												FROM 
												  Customer_Order, 
												  Stock_Item 
												WHERE 
												  Customer_Order.Invoiced_Flag = 'Y' AND 
												  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
												  Customer_Order.Invoiced_Date BETWEEN :1 AND :2
												UNION ALL 
												SELECT 
												  SUM( Cust_Order_History.Conf_Amt * @IF(@ISNA( Cust_Order_History.Invoice_Tree_Price ), Stock_Item.Base_Price, Cust_Order_History.Invoice_Tree_Price ) ) 
												FROM 
												  Cust_Order_History, 
												  Stock_Item 
												WHERE 
												  Cust_Order_History.Invoiced_Flag = 'Y' AND 
												  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
												  Cust_Order_History.Invoiced_Date BETWEEN :1 AND :2 "
										Set sName = 'INVFIGCATINVSTP'
										Set sBind = ':dtFromDate, :dtToDate'
										Set sInto = ':nGotInvoiced'
										Call haSqlHandles[ nAllHandleNo ].Setup( sSql, sName, sBind, sInto )
										Call SqlVarSetup( haSqlHandles[ nAllHandleNo ].hSqlHandle )
										!
										If haSqlHandles[ nAllHandleNo ].Execute( )
											While haSqlHandles[ nAllHandleNo ].FetchNext( nInd )
												Set nInvoiced = nInvoiced + nGotInvoiced
											Return TRUE
										Else
											Return FALSE
									Else
										Set sSql = " SELECT 
												  SUM( Customer_Order.Conf_Amt * @IF(@ISNA( Customer_Order.Invoice_Tree_Price ), Stock_Item.Base_Price, Customer_Order.Invoice_Tree_Price ) ) 
												FROM 
												  Customer_Order, 
												  Stock_Item 
												WHERE 
												  Customer_Order.Invoiced_Flag = 'Y' AND 
												  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
												  Customer_Order.Invoiced_Date BETWEEN :1 AND :2 AND 
												  Stock_Item.Stock_Type = :3 
												UNION ALL 
												SELECT 
												  SUM( Cust_Order_History.Conf_Amt * @IF(@ISNA( Cust_Order_History.Invoice_Tree_Price ), Stock_Item.Base_Price, Cust_Order_History.Invoice_Tree_Price ) ) 
												FROM 
												  Cust_Order_History, 
												  Stock_Item 
												WHERE 
												  Cust_Order_History.Invoiced_Flag = 'Y' AND 
												  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
												  Cust_Order_History.Invoiced_Date BETWEEN :1 AND :2 AND 
												  Stock_Item.Stock_Type = :3 "
										Set sName = 'INVFIGCATSTISTP'
										Set sBind = ':dtFromDate, :dtToDate, :sStockType'
										Set sInto = ':nGotInvoiced'
										Call haSqlHandles[ nStockTypeHandleNo ].Setup( sSql, sName, sBind, sInto )
										Call SqlVarSetup( haSqlHandles[ nStockTypeHandleNo ].hSqlHandle )
										!
										If sStockTypeDesc = 'Bare'
											Set sStockType = 'B'
										Else
											Set sStockType = 'C'
										!
										If haSqlHandles[ nStockTypeHandleNo ].Execute( )
											While haSqlHandles[ nStockTypeHandleNo ].FetchNext( nInd )
												Set nInvoiced = nInvoiced + nGotInvoiced
											Return TRUE
										Else
											Return FALSE
								Case SH_cls_Disconnect
									Set bOk = TRUE
									If NOT haSqlHandles[ nAllHandleNo ].Disconnect( )
										Set bOk = FALSE
									If NOT haSqlHandles[ nStockTypeHandleNo ].Disconnect( )
										Set bOk = FALSE
									Return bOk
				Window Variables
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set bAddAllowed = TRUE
						Set bAddRowBellow = TRUE
						!
						Set bReportAllowed = TRUE
						Set sReportFileName = 'InvFig.qrp'
						Set sRepBind = ':frmInvFigures.tblInvFigures.colMonth,
								:frmInvFigures.tblInvFigures.colFromDate,
								:frmInvFigures.tblInvFigures.colToDate,
								:frmInvFigures.tblInvFigures.colInvTotalActual,
								:frmInvFigures.tblInvFigures.colStockType,
								:frmInvFigures.tblInvFigures.colInvTotalCatagory,
								:frmInvFigures.tblInvFigures.colInvTotalEstimated'
						Set sRepInto = 'sMonth,
								dtFromDate,
								dtToDate,
								nInvTotalActual,
								sStockType,
								nInvTotalCatagory, 
								nInvTotalEstimated'
					On SAM_CreateComplete
						Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
						Set colMonth = 'Jan'
						Call MonthFromAndToDates( 1, colFromDate, colToDate )
						!
						Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
						Set colMonth = 'Feb'
						Call MonthFromAndToDates( 2, colFromDate, colToDate )
						!
						Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
						Set colMonth = 'Mar'
						Call MonthFromAndToDates( 3, colFromDate, colToDate )
						!
						Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
						Set colMonth = 'Apr'
						Call MonthFromAndToDates( 4, colFromDate, colToDate )
						!
						Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
						Set colMonth = 'May'
						Call MonthFromAndToDates( 5, colFromDate, colToDate )
						!
						Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
						Set colMonth = 'Jun'
						Call MonthFromAndToDates( 6, colFromDate, colToDate )
						!
						Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
						Set colMonth = 'Jul'
						Call MonthFromAndToDates( 7, colFromDate, colToDate )
						!
						Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
						Set colMonth = 'Aug'
						Call MonthFromAndToDates( 8, colFromDate, colToDate )
						!
						Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
						Set colMonth = 'Sep'
						Call MonthFromAndToDates( 9, colFromDate, colToDate )
						!
						Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
						Set colMonth = 'Oct'
						Call MonthFromAndToDates( 10, colFromDate, colToDate )
						!
						Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
						Set colMonth = 'Nov'
						Call MonthFromAndToDates( 11, colFromDate, colToDate )
						!
						Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
						Set colMonth = 'Dec'
						Call MonthFromAndToDates( 12, colFromDate, colToDate )
						!
						Return TRUE
					On PAM_clsTBL_ADDROW
						Call SalSendClassMessage( PAM_clsTBL_ADDROW, wParam, lParam )
						Call SalTblSetRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_HideMarks, TRUE )
						Return TRUE
					On PAM_clsTBL_ROWNEWINIT
						Set colStockType = 'Bare & Cont'
						Set colFetchedActual = 'N'
						Set colFetchedEstimate = 'N'
						Set colFetchedCatagory = 'N'
						Return TRUE
					On PAM_clsTBL_ROWACTION
						If wParam = 1
							If colCalcActual = 'Y'
								If colFetchedActual = 'N'
									If CalcActualInvoiced( colFromDate, colToDate, colInvTotalActual, SH_cls_Execute )
										Set colFetchedActual = 'Y'
									Else
										Call SalClearField( colInvTotalActual )
								Set dfActualTotal = dfActualTotal + colInvTotalActual
						Else If wParam = 2
							If colCalcEstimate = 'Y'
								If colFetchedEstimate = 'N'
									If CalcEstimateInvoiced( colFromDate, colToDate, colStockType, colInvTotalEstimated, SH_cls_Execute )
										Set colFetchedEstimate = 'Y'
									Else
										Call SalClearField( colInvTotalEstimated )
								Set dfEstimatedTotal = dfEstimatedTotal + colInvTotalEstimated
						Else If wParam = 3
							If colCalcCatagory = 'Y'
								If colFetchedCatagory = 'N'
									If CalcCatagoryInvoiced( colFromDate, colToDate, colStockType, colInvTotalCatagory, SH_cls_Execute )
										Set colFetchedCatagory = 'Y'
									Else
										Call SalClearField( colInvTotalCatagory )
								Set dfCatagoryTotal = dfCatagoryTotal + colInvTotalCatagory
						Else
							Return FALSE
						Return TRUE
					On SAM_Destroy
						Call CalcActualInvoiced( colFromDate, colToDate, colInvTotalActual, SH_cls_Disconnect )
						Call CalcEstimateInvoiced( colFromDate, colToDate, colStockType, colInvTotalEstimated, SH_cls_Disconnect )
						Call CalcCatagoryInvoiced( colFromDate, colToDate, colStockType, colInvTotalCatagory, SH_cls_Disconnect )
						Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

									Set sSalesSeqVarsTreeTypeDesc = colTreeTypeDesc
									Set sSalesSeqVarsVariety = colVariety
									Set sSalesSeqVarsCultId = colCultId
									Set sSalesSeqVarsCultDesc = colCultDesc
									Set sSalesSeqVarsRootId = colRootId
									Set sSalesSeqVarsRootDesc = colRootDesc

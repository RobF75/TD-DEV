									Set nSalesSeqVarsORTotalTrees = colORTotalTrees
									Set nSalesSeqVarsFCRPTotalTrees = colFCRPTotalTrees
									Set nSalesSeqVarsOtherTotalTrees = colOtherTotalTrees
									Set nSalesSeqVarsTotalTrees = colTotalTrees

							 Enabled when: NOT sInvoiceType = 'CUSTOMERVIEWONLY'
							 Checked when: 
						 Menu Actions 
							 Set hWndParent.bUpdateFiles = TRUE
							! Call SalReportCmd( hWndParent.hWndReport, RPT_CmdPrint )
							 Call SalSendMsg( SalParentWindow( hWndForm ), PAM_PRINTINVOICE, nINV_Print, 0 )
							 If hWndParent.bInvoiceRunOk
								 Call SalMessageBox( 'Invoice successfully generated.', 'Invoice', MB_Ok )
								 Call SalPostMsg( SalParentWindow( hWndParent ), PAM_REPORTFINISHED, nInvoice, 0 )
								 Call SalSendMsg( hWndParent, PAM_END, 0, 0 )
							 Else 
								 Call SalMessageBox( 'Some errors occoured in the final update run! Please contact programmers!', 'Error', MB_Ok )

						Message Actions
				Functions
				Window Variables
					Number: nRow
					Number: nNewRow
					Boolean: bInserted
					!
					String: sNewVarietyType
					String: sNewUpperVariety
					String: sNewUpperCultDesc
					String: sNewUpperRootDesc
					String: sNewTreeTypeDesc
					String: sNewVariety
					String: sNewCultId
					String: sNewCultDesc
					String: sNewRootId
					String: sNewRootDesc
					Number: nNewItemNo
					Number: nNewGCTotalTrees
					Number: nNewORTotalTrees
					Number: nNewFCRPTotalTrees
					Number: nNewOtherTotalTrees
					Number: nNewTotalTrees
					Number: nNewGCTotalSales
					Number: nNewORTotalSales
					Number: nNewOtherTotalSales
					Number: nNewTotalSales
					Number: nNewOwnerRoyalties
					Number: nNewFNARoyalties
					Number: nNewFMNRoyalties
				Message Actions
					On PAM_SALES_INSERTINDEX
						If SalSendMsg( hWndForm, PAM_SALES_POPFIELDS, 0, 0 )
							Set bInserted = FALSE
							Set nRow = TBL_MinRow
							While SalTblFindNextRow( hWndForm, nRow, 0, 0 ) AND NOT bInserted
								Call SalTblSetContext( hWndForm, nRow )
								If colTotalSales < nNewTotalSales
									Set nNewRow = SalTblInsertRow( hWndForm, nRow )
									Call SalTblSetContext( hWndForm, nNewRow )
									!
									Set colVarietyType = ''
									Set colUpperVariety = ''
									Set colUpperCultDesc = ''
									Set colUpperRootDesc = ''
									Set colTreeTypeDesc = ''
									Set colVariety = sNewVariety
									Set colCultId = ''
									Set colCultDesc = sNewVariety
									Set colRootId = ''
									Set colRootDesc = ''
									Set colItemNo = NUMBER_Null
									Set colGCTotalTrees = nNewGCTotalTrees
									Set colORTotalTrees = nNewORTotalTrees
									Set colFCRPTotalTrees = nNewFCRPTotalTrees
									Set colOtherTotalTrees = nNewOtherTotalTrees
									Set colTotalTrees = nNewTotalTrees
									Set colGCTotalSales = nNewGCTotalSales
									Set colORTotalSales = nNewORTotalSales
									Set colOtherTotalSales = nNewOtherTotalSales
									Set colTotalSales = nNewTotalSales
									Set colOwnerRoyalties = nNewOwnerRoyalties
									Set colFNARoyalties = nNewFNARoyalties
									Set colFMNRoyalties = nNewFMNRoyalties
									!
									Set bInserted = TRUE
							If NOT bInserted
								Set nNewRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
								Call SalTblSetContext( hWndForm, nNewRow )
								!
								Set colVarietyType = ''
								Set colUpperVariety = ''
								Set colUpperCultDesc = ''
								Set colUpperRootDesc = ''
								Set colTreeTypeDesc = ''
								Set colVariety = sNewVariety
								Set colCultId = ''
								Set colCultDesc = sNewVariety
								Set colRootId = ''
								Set colRootDesc = ''
								Set colItemNo = NUMBER_Null
								Set colGCTotalTrees = nNewGCTotalTrees
								Set colORTotalTrees = nNewORTotalTrees
								Set colFCRPTotalTrees = nNewFCRPTotalTrees
								Set colOtherTotalTrees = nNewOtherTotalTrees
								Set colTotalTrees = nNewTotalTrees
								Set colGCTotalSales = nNewGCTotalSales
								Set colORTotalSales = nNewORTotalSales
								Set colOtherTotalSales = nNewOtherTotalSales
								Set colTotalSales = nNewTotalSales
								Set colOwnerRoyalties = nNewOwnerRoyalties
								Set colFNARoyalties = nNewFNARoyalties
								Set colFMNRoyalties = nNewFMNRoyalties
								!
								Set bInserted = TRUE
							Return TRUE
						Else
							Return FALSE
					On PAM_SALES_POPFIELDS
						Call PopNumber( nNewFMNRoyalties, TRUE )
						Call PopNumber( nNewFNARoyalties, TRUE )
						Call PopNumber( nNewOwnerRoyalties, TRUE )
						Call PopNumber( nNewTotalSales, TRUE )
						Call PopNumber( nNewOtherTotalSales, TRUE )
						Call PopNumber( nNewORTotalSales, TRUE )
						Call PopNumber( nNewGCTotalSales, TRUE )
						Call PopNumber( nNewTotalTrees, TRUE )
						Call PopNumber( nNewOtherTotalTrees, TRUE )
						Call PopNumber( nNewFCRPTotalTrees, TRUE )
						Call PopNumber( nNewORTotalTrees, TRUE )
						Call PopNumber( nNewGCTotalTrees, TRUE )
						Call PopNumber( nNewItemNo, TRUE )
						Call PopString( sNewRootDesc, TRUE )
						Call PopString( sNewRootId, TRUE )
						Call PopString( sNewCultDesc, TRUE )
						Call PopString( sNewCultId, TRUE )
						Call PopString( sNewVariety, TRUE )
						Call PopString( sNewTreeTypeDesc, TRUE )
						Call PopString( sNewUpperRootDesc, TRUE )
						Call PopString( sNewUpperCultDesc, TRUE )
						Call PopString( sNewUpperVariety, TRUE )
						Call PopString( sNewVarietyType, TRUE )
						Return TRUE
		Functions
		Window Parameters
			Number: nYear
			! sViewPrint = 'VIEW' OR 'PRINT'
			String: sViewPrint
			! sContainers = 'INCLUDE' OR 'EXCLUDE' OR 'ONLY'
			String: sContainers
			! sSelectedItems if '' means all else Comma separated list of item numbers
			String: sSelectedItems
			! sOrderDateType = 'ALL', 'BEFORE' OR 'AFTER'
			String: sOrderDateType
			Date/Time: dtOrderDate
		Window Variables
			String: sReportName
			String: sReportBinds
			String: sReportInputs
			Number: nError
			Window Handle: hWndReport
			!
			String: sReportHeading
			Number: nItemsRow
		Message Actions
			On SAM_CreateComplete
				Set sReportHeading = 'Best $ Sequence, Variety Summary'
			On PAM_SALES_REPORT
				Set sReportName = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\estsale2.qrp'
				Set sReportBinds = ':frmBestVarietySummaryReport.sReportHeading, 
						:frmBestVarietySummaryReport.nYear, 
						:frmBestVarietySummaryReport.sOrderDateType, 
						:frmBestVarietySummaryReport.dtOrderDate, 
						:frmBestVarietySummaryReport.tblItems.colItemNo, 
						:frmBestVarietySummaryReport.tblItems.colVarietyType, 
						:frmBestVarietySummaryReport.tblItems.colUpperVariety, 
						:frmBestVarietySummaryReport.tblItems.colTreeTypeDesc, 
						:frmBestVarietySummaryReport.tblItems.colCultDesc, 
						:frmBestVarietySummaryReport.tblItems.colRootDesc, 
						:frmBestVarietySummaryReport.tblItems.colGCTotalTrees, 
						:frmBestVarietySummaryReport.tblItems.colORTotalTrees, 
						:frmBestVarietySummaryReport.tblItems.colFCRPTotalTrees, 
						:frmBestVarietySummaryReport.tblItems.colOtherTotalTrees, 
						:frmBestVarietySummaryReport.tblItems.colTotalTrees, 
						:frmBestVarietySummaryReport.tblItems.colGCTotalSales, 
						:frmBestVarietySummaryReport.tblItems.colORTotalSales,
						:frmBestVarietySummaryReport.tblItems.colOtherTotalSales,  
						:frmBestVarietySummaryReport.tblItems.colTotalSales, 
						:frmBestVarietySummaryReport.tblItems.colOwnerRoyalties, 
						:frmBestVarietySummaryReport.tblItems.colFNARoyalties, 
						:frmBestVarietySummaryReport.tblItems.colFMNRoyalties'
				Set sReportInputs = 'ReportHeading, 
						YearOfSale, 
						OrderDateType, 
						OrderDate, 
						ItemNo, 
						VarietyType, 
						Variety, 
						TreeTypeDesc, 
						CultDesc, 
						RootDesc, 
						GCTrees, 
						ORTrees, 
						FCRPTrees, 
						OtherTrees, 
						TotalTrees, 
						GCSales, 
						ORSales, 
						OtherSales, 
						TotalSales, 
						OwnerRoyalties, 
						FNARoyalties, 
						FMNRoyalties'
				Set nError = 1
				If sViewPrint = 'PRINT'
					Set hWndReport = SalReportPrint( hWndForm, sReportName, sReportBinds, sReportInputs, 1, RPT_PrintAll | RPT_PrintNoWarn, 0, 0, nError )
				Else
					Set hWndReport = SalReportView( hWndForm, hWndForm, sReportName, sReportBinds, sReportInputs, nError )
					If hWndReport = hWndNULL
						Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
			On PAM_SALES_INSERTINDEX
				Return SalSendMsg( tblItems, PAM_SALES_INSERTINDEX, wParam, lParam )
			On SAM_ReportStart
				Return TRUE
			On SAM_ReportFetchInit
				Set nItemsRow = TBL_MinRow
				Return TRUE
			On SAM_ReportFetchNext
				If SalTblFindNextRow( tblItems, nItemsRow, 0, 0 )
					Call SalTblFetchRow( tblItems, nItemsRow )
					Return TRUE
				Else
					Return FALSE
			On SAM_ReportFinish
				Call SalDestroyWindow( hWndForm )
				Return TRUE

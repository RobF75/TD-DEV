						List Values
						Message Actions
				Functions
				Window Variables
					String: sSql
					: hPopSalesHdl
						Class: hcSqlHandle
					Boolean: bOk
					Number: nTmp
					String: sTmp
					: hWndMeter
						Class: clsMeterBar
					Number: nTotalItems
				Message Actions
					On SAM_Create
						Call hPopSalesHdl.Connect( )
					On PAM_SALES_POPULATE
						Set bOk = FALSE
						Set sSql = "SELECT 
								  Promo.Promo_Desc,
								  SUM(@IF(@SCAN(Customer_Type,'GC')+1,No_Units,0)),
								  SUM(@IF(@SCAN(Customer_Type,'OR')+1,No_Units,0)), 
								  SUM(No_Units),
								  SUM(@IF(@SCAN(Customer_Type,'GC')+1,Override_Price*No_Units,0)), 
								  SUM(@IF(@SCAN(Customer_Type,'OR')+1,Override_Price*No_Units,0)), 
								  SUM(Override_Price*No_Units)
								FROM 
								  Promo, 
								  Cust_Promo, 
								  Customer_Master 
								INTO 
								  :frmEstSalesPOSReport.tblItems.colCultDesc, 
								  :frmEstSalesPOSReport.tblItems.colGCTotalTrees, 
								  :frmEstSalesPOSReport.tblItems.colORTotalTrees, 
								  :frmEstSalesPOSReport.tblItems.colTotalTrees, 
								  :frmEstSalesPOSReport.tblItems.colGCTotalSales, 
								  :frmEstSalesPOSReport.tblItems.colORTotalSales, 
								  :frmEstSalesPOSReport.tblItems.colTotalSales
								WHERE 
								  Promo.Promo_Id = Cust_Promo.Promo_Id AND 
								  Cust_Promo.Year_Of_Order = :frmEstSalesPOSReport.nYear AND 
								  Cust_Promo.Cust_No = Customer_Master.Cust_No "
						!
						If frmEstSalesPOSReport.sOrderDateType = 'BEFORE'
							Set sSql = sSql || " AND Cust_Promo.Promo_DT_Stamp <= :frmEstSalesPOSReport.dtOrderDate GROUP BY 1 "
						Else If frmEstSalesPOSReport.sOrderDateType = 'AFTER'
							Set sSql = sSql || " AND Cust_Promo.Promo_DT_Stamp > :frmEstSalesPOSReport.dtOrderDate  GROUP BY 1 "
						Else
							Set sSql = sSql || " GROUP BY 1 "
						!
						If hPopSalesHdl.PrepareSetup( sSql )
							If hPopSalesHdl.PrepareAndExecute( )
								Call hPopSalesHdl.ResultSetCount( nTotalItems )
								Call hWndMeter.Setup( 'Populating POS Reports', nTotalItems )
								Set bOk = hPopSalesHdl.TablePopulate( hWndForm, TBL_FillAll )
								Call hWndMeter.End( )
						Return bOk
					On SAM_FetchRowDone
						Set colOtherTotalTrees = colTotalTrees - colGCTotalTrees - colORTotalTrees
						Set colOtherTotalSales = colTotalSales - colGCTotalSales - colORTotalSales
						If hWndSalesSeqPOS != hWndNULL
							If SalSendMsg( hWndForm, PAM_SALES_PUSHFIELDS, 0, 0 )
								If NOT SalSendMsg( hWndSalesSeqPOS, PAM_SALES_INSERTINDEX, 0, lParam )
									Call SalSendMsg( hWndForm, PAM_SALES_POPFIELDS, 0, 0 )
						Call hWndMeter.Increment( 1 )
					On PAM_SALES_PUSHFIELDS
						Call PushString( colCultDesc )
						Call PushNumber( colGCTotalTrees )
						Call PushNumber( colORTotalTrees )
						Call PushNumber( colOtherTotalTrees )
						Call PushNumber( colTotalTrees )
						Call PushNumber( colGCTotalSales )
						Call PushNumber( colORTotalSales )
						Call PushNumber( colOtherTotalSales )
						Call PushNumber( colTotalSales )
						Return TRUE
					On PAM_SALES_POPFIELDS
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Return TRUE
					On SAM_Destroy
						Call hPopSalesHdl.Disconnect( )
		Functions
		Window Parameters
			Number: nYear
			! sViewPrint = 'VIEW' OR 'PRINT'
			String: sViewPrint
			Window Handle: hWndSalesSeqPOS
			! sOrderDateType = 'ALL', 'BEFORE' OR 'AFTER'
			String: sOrderDateType
			Date/Time: dtOrderDate
		Window Variables
			String: sReportName
			String: sReportBinds
			String: sReportInputs
			Number: nError
			Window Handle: hWndReport
			!
			String: sReportHeading
			Number: nItemsRow
		Message Actions
			On SAM_CreateComplete
				Set sReportHeading = 'Estimated Sales P.O.S'
			On PAM_SALES_POPULATE
				Call OurWaitCursor( TRUE )
				Call SalSendMsg( tblItems, PAM_SALES_POPULATE, 0, 0 )
				Call OurWaitCursor( FALSE )
			On PAM_SALES_REPORT
				Set sReportName = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\estsale2.qrp'
				Set sReportBinds = ':frmEstSalesPOSReport.sReportHeading, 
						:frmEstSalesPOSReport.nYear, 
						:frmEstSalesPOSReport.sOrderDateType, 
						:frmEstSalesPOSReport.dtOrderDate, 
						:frmEstSalesPOSReport.tblItems.colItemNo, 
						:frmEstSalesPOSReport.tblItems.colVarietyType, 
						:frmEstSalesPOSReport.tblItems.colUpperVariety, 
						:frmEstSalesPOSReport.tblItems.colTreeTypeDesc, 
						:frmEstSalesPOSReport.tblItems.colCultDesc, 
						:frmEstSalesPOSReport.tblItems.colRootDesc, 
						:frmEstSalesPOSReport.tblItems.colGCTotalTrees, 
						:frmEstSalesPOSReport.tblItems.colORTotalTrees, 
						:frmEstSalesPOSReport.tblItems.colOtherTotalTrees, 
						:frmEstSalesPOSReport.tblItems.colTotalTrees, 
						:frmEstSalesPOSReport.tblItems.colGCTotalSales, 
						:frmEstSalesPOSReport.tblItems.colORTotalSales,
						:frmEstSalesPOSReport.tblItems.colOtherTotalSales,  
						:frmEstSalesPOSReport.tblItems.colTotalSales, 
						:frmEstSalesPOSReport.tblItems.colOwnerRoyalties, 
						:frmEstSalesPOSReport.tblItems.colFNARoyalties, 
						:frmEstSalesPOSReport.tblItems.colFMNRoyalties'
				Set sReportInputs = 'ReportHeading, 
						YearOfSale, 
						OrderDateType, 
						OrderDate, 
						ItemNo, 
						VarietyType, 
						Variety, 
						TreeTypeDesc, 
						CultDesc, 
						RootDesc, 
						GCTrees, 
						ORTrees, 
						OtherTrees, 
						TotalTrees, 
						GCSales, 
						ORSales, 
						OtherSales, 
						TotalSales, 
						OwnerRoyalties, 
						FNARoyalties, 
						FMNRoyalties'
				Set nError = 1
				If sViewPrint = 'PRINT'
					Set hWndReport = SalReportPrint( hWndForm, sReportName, sReportBinds, sReportInputs, 1, RPT_PrintAll | RPT_PrintNoWarn, 0, 0, nError )
				Else
					Set hWndReport = SalReportView( hWndForm, hWndForm, sReportName, sReportBinds, sReportInputs, nError )
					If hWndReport = hWndNULL
						Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
			On SAM_ReportStart
				Return TRUE
			On SAM_ReportFetchInit
				Set nItemsRow = TBL_MinRow
				Return TRUE
			On SAM_ReportFetchNext
				If SalTblFindNextRow( tblItems, nItemsRow, 0, 0 )
					Call SalTblFetchRow( tblItems, nItemsRow )
					Return TRUE
				Else
					Return FALSE
			On SAM_ReportFinish
				Call SalDestroyWindow( hWndForm )
				Return TRUE
	Form Window: frmItemsSalesSeqReport
		Class:
		Property Template:
		Class DLL Name:
		Title: Items Sales Seq.
		Icon File:

					Function: GetCultivarSalesRoyalties
						Description:
						Returns
							Boolean:
						Parameters
							String: sCultivarId
							Receive Number: nOtherAmtPayable
							Receive Number: nFMNAmtPayable
							Receive Number: nFNAAmtPayable
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							String: sName
							String: sBind
							String: sInto
							Number: nOurHandleNo
							!
							Number: nInd
							!
							String: sGotRoyOwner
							Number: nGotAmtPayable
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetCultivarSalesRoyalties' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT Royalty_Owner_Id, Amount_Payable 
											FROM Royalty_Payable 
											WHERE Cultivar_Id = :1 "
									Set sName = 'TRSLSCROYPY'
									Set sBind = ':sCultivarId'
									Set sInto = ':sGotRoyOwner, :nGotAmtPayable'
									!
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set nOtherAmtPayable = NUMBER_Null
									Set nFMNAmtPayable = NUMBER_Null
									Set nFNAAmtPayable = NUMBER_Null
									!
									Set sGotRoyOwner = ''
									Set nGotAmtPayable = NUMBER_Null
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
											If sGotRoyOwner = 'FMN'
												Set nFMNAmtPayable = nFMNAmtPayable + nGotAmtPayable
											Else If sGotRoyOwner = 'FNA'
												Set nFNAAmtPayable = nFNAAmtPayable + nGotAmtPayable
											Else
												Set nOtherAmtPayable = nOtherAmtPayable + nGotAmtPayable
										Return TRUE
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )

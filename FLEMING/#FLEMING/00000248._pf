						Set nTmp = ccSeasonYear.GetSeasonYear( )
						Call AdjustYearOfSaleToYear( nTmp )
						Set dfEstSalesOrdDate = SalDateConstruct( nTmp, SalDateMonth( dfEstSalesOrdDate ), SalDateDay( dfEstSalesOrdDate ), 23, 59, 59 )
						Return TRUE
		Functions
		Window Parameters
		Window Variables
			Number: nYear
			String: sViewPrint
			String: sContainers
			String: sOrderDateType
			String: sSelectedItems
			String: sTreeTypes[*]
			Window Handle: hWndEstSalesItems
			Window Handle: hWndEstSalesVarietySummary
			Window Handle: hWndEstSalesPOS
			Window Handle: hWndSalesSeqItems
			Window Handle: hWndEstSaleVarieties
			Window Handle: hWndEstSaleBestVarietySummary
			Window Handle: hWndSalesSeqPOS
			Window Handle: hWndSizeSalesItems
		Message Actions
			On SAM_CreateComplete
				Set rbExcludeContainers = TRUE
				Set cbEstSalesItems = TRUE
				Set cbEstSalesPOS = FALSE
				!
				Set rbEstSalesAllOrdDates = TRUE
				Set dfEstSalesOrdDate = SalDateConstruct( SalDateYear( SalDateCurrent(  ) ), SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 23, 59, 59 )
				!
				Set cbSalesSequenceItems = TRUE
				Set cbSalesSequencePOS = FALSE
				Set cbEstSaleVarieties = TRUE
				Set cbSizeSalesItems = TRUE
				Set cbEstSalesBestVarietySummary = TRUE
				Set cbEstSalesVarietySummary = TRUE
				Set rbPrint = FALSE
				Set hWndEstSalesItems = hWndNULL
				Set hWndEstSalesVarietySummary = hWndNULL
				Set hWndEstSalesPOS = hWndNULL
				Set hWndSalesSeqItems = hWndNULL
				Set hWndEstSaleVarieties = hWndNULL
				Set hWndEstSaleBestVarietySummary = hWndNULL
				Set hWndSalesSeqPOS = hWndNULL
				Set hWndSizeSalesItems = hWndNULL
				!
				Call SalSendMsg( tblSelectedTreeTypes, PAM_clsTBL_POPULATE, 0, 0 )
				Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
			On PAM_cls_SETINSTANCEVARS
				Set bPrintFormAllowed = FALSE
			On PAM_SALES_REPORT
				Call OurWaitCursor( TRUE )
				!
				If NOT hWndEstSalesItems = hWndNULL
					If SalDestroyWindow( hWndEstSalesItems )
						Set hWndEstSalesItems = hWndNULL
				If NOT hWndEstSalesVarietySummary = hWndNULL
					If SalDestroyWindow( hWndEstSalesVarietySummary )
						Set hWndEstSalesVarietySummary = hWndNULL
				If NOT hWndEstSalesPOS = hWndNULL
					If SalDestroyWindow( hWndEstSalesPOS )
						Set hWndEstSalesPOS = hWndNULL
				If NOT hWndSalesSeqItems = hWndNULL
					If SalDestroyWindow( hWndSalesSeqItems )
						Set hWndSalesSeqItems = hWndNULL
				If NOT hWndEstSaleVarieties = hWndNULL
					If SalDestroyWindow( hWndEstSaleVarieties )
						Set hWndEstSaleVarieties = hWndNULL
				If NOT hWndEstSaleBestVarietySummary = hWndNULL
					If SalDestroyWindow( hWndEstSaleBestVarietySummary )
						Set hWndEstSaleBestVarietySummary = hWndNULL
				If NOT hWndSalesSeqPOS = hWndNULL
					If SalDestroyWindow( hWndSalesSeqPOS )
						Set hWndSalesSeqPOS = hWndNULL
				If NOT hWndSizeSalesItems = hWndNULL
					If SalDestroyWindow( hWndSizeSalesItems )
						Set hWndSizeSalesItems= hWndNULL
				!
				If rbEstSalesBeforeOrdDate
					Set sOrderDateType = 'BEFORE'
				Else If rbEstSalesAfterOrdDate
					Set sOrderDateType = 'AFTER'
				Else
					Set sOrderDateType = 'ALL'
				!
				! Set nYear = SalStrToNumber( cYear.GetNumber( ) )
				Set nYear = ccSeasonYear.GetSeasonYear( )
				If rbView
					Set sViewPrint = 'VIEW'
				Else
					Set sViewPrint = 'PRINT'
				!
				If rbIncludeContainers
					Set sContainers = 'INCLUDE'
				Else If rbExcludeContainers
					Set sContainers = 'EXCLUDE'
				Else
					Set sContainers = 'ONLY'
				!
				If SalSendMsg( tblSelectedItems, PAM_SALES_GETSELECTEDITEMS, 0, 0 )
					Call PopString( sSelectedItems, TRUE )
					If sSelectedItems = 'YEARMISMATCH'
						Call OurWaitCursor( FALSE )
						Return FALSE
				Else
					Set sSelectedItems = ''
				!
				! Create Reports windows
				If cbSizeSalesItems
					Set hWndSizeSalesItems = SalCreateWindow( frmItemsSizeSalesReport, hWndForm, nYear, sViewPrint, sContainers, sSelectedItems, sTreeTypes, sOrderDateType, dfEstSalesOrdDate )
					If hWndSizeSalesItems = hWndNULL
						Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
				If cbEstSalesBestVarietySummary
					Set hWndEstSaleBestVarietySummary = SalCreateWindow( frmBestVarietySummaryReport, hWndForm, nYear, sViewPrint, sContainers, sSelectedItems, sOrderDateType, dfEstSalesOrdDate )
					If hWndEstSaleBestVarietySummary = hWndNULL
						Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
				If cbSalesSequencePOS
					Set hWndSalesSeqPOS = SalCreateWindow( frmSalesSeqPOSReport, hWndForm, nYear, sViewPrint, sOrderDateType, dfEstSalesOrdDate )
					If hWndSalesSeqPOS = hWndNULL
						Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
				If cbEstSaleVarieties
					Set hWndEstSaleVarieties = SalCreateWindow( frmVarietiesSalesSeqReport, hWndForm, nYear, sViewPrint, sContainers, sSelectedItems, sOrderDateType, dfEstSalesOrdDate )
					If hWndEstSaleVarieties = hWndNULL
						Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
				If cbEstSalesVarietySummary
					Set hWndEstSalesVarietySummary = SalCreateWindow( frmVarietySummaryReport, hWndForm, nYear, sViewPrint, sContainers, sSelectedItems, sOrderDateType, dfEstSalesOrdDate )
					If hWndEstSalesVarietySummary = hWndNULL
						Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
				If cbSalesSequenceItems
					Set hWndSalesSeqItems = SalCreateWindow( frmItemsSalesSeqReport, hWndForm, nYear, sViewPrint, sContainers, sSelectedItems, sOrderDateType, dfEstSalesOrdDate )
					If hWndSalesSeqItems = hWndNULL
						Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
				If cbEstSalesPOS
					Set hWndEstSalesPOS = SalCreateWindow( frmEstSalesPOSReport, hWndForm, nYear, sViewPrint, hWndSalesSeqPOS, sOrderDateType, dfEstSalesOrdDate )
					If hWndEstSalesPOS = hWndNULL
						Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
				If cbEstSalesItems
					If SalSendMsg( tblSelectedTreeTypes, PAM_SALES_GETSELECTEDITEMS, 0, 0 )
						Set hWndEstSalesItems = SalCreateWindow( frmEstSalesItemsReport, hWndForm, hWndSalesSeqItems, hWndEstSalesVarietySummary, hWndEstSaleVarieties, hWndEstSaleBestVarietySummary, hWndSizeSalesItems, nYear, sViewPrint, sContainers, 
								sSelectedItems, sOrderDateType, dfEstSalesOrdDate )
						If hWndEstSalesItems = hWndNULL 
							Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
				!
				! Populate Reports
				If cbEstSalesItems
					Call SalSendMsg( hWndEstSalesItems, PAM_SALES_POPULATE, 0, 0 )
				If cbEstSalesVarietySummary
					Call SalSendMsg( hWndEstSalesVarietySummary, PAM_SALES_POPULATE, 0, 0 )
				If cbEstSalesPOS
					Call SalSendMsg( hWndEstSalesPOS, PAM_SALES_POPULATE, 0, 0 )
				If cbSalesSequenceItems
					Call SalSendMsg( hWndSalesSeqItems, PAM_SALES_POPULATE, 0, 0 )
				If cbEstSaleVarieties
					Call SalSendMsg( hWndEstSaleVarieties, PAM_SALES_POPULATE, 0, 0 )
				If cbEstSalesBestVarietySummary
					Call SalSendMsg( hWndEstSaleBestVarietySummary, PAM_SALES_POPULATE, 0, 0 )
				If cbSalesSequencePOS
					Call SalSendMsg( hWndSalesSeqPOS, PAM_SALES_POPULATE, 0, 0 )
				If cbSizeSalesItems
					Call SalSendMsg( hWndSizeSalesItems, PAM_SALES_POPULATE, 0, 0 )
				!
				Call OurWaitCursor( FALSE )
				! Start Reports Print or View
				If cbEstSalesItems
					Call SalSendMsg( hWndEstSalesItems, PAM_SALES_REPORT, 0, 0 )
				If cbEstSalesVarietySummary
					Call SalSendMsg( hWndEstSalesVarietySummary, PAM_SALES_REPORT, 0, 0 )
				If cbEstSalesPOS
					Call SalSendMsg( hWndEstSalesPOS, PAM_SALES_REPORT, 0, 0 )
				If cbSalesSequenceItems
					Call SalSendMsg( hWndSalesSeqItems, PAM_SALES_REPORT, 0, 0 )
				If cbEstSaleVarieties
					Call SalSendMsg( hWndEstSaleVarieties, PAM_SALES_REPORT, 0, 0 )
				If cbEstSalesBestVarietySummary
					Call SalSendMsg( hWndEstSaleBestVarietySummary, PAM_SALES_REPORT, 0, 0 )
				If cbSalesSequencePOS
					Call SalSendMsg( hWndSalesSeqPOS, PAM_SALES_REPORT, 0, 0 )
				If cbSizeSalesItems
					Call SalSendMsg( hWndSizeSalesItems, PAM_SALES_REPORT, 0, 0 )

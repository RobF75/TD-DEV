			Child Table: tblSelectedTreeTypes
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: clsTableGeneral
				Property Template:
				Class DLL Name:
				Display Settings
					Window Location and Size
						Left:   0.4"
						Top:    3.5"
						Width:  3.9"
						Width Editable? Class Default
						Height: 1.063"
						Height Editable? Class Default
					Visible? Class Default
					Font Name: Arial
					Font Size: 8
					Font Enhancement: Class Default
					Text Color: Class Default
					Background Color: Class Default
					View: Class Default
					Allow Row Sizing? Class Default
					Lines Per Row: Class Default
				Memory Settings
					Maximum Rows in Memory: 6000
					Discardable? No
				Contents
					Column: colTreeType
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class: clsColumnGeneral
						Property Template:
						Class DLL Name:
						Title: Type
						Visible? No
						Editable? No
						Maximum Data Length: Class Default
						Data Type: Class Default
						Justify: Class Default
						Width:  1.017"
						Width Editable? Class Default
						Format: Class Default
						Country: Class Default
						Input Mask: Class Default
						Cell Options
							Cell Type? Class Default
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? Class Default
								Vertical Scroll? Class Default
								Auto Drop Down? Class Default
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
					Column: colTreeTypeDesc
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class: clsColumnGeneral
						Property Template:
						Class DLL Name:
						Title: Tree Type Description
						Visible? Class Default
						Editable? No
						Maximum Data Length: Class Default
						Data Type: Class Default
						Justify: Class Default
						Width:  4.467"
						Width Editable? Class Default
						Format: Class Default
						Country: Class Default
						Input Mask: Class Default
						Cell Options
							Cell Type? Class Default
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? Class Default
								Vertical Scroll? Class Default
								Auto Drop Down? Class Default
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
				Functions
				Window Variables
					Number: nTmp
					String: sTmp
					Number: nMaxTreeTypesInSizeReport
					Number: nSearchRow
					Boolean: bFound
					Boolean: bInsert
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set sSQLPopHandle = "SELECT Tree_Type, Tree_Type_Desc 
								FROM Tree_Type 
								WHERE Tree_Type IN ( 'MR1', 'MR2', 'RD1', 'RD2', 'MS1', 'MS2', 'MG1', 'MG2', 'REG', 
								'ADV', 'SHT', 'TALL', 'XLBR', 'STSM', 'SML' ) 
								ORDER BY Tree_Type_Desc "
						Set sNAMEPopHandle = 'SPOPDEFTTYPE'
						Set sBINDPopHandle = ''
						Set sINTOPopHandle = ':frmSalesReports.tblSelectedTreeTypes.colTreeType, :frmSalesReports.tblSelectedTreeTypes.colTreeTypeDesc '
						!
						Set bAddAllowed = TRUE
						Set bSelectFirstRow = FALSE
						!
						Set nMaxTreeTypesInSizeReport = 15
					On PAM_SALES_MATCHTREETYPES
						Call SalSendMsg( hWndForm, PAM_clsTBL_RESET, 0, 0 )
						If TableLoop( tblSelectedItems, hWndForm, PAM_SALES_MATCHITEM, 0, 0, 0, 'Matching Selected Items Tree Types', TBL_cls_LowToHi )
							Return TRUE
						Else
							Return FALSE
					On PAM_SALES_MATCHITEM
						Set bFound = FALSE
						Set nSearchRow = TBL_MinRow
						While SalTblFindNextRow( hWndForm, nSearchRow, 0, 0 ) AND NOT bFound
							Call SalTblSetContext( hWndForm, nSearchRow )
							If colTreeType = tblSelectedItems.colTreeType
								Set bFound = TRUE
						If NOT bFound
							Set bInsert = TRUE
							If rbOnlyContainers
								If SalStrScan( tblSelectedItems.colTreeType, 'C%' ) < 0
									Set bInsert = FALSE
							Else If rbExcludeContainers
								If SalStrScan( tblSelectedItems.colTreeType, 'C%' ) >= 0
									Set bInsert = FALSE
							!
							If bInsert
								Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
								Set nTmp = SalTblQueryContext( hWndForm )
								Set colTreeType = tblSelectedItems.colTreeType
								Set colTreeTypeDesc = tblSelectedItems.colTreeTypeDesc
								Call SalTblSetRowFlags( hWndForm, nTmp, ROW_HideMarks, TRUE )
						Return TRUE
					On SAM_FetchRowDone
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_New, TRUE )
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_HideMarks, TRUE )
						Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
					On PAM_SALES_GETSELECTEDITEMS
						Set nTmp = 0
						Set sTreeTypes[ nTmp ] = ''
						Set nTmp = nTmp + 1
						Set sTreeTypes[ nTmp ] = ''
						If TableLoop( hWndForm, hWndForm, PAM_SALES_GETSELECTED, 0, 0, 0, 'Extracting Tree Types', TBL_cls_LowToHi )
							If nTmp-1 > nMaxTreeTypesInSizeReport
								If IDYES = SalMessageBox( 'Only the first ' || SalNumberToStrX( nMaxTreeTypesInSizeReport, 0 ) || 
										' Tree Types can appear on the size report any others will be ignored! Continue with this report?', 'Warning', MB_YesNo )
									Return TRUE
								Else
									Return FALSE
							Else
								Return TRUE
						Else
							Return FALSE
					On PAM_SALES_GETSELECTED
						Set sTreeTypes[ nTmp ] = tblSelectedTreeTypes.colTreeType
						Set nTmp = nTmp + 1
						Set sTreeTypes[ nTmp ] = ''
						Return TRUE
			!

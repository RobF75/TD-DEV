					! Function: GetTreeSalesTotals
						 Description: 
						 Returns 
							 Boolean: 
						 Parameters 
							 Number: nItemNo
							 Number: nYear
							 Receive Number: nGCTotalTrees
							 Receive Number: nORTotalTrees
							 Receive Number: nFCRPTotalTrees
							 Receive Number: nTotalTrees
							 Receive Number: nGCTotalSales
							 Receive Number: nORTotalSales
							 Receive Number: nTotalSales
							 Number: nActionType
						 Static Variables 
							 : fcOurHandle
.winattr class
								Class: hcSqlHandle
.end
						 Local variables 
							 String: sSql
							 String: sName
							 String: sBind
							 String: sInto
							!
							 Number: nInd
							!
							 Number: nGotGCTotalTrees
							 Number: nGotORTotalTrees
							 Number: nGotFCRPTotalTrees
							 Number: nGotTotalTrees
							 Number: nGotGCTotalSales
							 Number: nGotORTotalSales
							 Number: nGotTotalSales
						 Actions 
							 Select Case nActionType
								 Case SH_cls_Execute
									 Set sSql = "SELECT 
											  SUM(@IF(@ISNA(Conf_Amt), 
											        @IF(@SCAN(Customer_Type,'GC')+1,
											            @IF(@EXACT(Sale_Cat,'FC'), 0, 
											            @IF(@EXACT(Sale_Cat,'RP'), 0, Ordered_Amount)),0), 
											        @IF(@SCAN(Customer_Type,'GC')+1,
											            @IF(@EXACT(Sale_Cat,'FC'), 0, 
											            @IF(@EXACT(Sale_Cat,'RP'), 0, Conf_Amt)),0))), 
											  SUM(@IF(@ISNA(Conf_Amt), 
											        @IF(@SCAN(Customer_Type,'OR')+1,
											            @IF(@EXACT(Sale_Cat,'FC'),0,
											            @IF(@EXACT(Sale_Cat,'RP'),0,Ordered_Amount)),0), 
											        @IF(@SCAN(Customer_Type,'OR')+1,
											            @IF(@EXACT(Sale_Cat,'FC'),0,
											            @IF(@EXACT(Sale_Cat,'RP'),0,Conf_Amt)),0))),  
											  SUM(@IF(@ISNA(Conf_Amt), 
											          @IF(@EXACT(Sale_Cat,'FC'),Ordered_Amount, 
											          @IF(@EXACT(Sale_Cat,'RP'),Ordered_Amount,0)), 
											      @IF(@EXACT(Sale_Cat,'FC'),Conf_Amt,
											      @IF(@EXACT(Sale_Cat,'RP'),Conf_Amt,0)))), 
											  SUM(@IF(@ISNA(Conf_Amt), Ordered_Amount, Conf_Amt)), 
											
											  SUM(@IF(@SCAN(Customer_Type,'GC')+1,
											      @IF(@ISNA(Contract_Price) , 
											        @IF(@EXACT(Sale_Cat,'FC'),0,
											          @IF(@EXACT(Sale_Cat,'RP'),0, 
											            @IF(@EXACT(Sale_Cat,'HP'), 
											              @IF(@ISNA(Conf_Amt),(Base_Price/2)*Ordered_Amount,(Base_Price/2) * Conf_Amt),
											              @IF(@ISNA(Conf_Amt),Base_Price*Ordered_Amount,Base_Price * Conf_Amt ) ) ) ), 
											        Contract_Price*Conf_Amt ),0 )), 
											  SUM(@IF(@SCAN(Customer_Type,'OR')+1,
											      @IF(@ISNA(Contract_Price) , 
											        @IF(@EXACT(Sale_Cat,'FC'),0,
											          @IF(@EXACT(Sale_Cat,'RP'),0, 
											            @IF(@EXACT(Sale_Cat,'HP'), 
											              @IF(@ISNA(Conf_Amt),(Base_Price/2)*Ordered_Amount,(Base_Price/2) * Conf_Amt),
											              @IF(@ISNA(Conf_Amt),Base_Price*Ordered_Amount,Base_Price * Conf_Amt ) ) ) ), 
											        Contract_Price*Conf_Amt ),0 )), 
											
											  SUM(@IF(@ISNA(Contract_Price) , 
											        @IF(@EXACT(Sale_Cat,'FC'),0,
											          @IF(@EXACT(Sale_Cat,'RP'),0, 
											            @IF(@EXACT(Sale_Cat,'HP'), 
											              @IF(@ISNA(Conf_Amt),(Base_Price/2)*Ordered_Amount,(Base_Price/2) * Conf_Amt),
											              @IF(@ISNA(Conf_Amt),Base_Price*Ordered_Amount,Base_Price * Conf_Amt ) ) ) ), 
											        Contract_Price*Conf_Amt ) ) 
											 FROM 
											  Stock_Item,
											  Customer_Order, 
											  Customer_Master 
											WHERE Stock_Item.Item_No = :1 AND 
											  Stock_Item.Item_No = Stock_Item_No AND 
											  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
											  Year_Of_Sale = :2 "
									!
									 Set sName = 'TRSALES'
									 Set sBind = ':nItemNo, :nYear'
									 Set sInto = ':nGotGCTotalTrees, :nGotORTotalTrees, :nGotFCRPTotalTrees, :nGotTotalTrees, :nGotGCTotalSales, :nGotORTotalSales, :nGotTotalSales'
									!
									 Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
									 Call SqlVarSetup( fcOurHandle.hSqlHandle )
									!
									 Set nGCTotalTrees = NUMBER_Null
									 Set nORTotalTrees = NUMBER_Null
									 Set nFCRPTotalTrees = NUMBER_Null
									 Set nTotalTrees = NUMBER_Null
									 Set nGCTotalSales = NUMBER_Null
									 Set nORTotalSales = NUMBER_Null
									 Set nTotalSales = NUMBER_Null
									!
									 Set nGotGCTotalTrees = NUMBER_Null
									 Set nGotORTotalTrees = NUMBER_Null
									 Set nGotFCRPTotalTrees = NUMBER_Null
									 Set nGotTotalTrees = NUMBER_Null
									 Set nGotGCTotalSales = NUMBER_Null
									 Set nGotORTotalSales = NUMBER_Null
									 Set nGotTotalSales = NUMBER_Null
									!
									 If fcOurHandle.Execute( )
										 Call fcOurHandle.FetchNext( nInd )
										 Set nGCTotalTrees = nGotGCTotalTrees
										 Set nORTotalTrees = nGotORTotalTrees
										 Set nFCRPTotalTrees = nGotFCRPTotalTrees
										 Set nTotalTrees = nGotTotalTrees
										 Set nGCTotalSales = nGotGCTotalSales
										 Set nORTotalSales = nGotORTotalSales
										 Set nTotalSales = nGotTotalSales
										 Return TRUE
									 Else 
										 Return FALSE
								 Case SH_cls_Disconnect
									 Return fcOurHandle.Disconnect( )
					Function: GetTreeSalesTotalsHist
						Description:
						Returns
							Boolean:
						Parameters
							Number: nItemNo
							Number: nYear
							String: sOrderDateType
							Date/Time: dtOrderDate
							Receive Number: nGCTotalTrees
							Receive Number: nORTotalTrees
							Receive Number: nFCRPTotalTrees
							Receive Number: nTotalTrees
							Receive Number: nGCTotalSales
							Receive Number: nORTotalSales
							Receive Number: nTotalSales
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							Number: nOurHandleNo
							Number: nInd
							!
							Number: nGotGCTotalTrees
							Number: nGotORTotalTrees
							Number: nGotFCRPTotalTrees
							Number: nGotTotalTrees
							Number: nGotGCTotalSales
							Number: nGotORTotalSales
							Number: nGotTotalSales
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetTreeSalesTotalsHist' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = "SELECT 
											  SUM(@IF(@ISNA(Conf_Amt), 
											        @IF(@SCAN(Customer_Type,'GC')+1,
											            @IF(@EXACT(Sale_Cat,'FC'), 0, 
											            @IF(@EXACT(Sale_Cat,'RP'), 0, Ordered_Amount)),0), 
											        @IF(@SCAN(Customer_Type,'GC')+1,
											            @IF(@EXACT(Sale_Cat,'FC'), 0, 
											            @IF(@EXACT(Sale_Cat,'RP'), 0, Conf_Amt)),0))), 
											  SUM(@IF(@ISNA(Conf_Amt), 
											        @IF(@SCAN(Customer_Type,'OR')+1,
											            @IF(@EXACT(Sale_Cat,'FC'),0,
											            @IF(@EXACT(Sale_Cat,'RP'),0,Ordered_Amount)),0), 
											        @IF(@SCAN(Customer_Type,'OR')+1,
											            @IF(@EXACT(Sale_Cat,'FC'),0,
											            @IF(@EXACT(Sale_Cat,'RP'),0,Conf_Amt)),0))),  
											  SUM(@IF(@ISNA(Conf_Amt), 
											          @IF(@EXACT(Sale_Cat,'FC'),Ordered_Amount, 
											          @IF(@EXACT(Sale_Cat,'RP'),Ordered_Amount,0)), 
											      @IF(@EXACT(Sale_Cat,'FC'),Conf_Amt,
											      @IF(@EXACT(Sale_Cat,'RP'),Conf_Amt,0)))), 
											  SUM(@IF(@ISNA(Conf_Amt), Ordered_Amount, Conf_Amt)), 
											
											  SUM(@IF(@SCAN(Customer_Type,'GC')+1,
											      @IF(@ISNA(Contract_Price) , 
											        @IF(@EXACT(Sale_Cat,'FC'),0,
											          @IF(@EXACT(Sale_Cat,'RP'),0, 
											            @IF(@EXACT(Sale_Cat,'HP'), 
											              @IF(@ISNA(Conf_Amt),(Base_Price/2)*Ordered_Amount,(Base_Price/2) * Conf_Amt),
											              @IF(@ISNA(Conf_Amt),Base_Price*Ordered_Amount,Base_Price * Conf_Amt ) ) ) ), 
											        Contract_Price*Conf_Amt ),0 )), 
											
											  SUM(@IF(@SCAN(Customer_Type,'OR')+1,
											      @IF(@ISNA(Contract_Price) , 
											        @IF(@EXACT(Sale_Cat,'FC'),0,
											          @IF(@EXACT(Sale_Cat,'RP'),0, 
											            @IF(@EXACT(Sale_Cat,'HP'), 
											              @IF(@ISNA(Conf_Amt),(Base_Price/2)*Ordered_Amount,(Base_Price/2) * Conf_Amt),
											              @IF(@ISNA(Conf_Amt),Base_Price*Ordered_Amount,Base_Price * Conf_Amt ) ) ) ), 
											        Contract_Price*Conf_Amt ),0 )), 
											
											  SUM(@IF(@ISNA(Contract_Price) , 
											        @IF(@EXACT(Sale_Cat,'FC'),0,
											          @IF(@EXACT(Sale_Cat,'RP'),0, 
											            @IF(@EXACT(Sale_Cat,'HP'), 
											              @IF(@ISNA(Conf_Amt),(Base_Price/2)*Ordered_Amount,(Base_Price/2) * Conf_Amt),
											              @IF(@ISNA(Conf_Amt),Base_Price*Ordered_Amount,Base_Price * Conf_Amt ) ) ) ), 
											        Contract_Price*Conf_Amt ) ) 
											 FROM 
											  Stock_Item,
											  Cust_Order_History, 
											  Customer_Master 
											INTO 
											  :nGotGCTotalTrees, 
											  :nGotORTotalTrees, 
											  :nGotFCRPTotalTrees, 
											  :nGotTotalTrees, 
											  :nGotGCTotalSales, 
											  :nGotORTotalSales, 
											  :nGotTotalSales
											WHERE Stock_Item.Item_No = :nItemNo AND 
											  Stock_Item.Item_No = Stock_Item_No AND 
											  Cust_Order_History.Cust_No = Customer_Master.Cust_No AND 
											  Year_Of_Sale = :nYear "
									!
									If sOrderDateType = 'BEFORE'
										Set sSql = sSql || " AND Cust_Order_History.Ord_Date <= :dtOrderDate "
									Else If sOrderDateType = 'AFTER'
										Set sSql = sSql || " AND Cust_Order_History.Ord_Date > :dtOrderDate "
									!
									Call haSqlHandles[ nOurHandleNo ].PrepareSetup( sSql )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set nGCTotalTrees = NUMBER_Null
									Set nORTotalTrees = NUMBER_Null
									Set nFCRPTotalTrees = NUMBER_Null
									Set nTotalTrees = NUMBER_Null
									Set nGCTotalSales = NUMBER_Null
									Set nORTotalSales = NUMBER_Null
									Set nTotalSales = NUMBER_Null
									!
									Set nGotGCTotalTrees = NUMBER_Null
									Set nGotORTotalTrees = NUMBER_Null
									Set nGotFCRPTotalTrees = NUMBER_Null
									Set nGotTotalTrees = NUMBER_Null
									Set nGotGCTotalSales = NUMBER_Null
									Set nGotORTotalSales = NUMBER_Null
									Set nGotTotalSales = NUMBER_Null
									!
									If haSqlHandles[ nOurHandleNo ].PrepareAndExecute( )
										Call haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
										Set nGCTotalTrees = nGotGCTotalTrees
										Set nORTotalTrees = nGotORTotalTrees
										Set nFCRPTotalTrees = nGotFCRPTotalTrees
										Set nTotalTrees = nGotTotalTrees
										Set nGCTotalSales = nGotGCTotalSales
										Set nORTotalSales = nGotORTotalSales
										Set nTotalSales = nGotTotalSales
										Return TRUE
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )

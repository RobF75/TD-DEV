				Functions
					Function: AddRow
						Description:
						Returns
							Number:
						Parameters
						Static Variables
						Local variables
							Number: nNewRow
						Actions
							Set nNewRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
							Call SalTblSetContext( hWndForm, nNewRow )
							Set colType1 = frmItemsSizeSalesReport.sTreeTypes[1]
							Set colType2 = frmItemsSizeSalesReport.sTreeTypes[2]
							Set colType3 = frmItemsSizeSalesReport.sTreeTypes[3]
							Set colType4 = frmItemsSizeSalesReport.sTreeTypes[4]
							Set colType5 = frmItemsSizeSalesReport.sTreeTypes[5]
							Set colType6 = frmItemsSizeSalesReport.sTreeTypes[6]
							Set colType7 = frmItemsSizeSalesReport.sTreeTypes[7]
							Set colType8 = frmItemsSizeSalesReport.sTreeTypes[8]
							Set colType9 = frmItemsSizeSalesReport.sTreeTypes[9]
							Set colType10 = frmItemsSizeSalesReport.sTreeTypes[10]
							Set colType11 = frmItemsSizeSalesReport.sTreeTypes[11]
							Set colType12 = frmItemsSizeSalesReport.sTreeTypes[12]
							Set colType13 = frmItemsSizeSalesReport.sTreeTypes[13]
							Set colType14 = frmItemsSizeSalesReport.sTreeTypes[14]
							Set colType15 = frmItemsSizeSalesReport.sTreeTypes[15]
							Set colUpperVariety = sNewUpperVariety
							Set colCultDesc = sNewCultDesc
							Set colRootDesc = sNewRootDesc
					Function: MatchTreeTypes
						Description:
						Returns
						Parameters
						Static Variables
						Local variables
						Actions
							If sNewTreeTypeDesc = colType1
								Set colSoldType1 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType2
								Set colSoldType2 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType3
								Set colSoldType3 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType4
								Set colSoldType4 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType5
								Set colSoldType5 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType6
								Set colSoldType6 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType7
								Set colSoldType7 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType8
								Set colSoldType8 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType9
								Set colSoldType9 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType10
								Set colSoldType10 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType11
								Set colSoldType11 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType12
								Set colSoldType12 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType13
								Set colSoldType13 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType14
								Set colSoldType14 = nNewTotalTrees
							Else If sNewTreeTypeDesc = colType15
								Set colSoldType15 = nNewTotalTrees
					Function: DoesTreeTypeMatch
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
							Boolean: bFound
						Actions
							If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[1]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[2]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[3]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[4]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[5]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[6]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[7]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[8]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[9]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[10]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[11]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[12]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[13]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[14]
								Set bFound = TRUE
							Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[15]
								Set bFound = TRUE
							Else
								Set bFound = FALSE
							Return bFound
				Window Variables
					!
					String: sLastUpperCultDesc
					String: sLastUpperRootDesc
					!
					String: sNewVarietyType
					String: sNewUpperVariety
					String: sNewUpperCultDesc
					String: sNewUpperRootDesc
					String: sNewTreeTypeDesc
					String: sNewVariety
					String: sNewCultId
					String: sNewCultDesc
					String: sNewRootId
					String: sNewRootDesc
					Number: nNewItemNo
					Number: nNewGCTotalTrees
					Number: nNewORTotalTrees
					Number: nNewOtherTotalTrees
					Number: nNewTotalTrees
					Number: nNewGCTotalSales
					Number: nNewORTotalSales
					Number: nNewOtherTotalSales
					Number: nNewTotalSales
					Number: nNewOwnerRoyalties
					Number: nNewFNARoyalties
					Number: nNewFMNRoyalties
				Message Actions
					On SAM_Create
						Set sLastUpperCultDesc = ''
						Set sLastUpperRootDesc = ''
					On PAM_SALES_INSERTINDEX
						If SalSendMsg( hWndForm, PAM_SALES_POPFIELDS, 0, 0 )
							If sLastUpperCultDesc = sNewUpperCultDesc AND sLastUpperRootDesc = sNewUpperRootDesc
								Call MatchTreeTypes(  )
							Else
								If DoesTreeTypeMatch( )
									Call AddRow(  )
									Call MatchTreeTypes(  )
									Set sLastUpperCultDesc = sNewUpperCultDesc
									Set sLastUpperRootDesc = sNewUpperRootDesc
							Return TRUE
						Else
							Return FALSE
					On PAM_SALES_POPFIELDS
						Call PopNumber( nNewFMNRoyalties, TRUE )
						Call PopNumber( nNewFNARoyalties, TRUE )
						Call PopNumber( nNewOwnerRoyalties, TRUE )
						Call PopNumber( nNewTotalSales, TRUE )
						Call PopNumber( nNewOtherTotalSales, TRUE )
						Call PopNumber( nNewORTotalSales, TRUE )
						Call PopNumber( nNewGCTotalSales, TRUE )
						Call PopNumber( nNewTotalTrees, TRUE )
						Call PopNumber( nNewOtherTotalTrees, TRUE )
						Call PopNumber( nNewORTotalTrees, TRUE )
						Call PopNumber( nNewGCTotalTrees, TRUE )
						Call PopNumber( nNewItemNo, TRUE )
						Call PopString( sNewRootDesc, TRUE )
						Call PopString( sNewRootId, TRUE )
						Call PopString( sNewCultDesc, TRUE )
						Call PopString( sNewCultId, TRUE )
						Call PopString( sNewVariety, TRUE )
						Call PopString( sNewTreeTypeDesc, TRUE )
						Call PopString( sNewUpperRootDesc, TRUE )
						Call PopString( sNewUpperCultDesc, TRUE )
						Call PopString( sNewUpperVariety, TRUE )
						Call PopString( sNewVarietyType, TRUE )
						Return TRUE
		Functions
		Window Parameters
			Number: nYear
			! sViewPrint = 'VIEW' OR 'PRINT'
			String: sViewPrint
			! sContainers = 'INCLUDE' OR 'EXCLUDE' OR 'ONLY'
			String: sContainers
			! sSelectedItems if '' means all else Comma separated list of item numbers
			String: sSelectedItems
			String: sTreeTypes[*]
			! sOrderDateType = 'ALL', 'BEFORE' OR 'AFTER'
			String: sOrderDateType
			Date/Time: dtOrderDate
		Window Variables
			String: sReportName
			String: sReportBinds
			String: sReportInputs
			Number: nError
			Window Handle: hWndReport
			!
			String: sReportHeading
			Number: nItemsRow
		Message Actions
			On SAM_CreateComplete
				Set sReportHeading = 'Tree Type Sales'
			On PAM_SALES_INSERTINDEX
				Return SalSendMsg( tblItems, PAM_SALES_INSERTINDEX, wParam, lParam )
			On PAM_SALES_REPORT
				Set sReportName = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\typesal2.qrp'
				Set sReportBinds = ':frmItemsSizeSalesReport.sReportHeading, 
						:frmItemsSizeSalesReport.nYear, 
						:frmItemsSizeSalesReport.sOrderDateType, 
						:frmItemsSizeSalesReport.dtOrderDate, 
						:frmItemsSizeSalesReport.tblItems.colUpperVariety, 
						:frmItemsSizeSalesReport.tblItems.colCultDesc, 
						:frmItemsSizeSalesReport.tblItems.colRootDesc, 
						:frmItemsSizeSalesReport.tblItems.colType1, 
						:frmItemsSizeSalesReport.tblItems.colType2, 
						:frmItemsSizeSalesReport.tblItems.colType3, 
						:frmItemsSizeSalesReport.tblItems.colType4, 
						:frmItemsSizeSalesReport.tblItems.colType5, 
						:frmItemsSizeSalesReport.tblItems.colType6,
						:frmItemsSizeSalesReport.tblItems.colType7,  
						:frmItemsSizeSalesReport.tblItems.colType8, 
						:frmItemsSizeSalesReport.tblItems.colType9, 
						:frmItemsSizeSalesReport.tblItems.colType10, 
						:frmItemsSizeSalesReport.tblItems.colType11, 
						:frmItemsSizeSalesReport.tblItems.colType12, 
						:frmItemsSizeSalesReport.tblItems.colType13, 
						:frmItemsSizeSalesReport.tblItems.colType14, 
						:frmItemsSizeSalesReport.tblItems.colType15, 
						:frmItemsSizeSalesReport.tblItems.colSoldType1,
						:frmItemsSizeSalesReport.tblItems.colSoldType2,
						:frmItemsSizeSalesReport.tblItems.colSoldType3,
						:frmItemsSizeSalesReport.tblItems.colSoldType4,
						:frmItemsSizeSalesReport.tblItems.colSoldType5,
						:frmItemsSizeSalesReport.tblItems.colSoldType6,
						:frmItemsSizeSalesReport.tblItems.colSoldType7,
						:frmItemsSizeSalesReport.tblItems.colSoldType8,
						:frmItemsSizeSalesReport.tblItems.colSoldType9,
						:frmItemsSizeSalesReport.tblItems.colSoldType10, 
						:frmItemsSizeSalesReport.tblItems.colSoldType11, 
						:frmItemsSizeSalesReport.tblItems.colSoldType12,
						:frmItemsSizeSalesReport.tblItems.colSoldType13,
						:frmItemsSizeSalesReport.tblItems.colSoldType14,
						:frmItemsSizeSalesReport.tblItems.colSoldType15'
				Set sReportInputs = 'ReportHeading, 
						YearOfSale, 
						OrderDateType, 
						OrderDate, 
						Variety, 
						CultDesc, 
						RootDesc, 
						Type1, 
						Type2, 
						Type3, 
						Type4, 
						Type5, 
						Type6, 
						Type7, 
						Type8, 
						Type9, 
						Type10, 
						Type11, 
						Type12, 
						Type13, 
						Type14, 
						Type15, 
						SoldType1,
						SoldType2,
						SoldType3,
						SoldType4,
						SoldType5,
						SoldType6,
						SoldType7,
						SoldType8,
						SoldType9,
						SoldType10,
						SoldType11,
						SoldType12,
						SoldType13,
						SoldType14,
						SoldType15'
				Set nError = 1
				If sViewPrint = 'PRINT'
					Set hWndReport = SalReportPrint( hWndForm, sReportName, sReportBinds, sReportInputs, 1, RPT_PrintAll | RPT_PrintNoWarn, 0, 0, nError )
				Else
					Set hWndReport = SalReportView( hWndForm, hWndForm, sReportName, sReportBinds, sReportInputs, nError )
					If hWndReport = hWndNULL
						Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
			On SAM_ReportStart
				Return TRUE
			On SAM_ReportFetchInit
				Set nItemsRow = TBL_MinRow
				Return TRUE
			On SAM_ReportFetchNext
				If SalTblFindNextRow( tblItems, nItemsRow, 0, 0 )
					Call SalTblFetchRow( tblItems, nItemsRow )
					Return TRUE
				Else
					Return FALSE
			On SAM_ReportFinish
				Call SalDestroyWindow( hWndForm )
				Return TRUE

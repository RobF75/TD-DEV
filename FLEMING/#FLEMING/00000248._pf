				Window Variables
					String: sSql
					String: sSelectPart
					String: sFromPart
					String: sIntoPart
					String: sWherePart
					String: sGroupPart
					: hPopSalesHdl
						Class: hcSqlHandle
					Boolean: bOk
					Number: nTmp
					String: sTmp
					: hWndMeter
						Class: clsMeterBar
					Number: nTotalItems
					Boolean: bHistory
					!
					Number: nOwnerRoyPay
					Number: nFMNRoyPay
					Number: nFNARoyPay
					!
					String: sSalesSeqItmsVarietyType
					String: sSalesSeqItmsUpperVariety
					String: sSalesSeqItmsUpperCultDesc
					String: sSalesSeqItmsUpperRootDesc
					String: sSalesSeqItmsTreeTypeDesc
					String: sSalesSeqItmsVariety
					String: sSalesSeqItmsCultId
					String: sSalesSeqItmsCultDesc
					String: sSalesSeqItmsRootId
					String: sSalesSeqItmsRootDesc
					Number: nSalesSeqItmsItemNo
					Number: nSalesSeqItmsGCTotalTrees
					Number: nSalesSeqItmsORTotalTrees
					Number: nSalesSeqItmsFCRPTotalTrees
					Number: nSalesSeqItmsOtherTotalTrees
					Number: nSalesSeqItmsTotalTrees
					Number: nSalesSeqItmsGCTotalSales
					Number: nSalesSeqItmsORTotalSales
					Number: nSalesSeqItmsOtherTotalSales
					Number: nSalesSeqItmsTotalSales
					Number: nSalesSeqItmsOwnerRoyalties
					Number: nSalesSeqItmsFNARoyalties
					Number: nSalesSeqItmsFMNRoyalties
					!
					String: sVarSummaryVarietyType
					String: sVarSummaryUpperVariety
					String: sVarSummaryUpperCultDesc
					String: sVarSummaryUpperRootDesc
					String: sVarSummaryTreeTypeDesc
					String: sVarSummaryVariety
					String: sVarSummaryCultId
					String: sVarSummaryCultDesc
					String: sVarSummaryRootId
					String: sVarSummaryRootDesc
					Number: nVarSummaryItemNo
					Number: nVarSummaryGCTotalTrees
					Number: nVarSummaryORTotalTrees
					Number: nVarSummaryFCRPTotalTrees
					Number: nVarSummaryOtherTotalTrees
					Number: nVarSummaryTotalTrees
					Number: nVarSummaryGCTotalSales
					Number: nVarSummaryORTotalSales
					Number: nVarSummaryOtherTotalSales
					Number: nVarSummaryTotalSales
					Number: nVarSummaryOwnerRoyalties
					Number: nVarSummaryFNARoyalties
					Number: nVarSummaryFMNRoyalties
					!
					String: sSalesSeqVarsVarietyType
					String: sSalesSeqVarsUpperVariety
					String: sSalesSeqVarsUpperCultDesc
					String: sSalesSeqVarsUpperRootDesc
					String: sSalesSeqVarsTreeTypeDesc
					String: sSalesSeqVarsVariety
					String: sSalesSeqVarsCultId
					String: sSalesSeqVarsCultDesc
					String: sSalesSeqVarsRootId
					String: sSalesSeqVarsRootDesc
					Number: nSalesSeqVarsItemNo
					Number: nSalesSeqVarsGCTotalTrees
					Number: nSalesSeqVarsORTotalTrees
					Number: nSalesSeqVarsFCRPTotalTrees
					Number: nSalesSeqVarsOtherTotalTrees
					Number: nSalesSeqVarsTotalTrees
					Number: nSalesSeqVarsGCTotalSales
					Number: nSalesSeqVarsORTotalSales
					Number: nSalesSeqVarsOtherTotalSales
					Number: nSalesSeqVarsTotalSales
					Number: nSalesSeqVarsOwnerRoyalties
					Number: nSalesSeqVarsFNARoyalties
					Number: nSalesSeqVarsFMNRoyalties
				Message Actions
					On SAM_Create
						Call hPopSalesHdl.Connect( )
						!
						Set sSalesSeqItmsVarietyType = ''
						Set sSalesSeqItmsUpperVariety = ''
						Set sSalesSeqItmsUpperCultDesc = ''
						Set sSalesSeqItmsUpperRootDesc = ''
						Set sSalesSeqItmsTreeTypeDesc = ''
						Set sSalesSeqItmsVariety = ''
						Set sSalesSeqItmsCultId = ''
						Set sSalesSeqItmsCultDesc = ''
						Set sSalesSeqItmsRootId = ''
						Set sSalesSeqItmsRootDesc = ''
						Set nSalesSeqItmsItemNo = NUMBER_Null
						Set nSalesSeqItmsGCTotalTrees = NUMBER_Null
						Set nSalesSeqItmsORTotalTrees = NUMBER_Null
						Set nSalesSeqItmsFCRPTotalTrees = NUMBER_Null
						Set nSalesSeqItmsOtherTotalTrees = NUMBER_Null
						Set nSalesSeqItmsTotalTrees = NUMBER_Null
						Set nSalesSeqItmsGCTotalSales = NUMBER_Null
						Set nSalesSeqItmsORTotalSales = NUMBER_Null
						Set nSalesSeqItmsOtherTotalSales = NUMBER_Null
						Set nSalesSeqItmsTotalSales = NUMBER_Null
						Set nSalesSeqItmsOwnerRoyalties = NUMBER_Null
						Set nSalesSeqItmsFNARoyalties = NUMBER_Null
						Set nSalesSeqItmsFMNRoyalties = NUMBER_Null
						!
						Set sVarSummaryVarietyType = ''
						Set sVarSummaryUpperVariety = ''
						Set sVarSummaryUpperCultDesc = ''
						Set sVarSummaryUpperRootDesc = ''
						Set sVarSummaryTreeTypeDesc = ''
						Set sVarSummaryVariety = ''
						Set sVarSummaryCultId = ''
						Set sVarSummaryCultDesc = ''
						Set sVarSummaryRootId = ''
						Set sVarSummaryRootDesc = ''
						Set nVarSummaryItemNo = NUMBER_Null
						Set nVarSummaryGCTotalTrees = NUMBER_Null
						Set nVarSummaryORTotalTrees = NUMBER_Null
						Set nVarSummaryFCRPTotalTrees = NUMBER_Null
						Set nVarSummaryOtherTotalTrees = NUMBER_Null
						Set nVarSummaryTotalTrees = NUMBER_Null
						Set nVarSummaryGCTotalSales = NUMBER_Null
						Set nVarSummaryORTotalSales = NUMBER_Null
						Set nVarSummaryOtherTotalSales = NUMBER_Null
						Set nVarSummaryTotalSales = NUMBER_Null
						Set nVarSummaryOwnerRoyalties = NUMBER_Null
						Set nVarSummaryFNARoyalties = NUMBER_Null
						Set nVarSummaryFMNRoyalties = NUMBER_Null
						!
						Set sSalesSeqVarsVarietyType = ''
						Set sSalesSeqVarsUpperVariety = ''
						Set sSalesSeqVarsUpperCultDesc = ''
						Set sSalesSeqVarsUpperRootDesc = ''
						Set sSalesSeqVarsTreeTypeDesc = ''
						Set sSalesSeqVarsVariety = ''
						Set sSalesSeqVarsCultId = ''
						Set sSalesSeqVarsCultDesc = ''
						Set sSalesSeqVarsRootId = ''
						Set sSalesSeqVarsRootDesc = ''
						Set nSalesSeqVarsItemNo = NUMBER_Null
						Set nSalesSeqVarsGCTotalTrees = NUMBER_Null
						Set nSalesSeqVarsORTotalTrees = NUMBER_Null
						Set nSalesSeqVarsFCRPTotalTrees = NUMBER_Null
						Set nSalesSeqVarsOtherTotalTrees = NUMBER_Null
						Set nSalesSeqVarsTotalTrees = NUMBER_Null
						Set nSalesSeqVarsGCTotalSales = NUMBER_Null
						Set nSalesSeqVarsORTotalSales = NUMBER_Null
						Set nSalesSeqVarsOtherTotalSales = NUMBER_Null
						Set nSalesSeqVarsTotalSales = NUMBER_Null
						Set nSalesSeqVarsOwnerRoyalties = NUMBER_Null
						Set nSalesSeqVarsFNARoyalties = NUMBER_Null
						Set nSalesSeqVarsFMNRoyalties = NUMBER_Null
					On PAM_SALES_POPULATE
						Set bOk = FALSE
						Set sSelectPart = "SELECT 
								  Stock_Item.Variety_Type, 
								  @UPPER(Stock_Item.Variety), 
								  @UPPER(Stock_Item.Cult_Desc), 
								  @UPPER(Stock_Item.Root_Desc), 
								  Stock_Item.Tree_Type_Desc, 
								  Stock_Item.Variety, 
								  Stock_Item.Cultivar_Id, 
								  Stock_Item.Cult_Desc, 
								  Stock_Item.Rootstock_Id, 
								  Stock_Item.Root_Desc, 
								  Stock_Item.Item_No "
						!
						Set sIntoPart = ' INTO :frmEstSalesItemsReport.tblItems.colVarietyType, 
								:frmEstSalesItemsReport.tblItems.colUpperVariety, 
								:frmEstSalesItemsReport.tblItems.colUpperCultDesc, 
								:frmEstSalesItemsReport.tblItems.colUpperRootDesc, 
								:frmEstSalesItemsReport.tblItems.colTreeTypeDesc, 
								:frmEstSalesItemsReport.tblItems.colVariety, 
								:frmEstSalesItemsReport.tblItems.colCultId, 
								:frmEstSalesItemsReport.tblItems.colCultDesc, 
								:frmEstSalesItemsReport.tblItems.colRootId, 
								:frmEstSalesItemsReport.tblItems.colRootDesc, 
								:frmEstSalesItemsReport.tblItems.colItemNo'
						!
						Set sGroupPart = " ORDER BY 1,2,3,4,5 "
						!
						If frmEstSalesItemsReport.nYear < OurDateYear( SalDateCurrent(  ) )
							Set bHistory = TRUE
						Else
							Set bHistory = FALSE
						!
						Set sFromPart = ' FROM Stock_Item_Sale, Stock_Item '
						!
						If frmEstSalesItemsReport.sContainers = 'INCLUDE'
							If frmEstSalesItemsReport.sSelectedItems = ''
								Set sWherePart = " WHERE Stock_Item_Sale.Stock_Item_No = Stock_Item.Item_No AND 
										Stock_Item_Sale.Year_Of_Sale = " || SalNumberToStrX( frmEstSalesItemsReport.nYear, 0 ) || " AND 
										( 
										  Stock_Item_Sale.Amt_Shipped > 0 OR 
										  Stock_Item_Sale.Amt_On_Order > 0 OR 
										  EXISTS ( 
										     SELECT 
										       Growing_Sale.Location_Id 
										     FROM 
										        Growing_Sale 
										     WHERE 
										        Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
										        Growing_Sale.Year_Of_Sale = Stock_Item_Sale.Year_Of_Sale AND 
										        Growing_Sale.Forward_Orders > 0 
										  )
										) "
							Else
								Set sWherePart = " WHERE  Stock_Item_Sale.Stock_Item_No IN ( " || 
										  frmEstSalesItemsReport.sSelectedItems || " ) AND 
										Stock_Item_Sale.Year_Of_Sale = " || SalNumberToStrX( frmEstSalesItemsReport.nYear, 0 ) || " AND 
										Stock_Item_Sale.Stock_Item_No = Stock_Item.Item_No AND 
										( 
										  Stock_Item_Sale.Amt_Shipped > 0 OR 
										  Stock_Item_Sale.Amt_On_Order > 0 OR 
										  EXISTS ( 
										     SELECT 
										       Growing_Sale.Location_Id 
										     FROM 
										        Growing_Sale 
										     WHERE 
										        Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
										        Growing_Sale.Year_Of_Sale = Stock_Item_Sale.Year_Of_Sale AND 
										        Growing_Sale.Forward_Orders > 0 
										  ) 
										)  "
						Else If frmEstSalesItemsReport.sContainers = 'EXCLUDE'
							If frmEstSalesItemsReport.sSelectedItems = ''
								Set sWherePart = " WHERE Stock_Item_Sale.Stock_Item_No = Stock_Item.Item_No AND 
										Stock_Item_Sale.Year_Of_Sale = " || SalNumberToStrX( frmEstSalesItemsReport.nYear, 0 ) || " AND 
										( 
										  Stock_Item_Sale.Amt_Shipped > 0 OR 
										  Stock_Item_Sale.Amt_On_Order > 0 OR 
										  EXISTS ( 
										     SELECT 
										       Growing_Sale.Location_Id 
										     FROM 
										        Growing_Sale 
										     WHERE 
										        Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
										        Growing_Sale.Year_Of_Sale = Stock_Item_Sale.Year_Of_Sale AND 
										        Growing_Sale.Forward_Orders > 0 
										  )
										) AND 
										NOT Stock_Item.Stock_Type = 'C' "
							Else
								Set sWherePart = " WHERE Stock_Item_Sale.Stock_Item_No IN ( " || 
										  frmEstSalesItemsReport.sSelectedItems || " ) AND 
										Stock_Item_Sale.Year_Of_Sale = " || SalNumberToStrX( frmEstSalesItemsReport.nYear, 0 ) || " AND 
										Stock_Item_Sale.Stock_Item_No = Stock_Item.Item_No AND 
										( 
										  Stock_Item_Sale.Amt_Shipped > 0 OR 
										  Stock_Item_Sale.Amt_On_Order > 0 OR 
										  EXISTS ( 
										     SELECT 
										       Growing_Sale.Location_Id 
										     FROM 
										        Growing_Sale 
										     WHERE 
										        Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
										        Growing_Sale.Year_Of_Sale = Stock_Item_Sale.Year_Of_Sale AND 
										        Growing_Sale.Forward_Orders > 0 
										  ) 
										) AND
										NOT Stock_Item.Stock_Type = 'C' "
						Else If frmEstSalesItemsReport.sContainers = 'ONLY'
							If frmEstSalesItemsReport.sSelectedItems = ''
								Set sWherePart = " WHERE Stock_Item_Sale.Stock_Item_No = Stock_Item.Item_No AND 
										Stock_Item_Sale.Year_Of_Sale = " || SalNumberToStrX( frmEstSalesItemsReport.nYear, 0 ) || " AND 
										( 
										  Stock_Item_Sale.Amt_Shipped > 0 OR 
										  Stock_Item_Sale.Amt_On_Order > 0 OR 
										  EXISTS ( 
										     SELECT 
										       Growing_Sale.Location_Id 
										     FROM 
										        Growing_Sale 
										     WHERE 
										        Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
										        Growing_Sale.Year_Of_Sale = Stock_Item_Sale.Year_Of_Sale AND 
										        Growing_Sale.Forward_Orders > 0 
										  ) 
										) AND 
										Stock_Item.Stock_Type = 'C' "
							Else
								Set sWherePart = " WHERE  Stock_Item_Sale.Stock_Item_No IN ( " || 
										  frmEstSalesItemsReport.sSelectedItems || " ) AND 
										Stock_Item_Sale.Year_Of_Sale = " || SalNumberToStrX( frmEstSalesItemsReport.nYear, 0 ) || " AND 
										Stock_Item_Sale.Stock_Item_No = Stock_Item.Item_No AND 
										( 
										  Stock_Item_Sale.Amt_Shipped > 0 OR 
										  Stock_Item_Sale.Amt_On_Order > 0 OR 
										  EXISTS ( 
										     SELECT 
										       Growing_Sale.Location_Id 
										     FROM 
										        Growing_Sale 
										     WHERE 
										        Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
										        Growing_Sale.Year_Of_Sale = Stock_Item_Sale.Year_Of_Sale AND 
										        Growing_Sale.Forward_Orders > 0 
										  ) 
										) AND
										Stock_Item.Stock_Type = 'C' "
						!
						Set sSql = sSelectPart || sFromPart || sIntoPart || sWherePart || sGroupPart
						If hPopSalesHdl.PrepareSetup( sSql )
							If hPopSalesHdl.PrepareAndExecute( )
								Call hPopSalesHdl.ResultSetCount( nTotalItems )
								Call hWndMeter.Setup( 'Populating Tree Reports', nTotalItems )
								If hPopSalesHdl.TablePopulate( hWndForm, TBL_FillAll )
									If hWndSalesSeqItems != hWndNULL
										If SalSendMsg( hWndForm, PAM_SALES_PUSHFIELDS, 1, 0 )
											If NOT SalSendMsg( hWndSalesSeqItems, PAM_SALES_INSERTINDEX, 0, lParam )
												Call SalSendMsg( hWndForm, PAM_SALES_POPFIELDS, 0, 0 )
										!
										Set sSalesSeqItmsVarietyType = ''
										Set sSalesSeqItmsUpperVariety = ''
										Set sSalesSeqItmsUpperCultDesc = ''
										Set sSalesSeqItmsUpperRootDesc = ''
										Set sSalesSeqItmsTreeTypeDesc = ''
										Set sSalesSeqItmsVariety = ''
										Set sSalesSeqItmsCultId = ''
										Set sSalesSeqItmsCultDesc = ''
										Set sSalesSeqItmsRootId = ''
										Set sSalesSeqItmsRootDesc = ''
										Set nSalesSeqItmsItemNo = NUMBER_Null
										Set nSalesSeqItmsGCTotalTrees = NUMBER_Null
										Set nSalesSeqItmsORTotalTrees = NUMBER_Null
										Set nSalesSeqItmsFCRPTotalTrees = NUMBER_Null
										Set nSalesSeqItmsOtherTotalTrees = NUMBER_Null
										Set nSalesSeqItmsTotalTrees = NUMBER_Null
										Set nSalesSeqItmsGCTotalSales = NUMBER_Null
										Set nSalesSeqItmsORTotalSales = NUMBER_Null
										Set nSalesSeqItmsOtherTotalSales = NUMBER_Null
										Set nSalesSeqItmsTotalSales = NUMBER_Null
										Set nSalesSeqItmsOwnerRoyalties = NUMBER_Null
										Set nSalesSeqItmsFNARoyalties = NUMBER_Null
										Set nSalesSeqItmsFMNRoyalties = NUMBER_Null
									If hWndVarietySummary != hWndNULL OR hWndBestVarietySummary != hWndNULL
										If hWndVarietySummary != hWndNULL
											If SalSendMsg( hWndForm, PAM_SALES_PUSHFIELDS, 2, 0 )
												If NOT SalSendMsg( hWndVarietySummary, PAM_SALES_INSERTINDEX, 0, lParam )
													Call SalSendMsg( hWndForm, PAM_SALES_POPFIELDS, 0, 0 )
										If hWndBestVarietySummary != hWndNULL
											If SalSendMsg( hWndForm, PAM_SALES_PUSHFIELDS, 2, 0 )
												If NOT SalSendMsg( hWndBestVarietySummary, PAM_SALES_INSERTINDEX, 0, lParam )
													Call SalSendMsg( hWndForm, PAM_SALES_POPFIELDS, 0, 0 )
										!
										Set sVarSummaryVarietyType = ''
										Set sVarSummaryUpperVariety = ''
										Set sVarSummaryUpperCultDesc = ''
										Set sVarSummaryUpperRootDesc = ''
										Set sVarSummaryTreeTypeDesc = ''
										Set sVarSummaryVariety = ''
										Set sVarSummaryCultId = ''
										Set sVarSummaryCultDesc = ''
										Set sVarSummaryRootId = ''
										Set sVarSummaryRootDesc = ''
										Set nVarSummaryItemNo = NUMBER_Null
										Set nVarSummaryGCTotalTrees = NUMBER_Null
										Set nVarSummaryORTotalTrees = NUMBER_Null
										Set nVarSummaryFCRPTotalTrees = NUMBER_Null
										Set nVarSummaryOtherTotalTrees = NUMBER_Null
										Set nVarSummaryTotalTrees = NUMBER_Null
										Set nVarSummaryGCTotalSales = NUMBER_Null
										Set nVarSummaryORTotalSales = NUMBER_Null
										Set nVarSummaryOtherTotalSales = NUMBER_Null
										Set nVarSummaryTotalSales = NUMBER_Null
										Set nVarSummaryOwnerRoyalties = NUMBER_Null
										Set nVarSummaryFNARoyalties = NUMBER_Null
										Set nVarSummaryFMNRoyalties = NUMBER_Null
									If hWndEstSalesVarieties != hWndNULL
										If SalSendMsg( hWndForm, PAM_SALES_PUSHFIELDS, 3, 0 )
											If NOT SalSendMsg( hWndEstSalesVarieties, PAM_SALES_INSERTINDEX, 0, lParam )
												Call SalSendMsg( hWndForm, PAM_SALES_POPFIELDS, 0, 0 )
										!
										Set sSalesSeqVarsVarietyType = ''
										Set sSalesSeqVarsUpperVariety = ''
										Set sSalesSeqVarsUpperCultDesc = ''
										Set sSalesSeqVarsUpperRootDesc = ''
										Set sSalesSeqVarsTreeTypeDesc = ''
										Set sSalesSeqVarsVariety = ''
										Set sSalesSeqVarsCultId = ''
										Set sSalesSeqVarsCultDesc = ''
										Set sSalesSeqVarsRootId = ''
										Set sSalesSeqVarsRootDesc = ''
										Set nSalesSeqVarsItemNo = NUMBER_Null
										!
										Set nSalesSeqVarsGCTotalTrees = NUMBER_Null
										Set nSalesSeqVarsORTotalTrees = NUMBER_Null
										Set nSalesSeqVarsFCRPTotalTrees = NUMBER_Null
										Set nSalesSeqVarsOtherTotalTrees = NUMBER_Null
										Set nSalesSeqVarsTotalTrees = NUMBER_Null
										Set nSalesSeqVarsGCTotalSales = NUMBER_Null
										Set nSalesSeqVarsORTotalSales = NUMBER_Null
										Set nSalesSeqVarsOtherTotalSales = NUMBER_Null
										Set nSalesSeqVarsTotalSales = NUMBER_Null
										Set nSalesSeqVarsOwnerRoyalties = NUMBER_Null
										Set nSalesSeqVarsFNARoyalties = NUMBER_Null
										Set nSalesSeqVarsFMNRoyalties = NUMBER_Null
								Call hWndMeter.End( )
						Return bOk
					On SAM_FetchRowDone
						If bHistory
							If GetTreeSalesTotalsHist( colItemNo, frmEstSalesItemsReport.nYear, frmEstSalesItemsReport.sOrderDateType, frmEstSalesItemsReport.dtOrderDate, colGCTotalTrees, colORTotalTrees, colFCRPTotalTrees, colTotalTrees, colGCTotalSales, colORTotalSales, 
									colTotalSales, SH_cls_Execute )
								Set colOtherTotalTrees = colTotalTrees - colGCTotalTrees - colORTotalTrees - colFCRPTotalTrees
								Set colTotalTrees = colTotalTrees - colFCRPTotalTrees
								Set colOtherTotalSales = colTotalSales - colGCTotalSales - colORTotalSales
						Else
							If GetTreeSalesTotals( colItemNo, frmEstSalesItemsReport.nYear, frmEstSalesItemsReport.sOrderDateType, frmEstSalesItemsReport.dtOrderDate, colGCTotalTrees, colORTotalTrees, colFCRPTotalTrees, colTotalTrees, colGCTotalSales, colORTotalSales, 
									colTotalSales, SH_cls_Execute )
								Set colOtherTotalTrees = colTotalTrees - colGCTotalTrees - colORTotalTrees - colFCRPTotalTrees
								Set colTotalTrees = colTotalTrees - colFCRPTotalTrees
								Set colOtherTotalSales = colTotalSales - colGCTotalSales - colORTotalSales
						If colTotalTrees > 0 OR colTotalSales > 0
							Set colOwnerRoyalties = NUMBER_Null
							Set colFMNRoyalties = NUMBER_Null
							Set colFNARoyalties = NUMBER_Null
							If GetCultivarSalesRoyalties( colCultId, nOwnerRoyPay, nFMNRoyPay, nFNARoyPay, SH_cls_Execute )
								Set colOwnerRoyalties = colOwnerRoyalties + ( nOwnerRoyPay * colTotalTrees )
								Set colFMNRoyalties = colFMNRoyalties + ( nFMNRoyPay * colTotalTrees )
								Set colFNARoyalties = colFNARoyalties + ( nFNARoyPay * colTotalTrees )
							If GetRootstockSalesRoyalties( colRootId, nOwnerRoyPay, nFMNRoyPay, nFNARoyPay, SH_cls_Execute )
								Set colOwnerRoyalties = colOwnerRoyalties + ( nOwnerRoyPay * colTotalTrees )
								Set colFMNRoyalties = colFMNRoyalties + ( nFMNRoyPay * colTotalTrees )
								Set colFNARoyalties = colFNARoyalties + ( nFNARoyPay * colTotalTrees )
							!
							If hWndSalesSeqItems != hWndNULL
								If colCultId = sSalesSeqItmsCultId OR sSalesSeqItmsCultId = ''
									Set sSalesSeqItmsVarietyType = colVarietyType
									Set sSalesSeqItmsUpperVariety = colUpperVariety
									Set sSalesSeqItmsUpperCultDesc = colUpperCultDesc
									Set sSalesSeqItmsUpperRootDesc = colUpperRootDesc
									Set sSalesSeqItmsTreeTypeDesc = colTreeTypeDesc
									Set sSalesSeqItmsVariety = colVariety
									Set sSalesSeqItmsCultId = colCultId
									Set sSalesSeqItmsCultDesc = colCultDesc
									Set sSalesSeqItmsRootId = colRootId
									Set sSalesSeqItmsRootDesc = colRootDesc
									Set nSalesSeqItmsItemNo = colItemNo
									Set nSalesSeqItmsGCTotalTrees =  nSalesSeqItmsGCTotalTrees + colGCTotalTrees
									Set nSalesSeqItmsORTotalTrees = nSalesSeqItmsORTotalTrees + colORTotalTrees
									Set nSalesSeqItmsFCRPTotalTrees = nSalesSeqItmsFCRPTotalTrees + colFCRPTotalTrees
									Set nSalesSeqItmsOtherTotalTrees = nSalesSeqItmsOtherTotalTrees + colOtherTotalTrees
									Set nSalesSeqItmsTotalTrees = nSalesSeqItmsTotalTrees + colTotalTrees
									Set nSalesSeqItmsGCTotalSales = nSalesSeqItmsGCTotalSales + colGCTotalSales
									Set nSalesSeqItmsORTotalSales = nSalesSeqItmsORTotalSales + colORTotalSales
									Set nSalesSeqItmsOtherTotalSales = nSalesSeqItmsOtherTotalSales + colOtherTotalSales
									Set nSalesSeqItmsTotalSales = nSalesSeqItmsTotalSales + colTotalSales
									Set nSalesSeqItmsOwnerRoyalties = nSalesSeqItmsOwnerRoyalties + colOwnerRoyalties
									Set nSalesSeqItmsFNARoyalties = nSalesSeqItmsFNARoyalties + colFNARoyalties
									Set nSalesSeqItmsFMNRoyalties = nSalesSeqItmsFMNRoyalties + colFMNRoyalties
								Else
									!
									If SalSendMsg( hWndForm, PAM_SALES_PUSHFIELDS, 1, 0 )
										If NOT SalSendMsg( hWndSalesSeqItems, PAM_SALES_INSERTINDEX, 0, lParam )
											Call SalSendMsg( hWndForm, PAM_SALES_POPFIELDS, 0, 0 )
									!
									Set sSalesSeqItmsVarietyType = colVarietyType
									Set sSalesSeqItmsUpperVariety = colUpperVariety
									Set sSalesSeqItmsUpperCultDesc = colUpperCultDesc
									Set sSalesSeqItmsUpperRootDesc = colUpperRootDesc
									Set sSalesSeqItmsTreeTypeDesc = colTreeTypeDesc
									Set sSalesSeqItmsVariety = colVariety
									Set sSalesSeqItmsCultId = colCultId
									Set sSalesSeqItmsCultDesc = colCultDesc
									Set sSalesSeqItmsRootId = colRootId
									Set sSalesSeqItmsRootDesc = colRootDesc
									Set nSalesSeqItmsItemNo = colItemNo
									Set nSalesSeqItmsGCTotalTrees = colGCTotalTrees
									Set nSalesSeqItmsORTotalTrees = colORTotalTrees

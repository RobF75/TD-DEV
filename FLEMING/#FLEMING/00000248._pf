		Functions
		Window Parameters
			Window Handle: hWndSalesSeqItems
			Window Handle: hWndVarietySummary
			Window Handle: hWndEstSalesVarieties
			Window Handle: hWndBestVarietySummary
			Window Handle: hWndSizeSalesItems
			Number: nYear
			! sViewPrint = 'VIEW' OR 'PRINT'
			String: sViewPrint
			! sContainers = 'INCLUDE' OR 'EXCLUDE' OR 'ONLY'
			String: sContainers
			! sSelectedItems if '' means all else Comma separated list of item numbers
			String: sSelectedItems
			! sOrderDateType = 'ALL', 'BEFORE' OR 'AFTER'
			String: sOrderDateType
			Date/Time: dtOrderDate
		Window Variables
			String: sReportName
			String: sReportBinds
			String: sReportInputs
			Number: nError
			Window Handle: hWndReport
			!
			String: sReportHeading
			Number: nItemsRow
		Message Actions
			On SAM_CreateComplete
				Set sReportHeading = 'Estimated Sales, ALPHA LISTING'
			On PAM_SALES_POPULATE
				Call OurWaitCursor( TRUE )
				Call SalSendMsg( tblItems, PAM_SALES_POPULATE, 0, 0 )
				Call OurWaitCursor( FALSE )
			On PAM_SALES_REPORT
				Set sReportName = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\estsale2.qrp'
				Set sReportBinds = ':frmEstSalesItemsReport.sReportHeading, 
						:frmEstSalesItemsReport.nYear, 
						:frmEstSalesItemsReport.sOrderDateType, 
						:frmEstSalesItemsReport.dtOrderDate, 
						:frmEstSalesItemsReport.tblItems.colItemNo, 
						:frmEstSalesItemsReport.tblItems.colVarietyType, 
						:frmEstSalesItemsReport.tblItems.colUpperVariety, 
						:frmEstSalesItemsReport.tblItems.colTreeTypeDesc, 
						:frmEstSalesItemsReport.tblItems.colCultDesc, 
						:frmEstSalesItemsReport.tblItems.colRootDesc, 
						:frmEstSalesItemsReport.tblItems.colGCTotalTrees, 
						:frmEstSalesItemsReport.tblItems.colORTotalTrees, 
						:frmEstSalesItemsReport.tblItems.colFCRPTotalTrees, 
						:frmEstSalesItemsReport.tblItems.colOtherTotalTrees, 
						:frmEstSalesItemsReport.tblItems.colTotalTrees, 
						:frmEstSalesItemsReport.tblItems.colGCTotalSales, 
						:frmEstSalesItemsReport.tblItems.colORTotalSales,
						:frmEstSalesItemsReport.tblItems.colOtherTotalSales,  
						:frmEstSalesItemsReport.tblItems.colTotalSales, 
						:frmEstSalesItemsReport.tblItems.colOwnerRoyalties, 
						:frmEstSalesItemsReport.tblItems.colFNARoyalties, 
						:frmEstSalesItemsReport.tblItems.colFMNRoyalties'
				Set sReportInputs = 'ReportHeading, 
						YearOfSale, 
						OrderDateType, 
						OrderDate, 
						ItemNo, 
						VarietyType, 
						Variety, 
						TreeTypeDesc, 
						CultDesc, 
						RootDesc, 
						GCTrees, 
						ORTrees, 
						FCRPTrees, 
						OtherTrees, 
						TotalTrees, 
						GCSales, 
						ORSales, 
						OtherSales, 
						TotalSales, 
						OwnerRoyalties, 
						FNARoyalties, 
						FMNRoyalties'
				Set nError = 1
				If sViewPrint = 'PRINT'
					Set hWndReport = SalReportPrint( hWndForm, sReportName, sReportBinds, sReportInputs, 1, RPT_PrintAll | RPT_PrintNoWarn, 0, 0, nError )
				Else
					Set hWndReport = SalReportView( hWndForm, hWndForm, sReportName, sReportBinds, sReportInputs, nError )
					If hWndReport = hWndNULL
						Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
			On SAM_ReportStart
				Return TRUE
			On SAM_ReportFetchInit
				Set nItemsRow = TBL_MinRow
				Return TRUE
			On SAM_ReportFetchNext
				If SalTblFindNextRow( tblItems, nItemsRow, 0, ROW_Selected )
					Call SalTblFetchRow( tblItems, nItemsRow )
					Return TRUE
				Else
					Return FALSE
			On SAM_ReportFinish
				Call SalDestroyWindow( hWndForm )
				Return TRUE

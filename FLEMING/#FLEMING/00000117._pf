			Contents
		Contents
		Functions
		Window Parameters
		Window Variables
			! REPORT FIELDS
			String: sCultDesc
			String: sRootDesc
			String: sFarmName
			Number: nRowNo
			Number: nSeqNo
			String: sVariety
			String: sVarietyType
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set sReportFileNameNoPath = 'AlphaOrchPlanS.qrp'
				!
				Set sReportBind = ':frmPrintAlphaOrchPlanS.sCultDesc, 
						  :frmPrintAlphaOrchPlanS.sRootDesc, 
						  :frmPrintAlphaOrchPlanS.sFarmName, 
						  :frmPrintAlphaOrchPlanS.nRowNo, 
						  :frmPrintAlphaOrchPlanS.nSeqNo, 
						  :frmPrintAlphaOrchPlanS.sVariety, 
						  :frmPrintAlphaOrchPlanS.sVarietyType'
				Set sReportInto = 'CULT_DESC, 
						ROOT_DESC, 
						FARM_NAME, 
						ROW#, 
						SEQ#, 
						variety, 
						var_type'
				Set sReportSql = " SELECT 
						  cult_desc,
						  root_desc,
						  farm_name,
						  row#,
						  seq#,
						  variety,
						  variety_type 
						FROM 
						  scion_evaluation,
						  stock_item,
						  location 
						INTO  
						  :frmPrintAlphaOrchPlanS.sCultDesc, 
						  :frmPrintAlphaOrchPlanS.sRootDesc, 
						  :frmPrintAlphaOrchPlanS.sFarmName, 
						  :frmPrintAlphaOrchPlanS.nRowNo, 
						  :frmPrintAlphaOrchPlanS.nSeqNo, 
						  :frmPrintAlphaOrchPlanS.sVariety, 
						  :frmPrintAlphaOrchPlanS.sVarietyType 
						WHERE 
						  scion_evaluation.stock_item_no = stock_item.item_no and
						  scion_evaluation.location_id = location.location_id
						ORDER BY 
						  variety_type,
						  variety,
						  cult_desc,
						  farm_name,
						  row#,
						  seq# "
				!
				If IDYES = SalMessageBox( 'Would you like to View the report first?', 'Brief alpha orchard plan', MB_YesNo )
					Set sReportType = 'VIEW'
				Else
					Set sReportType = 'PRINT'

		Functions
			Function: CalcHistOrdAmt
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Number: nYear
					Receive Number: nLastYearOrdAmt
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Number: nInd
					!
					Number: nGotLastYearOrdAmt
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETSCMPHISTORD' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									   SUM(Cust_Order_History.Ordered_Amount)
									FROM 
									  Cust_Order_History, 
									  Stock_Item
									WHERE 
									  Cust_Order_History.Cust_No = :1 AND 
									  Cust_Order_History.Year_Of_Sale = :2 AND 
									  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
									  NOT Stock_Item.Tree_Type LIKE 'C%' "
							Set sName = 'GETSCMPHISTORD'
							Set sBind = ':nCustNo, :nYear'
							Set sInto = ':nGotLastYearOrdAmt'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nLastYearOrdAmt = NUMBER_Null
							Set nGotLastYearOrdAmt = NUMBER_Null
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set nLastYearOrdAmt = nGotLastYearOrdAmt
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: CalcOrchTotalHistOrdAmt
				Description:
				Returns
					Boolean:
				Parameters
					Number: nYear
					Receive Number: nLastYearOrdAmt
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Number: nInd
					!
					Number: nGotLastYearOrdAmt
					Date/Time: dtDate
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'CALCORTOTHISORD' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									   SUM(Cust_Order_History.Ordered_Amount)
									FROM 
									  Customer_Master, 
									  Cust_Order_History, 
									  Stock_Item
									WHERE 
									  Customer_Master.Customer_Type LIKE '%OR%' AND 
									  Customer_Master.Cust_No = Cust_Order_History.Cust_No AND 
									  Cust_Order_History.Year_Of_Sale = :1 AND 
									  Cust_Order_History.Ord_Date <= :2 AND 
									  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
									  NOT Stock_Item.Tree_Type LIKE 'C%' "
							Set sName = 'CALCORTOTHISORD'
							Set sBind = ':nYear,:dtDate'
							Set sInto = ':nGotLastYearOrdAmt'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nLastYearOrdAmt = NUMBER_Null
							Set nGotLastYearOrdAmt = NUMBER_Null
							If nYear >= 50 AND nYear <= 99
								Set dtDate = SalDateConstruct( nYear + 1900, SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 0, 0, 0 )
							Else If nYear >= 0 AND nYear <= 49
								Set dtDate = SalDateConstruct( nYear + 2000, SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 0, 0, 0 )
							Else
								Set dtDate = SalDateConstruct( nYear, SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 0, 0, 0 )
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set nLastYearOrdAmt = nGotLastYearOrdAmt
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: CalcOrchTotalOrdAmt
				Description:
				Returns
					Boolean:
				Parameters
					Number: nYear
					Receive Number: nLastYearOrdAmt
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Number: nInd
					!
					Number: nGotLastYearOrdAmt
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'CALCORTOTORD' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									   SUM(Customer_Order.Ordered_Amount)
									FROM 
									  Customer_Master, 
									  Customer_Order, 
									  Stock_Item
									WHERE 
									  Customer_Master.Customer_Type LIKE '%OR%' AND 
									  Customer_Master.Cust_No = Customer_Order.Cust_No AND 
									  Customer_Order.Year_Of_Sale = :1 AND 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									  NOT Stock_Item.Tree_Type LIKE 'C%' "
							Set sName = 'CALCORTOTORD'
							Set sBind = ':nYear'
							Set sInto = ':nGotLastYearOrdAmt'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nLastYearOrdAmt = NUMBER_Null
							Set nGotLastYearOrdAmt = NUMBER_Null
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set nLastYearOrdAmt = nGotLastYearOrdAmt
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: CalcPercentageIncrease
				Description:
				Returns
					Number:
				Parameters
					Number: nLastYear
					Number: nThisYear
				Static Variables
				Local variables
				Actions
					If nLastYear = 0 OR nLastYear = NUMBER_Null
						Return 1
					Else
						Return ( nThisYear / nLastYear ) - 1
		Window Parameters
		Window Variables
			String: sSql
			Number: nInd
			!
			String: sReportFileName
			String: sReportBind
			String: sReportInto
			Number: nError
			Window Handle: hWndReport
			!
			: hSqlOrders
				Class: hcSqlHandle
			Number: nTotalOrders
			Number: nCountOrders
			!
			Number: nLastYear
			Number: nThisYear
			Date/Time: dtMinOrdDate
			Number: nCustNo
			String: sCustName
			Number: nLastYearOrdAmt
			Number: nThisYearOrdAmt
			Number: nSalesComp
			Number: nPercSalesComp
			!
			Number: nGCLastYearOrdAmtTotal
			Number: nGCThisYearOrdAmtTotal
			Number: nGCSalesCompTotal
			Number: nGCPercSalesCompTotal
			!
			Number: nORLastYearOrdAmtTotal
			Number: nORThisYearOrdAmtTotal
			Number: nORSalesCompTotal
			Number: nORPercSalesCompTotal
		Message Actions
			On SAM_CreateComplete
				Set rbPrint = FALSE
				Set hWndReport = hWndNULL
				Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
			On PAM_clsSALSCMPD_REPORT
				Call OurWaitCursor( TRUE )
				!
				Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\salscmp.qrp'
				Set sReportBind = ':frmCustSalesComp.nLastYear, 
						:frmCustSalesComp.nThisYear, 
						:frmCustSalesComp.dtMinOrdDate,
						:frmCustSalesComp.nCustNo,
						:frmCustSalesComp.sCustName,
						:frmCustSalesComp.nLastYearOrdAmt,
						:frmCustSalesComp.nThisYearOrdAmt,
						:frmCustSalesComp.nSalesComp,
						:frmCustSalesComp.nPercSalesComp,
						:frmCustSalesComp.nGCLastYearOrdAmtTotal,
						:frmCustSalesComp.nGCThisYearOrdAmtTotal,
						:frmCustSalesComp.nGCSalesCompTotal,
						:frmCustSalesComp.nGCPercSalesCompTotal,
						:frmCustSalesComp.nORLastYearOrdAmtTotal,
						:frmCustSalesComp.nORThisYearOrdAmtTotal,
						:frmCustSalesComp.nORSalesCompTotal,
						:frmCustSalesComp.nORPercSalesCompTotal'
				Set sReportInto = 'nLastYear, 
						nThisYear, 
						dtMinOrdDate,
						nCustNo,
						sCustName,
						nLastYearOrdAmt,
						nThisYearOrdAmt,
						nSalesComp,
						nPercSalesComp,
						nGCLastYearOrdAmtTotal,
						nGCThisYearOrdAmtTotal,
						nGCSalesCompTotal,
						nGCPercSalesCompTotal,
						nORLastYearOrdAmtTotal,
						nORThisYearOrdAmtTotal,
						nORSalesCompTotal,
						nORPercSalesCompTotal'
				Set nError = 1
				If rbView
					Set hWndReport = SalReportView( hWndForm, hWndNULL, sReportFileName, sReportBind, sReportInto, nError )
				Else
					Set hWndReport = SalReportPrint( hWndForm, sReportFileName, sReportBind, sReportInto, 1, RPT_PrintAll | RPT_PrintDraft, 0, 0, nError )
				Call OurWaitCursor( FALSE )
			On SAM_ReportStart
				Set nThisYear = ccSeasonYear.GetSeasonYear( )
				Set nLastYear = nThisYear-1
				If nLastYear <1997 AND nLastYear >1950
					Set nLastYear = nLastYear - 1900
				Set sSql = " SELECT 
						  Customer_Master.Cust_No, 
						  Customer_Master.Cust_Name, 
						  MIN(Customer_Order.Ord_Date), 
						  SUM(Customer_Order.Ordered_Amount)
						FROM 
						  Customer_Order, 
						  Customer_Master, 
						  Stock_Item
						WHERE 
						  Customer_Master.Customer_Type LIKE '%GC%' AND 
						  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
						  Customer_Order.Year_Of_Sale = :frmCustSalesComp.nThisYear AND 
						  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
						  NOT Stock_Item.Tree_Type LIKE 'C%'
						GROUP BY 
						  1,2
						ORDER BY 
						  3,1,2
						INTO 
						  :frmCustSalesComp.nCustNo,
						  :frmCustSalesComp.sCustName,
						  :frmCustSalesComp.dtMinOrdDate,
						  :frmCustSalesComp.nThisYearOrdAmt"
				Call hSqlOrders.PrepareSetup( sSql )
				Return TRUE
			On SAM_ReportFetchInit
				Set nGCLastYearOrdAmtTotal = 0
				Set nGCThisYearOrdAmtTotal = 0
				Set nGCSalesCompTotal = 0
				Set nGCPercSalesCompTotal = 0
				Set nORLastYearOrdAmtTotal = 0
				Set nORThisYearOrdAmtTotal = 0
				Set nORSalesCompTotal = 0
				Set nORPercSalesCompTotal = 0
				Call hSqlOrders.PrepareAndExecute( )
				Call hSqlOrders.ResultSetCount( nTotalOrders )
				Set nCountOrders = 0
				Return TRUE
			On SAM_ReportFetchNext
				If hSqlOrders.FetchNext( nInd )
					Set nCountOrders = nCountOrders + 1
					!
					Call CalcHistOrdAmt( nCustNo, nLastYear, nLastYearOrdAmt, SH_cls_Execute )
					Set nSalesComp = nThisYearOrdAmt - nLastYearOrdAmt
					Set nPercSalesComp =  CalcPercentageIncrease( nLastYearOrdAmt, nThisYearOrdAmt )
					!
					Set nGCLastYearOrdAmtTotal = nGCLastYearOrdAmtTotal + nLastYearOrdAmt
					Set nGCThisYearOrdAmtTotal = nGCThisYearOrdAmtTotal + nThisYearOrdAmt
					!
					If nCountOrders = nTotalOrders
						If SqlUser = 'WES'
							Set nGCSalesCompTotal = nGCThisYearOrdAmtTotal - nGCLastYearOrdAmtTotal
							Set nGCPercSalesCompTotal =  CalcPercentageIncrease( nGCLastYearOrdAmtTotal, nGCThisYearOrdAmtTotal )
							!
							Call CalcOrchTotalHistOrdAmt( nLastYear, nORLastYearOrdAmtTotal, SH_cls_Execute )
							Call CalcOrchTotalOrdAmt( nThisYear, nORThisYearOrdAmtTotal, SH_cls_Execute )
							Set nORSalesCompTotal = nORThisYearOrdAmtTotal - nORLastYearOrdAmtTotal
							Set nORPercSalesCompTotal =  CalcPercentageIncrease( nORLastYearOrdAmtTotal, nORThisYearOrdAmtTotal )
						Else
							Set nGCLastYearOrdAmtTotal = NUMBER_Null
							Set nGCThisYearOrdAmtTotal = NUMBER_Null
							Set nGCSalesCompTotal = NUMBER_Null
							Set nGCPercSalesCompTotal =  NUMBER_Null
							!
							Set nORLastYearOrdAmtTotal = NUMBER_Null
							Set nORThisYearOrdAmtTotal = NUMBER_Null
							Set nORSalesCompTotal = NUMBER_Null
							Set nORPercSalesCompTotal =  NUMBER_Null
					Return TRUE
				Else
					Return FALSE
			On SAM_ReportFinish
				Call SalShowWindow( hWndForm )
				Call SalBringWindowToTop( hWndForm )
				Return TRUE
			On SAM_Destroy
				Call hSqlOrders.Disconnect( )
				Call CalcHistOrdAmt( 0, 0, nLastYearOrdAmt, SH_cls_Disconnect )
				Call CalcOrchTotalHistOrdAmt( 0, nORLastYearOrdAmtTotal, SH_cls_Disconnect )
				Call CalcOrchTotalOrdAmt( 0, nORThisYearOrdAmtTotal, SH_cls_Disconnect )
				Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

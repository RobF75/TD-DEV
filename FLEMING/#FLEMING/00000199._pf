								  :frmRoyOwnerItem.sCultRootId, 
								  :frmRoyOwnerItem.sRepCultRootDesc,
								  :frmRoyOwnerItem.nRepFCNoOfTrees, 
								  :frmRoyOwnerItem.nRepRPNoOfTrees, 
								  :frmRoyOwnerItem.nRepNoFCRPNoOfTrees
								WHERE 
								  Royalties_Paid.Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate  AND 
								  Royalties_Paid.Cult_Root_Id IN ( " || sSelCultIdsList || " ) AND 
								  Royalties_Paid.Cult_Root_Type = 'C'  AND 
								  Royalties_Paid.Royalty_Owner_Id = Royalty_Owner.Royalty_Owner_Id 
								GROUP BY 
								  1,3,5,2,4 "
					     Else If cbSelectedRootstocks
						     Set sSql = " SELECT  
								  Royalties_Paid.Royalty_Owner_Id,
								  Royalty_Owner.Roy_Bus_Name, 
								  Royalties_Paid.Cult_Root_Type,
								  Royalties_Paid.Cult_Root_Id, 
								  Royalties_Paid.Cult_Root_Desc, 
								  SUM(@IF(@EXACT(Sale_Cat,'FC'),Royalties_Paid.Conf_Amt, 0)), 
								  SUM(@IF(@EXACT(Sale_Cat,'RP'),Royalties_Paid.Conf_Amt, 0)),
								  SUM(@IF(@EXACT(Sale_Cat,'FC'),0, 
								          @IF(@EXACT(Sale_Cat,'RP'),0,Royalties_Paid.Conf_Amt))) 
								FROM 
								  Royalties_Paid, 
								  Royalty_Owner  
								INTO 
								  :frmRoyOwnerItem.sRepRoyOwnerId, 
								  :frmRoyOwnerItem.sRepRoyOwnerBusName, 
								  :frmRoyOwnerItem.sCultRootType,
								  :frmRoyOwnerItem.sCultRootId, 
								  :frmRoyOwnerItem.sRepCultRootDesc,
								  :frmRoyOwnerItem.nRepFCNoOfTrees, 
								  :frmRoyOwnerItem.nRepRPNoOfTrees, 
								  :frmRoyOwnerItem.nRepNoFCRPNoOfTrees
								WHERE 
								  Royalties_Paid.Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate  AND 
								  Royalties_Paid.Cult_Root_Id IN ( " || sSelRootIdsList || " ) AND 
								  Royalties_Paid.Cult_Root_Type = 'R'  AND 
								  Royalties_Paid.Royalty_Owner_Id = Royalty_Owner.Royalty_Owner_Id 
								GROUP BY 
								  1,3,5,2,4 "
					     Else 
						     Set sSql = " SELECT  
								  Royalties_Paid.Royalty_Owner_Id, 
								  Royalty_Owner.Roy_Bus_Name, 
								  Royalties_Paid.Cult_Root_Type,
								  Royalties_Paid.Cult_Root_Id, 
								  Royalties_Paid.Cult_Root_Desc, 
								  SUM(@IF(@EXACT(Sale_Cat,'FC'),Royalties_Paid.Conf_Amt, 0)), 
								  SUM(@IF(@EXACT(Sale_Cat,'RP'),Royalties_Paid.Conf_Amt, 0)),
								  SUM(@IF(@EXACT(Sale_Cat,'FC'),0, 
								          @IF(@EXACT(Sale_Cat,'RP'),0,Royalties_Paid.Conf_Amt))) 
								FROM 
								  Royalties_Paid, 
								  Royalty_Owner  
								INTO 
								  :frmRoyOwnerItem.sRepRoyOwnerId, 
								  :frmRoyOwnerItem.sRepRoyOwnerBusName, 
								  :frmRoyOwnerItem.sCultRootType,
								  :frmRoyOwnerItem.sCultRootId, 
								  :frmRoyOwnerItem.sRepCultRootDesc,
								  :frmRoyOwnerItem.nRepFCNoOfTrees, 
								  :frmRoyOwnerItem.nRepRPNoOfTrees, 
								  :frmRoyOwnerItem.nRepNoFCRPNoOfTrees
								WHERE 
								  Royalties_Paid.Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate AND 
								  Royalties_Paid.Royalty_Owner_Id = Royalty_Owner.Royalty_Owner_Id 
								GROUP BY 
								  1,3,5,2,4 "
					     If NOT hSqlRoyalties.PrepareSetup( sSql )
						     Set bReportMsgReturn = FALSE
					!
					     Set bProcessResultSet = TRUE
					     Set bProcessGrandTotal = FALSE
					     Call SalTblReset( tblGrandTotals )
					!
					     If bReportMsgReturn
						     If NOT hSqlRoyalties.PrepareAndExecute( )
							     Set bReportMsgReturn = FALSE
				If nReportType = 1
					If cbSelectedRoyOwners
						If cbSelectedRoyPatents
							If sSelRoyPatentCultIdsList != '' AND sSelRoyPatentRootIdsList != ''
								Set sSql = " SELECT
										  Cult_Root_Type,
										  @UPPER(@TRIM(@REPLACE(Cult_Root_Desc,@SCAN(Cult_Root_Desc, @CHAR(39)),1,' '))),
										  Cult_Root_Desc,
										  Cust_Name,
										  Inv_No,
										  Royalty_Owner_Id,
										  Paid_Date_Time,
										  Cult_Root_Id,
										  Inv_Date,
										  Conf_Amt,
										  Cust_No,

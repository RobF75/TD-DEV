			Number: nReturn
		Message Actions
			On PAM_clsFRM_REPORT_Print
				If frmRoyOwnerItem.rbAudit
					Set nReturn = SalMessageBox( 'Will you be paying royalties from this report!', 'Royalties', MB_YesNoCancel )
					If nReturn = IDYES
						Call SalSendMsg( frmRoyOwnerItem.cbPayingRoyaltiesInReport, PAM_clsCB_SET, TRUE, 0 )
						Set frmRoyOwnerItem.rbPrint = TRUE
						Set frmRoyOwnerItem.rbView = FALSE
						Call SalSendMsg( frmRoyOwnerItem, PAM_clsOWNITM_REPORT, frmRoyOwnerItem.nReportType, 0 )
						Set frmRoyOwnerItem.rbView = TRUE
						Set frmRoyOwnerItem.rbPrint = FALSE
						Return SalSendMsg( hWndForm, PAM_clsFRM_REPORT_Close, 0, 0 )
					Else If nReturn = IDNO
						Return SalSendClassMessage( PAM_clsFRM_REPORT_Print, wParam, lParam )
					Else
						Return FALSE
				Else
					Return SalSendClassMessage( PAM_clsFRM_REPORT_Print, wParam, lParam )

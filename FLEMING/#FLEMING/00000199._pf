									  :frmRoyOwnerItem.nRoyPerItem,
									  :frmRoyOwnerItem.nStockItemNo,
									  :frmRoyOwnerItem.nAmtPaid,
									  :frmRoyOwnerItem.dtOrderDateTime,
									  :frmRoyOwnerItem.sRowId
									WHERE
									  Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate AND
									  Royalty_Owner_Id IN ( " || sSelRoyOwnerIdsList || ", 'FMN', 'FNA' ) AND
									  Cult_Root_Id IN
									  (
									    SELECT
									      @IF( @ISNA( Cultivar_Id ), Rootstock_Id, Cultivar_Id  )
									    FROM
									      Royalty_Payable
									    WHERE
									      Royalty_Owner_Id IN ( " || sSelRoyOwnerIdsList || " )
									  )
									ORDER BY 1 desc, 2 asc, 14 asc, 15 asc, 4 asc, 7 asc "
						! If cbSelectedRoyPatents
							     If sSelRoyPatentCultIdsList != '' AND sSelRoyPatentRootIdsList != ''
								     Set sSql = " SELECT
										  Cult_Root_Type,
										  @UPPER(@TRIM(@REPLACE(Cult_Root_Desc,@SCAN(Cult_Root_Desc, @CHAR(39)),1,' '))),
										  Cult_Root_Desc,
										  Cust_Name,

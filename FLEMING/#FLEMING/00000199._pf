				Functions
				Window Variables
					Number: nRow
					String: sNewOwnerId
					String: sNewRoyBusName
					Number: nNewTotalDue
					Boolean: bFound
				Message Actions
					On PAM_OWNITM_ADDROYOWNRTOTAL
						Call PopNumber( nNewTotalDue, TRUE )
						Call PopString( sNewRoyBusName, TRUE )
						Call PopString( sNewOwnerId, TRUE )
						If sNewOwnerId != 'FMN' AND sNewOwnerId != 'FNA'
							Set sNewOwnerId = 'OS'
							Set sNewRoyBusName = 'Overseas Total'
						!
						Set bFound = FALSE
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( hWndForm, nRow, 0, 0 ) AND NOT bFound
							Call SalTblSetContext( hWndForm, nRow )
							If colRoyOwnerId = sNewOwnerId
								Set colTotalDue = colTotalDue + nNewTotalDue
								Set bFound = TRUE
						If NOT bFound
							Set bFound = FALSE
							Set nRow = TBL_MinRow
							While NOT bFound AND SalTblFindNextRow( hWndForm, nRow, 0, 0 )
								Call SalTblSetContext( hWndForm, nRow )
								If sNewRoyBusName <= colRoyBusName
									Set bFound = TRUE
							!
							If nRow = TBL_MinRow
								Set nRow = TBL_MaxRow
							!
							If bFound
								Set nRow = SalTblInsertRow( hWndForm, nRow )
							Else
								Set nRow = SalTblInsertRow( hWndForm, nRow + 1 )
							Call SalTblSetContext( hWndForm, nRow )
							!
							Set colRoyOwnerId = sNewOwnerId
							Set colRoyBusName = sNewRoyBusName
							Set colTotalDue = nNewTotalDue
						Return TRUE
			!

			Contents
				Pushbutton: pbCreateRoyaltiesPaid
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Roy.Paid
					Window Location and Size
						Left:   2.238"
						Top:    0.0"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default

								  :frmRoyOwnerItem.sRowId
								WHERE
								  Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate AND
								  Cult_Root_Id IN ( " || sSelCultIdsList || " ) AND
								  Cult_Root_Type = 'C'
								ORDER BY 1 desc, 2 asc, 14 asc, 15 asc, 4 asc, 7 asc "
					Else If cbSelectedRootstocks
						Set sSql = " SELECT
								  Cult_Root_Type,
								  @UPPER(@TRIM(@REPLACE(Cult_Root_Desc,@SCAN(Cult_Root_Desc, @CHAR(39)),1,' '))),
								  Cult_Root_Desc,
								  Cust_Name,
								  Inv_No,
								  Royalty_Owner_Id,
								  Paid_Date_Time,
								  Cult_Root_Id,
								  Inv_Date,
								  Conf_Amt,
								  Cust_No,
								  Sale_Cat,
								  Tree_Type_Desc,
								  Cult_Desc,
								  Root_Desc,
								  Roy_Per_Item,
								  Stock_Item_No,
								  Amt_Paid,
								  Order_Date_Time,
								  ROWID
								FROM
								  Royalties_Paid
								INTO
								  :frmRoyOwnerItem.sCultRootType,
								  :frmRoyOwnerItem.sUpperCultRootDesc,
								  :frmRoyOwnerItem.sCultRootDesc,
								  :frmRoyOwnerItem.sCustName,
								  :frmRoyOwnerItem.nInvoiceNo,
								  :frmRoyOwnerItem.sRoyOwnerId,
								  :frmRoyOwnerItem.dtPaidDate,
								  :frmRoyOwnerItem.sCultRootId,
								  :frmRoyOwnerItem.dtInvoicedDate,
								  :frmRoyOwnerItem.nConfAmt,
								  :frmRoyOwnerItem.nCustNo,
								  :frmRoyOwnerItem.sSaleCat,
								  :frmRoyOwnerItem.sTreeTypeDesc,
								  :frmRoyOwnerItem.sCultDesc,
								  :frmRoyOwnerItem.sRootDesc,
								  :frmRoyOwnerItem.nRoyPerItem,
								  :frmRoyOwnerItem.nStockItemNo,
								  :frmRoyOwnerItem.nAmtPaid,
								  :frmRoyOwnerItem.dtOrderDateTime,
								  :frmRoyOwnerItem.sRowId
								WHERE
								  Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate AND
								  Cult_Root_Id IN ( " || sSelRootIdsList || " ) AND
								  Cult_Root_Type = 'R'
								ORDER BY 1 desc, 2 asc, 14 asc, 15 asc, 4 asc, 7 asc "
					Else
						Set sSql = " SELECT
								  Cult_Root_Type,
								  @UPPER(@TRIM(@REPLACE(Cult_Root_Desc,@SCAN(Cult_Root_Desc, @CHAR(39)),1,' '))),
								  Cult_Root_Desc,
								  Cust_Name,
								  Inv_No,
								  Royalty_Owner_Id,
								  Paid_Date_Time,
								  Cult_Root_Id,
								  Inv_Date,
								  Conf_Amt,
								  Cust_No,
								  Sale_Cat,
								  Tree_Type_Desc,
								  Cult_Desc,
								  Root_Desc,
								  Roy_Per_Item,
								  Stock_Item_No,
								  Amt_Paid,
								  Order_Date_Time,
								  ROWID
								FROM
								  Royalties_Paid
								INTO
								  :frmRoyOwnerItem.sCultRootType,
								  :frmRoyOwnerItem.sUpperCultRootDesc,
								  :frmRoyOwnerItem.sCultRootDesc,
								  :frmRoyOwnerItem.sCustName,
								  :frmRoyOwnerItem.nInvoiceNo,
								  :frmRoyOwnerItem.sRoyOwnerId,
								  :frmRoyOwnerItem.dtPaidDate,
								  :frmRoyOwnerItem.sCultRootId,
								  :frmRoyOwnerItem.dtInvoicedDate,
								  :frmRoyOwnerItem.nConfAmt,
								  :frmRoyOwnerItem.nCustNo,
								  :frmRoyOwnerItem.sSaleCat,
								  :frmRoyOwnerItem.sTreeTypeDesc,
								  :frmRoyOwnerItem.sCultDesc,
								  :frmRoyOwnerItem.sRootDesc,
								  :frmRoyOwnerItem.nRoyPerItem,
								  :frmRoyOwnerItem.nStockItemNo,
								  :frmRoyOwnerItem.nAmtPaid,
								  :frmRoyOwnerItem.dtOrderDateTime,
								  :frmRoyOwnerItem.sRowId
								WHERE
								  Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate
								ORDER BY 1 desc, 2 asc, 14 asc, 15 asc, 4 asc, 7 asc "
					Call hSqlRoyalties.RePrepare( )
					If NOT hSqlRoyalties.PrepareSetup( sSql )
						Set bReportMsgReturn = FALSE
					!
					Set bProcessResultSet = TRUE
					Set bProcessSummaryTotal = FALSE
					Set bProcessGrandTotal = FALSE
					Call SalTblReset( tblSummaryTotals )
					Call SalTblReset( tblGrandTotals )
					!
					Set nOwnerPos = 0
					Set bOk = TRUE
					Set bFirst = TRUE
					Set bLast = FALSE
					Set sLastCultRootId = ''
					Set sLastUpperCultRootDesc = ''
					Set sLastCultDesc = ''
					Set sLastRootDesc = ''
					Set sLastCustName = ''
					Set nLastConfAmt = NUMBER_Null
					Set sLastSaleCat = ''
					Set nLastStockItemNo = NUMBER_Null
					Set dtLastOrderDateTime = DATETIME_Null
					!
					If bReportMsgReturn
						If NOT hSqlRoyalties.PrepareAndExecute( )
							Set bReportMsgReturn = FALSE
				Else
					If cbSelectedRoyOwners
						If cbSelectedRoyPatents
							If sSelRoyPatentCultIdsList != '' AND sSelRoyPatentRootIdsList != ''
								Set sSql = " SELECT
										  Royalties_Paid.Royalty_Owner_Id,
										  Royalty_Owner.Roy_Bus_Name,
										  Royalties_Paid.Cult_Root_Type,
										  Royalties_Paid.Cult_Root_Id,
										  Royalties_Paid.Cult_Root_Desc,
										  SUM(@IF(@EXACT(Sale_Cat,'FC'),Royalties_Paid.Conf_Amt, 0)),
										  SUM(@IF(@EXACT(Sale_Cat,'RP'),Royalties_Paid.Conf_Amt, 0)),
										  SUM(@IF(@EXACT(Sale_Cat,'FC'),0,
										          @IF(@EXACT(Sale_Cat,'RP'),0,Royalties_Paid.Conf_Amt))),
										  SUM( Royalties_Paid.Amt_Paid )
										FROM
										  Royalties_Paid,
										  Royalty_Owner
										INTO
										  :frmRoyOwnerItem.sRepRoyOwnerId,
										  :frmRoyOwnerItem.sRepRoyOwnerBusName,
										  :frmRoyOwnerItem.sCultRootType,
										  :frmRoyOwnerItem.sCultRootId,
										  :frmRoyOwnerItem.sRepCultRootDesc,
										  :frmRoyOwnerItem.nRepFCNoOfTrees,
										  :frmRoyOwnerItem.nRepRPNoOfTrees,
										  :frmRoyOwnerItem.nRepNoFCRPNoOfTrees,
										  :frmRoyOwnerItem.nRepRoyPaidPerTree
										WHERE
										  Royalties_Paid.Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate  AND
										  Royalties_Paid.Royalty_Owner_Id IN ( " || sSelRoyOwnerIdsList || " )  AND
										  Cult_Root_Id IN ( " || sSelRoyPatentCultIdsList || ", " || sSelRoyPatentRootIdsList || " ) AND
										  Royalties_Paid.Royalty_Owner_Id = Royalty_Owner.Royalty_Owner_Id
										GROUP BY
										  1,3,5,2,4 "
							Else If sSelRoyPatentCultIdsList != ''
								Set sSql = " SELECT
										  Royalties_Paid.Royalty_Owner_Id,
										  Royalty_Owner.Roy_Bus_Name,
										  Royalties_Paid.Cult_Root_Type,
										  Royalties_Paid.Cult_Root_Id,
										  Royalties_Paid.Cult_Root_Desc,
										  SUM(@IF(@EXACT(Sale_Cat,'FC'),Royalties_Paid.Conf_Amt, 0)),
										  SUM(@IF(@EXACT(Sale_Cat,'RP'),Royalties_Paid.Conf_Amt, 0)),
										  SUM(@IF(@EXACT(Sale_Cat,'FC'),0,
										          @IF(@EXACT(Sale_Cat,'RP'),0,Royalties_Paid.Conf_Amt))),
										  SUM( Royalties_Paid.Amt_Paid )
										FROM
										  Royalties_Paid,
										  Royalty_Owner
										INTO
										  :frmRoyOwnerItem.sRepRoyOwnerId,
										  :frmRoyOwnerItem.sRepRoyOwnerBusName,
										  :frmRoyOwnerItem.sCultRootType,
										  :frmRoyOwnerItem.sCultRootId,
										  :frmRoyOwnerItem.sRepCultRootDesc,
										  :frmRoyOwnerItem.nRepFCNoOfTrees,
										  :frmRoyOwnerItem.nRepRPNoOfTrees,
										  :frmRoyOwnerItem.nRepNoFCRPNoOfTrees,
										  :frmRoyOwnerItem.nRepRoyPaidPerTree
										WHERE
										  Royalties_Paid.Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate  AND
										  Royalties_Paid.Royalty_Owner_Id IN ( " || sSelRoyOwnerIdsList || " )  AND
										  Royalties_Paid.Royalty_Owner_Id = Royalty_Owner.Royalty_Owner_Id AND
										  Cult_Root_Type = 'C' AND
										  Cult_Root_Id IN ( " || sSelRoyPatentCultIdsList || " )
										GROUP BY
										  1,3,5,2,4 "
							Else
								Set sSql = " SELECT
										  Royalties_Paid.Royalty_Owner_Id,
										  Royalty_Owner.Roy_Bus_Name,
										  Royalties_Paid.Cult_Root_Type,
										  Royalties_Paid.Cult_Root_Id,
										  Royalties_Paid.Cult_Root_Desc,
										  SUM(@IF(@EXACT(Sale_Cat,'FC'),Royalties_Paid.Conf_Amt, 0)),
										  SUM(@IF(@EXACT(Sale_Cat,'RP'),Royalties_Paid.Conf_Amt, 0)),
										  SUM(@IF(@EXACT(Sale_Cat,'FC'),0,
										          @IF(@EXACT(Sale_Cat,'RP'),0,Royalties_Paid.Conf_Amt))),
										  SUM( Royalties_Paid.Amt_Paid )
										FROM
										  Royalties_Paid,
										  Royalty_Owner
										INTO
										  :frmRoyOwnerItem.sRepRoyOwnerId,
										  :frmRoyOwnerItem.sRepRoyOwnerBusName,
										  :frmRoyOwnerItem.sCultRootType,
										  :frmRoyOwnerItem.sCultRootId,
										  :frmRoyOwnerItem.sRepCultRootDesc,
										  :frmRoyOwnerItem.nRepFCNoOfTrees,
										  :frmRoyOwnerItem.nRepRPNoOfTrees,
										  :frmRoyOwnerItem.nRepNoFCRPNoOfTrees,
										  :frmRoyOwnerItem.nRepRoyPaidPerTree
										WHERE
										  Royalties_Paid.Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate  AND
										  Royalties_Paid.Royalty_Owner_Id IN ( " || sSelRoyOwnerIdsList || " )  AND
										  Royalties_Paid.Royalty_Owner_Id = Royalty_Owner.Royalty_Owner_Id AND
										  Cult_Root_Type = 'R' AND
										  Cult_Root_Id IN ( " || sSelRoyPatentRootIdsList || " )
										GROUP BY
										  1,3,5,2,4 "
						Else
							Set sSql = " SELECT
									  Royalties_Paid.Royalty_Owner_Id,
									  Royalty_Owner.Roy_Bus_Name,
									  Royalties_Paid.Cult_Root_Type,
									  Royalties_Paid.Cult_Root_Id,
									  Royalties_Paid.Cult_Root_Desc,
									  SUM(@IF(@EXACT(Sale_Cat,'FC'),Royalties_Paid.Conf_Amt, 0)),
									  SUM(@IF(@EXACT(Sale_Cat,'RP'),Royalties_Paid.Conf_Amt, 0)),
									  SUM(@IF(@EXACT(Sale_Cat,'FC'),0,
									          @IF(@EXACT(Sale_Cat,'RP'),0,Royalties_Paid.Conf_Amt))),
									  SUM( Royalties_Paid.Amt_Paid )
									FROM
									  Royalties_Paid,
									  Royalty_Owner
									INTO
									  :frmRoyOwnerItem.sRepRoyOwnerId,
									  :frmRoyOwnerItem.sRepRoyOwnerBusName,
									  :frmRoyOwnerItem.sCultRootType,
									  :frmRoyOwnerItem.sCultRootId,
									  :frmRoyOwnerItem.sRepCultRootDesc,
									  :frmRoyOwnerItem.nRepFCNoOfTrees,
									  :frmRoyOwnerItem.nRepRPNoOfTrees,
									  :frmRoyOwnerItem.nRepNoFCRPNoOfTrees,
									  :frmRoyOwnerItem.nRepRoyPaidPerTree
									WHERE
									  Royalties_Paid.Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate  AND
									  Royalties_Paid.Royalty_Owner_Id IN ( " || sSelRoyOwnerIdsList || " )  AND
									  Royalties_Paid.Royalty_Owner_Id = Royalty_Owner.Royalty_Owner_Id
									GROUP BY
									  1,3,5,2,4 "
					Else If cbSelectedCultivars
						Set sSql = " SELECT
								  Royalties_Paid.Royalty_Owner_Id,
								  Royalty_Owner.Roy_Bus_Name,
								  Royalties_Paid.Cult_Root_Type,
								  Royalties_Paid.Cult_Root_Id,
								  Royalties_Paid.Cult_Root_Desc,
								  SUM(@IF(@EXACT(Sale_Cat,'FC'),Royalties_Paid.Conf_Amt, 0)),
								  SUM(@IF(@EXACT(Sale_Cat,'RP'),Royalties_Paid.Conf_Amt, 0)),
								  SUM(@IF(@EXACT(Sale_Cat,'FC'),0,
								          @IF(@EXACT(Sale_Cat,'RP'),0,Royalties_Paid.Conf_Amt))),
								  SUM( Royalties_Paid.Amt_Paid )
								FROM
								  Royalties_Paid,
								  Royalty_Owner
								INTO
								  :frmRoyOwnerItem.sRepRoyOwnerId,
								  :frmRoyOwnerItem.sRepRoyOwnerBusName,
								  :frmRoyOwnerItem.sCultRootType,
								  :frmRoyOwnerItem.sCultRootId,
								  :frmRoyOwnerItem.sRepCultRootDesc,
								  :frmRoyOwnerItem.nRepFCNoOfTrees,
								  :frmRoyOwnerItem.nRepRPNoOfTrees,
								  :frmRoyOwnerItem.nRepNoFCRPNoOfTrees,
								  :frmRoyOwnerItem.nRepRoyPaidPerTree
								WHERE
								  Royalties_Paid.Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate  AND
								  Royalties_Paid.Cult_Root_Id IN ( " || sSelCultIdsList || " ) AND
								  Royalties_Paid.Cult_Root_Type = 'C'  AND
								  Royalties_Paid.Royalty_Owner_Id = Royalty_Owner.Royalty_Owner_Id
								GROUP BY
								  1,3,5,2,4 "
					Else If cbSelectedRootstocks
						Set sSql = " SELECT
								  Royalties_Paid.Royalty_Owner_Id,
								  Royalty_Owner.Roy_Bus_Name,
								  Royalties_Paid.Cult_Root_Type,
								  Royalties_Paid.Cult_Root_Id,
								  Royalties_Paid.Cult_Root_Desc,
								  SUM(@IF(@EXACT(Sale_Cat,'FC'),Royalties_Paid.Conf_Amt, 0)),
								  SUM(@IF(@EXACT(Sale_Cat,'RP'),Royalties_Paid.Conf_Amt, 0)),
								  SUM(@IF(@EXACT(Sale_Cat,'FC'),0,
								          @IF(@EXACT(Sale_Cat,'RP'),0,Royalties_Paid.Conf_Amt))),
								  SUM( Royalties_Paid.Amt_Paid )
								FROM
								  Royalties_Paid,
								  Royalty_Owner
								INTO
								  :frmRoyOwnerItem.sRepRoyOwnerId,
								  :frmRoyOwnerItem.sRepRoyOwnerBusName,
								  :frmRoyOwnerItem.sCultRootType,
								  :frmRoyOwnerItem.sCultRootId,
								  :frmRoyOwnerItem.sRepCultRootDesc,
								  :frmRoyOwnerItem.nRepFCNoOfTrees,
								  :frmRoyOwnerItem.nRepRPNoOfTrees,
								  :frmRoyOwnerItem.nRepNoFCRPNoOfTrees,
								  :frmRoyOwnerItem.nRepRoyPaidPerTree
								WHERE
								  Royalties_Paid.Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate  AND
								  Royalties_Paid.Cult_Root_Id IN ( " || sSelRootIdsList || " ) AND
								  Royalties_Paid.Cult_Root_Type = 'R'  AND
								  Royalties_Paid.Royalty_Owner_Id = Royalty_Owner.Royalty_Owner_Id
								GROUP BY
								  1,3,5,2,4 "
					Else
						Set sSql = " SELECT
								  Royalties_Paid.Royalty_Owner_Id,
								  Royalty_Owner.Roy_Bus_Name,
								  Royalties_Paid.Cult_Root_Type,
								  Royalties_Paid.Cult_Root_Id,
								  Royalties_Paid.Cult_Root_Desc,
								  SUM(@IF(@EXACT(Sale_Cat,'FC'),Royalties_Paid.Conf_Amt, 0)),
								  SUM(@IF(@EXACT(Sale_Cat,'RP'),Royalties_Paid.Conf_Amt, 0)),
								  SUM(@IF(@EXACT(Sale_Cat,'FC'),0,
								          @IF(@EXACT(Sale_Cat,'RP'),0,Royalties_Paid.Conf_Amt))),
								  SUM( Royalties_Paid.Amt_Paid )
								FROM
								  Royalties_Paid,
								  Royalty_Owner
								INTO
								  :frmRoyOwnerItem.sRepRoyOwnerId,
								  :frmRoyOwnerItem.sRepRoyOwnerBusName,
								  :frmRoyOwnerItem.sCultRootType,
								  :frmRoyOwnerItem.sCultRootId,
								  :frmRoyOwnerItem.sRepCultRootDesc,
								  :frmRoyOwnerItem.nRepFCNoOfTrees,
								  :frmRoyOwnerItem.nRepRPNoOfTrees,
								  :frmRoyOwnerItem.nRepNoFCRPNoOfTrees,
								  :frmRoyOwnerItem.nRepRoyPaidPerTree
								WHERE
								  Royalties_Paid.Inv_Date BETWEEN :frmRoyOwnerItem.dfFromDate AND :frmRoyOwnerItem.dfToDate AND
								  Royalties_Paid.Royalty_Owner_Id = Royalty_Owner.Royalty_Owner_Id
								GROUP BY
								  1,3,5,2,4 "
					Call hSqlRoyalties.RePrepare( )
					If NOT hSqlRoyalties.PrepareSetup( sSql )
						Set bReportMsgReturn = FALSE
					!
					Set bProcessResultSet = TRUE
					Set bProcessGrandTotal = FALSE
					Call SalTblReset( tblGrandTotals )
					!
					If bReportMsgReturn
						If NOT hSqlRoyalties.PrepareAndExecute( )
							Set bReportMsgReturn = FALSE
				!
				If bPayRoyaltiesPaid
					Set sPayOrInfo = 'This is the final listing that these records will appear on.  Please file away safely.'
					Call fcRoyaltiesPaidPkFile.Setup( 'c:\\temp\\roypaid.tmp', NUMBER_Null, NUMBER_Null )
					If NOT fcRoyaltiesPaidPkFile.Open( )
						Set bReportMsgReturn = FALSE
					Set nNoInRoyaltiesPaidFile = 0
				Else
					Set sPayOrInfo = 'Informational copy only should NOT be used to pay from.  As files need to be cleared.'
				Return bReportMsgReturn
			On SAM_ReportFetchNext
				If nReportType = 1
					Call ResetReportFields( nReportType )
					Loop
						If bProcessResultSet
							If bOk
								If hSqlRoyalties.FetchNext( nInd )
									!
									If bPayRoyaltiesPaid
										Call fcRoyaltiesPaidPkFile.Write( sRowId )
										Set nNoInRoyaltiesPaidFile = nNoInRoyaltiesPaidFile + 1
									!
									Set bOk = TRUE
								Else
									Set bOk = FALSE
									Set bLast = TRUE
							Else
								Set bProcessResultSet = FALSE
								Set bProcessSummaryTotal = TRUE
								Set nTotalRow = TBL_MinRow
							!
							If bOk OR bLast
								If ( sLastCultRootId = sCultRootId AND 
										     sLastUpperCultRootDesc = sUpperCultRootDesc AND 
										     sLastCultDesc = sCultDesc AND 
										     sLastRootDesc = sRootDesc AND 
										     sLastCustName = sCustName AND 
										     nLastConfAmt = nConfAmt AND 
										     sLastSaleCat = sSaleCat AND 
										     nLastStockItemNo = nStockItemNo AND 
										     dtLastOrderDateTime = dtOrderDateTime AND 
										     NOT bLast ) OR bFirst
									If bFirst
										Set bFirst = FALSE
										Set sLastCultRootId = sCultRootId
										Set sLastUpperCultRootDesc = sUpperCultRootDesc
										Set sLastCultDesc = sCultDesc
										Set sLastRootDesc = sRootDesc
										Set sLastCustName = sCustName
										Set nLastConfAmt = nConfAmt
										Set sLastSaleCat = sSaleCat
										Set nLastStockItemNo = nStockItemNo
										Set dtLastOrderDateTime = dtOrderDateTime
									Set bLast = FALSE
									!
									Set nOwnerPos = nOwnerPos + 1
									If nOwnerPos = 1
										Set sOwner1Head = sRoyOwnerId
										Set sOwner2Head = ''
										Set sOwner3Head = ''
										Set nOwner1AmtPaid = nAmtPaid
										Set nOwner2AmtPaid = NUMBER_Null
										Set nOwner3AmtPaid = NUMBER_Null
									Else If nOwnerPos = 2
										Set sOwner2Head = sRoyOwnerId
										Set sOwner3Head = ''
										Set nOwner2AmtPaid = nAmtPaid
										Set nOwner3AmtPaid = NUMBER_Null
									Else
										Set sOwner3Head = sRoyOwnerId
										Set nOwner3AmtPaid = nAmtPaid
									!
									Set sPrevCultRootType = sCultRootType
									Set sPrevUpperCultRootDesc = sUpperCultRootDesc
									Set sPrevCultRootDesc = sCultRootDesc
									Set sPrevCustName = sCustName
									Set nPrevInvoiceNo = nInvoiceNo
									Set dtPrevPaidDate = dtPaidDate
									Set sPrevCultRootId = sCultRootId
									Set dtPrevInvoicedDate = dtInvoicedDate
									Set nPrevConfAmt = nConfAmt
									Set nPrevCustNo = nCustNo
									Set sPrevSaleCat = sSaleCat
									Set sPrevTreeTypeDesc = sTreeTypeDesc
									Set sPrevCultDesc = sCultDesc
									Set sPrevRootDesc = sRootDesc
									Set nPrevRoyPerItem = nRoyPerItem
									Set nPrevStockItemNo = nStockItemNo
									Set nPrevAmtPaid = nAmtPaid
									Set dtPrevOrderDateTime = dtOrderDateTime
								Else
									Set bLast = FALSE
									! Set Report Fields
									Set sRepCultRootType = sPrevCultRootType
									Set sRepCultRootDesc = sPrevCultRootDesc
									Set sRepCustName = sPrevCustName
									Set nRepInvoiceNo = nPrevInvoiceNo
									Set dtRepPaidDate = dtPrevPaidDate
									Set sRepCultRootId = sPrevCultRootId
									Set dtRepInvoicedDate = dtPrevInvoicedDate
									Set nRepConfAmt = nPrevConfAmt
									Set nRepCustNo = nPrevCustNo
									Set sRepSaleCat = sPrevSaleCat
									Set sRepTreeTypeDesc = sPrevTreeTypeDesc
									Set sRepCultDesc = sPrevCultDesc
									Set sRepRootDesc = sPrevRootDesc
									Set nRepRoyPerItem = nPrevRoyPerItem
									Set nRepStockItemNo = nPrevStockItemNo
									Set nRepAmtPaid = nPrevAmtPaid
									!
									Select Case WhichPosIsntFNAorFMNRoyOwner( sOwner1Head, sOwner2Head, sOwner2Head )
										Case 1
											Set sRepOwner1Head = sOwner1Head
											Set nRepOwner1AmtPaid = nOwner1AmtPaid
											Break
										Case 2
											Set sRepOwner1Head = sOwner2Head
											Set nRepOwner1AmtPaid = nOwner2AmtPaid
											Break
										Case 3
											Set sRepOwner1Head = sOwner3Head
											Set nRepOwner1AmtPaid = nOwner3AmtPaid
											Break
										Default
											Set sRepOwner1Head = ''
											Set nRepOwner1AmtPaid = NUMBER_Null
									Select Case WhichPosIsRoyOwner( 'FMN', sOwner1Head, sOwner2Head, sOwner3Head )
										Case 1
											Set sRepOwner2Head = sOwner1Head
											Set nRepOwner2AmtPaid = nOwner1AmtPaid
											Break
										Case 2
											Set sRepOwner2Head = sOwner2Head
											Set nRepOwner2AmtPaid = nOwner2AmtPaid
											Break
										Case 3
											Set sRepOwner2Head = sOwner3Head
											Set nRepOwner2AmtPaid = nOwner3AmtPaid
											Break
										Default
											Set sRepOwner2Head = ''
											Set nRepOwner2AmtPaid = NUMBER_Null
									Select Case WhichPosIsRoyOwner( 'FNA', sOwner1Head, sOwner2Head, sOwner3Head )
										Case 1
											Set sRepOwner3Head = sOwner1Head
											Set nRepOwner3AmtPaid = nOwner1AmtPaid
											Break
										Case 2
											Set sRepOwner3Head = sOwner2Head
											Set nRepOwner3AmtPaid = nOwner2AmtPaid
											Break
										Case 3
											Set sRepOwner3Head = sOwner3Head
											Set nRepOwner3AmtPaid = nOwner3AmtPaid
											Break
										Default
											Set sRepOwner3Head = ''
											Set nRepOwner3AmtPaid = NUMBER_Null
									!
									Set sRepOwner123Head = sRepOwner1Head || sRepOwner2Head || sRepOwner3Head
									!
									Call KeepRoyOwnersTotals( tblSummaryTotals, sOwner1Head, '', nOwner1AmtPaid )
									Call KeepRoyOwnersTotals( tblSummaryTotals, sOwner2Head, '', nOwner2AmtPaid )
									Call KeepRoyOwnersTotals( tblSummaryTotals, sOwner3Head, '', nOwner3AmtPaid )
									!
									Set nOwnerPos = 1
									Set sOwner1Head = sRoyOwnerId
									Set sOwner2Head = ''
									Set sOwner3Head = ''
									Set nOwner1AmtPaid = nAmtPaid
									Set nOwner2AmtPaid = NUMBER_Null
									Set nOwner3AmtPaid = NUMBER_Null
									!
									Set sLastCultRootId = sCultRootId
									Set sLastUpperCultRootDesc = sUpperCultRootDesc
									Set sLastCultDesc = sCultDesc
									Set sLastRootDesc = sRootDesc
									Set sLastCustName = sCustName
									Set nLastConfAmt = nConfAmt
									Set sLastSaleCat = sSaleCat
									Set nLastStockItemNo = nStockItemNo
									Set dtLastOrderDateTime = dtOrderDateTime
									Return TRUE
						If bProcessSummaryTotal
							If nTotalRow = TBL_MinRow
								Set sRepTotalOwnerHead = '
										SUMMARY TOTAL Royalty Owners
										'
								Set sRepTotalTotalDueHead = '
										Total Due
										'
							If SalTblFindNextRow( tblSummaryTotals, nTotalRow, 0, 0 )
								Call SalTblSetContext( tblSummaryTotals, nTotalRow )
								Set sRepTotalOwner = tblSummaryTotals.colRoyOwnerId
								Set sRepTotalOwnerBusName = tblSummaryTotals.colRoyBusName
								Set nRepTotalTotalDue = tblSummaryTotals.colTotalDue
								!
								Call KeepRoyOwnersTotals( tblGrandTotals, sRepTotalOwner, sRepTotalOwnerBusName, nRepTotalTotalDue )
								Return TRUE
							Else
								Set bProcessSummaryTotal = FALSE
								Set bProcessGrandTotal = TRUE
								Set nTotalRow = TBL_MinRow
						If bProcessGrandTotal
							If nTotalRow = TBL_MinRow
								Set sRepTotalOwnerHead = '
										GRAND TOTAL Royalty Owners
										'
								Set sRepTotalTotalDueHead = '
										Total Due
										'
							If SalTblFindNextRow( tblGrandTotals, nTotalRow, 0, 0 )
								Call SalTblSetContext( tblGrandTotals, nTotalRow )
								Set sRepTotalOwner = tblGrandTotals.colRoyOwnerId
								Set sRepTotalOwnerBusName = tblGrandTotals.colRoyBusName
								Set nRepTotalTotalDue = tblGrandTotals.colTotalDue
								Return TRUE
							Else
								Return FALSE
				Else
					Call ResetReportFields( nReportType )
					Loop
						If bProcessResultSet
							If hSqlRoyalties.FetchNext( nInd )
								!
								If bPayRoyaltiesPaid
									Call fcRoyaltiesPaidPkFile.Write( sRowId )
									Set nNoInRoyaltiesPaidFile = nNoInRoyaltiesPaidFile + 1
								!
								Call GetCultRootRoyPerItem( sCultRootType, sCultRootId, sRepRoyOwnerId, nRepRoyPerTree, nRepRoyPercPerTree, SH_cls_Execute )
								Call KeepRoyOwnersTotals( tblGrandTotals, sRepRoyOwnerId, sRepRoyOwnerBusName, nRepRoyPaidPerTree )
								Return TRUE
							Else
								Set bProcessResultSet = FALSE
								Set bProcessGrandTotal = TRUE
								Set nTotalRow = TBL_MinRow
						If bProcessGrandTotal
							If nTotalRow = TBL_MinRow
								Set sRepTotalOwnerHead = '
										TOTAL Royalty Owners
										'
								Set sRepTotalTotalDueHead = '
										Approx. Total Due
										'
							If SalTblFindNextRow( tblGrandTotals, nTotalRow, 0, 0 )
								Call SalTblSetContext( tblGrandTotals, nTotalRow )
								Set sRepTotalOwner = tblGrandTotals.colRoyOwnerId
								Set sRepTotalOwnerBusName = tblGrandTotals.colRoyBusName
								Set nRepTotalTotalDue = tblGrandTotals.colTotalDue
								Return TRUE
							Else
								Return FALSE
			On SAM_ReportFinish
				If bPayRoyaltiesPaid
					Call fcRoyaltiesPaidPkFile.Seek( 0, FILE_SeekBegin )
					Call hMeterBar.Setup( 'Clearing Royalties Paid.', nNoInRoyaltiesPaidFile )
					While fcRoyaltiesPaidPkFile.Read( sTmp )
						If DeleteRoyaltiesPaid( sTmp, SH_cls_Execute )
							Call DeleteRoyaltiesPaid( '', SH_cls_Commit )
						Call hMeterBar.Increment( 1 )
					Call hMeterBar.End( )
					Call fcRoyaltiesPaidPkFile.Close( )
					Set bPayRoyaltiesPaid = FALSE
				!
				Call SalShowWindow( hWndForm )
				Call SalBringWindowToTop( hWndForm )
				!
				Set hWndReport = hWndNULL
				Return TRUE
			On SAM_Destroy
				Call hSqlRoyalties.Disconnect( )
				Call GetRoyOwnerBusName( '', sRepRoyOwnerBusName, SH_cls_Disconnect )
				Call GetCultRootRoyPerItem( '', '', '', nRepRoyPerTree, nRepRoyPercPerTree, SH_cls_Disconnect )
				Call CreateRoyaltiesPaidTable( DATETIME_Null, DATETIME_Null, SH_cls_Disconnect )
				Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

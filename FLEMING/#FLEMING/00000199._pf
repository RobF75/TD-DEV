					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name:
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_clsPB_CLICK
							If IDYES = SalMessageBox( 'This action assumes Royalties_Paid table is empty.  
									It inserts new records and automatically generates the report.  
									Make sure that Log Backup mode is OFF on STOCK first, 
									the From and To date fields are correct and the Report Print ONLY is checked!', 'Continue ?', MB_YesNo )
								Call CreateRoyaltiesPaidTable( dfFromDate, dfToDate, SH_cls_Execute )
								Call SalSendMsg( pbReport, SAM_Click, 0, 0 )
				Pushbutton: pbReport
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbTblTableReport
					Property Template:
					Class DLL Name:
					Title:
					Window Location and Size
						Left:   4.5"
						Top:    0.0"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name:
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_clsPB_CLICK
							Set bOk = TRUE
							If cbPayingRoyaltiesInReport
								If IDCANCEL = SalMessageBox( 'Royalties will be deleted after the report prints.  Proceed?', 'Warning', MB_OkCancel | MB_DefButton2 )
									Set bOk = FALSE
							If bOk
								If rbAudit
									Call SalSendMsg( hWndForm, PAM_clsOWNITM_REPORT, 1, 0 )
								Else
									Call SalSendMsg( hWndForm, PAM_clsOWNITM_REPORT, 2, 0 )
				Pushbutton: pbHelp

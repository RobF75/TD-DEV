								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
					Column: colRootDesc
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class: clsColumnGeneral
						Property Template:
						Class DLL Name:
						Title: Root.Desc.
						Visible? Class Default
						Editable? No
						Maximum Data Length: Class Default
						Data Type: Class Default
						Justify: Class Default
						Width:  1.217"
						Width Editable? Class Default
						Format: Class Default
						Country: Class Default
						Input Mask: Class Default
						Cell Options
							Cell Type? Class Default
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? Class Default
								Vertical Scroll? Class Default
								Auto Drop Down? Class Default
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
				Functions
				Window Variables
					Number: nTmpCultIdPos
					Number: nTmpRootIdPos
					Number: nTmp
					String: sShowRoyOwnerId
					Boolean: bOk
				Message Actions
					!
					On PAM_OWNITM_GETSELECTEDITEMS
						Set nTmpCultIdPos = 0
						Set nTmpRootIdPos = 0
						Set sSelectedRoyPatentCultIds[ nTmpCultIdPos ] = ''
						Set sSelectedRoyPatentRootIds[ nTmpRootIdPos ] = ''
						If TableLoop( hWndForm, hWndForm, PAM_OWNITM_GETSELECTED, 0, 0, 0, 'Extracting Royalty Patents', TBL_cls_LowToHi )
							Return TRUE
						Else
							Return FALSE
					On PAM_OWNITM_GETSELECTED
						If colCultId != ''
							Set sSelectedRoyPatentCultIds[ nTmpCultIdPos ] = colCultId
							Set nTmpCultIdPos = nTmpCultIdPos + 1
							Set sSelectedRoyPatentCultIds[ nTmpCultIdPos ] = ''
						If colRootId != ''
							Set sSelectedRoyPatentRootIds[ nTmpRootIdPos ] = colRootId
							Set nTmpRootIdPos = nTmpRootIdPos + 1
							Set sSelectedRoyPatentRootIds[ nTmpRootIdPos ] = ''
						Return TRUE
					!
					On PAM_cls_SETINSTANCEVARS
						Set bAddAllowed = TRUE
					! On PAM_clsPICK_LOOKUP
						     Call PopString( colRootDesc, TRUE )
						     Call PopString( colRootId, TRUE )
						     Call PopString( colCultDesc, TRUE )
						     Call PopString( colCultId, TRUE )
						     Call PopNumber( colRoyInstanceNo, TRUE )
						     Set colRoyOwnerId = tblSelectedRoyOwners.colRoyOwnerId
						     Set nTmp = SalTblQueryContext( hWndForm )
						     Call SalTblSetRowFlags( hWndForm, nTmp, ROW_Selected, TRUE )
						     Call SalTblSetRowFlags( hWndForm, nTmp, ROW_HideMarks, TRUE )
						     Call SalSendMsg( tblSelectedRoyOwners, PAM_OWNITM_SETSELECTEDPATENTS, TRUE, 0 )
						     Return TRUE
					!
					On PAM_clsTBL_CLEARSELECTIONS
						Set sShowRoyOwnerId = ''
						Set bOk = SalSendClassMessage( PAM_clsTBL_CLEARSELECTIONS, wParam, lParam )
						If bOk
							Set nTmp = TBL_MinRow
							If SalTblFindNextRow( hWndForm, nTmp, 0, ROW_Hidden )
								Return TRUE
							Else
								Return SalSendMsg( tblSelectedRoyOwners, PAM_OWNITM_PATENTSCLEARED, 0, SalHStringToNumber( sShowRoyOwnerId ) )
						Else
							Return FALSE
					On PAM_clsTBL_CLEARROW
						Set sShowRoyOwnerId = colRoyOwnerId
						Return SalSendClassMessage( PAM_clsTBL_CLEARROW, wParam, lParam )
					On PAM_OWNITM_SHOWSELROYPATENTS
						Set sShowRoyOwnerId = SalNumberToHString( lParam )
						Return TableLoop( hWndForm, hWndForm, PAM_clsTBL_ROWACTION, 0, 0, 0, 'Showing Selected Owners Patents.', TBL_cls_LowToHi )
					On PAM_clsTBL_ROWACTION
						If colRoyOwnerId = sShowRoyOwnerId
							Call SalTblSetRowFlags( hWndForm, lParam, ROW_Hidden, FALSE )
						Else
							Call SalTblSetRowFlags( hWndForm, lParam, ROW_Hidden, TRUE )
						Return TRUE
					!
					On PAM_OWNITM_CLEARSELROYPATENTS
						Set sShowRoyOwnerId = SalNumberToHString( lParam )
						Return TableLoop( hWndForm, hWndForm, PAM_OWNITM_REMOVEROYPATENT, 0, 0, 0, 'Clearing Selected Owners Patents', TBL_cls_LowToHi )
					On PAM_OWNITM_REMOVEROYPATENT
						If colRoyOwnerId = sShowRoyOwnerId
							Call SalTblDeleteRow( hWndForm, lParam, TBL_NoAdjust )
							Return TBL_cls_RowDeleted
						Else
							Return TRUE
					!
					! On PAM_OWNITM_GETSELECTEDITEMS
						     Set nTmp = 0
						     Set sSelectedRoyOwnerIds[ nTmp ] = ''
						     If TableLoop( hWndForm, hWndForm, PAM_OWNITM_GETSELECTED, 0, 0, 0, 'Extracting Royalty Owners', TBL_cls_LowToHi )
							     Return TRUE
						     Else 
							     Return FALSE
					! On PAM_OWNITM_GETSELECTED
						     Set sSelectedRoyOwnerIds[ nTmp ] = tblSelectedRoyOwners.colRoyOwnerId
						     Set nTmp = nTmp + 1
						     Set sSelectedRoyOwnerIds[ nTmp ] = ''
						     Return TRUE
			!

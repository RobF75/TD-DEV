								Ignore Case? Class Default
						List Values
						Message Actions
					Column: colSelectedPatents
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class: clsColumnGeneral
						Property Template:
						Class DLL Name:
						Title: Sel.Patents
						Visible? Class Default
						Editable? No
						Maximum Data Length: Class Default
						Data Type: Class Default
						Justify: Class Default
						Width:  0.983"
						Width Editable? Class Default
						Format: Class Default
						Country: Class Default
						Input Mask: Class Default
						Cell Options
							Cell Type? Check Box
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? Class Default
								Vertical Scroll? Class Default
								Auto Drop Down? Class Default
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value: Y
								Uncheck Value: N
								Ignore Case? Class Default
						List Values
						Message Actions
				Functions
				Window Variables
					Number: nTmp
					String: sRoyOwnerId
					Boolean: bFound
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set bAddAllowed = TRUE
						! Call SalTblSetTableFlags( hWndForm, TBL_Flag_SingleSelection, TRUE )
					On PAM_OWNITM_GETSELECTEDITEMS
						Set nTmp = 0
						Set sSelectedRoyOwnerIds[ nTmp ] = ''
						If TableLoop( hWndForm, hWndForm, PAM_OWNITM_GETSELECTED, 0, 0, 0, 'Extracting Royalty Owners', TBL_cls_LowToHi )
							Return TRUE
						Else
							Return FALSE
					On PAM_OWNITM_GETSELECTED
						Set sSelectedRoyOwnerIds[ nTmp ] = tblSelectedRoyOwners.colRoyOwnerId
						Set nTmp = nTmp + 1
						Set sSelectedRoyOwnerIds[ nTmp ] = ''
						Return TRUE
					On PAM_OWNITM_SETSELECTEDPATENTS
						If wParam
							Set colSelectedPatents = 'Y'
							Call SalTblSetRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_UnusedFlag1, TRUE )
							Call SalSendMsg( cbSelectedRoyPatents, PAM_clsCB_SET, wParam, lParam )
						Else
							Set colSelectedPatents = 'N'
							Call SalTblSetRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_UnusedFlag1, FALSE )
					!
					On PAM_clsTBL_CLEARROW
						Call SalSendMsg( tblSelectedRoyPatents, PAM_OWNITM_CLEARSELROYPATENTS, 0, SalHStringToNumber( colRoyOwnerId ) )
						Return SalSendClassMessage( PAM_clsTBL_CLEARROW, wParam, lParam )
					!
					On PAM_OWNITM_NEWROWSELECTED
						Return SalSendMsg( tblSelectedRoyPatents, PAM_OWNITM_SHOWSELROYPATENTS, 0, SalHStringToNumber( colRoyOwnerId ) )
					On SAM_RowValidate
						Call SalPostMsg( hWndForm, PAM_OWNITM_NEWROWSELECTED, 0, 0 )
						Return VALIDATE_Ok
					!
					On PAM_OWNITM_PATENTSCLEARED
						Set sRoyOwnerId = SalNumberToHString( lParam )
						If colRoyOwnerId = sRoyOwnerId
							Call SalSendMsg( hWndForm, PAM_OWNITM_SETSELECTEDPATENTS, FALSE, 0 )
							Return TRUE
						Else
							Set bFound = FALSE
							Call TableLoop( hWndForm, hWndForm, PAM_OWNITM_LOCATEDOWNER, 0, 0, 0, 'Locating Royalty Owner', TBL_cls_LowToHi )
							If bFound
								Call SalSendMsg( hWndForm, PAM_OWNITM_SETSELECTEDPATENTS, FALSE, 0 )
								Return TRUE
							Else
								Return FALSE
					On PAM_OWNITM_LOCATEDOWNER
						If colRoyOwnerId = sRoyOwnerId
							Set bFound = TRUE
							! RETURN FALSE TO END LOOP
							Return FALSE
						Return TRUE

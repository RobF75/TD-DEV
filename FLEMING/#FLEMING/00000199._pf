					On PAM_cls_SETFIELDS
						Call pbPickRoyPatents.SetOwnerPatentsFields( tblSelectedRoyOwners.colRoyOwnerId, tblSelectedRoyOwners.colRoyBusName )
						Return TRUE
					On PAM_cls_GETFIELDS
						Call pbPickRoyPatents.GetOwnerPatentsFields( tblSelectedRoyPatents.colRoyInstanceNo, 
								tblSelectedRoyPatents.colCultId, 
								tblSelectedRoyPatents.colCultDesc, 
								tblSelectedRoyPatents.colRootId, 
								tblSelectedRoyPatents.colRootDesc  )
						Set tblSelectedRoyPatents.colRoyOwnerId = tblSelectedRoyOwners.colRoyOwnerId
						Set nTmp = SalTblQueryContext( tblSelectedRoyPatents )
						Call SalTblSetRowFlags( tblSelectedRoyPatents, nTmp, ROW_Selected, TRUE )
						Call SalTblSetRowFlags( tblSelectedRoyPatents, nTmp, ROW_HideMarks, TRUE )
						Call SalSendMsg( tblSelectedRoyOwners, PAM_OWNITM_SETSELECTEDPATENTS, TRUE, 0 )
						Return TRUE

		Named Menus
		Internal Functions
			Function: InitLastNameFirstColumn
				Description:
				Returns
					Boolean:
				Parameters
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					Number: nResultSetCount
					: fcMeter
						Class: clsMeterBar
					!
					Number: nInd
					Date/Time: dtGotTimeStamp
					String: sGotName
					String: sLastNameFirst
					Boolean: bOk
					!
				Actions
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT Time_Stamp, Name
									FROM Mailing_List
									WHERE Last_Name_First IS NULL "
							Set sName = 'GETNMEFLST'
							Set sBind = ''
							Set sInto = ':dtGotTimeStamp, :sGotName'
							Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							Set sGotName = ''
							!
							If fcOurHandle.Execute( )
								Call fcOurHandle.ResultSetCount( nResultSetCount )
								Call fcMeter.Setup( 'Initialising Last Name First column in the mailing list file.', nResultSetCount )
								Set bOk = TRUE
								While fcOurHandle.FetchNext( nInd ) AND bOk
									If UpdtLastNameFirstColumn( dtGotTimeStamp, ReverseName( sGotName ), SH_cls_Execute )
										Call UpdtLastNameFirstColumn( DATETIME_Null, '', SH_cls_Commit )
									Else
										Set bOk = FALSE
									Call fcMeter.Increment( 1 )
								Call fcMeter.End( )
								Return bOk
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT UpdtLastNameFirstColumn( DATETIME_Null, '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT fcOurHandle.Disconnect( )
								Set bOk = FALSE
							Return bOk
			Function: UpdtLastNameFirstColumn
				Description:
				Returns
					Boolean:
				Parameters
					Date/Time: dtTimeStamp
					String: sLastNameFirst
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
				Actions
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " UPDATE Mailing_List
									SET Last_Name_First = :2
									WHERE Time_Stamp = :1 "
							Set sName = 'UPDTLNF'
							Set sBind = ':dtTimeStamp, :sLastNameFirst'
							Set sInto = ''
							Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							Return fcOurHandle.Execute( )
						Case SH_cls_Commit
							Return fcOurHandle.Commit( )
						Case SH_cls_Rollback
							Return fcOurHandle.Rollback( )
						Case SH_cls_Disconnect
							Return fcOurHandle.Disconnect( )
			Function: ReverseName
				Description:
				Returns
					String:
				Parameters
					String: sName
				Static Variables
				Local variables
					Number: nNameLength
					Number: nPos
					String: sCurrentPosChar
					String: sNewName
					Boolean: bFound
				Actions
					Set nNameLength = SalStrLength( sName )
					Set bFound = FALSE
					Set nPos = nNameLength - 1
					While nPos >= 0 AND NOT bFound
						Set sCurrentPosChar = SalStrMidX( sName, nPos, 1 )
						If sCurrentPosChar = ' ' OR sCurrentPosChar = ','
							Set sNewName = SalStrMidX( sName, nPos + 1, nNameLength - nPos ) || sCurrentPosChar || SalStrMidX( sName, 0, nPos )
							Set bFound = TRUE
						Set nPos = nPos - 1
					If bFound
						Return sNewName
					Else
						Return sName

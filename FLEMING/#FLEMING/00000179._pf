					Text: VIC
					Text: NSW
					Text: QLD
					Text: NT
					Text: WA
					Text: SA
					Text: TAS
					Text: ACT
				Message Actions
					On PAM_clsFRMDETS_DATAVAL
						If cmbState = 'VIC' OR 
								   cmbState = 'NSW' OR 
								   cmbState = 'QLD' OR 
								   cmbState = 'NT' OR 
								   cmbState = 'WA' OR 
								   cmbState = 'SA' OR 
								   cmbState = 'TAS' OR 
								   cmbState = 'ACT'
							Return TRUE
						Else

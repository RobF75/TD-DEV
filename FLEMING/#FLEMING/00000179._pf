				Pushbutton: pbPrintAddrLabels
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbPrintAddrLabels
					Property Template:
					Class DLL Name:
					Title:
					Window Location and Size
						Left:   6.313"
						Top:    0.0"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name:
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_cls_SETINSTANCEVARS
							Set pbPrintAddrLabels.sOrderFormSourceType = 'MAILING_LIST'
							Return SalSendClassMessage( PAM_cls_SETINSTANCEVARS, wParam, lParam )
						On PAM_cls_SETFIELDS
							Set pbPrintAddrLabels.nPos = 0
							Set bOk = TRUE
							If SalTblAnyRows( tblMailList, ROW_Selected, 0 )
								Call TableLoop( tblMailList, hWndItem, PAM_clsTBL_ROWACTION, 0, ROW_Selected, 0, 'Fetching Selected Customers', TBL_cls_LowToHi )
							Else
								If IDYES = SalMessageBox( 'Do you wish to print for ALL showing customers', 'Address Labels', MB_YesNo | MB_DefButton2 )
									Call TableLoop( tblMailList, hWndItem, PAM_clsTBL_ROWACTION, 0, 0, 0, 'Fetching Selected Customers', TBL_cls_LowToHi )
								Else
									Set bOk = FALSE
							Return bOk
						On PAM_clsTBL_ROWACTION
							Set pbPrintAddrLabels.dtaMailListTimeStamps[ pbPrintAddrLabels.nPos ] = tblMailList.colSysDT
							Set pbPrintAddrLabels.nPos = pbPrintAddrLabels.nPos + 1
							Set pbPrintAddrLabels.dtaMailListTimeStamps[ pbPrintAddrLabels.nPos ] = DATETIME_Null
							Return TRUE

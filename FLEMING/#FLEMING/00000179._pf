				Functions
				Window Variables
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set sSQLPopHandle = 'SELECT 
								  Time_Stamp,
								  Date_Added, 
								  Name, 
								  Bus_Name, 
								  Cust_Type, 
								  Address_Type, 
								  Address_1, 
								  Address_2, 
								  Suburb, 
								  State, 
								  Postcode, 
								  Area_Code_Phone, 
								  Phone_No, 
								  Area_Code_Fax, 
								  Fax_No, 
								  Contact_Title, 
								  Contact_Given_Name, 
								  Contact_Surname, 
								  No_Mail_Flag, 
								  Advertising, 
								  Subject, 
								  Nursery_Name, 
								  Nursery_Suburb, 
								  Comments, 
								  Last_Name_First 
								FROM 
								  Mailing_List 
								ORDER BY 
								  Name, 
								  Time_Stamp '
						Set sNAMEPopHandle = 'MAILLIST'
						Set sBINDPopHandle = ''
						Set sINTOPopHandle = ':frmMailList.tblMailList.colSysDT,
								:frmMailList.tblMailList.colDateAdded,
								:frmMailList.tblMailList.colName,
								:frmMailList.tblMailList.colBusName,
								:frmMailList.tblMailList.colCustType,
								:frmMailList.tblMailList.colAddressType,
								:frmMailList.tblMailList.colAddressLine1,
								:frmMailList.tblMailList.colAddressLine2,
								:frmMailList.tblMailList.colSuburb,
								:frmMailList.tblMailList.colState,
								:frmMailList.tblMailList.colPostcode,
								:frmMailList.tblMailList.colACodePhone,
								:frmMailList.tblMailList.colPhoneNo,
								:frmMailList.tblMailList.colACodeFax,
								:frmMailList.tblMailList.colFaxNo,
								:frmMailList.tblMailList.colContactTitle,
								:frmMailList.tblMailList.colContactGivenName,
								:frmMailList.tblMailList.colContactSurname,
								:frmMailList.tblMailList.colNoMailFlag,
								:frmMailList.tblMailList.colAdvertising, 
								:frmMailList.tblMailList.colSubject, 
								:frmMailList.tblMailList.colNurseryName,
								:frmMailList.tblMailList.colNurserySuburb, 
								:frmMailList.tblMailList.colComments, 
								:frmMailList.tblMailList.colLastNameFirst'
						!
						Set sSQLRefreshHandle = 'SELECT 
								  Time_Stamp, 
								  Date_Added, 
								  Name, 
								  Bus_Name, 
								  Cust_Type, 
								  Address_Type, 
								  Address_1, 
								  Address_2, 
								  Suburb, 
								  State, 
								  Postcode, 
								  Area_Code_Phone, 
								  Phone_No, 
								  Area_Code_Fax, 
								  Fax_No, 
								  Contact_Title, 
								  Contact_Given_Name, 
								  Contact_Surname, 
								  No_Mail_Flag, 
								  Advertising, 
								  Subject, 
								  Nursery_Name, 
								  Nursery_Suburb, 
								  Comments, 
								  Last_Name_First 
								FROM 
								  Mailing_List 
								WHERE 
								  Time_Stamp = :1 '
						Set sNAMERefreshHandle = 'REFMAILLIST'
						Set sBINDRefreshHandle = ':frmMailList.tblMailList.colSysDT'
						Set sINTORefreshHandle = ':frmMailList.tblMailList.colSysDT, 
								:frmMailList.tblMailList.colDateAdded,
								:frmMailList.tblMailList.colName,
								:frmMailList.tblMailList.colBusName,
								:frmMailList.tblMailList.colCustType,
								:frmMailList.tblMailList.colAddressType,
								:frmMailList.tblMailList.colAddressLine1,
								:frmMailList.tblMailList.colAddressLine2,
								:frmMailList.tblMailList.colSuburb,
								:frmMailList.tblMailList.colState,
								:frmMailList.tblMailList.colPostcode,
								:frmMailList.tblMailList.colACodePhone,
								:frmMailList.tblMailList.colPhoneNo,
								:frmMailList.tblMailList.colACodeFax,
								:frmMailList.tblMailList.colFaxNo,
								:frmMailList.tblMailList.colContactTitle,
								:frmMailList.tblMailList.colContactGivenName,
								:frmMailList.tblMailList.colContactSurname,
								:frmMailList.tblMailList.colNoMailFlag,
								:frmMailList.tblMailList.colAdvertising, 
								:frmMailList.tblMailList.colSubject, 
								:frmMailList.tblMailList.colNurseryName,
								:frmMailList.tblMailList.colNurserySuburb, 
								:frmMailList.tblMailList.colComments, 
								:frmMailList.tblMailList.colLastNameFirst'
						!
						Set sSQLInsertHandle = ''
						Set sNAMEInsertHandle = ''
						Set sBINDInsertHandle = ''
						Set sINTOInsertHandle = ''
						!
						Set sSQLUpdateHandle = ''
						Set sNAMEUpdateHandle = ''
						Set sBINDUpdateHandle = ''
						Set sINTOUpdateHandle = ''
						!
						! BEWARE THE bellow delete statement is the same as under frmMailListDets
						Set sSQLDeleteHandle = 'DELETE FROM Mailing_List 
								WHERE 
								  Time_Stamp = :1 '
						Set sNAMEDeleteHandle = 'DELDTMAILLIST'
						Set sBINDDeleteHandle = ':frmMailList.tblMailList.colSysDT'
						Set sINTODeleteHandle = ''
						!
						Set bAddAllowed = FALSE
						Set bSaveAllowed = TRUE
						Set bDeleteAllowed = TRUE
						Set bUnDeleteAllowed = TRUE
						Set bRepopulateAllowed = TRUE
						Set bClearSelectAllowed = TRUE
						Set bQueryAllowed = TRUE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = TRUE
						!
						Set bSelectFirstRow = FALSE
						!
						Set nTableFillType = TBL_FillNormal
						!
						Set sQueryDialogName = 'dlgQueryMailList'
						Set sTableHeading = 'Mailing List'

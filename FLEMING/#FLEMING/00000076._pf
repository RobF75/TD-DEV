			Function: TokenCustInvoiceCSVFileName
				Description:
				Returns
				Parameters
					String: sFileName
					Receive Number: nCustNo
					Receive Number: nYear
					Receive String: sInvoiceNo
					Receive String: sQrpFileName
					Receive String: sFileType
				Static Variables
				Local variables
				Actions
					Set nCustNo = SalStrToNumber( SalStrMidX( sFileName, 1, 6 ) )
					Set nYear = SalStrToNumber( SalStrMidX( sFileName, 8, 2 ) )
					Call AdjustYearToYearOfSale( nYear )
					Set sInvoiceNo = SalStrMidX( sFileName, 13, 8 )
					Set sQrpFileName = ExctractQrpNameFromCSVName( sFileName )
					Set sFileType = 'INV'

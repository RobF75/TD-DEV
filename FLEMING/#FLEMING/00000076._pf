.enddata
			Functional Class: strStack
				Description:
				Derived From
				Class Variables
				Instance Variables
					String: Strings[*]
					Number: nLast
				Functions
					Function: StackInit
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
						Actions
							Set Strings[0] = ''
							Set Strings[1] = ''
							Set nLast = -1
							Return TRUE
					Function: StackFind
						Description:
						Returns
							Boolean:
						Parameters
							String: sStrToFind
						Static Variables
						Local variables
							Number: nPos
							Boolean: bFound
						Actions
							If sStrToFind = ''
								Return FALSE
							Else
								! Set nPos = 0
								! Set bFound = FALSE
								! While nPos <= nLast AND NOT bFound
									                If Strings[ nPos ] = sStrToFind
										                Set bFound = TRUE
									                Set nPos = nPos + 1
								! Return bFound
								Return StrArrayFind( Strings, nLast, sStrToFind, nPos )
					Function: StackPush
						Description:
						Returns
							Boolean:
						Parameters
							String: sStr
						Static Variables
						Local variables
						Actions
							If sStr != ''
								Set nLast = nLast + 1
								Set Strings[ nLast ] = sStr
								Set Strings[ nLast + 1 ] = ''
								Return TRUE
							Else
								Return FALSE
					Function: StackPushUnique
						Description:
						Returns
							Boolean:
						Parameters
							String: sStr
						Static Variables
						Local variables
						Actions
							If StackFind( sStr )
								Return FALSE
							Else
								Call StackPush( sStr )
								Return TRUE
					Function: StackPop
						Description:
						Returns
							Boolean:
						Parameters
							Receive String: sStr
						Static Variables
						Local variables
						Actions
							If nLast >= 0
								Set sStr = Strings[ nLast ]
								Set Strings[ nLast ] = ''
								Set nLast = nLast - 1
								Return TRUE
							Else
								Return FALSE
					Function: StackMakeList
						Description: sSeparator : string used as the list string separator
								                       eg: jan, michelle, dani the comma is the separator
								  sQuoteType : string used as the type of character for the quotes around the strings.
								                         eg: "jan", "michelle", "dani" the double quote is the quote type character
								                         note use sQueryType of blank to obtain a non quoted string list.
						Returns
						Parameters
							String: sSeparator
							String: sQuoteType
							Receive String: sStringList
						Static Variables
						Local variables
						Actions
							Call MakeStringList( Strings, sSeparator, sQuoteType, sStringList )
					Function: StackCount
						Description:
						Returns
							Number:
						Parameters
						Static Variables
						Local variables
						Actions
							Return nLast

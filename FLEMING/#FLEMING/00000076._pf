		Named Menus
		Internal Functions
			Function: StringReplace  
				Description: Given the source string, the search string and the replacing string.
						This function finds every occurance of Search String in source string
						and replaces it with Replace String.  The source string will contain
						the replaced characters on return.
				Returns
				Parameters
					Receive String: sSourceStr  
					String: sSearchStr  
					String: sReplaceStr  
				Static Variables
				Local variables
					Number: nOffSet  
					String: sNewSourceStr  
					String: sTmpStr  
				Actions
					Set sNewSourceStr = ''
					Loop
						Set nOffSet = SalStrScan( sSourceStr, sSearchStr )
						If nOffSet >= 0
							Call SalStrLeft( sSourceStr, nOffSet, sTmpStr )
							Set sNewSourceStr = sNewSourceStr || sTmpStr || sReplaceStr
							Call SalStrMid( sSourceStr, nOffSet + SalStrLength( sSearchStr ), SalStrLength( sSourceStr ) - ( nOffSet + SalStrLength( sSearchStr ) ), sSourceStr )
						Else
							Set sNewSourceStr = sNewSourceStr || sSourceStr
							Break
					Set sSourceStr = sNewSourceStr
			Function: StringScan  
				Description: Works just like SalStrScan except if case sensitivity is required set bCaseSensitive = TRUE
				Returns
					Number:
				Parameters
					String: sString1  
					String: sString2  
					Boolean: bCaseSensitive  
				Static Variables
				Local variables
					Boolean: bFound  
					Number: nOffSet  
				Actions
					If bCaseSensitive
						Set bFound = FALSE
						Set nOffSet = 0
						While NOT bFound AND nOffSet >= 0
							Set nOffSet = SalStrScan( sString1, sString2 )
							If nOffSet >= 0
								If SalStrMidX( sString1, nOffSet, SalStrLength( sString2 ) ) = sString2
									Set bFound = TRUE
								Else
									Set sString1 = SalStrReplaceX( sString1, nOffSet, SalStrLength( sString2 ), SalStrRepeatX( ' ', SalStrLength( sString2 ) ) )
						Return nOffSet
					Else
						Return SalStrScan( sString1, sString2 )
			Function: StringStartPad
				Description:
				Returns
				Parameters
					Receive String: sSource  
					String: sPad  
					Number: nLength  
				Static Variables
				Local variables
					Number: nActualLength  
				Actions
					Set nActualLength = SalStrLength( sSource )
					While nActualLength < nLength
						Set sSource = sPad || sSource
						Set nActualLength = SalStrLength( sSource )
			Function: StringEndPad
				Description:
				Returns
				Parameters
					Receive String: sSource  
					String: sPad  
					Number: nLength  
				Static Variables
				Local variables
					Number: nActualLength  
				Actions
					Set nActualLength = SalStrLength( sSource )
					While nActualLength < nLength
						Set sSource = sSource || sPad
						Set nActualLength = SalStrLength( sSource )
			Function: StringStartPadX
				Description:
				Returns
					String:
				Parameters
					String: sSource  
					String: sPad  
					Number: nLength  
				Static Variables
				Local variables
					String: sTmp
				Actions
					Set sTmp = sSource
					Call StringStartPad( sTmp, sPad, nLength )
					Return sTmp
			Function: StringEndPadX
				Description:
				Returns
					String:
				Parameters
					String: sSource  
					String: sPad  
					Number: nLength  
				Static Variables
				Local variables
					String: sTmp
				Actions
					Set sTmp = sSource
					Call StringEndPad( sTmp, sPad, nLength )
					Return sTmp
			Function: GetStringBetweenCharMarks
				Description: Returns a string encapsulated withing another string by starting and ending characters
				Returns
					String:
				Parameters
					String: sInputStr  
					String: sStartCharacter  
					String: sEndCharacter  
				Static Variables
				Local variables
					Number: nStartCharPos  
					Number: nEndCharPos  
					String: sTmpInputStr  
					String: sOutputStr  
				Actions
					Set nStartCharPos = SalStrScan( sInputStr, sStartCharacter )
					If nStartCharPos >= 0
						Set sTmpInputStr = SalStrRightX( sInputStr, SalStrLength( sInputStr ) - nStartCharPos - SalStrLength( sStartCharacter ) )
						Set nEndCharPos = SalStrScan( sTmpInputStr, sEndCharacter )
						If nEndCharPos < 0
							Set nEndCharPos = SalStrLength( sTmpInputStr )
						Set sOutputStr = SalStrMidX( sInputStr, nStartCharPos + SalStrLength( sStartCharacter ), nEndCharPos )
					Else
						Set nEndCharPos = SalStrScan( sInputStr, sEndCharacter )
						If nEndCharPos >= 0
							Set sOutputStr = SalStrLeftX( sInputStr, nEndCharPos )
						Else
							Set sOutputStr = sInputStr
					Return sOutputStr
			Function: RemoveStringBetweenCharMarks  
				Description: Returns a string with the substring encapsulated by starting and ending characters removed.
				Returns
					String:
				Parameters
					String: sInputStr  
					String: sStartCharacter  
					String: sEndCharacter  
				Static Variables
				Local variables
					Number: nStartCharPos  
					Number: nEndCharPos  
					String: sFirstInputStr  
					String: sLastInputStr  
					String: sTmpInputStr  
					String: sOutputStr  
				Actions
					Set nStartCharPos = SalStrScan( sInputStr, sStartCharacter )
					If nStartCharPos >= 0
						Set sFirstInputStr = SalStrLeftX( sInputStr, nStartCharPos )
						Set sTmpInputStr = SalStrRightX( sInputStr, SalStrLength( sInputStr ) - nStartCharPos - SalStrLength( sStartCharacter ) )
						Set nEndCharPos = SalStrScan( sTmpInputStr, sEndCharacter )
						If nEndCharPos >= 0
							Set sLastInputStr = SalStrRightX( sTmpInputStr, SalStrLength( sTmpInputStr ) - nEndCharPos - SalStrLength( sEndCharacter ))
						Else
							Set sLastInputStr = ''
						Set sOutputStr = sFirstInputStr || sLastInputStr
					Else
						Set sOutputStr = sInputStr
					Return sOutputStr
			!
			Function: StrArrayFind  
				Description:
				Returns
					Boolean:
				Parameters
					String: saStringArray[*]  
					! nArrayCount = number of elements or ARRAY_Null_Terminated constant
					Number: nArrayCount  
					String: sStrToFind  
					Receive Number: nFoundPos  
				Static Variables
				Local variables
					Number: nPos  
					Boolean: bFound  
				Actions
					Set nFoundPos = NUMBER_Null
					Set nPos = 0
					Set bFound = FALSE
					If nArrayCount = ARRAY_Null_Terminated
						While saStringArray[ nPos ] != '' AND NOT bFound
							If saStringArray[ nPos ] = sStrToFind
								Set bFound = TRUE
								Set nFoundPos = nPos
							Set nPos = nPos + 1
					Else
						While nPos <= nArrayCount AND NOT bFound
							If saStringArray[ nPos ] = sStrToFind
								Set bFound = TRUE
								Set nFoundPos = nPos
							Set nPos = nPos + 1
					Return bFound
			Function: NumArrayFind  
				Description:
				Returns
					Boolean:
				Parameters
					Number: naNumberArray[*]  
					! nArrayCount = number of elements or ARRAY_Null_Terminated constant
					Number: nArrayCount  
					Number: nNumToFind  
					Receive Number: nFoundPos  
				Static Variables
				Local variables
					Number: nPos  
					Boolean: bFound  
				Actions
					Set nFoundPos = NUMBER_Null
					Set nPos = 0
					Set bFound = FALSE
					If nArrayCount = ARRAY_Null_Terminated
						While naNumberArray[ nPos ] != NUMBER_Null AND NOT bFound
							If naNumberArray[ nPos ] = nNumToFind
								Set bFound = TRUE
								Set nFoundPos = nPos
							Set nPos = nPos + 1
					Else
						While nPos <= nArrayCount AND NOT bFound
							If naNumberArray[ nPos ] = nNumToFind
								Set bFound = TRUE
								Set nFoundPos = nPos
							Set nPos = nPos + 1
					Return bFound
			Function: DTArrayFind  
				Description:
				Returns
					Boolean:
				Parameters
					Date/Time: dtaDateTimeArray[*]  
					! nArrayCount = number of elements or ARRAY_Null_Terminated constant
					Number: nArrayCount  
					Date/Time: dtDateTimeToFind  
					Receive Number: nFoundPos  
				Static Variables
				Local variables
					Number: nPos  
					Boolean: bFound  
				Actions
					Set nFoundPos = NUMBER_Null
					Set nPos = 0
					Set bFound = FALSE
					If nArrayCount = ARRAY_Null_Terminated
						While dtaDateTimeArray[ nPos ] != DATETIME_Null AND NOT bFound
							If dtaDateTimeArray[ nPos ] = dtDateTimeToFind
								Set bFound = TRUE
								Set nFoundPos = nPos
							Set nPos = nPos + 1
					Else
						While nPos <= nArrayCount AND NOT bFound
							If dtaDateTimeArray[ nPos ] = dtDateTimeToFind
								Set bFound = TRUE
								Set nFoundPos = nPos
							Set nPos = nPos + 1
					Return bFound
			!
			Function: MakeStringList  
				Description: This functions make a any character separated list into sStringList from the array saStrings[*].
						VERY IMPORTANT ASSUMPTION : saStrings[*] is assumed to be terminated by a NULL value.
						PARAMETERS :
						  saStirng[*] : array of strings terminated by a NULL value
						  sSeparator : string used as the list string separator
						                       eg: jan, michelle, dani the comma is the separator
						  sQuoteType : string used as the type of character for the quotes around the strings.
						                         eg: "jan", "michelle", "dani" the double quote is the quote type character
						                         note use sQueryType of blank to obtain a non quoted string list.
				Returns
				Parameters
					String: saStrings[*]  
					String: sSeparator  
					String: sQuoteType  
					Receive String: sStringList  
				Static Variables
				Local variables
					Number: naStringPos  
					Boolean: bFirst  
				Actions
					Call OurWaitCursor( TRUE )
					Set bFirst = TRUE
					Set sStringList = ''
					Set naStringPos = 0
					While saStrings[ naStringPos ] != ''
						If bFirst
							Set sStringList = sQuoteType || saStrings[ naStringPos ] || sQuoteType
							Set bFirst = FALSE
						Else
							Set sStringList = sStringList || sSeparator || sQuoteType || saStrings[ naStringPos ] || sQuoteType
						Set naStringPos = naStringPos + 1
					Call OurWaitCursor( FALSE )
			Function: MakeDateTimeList  
				Description: This functions make a any character separated list into sStringList from the array dtaDT[*].
						VERY IMPORTANT ASSUMPTION : dtaDT[*] is assumed to be terminated by a DATETIME_NULL value.
						PARAMETERS :
						  dtaDT[*] : array of DateTime stamps terminated by a DATETIME_NULL value
						  sSeparator : string used as the list string separator
						                       eg: jan, michelle, dani the comma is the separator
						  sQuoteType : string used as the type of character for the quotes around the strings.
						                         eg: "jan", "michelle", "dani" the double quote is the quote type character
						                         note use sQueryType of blank to obtain a non quoted string list.
				Returns
				Parameters
					Date/Time: dtaDT[*]  
					String: sSeparator  
					String: sQuoteType  
					Receive String: sStringList  
				Static Variables
				Local variables
					Number: naStringPos  
					Boolean: bFirst  
					String: sDate  
				Actions
					Call OurWaitCursor( TRUE )
					Set bFirst = TRUE
					Set sStringList = ''
					Set naStringPos = 0
					While dtaDT[ naStringPos ] != DATETIME_Null
						Call SalDateToStr( dtaDT[ naStringPos ], sDate )
						If bFirst
							Set sStringList = sQuoteType || sDate || sQuoteType
							Set bFirst = FALSE
						Else
							Set sStringList = sStringList || sSeparator || sQuoteType || sDate || sQuoteType
						Set naStringPos = naStringPos + 1
					Call OurWaitCursor( FALSE )
			Function: MakeNumberList  
				Description: This functions make a any character separated list into sStringList from the array naNumber[*].
						VERY IMPORTANT ASSUMPTION : naDT[*] is assumed to be terminated by a NUMBER_NULL value.
						PARAMETERS :
						  naNumber[*] : array of DateTime stamps terminated by a NUMBER_NULL value
						  nPrecision : number of precision decimal places applied through out naNumber[*]
						  sSeparator : string used as the list string separator
						                       eg: jan, michelle, dani the comma is the separator
						  sQuoteType : string used as the type of character for the quotes around the strings.
						                         eg: "jan", "michelle", "dani" the double quote is the quote type character
						                         note use sQueryType of blank to obtain a non quoted string list.
				Returns
				Parameters
					Number: naNumber[*]  
					Number: nPrecision  
					String: sSeparator  
					String: sQuoteType  
					Receive String: sStringList  
				Static Variables
				Local variables
					Number: naStringPos  
					Boolean: bFirst  
					String: sNumber  
				Actions
					Set bFirst = TRUE
					Set sStringList = ''
					Set naStringPos = 0
					While naNumber[ naStringPos ] != NUMBER_Null
						Set sNumber = SalNumberToStrX( naNumber[ naStringPos ], nPrecision )
						If bFirst
							Set sStringList = sQuoteType || sNumber || sQuoteType
							Set bFirst = FALSE
						Else
							Set sStringList = sStringList || sSeparator || sQuoteType || sNumber || sQuoteType
						Set naStringPos = naStringPos + 1
			!
			Function: StringField
				Description:
				Returns
					String:
				Parameters
					String: sField
				Static Variables
				Local variables
				Actions
					Return '"' || sField || '", '
			Function: NumberField
				Description:
				Returns
					String:
				Parameters
					Number: nValue
					Number: nNumericPlaces
				Static Variables
				Local variables
				Actions
					Return SalNumberToStrX( nValue, nNumericPlaces ) || ', '
			Function: DateField
				Description:
				Returns
					String:
				Parameters
					Date/Time: dtDate
				Static Variables
				Local variables
					String: sDate
				Actions
					Set sDate = ''
					Call SalDateToStr( dtDate, sDate )
					Return sDate || ', '
			!
			Function: StrCSVTokenize  
				Description:
				Returns
					Number:
				Parameters
					String: sCSVLine  
					Receive String: sCSVFields[*]  
				Static Variables
				Local variables
					Number: nFieldPos  
					Number: nCharPos  
					Number: nNumChars  
					String: sField  
					String: sPosChar  
					Boolean: bQuoteOpen  
				Actions
					Set nNumChars = SalStrLength( sCSVLine )
					Set nFieldPos = 0
					Set sCSVFields[ nFieldPos ] = ''
					Set nCharPos = 0
					Set sField = ''
					While nCharPos < nNumChars
						Set sPosChar = SalStrMidX( sCSVLine, nCharPos, 1 )
						!
						If sPosChar = '"'
							If bQuoteOpen
								Set bQuoteOpen = FALSE
							Else
								Set bQuoteOpen = TRUE
						Else If sPosChar = ',' AND NOT bQuoteOpen
							Set bQuoteOpen = FALSE
							Set sCSVFields[ nFieldPos ] = sField
							Set nFieldPos = nFieldPos + 1
							Set sCSVFields[ nFieldPos ] = ''
							Set sField = ''
						Else
							Set sField = sField || sPosChar
						Set nCharPos = nCharPos + 1
					Set sCSVFields[ nFieldPos ] = sField
					Set nFieldPos = nFieldPos + 1
					Set sCSVFields[ nFieldPos ] = ''
					Return nFieldPos
			!
			Function: WriteStrArrayListToFile  
				Description: Assumption is that the saString[ * ] is termintated by a NULL string
				Returns
					Boolean:
				Parameters
					String: saStrings[*]  
					String: sFileName  
				Static Variables
				Local variables
					File Handle: hOutFile  
					Number: naStringPos  
					Boolean: bOk  
				Actions
					Call OurWaitCursor( TRUE )
					Set bOk = TRUE
					If SalFileOpen( hOutFile, sFileName, OF_Create | OF_ReadWrite | OF_Text )
						Set naStringPos = 0
						While saStrings[ naStringPos ] != ''
							If NOT SalFilePutStr( hOutFile, saStrings[ naStringPos ] )
								Set bOk = FALSE
							Set naStringPos = naStringPos + 1
						If NOT SalFileClose( hOutFile )
							Set bOk = FALSE
					Else
						Set bOk = FALSE
					Call OurWaitCursor( FALSE )
					Return bOk
			Function: WriteNumArrayListToFile  
				Description: Assumption is that the naNumber[ * ] is termintated by a NUMBER_Null
				Returns
					Boolean:
				Parameters
					String: sFileName  
					Number: naNumber[*]  
				Static Variables
				Local variables
					File Handle: hOutFile  
					Number: naPos  
					Boolean: bOk  
				Actions
					Call OurWaitCursor( TRUE )
					Set bOk = TRUE
					If SalFileOpen( hOutFile, sFileName, OF_Create | OF_ReadWrite | OF_Text )
						Set naPos = 0
						While naNumber[ naPos ] != NUMBER_Null
							If NOT SalFilePutStr( hOutFile, SalNumberToStrX( naNumber[ naPos ], 0 ))
								Set bOk = FALSE
							Set naPos = naPos + 1
						If NOT SalFileClose( hOutFile )
							Set bOk = FALSE
					Else
						Set bOk = FALSE
					Call OurWaitCursor( FALSE )
					Return bOk
			Function: WriteDateTimeArrayListToFile  
				Description: Assumption is that the dtaDateTime[ * ] is termintated by a NUMBER_Null
				Returns
					Boolean:
				Parameters
					String: sFileName  
					Date/Time: dtaDateTime[*]  
				Static Variables
				Local variables
					File Handle: hOutFile  
					Number: naPos  
					Boolean: bOk  
				Actions
					Call OurWaitCursor( TRUE )
					Set bOk = TRUE
					If SalFileOpen( hOutFile, sFileName, OF_Create | OF_ReadWrite | OF_Text )
						Set naPos = 0
						While dtaDateTime[ naPos ] != DATETIME_Null
							If NOT SalFilePutStr( hOutFile, DateToStrX( dtaDateTime[ naPos ] ) )
								Set bOk = FALSE
							Set naPos = naPos + 1
						If NOT SalFileClose( hOutFile )
							Set bOk = FALSE
					Else
						Set bOk = FALSE
					Call OurWaitCursor( FALSE )
					Return bOk
			Function: ReadStrArrayListFromFile  
				Description: The saString[ * ] will be returned and is termintated by a NULL string
				Returns
					Boolean:
				Parameters
					String: sFileName  
					Receive String: saStrings[*]  
				Static Variables
				Local variables
					File Handle: hOutFile  
					Number: naStringPos  
					Boolean: bOk  
				Actions
					Call OurWaitCursor( TRUE )
					Set bOk = TRUE
					If SalFileOpen( hOutFile, sFileName, OF_ReadWrite | OF_Text )
						Set naStringPos = 0
						While SalFileGetStr( hOutFile, saStrings[ naStringPos ], 255 )
							Set naStringPos = naStringPos + 1
						Set saStrings[ naStringPos ] = ''
						If NOT SalFileClose( hOutFile )
							Set bOk = FALSE
					Else
						Set bOk = FALSE
					Call OurWaitCursor( FALSE )
					Return bOk
			Function: ReadNumArrayListFromFile  
				Description: The naNumber[ * ] will be returned and is termintated by a NUMBER_Null
				Returns
					Boolean:
				Parameters
					String: sFileName  
					Receive Number: naNumber[*]  
				Static Variables
				Local variables
					File Handle: hOutFile  
					Number: naPos  
					Boolean: bOk  
					String: sString  
				Actions
					Call OurWaitCursor( TRUE )
					Set bOk = TRUE
					If SalFileOpen( hOutFile, sFileName, OF_ReadWrite | OF_Text )
						Set naPos = 0
						While SalFileGetStr( hOutFile, sString, 255 )
							Set naNumber[ naPos ] = SalStrToNumber( sString )
							Set naPos = naPos + 1
						Set naNumber[ naPos ] = NUMBER_Null
						If NOT SalFileClose( hOutFile )
							Set bOk = FALSE
					Else
						Set bOk = FALSE
					Call OurWaitCursor( FALSE )
					Return bOk
			Function: ReadDateTimeArrayListFromFile  
				Description: The dtaDateTime[ * ] will be returned and is termintated by a NUMBER_Null
				Returns
					Boolean:
				Parameters
					String: sFileName  
					Receive Date/Time: dtaDateTime[*]  
				Static Variables
				Local variables
					File Handle: hOutFile  
					Number: naPos  
					Boolean: bOk  
					String: sString  
				Actions
					Call OurWaitCursor( TRUE )
					Set bOk = TRUE
					If SalFileOpen( hOutFile, sFileName, OF_ReadWrite | OF_Text )
						Set naPos = 0
						While SalFileGetStr( hOutFile, sString, 255 )
							Set dtaDateTime[ naPos ] = SalStrToDate( sString )
							Set naPos = naPos + 1
						Set dtaDateTime[ naPos ] = DATETIME_Null
						If NOT SalFileClose( hOutFile )
							Set bOk = FALSE
					Else
						Set bOk = FALSE
					Call OurWaitCursor( FALSE )
					Return bOk
			! The previous to this point
			Function: StrArrayAppend
				Description:
				Returns
				Parameters
					Receive String: saStringArray[*]
					! nArrayCount = number of elements or ARRAY_Null_Terminated constant
					Receive Number: nArrayCount
					String: sStrToAdd
				Static Variables
				Local variables
					Number: nLastPos
				Actions
					If nArrayCount = ARRAY_Null_Terminated
						Set nLastPos = StrArrayNullEndFindLastPos( saStringArray )
						Set saStringArray[ nLastPos ] = sStrToAdd
						Set saStringArray[ nLastPos + 1 ] = ''
					Else
						Set saStringArray[ nArrayCount ] = sStrToAdd
						Set nArrayCount = nArrayCount + 1
						Set saStringArray[ nArrayCount ] = ''
			Function: StrArrayNullEndFindLastPos
				Description:
				Returns
					Number:
				Parameters
					String: saStringArray[*]
				Static Variables
				Local variables
					Number: nPos
				Actions
					Set nPos = 0
					While saStringArray[ nPos ] != ''
						Set nPos = nPos + 1
					Return nPos
			Function: StrArrayClearOut
				Description:
				Returns
				Parameters
					Receive String: saStringArray[*]
					! nArrayCount = number of elements or ARRAY_Null_Terminated constant
					Receive Number: nArrayCount
				Static Variables
				Local variables
				Actions
					Set saStringArray[ 0 ] = ''
					If NOT nArrayCount = ARRAY_Null_Terminated
						Set nArrayCount = 0
			Function: StrArrayFetchStr
				Description:
				Returns
					Boolean:
				Parameters
					String: saStringArray[*]
					! nArrayCount = number of elements or ARRAY_Null_Terminated constant
					Number: nArrayCount
					Receive String: sGotString
					Number: nActionType
				Static Variables
					Number: nPos
				Local variables
				Actions
					Select Case nActionType
						Case ARRAY_Reset
							Set nPos = -1
							Return TRUE
						Case ARRAY_FetchNext
							Set nPos = nPos + 1
							If nArrayCount = ARRAY_Null_Terminated
								If saStringArray[ nPos ] = ''
									Set sGotString = ''
									Set nPos = nPos - 1
									Return FALSE
								Else
									Set sGotString = saStringArray[ nPos ]
									Return TRUE
							Else
								If nPos < nArrayCount
									Set sGotString = saStringArray[ nPos ]
									Return TRUE
								Else
									Set sGotString = ''
									Set nPos = nPos - 1
									Return FALSE
						Case ARRAY_FetchPrevious
							Set nPos = nPos - 1
							If nPos < 0
								Set sGotString = ''
								Set nPos = nPos + 1
								Return FALSE
							Else
								Set sGotString = saStringArray[ nPos ]
								Return TRUE
						Case ARRAY_FetchLast
							If nArrayCount = ARRAY_Null_Terminated
								Set nPos = StrArrayNullEndFindLastPos( saStringArray )
								Set sGotString = saStringArray[ nPos ]
								Return TRUE
							Else
								Set nPos = nArrayCount -1
								Set sGotString = saStringArray[ nPos ]
								Return TRUE
						Case ARRAY_FetchFirst
							Set nPos = 0
							Set sGotString = saStringArray[ nPos ]
							Return TRUE
			!
			Function: CreateCustStructure0
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
				Static Variables
				Local variables
					Boolean: bOk
					String: sPath
					String: saFolders[*]
					String: sCustState
				Actions
					Call OurWaitCursor( TRUE )
					Set bOk = TRUE
					Set sPath = OurGetIniFileParameter( 'GENERAL', 'FilingCabinet', 'C:\\TEMP' )
					Set saFolders[ 0 ] = 'Filing Cabinet'
					Set saFolders[ 1 ] = ''
					If CreateFolders( sPath, saFolders )
						Set saFolders[ 0 ] = 'Customers'
						Set saFolders[ 1 ] = 'Suppliers'
						Set saFolders[ 2 ] = 'Templates'
						Set saFolders[ 3 ] = ''
						If CreateFolders( sPath || '\\Filing Cabinet', saFolders )
							! Parent 'Customers'
							Set saFolders[ 0 ] = 'NSW'
							Set saFolders[ 1 ] = 'NT'
							Set saFolders[ 2 ] = 'QLD'
							Set saFolders[ 3 ] = 'SA'
							Set saFolders[ 4 ] = 'TAS'
							Set saFolders[ 5 ] = 'VIC'
							Set saFolders[ 6 ] = 'WA'
							Set saFolders[ 7 ] = ''
							If CreateFolders( sPath || '\\Filing Cabinet' || '\\Customers', saFolders )
								Set saFolders[ 0 ] = SalNumberToStrX( nCustNo, 0 )
								Set saFolders[ 1 ] = ''
								Set sCustState = GetCustNoState( nCustNo )
								If CreateFolders( sPath || '\\Filing Cabinet' || '\\Customers' || '\\' || sCustState, saFolders )
									Set saFolders[ 0 ] = 'Acknowledgments'
									Set saFolders[ 1 ] = 'Confirmations'
									Set saFolders[ 2 ] = 'Correspondence'
									Set saFolders[ 3 ] = 'Credit Notes'
									Set saFolders[ 4 ] = 'Invoices'
									Set saFolders[ 5 ] = 'NPAs'
									Set saFolders[ 6 ] = 'Quotes'
									Set saFolders[ 7 ] = 'Receipts'
									Set saFolders[ 8 ] = 'Statements'
									Set saFolders[ 9 ] = ''
									If NOT CreateFolders( sPath || '\\Filing Cabinet' || '\\Customers' || '\\' || sCustState || '\\' || SalNumberToStrX( nCustNo, 0 ), saFolders )
										Set bOk = FALSE
								Else
									Set bOk = FALSE
							Else
								Set bOk = FALSE
							! Parent Templates
							Set saFolders[ 0 ] = 'Quote'
							Set saFolders[ 1 ] = ''
							If NOT CreateFolders( sPath || '\\Filing Cabinet' || '\\Templates', saFolders )
								Set bOk = FALSE
						Else
							Set bOk = FALSE
					Else
						Set bOk = FALSE
					Call OurWaitCursor( FALSE )
					Return bOk
			Function: CreateCustStructure
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
				Static Variables
				Local variables
					Boolean: bOk
					String: sPath
					String: saFolders[*]
					String: sCustState
				Actions
					Call OurWaitCursor( TRUE )
					Set bOk = TRUE
					Set sPath = OurGetIniFileParameter( 'GENERAL', 'FilingCabinet', 'C:\\TEMP' )
					Set saFolders[ 0 ] = 'Filing'
					Set saFolders[ 1 ] = ''
					If CreateFolders( sPath, saFolders )
						Set saFolders[ 0 ] = 'Customer'
						Set saFolders[ 1 ] = 'Supplier'
						Set saFolders[ 2 ] = 'Template'
						Set saFolders[ 3 ] = ''
						If CreateFolders( sPath || '\\Filing', saFolders )
							! Parent 'Customer'
							Set saFolders[ 0 ] = 'NSW'
							Set saFolders[ 1 ] = 'NT'
							Set saFolders[ 2 ] = 'QLD'
							Set saFolders[ 3 ] = 'SA'
							Set saFolders[ 4 ] = 'TAS'
							Set saFolders[ 5 ] = 'VIC'
							Set saFolders[ 6 ] = 'WA'
							Set saFolders[ 7 ] = ''
							If CreateFolders( sPath || '\\Filing' || '\\Customer', saFolders )
								Set saFolders[ 0 ] = SalNumberToStrX( nCustNo, 0 )
								Set saFolders[ 1 ] = ''
								Set sCustState = GetCustNoState( nCustNo )
								If CreateFolders( sPath || '\\Filing' || '\\Customer' || '\\' || sCustState, saFolders )
									Set saFolders[ 0 ] = 'Acknow'
									Set saFolders[ 1 ] = 'Confirm'
									Set saFolders[ 2 ] = 'Corresp'
									Set saFolders[ 3 ] = 'CRNotes'
									Set saFolders[ 4 ] = 'Invoices'
									Set saFolders[ 5 ] = 'NPAs'
									Set saFolders[ 6 ] = 'Quotes'
									Set saFolders[ 7 ] = 'Receipts'
									Set saFolders[ 8 ] = 'Statemnt'
									Set saFolders[ 9 ] = 'PRCs'
									Set saFolders[ 10 ] = 'Other'
									Set saFolders[ 11 ] = ''
									If NOT CreateFolders( sPath || '\\Filing' || '\\Customer' || '\\' || sCustState || '\\' || SalNumberToStrX( nCustNo, 0 ), saFolders )
										Set bOk = FALSE
								Else
									Set bOk = FALSE
							Else
								Set bOk = FALSE
							! Parent Template
							Set saFolders[ 0 ] = 'Quote'
							Set saFolders[ 1 ] = ''
							If NOT CreateFolders( sPath || '\\Filing' || '\\Template', saFolders )
								Set bOk = FALSE
						Else
							Set bOk = FALSE
					Else
						Set bOk = FALSE
					Call OurWaitCursor( FALSE )
					Return bOk
			Function: GetCustCSVFileStructurePath
				Description:
				Returns
					String:
				Parameters
					Number: nCustNo
					! sFileType = 'INV', 'CR', 'STAT', 'CONF', 'NPA', 'ACK', 'RCP'
					String: sFileType
				Static Variables
				Local variables
					String: sPath
				Actions
					Set sPath = OurGetIniFileParameter( 'GENERAL', 'FilingCabinet', 'C:\\TEMP' )
					If sFileType = 'INV'
						Set sFileType = 'Invoices'
					Else If sFileType = 'CR'
						Set sFileType = 'CRNotes'
					Else If sFileType = 'STAT'
						Set sFileType = 'Statemnt'
					Else If sFileType = 'CONF'
						Set sFileType = 'Confirm'
					Else If sFileType = 'NPA'
						Set sFileType = 'NPAs'
					Else If sFileType = 'PRC'
						Set sFileType = 'PRCs'
					Else If sFileType = 'ACK'
						Set sFileType = 'Acknow'
					Else If sFileType = 'RCP'
						Set sFileType = 'Receipts'
					Else
						Set sFileType = 'Other'
					Set sPath = sPath || '\\' || 'Filing' || '\\' || 'Customer' || '\\' || GetCustNoState( nCustNo ) || '\\' || SalNumberToStrX( nCustNo, 0 ) || '\\' || sFileType
					Return sPath
			Function: MakeCustInvoiceCSVFileName
				Description:
				Returns
					String:
				Parameters
					Number: nCustNo
					Number: nYear
					String: sInvoiceNo
					String: sQrpFileName
				Static Variables
				Local variables
				Actions
					Return 'c' || StringStartPadX( SalNumberToStrX( nCustNo, 0 ), '0', 6 ) || 'y' || LastStrTwoDigitsFromYear( nYear ) || 'INV' || StringStartPadX( sInvoiceNo, '0', 8 ) || 'q' || StripOutFileName( sQrpFileName ) || '.CSV'

			Function: ExctractQrpNameFromCSVName
				Description:
				Returns
					String:
				Parameters
					String: sFileName
				Static Variables
				Local variables
					Number: nPos
					String: sQrpFileName
					String: sChar
					Boolean: bFound
				Actions
					Set sQrpFileName = ''
					Set bFound = FALSE
					Set nPos = SalStrScan( sFileName, '.CSV' ) - 1
					While nPos > 0 AND NOT bFound
						Set sChar = SalStrMidX( sFileName, nPos, 1 )
						If SalStrUpperX( sChar ) = 'Q'
							Set bFound = TRUE
						Else
							Set sQrpFileName = sChar || sQrpFileName
						!
						Set nPos = nPos - 1
					Return sQrpFileName
			Function: NumberToStrXNullNull
				Description:
				Returns
					String:
				Parameters
					Number: nNumber
					Number: nPrecision
				Static Variables
				Local variables
				Actions
					If nNumber = NUMBER_Null
						Return ''
					Else
						Return SalNumberToStrX( nNumber, nPrecision )
			Function: StrToNumberXNullNull
				Description:
				Returns
					Number:
				Parameters
					String: sString
				Static Variables
				Local variables
				Actions
					If sString = ''
						Return NUMBER_Null
					Else
						Return SalStrToNumber( sString )
			!
			Function: CreateFolders
				Description:
				Returns
					Boolean:
				Parameters
					String: sPath
					String: saFolders[*]
					! null terminated array
				Static Variables
				Local variables
					Boolean: bOk
					Boolean: bCreate
					String: saDirs[*]
					Number: nCount
				Actions
					Set bOk = TRUE
					Set nCount = VisDosEnumDirs( sPath||'\\*.*', saDirs )
					If nCount > 0
						Set nCount = 0
						While saFolders[ nCount ] != '' AND bOk
							If VisArrayFindString( saDirs, saFolders[ nCount ] ) < 0
								Set bOk = SalFileCreateDirectory( sPath || '\\' || saFolders[ nCount ] )
							Set nCount = nCount + 1
					Else
						Set nCount = 0
						While saFolders[ nCount ] != '' AND bOk
							Set bOk = SalFileCreateDirectory( sPath || '\\' || saFolders[ nCount ] )
							Set nCount = nCount + 1
					Return bOk
			Function: ConvertStrHexToStrBinX
				Description:
				Returns
					String:
				Parameters
					String: sHex
				Static Variables
				Local variables
					Number: nStrHexLength
					String: sHexChar
					String: sBinChar
					Number: nPos
					Number: nDecChar
					String: sBin
				Actions
					Set nStrHexLength = SalStrLength( sHex )
					Set sBin = ''
					Set nPos = 0
					While nPos < nStrHexLength
						!
						Set sHexChar = SalStrUpperX( SalStrMidX( sHex, nPos, 1 ) )
						If sHexChar = 'A'
							Set nDecChar = 10
						Else If sHexChar = 'B'
							Set nDecChar = 11
						Else If sHexChar = 'C'
							Set nDecChar = 12
						Else If sHexChar = 'D'
							Set nDecChar = 13
						Else If sHexChar = 'E'
							Set nDecChar = 14
						Else If sHexChar = 'F'
							Set nDecChar = 15
						Else
							Set nDecChar = SalStrToNumber( sHexChar )
						!
						Set sBinChar = ''
						While nDecChar > 0
							If SalNumberMod( nDecChar, 2 ) = 0
								Set sBinChar = '0' || sBinChar
							Else
								Set sBinChar = '1' || sBinChar
							Set nDecChar = SalNumberTruncate( nDecChar / 2, 4, 0 )
						!
						Call StringStartPad( sBinChar, '0', 4 )
						Set sBin = sBin || sBinChar
						Set nPos = nPos + 1
					Return sBin
			Function: LastStrTwoDigitsFromYear
				Description:
				Returns
					String:
				Parameters
					Number: nYear
				Static Variables
				Local variables
				Actions
					Return SalStrRightX( SalNumberToStrX( nYear, 0 ), 2 )
			Function: GetCustNoState
				Description:
				Returns
					String:
				Parameters
					Number: nCustNo
				Static Variables
				Local variables
					String: sState
				Actions
					If nCustNo >= 080000 AND nCustNo <= 099999
						Set sState = 'NT'
					Else If nCustNo >= 200000 AND nCustNo <= 299999
						Set sState = 'NSW'
					Else If nCustNo >= 300000 AND nCustNo <= 399999
						Set sState = 'VIC'
					Else If nCustNo >= 400000 AND nCustNo <= 499999
						Set sState = 'QLD'
					Else If nCustNo >= 500000 AND nCustNo <= 599999
						Set sState = 'SA'
					Else If nCustNo >= 600000 AND nCustNo <= 699999
						Set sState = 'WA'
					Else If nCustNo >= 700000 AND nCustNo <= 799999
						Set sState = 'TAS'
					Else
						Set sState = 'OS'
					Return sState
			Function: StripOutFileName
				Description:
				Returns
					String:
				Parameters
					String: sFullPathFileName
				Static Variables
				Local variables
					String: sLast
					String: sCurrent
					Number: nPos
					String: sChar
				Actions
					Set sCurrent = ''
					! replace the " \ " with " ~ " because SalStrScan has problems.
					Set nPos = 0
					While nPos < SalStrLength( sFullPathFileName )
						Set sChar = SalStrMidX( sFullPathFileName, nPos, 1 )
						If sChar = '\\'
							Set sChar = '~'
						Set sCurrent = sCurrent || sChar
						Set nPos = nPos + 1
					!
					Set sLast = sCurrent
					Set sCurrent = GetStringBetweenCharMarks( sCurrent, '~', '.' )
					While sLast != sCurrent
						Set sLast = sCurrent
						Set sCurrent = GetStringBetweenCharMarks( sCurrent, '~', '.' )
					Return sCurrent

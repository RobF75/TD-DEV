			Functional Class: clsStrFileHandle
				Description:
				Derived From
				Class Variables
				Instance Variables
					File Handle: hFileHandle
					String: sFileName
					! If nFileType = NUMBER_Null then Default OF_Create | OF_ReadWrite | OF_Text is assumed
					Number: nFileType
					! if nLineSize = NUMBER_Null then Default nLineSize = 1024
					Number: nLineSize
				Functions
					Function: Setup
						Description:
						Returns
						Parameters
							String: sNewFileName
							Number: nNewFileType
							Number: nNewLineSize
						Static Variables
						Local variables
						Actions
							Set sFileName = sNewFileName
							If nNewFileType = NUMBER_Null
								Set nNewFileType = OF_Create | OF_ReadWrite | OF_Text
							If nNewLineSize = NUMBER_Null
								Set nNewLineSize = 1024
							Set nFileType = nNewFileType
							Set nLineSize = nNewLineSize
					Function: Open
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
						Actions
							Return SalFileOpen( hFileHandle, sFileName, nFileType )
					Function: Close
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
						Actions
							Return SalFileClose( hFileHandle )
					Function: Write
						Description:
						Returns
							Boolean:
						Parameters
							String: sString
						Static Variables
						Local variables
						Actions
							Return SalFilePutStr( hFileHandle, sString )
					Function: Read
						Description:
						Returns
							Boolean:
						Parameters
							Receive String: sString
						Static Variables
						Local variables
						Actions
							Return SalFileGetStr( hFileHandle, sString, nLineSize )
					Function: Seek
						Description:
						Returns
							Boolean:
						Parameters
							Number: nBytes
							Number: nPosition
						Static Variables
						Local variables
						Actions
							Return SalFileSeek( hFileHandle, nBytes, nPosition )
					Function: Tell

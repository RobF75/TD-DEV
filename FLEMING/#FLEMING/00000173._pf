.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set pbPickItems.hWndPickIntoTable = tblSelectedItems
.head 6 -  Set pbPickItems.nQueryType = STCKITMQ_QueryStockItem
.head 5 +  On PAM_cls_SETFIELDS
.head 6 -  Call pbPickItems.SetStockItemsFields( 0, '', '', '' )
.head 6 -  Return TRUE
.head 5 +  On PAM_cls_GETFIELDS
.head 6 -  Call pbPickItems.GetStockItemsFields( tblSelectedItems.colItemNo, 
nTmp, 
tblSelectedItems.colTreeType, 
tblSelectedItems.colTreeTypeDesc, 
sTmp, 
tblSelectedItems.colCultDesc, 
sTmp, 
tblSelectedItems.colRootDesc, 
nTmp, nTmp  )
.head 6 -  !
.head 6 -  Set nTmp = SalTblQueryContext( tblSelectedItems )
.head 6 -  Call SalTblSetRowFlags( tblSelectedItems, nTmp, ROW_Selected, TRUE )
.head 6 -  Call SalTblSetRowFlags( tblSelectedItems, nTmp, ROW_HideMarks, TRUE )

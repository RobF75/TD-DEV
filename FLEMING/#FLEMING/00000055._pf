					! PUBLIC
					      String: sReportSql
					! PRIVATE
					      Number: nInd
					      : fcReportHdl
				      Functions 
				      Message Actions 
					      On SAM_Create
						      Set sReportSql = ''
						      Return SalSendClassMessage( SAM_Create, wParam, lParam )
					      On SAM_ReportStart
						      Return SalSendMsg( hWndForm, PAM_clsFRM_REPORTSTART, wParam, lParam )
					      On PAM_clsFRM_REPORTSTART
						      Return TRUE
					      On SAM_ReportFetchInit
						      Call fcReportHdl.PrepareSetup( sReportSql )
						      Call SqlVarSetup( fcReportHdl.hSqlHandle )
						!
						      Set bOk = fcReportHdl.PrepareAndExecute( )
						      If bOk
							      If NOT SalSendMsg( hWndForm, PAM_clsFRM_REPORTFETCHINIT, wParam, lParam )

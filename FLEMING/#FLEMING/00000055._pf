				Contents
				Class Variables
					Number: nTmp
					String: sTmp
					Date/Time: dtTmp
					Window Handle: hWndTmp
					Number: nReturn
				Instance Variables
					String: sHelpFileName
					Number: nActionOnExit
					String: sFormHeading
					Boolean: bMapEnterToTab
					Boolean: bPrintFormAllowed
					Boolean: bTreeSystem
					!
					String: sWinShowType
				Functions
				Message Actions
					On SAM_Create
						Call OurWaitCursor( TRUE )
						Call SalGetWindowText( hWndForm, sFormHeading, 130 )
						Set nActionOnExit = FRM_EndOnExit
						Set sHelpFileName = ''
						Set bMapEnterToTab = FALSE
						Set bPrintFormAllowed = TRUE
						Set bTreeSystem = TRUE
						! Call SalSendMsg( hWndForm, PAM_cls_CREATE, 0, 0 )
						Call SalSendMsg( hWndForm, PAM_clsFRM_POPFIELDS, 0, 0 )
						Call SalSendMsg( hWndForm, PAM_cls_SETINSTANCEVARS, 0, 0 )
						If NOT bPrintFormAllowed
							Call SalSendMsg( hWndForm, PAM_clsFRM_PRINTHIDE, 0, 0 )
						If NOT bTreeSystem
							Call SalSendMsgToChildren( hWndForm, PAM_clsFRM_NOTTREESYS, 0, 0 )
					On SAM_CreateComplete
						If bMapEnterToTab
							Call OurMapEnterToTab( TRUE )
						! Call SalSendMsg( hWndForm, PAM_cls_CREATECOMPLETE, 0, 0 )
						If sFormHeading = 'Form'
							Call SalGetWindowText( hWndForm, sTmp, 132 )
							If sTmp != 'Form'
								Set sFormHeading = sTmp
						Call OurWaitCursor( FALSE )
						! Call VisWinShow( SalParentWindow( hWndForm ), SHOW_Minimized )
						! Call SalDisableWindow( SalParentWindow( hWndForm ) )
						Call SalSendMsg( SalParentWindow( hWndForm ), PAM_clsFRM_CHILDWINACTIVATED, 0, SalWindowHandleToNumber( SalParentWindow( hWndForm ) ) )
						If VisWinIsMaximized( hWndForm )
							Set sWinShowType = 'MAXIMIZED'
						Else If VisWinIsMinimized( hWndForm )
							Set sWinShowType = 'MINIMIZED'
						Else
							Set sWinShowType = 'RESTORED'
						Call SalSendMsg( hWndForm, PAM_cls_PARENTACTIVATE, 0, SalWindowHandleToNumber( hWndForm ) )
					On SAM_Destroy
						If nActionOnExit = FRM_EndOnExit
							Return SalSendMsg( hWndForm, PAM_cls_DESTROY, FRM_EndOnExit, 0 )
					On PAM_cls_DESTROY
						If bMapEnterToTab
							Call OurMapEnterToTab( FALSE )
						If SalParentWindow( hWndForm )
							! If wParam = FRM_HideOnExit
								                        Call SalSendMsg( SalParentWindow( hWndForm ), PAM_cls_PARENTACTIVATE, 0, 0 )
							! Else
								                        Call SalPostMsg( SalParentWindow( hWndForm ), PAM_cls_PARENTACTIVATE, 0, 0 )
							Call SalPostMsg( SalParentWindow( hWndForm ), PAM_cls_PARENTACTIVATE, 0, SalWindowHandleToNumber( SalParentWindow( hWndForm ) ) )
						Call SalPostMsg( SalParentWindow( hWndForm ), PAM_clsFRM_RETURN, 0, SalWindowHandleToNumber( hWndForm ) )
						Return TRUE
					On SAM_Close
						Set nReturn = SalSendMsg( hWndForm, PAM_cls_CLOSE, 0, 0 )
						If nReturn = PB_ExitHideWindow
							! Call VisWinShow( hWndForm, SHOW_Hidden )
							Return FALSE
					On PAM_cls_CLOSE
						Set nReturn =  SalSendMsg( hWndForm, PAM_cls_EXIT, wParam, lParam )
						If nReturn = PB_ExitDestroyWindow
							Return SalDestroyWindow( hWndForm )
						Else If nReturn = PB_ExitEndDialog
							Return SalEndDialog( hWndForm, wParam )
						Else If nReturn = PB_ExitHideWindow
							! Set nReturn = SalHideWindow( hWndForm )
							Call VisWinShow( hWndForm, SHOW_Minimized )
							! Call ShowWindow( hWndForm, SW_MINIMIZE )
							Call SalSendMsg( hWndForm, PAM_cls_DESTROY, FRM_HideOnExit, 0 )
							Return nReturn
					On PAM_cls_PARENTACTIVATE
						! Call SalEnableWindow( hWndForm )
						! Call SalBringWindowToTop( hWndForm )
						! If sWinShowType = 'MAXIMIZED'
							                      Return VisWinShow( hWndForm, SHOW_Maximized )
						! Else If sWinShowType = 'MINIMIZED'
							                      Return VisWinShow( hWndForm, SHOW_Minimized )
						! Else
							                      Return VisWinShow( hWndForm, SHOW_Normal )
						Call SalEnableWindow( SalNumberToWindowHandle( lParam ) )
						! Call VisWinShow( SalNumberToWindowHandle( lParam ), SHOW_Normal )
						Call ShowWindow( SalNumberToWindowHandle( lParam ), SW_SHOWNORMAL )
						Call SalBringWindowToTop( SalNumberToWindowHandle( lParam ) )
						Call SalInvalidateWindow( SalNumberToWindowHandle( lParam ) )
						! If sWinShowType = 'MAXIMIZED'
							! Return VisWinShow( SalNumberToWindowHandle( lParam ), SHOW_Maximized )
							                Return ShowWindow( SalNumberToWindowHandle( lParam ), SW_SHOWMAXIMIZED )
						! Else If sWinShowType = 'MINIMIZED'
							! Return VisWinShow( SalNumberToWindowHandle( lParam ), SHOW_Minimized )
							                Return ShowWindow( SalNumberToWindowHandle( lParam ), SW_SHOWMINIMIZED )
						! Else
							! Return VisWinShow( SalNumberToWindowHandle( lParam ), SHOW_Normal )
							                Return ShowWindow( SalNumberToWindowHandle( lParam ), SW_NORMAL )
					On PAM_clsFRM_CHILDWINACTIVATED
						! Call VisWinShow( hWndForm, SHOW_Minimized )
						Call SalDisableWindow( SalNumberToWindowHandle( lParam ) )
						Call ShowWindow( SalNumberToWindowHandle( lParam ), SW_SHOWMINIMIZED )
						Set sWinShowType = 'MINIMIZED'
						! If VisWinIsMaximized( hWndForm )
							                  Set sWinShowType = 'MAXIMIZED'
						! Else If VisWinIsMinimized( hWndForm )
							                  Set sWinShowType = 'MINIMIZED'
						! Else
							                  Set sWinShowType = 'RESTORED'
						Return TRUE
					On SAM_Activate
						Call SalSendMsgToChildren( hWndForm, PAM_clsFRM_ACTIVATE, wParam, lParam )
					On PAM_cls_EXIT
						Call SalSendMsg( hWndForm, PAM_clsFRM_PUSHFIELDS, 0, 0 )
						! Call SalSendMsg( SalParentWindow( hWndForm ), PAM_clsFRM_RETURN, 0, SalWindowHandleToNumber( hWndForm ) )
						If nActionOnExit = FRM_HideOnExit
							Return PB_ExitHideWindow
						Else
							Return PB_ExitDestroyWindow
					On PAM_cls_HELP
						Return DisplayHelp( hWndForm )
					On PAM_clsFRM_SHOW
						Call SalSendMsg( hWndForm, PAM_clsFRM_POPFIELDS, 0, 0 )
						! Return SalShowWindow(  )
						Call SalEnableWindow( hWndForm )
						Call VisWinShow( hWndForm, SHOW_Normal )
						Return SalSendMsg( hWndForm, PAM_cls_PARENTACTIVATE, 0, SalWindowHandleToNumber( hWndForm ) )

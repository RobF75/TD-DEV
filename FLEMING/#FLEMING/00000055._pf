					On PAM_clsFRM_REPORT_GotoPage
						Return ActivateReportCommand( hWndForm, RPT_CmdGoToPage )
					On PAM_clsFRM_REPORT_Close
						Return SalDestroyWindow( hWndForm )
					On PAM_clsFRM_REPORT_SizeActual
						Return ActivateReportCommand( hWndForm, RPT_CmdSizeActual )
					On PAM_clsFRM_REPORT_SizeFit
						Return ActivateReportCommand( hWndForm, RPT_CmdSizeFit )
					On PAM_clsFRM_REPORT_Print
						Return ActivateReportCommand( hWndForm, RPT_CmdPrint )
					On PAM_clsFRM_REPORT_PrinterSetup
						Return ActivateReportCommand( hWndForm, RPT_CmdPrinterSetup )

				Property Template:
				Class DLL Name:
				Description:
				Derived From
					Class: clsFormReportView
				Menu
				Tool Bar
					Display Settings
						Display Style? Class Default
						Location? Class Default
						Visible? Class Default
						Size: Class Default
						Size Editable? Class Default
						Font Name: Class Default
						Font Size: Class Default
						Font Enhancement: Class Default
						Text Color: Class Default
						Background Color: Class Default
					Contents
				Contents
				Class Variables
				Instance Variables
					! PUBLIC
					String: sReportFileNameNoPath
					String: sReportBind
					String: sReportInto
					! sReportType = 'PRINT' OR 'VIEW'
					String: sReportType
					Number: nReportCopies
					Boolean: bReportBeginAutomatically
					!
					! nReportPrintFlags by default = RPT_PrintAll | RPT_PrintDraft
					Number: nReportPrintFlags
					! PRIVATE
					String: sReportPath
					String: sReportPathFileName
					String: sDestinFileName
					Number: nError
					Window Handle: hWndReport
				Functions
				Message Actions
					On SAM_Create
						Set sReportType = 'PRINT'
						Set sReportFileNameNoPath = ''
						Set sDestinFileName = ''
						Set sReportBind = ''
						Set sReportInto = ''
						Set nReportPrintFlags = RPT_PrintAll | RPT_PrintDraft
						Set nReportCopies = 1
						Set bReportBeginAutomatically = TRUE
						Call SalSendMsg( hWndForm, PAM_cls_SETINSTANCEVARS, 0, 0 )
						If sReportType = 'PRINT'
							Call SalDisableWindow( hWndForm )
							Call VisWinShow( hWndForm, SHOW_Minimized )
						Else If sReportType = 'FILE'
							Call SalDisableWindow( hWndForm )
							Call VisWinShow( hWndForm, SHOW_Minimized )
						Call VisWinShow( SalParentWindow( hWndForm ), SHOW_Minimized )
						Call SalDisableWindow( SalParentWindow( hWndForm ) )
					On SAM_CreateComplete
						If bReportBeginAutomatically
							Call SalSendMsg( hWndForm, PAM_clsFRM_REPORT_BEGIN, 0, 0 )
					On PAM_clsFRM_REPORT_BEGIN
						Set sReportPath = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )
						If sReportPath = ''
							Set sReportPathFileName = sReportFileNameNoPath
						Else
							Set sReportPathFileName = sReportPath || '\\' || sReportFileNameNoPath
						If sReportType = 'FILE'
							If sDestinFileName = ''
								Set sDestinFileName = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', '' )||'temp.txt'
						Set nError = 1
						If sReportType = 'VIEW'
							Set nError = nReportPrintFlags
							Set hWndReport = SalReportView( hWndForm, hWndForm, sReportPathFileName, sReportBind, sReportInto, nError )
						Else If sReportType = 'FILE'
							Set hWndReport = SalReportPrintToFile( hWndForm, sReportPathFileName, sDestinFileName, sReportBind, sReportInto, nReportCopies, nReportPrintFlags, 0, 0, FALSE, nError )
						Else
							Set hWndReport = SalReportPrint( hWndForm, sReportPathFileName, sReportBind, sReportInto, nReportCopies, nReportPrintFlags, 0, 0, nError )
					On SAM_ReportNotify
						! This is necessary to set here as the hWndReport which is returned on SalReportPrint is not correct
						If lParam = RPT_BeforeReportHeader
							Set hWndReport = SalNumberToWindowHandle( wParam )
						Return TRUE
					On SAM_ReportFinish
						Call SalSendMsg( hWndForm, PAM_clsFRM_REPORTFINISH, wParam, lParam )
						Return SalDestroyWindow( hWndForm )
					On SAM_Destroy
						Call SalPostMsg( SalParentWindow( hWndForm ), PAM_clsFRM_REPORTCLOSED, 0, 0 )
						Call SalPostMsg( SalParentWindow( hWndForm ), PAM_cls_PARENTACTIVATE, 0, SalWindowHandleToNumber( SalParentWindow( hWndForm ) ) )
					On PAM_cls_PARENTACTIVATE
						Call SalEnableWindow( SalNumberToWindowHandle( lParam ) )
						Call SalShowWindow( SalNumberToWindowHandle( lParam ) )
						Call SalBringWindowToTop( SalNumberToWindowHandle( lParam ) )
						Call VisWinShow( SalNumberToWindowHandle( lParam ), SHOW_Maximized )

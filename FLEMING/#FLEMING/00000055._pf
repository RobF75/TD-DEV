					Function: ActivateReportCommand
						Description:
						Returns
							Boolean:
						Parameters
							Window Handle: hWndSource
							Number: nCommand
						Static Variables
						Local variables
							Boolean: bOk
						Actions
							Call OurWaitCursor( TRUE )
							Set bOk = SalReportCmd( hWndSource, nCommand )
							Call OurWaitCursor( FALSE )
							Return bOk
				Message Actions
					On PAM_clsFRM_REPORT_FirstPage
						Return ActivateReportCommand( hWndForm, RPT_CmdFirstPage )
					On PAM_clsFRM_REPORT_PrevPage

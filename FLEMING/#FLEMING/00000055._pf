						Font Size: Class Default
						Font Enhancement: Class Default
						Text Color: Class Default
						Background Color: Class Default
					Contents
				Contents
				Class Variables
					Boolean: bOk
				Instance Variables
					! PUBLIC
					String: sReportSql
					! PRIVATE
					Number: nInd
					: fcReportHdl
						Class: hcSqlHandle
					Boolean: bInitFetch
				Functions
				Message Actions
					On SAM_Create
						Set sReportSql = ''
						Return SalSendClassMessage( SAM_Create, wParam, lParam )
					On SAM_ReportStart
						Set bOk = TRUE
						If NOT  SalSendMsg( hWndForm, PAM_clsFRM_REPORTSTART, wParam, lParam )
							Set bOk = FALSE
						!
						If bOk
							Call fcReportHdl.PrepareSetup( sReportSql )
							Call SqlVarSetup( fcReportHdl.hSqlHandle )
							!
							Set bOk = fcReportHdl.PrepareAndExecute( )
						Return bOk
					On PAM_clsFRM_REPORTSTART
						Return TRUE
					On SAM_ReportFetchInit
						Set bOk = fcReportHdl.FetchRow( 0, nInd )
						If bOk
							Set bInitFetch = TRUE
							If NOT SalSendMsg( hWndForm, PAM_clsFRM_REPORTFETCHINIT, wParam, lParam )
								Set bOk = FALSE
						Return bOk
					On PAM_clsFRM_REPORTFETCHINIT
						Return TRUE
					On SAM_ReportFetchNext
						If bInitFetch
							Set bOk = fcReportHdl.FetchRow( 0, nInd )
							Set bInitFetch = FALSE
						Else
							Set bOk = fcReportHdl.FetchNext( nInd )
						If bOk
							Return SalSendMsg( hWndForm, PAM_clsFRM_REPORTFETCHNEXT, wParam, lParam )
						Else
							Return SalSendMsg( hWndForm, PAM_clsFRM_REPORTFETCHNEXTEND, wParam, lParam )
					On PAM_clsFRM_REPORTFETCHNEXT
						Return TRUE
					On PAM_clsFRM_REPORTFETCHNEXTEND
						Return FALSE
					On SAM_ReportFinish
						Call fcReportHdl.Disconnect( )
						Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )

.head 9 -  Set saManyCultIds[ nPos ] = ''
.head 9 -  Set nManyCultIdsCount = 0
.head 9 -  Call TableLoop( tblCult, hWndItem, PAM_clsTBL_ROWACTION, 0, ROW_Selected, 0, 'Collecting Cult Ids.', TBL_cls_LowToHi )
.head 9 +  If nManyCultIdsCount > 1 
.head 10 -  Set sTempCultIdsFile = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'C:\\TEMP' )||'\\cultids.tmp'
.head 10 -  Call WriteStrArrayListToFile( saManyCultIds, sTempCultIdsFile )
.head 10 -  Call pbCultRoyOwners.SetCultRoyOwnerFields( 'A', 'B', sTempCultIdsFile )
.head 9 +  Else

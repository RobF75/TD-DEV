			! !
		Functions
			! Function: GenerateBarCodeStockItemsCSVFile
				       Description: 
				       Returns 
					       Boolean: 
				       Parameters 
					       String: sFileName
					! sFileType = 'STORES', 'PRICE_LIST_POTS', 'PRICE_LIST_BARE_ROOT'
					       String: sFileType
					       Number: nActionType
				       Static Variables 
					! hcSqlHandle: fcOurHandle
				       Local variables 
					       String: sSql
					! String: sBind
					! String: sInto
					! String: sName
					       Number: nOurHandleNo
					       Number: nInd
					!
					       Number: nGotItemNo
					       String: sGotTreeDesc
					       String: sGotCultDesc
					       String: sGotRootDesc
					       String: sGotVarietyType
					       String: sGotUpperVariety
					       String: sGotUpperCultDesc
					       String: sGotUpperRootDesc
					       String: sGotTreeTypeDesc
					!
					       : fcCSVFile
					       : fcPriceListNumOnlyCSVFile
					       : fcMeterBar
					       Number: nResultSet
					!
					       Boolean: bFound
					       String: sBarCodeNum
					       String: sBarCodeCheckDigit
				       Actions 
					       Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GenerateBarCodeStockItemsCSVFile' )
					       Select Case nActionType
						       Case SH_cls_Execute
							       Call fcCSVFile.Setup( sFileName, NUMBER_Null, NUMBER_Null )
							       If fcCSVFile.Open( )
								       If sFileType = 'STORE'
									       Set sSql = "SELECT 
											  Stock_Labels.Stock_Item_No, 
											  Tree_Type.Type_Description, 
											  Stock_Item.Cult_Desc, 
											  Stock_Item.Root_Desc, 
											  Stock_Item.Variety_Type, 
											  @UPPER( Stock_Item.Variety ),
											  @UPPER( Stock_Item.Cult_Desc ), 
											  @UPPER( Stock_Item.Root_Desc ), 
											  @UPPER( Stock_Item.Tree_Type_Desc )
											FROM
											  Stock_Labels,
											  Stock_Item,
											  Tree_Type 
											INTO 
											  :nGotItemNo, 
											  :sGotTreeDesc, 
											  :sGotCultDesc, 
											  :sGotRootDesc, 
											  :sGotVarietyType, 
											  :sGotUpperVariety, 
											  :sGotUpperCultDesc, 
											  :sGotUpperRootDesc, 
											  :sGotTreeTypeDesc 
											WHERE
											  Stock_Labels.Stock_Label_Use = 'BC' AND 
											  Stock_Labels.Stock_Item_No = Stock_Item.Item_No AND 
											  Stock_Item.Tree_Type = Tree_Type.Tree_Type 
											ORDER BY 6,7,8,9,1 "
								       Else If sFileType = 'PRICE_LIST_POTS'
									       Set sSql = "SELECT 
											  Stock_Labels.Stock_Item_No, 
											  Tree_Type.Type_Description, 
											  Stock_Item.Cult_Desc, 
											  Stock_Item.Root_Desc, 
											  Stock_Item.Variety_Type, 
											  @UPPER( Stock_Item.Variety ),
											  @UPPER( Stock_Item.Cult_Desc ), 
											  @UPPER( Stock_Item.Root_Desc ), 
											  @UPPER( Stock_Item.Tree_Type_Desc )
											FROM
											  Stock_Labels,
											  Stock_Item,
											  Tree_Type 
											INTO 
											  :nGotItemNo, 
											  :sGotTreeDesc, 
											  :sGotCultDesc, 
											  :sGotRootDesc, 
											  :sGotVarietyType, 
											  :sGotUpperVariety, 
											  :sGotUpperCultDesc, 
											  :sGotUpperRootDesc, 
											  :sGotTreeTypeDesc 
											WHERE
											  Stock_Labels.Stock_Label_Use = 'BC' AND 
											  Stock_Labels.Stock_Item_No = Stock_Item.Item_No AND 
											  Stock_Item.Tree_Type = Tree_Type.Tree_Type AND 
											  Stock_Item.Stock_Type = 'C' 
											ORDER BY 6,7,8,9,1 "
									       Call fcPriceListNumOnlyCSVFile.Setup( sFileName||'.NoOnly', NUMBER_Null, NUMBER_Null )
									       Call fcPriceListNumOnlyCSVFile.Open( )
								       Else 
									       Set sSql = "SELECT 
											  Stock_Labels.Stock_Item_No, 
											  Tree_Type.Type_Description, 
											  Stock_Item.Cult_Desc, 
											  Stock_Item.Root_Desc, 
											  Stock_Item.Variety_Type, 
											  @UPPER( Stock_Item.Variety ),
											  @UPPER( Stock_Item.Cult_Desc ), 
											  @UPPER( Stock_Item.Root_Desc ), 
											  @UPPER( Stock_Item.Tree_Type_Desc )
											FROM
											  Stock_Labels,
											  Stock_Item,
											  Tree_Type 
											INTO 
											  :nGotItemNo, 
											  :sGotTreeDesc, 
											  :sGotCultDesc, 
											  :sGotRootDesc, 
											  :sGotVarietyType, 
											  :sGotUpperVariety, 
											  :sGotUpperCultDesc, 
											  :sGotUpperRootDesc, 
											  :sGotTreeTypeDesc 
											WHERE
											  Stock_Labels.Stock_Label_Use = 'BC' AND 
											  Stock_Labels.Stock_Item_No = Stock_Item.Item_No AND 
											  Stock_Item.Tree_Type = Tree_Type.Tree_Type AND 
											  Stock_Item.Stock_Type = 'B' 
											ORDER BY 6,7,8,9,1 "
									       Call fcPriceListNumOnlyCSVFile.Setup( sFileName||'.NoOnly', NUMBER_Null, NUMBER_Null )
									       Call fcPriceListNumOnlyCSVFile.Open( )
								! Set sName = 'BCSTKITMS'
								! Set sBind = ''
								! Set sInto = ':nGotItemNo, 
										:sGotTreeDesc, 
										:sGotCultDesc, 
										:sGotRootDesc, 
										:sGotVarietyType, 
										:sGotUpperVariety, 
										:sGotUpperCultDesc, 
										:sGotUpperRootDesc, 
										:sGotTreeTypeDesc'
								! Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
								       Call haSqlHandles[ nOurHandleNo ].PrepareSetup( sSql )
								       Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
								!
								       If haSqlHandles[ nOurHandleNo ].PrepareAndExecute( )
									       Call haSqlHandles[ nOurHandleNo ].ResultSetCount( nResultSet )
									       Call fcMeterBar.Setup( 'Generating bar code stock item file', nResultSet )
									       If sFileType = 'STORE'
										       Set sTmp = '\"Product Number\", \"Description\"'
										       Call fcCSVFile.Write( sTmp )
									       While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
										       Set sTmp = SalNumberToStrX( nGotItemNo, 0 )
										       Call StringStartPad( sTmp, '0', 5 )
										       Set sBarCodeNum = '9317036'||sTmp
										       Set sBarCodeCheckDigit = SalNumberToStrX( Mod10AlgorithmEAN13CheckDigit( sBarCodeNum ), 0 )
										! Set sBarCodeNum = sBarCodeNum||SalNumberToStrX( Mod10AlgorithmEAN13CheckDigit( sBarCodeNum ), 0 )
										       If sFileType = 'STORE'
											       Set sBarCodeNum = sBarCodeNum || sBarCodeCheckDigit
											       Set sTmp = FormatBarCodeNumToEAN13( sBarCodeNum )
											       Set sTmp = '\"' || sTmp || '\", \"' || sGotTreeDesc || ' ' || sGotCultDesc || ' ' || sGotRootDesc || '\"'
										       Else 
											       Set sTmp = sBarCodeNum || ' ~~ ' || sBarCodeCheckDigit || ' qq ' || sGotCultDesc || ' ' || sGotRootDesc || ' qq ' || sGotTreeDesc
										!
										       Call fcCSVFile.Write( sTmp )
										       If NOT sFileType = 'STORE'
											       Call fcPriceListNumOnlyCSVFile.Write( sBarCodeNum )
										       Call fcMeterBar.Increment( 1 )
									       Call fcMeterBar.End( )
								!
								       Call fcCSVFile.Close( )
								       If NOT sFileType = 'STORE'
									       Call fcPriceListNumOnlyCSVFile.Close( )
							       Return TRUE
						       Case SH_cls_Disconnect
							       Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: SetTBLocationAndFileName
				Description:
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Set dfTrialBalCSVFullFileName = GetTrialBalCSVPath( )
					Set nTBYear = SalStrToNumber( ccYear.GetNumber( ) )
					Set nTBMonth = lbMonths.GetSelectedMonth( )
					Set dfTrialBalCSVFullFileName = dfTrialBalCSVFullFileName || '\\' || GetTrialBalCSVFileNameNoPath( nTBMonth, nTBYear )
		Window Parameters
		Window Variables
			Number: nTBYear
			Number: nTBMonth
			String: sTBReportType
			String: sReportType
			Window Handle: hWndReport
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set bMapEnterToTab = TRUE
			On SAM_CreateComplete
				Call SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
				Call SetTBLocationAndFileName(  )
			On SAM_Destroy
				! Call GenerateBarCodeStockItemsCSVFile( dfFileName, '', SH_cls_Disconnect )
				Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
			On PAM_clsFRM_REPORTCLOSED
				Set hWndReport = hWndNULL
				Return TRUE

		Named Menus
		Internal Functions
			Function: GetTrialBalCSVPath
				Description:
				Returns
					String:
				Parameters
				Static Variables
				Local variables
				Actions
					Return OurGetIniFileParameter( 'ACCOUNTS', 'TBCSVPath', OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'c:\\temp' ) )
			Function: GetTrialBalCSVFileNameNoPath
				Description:
				Returns
					String:
				Parameters
					Number: nTBMonth
					Number: nTBYear
				Static Variables
				Local variables
					Number: nTBMonthBegDay
					Number: nTBMonthEndDay
					Date/Time: dtTBDate
					String: sPath
				Actions
					Call GetMonthBegEndDays( nTBMonth, nTBYear, nTBMonthBegDay, nTBMonthEndDay )
					Set dtTBDate = SalDateConstruct( nTBYear, nTBMonth, nTBMonthEndDay, 0, 0, 0 )
					Set sPath = 'tb'|| SalStrRightX( SalNumberToStrX( nTBYear, 0 ), 1 ) || SalNumberToStrX(
							SalDateConstruct( SalDateYear( dtTBDate ),
							SalDateMonth( dtTBDate ), SalDateDay( dtTBDate ), 0, 0, 0 ) -
							SalDateConstruct( SalDateYear( dtTBDate ), 1, 1, 0, 0, 0 ), 0 )||'.csv'
					Return sPath

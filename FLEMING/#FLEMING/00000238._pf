		Window Parameters
			String: sTBFullFileName
			! TBReportType = 'NORMAL', 'SUMMARY', 'PHONELIST'
			String: sTBReportType
			! sReportPrintOrView = 'VIEW' OR 'PRINT'
			String: sReportPrintOrView
		Window Variables
			String: sCSVFields[*]
			: fcTrialBalanceCSVFile
				Class: clsStrFileHandle
			String: sTemp
			! REPORT FIELDS
			Number: nCustNo
			String: sCustName
			String: sBusName
			String: sAreaCode
			String: sPhone
			String: sAddressLine1
			String: sAddressLine2
			String: sSuburb
			String: sState
			String: sPostcode
			Date/Time: dtRolloverDate
			Number: nServiceCharge
			String: sDebtcolect
			String: sARNotes
			String: sReferenceId
			Date/Time: dtTransDate
			String: sTransType
			Number: nTransAmount
			String: sTransCode
			Number: nTransAmountOutstand
			Number: nDeposit
			Number: nOutstandDeposit
			Number: nCustARBalance
			Number: n0to30
			Number: n31to60
			Number: n61to90
			Number: n91plus
			Number: nTotalARAtStart
			String: sTransCancelled
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				If sTBReportType = 'NORMAL'
					Set sReportFileNameNoPath = 'Arbalsh6.qrp'
				Else If sTBReportType = 'SUMMARY'
					Set sReportFileNameNoPath = 'Arbalsh6Summary.qrp'
				Else
					Set sReportFileNameNoPath = 'Arbalsh6SummaryPhoneList.qrp'
				!
				Set sReportBind = ':frmRePrintTrialBalance.nCustNo, 
						:frmRePrintTrialBalance.sCustName,
						:frmRePrintTrialBalance.sBusName,
						:frmRePrintTrialBalance.sAreaCode,
						:frmRePrintTrialBalance.sPhone,
						:frmRePrintTrialBalance.sAddressLine1,
						:frmRePrintTrialBalance.sAddressLine2,
						:frmRePrintTrialBalance.sSuburb,
						:frmRePrintTrialBalance.sState,
						:frmRePrintTrialBalance.sPostcode,
						:frmRePrintTrialBalance.dtRolloverDate,
						:frmRePrintTrialBalance.nServiceCharge,
						:frmRePrintTrialBalance.sDebtcolect,
						:frmRePrintTrialBalance.sARNotes,
						:frmRePrintTrialBalance.sReferenceId,
						:frmRePrintTrialBalance.dtTransDate,
						:frmRePrintTrialBalance.sTransType,
						:frmRePrintTrialBalance.nTransAmount,
						:frmRePrintTrialBalance.sTransCode,
						:frmRePrintTrialBalance.nTransAmountOutstand,
						:frmRePrintTrialBalance.nDeposit,
						:frmRePrintTrialBalance.nOutstandDeposit,
						:frmRePrintTrialBalance.nCustARBalance,
						:frmRePrintTrialBalance.n0to30,
						:frmRePrintTrialBalance.n31to60,
						:frmRePrintTrialBalance.n61to90,
						:frmRePrintTrialBalance.n91plus,
						:frmRePrintTrialBalance.nTotalARAtStart,
						:frmRePrintTrialBalance.sTransCancelled'
				Set sReportInto = 'Cust_No, 
						Cust_Name, 
						Bus_Name, 
						Area_Code, 
						Phone, 
						Address_Line_1, 
						Address_Line_2, 
						Suburb, 
						State, 
						Postcode, 
						Rollover_Date, 
						ServiceCharge, 
						WithDebtCollect, 
						ARNotes, 
						Reference_Id, 
						Transaction_Date, 
						Transaction_Type, 
						Transaction_Amount, 
						Transaction_Code, 
						Trans_Amount_Outstand, 
						Deposit, 
						OutstandDeposit, 
						CustARBalance, 
						n0to30, 
						n31to60, 
						n61to90, 
						n91plus, 
						nTotalARAtStart, 
						sTransCancelled'
				Set sReportType = sReportPrintOrView
			On SAM_ReportStart
				Call fcTrialBalanceCSVFile.Setup( sTBFullFileName, OF_Read | OF_Text, NUMBER_Null )
				If fcTrialBalanceCSVFile.Open( )
					Return TRUE
				Else
					Call SalMessageBox( 'Please check the path of the CSV trial balance file!, before trying again.', 'Warning', MB_Ok )
					Return FALSE
			On SAM_ReportFetchInit
				Return fcTrialBalanceCSVFile.Seek( 0, FILE_SeekBegin )
			On SAM_ReportFetchNext
				If fcTrialBalanceCSVFile.Read( sTemp )
					!
					Set sCSVFields[0] = ''
					Set sCSVFields[1] = ''
					Set sCSVFields[2] = ''
					Set sCSVFields[3] = ''
					Set sCSVFields[4] = ''
					Set sCSVFields[5] = ''
					Set sCSVFields[6] = ''
					Set sCSVFields[7] = ''
					Set sCSVFields[8] = ''
					Set sCSVFields[9] = ''
					Set sCSVFields[10] = ''
					Set sCSVFields[11] = ''
					Set sCSVFields[12] = ''
					Set sCSVFields[13] = ''
					Set sCSVFields[14] = ''
					Set sCSVFields[15] = ''
					Set sCSVFields[16] = ''
					Set sCSVFields[17] = ''
					Set sCSVFields[18] = ''
					Set sCSVFields[19] = ''
					Set sCSVFields[20] = ''
					Set sCSVFields[21] = ''
					Set sCSVFields[22] = ''
					Set sCSVFields[23] = ''
					Set sCSVFields[24] = ''
					Set sCSVFields[25] = ''
					Set sCSVFields[26] = ''
					Set sCSVFields[27] = ''
					Set sCSVFields[28] = ''
					Set sCSVFields[29] = ''
					Set sCSVFields[30] = ''
					!
					Call StrCSVTokenize( sTemp, sCSVFields )
					!
					Set nCustNo =  StrToNumberXNullNull( sCSVFields[0] )
					Set sCustName = sCSVFields[1]
					Set sBusName = sCSVFields[2]
					Set sAreaCode = sCSVFields[3]
					Set sPhone = sCSVFields[4]
					Set sAddressLine1 = sCSVFields[5]
					Set sAddressLine2 = sCSVFields[6]
					Set sSuburb = sCSVFields[7]
					Set sState = sCSVFields[8]
					Set sPostcode = sCSVFields[9]
					Set dtRolloverDate =  SalStrToDate( sCSVFields[10] )
					Set nServiceCharge =  StrToNumberXNullNull( sCSVFields[11] )
					Set sDebtcolect = sCSVFields[12]
					Set sARNotes = sCSVFields[13]
					Set sReferenceId = sCSVFields[14]
					Set dtTransDate =  SalStrToDate( sCSVFields[15] )
					Set sTransType = sCSVFields[16]
					Set nTransAmount =  StrToNumberXNullNull( sCSVFields[17] )
					Set sTransCode = sCSVFields[18]
					Set nTransAmountOutstand =  StrToNumberXNullNull( sCSVFields[19] )
					Set nDeposit =  SalStrToNumber( sCSVFields[20] )
					Set nOutstandDeposit =  StrToNumberXNullNull( sCSVFields[21] )
					Set nCustARBalance =  StrToNumberXNullNull( sCSVFields[22] )
					Set n0to30 =  StrToNumberXNullNull( sCSVFields[23] )
					Set n31to60 =  StrToNumberXNullNull( sCSVFields[24] )
					Set n61to90 =  StrToNumberXNullNull( sCSVFields[25] )
					Set n91plus =  StrToNumberXNullNull( sCSVFields[26] )
					Set nTotalARAtStart =  StrToNumberXNullNull( sCSVFields[27] )
					Set sTransCancelled =  sCSVFields[28]
					Return TRUE
				Else
					Return FALSE
			On SAM_ReportFinish
				Call fcTrialBalanceCSVFile.Close( )
				Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )

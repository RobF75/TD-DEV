					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_clsPB_CLICK
							If rbTrialBalNormal
								Set sTBReportType = 'NORMAL'
							Else If rbTrialBalSummary
								Set sTBReportType = 'SUMMARY'
							Else
								Set sTBReportType = 'PHONELIST'
							!
							If rbView
								Set sReportType = 'VIEW'
							Else
								Set sReportType = 'PRINT'
							!
							If hWndReport = hWndNULL
								Set hWndReport = SalCreateWindow( frmRePrintTrialBalance, hWndForm, dfTrialBalCSVFullFileName, sTBReportType, sReportType )
								Return TRUE
							Else
								Call SalMessageBox( 'Please close down your first report!', 'Warning', MB_Ok )
								Return FALSE

			Pushbutton: pbDet
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Details - F2
				Window Location and Size
					Left:   3.55"
					Top:    4.74"
					Width:  1.2"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: F2
				Font Name: Default
				Font Size: Default
				Font Enhancement: Italic
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						Set nRow = TBL_MinRow
						Call SalTblFindNextRow( tblEvaluation, nRow, ROW_Selected, 0 )
						Call SalTblFetchRow( tblEvaluation, nRow )
						If NOT SalTblAnyRows( tblEvaluation, ROW_Selected, 0 )
							Call SalMessageBox( 'Record Not Selected', 'Error', MB_Ok )
						Else
							Call SalWaitCursor( TRUE )
							Call DetEvalFromList(  )
							Call SalWaitCursor( FALSE )
					On PAM_ENABLE
						Call SalEnableWindow( hWndItem )
						Call SalSendMsg( tblEvaluation, PAM_POPULATE, 0, 0 )

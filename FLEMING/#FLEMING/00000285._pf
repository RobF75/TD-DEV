			Pushbutton: pbOk
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Ok - Enter
				Window Location and Size
					Left:   0.1"
					Top:    2.021"
					Width:  2.25"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: Enter
				Font Name: Default
				Font Size: Default
				Font Enhancement: Default
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						Call SalWaitCursor( TRUE )
						Call SalDisableWindow( hWndItem )
						!
						If SalIsNull( dfFromRowNo )
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Please enter a Starting Row No. first!', 'Warning', MB_Ok )
							Call SalEnableWindow( hWndItem )
							Return FALSE
						Else If dfFromRowNo < 0
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Please enter a Starting Row No. greater than 0 only!', 'Warning', MB_Ok )
							Call SalEnableWindow( hWndItem )
							Return FALSE
						Else If SalIsNull( dfToRowNo )
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Please enter a Finishing Row No. first!', 'Warning', MB_Ok )
							Call SalEnableWindow( hWndItem )
							Return FALSE
						Else If dfToRowNo < 0
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Please enter a Finishing Row No. greater than 0 only!', 'Warning', MB_Ok )
							Call SalEnableWindow( hWndItem )
							Return FALSE
						Else If SalIsNull( dfSeqNo )
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Please enter a Sequence No. first!', 'Warning', MB_Ok )
							Call SalEnableWindow( hWndItem )
							Return FALSE
						Else If dfSeqNo < 0
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Please enter a Sequence No. greater than 0 only!', 'Warning', MB_Ok )
							Call SalEnableWindow( hWndItem )
							Return FALSE
						!
						! Set nRowCount = dfToRowNo
						! While nRowCount >= dfFromRowNo
							    Call PushNumber( nRowCount )
							    Call PushNumber( dfSeqNo )
							    Call SalSendMsg( hWndTable, PAM_TBLBULKADDROW, 0, TBL_MaxRow )
							    Set nRowCount = nRowCount - dfIncRowNoBy
						Set nLastContextRow = -99
						Set nContextRow = -99
						Set nNumRows = 0
						Set nRowCount = dfFromRowNo
						While nRowCount <= dfToRowNo
							Call PushNumber( nRowCount )
							Call PushNumber( dfSeqNo )
							If SalSendMsg( hWndTable, PAM_TBLBULKADDROW, 0, TBL_MaxRow )
								Call PopNumber( nContextRow, TRUE )
								Set nLastContextRow = nContextRow
								Set nNumRows = nNumRows + 1
							Else
								Call SalMessageBox( 'Opps, I have missed a row! Please inform Jan! (Code1)', 'Warning', MB_Ok )
							If nLastContextRow != nContextRow
								Call SalMessageBox( 'Opps, I have missed a row! Please inform Jan! (Code 2)', 'Warning', MB_Ok )
							Set nRowCount = nRowCount + dfIncRowNoBy
						Call SalTblSetFocusRow( hWndTable, nContextRow - nNumRows + 1 )
						!
						Call PushNumber( dfFromRowNo )
						Call PushNumber( dfToRowNo )
						Call PushNumber( dfSeqNo )
						Call PushNumber( dfIncRowNoBy )
						Call SalEndDialog( hWndForm, nOk )
			Pushbutton: pbCancel

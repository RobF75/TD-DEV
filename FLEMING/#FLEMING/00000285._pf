			Data Field: dfCultDesc
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Data
					Maximum Data Length: 60
					Data Type: String
					Editable? Yes
				Display Settings
					Window Location and Size
						Left:   1.65"
						Top:    1.594"
						Width:  3.138"
						Width Editable? Yes
						Height: 0.25"
						Height Editable? Yes
					Visible? Yes
					Border? Yes
					Justify: Left
					Format: Unformatted
					Country: Default
					Font Name: Default
					Font Size: Default
					Font Enhancement: Default
					Text Color: Default
					Background Color: White
					Input Mask: Unformatted
				Message Actions
					! denorm
					On PAM_QBE
						If NOT SalIsNull( hWndItem )
							Set sQueryTmpStr = dfCultDesc
							Set sQueryTmpStr = '%'||sQueryTmpStr||'%'
							Call SalStrUpper( sQueryTmpStr, sQueryTmpStr )
							Call PushString( sQueryTmpStr )
							Call PushString( LIKEOPERAND )
							Call PushString( STRINGFOLLOWING )
							Call PushString( '@UPPER( STOCK_ITEM.CULT_DESC)' )
							Return TRUE
					! On PAM_QBE
						    If NOT SalIsNull( hWndItem )
							    Set sQueryTmpStr = dfCultDesc
							    Call SalStrUpper( sQueryTmpStr, sQueryTmpStr )
							    Call MyStrReplace( sQueryTmpStr, '\'', '_' )
							    Set sQueryTmpStr = '%'||sQueryTmpStr||'%'
							    Set sQueryTmpStr = ' (SELECT Cult_Id FROM Cultivar WHERE @UPPER(Cult_Desc) LIKE \''||sQueryTmpStr||'\') '
							    Call PushString( sQueryTmpStr )
							    Call PushString( INOPERAND )
							    Call PushString( STRINGHDLFOLLOWING )
							    Call PushString( 'STOCK_ITEM.CULTIVAR_ID' )
							    Return TRUE

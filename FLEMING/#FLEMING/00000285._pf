		Named Menus
		Internal Functions
			Function: LocationExists
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					String: sFarmId
					Number: nRowNo
					Number: nSeqNo
					Receive Number: nLocationId
				Static Variables
				Local variables
					String: sSql
					Number: nInd
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Set sSql = ' SELECT Location_Id FROM Location INTO :nLocationId WHERE Farm_Name = :sFarmId AND Row# = :nRowNo AND Seq# = :nSeqNo '
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						If SqlFetchNext( hSqlHandle, nInd )
							Return TRUE
						Else
							Return FALSE
					Else
						Set bHandlePrepared = FALSE
						Return FALSE
			Function: StockItemSaleExists
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					Number: nItemNo
					Number: nYear
				Static Variables
				Local variables
					String: sSql
					Number: nInd
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Set sSql = ' SELECT Stock_Item_No FROM Stock_Item_Sale WHERE Year_Of_Sale = :nYear AND Stock_Item_No = :nItemNo '
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						If SqlFetchNext( hSqlHandle, nInd )
							Return TRUE
						Else
							Return FALSE
					Else
						Set bHandlePrepared = FALSE
						Return FALSE
			Function: GrowingAnything
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					Number: nLocationId
					Number: nYear
					Receive Number: nItemNo
				Static Variables
				Local variables
					String: sSql
					Number: nInd
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Set sSql = ' SELECT Stock_Item_No FROM Growing_Sale INTO :nItemNo WHERE Year_Of_Sale = :nYear AND Location_Id = :nLocationId '
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					!
					Set nItemNo = NUMBER_Null
					!
					If SqlExecute( hSqlHandle )
						If SqlFetchNext( hSqlHandle, nInd )
							Return TRUE
						Else
							Return FALSE
					Else
						Set bHandlePrepared = FALSE
						Return FALSE
			Function: CheckInvForwardOrdersExist
				Description:
				Returns
					Boolean:
				Parameters
					Number: nLocationId
					Number: nYear
					Receive Boolean: bExists
					Receive Number: nTotalConfAmt
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nGotTotalConfAmt
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  SUM( Conf_Amt )
									FROM 
									  Customer_Order
									WHERE 
									  Batch_Location_Id = :1 AND 
									  Batch_Year_Of_Sale = :2 AND 
									  Invoiced_Flag = 'Y' "
							Set sName = 'INVFUTORDEXIST'
							Set sBind = ':nLocationId, :nYear'
							Set sInto = ':nGotTotalConfAmt'
							Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							Set bExists = FALSE
							Set nGotTotalConfAmt = NUMBER_Null
							Set nTotalConfAmt = NUMBER_Null
							If fcOurHandle.Execute( )
								Call fcOurHandle.FetchNext( nInd )
								If nGotTotalConfAmt > 0
									Set bExists = TRUE
									Set nTotalConfAmt = nGotTotalConfAmt
								Return TRUE
							Else
								Return FALSE
						Case nDisconnect
							Return fcOurHandle.Disconnect( )
			Function: CheckForwardOrdersExist
				Description:
				Returns
					Boolean:
				Parameters
					Number: nLocationId
					Number: nYear
					Receive Boolean: bExists
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Cust_No
									FROM 
									  Customer_Order
									WHERE 
									  Batch_Location_Id = :1 AND 
									  Batch_Year_Of_Sale = :2 AND 
									  ( NOT Invoiced_Flag = 'Y' OR 
									    Invoiced_Flag IS NULL ) "
							Set sName = 'CHKFUTORDEXIST'
							Set sBind = ':nLocationId, :nYear'
							Set sInto = ''
							Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							Set bExists = FALSE
							If fcOurHandle.Execute( )
								If fcOurHandle.FetchNext( nInd )
									Set bExists = TRUE
								Return TRUE
							Else
								Return FALSE
						Case nDisconnect
							Return fcOurHandle.Disconnect( )
			!
			! Function: ReAdjustContainerGradFigure
				    Description: nItemNos[*] is NUMBER_Null terminated
				    Returns 
					    Boolean: 
				    Parameters 
					    Number: nItemNos[*]
					    Number: nYear
					!
					    Number: naItemNosNotToReAdjust[*]
					    Number: naYearsNotToReAdjust[*]
					!
					    Number: nActionType
				    Static Variables 
					    : fcOurHandle
				    Local variables 
					    String: sSql
					    String: sBind
					    String: sInto
					    String: sName
					!
					    Number: nInd
					    Number: nPos
					!
					    Boolean: bOk
					!
					    Number: nItemNo
					    Number: nBegCount
					    Number: nFirstCount
					    Number: nSecondCount
					    Number: nItemActualGrowing
					!
					    Boolean: bFoundSomething
				    Actions 
					    Select Case nActionType
						    Case nExecute
							    Set bOk = TRUE
							    Set sSql = " SELECT 
									  Growing_Sale.Beg_Count, 
									  Growing_Sale.First_Count, 
									  Growing_Sale.Second_Count
									FROM 
									  Growing_Sale, 
									  Stock_Item 
									WHERE 
									  Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
									  Growing_Sale.Stock_Item_No = :1 AND 
									  Growing_Sale.Year_Of_Sale = :2 AND 
									  ( Growing_Sale.Not_For_Sale = 'N' OR 
									    Growing_Sale.Not_For_Sale IS NULL ) AND 
									  ( Growing_Sale.Est_Sale_Date <= SYSDATE OR 
									    Growing_Sale.Est_Sale_Date IS NULL ) AND 
									  Stock_Item.Stock_Type = 'C' "
							    Set sName = 'GETCNTONLYCOUNTS'
							    Set sBind = ':nItemNo, :nYear'
							    Set sInto = ':nBegCount, 
									:nFirstCount, 
									:nSecondCount'
							    Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							    Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							    Set nBegCount = NUMBER_Null
							    Set nFirstCount = NUMBER_Null
							    Set nSecondCount = NUMBER_Null
							!
							    Set nPos = 0
							    While nItemNos[ nPos ] != NUMBER_Null AND bOk
								    Set nItemNo = nItemNos[ nPos ]
								    If NOT ExistsItemNoNotToReAdjust( nItemNo, nYear, naItemNosNotToReAdjust, naYearsNotToReAdjust )
									    If fcOurHandle.Execute( )
										    Set nItemActualGrowing = NUMBER_Null
										    Set bFoundSomething = FALSE
										    While fcOurHandle.FetchNext( nInd )
											    Set bFoundSomething = TRUE
											    If nSecondCount >= 0
												    Set nItemActualGrowing = nItemActualGrowing + nSecondCount
											    Else If nFirstCount >= 0
												    Set nItemActualGrowing = nItemActualGrowing + nFirstCount
											    Else 
												    Set nItemActualGrowing = nItemActualGrowing + nBegCount
										    If bFoundSomething
											    If UpdReAdjustContGradFigure( nItemNo, nYear, nItemActualGrowing, nExecute )
												    Call UpdReAdjustContGradFigure( 0, 0, 0, nCommit )
									    Else 
										    Set bOk = FALSE
								    Set nPos = nPos + 1
							!
							    Return bOk
						    Case nDisconnect
							    Set bOk = TRUE
							    If NOT fcOurHandle.Disconnect( )
								    Set bOk = FALSE
							    If NOT UpdReAdjustContGradFigure( 0, 0, 0, nDisconnect )
								    Set bOk = FALSE
							    Return bOk
			Function: UpdReAdjustContGradFigure
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Number: nYear
					Number: nAmtGraded
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " UPDATE Stock_Item_Sale 
									SET  
									  Amt_Graded = :3
									WHERE 
									  Stock_Item_No = :1 AND Year_Of_Sale = :2 "
							Set sName = 'UPTCNTONLYGR'
							Set sBind = ':nItemNo, 
									:nYear, 
									:nAmtGraded'
							Set sInto = ''
							Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							Return fcOurHandle.Execute( )
						Case nCommit
							Return fcOurHandle.Commit( )
						Case nRollback
							Return fcOurHandle.Rollback( )
						Case nDisconnect
							Return fcOurHandle.Disconnect( )
			Function: ExistsItemNoNotToReAdjust
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Number: nYear
					Number: nItemNos[*]
					Number: nYears[*]
				Static Variables
				Local variables
					Number: nPos
					Boolean: bFound
				Actions
					Set nPos = 0
					While nItemNos[ nPos ] != NUMBER_Null AND NOT bFound
						If nItemNos[ nPos ] = nItemNo AND nYears[ nPos ] = nYear
							Set bFound = TRUE
						Set nPos = nPos + 1
					Return bFound
			! Function: GetItemStockType
				    Description: 
				    Returns 
					    Boolean: 
				    Parameters 
					    Number: nItemNo
					    Receive String: sStockType
					    Number: nActionType
				    Static Variables 
					    : fcOurHandle
				    Local variables 
					    String: sSql
					    String: sBind
					    String: sInto
					    String: sName
					!
					    String: sGotStockType
					    Number: nInd
				    Actions 
					    Select Case nActionType
						    Case nExecute
							    Set sSql = " SELECT Stock_Type 
									FROM Stock_Item  
									WHERE Item_No = :1 "
							    Set sName = 'GTITMSTKTYP'
							    Set sBind = ':nItemNo'
							    Set sInto = ':sGotStockType'
							!
							    Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							    Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							    Set sStockType = ''
							    Set sGotStockType = ''
							!
							    If fcOurHandle.Execute( )
								    If fcOurHandle.FetchNext( nInd )
									    Set sStockType = sGotStockType
								    Return TRUE
							    Else 
								    Return FALSE
						    Case nDisconnect
							    Return fcOurHandle.Disconnect( )
			!
			Function: IsLocItemOnFutureOrders
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Number: nYear
					Number: nLocationId
					Receive Boolean: bExists
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					Number: nInd
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Cust_No 
									FROM 
									  Customer_Order  
									WHERE 
									  Batch_Year_Of_Sale = :1 AND 
									  Batch_Location_Id = :2 AND 
									  Year_Of_Sale = :1 AND 
									  Stock_Item_No = :3 AND 
									  ( NOT Invoiced_Flag = 'Y' OR Invoiced_Flag IS NULL ) "
							Set sName = 'EXLOCITMFORD'
							Set sBind = ':nYear, :nLocationId, :nItemNo'
							Set sInto = ''
							!
							Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							Set bExists = FALSE
							!
							If fcOurHandle.Execute( )
								If fcOurHandle.FetchNext( nInd )
									Set bExists = TRUE
								Return TRUE
							Else
								Return FALSE
						Case nDisconnect
							Return fcOurHandle.Disconnect( )

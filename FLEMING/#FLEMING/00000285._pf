		Functions
			Function: ClearEvalDet
				Description: Clear the screen and reset field defaults
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Call InitTopLevelWindow( hWndForm )
					Call SalSetFocus( hWndForm.dfEvalYear )
					Set bgNew = TRUE
					Call SalSendMsgToChildren( hWndForm,PAM_NEWREC,0,0 )
					Set bgEdit = FALSE
					Call SalSendMsgToChildren( hWndForm, PAM_INITIALIZE, 0, 0 )
			Function: DetEval
				Description: Fetch the selected Evaluation and display
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Set bgNew = FALSE
					! set an sqlStatement
					Call CallBuildSql( hWndForm,nSELECT, PAM_SQL, EVALUATION, WHEREEVALYEAR )
					If SqlOK( frmEvalDet.hLocalSqlA,sgSql )
						If SqlFetchNext( frmEvalDet.hLocalSqlA,ngFetch )
							Set bgNew = FALSE
							Set bgEdit = FALSE
							Call SalSendMsgToChildren( hWndForm,PAM_DISPREC,0,0 )
						Else
							Call SalMessageBox( 'Record Not Found','No Record', MB_Ok )
							Return FALSE
			Function: AddEval
				Description: To add a record into table Evaluation
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Set hWndChild = SalGetFirstChild( hWndForm, TYPE_DataField )
					While NOT hWndChild = hWndNULL 
						If NOT SalSendMsg( hWndChild, PAM_DATAVAL, 0, 0 )
							Return FALSE
						Set hWndChild = SalGetNextChild( hWndChild, TYPE_DataField )
					Set bgEdit = FALSE
					Set sgSql = 'SELECT Evaluation_Year FROM Evaluation
							 WHERE Item_No = :hWndForm.dfItemNo AND
							Location_Id = :hWndForm.dfLocId AND 
							Evaluation_Year = :hWndForm.dfEvalYear'
					If NOT RowIdExists( sgSql )
						Call CallBuildSql( hWndForm,nINSERT, PAM_SQL, EVALUATION, '' )
						If SqlOK( frmEvalDet.hLocalSqlA,sgSql )
							Call SqlCommit( frmEvalDet.hLocalSqlA )
							! On addition of a customer we wish to clear the screen and reset it 
							Call SalMessageBox( 'Record Added Successfully','Add OK', MB_Ok )
							Call ClearEval (  )
						Else
							Call SalMessageBox ('Record Addition Unsuccessful','Add Error', MB_RetryCancel )
							! Need to reset fields and allow
							Return FALSE
					Else
						Call SalMessageBox( 'Evaluation Year Already Exists','Record Exists',MB_Ok )
						Call SalSetFocus( hWndForm.dfEvalYear )
						Return FALSE
			Function: SaveEval
				Description: Save the changes done to a Evaluation
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					If NOT bgEdit
						Call SalMessageBox( 'Nothing has been modified','Evaluation',MB_Ok )
						Return TRUE
					Set bgEdit = FALSE
					Set hWndChild = SalGetFirstChild( hWndForm, TYPE_DataField )
					While NOT hWndChild = hWndNULL 
						If NOT SalSendMsg( hWndChild, PAM_DATAVAL, 0, 0 )
							Return FALSE
						Set hWndChild = SalGetNextChild( hWndChild, TYPE_DataField )
					Call CallBuildSql( hWndForm,nUPDATE, PAM_SQL, EVALUATION, WHEREEVALYEAR )
					If SqlOK( frmEvalDet.hLocalSqlB,sgSql )
						Call SqlCommit( frmEvalDet.hLocalSqlB )
						! On modification of an order we wish to redisplay it
						Call SalMessageBox( 'Record Modified Successfully','Add OK', MB_Ok )
						Call DetEval (  )
					Else
						Call SalMessageBox ('Record Modification Unsuccessful','Add Error',
								 MB_RetryCancel )
						! Need to reset fields and allow
						Return FALSE
			Function: NextEval
				Description: To get the next Evaluation to display from the table selections
				Returns
				Parameters
					Window Handle: hWndTable
				Static Variables
				Local variables
					Number: nRow
				Actions
					Set nRow = SalTblQueryContext( hWndTable )
					If SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
						Call SalTblFetchRow( hWndTable, nRow )
						Call PushNumber( frmEvaluation.dfRowNo )
						Call PushNumber( frmEvaluation.dfSeqNo )
						Call PushNumber( frmEvaluation.dfItemNo )
						Call PushNumber( frmEvaluation.dfLocationId )
						Call PushNumber( PAM_DETREC )
						Call PushString( hWndTable.colEvalYear )
						Call PushString( frmEvaluation.dfFarmId )
						Call PushString( frmEvaluation.dfTreeTypeDesc )
						Call PushString( frmEvaluation.dfCultDesc )
						Call PushString( frmEvaluation.dfRootId )
						Call SalSendMsg( frmEvalDet, PAM_CREATECOMPLETE,0,0 )
					Else
						Call SalMessageBox( 'No next selected records to display', 'Evaluation', MB_Ok )
			Function: PrevEval
				Description: To get the previous Evaluation to display from the table selections
				Returns
				Parameters
					Window Handle: hWndTable
				Static Variables
				Local variables
					Number: nRow
				Actions
					Set nRow = SalTblQueryContext( hWndTable )
					If SalTblFindPrevRow( hWndTable, nRow, ROW_Selected, 0 )
						Call SalTblFetchRow( hWndTable, nRow )
						Call PushNumber( frmEvaluation.dfRowNo )
						Call PushNumber( frmEvaluation.dfSeqNo )
						Call PushNumber( frmEvaluation.dfItemNo )
						Call PushNumber( frmEvaluation.dfLocationId )
						Call PushNumber( PAM_DETREC )
						Call PushString( hWndTable.colEvalYear )
						Call PushString( frmEvaluation.dfFarmId )
						Call PushString( frmEvaluation.dfTreeTypeDesc )
						Call PushString( frmEvaluation.dfCultDesc )
						Call PushString( frmEvaluation.dfRootId )
						Call SalSendMsg( frmEvalDet, PAM_CREATECOMPLETE,0,0 )
					Else
						Call SalMessageBox( 'No previous selected records to display', 'Evaluation', MB_Ok )
			Function: ClearEval
				Description: Clear the screen and reset field defaults
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Call InitTopLevelWindow( hWndForm )
					Call SalSetFocus( hWndForm.dfEvalYear )
					Set bgNew = TRUE
					Call SalSendMsgToChildren( hWndForm,PAM_NEWREC,0,0 )
					Set bgEdit = FALSE
					Call SalSendMsgToChildren( hWndForm, PAM_INITIALIZE, 0, 0 )
			Function: LoseEvalEdit
				Description: Ask the user if they want their changes saved prior to doing other
						functions
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					If IDYES = SalMessageBox( 'Your current changes have not been saved.
							Would you like them saved to the database?', 'Evaluation',
							MB_IconAsterisk|MB_YesNo  )
						If bgNew
							Call AddEval(  )
						Else
							Call SaveEval(  )
			Function: FetchEval
				Description: To prime fields to enable the fetching of prev and next orders
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Call PushString( hWndForm.dfEvalYear )
					Call SalSendMsg( hWndForm, PAM_DETREC, 0, 0 )
			Function: DelEval
				Description: Delete the selected record from Evaluation
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					If SalMessageBox( 'Are you sure?','Delete',MB_YesNo ) = IDYES
						Set sgSql = 'DELETE FROM EVALUATION
								 WHERE Item_No =:hWndForm.dfItemNo AND
								Location_Id = :hWndForm.dfLocId AND
								Evaluation_year = :hWndForm.dfEvalYear'
						If SqlOK( frmEvalDet.hLocalSqlA,sgSql )
							Call SqlCommit( frmEvalDet.hLocalSqlA )
							Call ClearEval ( )
							Call SalMessageBox( 'Record Deleted Successfully','Delete OK', MB_Ok )
						Else
							Call SalMessageBox ('Record Deletion Unsuccessful','Deletion Error', MB_RetryCancel )
		Window Parameters
		Window Variables
			String: sHelpFileName
			Boolean: bgSelect
			Boolean: bgEdit
			Boolean: bgNew
			Number: ngMessNo
			Window Handle: hWndPushbutton
			Window Handle: hWndParent
			Boolean: bShowSaveMenuItem
			Boolean: bShowAddMenuItem
			Boolean: bNextPbEnabled
			Boolean: bPrevPbEnabled
			Sql Handle: hLocalSqlA
			Boolean: bLocalSqlA
			Sql Handle: hLocalSqlB
			Boolean: bLocalSqlB
		Message Actions
			On PAM_ADDREC
				Call ClearEval (  )
				Call SalWaitCursor( FALSE )
			On SAM_Create
				Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
				If bLocalSqlA
					Call SqlSetIsolationLevel( hLocalSqlA, 'RL' )
					Call SqlSetLockTimeout( hLocalSqlA, 10 )
				Else
					Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
					Return FALSE
				Set bLocalSqlB = SqlConnect( hLocalSqlB ) 
				If bLocalSqlB
					Call SqlSetIsolationLevel( hLocalSqlB, 'RL' )
					Call SqlSetLockTimeout( hLocalSqlB, 10 )
				Else
					Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
					Return FALSE
				Set sHelpFileName = ''
				Call PopWndHdl( hWndParent, TRUE )
				Call PopWndHdl( hWndPushbutton, TRUE )
				Call SalSendMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
			On PAM_CREATECOMPLETE
				Set bgSelect = FALSE
				Set hWndForm.dfCurrDate = SalDateCurrent(  )
				Call PopNumber( ngMessNo, TRUE )
				Call PopNumber( hWndForm.dfLocId, TRUE )
				Call PopNumber( hWndForm.dfItemNo, TRUE )
				Call PopNumber( hWndForm.dfSeqNo, TRUE )
				Call PopNumber( hWndForm.dfRowNo, TRUE )
				Call PopString( hWndForm.dfRootId, TRUE )
				Call PopString( hWndForm.dfCultDesc, TRUE )
				Call PopString( hWndForm.dfTreeTypeDesc, TRUE )
				Call PopString( hWndForm.dfFarmName, TRUE )
				! Want to pass from the prior form whether the user is adding or displaying
				Call SalSendMsg( hWndForm, ngMessNo, 0, 0 )
			On SAM_Destroy
				Call SalShowWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				If bLocalSqlA
					Call SqlDisconnect( hLocalSqlA )
				If bLocalSqlB
					Call SqlDisconnect( hLocalSqlB )
				Call SalSendMsg( hWndPushbutton,PAM_ENABLE,0,0 )
				Call SalSendMsg( hWndParent, PAM_POPULATE, 0, 0 )
			On SAM_Close
				Call SalWaitCursor( TRUE )
				Call SalSendValidateMsg(  )
				If bgEdit
					If NOT ForgetChanges(  )
						Return FALSE
			On PAM_DETREC
				Set bgEdit = FALSE
				Call PopString( hWndForm.dfEvalYear, TRUE )
				Call DetEval(  )
				Call SalWaitCursor( FALSE )

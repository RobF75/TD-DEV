		Functions
			Function: AddEvalFromList
				Description: To pass the variables required to display the Evaluation addition screen
						from the list screen
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Call PushWndHdl (hWndForm.pbAdd)
					Call PushWndHdl (hWndForm.tblEvaluation)
					Call SalDisableWindow (hWndForm.pbAdd ) 
					Call PushNumber( hWndForm.dfRowNo )
					Call PushNumber( hWndForm.dfSeqNo )
					Call PushNumber( hWndForm.dfItemNo )
					Call PushNumber( hWndForm.dfLocationId )
					Call PushNumber( PAM_ADDREC )
					Call PushString( hWndForm.dfFarmId )
					Call PushString( hWndForm.dfTreeTypeDesc )
					Call PushString( hWndForm.dfCultDesc )
					Call PushString( hWndForm.dfRootId )
					Call SalCreateWindow( frmEvalDet, hWndForm )
			Function: DetEvalFromList
				Description: To pass the variables required to display the Evaluation display screen
						from the list screen
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Call PushWndHdl (hWndForm.pbDet)
					Call PushWndHdl (hWndForm.tblEvaluation )
					Call SalDisableWindow (hWndForm.pbDet ) 
					Call PushNumber( hWndForm.dfRowNo )
					Call PushNumber( hWndForm.dfSeqNo )
					Call PushNumber( hWndForm.dfItemNo )
					Call PushNumber( hWndForm.dfLocationId )
					Call PushNumber( PAM_DETREC )
					Call PushString( tblEvaluation.colEvalYear )
					Call PushString( hWndForm.dfFarmId )
					Call PushString( hWndForm.dfTreeTypeDesc )
					Call PushString( hWndForm.dfCultDesc )
					Call PushString( hWndForm.dfRootId )
					Call SalCreateWindow( frmEvalDet, hWndForm )
		Window Parameters
		Window Variables
			Boolean: bEnableQItemDlgSelectPb
			Number: nRow
			Boolean: bMultipleRowsForItem
			String: sTreeType
			String: sCultDesc
			String: sRootId
		Message Actions
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
				Set bQueryTableAllowed = FALSE
				Set bAddRowsAllowed = FALSE
			On SAM_Destroy
				Call SalShowWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
			On PAM_POPFIELDS
				Call PopString( dfRootId, TRUE )
				Call PopString( dfRootDesc, TRUE )
				Call PopString( dfCultDesc, TRUE )
				Call PopString( dfTreeTypeDesc, TRUE )
				Call PopNumber( dfItemNo, TRUE )
				Call PopNumber( dfLocationId, TRUE )
				Call PopNumber( dfSeqNo, TRUE )
				Call PopNumber( dfRowNo, TRUE )
				Call PopString( dfFarmDesc, TRUE )
				Call PopString( dfFarmId, TRUE )

			Frame
				Resource Id: 55823
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Window Location and Size
					Left:   0.063"
					Top:    4.635"
					Width:  9.8"
					Width Editable? Yes
					Height: 0.802"
					Height Editable? Yes
				Visible? Yes
				Corners: Square
				Border Style: Solid
				Border Thickness: 1
				Border Color: Default
				Background Color: Default
		Functions
		Window Parameters
		Window Variables
			Window Handle: hWndPushbutton
			Window Handle: hWndCol
			String: sHelpFileName
			Boolean: bEnableQItemDlgSelectPb
			Boolean: bPopulateAllYears
			Number: nRow
			Number: nTmp
			String: sRepInto
			String: sRepBind
			String: sReportFile
			Number: nError
			Number: nStockRow
			Boolean: bMultipleRowsForItem
			Boolean: bPrintBudOverList
			Boolean: bPopulateTblStock
			String: sTreeType
			String: sCultDesc
			String: sRootDesc
			! Number: nDefaultYear
		Message Actions
			On SAM_Create
				Set sHelpFileName = ''
				Set bEnableQItemDlgSelectPb = FALSE
				Set sTreeType = ''
				Set sCultDesc = ''
				Set sRootDesc = ''
				Call PopWndHdl( hWndPushbutton, TRUE )
				Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
			On SAM_Destroy
				Call SalMapEnterToTab( FALSE )
				Call SalShowWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				Call CalcItemTotalAvail( 0, 0, nCalcItemAvail, nDisconnect )
				Call SalSendMsg( hWndPushbutton, PAM_ENABLE, 0, 0 )
			On SAM_Activate
				Return SalSendMsgToChildren( hWndForm, PAM_ACTIVATE, wParam, lParam )
			On SAM_Close
				If NOT TableForgetChanges( tblGrowingStock, frmFarmStock.tblGrowingStock.bEdit )
					Return FALSE
				Call SalWaitCursor( TRUE )
			On PAM_CREATECOMPLETE
				Set dfCurrDate = SalDateCurrent(  )
				! Set nDefaultYear = cSeasonYear.GetSeasonYear( )
				Call PopString( dfFarmDesc, TRUE )
				Call PopString( dfFarmId, TRUE )
				Call PopNumber( dfYear, TRUE )
				If SalIsNull( dfYear )
					Set bPopulateAllYears = TRUE
				Else
					Set bPopulateAllYears = FALSE
				Set sBuildWhere = ''
				Call SalSendMsg( tblGrowingStock, PAM_POPULATE, 0, 0 )
				Call SalMapEnterToTab( TRUE )
				Call SalWaitCursor( FALSE )
			On PAM_PRINTBUDOVERLIST
				Set bPrintBudOverList = TRUE
				!
				Call CallBuildSql( hWndForm, nSELECT, PAM_FIELDCOUNTLISTFIELDS, '', '' )
				Set sRepInto = sColumns
				Set sRepBind = sIntoVars
				Call CallBuildSql( tblGrowingStock, nSELECT, PAM_FIELDCOUNTLISTFIELDS, '', '' )
				Set sRepInto = sRepInto||','||sColumns
				Set sRepBind = sRepBind||','||sIntoVars
				! Call CallBuildSql( tblGrowingStock, nSELECT, PAM_FIELDCOUNTLISTFIELDS, '', '' )
				! Set sRepInto = sRepInto||','||sColumns
				! Set sRepBind = sRepBind||','||sIntoVars
				Set sReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\budover3.qrp'
				Set nError = 1
				Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, RPT_PrintAll,0,0, nError )
			On SAM_ReportStart
				If bPrintBudOverList
					Set nStockRow = TBL_MinRow
					! Set bProcessStock = FALSE
					Return TRUE
			On SAM_ReportFetchInit
				Return TRUE
			On SAM_ReportFetchNext
				If bPrintBudOverList
					Set bOk = SalTblFindNextRow( tblGrowingStock, nStockRow, ROW_Selected, 0 )
					Call SalTblFetchRow( tblGrowingStock, nStockRow )
					If NOT bOk
						Return FALSE
					Return TRUE
			On SAM_ReportFinish
				Call SalWaitCursor( FALSE )
				Return TRUE

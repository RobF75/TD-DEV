			Pushbutton: pbOk
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: O&k - Enter
				Window Location and Size
					Left:   0.175"
					Top:    2.365"
					Width:  Class Default
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Enter
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If rbRowRange
							If SalIsNull( cRowNoFrom )
								Call SalMessageBox( 'Please enter a Starting Row No. first!', 'Warning', MB_Ok )
								Return FALSE
							Else If SalIsNull( cRowNoTo )
								Call SalMessageBox( 'Please enter a Finishing Row No. first!', 'Warning', MB_Ok )
								Return FALSE
							Else If SalIsNull( cSeqNo )
								Call SalMessageBox( 'Please enter a Sequence No. first!', 'Warning', MB_Ok )
								Return FALSE
							!
							Set nFromRowNo = SalStrToNumber( cRowNoFrom.GetNumber( ) )
							Set nToRowNo = SalStrToNumber( cRowNoTo.GetNumber( ) )
							Set nSeqNo = SalStrToNumber( cSeqNo.GetNumber( ) )
							Set nIncBy = SalStrToNumber( cIncBy.GetNumber( ) )
							!
							Set nLastContextRow = -99
							Set nContextRow = -99
							Set nNumRows = 0
							Set nRowCount = nFromRowNo
							While nRowCount <= nToRowNo
								Call PushNumber( nRowCount )
								Call PushNumber( nSeqNo )
								If SalSendMsg( hWndTable, PAM_TBLBULKADDROW, nRowRange, TBL_MaxRow )
									Call PopNumber( nContextRow, TRUE )
									Set nLastContextRow = nContextRow
									Set nNumRows = nNumRows + 1
								Else
									Call SalMessageBox( 'Opps, I have missed a row! Please inform Jan! (Code1)', 'Warning', MB_Ok )
								If nLastContextRow != nContextRow
									Call SalMessageBox( 'Opps, I have missed a row! Please inform Jan! (Code 2)', 'Warning', MB_Ok )
								Set nRowCount = nRowCount + nIncBy
							Call SalTblSetFocusRow( hWndTable, nContextRow - nNumRows + 1 )
							Call SalEndDialog( hWndForm, nOk )
						Else
							If SalIsNull( cSeqNoFrom )
								Call SalMessageBox( 'Please enter a Starting Seq. No. first!', 'Warning', MB_Ok )
								Return FALSE
							Else If SalIsNull( cSeqNoTo )
								Call SalMessageBox( 'Please enter a Finishing Seq. No. first!', 'Warning', MB_Ok )
								Return FALSE
							Else If SalIsNull( cRowNo )
								Call SalMessageBox( 'Please enter a Row No. first!', 'Warning', MB_Ok )
								Return FALSE
							!
							Set nFromSeqNo = SalStrToNumber( cSeqNoFrom.GetNumber( ) )
							Set nToSeqNo = SalStrToNumber( cSeqNoTo.GetNumber( ) )
							Set nRowNo = SalStrToNumber( cRowNo.GetNumber( ) )
							Set nIncBy = SalStrToNumber( cIncBy.GetNumber( ) )
							!
							Set nLastContextRow = -99
							Set nContextRow = -99
							Set nNumRows = 0
							Set nRowCount = nFromSeqNo
							While nRowCount <= nToSeqNo
								Call PushNumber( nRowCount )
								Call PushNumber( nRowNo )
								If SalSendMsg( hWndTable, PAM_TBLBULKADDROW, nSeqRange, TBL_MaxRow )
									Call PopNumber( nContextRow, TRUE )
									Set nLastContextRow = nContextRow
									Set nNumRows = nNumRows + 1
								Else
									Call SalMessageBox( 'Opps, I have missed a row! Please inform Jan! (Code1)', 'Warning', MB_Ok )
								If nLastContextRow != nContextRow
									Call SalMessageBox( 'Opps, I have missed a row! Please inform Jan! (Code 2)', 'Warning', MB_Ok )
								Set nRowCount = nRowCount + nIncBy
							Call SalTblSetFocusRow( hWndTable, nContextRow - nNumRows + 1 )
							Call SalEndDialog( hWndForm, nOk )

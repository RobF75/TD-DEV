		Functions
			Function: IsAnyStockGrowing
				Description:
				Returns
					Boolean:
				Parameters
					String: sFarmId
					Number: nYear
					Number: nExecuteOrDisconnect
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					String: sSql
					Number: nInd
				Actions
					If nExecuteOrDisconnect != nDisconnect
						If NOT bHandleConnected
							Set bHandleConnected = SqlConnect( hSqlHandle ) 
							If bHandleConnected
								Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
								Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
							Else
								Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
								Return FALSE
						If NOT bHandlePrepared
							Set sSql = ' SELECT Stock_Item_No FROM Growing_Sale, Location  
									  WHERE Growing_Sale.Location_Id = Location.Location_Id AND 
									  Growing_Sale.Year_Of_Sale = :nYear AND 
									  Location.Farm_Name = :sFarmId '
							If SqlPrepare( hSqlHandle, sSql )
								Set bHandlePrepared = TRUE
							Else
								Set bHandlePrepared = FALSE
						!
						If SqlExecute( hSqlHandle )
							If SqlFetchNext( hSqlHandle, nInd )
								Return TRUE
							Else
								Return FALSE
						Else
							Set bHandlePrepared = FALSE
							Call SalMessageBox( 'SqlExecute had a error in IsAnyStockGrowing!, Contact programmers please!', 'ERROR', MB_Ok )
							Return FALSE
					Else
						Set bHandlePrepared = FALSE
						If bHandleConnected
							Set bHandleConnected = FALSE
							Call SqlDisconnect( hSqlHandle )
						Return TRUE
		Window Parameters
		Window Variables
			String: sHelpFileName
			Boolean: bFirstEntry
			Number: nDefaultYear
			Number: nQtr
			!
			!
			String: sRepInto
			String: sRepBind
			String: sReportFile
			Number: nError
			!
			Number: nFarmRow
			Number: nStockRow
			Boolean: bProcessFarm
			Boolean: bProcessStock
			Boolean: bPopulateTblStock
			!
			Boolean: bPrintFieldCountList
			Boolean: bPrintBudOverList
			Boolean: bPrintScionEvalList
		Message Actions
			On SAM_Create
				Set sHelpFileName = ''
				Set bFirstEntry = TRUE
				Set dfCurrDate = SalDateCurrent(  )
				! Set nQtr = SalDateQuarter( dfCurrDate )
				! If nQtr = 4
					    Set nDefaultYear = nDefaultYear + 1
				Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
			On PAM_CREATECOMPLETE
				Set nDefaultYear = cSeasonYear.GetSeasonYear( )
				Set sBuildWhere = ''
				Call SalSendMsg( tblFarm, PAM_POPULATE, 0, 0 )
				Call SalMapEnterToTab( TRUE )
			On SAM_Close
				If NOT TableForgetChanges( tblFarm, frmFarms.tblFarm.bEdit )
					Return FALSE
				Call SalWaitCursor( TRUE )
			On SAM_Destroy
				Call SalMapEnterToTab( FALSE )
				Call IsAnyStockGrowing( '', 0, nDisconnect )
			On SAM_Activate
				Return SalSendMsgToChildren( hWndForm, PAM_ACTIVATE, wParam, lParam )
			On PAM_PRINTFIELDCOUNTLIST
				Set bPrintFieldCountList = TRUE
				Set bPrintBudOverList = FALSE
				Set bPrintScionEvalList = FALSE
				!
				Call CallBuildSql( hWndForm, nSELECT, PAM_FIELDCOUNTLISTFIELDS, '', '' )
				Set sRepInto = sColumns
				Set sRepBind = sIntoVars
				Call CallBuildSql( tblFarm, nSELECT, PAM_FIELDCOUNTLISTFIELDS, '', '' )
				Set sRepInto = sRepInto||','||sColumns
				Set sRepBind = sRepBind||','||sIntoVars
				Call CallBuildSql( tblGrowingStock, nSELECT, PAM_FIELDCOUNTLISTFIELDS, '', '' )
				Set sRepInto = sRepInto||','||sColumns
				Set sRepBind = sRepBind||','||sIntoVars
				Set sReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\grwplan3.qrp'
				Set nError = 1
				Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, RPT_PrintAll,0,0, nError )
			On PAM_PRINTSCIONEVALLISTING
				Set bPrintFieldCountList = FALSE
				Set bPrintBudOverList = FALSE
				Set bPrintScionEvalList = TRUE
				!
				Call CallBuildSql( tblFarm, nSELECT, PAM_FIELDCOUNTLISTFIELDS, '', '' )
				Set sRepInto = sColumns
				Set sRepBind = sIntoVars
				Call CallBuildSql( tblScionEvalOnFarm, nSELECT, PAM_FIELDCOUNTLISTFIELDS, '', '' )
				Set sRepInto = sRepInto||','||sColumns
				Set sRepBind = sRepBind||','||sIntoVars
				Set sReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\scinpln3.qrp'
				Set nError = 1
				Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, RPT_PrintAll,0,0, nError )
			On PAM_PRINTBUDOVERLIST
				Set bPrintFieldCountList = FALSE
				Set bPrintBudOverList = TRUE
				Set bPrintScionEvalList = FALSE
				!
				Call CallBuildSql( hWndForm, nSELECT, PAM_FIELDCOUNTLISTFIELDS, '', '' )
				Set sRepInto = sColumns
				Set sRepBind = sIntoVars
				Call CallBuildSql( tblFarm, nSELECT, PAM_FIELDCOUNTLISTFIELDS, '', '' )
				Set sRepInto = sRepInto||','||sColumns
				Set sRepBind = sRepBind||','||sIntoVars
				Call CallBuildSql( tblGrowingStock, nSELECT, PAM_FIELDCOUNTLISTFIELDS, '', '' )
				Set sRepInto = sRepInto||','||sColumns
				Set sRepBind = sRepBind||','||sIntoVars
				Set sReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\budover3.qrp'
				Set nError = 1
				Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, RPT_PrintAll,0,0, nError )
			On SAM_ReportStart
				If bPrintFieldCountList OR bPrintBudOverList
					Set nFarmRow = TBL_MinRow
					Set nStockRow = TBL_MinRow
					Set bProcessFarm = TRUE
					Set bProcessStock = FALSE
					Set bPopulateTblStock = FALSE
					Return TRUE
				If bPrintScionEvalList
					Set nFarmRow = TBL_MinRow
					Set nStockRow = TBL_MinRow
					Set bProcessFarm = TRUE
					Set bProcessStock = FALSE
					Set bPopulateTblStock = FALSE
					Return TRUE
			On SAM_ReportFetchInit
				Return TRUE
			On SAM_ReportFetchNext
				If bPrintFieldCountList OR bPrintBudOverList
					If bProcessFarm
						Loop
							Set bOk = SalTblFindNextRow( tblFarm, nFarmRow, ROW_Selected, 0 )
							!
							If bOk
								Call SalTblFetchRow( tblFarm, nFarmRow )
								If IsAnyStockGrowing( tblFarm.colFarm, dfYear, nExecute )
									Call SalTblReset( tblGrowingStock )
									Set bProcessFarm = FALSE
									Set bProcessStock = TRUE
									Set nStockRow = TBL_MinRow
									Set bPopulateTblStock = TRUE
									Return TRUE
							If NOT bOk
								Return FALSE
					If bProcessStock
						If bPopulateTblStock
							Call SalSendMsg( tblGrowingStock, PAM_POPULATE, 0, 0 )
							Set bPopulateTblStock = FALSE
						Loop
							Set bOk = SalTblFindNextRow( tblGrowingStock, nStockRow, 0, 0 )
							If bOk
								If NOT SalTblFindNextRow( tblGrowingStock, nStockRow, 0, 0 )
									Set bProcessFarm = TRUE
									Set bProcessStock = FALSE
								Else
									Call SalTblFindPrevRow( tblGrowingStock, nStockRow, 0, 0  )
								Call SalTblFetchRow( tblGrowingStock, nStockRow )
								If bPrintFieldCountList
									Call GetPaintCodes( tblGrowingStock.colCultId, '', frmFarms.dfYear, tblGrowingStock.colCultPaintCodes, nExecute )
									Call GetPaintCodes( '', tblGrowingStock.colRootId, frmFarms.dfYear, tblGrowingStock.colRootPaintCodes, nExecute )
								Break
							If NOT bOk
								Set bProcessFarm = TRUE
								Set bProcessStock = FALSE
								Return TRUE
						Return TRUE
				If bPrintScionEvalList
					If bProcessFarm
						Loop
							Set bOk = SalTblFindNextRow( tblFarm, nFarmRow, ROW_Selected, 0 )
							!
							If bOk
								Call SalTblFetchRow( tblFarm, nFarmRow )
								Call SalTblReset( tblScionEvalOnFarm )
								Set bProcessFarm = FALSE
								Set bProcessStock = TRUE
								Set nStockRow = TBL_MinRow
								Set bPopulateTblStock = TRUE
								Return TRUE
							If NOT bOk
								Return FALSE
					If bProcessStock
						If bPopulateTblStock
							Call SalSendMsg( tblScionEvalOnFarm, PAM_POPULATE, 0, 0 )
							Set bPopulateTblStock = FALSE
						Loop
							Set bOk = SalTblFindNextRow( tblScionEvalOnFarm, nStockRow, 0, 0 )
							If bOk
								If NOT SalTblFindNextRow( tblScionEvalOnFarm, nStockRow, 0, 0 )
									Set bProcessFarm = TRUE
									Set bProcessStock = FALSE
								Else
									Call SalTblFindPrevRow( tblScionEvalOnFarm, nStockRow, 0, 0  )
								Call SalTblFetchRow( tblScionEvalOnFarm, nStockRow )
								Break
							If NOT bOk
								Set bProcessFarm = TRUE
								Set bProcessStock = FALSE
								Return TRUE
						Return TRUE
			On SAM_ReportFinish
				Call GetPaintCodes( '', '', 0, tblGrowingStock.colRootPaintCodes, nDisconnect )
				Call SalWaitCursor( FALSE )
				Return TRUE

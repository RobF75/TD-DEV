					Column: colLocationId
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class: OurColumnClass
						Property Template:
						Class DLL Name:
						Title: Location Id
						Visible? No
						Editable? Class Default
						Maximum Data Length: Class Default
						Data Type: Number
						Justify: Class Default
						Width:  Class Default
						Width Editable? Class Default
						Format: Class Default
						Country: Class Default
						Input Mask: Class Default
						Cell Options
							Cell Type? Class Default
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? Class Default
								Vertical Scroll? Class Default
								Auto Drop Down? Class Default
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
							On PAM_SETINSTANCEVARS
								Set OurColumnClass.sSQLCOLNAME = ' SCION_EVALUATION.LOCATION_ID '
								Set OurColumnClass.bUpdate = FALSE
								Set OurColumnClass.bRenewRowId = TRUE
							On PAM_CHECKROWNEW
								If GetLocationId( frmScionEvalOnFarm.dfFarmId, colRow, colSeq, colLocationId, nExecute )
									Set nItemNo = NUMBER_Null
									If GetAnyScionEvalGrowing( colLocationId, nItemNo, nExecute )
										Set bUserNotification = TRUE
										Set colUserNotification = 'This growing location already exists in the growing sale table!'
										Return FALSE
									Else
										If nItemNo > 0
											Set bUserNotification = TRUE
											Set colUserNotification = 'Another Stock Item is already growing at this location!'
											Return FALSE
								Else
									If GetNewLocationId( colLocationId, nExecute )
										If AddNewLocation( colLocationId, frmScionEvalOnFarm.dfFarmId, colRow, colSeq, nExecute )
											Call AddNewLocation( 0, '', 0, 0, nCommit )
											Set bUserNotification = TRUE
											Set colUserNotification = 'A Location has been inserted into the Location table!'
										Else
											Call AddNewLocation( 0, '', 0, 0, nRollback )
											Set bUserNotification = TRUE
											Set colUserNotification = 'Insert Failed into the Location table!'
											Return FALSE
									Else
										Set bUserNotification = TRUE
										Set colUserNotification = 'Insert Failed into the Location table! Could not obtain new Location Id!'
										Return FALSE
								Return TRUE
					Column: colItemNo
						Class Child Ref Key: 0
						Class ChildKey: 0

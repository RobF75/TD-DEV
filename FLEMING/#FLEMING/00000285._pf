				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					Sql Handle: hSqlRootDescHdl
					Boolean: bRootDescHdlConnected
					Boolean: bRootDescHdlPrepared
					String: sSQLTABLENAME
					String: sORDERBY
					String: sQueryTmpStr
					String: sCurrentBuildWhere
					String: sQueryBuildWhere
					String: sSqlRootDesc
					Number: nInd
				Message Actions
					On PAM_POPULATE
						Set sQueryBuildWhere = sBuildWhere
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_REPOPULATE
						Call TableRePopulate( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLTABLENAME, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_SEARCH
						Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_RESET
						Call TableReset( hWndForm, colTreeTypeDesc )
					! On SAM_FetchRow
						    If SqlFetchRow( hLocalSqlPopTbl, lParam, nInd )
							    If NOT SalIsNull( colRootId )
								    If NOT MySelectRecord( hSqlRootDescHdl, bRootDescHdlConnected, bRootDescHdlPrepared, sSqlRootDesc, nFetchFirst, nInd )
									    Call SalMessageBox( 'Extraction of Root Description failed on FetchRow of Root Description, Contact Jan about this error.', 'Error', MB_Ok )
							    Return TBL_RowFetched
					! On SAM_FetchRowDone
						    If NOT SalIsNull( colRootId )
							    If NOT MySelectRecord( hSqlRootDescHdl, bRootDescHdlConnected, bRootDescHdlPrepared, sSqlRootDesc, nFetchFirst, nInd )
								    Call SalMessageBox( 'Extraction of Root Description failed on FetchRow of Root Description, Contact Jan about this error.', 'Error', MB_Ok )
					On SAM_DoubleClick
						Call SalSendMsg( dlgQItem.pbSelect, SAM_Click, 0, 0 )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set sSQLTABLENAME = ' STOCK_ITEM ' 
						Set sORDERBY = ' ORDER BY 2,3 '
						Set sSqlRootDesc = ' SELECT Root_Desc FROM Rootstock
								  INTO :dlgQItem.tblItem.colRootDesc WHERE 
								  Root_Id = :dlgQItem.tblItem.colRootId'
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
						If bRootDescHdlConnected
							Call SqlDisconnect( hSqlRootDescHdl )
			Pushbutton: pbSelect
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: S&elect
				Window Location and Size
					Left:   0.163"
					Top:    5.177"
					Width:  1.575"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: (none)
				Font Name: Default
				Font Size: Default
				Font Enhancement: Italic
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						If NOT SalTblAnyRows( tblItem, ROW_Selected, 0 )
							Call SalMessageBox( 'Record Not Selected', 'Error', MB_Ok )
						Else
							Call SalWaitCursor( TRUE )
							Set bSelect = TRUE
							Set nRow = TBL_MaxRow
							! Check to see in Centura if the bug about a large result set and not selecting records
									from a large result set with TBL_FillNormal is still in here
							While SalTblFindPrevRow( tblItem, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblItem, nRow )
								Call SalTblSetRowFlags( tblItem, nRow, ROW_Selected, FALSE )
								Call PushNumber( dlgQItem.tblItem.colItemNo )
								Call PushString( dlgQItem.tblItem.colRootDesc )
								Call PushString( dlgQItem.tblItem.colRootId )
								Call PushString( dlgQItem.tblItem.colCultVariety )
								Call PushString( dlgQItem.tblItem.colCultDesc )
								Call PushString( dlgQItem.tblItem.colCultId )
								Call PushString( dlgQItem.tblItem.colTreeTypeDesc )
								Call SalSendMsg( hWndPushbutton, PAM_LOOKUP, 0, 0 )
								If SalTblAnyRows( tblItem, ROW_Selected, 0 )
									Call SalSendMsg( hWndPushbutton, PAM_READYFORNEXTLOOKUP, 0, 0 )
							Call SalEndDialog( hWndForm, 0 )
					On SAM_Create
						If NOT bEnableSelectPb
							Call SalDisableWindow( hWndItem )
					On PAM_ENABLE
						Call SalEnableWindow( hWndItem )
					On PAM_DISABLE
						Call SalDisableWindow( hWndItem )

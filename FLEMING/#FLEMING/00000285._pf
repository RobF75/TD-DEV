				    Message Actions 
					    On SAM_Click
						    Set dfYear = dfYear + 1
			    Pushbutton: pbOk
				    Message Actions 
					    On SAM_Click
						    Call SalWaitCursor( TRUE )
						    Call SalDisableWindow( hWndItem )
						    If SalIsNull( dfYear )
							    Call SalWaitCursor( FALSE )
							    Call SalMessageBox( 'Please enter a year first!', 'Warning', MB_Ok )
							    Call SalEnableWindow( hWndItem )
							    Return FALSE
						    Else If dfYear >= 97 AND dfYear <  100
							    Set dfYear = dfYear + 1900
						    Call PushNumber( dfYear )
						    Call SalEndDialog( hWndForm, nOk )
			    Pushbutton: pbCancel
				    Message Actions 
					    On SAM_Click
						    Call SalWaitCursor( TRUE )
						    Call SalDisableWindow( hWndItem )
						    Call SalEndDialog( hWndForm, nCancel )
		    Functions 

					Maximum Rows in Memory: 1000
					Discardable? Yes
				Contents
					Column: colWhere
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title:
						Visible? No
						Editable? Yes
						Maximum Data Length: Default
						Data Type: String
						Justify: Left
						Width:  1.2"
						Width Editable? Yes
						Format: Unformatted
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_WHEREPOPULATE
								If sQueryBuildWhere = ''
									If frmFarmStock.bPopulateAllYears
										Set sBuildWhere = ' WHERE  
												  GROWING_SALE.LOCATION_ID = LOCATION.LOCATION_ID AND
												  LOCATION.FARM_NAME = :frmFarmStock.dfFarmId AND
												  GROWING_SALE.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO(+) '
									Else
										Set sBuildWhere = ' WHERE GROWING_SALE.YEAR_OF_SALE = :frmFarmStock.dfYear AND 
												  GROWING_SALE.LOCATION_ID = LOCATION.LOCATION_ID AND
												  LOCATION.FARM_NAME = :frmFarmStock.dfFarmId AND
												  GROWING_SALE.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO(+) '
								Else
									If frmFarmStock.bPopulateAllYears
										Set sBuildWhere = sQueryBuildWhere || ' AND 
												  GROWING_SALE.LOCATION_ID = LOCATION.LOCATION_ID AND
												  LOCATION.FARM_NAME = :frmFarmStock.dfFarmId AND
												  GROWING_SALE.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO(+) '
									Else
										Set sBuildWhere = sQueryBuildWhere || ' AND GROWING_SALE.YEAR_OF_SALE = :frmFarmStock.dfYear AND 
												  GROWING_SALE.LOCATION_ID = LOCATION.LOCATION_ID AND
												  LOCATION.FARM_NAME = :frmFarmStock.dfFarmId AND
												  GROWING_SALE.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO(+) '
							On PAM_QBE
								Call PushString( NOTHINGFOLLOWING )
								If frmFarmStock.bPopulateAllYears
									Call PushString( ' GROWING_SALE.LOCATION_ID = LOCATION.LOCATION_ID AND
											  LOCATION.FARM_NAME = :frmFarmStock.dfFarmId AND
											  GROWING_SALE.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO(+) ' )
								Else
									Call PushString( ' GROWING_SALE.YEAR_OF_SALE = :frmFarmStock.dfYear AND 
											  GROWING_SALE.LOCATION_ID = LOCATION.LOCATION_ID AND
											  LOCATION.FARM_NAME = :frmFarmStock.dfFarmId AND
											  GROWING_SALE.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO(+) ' )
							On PAM_DATAVAL
								Return TRUE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE

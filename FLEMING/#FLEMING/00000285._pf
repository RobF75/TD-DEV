			Pushbutton: pbSetNextSeason
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: Mark Next Season, for conversion
				Window Location and Size
					Left:   3.325"
					Top:    0.552"
					Width:  3.05"
					Width Editable? Yes
					Height: 0.198"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: F3
				Font Name: Default
				Font Size: Default
				Font Enhancement: Default
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Create
						If SqlUser = 'JAN' OR SqlUser = 'DANI'
							Call SalShowWindow( hWndItem )
						Else
							Call SalHideWindow( hWndItem )
					On SAM_Click
						Call MyTableLoop( tblGrowingStock, hWndItem, PAM_ROWACTION, 0, 0, 'Checking Season Year', nLowToHi )
					On PAM_ROWACTION
						! If SalIsNull( tblGrowingStock.colEstSaleDate )
							    Set nTmp = cSeasonYear.GetSeasonYear( )
							    If nTmp < 1900
								    Set nTmp = nTmp + 1900
							    Set tblGrowingStock.colEstSaleDate = SalDateConstruct( nTmp, 9, 1, 0, 0, 0 )
							    Call SalTblSetRowFlags( tblGrowingStock, lParam, ROW_Edited, TRUE )
						! Else
							    If WhichSeasonYear( tblGrowingStock.colEstSaleDate ) != cSeasonYear.GetSeasonYear( )
								    Call SalTblSetRowFlags( tblGrowingStock, lParam, ROW_Edited, TRUE )
						If NOT SalIsNull( tblGrowingStock.colEstSaleDate )
							If WhichSeasonYear( tblGrowingStock.colEstSaleDate ) != cSeasonYear.GetSeasonYear( )
								Call SalTblSetRowFlags( tblGrowingStock, lParam, ROW_Edited, TRUE )
						Return TRUE

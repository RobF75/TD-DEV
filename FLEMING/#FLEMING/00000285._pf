						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL(  wParam, hWndItem, 'LOCATION.ROW#' )
							On PAM_ADDLOCATION
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'ROW#' )
							On PAM_ADDNEWLOCATION
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'ROW#' )
							On PAM_CANORDERBY
								Call PushNumber( 3 )
								Call SalTblGetColumnTitle( hWndItem, sQueryTmpStr, 30 )
								Call PushString( sQueryTmpStr )
								Return TRUE
							On PAM_ENABLECHILDSELECTPB
								Set frmFarmStock.bEnableQItemDlgSelectPb = TRUE
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On PAM_EDITCHECK
								If NOT SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
									Call SalTblKillEdit( hWndForm )
							On PAM_DATAVAL
								If SalIsNull( hWndItem )
									Call SalMessageBox( 'Please enter a Row# first!', 'Warning', MB_Ok )
									Return FALSE
								Return TRUE

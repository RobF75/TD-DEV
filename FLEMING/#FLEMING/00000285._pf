			Number: nNumRows
		Message Actions
			On SAM_Create
				Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
			On PAM_CREATECOMPLETE
				Call PopWndHdl( hWndTable, TRUE )
				Call PopNumber( dfIncRowNoBy, TRUE )
				Call PopNumber( dfSeqNo, TRUE )
				Call PopNumber( dfToRowNo, TRUE )
				Call PopNumber( dfFromRowNo, TRUE )
				Set dfCurrDate = SalDateCurrent(  )
				Call SalWaitCursor( FALSE )

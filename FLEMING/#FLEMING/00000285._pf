						Parameters
							String: sFarmId
							Number: nRowNo
							Number: nSeqNo
							Receive Number: nLocationId
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Number: nGotLocationId
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Location_Id FROM Location INTO :nGotLocationId WHERE Farm_Name = :sFarmId AND Row# = :nRowNo AND Seq# = :nSeqNo '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								Set nLocationId = NUMBER_Null
								Set nGotLocationId = NUMBER_Null
								If SqlExecute( hSqlHandle )
									If SqlFetchNext( hSqlHandle, nInd )
										Set nLocationId = nGotLocationId
										Return TRUE
									Else
										Return FALSE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in GetLocationId!, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Call SqlDisconnect( hSqlHandle )
								Return TRUE
					Function: AddNewLocation
						Description:
						Returns
							Boolean:
						Parameters
							Number: nLocationId
							String: sFarmId
							Number: nRowNo
							Number: nSeqNo
							Number: nActionType
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
						Actions
							Select Case nActionType
								Case nExecute
									If NOT bHandleConnected
										Set bHandleConnected = SqlConnect( hSqlHandle ) 
										If bHandleConnected
											Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
											Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
										Else
											Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
											Return FALSE
									If NOT bHandlePrepared
										Set sSql = ' INSERT INTO Location ( Location_Id, Farm_Name, Row#, Seq#, Loc_Added_By, Loc_Added_Date )
												  VALUES ( :nLocationId, :sFarmId, :nRowNo, :nSeqNo, USER, SYSDATE ) '
										If SqlPrepare( hSqlHandle, sSql )
											Set bHandlePrepared = TRUE
										Else
											Set bHandlePrepared = FALSE
									If SqlExecute( hSqlHandle )
										Return TRUE
									Else
										Set bHandlePrepared = FALSE
										Call SalMessageBox( 'SqlExecute had a error in AddNewLocation!, Contact programmers please!', 'ERROR', MB_Ok )
										Return FALSE
								Case nCommit
									Call SqlCommit( hSqlHandle )
									Return TRUE
								Case nRollback
									Call SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
									Set bHandlePrepared = FALSE
									Return TRUE
								Case nDisconnect
									Set bHandlePrepared = FALSE
									If bHandleConnected
										Set bHandleConnected = FALSE
										Call SqlDisconnect( hSqlHandle )
									Return TRUE
					Function: GetNewLocationId
						Description:
						Returns
							Boolean:
						Parameters
							Receive Number: nLocationId
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Number: nGotLocationId
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Max( Location_Id ) + 1 FROM Location INTO :nGotLocationId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								Set nLocationId = 1
								Set nGotLocationId = 1
								If SqlExecute( hSqlHandle )
									If SqlFetchNext( hSqlHandle, nInd )
										Set nLocationId = nGotLocationId
										Return TRUE
									Else
										Return FALSE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in GetLocationId!, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Call SqlDisconnect( hSqlHandle )
								Return TRUE
					Function: GetAnyScionEvalGrowing
						Description:
						Returns
							Boolean:
						Parameters
							Number: nLocationId
							Receive Number: nItemNo
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Number: nGotItemNo
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Stock_Item_No FROM Scion_Evaluation INTO :nGotItemNo 
											  WHERE Location_Id = :nLocationId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								Set nItemNo = NUMBER_Null
								Set nGotItemNo = NUMBER_Null
								If SqlExecute( hSqlHandle )
									If SqlFetchNext( hSqlHandle, nInd )
										Set nItemNo = nGotItemNo
										Return TRUE
									Else
										Return FALSE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in GetAnyScionEvalGrowing!, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Call SqlDisconnect( hSqlHandle )
								Return TRUE
				Window Variables
					Number: nItemNo
					Number: nRow
					Boolean: bUserNotification
					Number: nDefaultFromRowNo
					Number: nDefaultToRowNo
					Number: nDefaultIncRowNoBy
					Number: nDefaultSeqNo
					Number: nSelectedItemNo
					String: sSelectedTreeTypeDesc
					String: sSelectedCultId
					String: sSelectedCultDesc
					String: sSelectedVariety
					String: sSelectedRootId
					String: sSelectedRootDesc
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' SCION_EVALUATION '
						Set sSQLPOPTABLENAME = ' SCION_EVALUATION, LOCATION, STOCK_ITEM '
						Set sSQLWHERE = ' WHERE Location.Farm_Name = :frmScionEvalOnFarm.dfFarmId AND 
								  Scion_Evaluation.Location_Id = Location.Location_Id AND 
								  Scion_Evaluation.Stock_Item_No = Stock_Item.Item_No(+) '
						Set sORDERBY = ' ORDER BY LOCATION.ROW#, LOCATION.SEQ# '
						Set sROWID = ' SCION_EVALUATION.ROWID '
						Set sTableHeading = ' Scion Evaluation '
						!
						Set nDefaultFromRowNo = 1
						Set nDefaultToRowNo = 100
						Set nDefaultSeqNo = 10
						Set nDefaultIncRowNoBy = 1
					! On SAM_FetchRowDone
						    If NOT SalIsNull( colItemNo ) AND ( SalIsNull( colCultId ) AND SalIsNull( colRootId ) )
							    Call GetItemBasicDetails( colItemNo, colTreeType, colCultId, colRootId, nExecute )
							! Call GetCultDescription( colCultId, colCultDesc, nExecute )
							! Call GetRootDescription( colRootId, colRootDesc, nExecute )
						    Else 
							    Call GetCultDescription( colCultId, colCultDesc, nExecute )
							    Call GetRootDescription( colRootId, colRootDesc, nExecute )
					On PAM_WRITEINSERTSUPDATES
						Set bUserNotification = FALSE
						Call SalSendClassMessage( PAM_WRITEINSERTSUPDATES, wParam, lParam )
						If bUserNotification
							Call SalSendMsg( colUserNotification, PAM_ENABLE, TRUE, 0 )
							Call SalMessageBox( 'Special actions were performed on some of the rows!', 'NOTE', MB_Ok )
						Else
							Call SalSendMsg( colUserNotification, PAM_ENABLE, FALSE, 0 )
					On PAM_TBLBULKADDROW
						If wParam = nSeqRange
							Set nRow = SalTblInsertRow( hWndForm, lParam )
							Call PopNumber( colRow, TRUE )
							Call PopNumber( colSeq, TRUE )
							Call PushNumber( nRow )
							Return TRUE
						Else
							Set nRow = SalTblInsertRow( hWndForm, lParam )
							Call PopNumber( colSeq, TRUE )
							Call PopNumber( colRow, TRUE )
							Call PushNumber( nRow )
							Return TRUE
					On SAM_Destroy
						! Call GetItemBasicDetails( 0, colTreeType, colCultId, colRootId, nDisconnect )
						! Call GetCultDescription( '', colCultDesc, nDisconnect )
						! Call GetRootDescription( '', colRootDesc, nDisconnect )
						Call GetLocationId( '', 0, 0, colLocationId, nDisconnect )
						Call GetAnyScionEvalGrowing( 0, nItemNo, nDisconnect )
						Call GetNewLocationId( colLocationId, nDisconnect )
						Call AddNewLocation( 0, '', 0, 0, nDisconnect )
						Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
			Pushbutton: pbTblBulkAddLocations

								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL(  wParam, hWndItem, 'GROWING_SALE.STOCK_ITEM_NO' )
							On PAM_ADDGRSALE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM_NO' )
							On PAM_ADDNEWGRSALE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM_NO' )
							On PAM_ADDSTCKITMSALE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM_NO' )
							On PAM_UPDATEGRSALE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM_NO' )
							On PAM_LOOKUPITEM
								Call PopNumber( nSelectedItemNo,TRUE )
								Call PopString( sSelectedTreeTypeDesc,TRUE )
								Call PopString( sSelectedCultId,TRUE )
								Call PopString( sSelectedCultDesc,TRUE )
								Call PopString( sSelectedVariety,TRUE )
								Call PopString( sSelectedRootId,TRUE )
								Call PopString( sSelectedRootDesc,TRUE )
								!
								If colOldItemNo > 0
									! Call CheckForwardOrdersExist( colLocationId, colOrgYear, bExists, nExecute )
									! If bExists
										    Call SalMessageBox( 'The currently picked over item has future orders placed against and CANNOT be picked over.', 'Warning', MB_Ok )
										    Return TRUE
									Call SalMessageBox( 'Picked over a existing item is not implemented as yet.', 'Warning', MB_Ok )
									Return TRUE
								!
								Set colItemNo = nSelectedItemNo
								Set colTreeTypeDesc = sSelectedTreeTypeDesc
								Set colCultId = sSelectedCultId
								Set colCultDesc = sSelectedCultDesc
								Set colVariety = sSelectedVariety
								Set colRootId = sSelectedRootId
								Set colRootDesc = sSelectedRootDesc
								Call SalSetFieldEdit( colItemNo, TRUE )
								Call SalSetFieldEdit( colTreeTypeDesc, TRUE )
								Call SalSetFieldEdit( colCultId, TRUE )
								Call SalSetFieldEdit( colCultDesc, TRUE )
								Call SalSetFieldEdit( colVariety, TRUE )
								Call SalSetFieldEdit( colRootId, TRUE )
								Call SalSetFieldEdit( colRootDesc, TRUE )
								Return TRUE
							On PAM_SETSELECTEDITEM
								If colOldItemNo > 0
									! Call CheckForwardOrdersExist( colLocationId, colOrgYear, bExists, nExecute )
									! If bExists
										    Call SalMessageBox( 'The currently picked over item has future orders placed against and CANNOT be picked over.', 'Warning', MB_Ok )
										    Return TRUE
									Call SalMessageBox( 'Picked over a existing item is not implemented as yet.', 'Warning', MB_Ok )
									Return TRUE
								Else
									Set colItemNo = nSelectedItemNo
									Call SalSetFieldEdit( hWndItem, TRUE )
									Set colTreeTypeDesc = sSelectedTreeTypeDesc
									Call SalSetFieldEdit( hWndItem, TRUE )
									Set colCultId = sSelectedCultId
									Call SalSetFieldEdit( hWndItem, TRUE )
									Set colCultDesc = sSelectedCultDesc
									Call SalSetFieldEdit( hWndItem, TRUE )
									Set colVariety = sSelectedVariety
									Call SalSetFieldEdit( hWndItem, TRUE )
									Set colRootId = sSelectedRootId
									Call SalSetFieldEdit( hWndItem, TRUE )
									Set colRootDesc = sSelectedRootDesc
									Call SalSetFieldEdit( hWndItem, TRUE )
									Return TRUE
							On PAM_DATAVAL
								If SalIsNull( hWndItem ) AND 
										( NOT SalIsNull( colBegCount ) 
										  OR NOT SalIsNull( colFirstCount ) 
										  OR NOT SalIsNull( colSecondCount ) 
										  OR NOT SalIsNull( colDatePlanted ) 
										  OR NOT SalIsNull( colDateBudded ) )
									Call ErrorMessage( 'A Stock Item is needed before any Counts can be entered!  Please rectify!', hWndForm, ngRow )
									Return FALSE
								Return TRUE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE

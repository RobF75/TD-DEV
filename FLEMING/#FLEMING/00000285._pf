								Set OurColumnClass.sSQLCOLNAME = ' SCION_EVALUATION.STOCK_ITEM_NO '
							On PAM_LOOKUPITEM
								Call PopNumber( colItemNo,TRUE )
								Set nSelectedItemNo = colItemNo
								Call SalSetFieldEdit( hWndItem, TRUE )
							On PAM_SETSELECTEDITEM
								Set colItemNo = nSelectedItemNo
								Call SalSetFieldEdit( hWndItem, TRUE )
							On PAM_DATAVAL
								If ( NOT SalIsNull( colTreeTypeDesc ) OR 
										     NOT SalIsNull( colCultDesc ) OR
										     NOT SalIsNull( colRootDesc ) OR
										     NOT SalIsNull( colComments ) )AND 
										  SalIsNull( hWndItem )
									Call ErrorMessage( 'Please dont just type the item details but rather Pick from the Stock Items button!', hWndForm, lParam )
									Return FALSE
								Else
									Return TRUE

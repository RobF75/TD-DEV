							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_WHEREPOPULATE
								Set sBuildWhere = ' WHERE GROWING_SALE.YEAR_OF_SALE = :frmFarms.dfYear AND 
										  GROWING_SALE.LOCATION_ID = LOCATION.LOCATION_ID AND
										  LOCATION.FARM_NAME = :frmFarms.tblFarm.colFarm AND
										  GROWING_SALE.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO(+) '
							On PAM_QBE
								Call PushString( NOTHINGFOLLOWING )
								Call PushString( ' GROWING_SALE.YEAR_OF_SALE = :frmFarmStock.dfYear AND 
										  GROWING_SALE.LOCATION_ID = LOCATION.LOCATION_ID AND
										  LOCATION.FARM_NAME = :frmFarmStock.dfFarmId AND
										  GROWING_SALE.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO(+) ' )
							On PAM_DATAVAL
								Return TRUE

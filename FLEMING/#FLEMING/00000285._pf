					Column: colNotForSale
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: NFS
						Visible? Yes
						Editable? Yes
						Maximum Data Length: 1
						Data Type: String
						Justify: Center
						Width:  0.413"
						Width Editable? Yes
						Format: Uppercase
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Check Box
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value: Y
								Uncheck Value: N
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL(  wParam, hWndItem, 'GROWING_SALE.NOT_FOR_SALE' )
							On PAM_ADDGRSALE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'GROWING_SALE.NOT_FOR_SALE' )
							On PAM_ADDNEWGRSALE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'GROWING_SALE.NOT_FOR_SALE' )
							On PAM_UPDATEGRSALE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'GROWING_SALE.NOT_FOR_SALE' )
							On PAM_DATAVAL
								If SalIsNull( hWndItem )
									Set colNotForSale = 'N'
									Return TRUE
								Else If colNotForSale = 'Y' OR colNotForSale = 'N'
									Return TRUE
								Else
									Call ErrorMessage( 'Please use Y/N only!', hWndForm, ngRow )
									Return FALSE
							On PAM_ENABLECHILDSELECTPB
								Set frmFarmStock.bEnableQItemDlgSelectPb = TRUE
							On PAM_FIELDCOUNTLISTFIELDS
								Call BuildSQL(  wParam, hWndItem, 'NotForSaleFlag' )
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE

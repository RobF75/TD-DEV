				Functions
					Function: DeleteFarmLocations
						Description:
						Returns
							Boolean:
						Parameters
							String: sFarmId
							Number: nActionType
						Static Variables
							: fcOurHandle
								Class: hcSqlHandle
						Local variables
							String: sSql
						Actions
							Select Case nActionType
								Case nExecute
									Set sSql = " DELETE FROM Location 
											WHERE 
											  Farm_Name = :sFarmId "
									Call fcOurHandle.PrepareSetup( sSql )
									Call SqlVarSetup( fcOurHandle.hSqlHandle )
									!
									Return fcOurHandle.PrepareAndExecute( )
								Case nCommit
									Return fcOurHandle.Commit( )
								Case nRollback
									Return fcOurHandle.Rollback( )
								Case nDisconnect
									Return fcOurHandle.Disconnect( )
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					Sql Handle: hLocalSqlDoTbl
					Boolean: bLocalSqlDoTbl
					Boolean: bEdit
					Boolean: bExists
					String: sSql
					String: sSQLTABLENAME
					String: sORDERBY
					String: sWHEREROWID
					String: sCurrentBuildWhere
					String: sQueryTmpStr
					String: sQueryBuildWhere
				Message Actions
					On PAM_POPULATE
						Set sQueryBuildWhere = sBuildWhere
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_REPOPULATE
						Call TableRePopulate( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLTABLENAME, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_SEARCH
						Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_ADDROW
						Call TableAddRowNew( hWndForm, colFarm )
					On PAM_RESET
						Call TableReset( hWndForm, colFarm )
					On PAM_WRITEINSERTSUPDATES
						Call TableSaveChanges( hWndForm, hLocalSqlDoTbl, 'Farms', sSQLTABLENAME, sWHEREROWID, bEdit, TRUE )
					On PAM_DELETEROWS
						Call TableDeleteRows( hWndForm )
					On PAM_UNDELETEROWS
						Call TableUnDeleteRows( hWndForm )
					On PAM_NOROWS
						Call SalMessageBox( 'No rows were found.', 'Farms', MB_Ok|MB_IconAsterisk )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bLocalSqlDoTbl = SqlConnect( hLocalSqlDoTbl ) 
						If bLocalSqlDoTbl
							Call SqlSetLockTimeout( hLocalSqlDoTbl, SQLTIMEOUT )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bEdit = FALSE
						Set sSQLTABLENAME = ' FARM_MASTER '
						Set sORDERBY = ' ORDER BY FARM_NAME '
						Set sWHEREROWID = ' WHERE ROWID = :frmFarms.tblFarm.colRowId '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
						If bLocalSqlDoTbl
							Call SqlDisconnect( hLocalSqlDoTbl )
						Call DeleteFarmLocations( '', nDisconnect )

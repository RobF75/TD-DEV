					Sql Handle: hSqlSISExistsHdl
					Boolean: bSISExistsHdlConnected
					Boolean: bSISExistsHdlPrepared
					Sql Handle: hSqlInsSISHdl
					Boolean: bInsSISHdlConnected
					Boolean: bInsSISHdlPrepared
					Sql Handle: hSqlUpdtGrLocHdl
					Boolean: bUpdtGrLocHdlConnected
					Boolean: bUpdtGrLocHdlPrepared
					Sql Handle: hSqlDelItemHdl
					Boolean: bDelItemHdlConnected
					Boolean: bDelItemHdlPrepared
					Sql Handle: hSqlGrSaleItemsHdl
					Boolean: bGrSaleItemsHdlConnected
					Boolean: bGrSaleItemsHdlPrepared
					Sql Handle: hSqlAmtGrSISHdl
					Boolean: bAmtGrSISHdlConnected
					Boolean: bAmtGrSISHdlPrepared
					Sql Handle: hSqlUpdtSISTotHdl
					Boolean: bUpdtSISTotHdlConnected
					Boolean: bUpdtSISTotHdlPrepared
					String: sSqlGetNewLocId
					String: sSqlWhereGrSale
					String: sSqlWhereLocation
					String: sSqlGrSaleItems
					String: sSqlAmtGrowSIS
					String: sSqlUpdtSIS
					! Boolean: bAddGrSale
				Message Actions
					On PAM_POPULATE
						Set sQueryBuildWhere = sBuildWhere
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_REPOPULATE
						Call TableRePopulate( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_SEARCH
						Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_ADDROW
						Call TableAddRowNew( hWndForm, colRow )
					! On PAM_TBLBULKADDROW
						    Call TableAddRowNew( hWndForm, colRow )
						    Call PopNumber( colSeq, TRUE )
						    Call PopNumber( colRow, TRUE )
					On PAM_TBLBULKADDROW
						Set nRow = SalTblInsertRow( hWndForm, lParam )
						Call PopNumber( colSeq, TRUE )
						Call PopNumber( colRow, TRUE )
						Call PushNumber( nRow )
						Return TRUE
					On PAM_RESET
						Call TableReset( hWndForm, colRow )
					On PAM_WRITEINSERTSUPDATES
						If NOT TableDataVal( hWndForm )
							Return FALSE
						Set bSaveOk = TRUE
						Set bUserNotification = FALSE
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( hWndForm, nRow, ROW_New|ROW_Edited|ROW_MarkDeleted, 0 )
							Call SalTblFetchRow( hWndForm, nRow )
							Call SalTblSetFocusRow( hWndForm, nRow )
							Set colUserNotification = ''
							Set bRowOk = FALSE
							If SalTblQueryRowFlags( hWndForm, nRow, ROW_New )
								If LocationExists( hSqlLocExistsHdl, bLocExistsHdlConnected, bLocExistsHdlPrepared, frmFarmStock.dfFarmId, colRow, colSeq, frmFarmStock.tblGrowingStock.colLocationId )
									If GrowingAnything( hSqlGrowAnyHdl, bGrowAnyHdlConnected, bGrowAnyHdlPrepared, frmFarmStock.tblGrowingStock.colLocationId, frmFarmStock.dfYear, nItemNo )
										Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
										Call SalTblFetchRow( hWndForm, nRow )
										Set bUserNotification = TRUE
										Set colUserNotification = 'This growing location already exists in the growing sale table!'
									Else
										If nItemNo > 0
											Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
											Call SalTblFetchRow( hWndForm, nRow )
											Set bUserNotification = TRUE
											Set colUserNotification = 'Another Stock Item is already growing at this location!'
										Else
											If SalIsNull( colItemNo )
												If MyInsertRecord( hSqlAddGrSaleHdl, bAddGrSaleHdlConnected, bAddGrSaleHdlPrepared, sSQLTABLENAME, hWndForm, PAM_ADDGRSALE, PAM_SETGRSALEVALUES )
													Call SqlCommit( hSqlAddGrSaleHdl )
													Set bRowOk = TRUE
												Else
													Call SqlPrepareAndExecute( hSqlAddGrSaleHdl, 'ROLLBACK' )
													Set bAddGrSaleHdlPrepared = FALSE
													Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
													Call SalTblFetchRow( hWndForm, nRow )
													Set colUserNotification = 'Insert Failed into the Growing Sale Table!'
											Else
												If StockItemSaleExists( hSqlSISExistsHdl, bSISExistsHdlConnected, bSISExistsHdlPrepared, frmFarmStock.tblGrowingStock.colItemNo, frmFarmStock.dfYear )
													If MyInsertRecord( hSqlAddGrSaleHdl, bAddGrSaleHdlConnected, bAddGrSaleHdlPrepared, sSQLTABLENAME, hWndForm, PAM_ADDGRSALE, PAM_SETGRSALEVALUES )
														Call SqlCommit( hSqlAddGrSaleHdl )
														Set bRowOk = TRUE
													Else
														Call SqlPrepareAndExecute( hSqlAddGrSaleHdl, 'ROLLBACK' )
														Set bAddGrSaleHdlPrepared = FALSE
														Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
														Call SalTblFetchRow( hWndForm, nRow )
														Set colUserNotification = 'Insert Failed into the Growing Sale Table!'
												Else
													If MyInsertRecord( hSqlInsSISHdl, bInsSISHdlConnected, bInsSISHdlPrepared, ' STOCK_ITEM_SALE ', hWndForm, PAM_ADDSTCKITMSALE, PAM_SETSISVALUES )
														Call SqlCommit( hSqlInsSISHdl )
														Set bUserNotification = TRUE
														Set colUserNotification = 'A Inventory year has been inserted into the Stock Item Sale table!'
														If MyInsertRecord( hSqlAddGrSaleHdl, bAddGrSaleHdlConnected, bAddGrSaleHdlPrepared, sSQLTABLENAME, hWndForm, PAM_ADDGRSALE, PAM_SETGRSALEVALUES )
															Call SqlCommit( hSqlAddGrSaleHdl )
															Set bRowOk = TRUE
														Else
															Call SqlPrepareAndExecute( hSqlAddGrSaleHdl, 'ROLLBACK' )
															Set bAddGrSaleHdlPrepared = FALSE
															Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
															Call SalTblFetchRow( hWndForm, nRow )
															Set colUserNotification = 'Insert Failed into the Growing Sale table!'
													Else
														Call SqlPrepareAndExecute( hSqlInsSISHdl, 'ROLLBACK' )
														Set bInsSISHdlPrepared = FALSE
														Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
														Call SalTblFetchRow( hWndForm, nRow )
														Set colUserNotification = 'Insert Failed into the Stock Item Sale table!'
								Else
									If MyInsertRecord( hSqlAddLocHdl, bAddLocHdlConnected, bAddLocHdlPrepared, ' LOCATION ', hWndForm, PAM_ADDLOCATION, PAM_SETLOCATIONVALUES )
										Call SqlCommit( hSqlAddLocHdl )
										Set bUserNotification = TRUE
										Set colUserNotification = 'A Location has been inserted into the Location table!'
										If MyInsertRecord( hSqlAddGrSaleHdl, bAddGrSaleHdlConnected, bAddGrSaleHdlPrepared, sSQLTABLENAME, hWndForm, PAM_ADDGRSALE, PAM_SETGRSALEVALUES )
											Call SqlCommit( hSqlAddGrSaleHdl )
											Set bRowOk = TRUE
										Else
											Call SqlPrepareAndExecute( hSqlAddGrSaleHdl, 'ROLLBACK' )
											Set bAddGrSaleHdlPrepared = FALSE
											Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
											Call SalTblFetchRow( hWndForm, nRow )
											Set colUserNotification = 'Insert Failed into the Growing Sale table!'
									Else
										Call SqlPrepareAndExecute( hSqlAddLocHdl, 'ROLLBACK' )
										Set bAddLocHdlPrepared = FALSE
										Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
										Call SalTblFetchRow( hWndForm, nRow )
										Set colUserNotification = 'Insert Failed into the Location table!'
								If bRowOk
									Call SalTblSetRowFlags( hWndForm, nRow, ROW_New, FALSE )
									Call SalTblSetRowFlags( hWndForm, nRow, ROW_Edited, FALSE )
								Else
									Set bSaveOk = FALSE
							Else If SalTblQueryRowFlags( hWndForm, nRow, ROW_Edited )
								If GrowingAnything( hSqlGrowAnyHdl, bGrowAnyHdlConnected, bGrowAnyHdlPrepared, frmFarmStock.tblGrowingStock.colLocationId, frmFarmStock.dfYear, nItemNo )
									! This is the way is was to prevent the a stock item to be put over another
											  stock item growing.  We took it out on 28/9/94 because users found they
											  needed to change the item growing on a location when there was one
											  already growing there!
									! If frmFarmStock.tblGrowingStock.colItemNo = nItemNo OR NOT nItemNo > 0
										    If NOT nItemNo > 0
											    If StockItemSaleExists( hSqlSISExistsHdl, bSISExistsHdlConnected, bSISExistsHdlPrepared, frmFarmStock.tblGrowingStock.colItemNo, frmFarmStock.dfYear )
												    If MyUpdateRecord( hSqlUpdtGrLocHdl, bUpdtGrLocHdlConnected, bUpdtGrLocHdlPrepared, sSQLTABLENAME, sSqlWhereGrSale, hWndForm, PAM_UPDATEGRSALE, PAM_SETGRSALEVALUES )
													    Call SqlCommit( hSqlUpdtGrLocHdl )
													    Set bRowOk = TRUE
												    Else 
													    Call SqlPrepareAndExecute( hSqlUpdtGrLocHdl, 'ROLLBACK' )
													    Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
													    Call SalTblFetchRow( hWndForm, nRow )
													    Set colUserNotification = 'Update Failed of the Growing Sale table!'
											    Else 
												    If MyInsertRecord( hSqlInsSISHdl, bInsSISHdlConnected, bInsSISHdlPrepared, ' STOCK_ITEM_SALE ', hWndForm, PAM_ADDSTCKITMSALE, PAM_SETSISVALUES )
													    Call SqlCommit( hSqlInsSISHdl )
													    Set bUserNotification = TRUE
													    Set colUserNotification = 'A Inventory year has been inserted into the Stock Item Sale table!'
													    If MyUpdateRecord( hSqlUpdtGrLocHdl, bUpdtGrLocHdlConnected, bUpdtGrLocHdlPrepared, sSQLTABLENAME, sSqlWhereGrSale, hWndForm, PAM_UPDATEGRSALE, PAM_SETGRSALEVALUES )
														    Call SqlCommit( hSqlUpdtGrLocHdl )
														    Set bRowOk = TRUE
													    Else 
														    Call SqlPrepareAndExecute( hSqlUpdtGrLocHdl, 'ROLLBACK' )
														    Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
														    Call SalTblFetchRow( hWndForm, nRow )
														    Set colUserNotification = 'Update Failed of the Growing Sale table!'
												    Else 
													    Call SqlPrepareAndExecute( hSqlInsSISHdl, 'ROLLBACK' )
													    Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
													    Call SalTblFetchRow( hWndForm, nRow )
													    Set colUserNotification = 'Insert Failed into the Stock Item Sale table!'
										    Else 
											    If MyUpdateRecord( hSqlUpdtGrLocHdl, bUpdtGrLocHdlConnected, bUpdtGrLocHdlPrepared, sSQLTABLENAME, sSqlWhereGrSale, hWndForm, PAM_UPDATEGRSALE, PAM_SETGRSALEVALUES )
												    Call SqlCommit( hSqlUpdtGrLocHdl )
												    Set bRowOk = TRUE
											    Else 
												    Call SqlPrepareAndExecute( hSqlUpdtGrLocHdl, 'ROLLBACK' )
												    Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
												    Call SalTblFetchRow( hWndForm, nRow )
												    Set colUserNotification = 'Update Failed of the Growing Sale table!'
									! Else 
										    Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
										    Call SalTblFetchRow( hWndForm, nRow )
										    Set bUserNotification = TRUE
										    Set colUserNotification = 'Another stock item is already growing on this location!'
									If NOT nItemNo > 0
										If StockItemSaleExists( hSqlSISExistsHdl, bSISExistsHdlConnected, bSISExistsHdlPrepared, frmFarmStock.tblGrowingStock.colItemNo, frmFarmStock.dfYear )
											If MyUpdateRecord( hSqlUpdtGrLocHdl, bUpdtGrLocHdlConnected, bUpdtGrLocHdlPrepared, sSQLTABLENAME, sSqlWhereGrSale, hWndForm, PAM_UPDATEGRSALE, PAM_SETGRSALEVALUES )
												Call SqlCommit( hSqlUpdtGrLocHdl )
												Set bRowOk = TRUE
											Else
												Call SqlPrepareAndExecute( hSqlUpdtGrLocHdl, 'ROLLBACK' )
												Set bUpdtGrLocHdlPrepared = FALSE
												Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
												Call SalTblFetchRow( hWndForm, nRow )
												Set colUserNotification = 'Update Failed of the Growing Sale table!'
										Else
											If MyInsertRecord( hSqlInsSISHdl, bInsSISHdlConnected, bInsSISHdlPrepared, ' STOCK_ITEM_SALE ', hWndForm, PAM_ADDSTCKITMSALE, PAM_SETSISVALUES )
												Call SqlCommit( hSqlInsSISHdl )
												Set bUserNotification = TRUE
												Set colUserNotification = 'A Inventory year has been inserted into the Stock Item Sale table!'
												If MyUpdateRecord( hSqlUpdtGrLocHdl, bUpdtGrLocHdlConnected, bUpdtGrLocHdlPrepared, sSQLTABLENAME, sSqlWhereGrSale, hWndForm, PAM_UPDATEGRSALE, PAM_SETGRSALEVALUES )
													Call SqlCommit( hSqlUpdtGrLocHdl )
													Set bRowOk = TRUE
												Else
													Call SqlPrepareAndExecute( hSqlUpdtGrLocHdl, 'ROLLBACK' )
													Set bUpdtGrLocHdlPrepared = FALSE
													Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
													Call SalTblFetchRow( hWndForm, nRow )
													Set colUserNotification = 'Update Failed of the Growing Sale table!'
											Else
												Call SqlPrepareAndExecute( hSqlInsSISHdl, 'ROLLBACK' )
												Set bInsSISHdlPrepared = FALSE
												Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
												Call SalTblFetchRow( hWndForm, nRow )
												Set colUserNotification = 'Insert Failed into the Stock Item Sale table!'
									Else
										If MyUpdateRecord( hSqlUpdtGrLocHdl, bUpdtGrLocHdlConnected, bUpdtGrLocHdlPrepared, sSQLTABLENAME, sSqlWhereGrSale, hWndForm, PAM_UPDATEGRSALE, PAM_SETGRSALEVALUES )
											Call SqlCommit( hSqlUpdtGrLocHdl )
											Set bRowOk = TRUE
										Else
											Call SqlPrepareAndExecute( hSqlUpdtGrLocHdl, 'ROLLBACK' )
											Set bUpdtGrLocHdlPrepared = FALSE
											Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
											Call SalTblFetchRow( hWndForm, nRow )
											Set colUserNotification = 'Update Failed of the Growing Sale table!'
								Else
									If StockItemSaleExists( hSqlSISExistsHdl, bSISExistsHdlConnected, bSISExistsHdlPrepared, frmFarmStock.tblGrowingStock.colItemNo, frmFarmStock.dfYear )
										If MyInsertRecord( hSqlAddGrSaleHdl, bAddGrSaleHdlConnected, bAddGrSaleHdlPrepared, sSQLTABLENAME, hWndForm, PAM_ADDGRSALE, PAM_SETGRSALEVALUES )
											Call SqlCommit( hSqlAddGrSaleHdl )
											Set bRowOk = TRUE
										Else
											Call SqlPrepareAndExecute( hSqlAddGrSaleHdl, 'ROLLBACK' )
											Set bAddGrSaleHdlPrepared = FALSE
											Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
											Call SalTblFetchRow( hWndForm, nRow )
											Set colUserNotification = 'Insert Failed into the Growing Sale table!'
									Else
										If MyInsertRecord( hSqlInsSISHdl, bInsSISHdlConnected, bInsSISHdlPrepared, ' STOCK_ITEM_SALE ', hWndForm, PAM_ADDSTCKITMSALE, PAM_SETSISVALUES )
											Call SqlCommit( hSqlInsSISHdl )
											Set bUserNotification = TRUE
											Set colUserNotification = 'A Inventory year has been inserted into the Stock Item Sale table!'
											If MyInsertRecord( hSqlAddGrSaleHdl, bAddGrSaleHdlConnected, bAddGrSaleHdlPrepared, sSQLTABLENAME, hWndForm, PAM_ADDGRSALE, PAM_SETGRSALEVALUES )
												Call SqlCommit( hSqlAddGrSaleHdl )
												Set bRowOk = TRUE
											Else
												Call SqlPrepareAndExecute( hSqlAddGrSaleHdl, 'ROLLBACK' )
												Set bAddGrSaleHdlPrepared = FALSE
												Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
												Call SalTblFetchRow( hWndForm, nRow )
												Set colUserNotification = 'Insert Failed into the Growing Sale table!'
										Else
											Call SqlPrepareAndExecute( hSqlInsSISHdl, 'ROLLBACK' )
											Set bInsSISHdlPrepared = FALSE
											Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
											Call SalTblFetchRow( hWndForm, nRow )
											Set colUserNotification = 'Insert Failed into the Stock Item Sale table!'
								!
								If bRowOk
									Call SalTblSetRowFlags( hWndForm, nRow, ROW_Edited, FALSE )
								Else
									Set bSaveOk = FALSE
							Else If SalTblQueryRowFlags( hWndForm, nRow, ROW_MarkDeleted )
								If MyDeleteRecord( hSqlDelItemHdl, bDelItemHdlConnected, bDelItemHdlPrepared, sSQLTABLENAME, sSqlWhereGrSale, hWndForm, PAM_SETDELITEMVALUES )
									Call SqlCommit( hSqlDelItemHdl )
									Set bRowOk = TRUE
								Else
									Call SqlPrepareAndExecute( hSqlDelItemHdl, 'ROLLBACK' )
									Set bDelItemHdlPrepared = FALSE
									Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
									Call SalTblFetchRow( hWndForm, nRow )
									Set colUserNotification = 'Delete Failed of a Tree from the Growing Sale table!'
								If bRowOk
									Call SalTblDeleteRow( hWndForm, nRow, TBL_Adjust )
									Set nRow = nRow - 1
								Else
									Set bSaveOk = FALSE
							If bRowOk
								If NOT SalIsNull( colItemNo )
									!
									! If NOT CalcItemTotalAvail( colItemNo, frmFarmStock.dfYear, nCalcItemAvail, nExecute )
										    Set bSaveOk = FALSE
										    Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, TRUE )
										    Call SalTblFetchRow( hWndForm, nRow )
										    Set colUserNotification = 'Update of Stock Item Sale growing figures failed!'
									Set nItemNos[0] = colItemNo
									Set nItemNos[1] = NUMBER_Null
									Call RecalculateInventoryFigures( nItemNos, frmFarmStock.dfYear, 'SELECTED', nExecute )
						If bSaveOk
							Set bEdit = FALSE
							Call SalSendMsg( colUserNotification, PAM_ENABLE, FALSE, 0 )
						Else
							Call SalWaitCursor( FALSE )
							Call SalSendMsg( colUserNotification, PAM_ENABLE, TRUE, 0 )
							Call SalMessageBox( 'The selected row/s had errors occour while trying to Save them! Please rectify!', 'Warning', MB_Ok )
							Call SalWaitCursor( TRUE )
						If bUserNotification
							Call SalSendMsg( colUserNotification, PAM_ENABLE, TRUE, 0 )
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'Special actions were performed on some of the rows!', 'NOTE', MB_Ok )
							Call SalWaitCursor( TRUE )
					On PAM_DELETEROWS
						Call TableDeleteRows( hWndForm )
					On PAM_UNDELETEROWS
						Call TableUnDeleteRows( hWndForm )
					On PAM_NOROWS
						! Call SalMessageBox( 'No rows were found.', 'Stock Growing On Farm', MB_Ok|MB_IconAsterisk )
					! On SAM_FetchRow
						    If SqlFetchRow( hLocalSqlPopTbl, lParam, nInd )
							    If NOT SalIsNull( colCultId )
								    If NOT MySelectRecord( hSqlCultDescHdl, bCultDescHdlConnected, bCultDescHdlPrepared, sSqlCultDesc, nFetchFirst, nInd )
									    Call SalMessageBox( 'Extraction of Cultivar Description failed on FetchRow of Root Description, Contact Jan about this error.', 'Error', MB_Ok )
							    If NOT SalIsNull( colRootId )
								    If NOT MySelectRecord( hSqlRootDescHdl, bRootDescHdlConnected, bRootDescHdlPrepared, sSqlRootDesc, nFetchFirst, nInd )
									    Call SalMessageBox( 'Extraction of Root Description failed on FetchRow of Root Description, Contact Jan about this error.', 'Error', MB_Ok )
							    Return TBL_RowFetched
					! On SAM_FetchRowDone
						    If NOT SalIsNull( colCultId )
							    If NOT MySelectRecord( hSqlCultDescHdl, bCultDescHdlConnected, bCultDescHdlPrepared, sSqlCultDesc, nFetchFirst, nInd )
								    Call SalMessageBox( 'Extraction of Cultivar Description failed on FetchRow of Root Description, Contact Jan about this error.', 'Error', MB_Ok )
						    If NOT SalIsNull( colRootId )
							    If NOT MySelectRecord( hSqlRootDescHdl, bRootDescHdlConnected, bRootDescHdlPrepared, sSqlRootDesc, nFetchFirst, nInd )
								    Call SalMessageBox( 'Extraction of Root Description failed on FetchRow of Root Description, Contact Jan about this error.', 'Error', MB_Ok )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, 10 )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bEdit = FALSE
						Set sSQLPOPTABLENAME = ' GROWING_SALE, LOCATION, STOCK_ITEM '
						Set sSQLTABLENAME = ' GROWING_SALE '
						Set sORDERBY = ' ORDER BY LOCATION.ROW#, LOCATION.SEQ# '
						Set sWHEREROWID = ''
						Set sSqlCultDesc = ' SELECT Cult_Desc, Variety FROM Cultivar 
								  INTO :frmFarms.tblGrowingStock.colCultDesc, :frmFarms.tblGrowingStock.colVariety WHERE 
								  Cult_Id = :frmFarms.tblGrowingStock.colCultId '
						Set sSqlRootDesc = ' SELECT Root_Desc FROM Rootstock
								  INTO :frmFarms.tblGrowingStock.colRootDesc WHERE 
								  Root_Id = :frmFarms.tblGrowingStock.colRootId'
						Set sSqlGetNewLocId =  'SELECT MAX( LOCATION_ID ) + 1 FROM LOCATION INTO :frmFarmStock.tblGrowingStock.colLocationId '
						Set sSqlWhereGrSale = ' WHERE Year_Of_Sale = :frmFarmStock.tblGrowingStock.colYear AND Location_Id = :frmFarmStock.tblGrowingStock.colLocationId '
						Set sSqlWhereLocation = ' WHERE Location_Id = :frmFarmStock.tblGrowingStock.colLocationId '
						Set sSqlGrSaleItems = ' SELECT Beg_Count, First_Count, Second_Count FROM Growing_Sale INTO :frmFarmStock.tblGrowingStock.nBegCount, :frmFarmStock.tblGrowingStock.nFirstCount, :frmFarmStock.tblGrowingStock.nSecondCount WHERE Year_Of_Sale = 
								:frmFarmStock.dfYear AND Stock_Item_No = 
								:frmFarmStock.tblGrowingStock.colItemNo '
						Set sSqlAmtGrowSIS = ' SELECT 
								Amt_Growing, 
								Amt_Graded, 
								Amt_Pend_Digging, 
								Amt_Shipped, 
								Amt_Supplied, 
								Amt_On_Order, 
								Tot_Avail, 
								On_Ord_As_Subs
								FROM Stock_Item_Sale INTO 
								:frmFarmStock.tblGrowingStock.nSISAmtGrowing, 
								:frmFarmStock.tblGrowingStock.nSISAmtGraded, 
								:frmFarmStock.tblGrowingStock.nSISAmtPendDigging, 
								:frmFarmStock.tblGrowingStock.nSISAmtShipped, 
								:frmFarmStock.tblGrowingStock.nSISAmtSupplied, 
								:frmFarmStock.tblGrowingStock.nSISAmtOnOrder, 
								:frmFarmStock.tblGrowingStock.nSISTotAvail, 
								:frmFarmStock.tblGrowingStock.nSISAmtOnOrdAsSubs
								 WHERE Stock_Item_No = :frmFarmStock.tblGrowingStock.colItemNo AND Year_Of_Sale = :frmFarmStock.dfYear '
						Set sSqlUpdtSIS = ' UPDATE Stock_Item_Sale SET Amt_Growing = :frmFarmStock.tblGrowingStock.nGrowing WHERE Stock_Item_No = :frmFarmStock.tblGrowingStock.colItemNo AND Year_Of_Sale = :frmFarmStock.dfYear '
						Set nDefaultFromRowNo = 1
						Set nDefaultToRowNo = 100
						Set nDefaultSeqNo = 10
						Set nDefaultIncRowNoBy = 1
						Call SalDateToStr( SalDateCurrent(  ), sCurrentDate )
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
						If bCultDescHdlConnected
							Call SqlDisconnect( hSqlCultDescHdl )
						If bRootDescHdlConnected
							Call SqlDisconnect( hSqlRootDescHdl )
						If bLocExistsHdlConnected
							Call SqlDisconnect( hSqlLocExistsHdl )
						If bGrowAnyHdlConnected
							Call SqlDisconnect( hSqlGrowAnyHdl )
						If bAddGrSaleHdlConnected
							Call SqlDisconnect( hSqlAddGrSaleHdl )
						If bAddLocHdlConnected
							Call SqlDisconnect( hSqlAddLocHdl )
						If bSISExistsHdlConnected
							Call SqlDisconnect( hSqlSISExistsHdl )
						If bInsSISHdlConnected
							Call SqlDisconnect( hSqlInsSISHdl )
						If bUpdtGrLocHdlConnected
							Call SqlDisconnect( hSqlUpdtGrLocHdl )
						If bDelItemHdlConnected
							Call SqlDisconnect( hSqlDelItemHdl )
						If bGrSaleItemsHdlConnected
							Call SqlDisconnect( hSqlGrSaleItemsHdl )
						If bAmtGrSISHdlConnected
							Call SqlDisconnect( hSqlAmtGrSISHdl )
						If bUpdtSISTotHdlConnected
							Call SqlDisconnect( hSqlUpdtSISTotHdl )

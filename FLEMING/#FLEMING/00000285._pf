			Number: nRow
			String: sTreeTypeDesc
			String: sCultDesc
			String: sRootDesc
		Message Actions
			On SAM_Create
				Set sHelpFileName = 'f:\\apps\\gupta\\stock\\qitem.hlp'
				Set bFirstEntry = TRUE
				Call PopNumber( bEnableSelectPb, TRUE )
				Call PopWndHdl( hWndPushbutton, TRUE )
				Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
			On PAM_CREATECOMPLETE
				Set dfCurrDate = SalDateCurrent(  )
				Call PopString( sRootDesc, TRUE )
				Call PopString( sCultDesc, TRUE )
				Call PopString( sTreeTypeDesc, TRUE )
				Call SalSendMsg( pbQuery, SAM_Click, 0, 0 )
				Call SalMapEnterToTab( TRUE )
			On SAM_Destroy
				Call PushString( sTreeTypeDesc )
				Call PushString( sCultDesc )
				Call PushString( sRootDesc )
				Call SalMapEnterToTab( FALSE )
				Call SalSendMsg( hWndPushbutton, PAM_ENABLE, 0, bSelect )
			On SAM_Close
				Call SalWaitCursor( TRUE )

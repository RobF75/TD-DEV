						Call SalWaitCursor( TRUE )
						Call SalDisableWindow( hWndItem )
						Call PushString( sTreeTypeDesc )
						Call PushString( sCultDesc )
						Call PushString( sRootDesc )
						If nOk = SalModalDialog( dlgQItemQuery, hWndForm )
							Call PopString( sRootDesc, TRUE )
							Call PopString( sCultDesc, TRUE )
							Call PopString( sTreeTypeDesc, TRUE )
							Call SalSendMsg( tblItem, PAM_POPULATE, 0, 0 )
							Set bFirstEntry = FALSE
						Else If bFirstEntry
							Call SalPostMsg( pbCancel, SAM_Click, 0, 0 )
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )

					Font Size: Default
					Font Enhancement: Default
					Text Color: Dark Blue
					Background Color: White
					Input Mask: Unformatted
				Message Actions
					On SAM_Validate
						Set bgEdit = TRUE
					On PAM_SQL
						Call BuildSQL( wParam,hWndItem,'EVALUATION_YEAR' )
					On PAM_DISPREC
						Call SalDisableWindow( dfEvalYear )
					On PAM_NEWREC
						Call SalEnableWindow( dfEvalYear )
					On PAM_DATAVAL
						If SalIsNull( hWndItem )
							Call SalMessageBox( 'Please enter a Evaluation Yer first', 'Evaluation',
									MB_Ok | MB_IconStop )
							Call SalSetFocus( hWndItem )
							Return FALSE
						Call SalSetFieldEdit( hWndItem, TRUE )
						Return TRUE

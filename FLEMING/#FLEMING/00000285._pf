								    Call SalSetFieldEdit( hWndItem, TRUE )
								    Call BuildSQL(  wParam, hWndItem, 'HAIL_DAMAGE' )
							    On PAM_SETSISVALUES
								    Set colSISHailDamage = 'N'
							    On PAM_DATAVAL
								    Return TRUE
							    On PAM_CHECKROWNEW
								    Return TRUE
							    On PAM_CHECKROWEDITED
								    Return TRUE
							    On PAM_CHECKROWDELETED
								    Return TRUE
					    Column: colOldItemNo
						    List Values 
						    Message Actions 
							    On PAM_DATAVAL
								    Return TRUE
							    On PAM_CHECKROWNEW
								    Return TRUE
							    On PAM_CHECKROWEDITED
								    Return TRUE
							    On PAM_CHECKROWDELETED
								    Return TRUE
				    Functions 
					! Function: KeepItemNoToRecalculate
						    Description: 
						    Returns 
						    Parameters 
							    Number: nItemNo
							    Receive Number: nItemNos[*]
						    Static Variables 
						    Local variables 
							    Number: nPos
							    Boolean: bFound
						    Actions 
							    Set nPos = 0
							    While nItemNos[ nPos ] != NUMBER_Null AND NOT bFound
								    If nItemNos[ nPos ] = nItemNo
									    Set bFound = TRUE
								    Set nPos = nPos + 1
							    If NOT bFound
								    Set nItemNos[ nPos ] = nItemNo
								    Set nPos = nPos + 1
								    Set nItemNos[ nPos ] = NUMBER_Null
					    Function: KeepItemNoToRecalculate
						    Description: 
						    Returns 
						    Parameters 
							    Number: nItemNo
							    Number: nYear
							    Receive Number: nItemNos[*]
							    Receive Number: nYears[*]
						    Static Variables 
						    Local variables 
							    Number: nPos
							    Boolean: bFound
						    Actions 
							    Set nPos = 0
							    While nItemNos[ nPos ] != NUMBER_Null AND NOT bFound
								    If nItemNos[ nPos ] = nItemNo AND nYears[ nPos ] = nYear
									    Set bFound = TRUE
								    Set nPos = nPos + 1
							    If NOT bFound
								    Set nItemNos[ nPos ] = nItemNo
								    Set nYears[ nPos ] = nYear
								    Set nPos = nPos + 1
								    Set nItemNos[ nPos ] = NUMBER_Null
								    Set nYears[ nPos ] = NUMBER_Null
					    Function: ExtractYearItemNos
						    Description: 
						    Returns 
							    Boolean: 
						    Parameters 
							    Number: nYear
							    Receive Number: nYearItemNos[*]
							    Number: nItemNos[*]
							    Number: nYears[*]
						    Static Variables 
						    Local variables 
							    Number: nPos
							    Number: nPosFound
							    Boolean: bFound
						    Actions 
							    Set nPosFound = 0
							    Set nPos = 0
							    While nItemNos[ nPos ] != NUMBER_Null
								    If nYears[ nPos ] = nYear
									    Set bFound = TRUE
									    Set nYearItemNos[ nPosFound ] = nItemNos[ nPos ]
									    Set nPosFound = nPosFound + 1
									    Set nYearItemNos[ nPosFound ] = NUMBER_Null
								    Set nPos = nPos + 1
							    Return bFound
					    Function: ExtractUniqueYears
						    Description: 
						    Returns 
							    Boolean: 
						    Parameters 
							    Receive Number: nUniqueYears[*]
							    Number: nYears[*]
						    Static Variables 
						    Local variables 
							    Number: nPos
							    Number: nPosUnique
							    Boolean: bFound
						    Actions 
							    Set nPos = 0
							    Set nUniqueYears[ nPos ] = NUMBER_Null
							    While nYears[ nPos ] != NUMBER_Null
								!
								    Set bFound = FALSE
								    Set nPosUnique = 0
								    While nUniqueYears[ nPosUnique ] != NUMBER_Null AND NOT bFound
									    If nUniqueYears[ nPosUnique ] = nYears[ nPos ]
										    Set bFound = TRUE
									    Set nPosUnique = nPosUnique + 1
								    If NOT bFound
									    Set nUniqueYears[ nPosUnique ] = nYears[ nPos ]
									    Set nPosUnique = nPosUnique + 1
									    Set nUniqueYears[ nPosUnique ] = NUMBER_Null
								!
								    Set nPos = nPos + 1
				    Window Variables 
					    Number: nPos
					    Number: nItemNos[*]
					    Number: nYears[*]
					    Number: nYearItemNos[*]
					    Number: nUniqueYears[*]
					!
					    Number: nTmpRow

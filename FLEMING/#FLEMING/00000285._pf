								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_WHEREPOPULATE
								If sQueryBuildWhere = ''
									Set sBuildWhere = " WHERE NOT Farm_Name LIKE 'C%' "
								Else
									Set sBuildWhere = sQueryBuildWhere || " AND NOT Farm_Name LIKE 'C%' "
							On PAM_DATAVAL
								Return TRUE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE
					Column: colFarm
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Farm Id
						Visible? Yes
						Editable? Yes
						Maximum Data Length: 8
						Data Type: String
						Justify: Left
						Width:  1.2"
						Width Editable? Yes
						Format: Uppercase
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL(  wParam, hWndItem, 'FARM_MASTER.FARM_NAME' )
							On PAM_INSERT
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'FARM_MASTER.FARM_NAME' )
							On PAM_RENEWROWID
								Call PushString( ':frmFarms.tblFarm.colFarm' )
								Call PushString( EQOPERAND )
								Call PushString( STRINGHDLFOLLOWING )
								Call PushString( 'FARM_MASTER.FARM_NAME' )
								Return TRUE
							On PAM_CANORDERBY
								Call PushNumber( 1 )
								Call SalTblGetColumnTitle( hWndItem, sQueryTmpStr, 30 )
								Call PushString( sQueryTmpStr )
								Return TRUE
							On PAM_DATAVAL
								If SalIsNull( hWndItem ) 
									Call ErrorMessage( 'Please enter a Farm first!', hWndForm, ngRow )
									Return FALSE
								Return TRUE
							On PAM_FIELDCOUNTLISTFIELDS
								Call BuildSQL(  wParam, hWndItem, 'FarmId' )
							On PAM_CHECKROWNEW
								Set sSql = 'SELECT Farm_Name FROM Farm_Master WHERE Farm_Name = :frmFarms.tblFarm.colFarm'
								If MySqlExists( sSql, bExists )
									If bExists
										Call ErrorMessage( 'This Farm Name already exists in this table.', hWndForm, lParam )
										Return FALSE
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								! Set sSql = 'SELECT Location_Id FROM Location WHERE Farm_Name = :frmFarms.tblFarm.colFarm'
								Set sSql = ' SELECT 
										  Growing_Sale.Stock_Item_No 
										FROM 
										  Location, 
										  Growing_Sale  
										WHERE 
										  Location.Farm_Name = :frmFarms.tblFarm.colFarm AND 
										  Location.Location_Id = Growing_Sale.Location_Id '
								If MySqlExists( sSql, bExists )
									If bExists
										Call ErrorMessage( 'There is stock still stock growing on this farm.  Cannot delete.', hWndForm, lParam )
										Return FALSE
								!
								Set sSql = ' SELECT 
										  Scion_Evaluation.Stock_Item_No 
										FROM 
										  Location, 
										  Scion_Evaluation  
										WHERE 
										  Location.Farm_Name = :frmFarms.tblFarm.colFarm AND 
										  Location.Location_Id = Scion_Evaluation.Location_Id '
								If MySqlExists( sSql, bExists )
									If bExists
										Call ErrorMessage( 'There is still scion evaluation on this farm.  Cannot delete.', hWndForm, lParam )
										Return FALSE
								!
								Set sSql = 'SELECT Location_Id FROM Location WHERE Farm_Name = :frmFarms.tblFarm.colFarm'
								If MySqlExists( sSql, bExists )
									If bExists
										If DeleteFarmLocations( colFarm, nExecute )
											Call DeleteFarmLocations( '', nCommit )
								Return TRUE
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On PAM_EDITCHECK
								If NOT SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
									Call SalTblKillEdit( hWndForm )

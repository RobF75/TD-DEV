			Pushbutton: pbItem
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: Stoc&k Item - F9
				Window Location and Size
					Left:   6.188"
					Top:    4.719"
					Width:  1.313"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: F9
				Font Name: Default
				Font Size: Default
				Font Enhancement: Italic
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						Call SalWaitCursor( TRUE )
						Call SalDisableWindow( hWndItem )
						Set bMultipleRowsForItem = FALSE
						Set bEnableQItemDlgSelectPb = FALSE
						Call SalTblQueryFocus( tblGrowingStock, nRow, hWndCol )
						If SalTblQueryRowFlags( tblGrowingStock, nRow, ROW_Selected )
							Set bEnableQItemDlgSelectPb = TRUE
						Else
							Call SalSendMsg( hWndCol, PAM_ENABLECHILDSELECTPB, nRow, 0 )
						Call PushNumber( bEnableQItemDlgSelectPb )
						Call PushWndHdl( hWndItem )
						If SalIsNull( frmFarmStock.tblGrowingStock.colTreeTypeDesc ) AND
								   SalIsNull( frmFarmStock.tblGrowingStock.colCultDesc ) AND
								   SalIsNull( frmFarmStock.tblGrowingStock.colRootDesc )
							Call PushString( frmFarmStock.sTreeType )
							Call PushString( frmFarmStock.sCultDesc )
							Call PushString( frmFarmStock.sRootDesc )
						Else
							Call PushString( frmFarmStock.tblGrowingStock.colTreeTypeDesc )
							Call PushString( frmFarmStock.tblGrowingStock.colCultDesc )
							Call PushString( frmFarmStock.tblGrowingStock.colRootDesc )
						Call SalModalDialog( dlgQItem, hWndForm )
					On PAM_ENABLE
						! The next line is the standard way of doing a select from a child screen,
								  however in this case we need a multi row selection from the child screen,
								  thats why the PAM_LOOKUP and PAM_READYFORNEXTLOOKUP are 
								  added to this button and the lParam uncommented.
						! If lParam
							    Call SalSendMsgToChildren( tblSub, PAM_LOOKUPTYPE, 0, 0 )
						Call PopString( sRootDesc, TRUE )
						Call PopString( sCultDesc, TRUE )
						Call PopString( sTreeType, TRUE )
						Call SalTblKillEdit( tblGrowingStock )
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
					On PAM_LOOKUP
						Call SalSendMsgToChildren( tblGrowingStock, PAM_LOOKUPITEM, 0, 0 )
						If NOT bMultipleRowsForItem
							If SalTblAnyRows( tblGrowingStock, ROW_Selected, 0 )
								Set bMultipleRowsForItem = TRUE
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblGrowingStock, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( tblGrowingStock, nRow )
									Call SalSendMsgToChildren( tblGrowingStock, PAM_SETSELECTEDITEM, 0, 0 )
					On PAM_READYFORNEXTLOOKUP
						Call SalSendMsg( tblGrowingStock, PAM_ADDROW, 0, 0 )

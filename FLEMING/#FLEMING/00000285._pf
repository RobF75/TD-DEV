						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL(  wParam, hWndItem, 'GROWING_SALE.STOCK_ITEM_NO' )
							On PAM_ADDGRSALE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM_NO' )
							On PAM_ADDSTCKITMSALE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM_NO' )
							On PAM_UPDATEGRSALE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM_NO' )
							On PAM_LOOKUPITEM
								Call PopNumber( colItemNo,TRUE )
								Set nSelectedItemNo = colItemNo
								Call SalSetFieldEdit( hWndItem, TRUE )
							On PAM_SETSELECTEDITEM
								Set colItemNo = nSelectedItemNo
								Call SalSetFieldEdit( hWndItem, TRUE )
							On PAM_DATAVAL
								If SalIsNull( hWndItem ) AND 
										( NOT SalIsNull( colBegCount ) 
										  OR NOT SalIsNull( colFirstCount ) 
										  OR NOT SalIsNull( colSecondCount ) 
										  OR NOT SalIsNull( colDatePlanted ) 
										  OR NOT SalIsNull( colDateBudded ) )
									Call ErrorMessage( 'A Stock Item is needed before any Counts can be entered!  Please rectify!', hWndForm, ngRow )
									Return FALSE
								Return TRUE

				Height: Class Default
				Height Editable? Class Default
			Form Size
				Width:  Class Default
				Height: Class Default
				Number of Pages: Class Default
			Font Name: Class Default
			Font Size: Class Default
			Font Enhancement: Class Default
			Text Color: Class Default
			Background Color: Class Default
		Description:
		Named Menus
		Menu
		Tool Bar
			Display Settings
				Display Style? Class Default
				Location? Class Default
				Visible? Class Default
				Size: Class Default
				Size Editable? Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Text Color: Class Default
				Background Color: Class Default
			Contents
		Contents
		Functions
		Window Parameters
			! sSelectedRegionIdList is a comma separated list of item numbers
			String: sSelectedRegionIdList
			Number: nYear
			! sRegionType = 'SELECTED' OR 'ALL'
			String: sRegionType
			! sCustType = 'GARDENCENTRES' OR 'ORCHARDISTS' OR 'ANY'
			String: sCustType
			! sReportPrintOrView = 'VIEW' OR 'PRINT'
			String: sReportPrintOrView
		Window Variables
			! REPORT FIELDS
			Number: nCustNo
			String: sCustName
			String: sRegionId
			String: sRegionDesc
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set sReportFileNameNoPath = 'PrtRegCust.qrp'
				!
				Set sReportBind = ':frmPrintRegionsCust.nCustNo, 
						  :frmPrintRegionsCust.sCustName, 
						  :frmPrintRegionsCust.sRegionId, 
						  :frmPrintRegionsCust.sRegionDesc'
				Set sReportInto = 'nCustNo, 
						  sCustName, 
						  sRegionId, 
						  sRegionDesc'
				Set sReportType = sReportPrintOrView
			On PAM_clsFRM_REPORTSTART
				If sRegionType = 'ALL'
					If sCustType = 'ANY'
						Set sReportSql = "SELECT 
								  Customer_Master.Cust_No, 
								  Customer_Master.Cust_Name, 
								  Customer_Master.Region_Id, 
								  Region.Region_Desc 
								FROM 
								  Customer_Master, 
								  Region 
								INTO 
								  :frmPrintRegionsCust.nCustNo, 
								  :frmPrintRegionsCust.sCustName, 
								  :frmPrintRegionsCust.sRegionId, 
								  :frmPrintRegionsCust.sRegionDesc 
								WHERE 
								  Customer_Master.Region_Id = Region.Region_Id 
								ORDER BY 
								  Region.Region_Desc, Customer_Master.Cust_Name "
					Else If sCustType = 'GARDENCENTRES'
						Set sReportSql = "SELECT 
								  Customer_Master.Cust_No, 
								  Customer_Master.Cust_Name, 
								  Customer_Master.Region_Id, 
								  Region.Region_Desc 
								FROM 
								  Customer_Master, 
								  Region 
								INTO 
								  :frmPrintRegionsCust.nCustNo, 
								  :frmPrintRegionsCust.sCustName, 
								  :frmPrintRegionsCust.sRegionId, 
								  :frmPrintRegionsCust.sRegionDesc 
								WHERE 
								  Customer_Master.Region_Id = Region.Region_Id AND 
								  Customer_Master.Customer_Type LIKE '%GC%' 
								ORDER BY 
								  Region.Region_Desc, Customer_Master.Cust_Name "
					Else
						Set sReportSql = "SELECT 
								  Customer_Master.Cust_No, 
								  Customer_Master.Cust_Name, 
								  Customer_Master.Region_Id, 
								  Region.Region_Desc 
								FROM 
								  Customer_Master, 
								  Region 
								INTO 
								  :frmPrintRegionsCust.nCustNo, 
								  :frmPrintRegionsCust.sCustName, 
								  :frmPrintRegionsCust.sRegionId, 
								  :frmPrintRegionsCust.sRegionDesc 
								WHERE 
								  Customer_Master.Region_Id = Region.Region_Id AND 
								  Customer_Master.Customer_Type LIKE '%OR%' 
								ORDER BY 
								  Region.Region_Desc, Customer_Master.Cust_Name "
				Else
					If sCustType = 'ANY'
						Set sReportSql = "SELECT 
								  Customer_Master.Cust_No, 
								  Customer_Master.Cust_Name, 
								  Customer_Master.Region_Id, 
								  Region.Region_Desc 
								FROM 
								  Customer_Master, 
								  Region 
								INTO 
								  :frmPrintRegionsCust.nCustNo, 
								  :frmPrintRegionsCust.sCustName, 
								  :frmPrintRegionsCust.sRegionId, 
								  :frmPrintRegionsCust.sRegionDesc 
								WHERE 
								  Customer_Master.Region_Id = Region.Region_Id AND 
								  Customer_Master.Region_Id IN ( " || sSelectedRegionIdList || " ) 
								ORDER BY 
								  Region.Region_Desc, Customer_Master.Cust_Name "
					Else If sCustType = 'GARDENCENTRES'
						Set sReportSql = "SELECT 
								  Customer_Master.Cust_No, 
								  Customer_Master.Cust_Name, 
								  Customer_Master.Region_Id, 
								  Region.Region_Desc 
								FROM 
								  Customer_Master, 
								  Region 
								INTO 
								  :frmPrintRegionsCust.nCustNo, 
								  :frmPrintRegionsCust.sCustName, 
								  :frmPrintRegionsCust.sRegionId, 
								  :frmPrintRegionsCust.sRegionDesc 
								WHERE 
								  Customer_Master.Region_Id = Region.Region_Id AND 
								  Customer_Master.Customer_Type LIKE '%GC%' AND 
								  Customer_Master.Region_Id IN ( " || sSelectedRegionIdList || " ) 
								ORDER BY 
								  Region.Region_Desc, Customer_Master.Cust_Name "
					Else
						Set sReportSql = "SELECT 
								  Customer_Master.Cust_No, 
								  Customer_Master.Cust_Name, 
								  Customer_Master.Region_Id, 
								  Region.Region_Desc 
								FROM 
								  Customer_Master, 
								  Region 
								INTO 
								  :frmPrintRegionsCust.nCustNo, 
								  :frmPrintRegionsCust.sCustName, 
								  :frmPrintRegionsCust.sRegionId, 
								  :frmPrintRegionsCust.sRegionDesc 
								WHERE 
								  Customer_Master.Region_Id = Region.Region_Id AND 
								  Customer_Master.Customer_Type LIKE '%OR%' AND 
								  Customer_Master.Region_Id IN ( " || sSelectedRegionIdList || " ) 
								ORDER BY 
								  Region.Region_Desc, Customer_Master.Cust_Name "
				Return TRUE

		Application Actions
			On SAM_AppStartup
				If strArgArray[0] = ''
					Set SqlDatabase = 'STKLOCAL'
					Set SqlUser = 'JAN'
					Set SqlPassword = 'JAN'
				Else
					Set SqlDatabase = strArgArray[1]
					Set SqlUser = strArgArray[2]
					Set SqlPassword = strArgArray[3]
				!
				Call CheckProgramExistance( 'Print Customers in Regions Report', TRUE )
				!
				Call SqlHandlesSetup(  )
			On SAM_AppExit
				Call SqlHandlesDisconnectClose(  )

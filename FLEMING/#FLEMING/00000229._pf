				Window Variables
					String: sTmp
					Number: nTmp
					String: sRegionIdList
					Boolean: bPopulated
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set sSQLPopHandle = " SELECT 
								  Region.Region_Id, 
								  Region.Region_Desc 
								FROM 
								  Region 
								ORDER BY 
								  Region.Region_Desc "
						Set sNAMEPopHandle = 'POPSELREGS'
						Set sBINDPopHandle = ''
						Set sINTOPopHandle = ':frmRegionsCustomers.tblSelectedRegions.colRegionId,
								  :frmRegionsCustomers.tblSelectedRegions.colRegionDesc'
						!
						Set bAddAllowed = TRUE
						Set bPopulated = FALSE
					On PAM_clsTBL_POPULATE
						Set bPopulated = TRUE
						Return SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
					On PAM_clsREGCUST_GETSELREGIDS
						Set sRegionIdList = ''
						If TableLoop( hWndForm, hWndForm, PAM_clsPRTREGIONCUST_GETSELECTED, 0, ROW_UnusedFlag1, 0, 'Extracting Selected Regions', TBL_cls_LowToHi )
							If sRegionIdList = ''
								Return FALSE
							Else
								Call PushString( sRegionIdList )
								Return TRUE
						Else
							Return FALSE
					On PAM_clsPRTREGIONCUST_GETSELECTED
						If sRegionIdList = ''
							Set sRegionIdList = "'" || sRegionIdList || "'"
						Else
							Set sRegionIdList = sRegionIdList || ', ' || "'" || colRegionId || "'"
						Return TRUE
			!

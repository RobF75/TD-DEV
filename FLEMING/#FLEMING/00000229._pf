			Contents
				Pushbutton: pbReport
					Class Child Ref Key: 0
					Class ChildKey: 0
					Class: clspbGeneral
					Property Template:
					Class DLL Name:
					Title: Report
					Window Location and Size
						Left:   4.45"
						Top:    0.0"
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? Class Default
					Keyboard Accelerator: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Picture File Name: C:\CENTURA\ICONS\LETTERS.BMP
					Picture Transparent Color: Class Default
					Image Style: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_clsPB_CLICK
							If rbGardenCentres
								Set sCustType = 'GARDENCENTRES'
							Else If rbOrchardists
								Set sCustType = 'ORCHARDISTS'
							Else
								Set sCustType = 'ANY'
							!
							If rbSelectedRegions
								Set sRegionType = 'SELECTED'
								If SalSendMsg( tblSelectedRegions, PAM_clsREGCUST_GETSELREGIDS, 0, 0 )
									Call PopString( sSelectedRegionIdList, TRUE )
								Else
									Call SalMessageBox( 'Please select some Regions by placing a tick in the Selected column first, or choose All.', 'Warning', MB_Ok )
									Return FALSE
							Else
								Set sRegionType = 'ALL'
							!
							If rbView
								Set sReportType = 'VIEW'
							Else
								Set sReportType = 'PRINT'
							!
							If hWndReport = hWndNULL
								Set hWndReport = SalCreateWindow( frmPrintRegionsCust, hWndForm, sSelectedRegionIdList, 
										ccSeasonYear.GetSeasonYear( ), sRegionType, sCustType, sReportType )
								Return TRUE
							Else
								Call SalMessageBox( 'Please close down your first report!', 'Warning', MB_Ok )
								Return FALSE

							On PAM_SETCRTRANSVALUES
								If colType = 'INVOICE'
									Set colType = 'WRITEOFF'
								Else If colType = 'SVC CHG'
									Set colType = 'SVCWROFF'
								Else If colType = 'BANK FEE'
									Set colType = 'BNKWROFF'
								Else
									Set colType = 'WRITEOFF'
							On PAM_INSERTCRTRANS
								Call SalSetFieldEdit( hWndItem, TRUE )

									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblQCustCont, nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( tblQCustCont, nRow )
										Call DeleteTransRecord( hSqlTransHdl, bHdlTransConnected, bHdlTransPrepared, 'frmQCustomer.tblQCustCont.colCustNo' )
							Call SalWaitCursor( FALSE )
					On PAM_ENABLE
						If wParam

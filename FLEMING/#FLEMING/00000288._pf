		Message Actions
			On SAM_Create
				! Set sHelpFileName = 'f:\\apps\\gupta\\stock\\qcustadd.hlp'
				Set bFirstCreateComplete = TRUE
				!
				Set bSqlBusAddrHdl = FALSE
				Set bSqlBusAddrHdlPrep = FALSE
				Set bSqlNPAHdlConnected = FALSE
				Set bSqlNPAHdlPrepared = FALSE
				Set bSqlNPAUpdHdlConnected = FALSE
				Set bSqlNPAUpdHdlPrepared = FALSE
				!
				Set bAutomatedTrialBalance = FALSE
				Set sAgingExceptionReportType = ''
			On SAM_Destroy
				If bSqlBusAddrHdl
					Call SqlDisconnect( hSqlBusAddrHdl )
				! If bSqlCVHdlConnected
					              Call SqlDisconnect( hSqlCVHdl )
				! If bSqlRtHdlConnected
					              Call SqlDisconnect( hSqlRtHdl )
				If bSqlNPAHdlConnected
					Call SqlDisconnect( hSqlNPAHdl )
				If bSqlNPAUpdHdlConnected
					Call SqlDisconnect( hSqlNPAUpdHdl )
				If bHdlTransConnected
					Call SqlDisconnect( hSqlTransHdl )
				If bHdlARConnected
					Call SqlDisconnect( hSqlARHdl )
				If bHdlUnConnected
					Call SqlDisconnect( hSqlUnHdl )
				If bHdlAR0Connected
					Call SqlDisconnect( hSqlAR0Hdl )
				Call AdjustCustARBalance( 0, 0, nIncrement, nDisconnect )
				Call AdjustCustARBalance( 0, 0, nDecrement, nDisconnect )
				Call SalSendMsg( hWndCallProg, PAM_ENABLE, 0, 0 )
				Call SalQuit(  )
			On SAM_Close
				If bShowQueryOk
					Return FALSE
				If IDCANCEL = SalMessageBox( 'You are about to EXIT the Transaction program, Do you want to do this?', 'Warning', MB_OkCancel )
					Return FALSE
			On SAM_CreateComplete
				Set dfCurrDate = SalDateCurrent(  )
				Set bSummaryTB = FALSE
				Set nOldTableActive = nWhichTableActive
				Set nWhichTableActive = SalModalDialog( dlgInitialQCustomer, hWndForm )
				Select Case nWhichTableActive
					Case nCustomerTbl
						If NOT sBuildWhere = ''
							Set sBuildWhere = ' WHERE ' || sBuildWhere
						Call PushString( sBuildWhere )
						Call SalSendMsg( dfQueryTypeHeading, PAM_REFRESH, 0, 0 )
						Call SalSendMsg( tblQCustomer, PAM_ENABLE, TRUE, 0 )
						Call SalSendMsg( tblQCustAddr, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblQCustCont, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblQCustomer, PAM_POPULATE, 0, 0 )
						Call SalSetFocus( tblQCustomer )
						Set bFirstCreateComplete = FALSE
						Break
					Case nCustAddrTbl
						Call PushString( sBuildWhere )
						Call SalSendMsg( dfQueryTypeHeading, PAM_REFRESH, 0, 0 )
						Call SalSendMsg( tblQCustomer, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblQCustAddr, PAM_ENABLE, TRUE, 0 )
						Call SalSendMsg( tblQCustCont, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblQCustAddr, PAM_POPULATE, 0, 0 )
						Call SalSetFocus( tblQCustAddr )
						Set bFirstCreateComplete = FALSE
						Break
					Case nCustContTbl
						Call PushString( sBuildWhere )
						Call SalSendMsg( dfQueryTypeHeading, PAM_REFRESH, 0, 0 )
						Call SalSendMsg( tblQCustomer, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblQCustAddr, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblQCustCont, PAM_ENABLE, TRUE, 0 )
						Call SalSendMsg( tblQCustCont, PAM_POPULATE, 0, 0 )
						Call SalSetFocus( tblQCustCont )
						Set bFirstCreateComplete = FALSE
						Break
					Case nAddNewCust
						Call SalPostMsg( pbAdd, SAM_Click, 0, 0 )
						Set bFirstCreateComplete = FALSE
						Break
					Default nCancel
						If bFirstCreateComplete
							! Call SalDestroyWindow( hWndForm )
						Else
							Set bFirstCreateComplete = FALSE
							Set nWhichTableActive = nOldTableActive
							Call SalWaitCursor( FALSE )
				! Call SalModalDialog( dlgApplyDate, hWndForm, dtApplyDate )
			On PAM_CREATECOMPLETE
				Set dfCurrDate = SalDateCurrent(  )
				Set nOldTableActive = nWhichTableActive
				Set nWhichTableActive = SalModalDialog( dlgInitialQCustomer, hWndForm )
				Select Case nWhichTableActive
					Case nCustomerTbl
						If NOT sBuildWhere = ''
							Set sBuildWhere = ' WHERE ' || sBuildWhere
						Call PushString( sBuildWhere )
						Call SalSendMsg( dfQueryTypeHeading, PAM_REFRESH, 0, 0 )
						Call SalSendMsg( tblQCustomer, PAM_ENABLE, TRUE, 0 )
						Call SalSendMsg( tblQCustAddr, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblQCustCont, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblQCustomer, PAM_POPULATE, 0, 0 )
						Call SalSetFocus( tblQCustomer )
						Set bFirstCreateComplete = FALSE
						Break
					Case nCustAddrTbl
						Call PushString( sBuildWhere )
						Call SalSendMsg( dfQueryTypeHeading, PAM_REFRESH, 0, 0 )
						Call SalSendMsg( tblQCustomer, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblQCustAddr, PAM_ENABLE, TRUE, 0 )
						Call SalSendMsg( tblQCustCont, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblQCustAddr, PAM_POPULATE, 0, 0 )
						Call SalSetFocus( tblQCustAddr )
						Set bFirstCreateComplete = FALSE
						Break
					Case nCustContTbl
						Call PushString( sBuildWhere )
						Call SalSendMsg( dfQueryTypeHeading, PAM_REFRESH, 0, 0 )
						Call SalSendMsg( tblQCustomer, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblQCustAddr, PAM_ENABLE, FALSE, 0 )
						Call SalSendMsg( tblQCustCont, PAM_ENABLE, TRUE, 0 )
						Call SalSendMsg( tblQCustCont, PAM_POPULATE, 0, 0 )
						Call SalSetFocus( tblQCustCont )
						Set bFirstCreateComplete = FALSE
						Break
					Case nAddNewCust
						Call SalPostMsg( pbAdd, SAM_Click, 0, 0 )
						Set bFirstCreateComplete = FALSE
						Break
					Default nCancel
						If bFirstCreateComplete
							Call SalDestroyWindow( hWndForm )
						Else
							Set bFirstCreateComplete = FALSE
							Set nWhichTableActive = nOldTableActive
							Call SalWaitCursor( FALSE )
			On PAM_REPORTFINISHED
				If SalNumberToHString( lParam ) = 'TRIAL_BALANCE'
					If bAutomatedTrialBalance
						Call SalCreateWindow( frmPrintAgingExceptionReport, hWndForm, dtRolloverDate, sAgingExceptionReportType )
						Set bAutomatedTrialBalance = FALSE
	!

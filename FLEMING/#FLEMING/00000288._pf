						Case nExecute
							Set sSql = " UPDATE 
									  Deposit_History 
									SET 
									  Trans_User_Id = NULL, 
									  Trans_Sysdatetime = NULL, 
									  Trans_Hist_User_Id = :1, 
									  Trans_Hist_SysDT = :2 
									WHERE 
									  Cust_No = :3 AND 
									  Trans_User_Id = :1 AND 
									  Trans_Sysdatetime = :2 "
							Set sName = 'RollInvDeps'
							Set sBind = ':sTransUserId, :dtTransSysDT, :nCustNo'
							Set sInto = ''
							!
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								Return TRUE
							Else
								Return FALSE
						Case nCommit

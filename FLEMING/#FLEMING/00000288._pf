										! If SalModalDialog( dlgNewGetDateSelect, hWndForm, nTBType )
											              Call PopDateTime( dtRolloverDate, TRUE )
											              If SalFileGetDateTime( GetTrialBalanceCSVFileName( dtRolloverDate ), dtTmp )
												              Call SalMessageBox( 'Please note that the last trial balance generated today will be used as the basis for this Aging Exception report.', 'NOTE', MB_Ok )
												              Call SalCreateWindow( frmPrintAgingExceptionReport, hWndForm, dtRolloverDate, sAgingExceptionReportType )
											              Else 

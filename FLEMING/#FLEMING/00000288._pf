						List Values
						Message Actions
							On PAM_ROWAPPLIED
								If wParam
									Set colApplied = 'Y'
									Call SalSendMsgToChildren( hWndForm, PAM_COLOURYOURSELF, 0, 0 )
								Else
									Set colApplied = 'N'
									Call SalSendMsgToChildren( hWndForm, PAM_COLOURRESET, 0, 0 )
				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					!
					Boolean: bTablePopulated
					!
					String: sSQLPOPTABLENAME
					String: sORDERBY
					String: sPreBuildWhere
					String: sQueryTmpStr
					String: sCurrentBuildWhere
					Number: nInd
					Number: nAppliedColour
					!
					Sql Handle: hSqlUpdtCshRcptHdl
					Boolean: bUpdtCshRcptHdlConnected
					Boolean: bUpdtCshRcptHdlPrepared
					String: sWHEREUpdtCshRcpt
				Message Actions
					On PAM_POPULATE
						Call SalSendMsg( frmTransaction.dfTotalUnapplied, PAM_RESET, 0, 0 )
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillAll, PAM_SQL )
						Set bTablePopulated = TRUE
					! On PAM_NOROWS
						              Call SalMessageBox( 'No Cash Receipts were found for this customer!', 'Customer Outstanding Transactions', MB_Ok )
					On PAM_SETROWEDITFLAG
						If NOT wParam
							Call SalTblFetchRow( hWndForm, lParam )
							If NOT colAmtUnApplied = colOrgAmtUnApplied
								Return FALSE
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_HideMarks, TRUE )
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, wParam )
						Call SalSendMsg( colApplied, PAM_ROWAPPLIED, wParam, 0 )
					On PAM_CLEARAPPLIEDROW
						Call SalTblDeleteRow( hWndForm, lParam, TBL_NoAdjust )
					On SAM_FetchRowDone
						If SqlFetchRow( hLocalSqlPopTbl, lParam, nInd )
							Set colOrgAmtUnApplied = colAmtUnApplied
							Set frmTransaction.dfTotalUnapplied = frmTransaction.dfTotalUnapplied + colAmtUnApplied
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bTablePopulated = FALSE
						Set nAppliedColour = COLOR_Red
						Set sSQLPOPTABLENAME = ' CASH_RECEIPT '
						Set sORDERBY = ' ORDER BY RCPT_SYSDATETIME '
						Set sWHEREUpdtCshRcpt = ' WHERE Receipt_User_Id = :frmTransaction.tblUnAppCash.colRcptUserId AND Rcpt_Sysdatetime = :frmTransaction.tblUnAppCash.colRcptSysDateTime '
						Set bUpdtCshRcptHdlConnected = FALSE
						Set bUpdtCshRcptHdlPrepared = FALSE
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
						If bUpdtCshRcptHdlConnected
							Call SqlDisconnect( hSqlUpdtCshRcptHdl )

							On PAM_WHEREPOPULATE
								Set sBuildWhere = sPassedInWhere
							On SAM_Create
								Set sPassedInWhere = sBuildWhere
					Column: colCustNo
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Cust. No.
						Visible? Yes
						Editable? Yes
						Maximum Data Length: Default
						Data Type: Number
						Justify: Left
						Width:  1.163"
						Width Editable? Yes
						Format: #0
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL( wParam, hWndItem, 'CUST_NO' )
							On PAM_QBE
								If NOT SalIsNull( hWndItem )
									Call PushNumber( colCustNo )
									Call PushString( EQOPERAND )
									Call PushString( NUMERICFOLLOWING )
									Call PushString( 'CUST_NO' )
									Return TRUE
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, 0 )
							On PAM_EDITCHECK
								If NOT SalTblQueryRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_New )
									Call SalTblKillEdit( hWndForm )
					Column: colCustName
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Customer Name
						Visible? Yes
						Editable? Yes
						Maximum Data Length: 60
						Data Type: String
						Justify: Left
						Width:  5.95"
						Width Editable? Yes
						Format: Unformatted
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL( wParam, hWndItem, 'CUST_NAME' )
							On PAM_QBE
								If NOT SalIsNull( hWndItem )
									Set sQueryTmpStr = colCustName
									Call SalStrUpper( sQueryTmpStr, sQueryTmpStr )
									Call MyStrReplace( sQueryTmpStr, '\'', '_' )
									Set sQueryTmpStr = '%'||sQueryTmpStr||'%'
									Call PushString( sQueryTmpStr )
									Call PushString( LIKEOPERAND )
									Call PushString( STRINGFOLLOWING )
									Call PushString( '@UPPER(CUST_NAME)' )
									Return TRUE
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, 0 )
							On PAM_EDITCHECK
								If NOT SalTblQueryRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_New )
									Call SalTblKillEdit( hWndForm )
				Functions
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					String: sSQLTABLENAME
					String: sORDERBY
					String: sPassedInWhere
					String: sQueryTmpStr
					String: sCurrentBuildWhere
				Message Actions
					On PAM_POPULATE
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_SEARCH
						Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_RESET
						Call TableReset( hWndForm, colCustNo )
					On SAM_DoubleClick
						Call SalSendMsg( dlgQCustomer.pbSelect, SAM_Click, 0, 0 )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl )
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set sSQLTABLENAME = ' CUSTOMER_MASTER '
						Set sORDERBY = ' ORDER BY 2 '
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
			Pushbutton: pbSelect
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: S&elect
				Window Location and Size
					Left:   0.088"
					Top:    3.573"
					Width:  1.2"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: (none)
				Font Name: Default
				Font Size: Default
				Font Enhancement: Italic
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						If NOT SalTblAnyRows( dlgQCustomer.tblCustomer, ROW_Selected, 0 )
							Call SalMessageBox( 'Record Not Selected', 'Error', MB_Ok )
						Else
							Call SalWaitCursor( TRUE )
							Set bSelect = TRUE
							Set nRow = TBL_MinRow
							While SalTblFindNextRow( dlgQCustomer.tblCustomer, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( dlgQCustomer.tblCustomer, nRow )
								Call SalTblSetRowFlags( dlgQCustomer.tblCustomer, nRow, ROW_Selected, FALSE )
								Call PushNumber( dlgQCustomer.tblCustomer.colCustNo )
								Call PushString( dlgQCustomer.tblCustomer.colCustName )
								Call SalSendMsg( hWndPushbutton, PAM_LOOKUP, 0, 0 )
								If SalTblAnyRows( dlgQCustomer.tblCustomer, ROW_Selected, 0 )
									If NOT SalSendMsg( hWndPushbutton, PAM_READYFORNEXTLOOKUP, 0, 0 )
										Break
							Call SalEndDialog( hWndForm, 0 )
					On SAM_Create
						If NOT bEnableSelectPb
							Call SalDisableWindow( hWndItem )
					On PAM_ENABLE
						Call SalEnableWindow( hWndItem )
					On PAM_DISABLE
						Call SalDisableWindow( hWndItem )
					On PAM_QUERYDISABLE
						If wParam
							Call SalDisableWindow( hWndItem )
						Else
							Call SalEnableWindow( hWndItem )

				Set dfNoHP = nNoHP
				Set dfNoRP = nNoRP
				Set dfNoNM = nNoNM
				Set dfNoInv = nNoInv
			On SAM_Destroy
				Call SalPostMsg( hWndPushButton, PAM_ENABLE, 0, 0 )
				Call SalShowWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )

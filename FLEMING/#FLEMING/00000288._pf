				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: O&K Query
				Window Location and Size
					Left:   0.125"
					Top:    4.625"
					Width:  1.113"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes

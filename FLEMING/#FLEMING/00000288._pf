				Background Color: Default
				Message Actions
					On SAM_Click
						! If IDOK = SalMessageBox( 'Are you sure you wish to delete the selected transactions?? 
								  (This option is only a temporarily available option)',
								 'Delete Transactions', MB_OkCancel )
						If NOT SalTblAnyRows( tblTransaction, ROW_Edited, 0 )
							Call SalMessageBox( 'No Transactions edited', 'Update Transaction', MB_Ok )
							Return FALSE
						Call SalWaitCursor( TRUE )
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( tblTransaction, nRow, ROW_Edited, 0 )
							Call SalTblFetchRow( tblTransaction, nRow )
							Call UpdateTransRecord( hSqlUpdTransHdl, bUpdTransHdlConnected, bUpdTransHdlPrepared, frmTransaction.tblTransaction, ' WHERE ROWID = :frmTransaction.tblTransaction.colRowid')
						Call SalSendMsg( frmTransaction.tblTransaction, PAM_POPULATE, 0, 0 )
						Call SalWaitCursor( FALSE )

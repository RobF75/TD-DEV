		Functions
			Function: DeleteTransRecord
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					String: sCustNo
				Static Variables
				Local variables
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Set sSql = 'DELETE FROM TRANSACTION WHERE CUST_NO = :'||sCustNo
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						Call SqlCommit( hSqlHandle )
						Return TRUE
					Else
						Set bHandlePrepared = FALSE
						Call SqlPrepareAndExecute( hSqlHandle, 'rollback' )
						Return FALSE
			Function: RecalcAR
				Description: To fetch all records in the transaction file for a customer and then adjust
						the amount in the customers AR balance
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSql0Handle
					Receive Boolean: b0HandleConnected
					Receive Boolean: b0HandlePrepared
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					Receive Sql Handle: hSqlUnAppHandle
					Receive Boolean: bUnAppHandleConnected
					Receive Boolean: bUnAppHandlePrepared
					String: sCustNo
					Number: nCustNo
				Static Variables
				Local variables
					Number: nInd
					String: sTransCode
					Number: nAmtOuts
					Number: nWhichWay
					Number: nTotUnApp
					Number: nUnApp
				Actions
					If NOT b0HandleConnected
						Set b0HandleConnected = SqlConnect( hSql0Handle ) 
						If b0HandleConnected
							Call SqlSetLockTimeout( hSql0Handle, SQLTIMEOUT )
							Call SqlSetParameter( hSql0Handle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT b0HandlePrepared
						Set sSql = 'UPDATE CUSTOMER_MASTER SET CUST_AR_BALANCE = 0 
								 WHERE CUST_NO = :'||sCustNo
						If SqlPrepare( hSql0Handle, sSql )
							Set b0HandlePrepared = TRUE
						Else
							Set b0HandlePrepared = FALSE
					If SqlExecute( hSql0Handle )
						Call SqlCommit( hSql0Handle )
					Else
						Set b0HandlePrepared = FALSE
						Call SqlPrepareAndExecute( hSql0Handle, 'rollback' )
						Return FALSE
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Set sSql = 'SELECT TRANSACTION_CODE, TRANS_AMOUNT_OUTST 
								 FROM TRANSACTION INTO :sTransCode, :nAmtOuts WHERE CUST_NO = :'||sCustNo
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						While SqlFetchNext( hSqlHandle, nInd )
							If nInd = FETCH_Ok
								If sTransCode = 'CR'
									Set nWhichWay = nDecrement
								Else
									Set nWhichWay = nIncrement
								If NOT AdjustCustARBalance( nCustNo, nAmtOuts, nWhichWay, nExecute )
									Call AdjustCustARBalance( 0, 0, nIncrement, nRollback )
									Call AdjustCustARBalance( 0, 0, nDecrement, nRollback )
									Call SalMessageBox( 'Error occurred whilst trying to recalc a customers AR Balance'
											, 'Recalc AR', MB_Ok )
									Return FALSE
					Else
						Set bHandlePrepared = FALSE
						Return FALSE
					Set nTotUnApp = 0
					If NOT bUnAppHandleConnected
						Set bUnAppHandleConnected = SqlConnect( hSqlUnAppHandle ) 
						If bUnAppHandleConnected
							Call SqlSetLockTimeout( hSqlUnAppHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlUnAppHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bUnAppHandlePrepared
						Set sSql = "SELECT AMOUNT_UNAPPLIED 
								 FROM CASH_RECEIPT INTO  :nUnApp WHERE CUST_NO = :"||sCustNo||
								" AND FULLY_APPLIED_FLAG = 'N'"
						If SqlPrepare( hSqlUnAppHandle, sSql )
							Set bUnAppHandlePrepared = TRUE
						Else
							Set bUnAppHandlePrepared = FALSE
					If SqlExecute( hSqlUnAppHandle )
						While SqlFetchNext( hSqlUnAppHandle, nInd )
							If nInd = FETCH_Ok
								Set nTotUnApp = nTotUnApp + nUnApp
						If nTotUnApp > 0
							If NOT AdjustCustARBalance( nCustNo, nTotUnApp, nDecrement, nExecute )
								Call AdjustCustARBalance( 0, 0, nIncrement, nRollback )
								Call AdjustCustARBalance( 0, 0, nDecrement, nRollback )
								Call SalMessageBox( 'Error occurred whilst trying to recalc a customers AR Balance'
										, 'Recalc AR', MB_Ok )
								Return FALSE
					Else
						Set bUnAppHandlePrepared = FALSE
						Return FALSE
					Call AdjustCustARBalance( 0, 0, nIncrement, nCommit )
					Call AdjustCustARBalance( 0, 0, nDecrement, nCommit )
					Return TRUE

				Functions
					Function: TransTypeColPop
						Description:
						Returns
							Boolean:
						Parameters
							Window Handle: hWndColumn
							!
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								Call SalWaitCursor( TRUE )
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Call SalWaitCursor( FALSE )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = 'select distinct transaction_type from transaction'
									If SalListPopulate( hWndColumn, hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
										Call SalWaitCursor( FALSE )
										Return TRUE
									Else
										Set bHandlePrepared = FALSE
										Call SalWaitCursor( FALSE )
										Return FALSE
								Else
									Call SalWaitCursor( FALSE )
									Return TRUE
							Else
								Set bHandlePrepared = FALSE
								Set bOk = TRUE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
					Function: GetTransCode
						Description:
						Returns
							Boolean:
						Parameters
							String: sTransType
							Receive String: sTransCode
							!
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Boolean: bOk
							Number: nInd
							String: sGotTransCode
						Actions
							If nExecuteOrDisconnect != nDisconnect
								Call SalWaitCursor( TRUE )
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Call SalWaitCursor( FALSE )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = 'select distinct transaction_code from transaction into :sGotTransCode where transaction_type = :sTransType'
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
										Call SalWaitCursor( FALSE )
										Return FALSE
								Set sTransCode = ''
								Set sGotTransCode = ''
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									Set sTransCode = sGotTransCode
									Call SalWaitCursor( FALSE )
									Return TRUE
								Else
									Call SalWaitCursor( FALSE )
									Return FALSE
							Else
								Set bHandlePrepared = FALSE
								Set bOk = TRUE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
					Function: CheckTransCode
						Description:
						Returns
							Boolean:
						Parameters
							String: sTransType
							Receive String: sTransCode
							!
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Boolean: bOk
							Number: nInd
							String: sGotTransCode
						Actions
							If nExecuteOrDisconnect != nDisconnect
								Call SalWaitCursor( TRUE )
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Call SalWaitCursor( FALSE )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = 'select distinct transaction_code from transaction into :sGotTransCode where transaction_type = :sTransType'
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
										Call SalWaitCursor( FALSE )
										Return FALSE
								Set sGotTransCode = ''
								If SqlExecute( hSqlHandle )
									If SqlFetchNext( hSqlHandle, nInd )
										If SqlFetchNext( hSqlHandle, nInd )
											Call SalMessageBox( 'Please notify programmers - there is invalid
													data in transaction file - this transaction type has a DR and CR code 
													in the data which is invalid - it should only be a Debit OR a Credit', 'Invalid Data', MB_Ok )
											! We dont know which is the correct one - hopefully this message will make the user
													question which type it is and then enter the correct one and notify us so that we can
													adjust the erroneous data in the file 
											Call SalWaitCursor( FALSE )
											Return TRUE
										Else
											If sGotTransCode != sTransCode
												Call SalMessageBox( 'The transaction code you have entered does not agree with other
														 records in the transaction file for this transaction type.   Please check', 'Data Error', MB_Ok )
												Call SalWaitCursor( FALSE )
												Return FALSE
											Call SalWaitCursor( FALSE )
											Return TRUE
									! This is a new type being entered and there are no records
									Else
										Call SalWaitCursor( FALSE )
										Return TRUE
								! This is a new type being entered and there are no records
								Else
									Call SalWaitCursor( FALSE )
									Return TRUE
							Else
								Set bHandlePrepared = FALSE
								Set bOk = TRUE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					!
					Boolean: bTablePopulated
					Boolean: bEdit
					!
					String: sSQLPOPTABLENAME
					String: sORDERBY
					String: sPreBuildWhere
					String: sQueryTmpStr
					String: sCurrentBuildWhere
					Number: nInd
					Number: nAppliedColour
					Number: nWriteOffColour
					Number: nTmpAppliedColour
					Number: nMaxWriteOffAmt
					String: sMaxWriteOffAmt
					String: sCreditTransUserId
					Date/Time: dtCreditTransSysDt
					!
					String: sWHERETransaction
					Sql Handle: hSqlDeleteTransHdl
					Boolean: bDeleteTransHdlConnected
					Boolean: bDeleteTransHdlPrepared
					!
					Sql Handle: hSqlInsertHistHdl
					Boolean: bInsertHistHdlConnected
					Boolean: bInsertHistHdlPrepared
					!
					Sql Handle: hSqlInsertHistWOffHdl
					Boolean: bInsertHistWOffHdlConnected
					Boolean: bInsertHistWOffHdlPrepared
					!
					Sql Handle: hSqlUpdtTransHdl
					Boolean: bUpdtTransHdlConnected
					Boolean: bUpdtTransHdlPrepared
					!
					Sql Handle: hSqlInsTransHdl
					Boolean: bInsTransHdlConnected
					Boolean: bInsTransHdlPrepared
					Sql Handle: hSqlInsCrTransHdl
					Boolean: bInsCrTransHdlConnected
					Boolean: bInsCrTransHdlPrepared
					Sql Handle: hSqlCshAppWOffHdl
					Boolean: bCshAppWOffHdlConnected
					Boolean: bCshAppWOffHdlPrepared
					!
				Message Actions
					On PAM_POPULATE
						Call SalSendMsg( frmTransaction.dfTransAmtOuts, PAM_RESET, 0, 0 )
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, FALSE, TBL_FillAll, PAM_SQL )
						Set bTablePopulated = TRUE
					On SAM_FetchRowDone
						If colTransCode = 'CR'
							If NOT SalIsNull( colAmtOuts )
								Set frmTransaction.dfTransAmtOuts = frmTransaction.dfTransAmtOuts - colAmtOuts
							Else
								Set frmTransaction.dfTransAmtOuts = frmTransaction.dfTransAmtOuts - colTransAmount
						Else
							If NOT SalIsNull( colAmtOuts )
								Set frmTransaction.dfTransAmtOuts = frmTransaction.dfTransAmtOuts + colAmtOuts
							Else
								Set frmTransaction.dfTransAmtOuts = frmTransaction.dfTransAmtOuts + colTransAmount
						Set colOrgAmtOuts = colAmtOuts
						Set colApplied = 'N'
						Set colWriteOff = 'N'
					On PAM_NOROWS
						Call SalMessageBox( 'No Debit transactions were found for this customer!', 'Cash Receipt', MB_Ok )
					On PAM_SETROWEDITFLAG
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, wParam )
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_Selected, FALSE )
						Call SalSendMsg( colApplied, PAM_ROWAPPLIED, wParam, 0 )
						! bUnApplied is set when apply pb checks if applying unapplied cash to a debit
								- it is not set when we are applying a credit trans to a debit trans 
						If bUnApplied
							If wParam
								Set colAppliedAgainstRow = SalTblQueryContext( frmTransaction.tblUnAppCash )
							Call SalSendMsg( frmTransaction.tblUnAppCash, PAM_SETROWEDITFLAG, wParam, colAppliedAgainstRow )
					On PAM_CLEARAPPLIEDROW
						Call SalTblDeleteRow( hWndForm, lParam, TBL_NoAdjust )
					On PAM_WRITEOFFROW
						If wParam
							Call SalTblSetRowFlags( hWndForm, lParam, ROW_UnusedFlag1, TRUE )
							Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, wParam )
							Set nTmpAppliedColour = nAppliedColour
							Set nAppliedColour = nWriteOffColour
							Call SalSendMsgToChildren( hWndForm, PAM_COLOURYOURSELF, 0, 0 )
							Set nAppliedColour = nTmpAppliedColour
						Else
							Call SalSendMsgToChildren( hWndForm, PAM_COLOURRESET, 0, 0 )
					On PAM_RESET
						Call SalTblReset( hWndForm )
						Set bTablePopulated = FALSE
					On PAM_ADDROW
						Call SalSendMsgToChildren( hWndForm, PAM_ROWNEW, TRUE, TableAddRowNew( hWndForm, colRefId ) )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bTablePopulated = FALSE
						Set nAppliedColour = COLOR_Red
						Set nWriteOffColour = COLOR_Magenta
						Set sSQLPOPTABLENAME = ' TRANSACTION '
						Set sORDERBY = ' ORDER BY TRANSACTION_DATE '
						Set sWHERETransaction = ' WHERE TRANS_USER_ID = :frmTransaction.tblTransaction.colTransUserId AND TRANS_SYSDATETIME = :frmTransaction.tblTransaction.colTransSysDT '
						Set bDeleteTransHdlConnected = FALSE
						Set bDeleteTransHdlPrepared = FALSE
						Set bInsertHistHdlConnected = FALSE
						Set bInsertHistHdlPrepared = FALSE
						Set bInsertHistWOffHdlConnected = FALSE
						Set bInsertHistWOffHdlPrepared = FALSE
						Set bUpdtTransHdlConnected = FALSE
						Set bUpdtTransHdlPrepared = FALSE
						Set bInsTransHdlConnected = FALSE
						Set bInsTransHdlPrepared = FALSE
						Set bCshAppWOffHdlConnected = FALSE
						Set bCshAppWOffHdlPrepared = FALSE
						Set nMaxWriteOffAmt = 20
						Call SalPostMsg( colWriteOff, PAM_WRITEOFFRESTRICTIONS, 0, 0 )
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
						If bDeleteTransHdlConnected
							Call SqlDisconnect( hSqlDeleteTransHdl )
						! If bInsertHistHdlConnected
							              Call SqlDisconnect( hSqlInsertHistHdl )
						! If bInsertHistWOffHdlConnected
							              Call SqlDisconnect( hSqlInsertHistWOffHdl )
						If bUpdtTransHdlConnected
							Call SqlDisconnect( hSqlUpdtTransHdl )
						If bCshAppWOffHdlConnected
							Call SqlDisconnect( hSqlCshAppWOffHdl )
						If bInsTransHdlConnected
							Call SqlDisconnect( hSqlInsTransHdl )
						Call TransTypeColPop( hWndItem, nDisconnect )
						Call GetTransCode( colType, colTransCode, nDisconnect )

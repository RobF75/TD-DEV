						Message Actions
							On PAM_SETINSTANCEVARS
								Set OurColumnClass.bPopulateColumn = FALSE
					Column: colTransNotes
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class: OurColumnClass
						Property Template:
						Class DLL Name:
						Title:
						Visible? No
						Editable? Class Default
						Maximum Data Length: Class Default
						Data Type: String
						Justify: Class Default
						Width:  Class Default
						Width Editable? Class Default
						Format: Class Default
						Country: Class Default
						Input Mask: Class Default
						Cell Options
							Cell Type? Class Default
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? Class Default
								Vertical Scroll? Class Default
								Auto Drop Down? Class Default
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
							On PAM_SETINSTANCEVARS
								Set OurColumnClass.sSQLCOLNAME = ' TRANSACTION.TRANS_NOTES'
				Functions
					Function: GetInvoiceDeposit
						Description:
						Returns
							Boolean:
						Parameters
							Number: nCustNo
							String: sTransUserId
							Date/Time: dtTransSysDT
							! sTransTable = 'TRANSACTION' or 'TRANS_HISTORY'
							String: sTransTable
							Receive Number: nDepAmtPaid
							Number: nActionType
						Static Variables
							: fcTransHdl
								Class: hcSqlHandle
							: fcTransHistHdl
								Class: hcSqlHandle
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							!
							Number: nGotDepAmtPaid
							Number: nInd
						Actions
							Select Case nActionType
								Case nExecute
									!
									Set nDepAmtPaid = NUMBER_Null
									Set nGotDepAmtPaid = NUMBER_Null
									!
									If sTransTable = 'TRANS_HISTORY'
										Set sSql = " SELECT DepHist_Amt_Paid 
												FROM Deposit_History 
												WHERE Cust_No = :1 AND 
												Trans_Hist_User_Id = :2 AND 
												Trans_Hist_SysDT = :3 "
										Set sName = 'INVHISTDEPHIST'
										Set sBind = ':nCustNo, :sTransUserId, :dtTransSysDT'
										Set sInto = ':nGotDepAmtPaid'
										Call fcTransHistHdl.Setup( sSql, sName, sBind, sInto )
										Call SqlVarSetup( fcTransHistHdl.hSqlHandle )
										!
										If fcTransHistHdl.Execute( )
											While fcTransHistHdl.FetchNext( nInd )
												Set nDepAmtPaid = nDepAmtPaid + nGotDepAmtPaid
											Return TRUE
										Else
											Return FALSE
									Else
										Set sSql = " SELECT DepHist_Amt_Paid 
												FROM Deposit_History 
												WHERE Cust_No = :1 AND 
												Trans_User_Id = :2 AND 
												Trans_Sysdatetime = :3 "
										Set sName = 'INVDEPHIST'
										Set sBind = ':nCustNo, :sTransUserId, :dtTransSysDT'
										Set sInto = ':nGotDepAmtPaid'
										Call fcTransHdl.Setup( sSql, sName, sBind, sInto )
										Call SqlVarSetup( fcTransHdl.hSqlHandle )
										!
										If fcTransHdl.Execute( )
											While fcTransHdl.FetchNext( nInd )
												Set nDepAmtPaid = nDepAmtPaid + nGotDepAmtPaid
											Return TRUE
										Else
											Return FALSE
								Case nDisconnect
									Call fcTransHdl.Disconnect( )
									Call fcTransHistHdl.Disconnect( )
									Return TRUE
					Function: GetTransNotes
						Description:
						Returns
							Boolean:
						Parameters
							String: sTransUserId
							Date/Time: dtTransSysDT
							String: sTableType
							Receive String: lsTransNotes
							Number: nActionType
						Static Variables
							: fcOurHandle
								Class: hcSqlHandle
							: fcOurHistHandle
								Class: hcSqlHandle
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nInd
							!
							String: lsGotTransNotes
						Actions
							Select Case nActionType
								Case nExecute
									!
									Set lsTransNotes = ''
									Set lsGotTransNotes = ''
									!
									If sTableType = 'TRANSACTION'
										Set sSql = " SELECT 
												  Transaction_Notes
												FROM 
												  Transaction
												WHERE 
												  Trans_User_Id = :1 AND 
												  Trans_Sysdatetime = :2 "
										Set sName = 'INVSUMTRNOTES'
										Set sBind = ':sTransUserId, :dtTransSysDT'
										Set sInto = ':lsGotTransNotes'
										Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
										Call SqlVarSetup( fcOurHandle.hSqlHandle )
										!
										If fcOurHandle.Execute( )
											If fcOurHandle.FetchNext( nInd )
												Set lsTransNotes = lsGotTransNotes
											Return TRUE
										Else
											Return FALSE
									Else
										Set sSql = " SELECT 
												  Hist_Trans_Notes
												FROM 
												  Trans_History
												WHERE 
												  Trans_Hist_User_Id = :1 AND 
												  TrHist_Sysdatetime = :2 "
										Set sName = 'INVSUMTRNOTEHS'
										Set sBind = ':sTransUserId, :dtTransSysDT'
										Set sInto = ':lsGotTransNotes'
										Call fcOurHistHandle.Setup( sSql, sName, sBind, sInto )
										Call SqlVarSetup( fcOurHistHandle.hSqlHandle )
										!
										If fcOurHistHandle.Execute( )
											If fcOurHistHandle.FetchNext( nInd )
												Set lsTransNotes = lsGotTransNotes
											Return TRUE
										Else
											Return FALSE
								Case nDisconnect
									Set bOk = TRUE
									If NOT fcOurHandle.Disconnect( )
										Set bOk = FALSE
									If NOT fcOurHistHandle.Disconnect( )
										Set bOk = FALSE
									Return bOk
				Window Variables
					!
					Number: nInvoiceNo
					Date/Time: dtInvoiceDate
					String: sStatus
					String: sRunType
					Number: nYearOfSale
					String: sLoadId
					Number: nCustNo
					String: sUserId
					!
					!
					String: sSql
					Number: nInd
					: fcOurInvNoRegRangeHdl
						Class: hcSqlHandle
					Number: nNewRow
					Boolean: bLoop
					Boolean: bAnotherRegInvNo
					!
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ''
						Set sSQLPOPTABLENAME = ''
						Set sROWID = ''
						Set sSQLWHERE = ''
						Set sORDERBY = ''
						Set bSelectFirstRow = FALSE
						Set nTableFillType = TBL_FillAll
					On PAM_POPULATE
						Call SalSendClassMessage( PAM_POPULATE, wParam, lParam )
						!
						Call MyTableLoop( hWndForm, hWndForm,  PAM_ROWACTION, 0, 0, 'Calculating the totals', nLowToHi )
						!
						Set sSql = " SELECT 
								  Invoice_No, 
								  Invoice_Date, 
								  Status, 
								  Run_Type, 
								  Year_Of_Sale, 
								  Load_Id, 
								  Cust_No, 
								  User_Id 
								FROM Inv_No_Register 
								INTO 
								  :frmPrintInvSummary.tblInvSummary.nInvoiceNo, 
								  :frmPrintInvSummary.tblInvSummary.dtInvoiceDate, 
								  :frmPrintInvSummary.tblInvSummary.sStatus, 
								  :frmPrintInvSummary.tblInvSummary.sRunType, 
								  :frmPrintInvSummary.tblInvSummary.nYearOfSale, 
								  :frmPrintInvSummary.tblInvSummary.sLoadId, 
								  :frmPrintInvSummary.tblInvSummary.nCustNo, 
								  :frmPrintInvSummary.tblInvSummary.sUserId
								WHERE  Invoice_Date BETWEEN :frmPrintInvSummary.dfReportFromDate AND :frmPrintInvSummary.dfReportToDate 
								ORDER BY Invoice_No "
						Call fcOurInvNoRegRangeHdl.PrepareSetup( sSql )
						Call SqlVarSetup( fcOurInvNoRegRangeHdl.hSqlHandle )
						Call fcOurInvNoRegRangeHdl.PrepareAndExecute( )
						!
						If fcOurInvNoRegRangeHdl.FetchNext( nInd )
							Set bAnotherRegInvNo = TRUE
						Else
							Set bAnotherRegInvNo = FALSE
						Call MyTableLoop( hWndForm, hWndForm,  PAM_CHECKMISSINVNOS, 0, 0, 'Checking for Missing Invoice Numbers.', nLowToHi )
						Return TRUE
					On PAM_SETSGSQL
						Set sgSql = " SELECT  
								  Transaction.Cust_No,
								  Customer_Master.Cust_Name, 
								  @VALUE( Transaction.Reference_Id ), 
								  Transaction.Reference_Id, 
								  Transaction.Transaction_Date,
								  Transaction.Transaction_Amount,
								  Transaction.Label_Charges,
								  Transaction.Postal_Charges,
								  Transaction.Freight_Charges,
								  Transaction.Rail_Charges,
								  Transaction.Royalties,
								  Transaction.Trans_User_Id,
								  Transaction.Trans_SysDateTime, 
								  Transaction.Transaction_Code, 
								  'TRANSACTION' 
								FROM  
								  Transaction,
								  Customer_Master
								WHERE 
								  Customer_Master.Cust_No = Transaction.Cust_No AND 
								  Transaction.Transaction_Date >= :frmPrintInvSummary.dfReportFromDate AND 
								  Transaction.Transaction_Date <= :frmPrintInvSummary.dfReportToDate AND
								  Transaction.Transaction_Type = 'INVOICE'
								UNION ALL
								SELECT  
								 Trans_History.Cust_No,
								 Customer_Master.Cust_Name,
								 @VALUE( Trans_History.Hist_Reference_Id ), 
								 Trans_History.Hist_Reference_Id,
								 Trans_History.Hist_Trans_Date,
								 Trans_History.Hist_Trans_Amount,
								 Trans_History.Hist_Label_Charges,
								 Trans_History.Hist_Postal_Charge,
								 Trans_History.Hist_Freight_Charg,
								 Trans_History.Hist_Rail_Charges,
								 Trans_History.Royalties,
								 Trans_History.Trans_Hist_User_Id,
								 Trans_History.TrHist_SysDateTime, 
								 Trans_History.Hist_Trans_Code, 
								 'TRANS_HISTORY'
								FROM  
								  Trans_History, 
								  Customer_Master  
								WHERE 
								  Customer_Master.Cust_No = Trans_History.Cust_No AND 
								  Trans_History.Hist_Trans_Date >= :frmPrintInvSummary.dfReportFromDate AND 
								  Trans_History.Hist_Trans_Date <= :frmPrintInvSummary.dfReportToDate AND
								  Trans_History.Hist_Trans_Type = 'INVOICE' 
								INTO 
								  :frmPrintInvSummary.tblInvSummary.colTransCustNo, 
								  :frmPrintInvSummary.tblInvSummary.colCustName, 
								  :frmPrintInvSummary.tblInvSummary.colNumericTransRefId, 
								  :frmPrintInvSummary.tblInvSummary.colTransRefId, 
								  :frmPrintInvSummary.tblInvSummary.colTransDate, 
								  :frmPrintInvSummary.tblInvSummary.colTransAmount, 
								  :frmPrintInvSummary.tblInvSummary.colTransLabelChrg, 
								  :frmPrintInvSummary.tblInvSummary.colTransPostalChrg, 
								  :frmPrintInvSummary.tblInvSummary.colTransFreightChrg, 
								  :frmPrintInvSummary.tblInvSummary.colTransRailChrg, 
								  :frmPrintInvSummary.tblInvSummary.colTransRoyalties, 
								  :frmPrintInvSummary.tblInvSummary.colTransUserId, 
								  :frmPrintInvSummary.tblInvSummary.colTransSysDT, 
								  :frmPrintInvSummary.tblInvSummary.colTransCode, 
								  :frmPrintInvSummary.tblInvSummary.colTransTable
								ORDER BY 3 "
						Return TRUE
					On SAM_FetchRowDone
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_HideMarks, TRUE )
						Call GetTransNotes( colTransUserId, colTransSysDT, colTransTable, colTransNotes, nExecute )
						If colTransNotes = 'Uninvoiced'
							Set dfTotUnInv = dfTotUnInv + colTransAmount
							Set colTransAmount = 0
							Set colTransLabelChrg = 0
							Set colTransPostalChrg = 0
							Set colTransFreightChrg = 0
							Set colTransRailChrg = 0
							Set colTransRoyalties = 0
							Set colDepAmtPaid = 0
							Set colCustName = 'Cancelled via reverse entry'
							Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, TRUE )
						Else
							Call GetInvoiceDeposit( colTransCustNo, colTransUserId, colTransSysDT, colTransTable, colDepAmtPaid, nExecute )
							Set colDepAmtPaid = colDepAmtPaid * -1
					On PAM_ROWACTION
						Set dfTotRail = dfTotRail + colTransRailChrg
						Set dfTotPostal = dfTotPostal + colTransPostalChrg
						Set dfTotFreight = dfTotFreight + colTransFreightChrg
						Set dfTotLabels = dfTotLabels + colTransLabelChrg
						Set dfTotDeposits = dfTotDeposits + colDepAmtPaid
						Set dfTotRoyalties = dfTotRoyalties + colTransRoyalties
						Set dfTotInvoices = dfTotInvoices + colTransAmount
						Set dfNoInv = dfNoInv + 1
						Return TRUE
					On PAM_CHECKMISSINVNOS
						Set bLoop = TRUE
						While bLoop AND bAnotherRegInvNo
							If nInvoiceNo < colNumericTransRefId
								Set nNewRow = SalTblInsertRow( hWndForm, lParam )
								Call SalTblSetContext( hWndForm, nNewRow )
								Call SalTblSetRowFlags( hWndForm, nNewRow, ROW_HideMarks, TRUE )
								If nCustNo > 0
									Set colTransCustNo = nCustNo
								If sStatus = 'ONSCREEN'
									Set colCustName = 'Canceled from Screen'
								Else
									Set colCustName = sStatus
								Set colTransRefId = SalNumberToStrX( nInvoiceNo, 0 )
								Set colTransDate = dtInvoiceDate
								Set colTransUserId = sUserId
								!
								If fcOurInvNoRegRangeHdl.FetchNext( nInd )
									Set bAnotherRegInvNo = TRUE
								Else
									Set bAnotherRegInvNo = FALSE
							Else If nInvoiceNo = colNumericTransRefId
								If fcOurInvNoRegRangeHdl.FetchNext( nInd )
									Set bAnotherRegInvNo = TRUE
								Else
									Set bAnotherRegInvNo = FALSE
							Else
								Set bLoop = FALSE
						Return TRUE
					On PAM_RESET
						Call PushWndHdl( hWndNULL )
						Call SalSendClassMessage( PAM_RESET, wParam, lParam )
					On PAM_NOROWS
						Return TRUE
					On SAM_Destroy
						Call GetInvoiceDeposit( 0, '', DATETIME_Null, '', colDepAmtPaid, nDisconnect )
						Call fcOurInvNoRegRangeHdl.Disconnect( )
						Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
			! NewOurChildTable: tblInvSummary
.winattr class Child Table:
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: NewOurChildTable
				Property Template:
				Class DLL Name:
				Display Settings
					Window Location and Size
						Left:   0.05"
						Top:    0.74"
						Width:  9.825"
						Width Editable? Yes
						Height: 4.635"
						Height Editable? Yes
					Visible? Yes
					Font Name: Default
					Font Size: Default
					Font Enhancement: Default
					Text Color: Dark Blue
					Background Color: Default
					View: Table
					Allow Row Sizing? No
					Lines Per Row: Default
				Memory Settings
					Maximum Rows in Memory: 10000
					Discardable? Yes
.end
				              Contents 
					              Column: colRowId
						              List Values 
						              Message Actions 
					              Column: colTransCustNo
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' TRANSACTION.CUST_NO '
							              On PAM_CUSTFIELDS
								              Call BuildSQL( wParam, hWndItem, 'CustNo' )
					              Column: colCustName
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' CUSTOMER_MASTER.CUST_NAME '
							              On PAM_CUSTFIELDS
								              Call BuildSQL( wParam, hWndItem, 'CustName' )
					              Column: colNumericTransRefId
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' @VALUE( TRANSACTION.REFERENCE_ID) '
					              Column: colTransRefId
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' TRANSACTION.REFERENCE_ID '
							              On PAM_CUSTFIELDS
								              Call BuildSQL( wParam, hWndItem, 'RefId' )
					              Column: colTransDate
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' TRANSACTION.TRANSACTION_DATE '
							              On PAM_CUSTFIELDS
								              Call BuildSQL( wParam, hWndItem, 'InvDate' )
					              Column: colTransAmount
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' TRANSACTION.TRANSACTION_AMOUNT '
							              On PAM_CUSTFIELDS
								              Call BuildSQL( wParam, hWndItem, 'TransAmount' )
					              Column: colTransLabelChrg
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' TRANSACTION.LABEL_CHARGES '
							              On PAM_CUSTFIELDS
								              Call BuildSQL( wParam, hWndItem, 'LabelChg' )
					              Column: colTransPostalChrg
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' TRANSACTION.POSTAL_CHARGES '
							              On PAM_CUSTFIELDS
								              Call BuildSQL( wParam, hWndItem, 'PostalChg' )
					              Column: colTransFreightChrg
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' TRANSACTION.FREIGHT_CHARGES '
							              On PAM_CUSTFIELDS
								              Call BuildSQL( wParam, hWndItem, 'FreightChg' )
					              Column: colTransRailChrg
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' TRANSACTION.RAIL_CHARGES '
							              On PAM_CUSTFIELDS
								              Call BuildSQL( wParam, hWndItem, 'RailChg' )
					              Column: colTransRoyalties
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' TRANSACTION.ROYALTIES '
							              On PAM_CUSTFIELDS
								              Call BuildSQL( wParam, hWndItem, 'Royalties' )
					              Column: colDepAmtPaid
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.bPopulateColumn = FALSE
							              On PAM_CUSTFIELDS
								              Call BuildSQL( wParam, hWndItem, 'DepAmtPaid' )
					              Column: colTransUserId
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' TRANSACTION.TRANS_USER_ID'
					              Column: colTransSysDT
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.sSQLCOLNAME = ' TRANSACTION.TRANS_SYSDATETIME'
					              Column: colTransTable
						              List Values 
						              Message Actions 
							              On PAM_SETINSTANCEVARS
								              Set OurColumnClass.bPopulateColumn = FALSE
				              Functions 
					              Function: GetInvoiceDeposit
						              Description: 
						              Returns 
							              Boolean: 
						              Parameters 
							              Number: nCustNo
							              String: sTransUserId
							              Date/Time: dtTransSysDT
							! sTransTable = 'TRANSACTION' or 'TRANS_HISTORY'
							              String: sTransTable
							              Receive Number: nDepAmtPaid
							              Number: nActionType
						              Static Variables 
							              : fcTransHdl
							              : fcTransHistHdl
						              Local variables 
							              String: sSql
							              String: sBind
							              String: sInto
							              String: sName
							!
							              Number: nGotDepAmtPaid
							              Number: nInd
						              Actions 
							              Select Case nActionType
								              Case nExecute
									!
									              Set nDepAmtPaid = NUMBER_Null
									              Set nGotDepAmtPaid = NUMBER_Null
									!
									              If sTransTable = 'TRANS_HISTORY'
										              Set sSql = " SELECT DepHist_Amt_Paid 
												FROM Deposit_History 
												WHERE Cust_No = :1 AND 
												Trans_Hist_User_Id = :2 AND 
												Trans_Hist_SysDT = :3 "
										              Set sName = 'INVHISTDEPHIST'
										              Set sBind = ':nCustNo, :sTransUserId, :dtTransSysDT'
										              Set sInto = ':nGotDepAmtPaid'
										              Call fcTransHistHdl.Setup( sSql, sName, sBind, sInto )
										              Call SqlVarSetup( fcTransHistHdl.hSqlHandle )
										!
										              If fcTransHistHdl.Execute( )
											              While fcTransHistHdl.FetchNext( nInd )
												              Set nDepAmtPaid = nDepAmtPaid + nGotDepAmtPaid
											              Return TRUE
										              Else 
											              Return FALSE
									              Else 
										              Set sSql = " SELECT DepHist_Amt_Paid 
												FROM Deposit_History 
												WHERE Cust_No = :1 AND 
												Trans_User_Id = :2 AND 
												Trans_Sysdatetime = :3 "
										              Set sName = 'INVDEPHIST'
										              Set sBind = ':nCustNo, :sTransUserId, :dtTransSysDT'
										              Set sInto = ':nGotDepAmtPaid'
										              Call fcTransHdl.Setup( sSql, sName, sBind, sInto )
										              Call SqlVarSetup( fcTransHdl.hSqlHandle )
										!
										              If fcTransHdl.Execute( )
											              While fcTransHdl.FetchNext( nInd )
												              Set nDepAmtPaid = nDepAmtPaid + nGotDepAmtPaid
											              Return TRUE
										              Else 
											              Return FALSE
								              Case nDisconnect
									              Call fcTransHdl.Disconnect( )
									              Call fcTransHistHdl.Disconnect( )
									              Return TRUE
					              Function: GetInvoiceNoRegisterDetails
						              Description: 
						              Returns 
							              Boolean: 
						              Parameters 
							              Number: nInvoiceNo
							              Receive Date/Time: dtInvoiceDate
							              Receive String: sStatus
							              Receive String: sRunType
							              Receive Number: nYearOfSale
							              Receive String: sLoadId
							              Receive Number: nCustNo
							              Receive String: sUserId
							              Number: nActionType
						              Static Variables 
							              : fcOurHandle
						              Local variables 
							              String: sSql
							              String: sBind
							              String: sInto
							              String: sName
							!
							              Date/Time: dtGotInvoiceDate
							              String: sGotStatus
							              String: sGotRunType
							              Number: nGotYearOfSale
							              String: sGotLoadId
							              Number: nGotCustNo
							              String: sGotUserId
							              Number: nInd
						              Actions 
							              Select Case nActionType
								              Case nExecute
									              Set sSql = " SELECT 
											  Invoice_Date, 
											  Status, 
											  Run_Type, 
											  Year_Of_Sale, 
											  Load_Id, 
											  Cust_No, 
											  User_Id 
											FROM Inv_No_Register 
											WHERE Invoice_No = :1 "
									              Set sName = 'INVNOSTATUS'
									              Set sBind = ':nInvoiceNo'
									              Set sInto = ':dtGotInvoiceDate,
											:sGotStatus,
											:sGotRunType,
											:nGotYearOfSale,
											:sGotLoadId,
											:nGotCustNo,
											:sGotUserId'
									              Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
									              Call SqlVarSetup( fcOurHandle.hSqlHandle )
									!
									              Set dtInvoiceDate = DATETIME_Null
									              Set sStatus = ''
									              Set sRunType = ''
									              Set nYearOfSale = NUMBER_Null
									              Set sLoadId = ''
									              Set nCustNo = NUMBER_Null
									              Set sUserId = ''
									              Set dtGotInvoiceDate = DATETIME_Null
									              Set sGotStatus = ''
									              Set sGotRunType = ''
									              Set nGotYearOfSale = NUMBER_Null
									              Set sGotLoadId = ''
									              Set nGotCustNo = NUMBER_Null
									              Set sGotUserId = ''
									              If fcOurHandle.Execute( )
										              If fcOurHandle.FetchNext( nInd )
											              Set dtInvoiceDate = dtGotInvoiceDate
											              Set sStatus = sGotStatus
											              Set sRunType = sGotRunType
											              Set nYearOfSale = nGotYearOfSale
											              Set sLoadId = sGotLoadId
											              Set nCustNo = nGotCustNo
											              Set sUserId = sGotUserId
										              Return TRUE
									              Else 
										              Return FALSE
								              Case nDisconnect
									              Return fcOurHandle.Disconnect( )
				              Window Variables 
					!
					              Date/Time: dtInvoiceDate
					              String: sStatus
					              String: sRunType
					              Number: nYearOfSale
					              String: sLoadId
					              Number: nCustNo
					              String: sUserId
					!
					              Number: nLastInvoiceNo
					              Number: nNewRow
				              Message Actions 
					              On PAM_SETINSTANCEVARS
						              Set sSQLTABLENAME = ''
						              Set sSQLPOPTABLENAME = ''
						              Set sROWID = ''
						              Set sSQLWHERE = ''
						              Set sORDERBY = ''
						              Set bSelectFirstRow = FALSE
						              Set nTableFillType = TBL_FillAll
					              On PAM_POPULATE
						              Call SalSendClassMessage( PAM_POPULATE, wParam, lParam )
						!
						              Call SalTblFetchRow( hWndForm, 0 )
						              If SalStrLength( colTransRefId ) >= 8
							              Set nLastInvoiceNo = SalStrToNumber( SalStrLeftX( colTransRefId, 4 )||'0000' )-1
						              Else 
							              Set nLastInvoiceNo = SalStrToNumber( SalStrLeftX( colTransRefId, 4 )||'000' )-1
						!
						              Call MyTableLoop( hWndForm, hWndForm,  PAM_ROWACTION, 0, 0, 'Calculating the totals', nLowToHi )
						              Call MyTableLoop( hWndForm, hWndForm,  PAM_CHECKMISSINVNOS, 0, 0, 'Checking for Missing Invoice Numbers.', nLowToHi )
					              On PAM_SETSGSQL
						              Set sgSql = " SELECT  
								  Transaction.Cust_No,
								  Customer_Master.Cust_Name, 
								  @VALUE( Transaction.Reference_Id ), 
								  Transaction.Reference_Id, 
								  Transaction.Transaction_Date,
								  Transaction.Transaction_Amount,
								  Transaction.Label_Charges,
								  Transaction.Postal_Charges,
								  Transaction.Freight_Charges,
								  Transaction.Rail_Charges,
								  Transaction.Royalties,
								  Transaction.Trans_User_Id,
								  Transaction.Trans_SysDateTime, 
								  'TRANSACTION'
								FROM  
								  Transaction,
								  Customer_Master
								WHERE 
								  Customer_Master.Cust_No = Transaction.Cust_No AND 
								  Transaction.Transaction_Date >= :frmPrintInvSummary.dfReportFromDate AND 
								  Transaction.Transaction_Date <= :frmPrintInvSummary.dfReportToDate AND
								  Transaction.Transaction_Type = 'INVOICE'
								UNION ALL
								SELECT  
								 Trans_History.Cust_No,
								 Customer_Master.Cust_Name,
								 @VALUE( Trans_History.Hist_Reference_Id ), 
								 Trans_History.Hist_Reference_Id,
								 Trans_History.Hist_Trans_Date,
								 Trans_History.Hist_Trans_Amount,
								 Trans_History.Hist_Label_Charges,
								 Trans_History.Hist_Postal_Charge,
								 Trans_History.Hist_Freight_Charg,
								 Trans_History.Hist_Rail_Charges,
								 Trans_History.Royalties,
								 Trans_History.Trans_Hist_User_Id,
								 Trans_History.TrHist_SysDateTime, 
								 'TRANS_HISTORY'
								FROM  
								  Trans_History, 
								  Customer_Master  
								WHERE 
								  Customer_Master.Cust_No = Trans_History.Cust_No AND 
								  Trans_History.Hist_Trans_Date >= :frmPrintInvSummary.dfReportFromDate AND 
								  Trans_History.Hist_Trans_Date <= :frmPrintInvSummary.dfReportToDate AND
								  Trans_History.Hist_Trans_Type = 'INVOICE' 
								INTO 
								  :frmPrintInvSummary.tblInvSummary.colTransCustNo, 
								  :frmPrintInvSummary.tblInvSummary.colCustName, 
								  :frmPrintInvSummary.tblInvSummary.colNumericTransRefId, 
								  :frmPrintInvSummary.tblInvSummary.colTransRefId, 
								  :frmPrintInvSummary.tblInvSummary.colTransDate, 
								  :frmPrintInvSummary.tblInvSummary.colTransAmount, 
								  :frmPrintInvSummary.tblInvSummary.colTransLabelChrg, 
								  :frmPrintInvSummary.tblInvSummary.colTransPostalChrg, 
								  :frmPrintInvSummary.tblInvSummary.colTransFreightChrg, 
								  :frmPrintInvSummary.tblInvSummary.colTransRailChrg, 
								  :frmPrintInvSummary.tblInvSummary.colTransRoyalties, 
								  :frmPrintInvSummary.tblInvSummary.colTransUserId, 
								  :frmPrintInvSummary.tblInvSummary.colTransSysDT, 
								  :frmPrintInvSummary.tblInvSummary.colTransTable 
								ORDER BY 3 "
						              Return TRUE
					              On SAM_FetchRowDone
						              Call GetInvoiceDeposit( colTransCustNo, colTransUserId, colTransSysDT, colTransTable, colDepAmtPaid, nExecute )
						              Set colDepAmtPaid = colDepAmtPaid * -1
					              On PAM_ROWACTION
						              Set dfTotRail = dfTotRail + colTransRailChrg
						              Set dfTotPostal = dfTotPostal + colTransPostalChrg
						              Set dfTotFreight = dfTotFreight + colTransFreightChrg
						              Set dfTotLabels = dfTotLabels + colTransLabelChrg
						              Set dfTotDeposits = dfTotDeposits + colDepAmtPaid
						              Set dfTotRoyalties = dfTotRoyalties + colTransRoyalties
						              Set dfTotInvoices = dfTotInvoices + colTransAmount
						              Set dfNoInv = dfNoInv + 1
						              Return TRUE
					              On PAM_CHECKMISSINVNOS
						              If NOT nLastInvoiceNo + 1 = colNumericTransRefId
							              Call GetInvoiceNoRegisterDetails( nLastInvoiceNo + 1, dtInvoiceDate, sStatus, 
									sRunType, nYearOfSale, sLoadId, nCustNo, sUserId, nExecute )
							              If sStatus = 'ONSCREEN'
								              Set nNewRow = SalTblInsertRow( hWndForm, lParam )
								              Call SalTblSetContext( hWndForm, nNewRow )
								              Call SalTblSetRowFlags( hWndForm, nNewRow, ROW_HideMarks, TRUE )
								              If nCustNo > 0
									              Set colTransCustNo = nCustNo
								              Set colCustName = 'Canceled from Screen'
								              Set colTransRefId = SalNumberToStrX( nLastInvoiceNo + 1, 0 )
								              Set colTransDate = dtInvoiceDate
								              Set colTransUserId = sUserId
								              Set nLastInvoiceNo = nLastInvoiceNo + 1
								! Set dfNoInv = dfNoInv - 1
								              Return TRUE
						              Set nLastInvoiceNo = colNumericTransRefId
						              Return TRUE
					              On PAM_RESET
						              Call PushWndHdl( hWndNULL )
						              Call SalSendClassMessage( PAM_RESET, wParam, lParam )
					              On PAM_NOROWS
						              Return TRUE
					              On SAM_Destroy
						              Call GetInvoiceDeposit( 0, '', DATETIME_Null, '', colDepAmtPaid, nDisconnect )
						              Call GetInvoiceNoRegisterDetails( 0, dtInvoiceDate, sStatus, 
								sRunType, nYearOfSale, sLoadId, nCustNo, sUserId, nDisconnect )
						              Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

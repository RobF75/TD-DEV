							Return bOk
						Case nDisconnect
							Set bOk = TRUE
							Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
							Return bOk
						Case nRePrepare
							Call haSqlHandles[ nSqlHandleNo ].RePrepare( )
							Return TRUE
			Function: RollInvoiceDeposits
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					String: sTransUserId
					Date/Time: dtTransSysDT
					!
					Number: nActionType
				Static Variables
				Local variables
					String: sSql

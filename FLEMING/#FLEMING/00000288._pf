				Functions
				Window Variables
					Sql Handle: hSqlTransHdl
					Boolean: bTransHdlConnected
					Boolean: bTransHdlPrepared
					Sql Handle: hSqlTrHistHdl
					Boolean: bTrHistHdlConnected
					Boolean: bTrHistHdlPrepared
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' Cash_Application, Customer_Master '
						Set sSQLPOPTABLENAME = ' Cash_Application, Customer_Master '
						Set sROWID = ' Cash_Application.ROWID '
						Set sSQLWHERE = ' WHERE Customer_Master.Cust_No = Cash_Application.Cust_No AND 
								    Cash_Application.Date_Applied >= :frmPrintCashApp.dfReportFromDate AND 
								    Cash_Application.Date_Applied <= :frmPrintCashApp.dfReportToDate '
						! Set sSQLWHERE = ' WHERE Customer_Master.Cust_No = Cash_Application.Cust_No AND 
								 Cash_Application.Cust_No = 310532 and 
								    Cash_Application.Date_Applied >= :frmPrintCashApp.dfReportFromDate AND 
								    Cash_Application.Date_Applied <= :frmPrintCashApp.dfReportToDate '
						Set sORDERBY = ' ORDER BY Cash_Application.Cust_No, 
								Cash_Application.Date_Applied, Cash_Application.Applied_Amount '
						! Set sORDERBY = ' ORDER BY Cash_Application.Date_Applied, 
								Cash_Application.Cust_No, Cash_Application.Applied_Amount '
					On PAM_POPULATE
						If NOT bTransHdlConnected
							Set bTransHdlConnected = SqlConnect( hSqlTransHdl ) 
							If bTransHdlConnected
								Call SqlSetLockTimeout( hSqlTransHdl, SQLTIMEOUT )
								Call SqlSetParameter( hSqlTransHdl, DBP_PRESERVE, TRUE, ''  )
							Else
								Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
								Return -1
						If NOT bTransHdlPrepared
							Set sgSql = " SELECT TRANSACTION_TYPE, REFERENCE_ID FROM TRANSACTION INTO 
									:frmPrintCashApp.tblCashApp.colTransType, :frmPrintCashApp.tblCashApp.colRefId WHERE
									  Transaction.Trans_User_Id = :frmPrintCashApp.tblCashApp.colTransUser AND
									  Transaction.Trans_Sysdatetime = :frmPrintCashApp.tblCashApp.colTransSysDate "
							If SqlPrepare( hSqlTransHdl, sgSql )
								Set bTransHdlPrepared = TRUE
							Else
								Set bTransHdlPrepared = FALSE
						If NOT bTrHistHdlConnected
							Set bTrHistHdlConnected = SqlConnect( hSqlTrHistHdl ) 
							If bTrHistHdlConnected
								Call SqlSetLockTimeout( hSqlTrHistHdl, SQLTIMEOUT )
								Call SqlSetParameter( hSqlTrHistHdl, DBP_PRESERVE, TRUE, ''  )
							Else
								Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
								Return -1
						If NOT bTrHistHdlPrepared
							Set sgSql = " SELECT HIST_TRANS_TYPE, HIST_REFERENCE_ID FROM TRANS_HISTORY INTO 
									:frmPrintCashApp.tblCashApp.colTransType, :frmPrintCashApp.tblCashApp.colRefId WHERE
									  Trans_History.Trans_Hist_User_Id = :frmPrintCashApp.tblCashApp.colTransHUser AND
									  Trans_History.TrHist_Sysdatetime = :frmPrintCashApp.tblCashApp.colTransHSysDate "
							If SqlPrepare( hSqlTrHistHdl, sgSql )
								Set bTrHistHdlPrepared = TRUE
							Else
								Set bTrHistHdlPrepared = FALSE
						Call SalSendClassMessage( PAM_POPULATE, wParam, lParam )
					On SAM_FetchRowDone
						If NOT SalIsNull( frmPrintCashApp.tblCashApp.colTransUser )
							If SqlExecute( hSqlTransHdl ) 
								Call SqlFetchNext( hSqlTransHdl, nInd )
						If NOT SalIsNull( frmPrintCashApp.tblCashApp.colTransHUser )
							If SqlExecute( hSqlTrHistHdl ) 
								Call SqlFetchNext( hSqlTrHistHdl, nInd )
						If NOT SalIsNull( frmPrintCashApp.tblCashApp.colTransUserCred )
							Set frmPrintCashApp.tblCashApp.colCrAmount = frmPrintCashApp.tblCashApp.colAppAmount
						If NOT SalIsNull( frmPrintCashApp.tblCashApp.colTransHUserCred )
							Set frmPrintCashApp.tblCashApp.colCrAmount = frmPrintCashApp.tblCashApp.colAppAmount
						Return TRUE
					On SAM_Create
						Set bTrHistHdlConnected = FALSE
						Set bTrHistHdlPrepared = FALSE
						Set bTransHdlConnected = FALSE
						Set bTransHdlPrepared = FALSE
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
					On PAM_NOROWS
						Return TRUE
					On SAM_Destroy
						If bTrHistHdlConnected
							Call SqlDisconnect( hSqlTrHistHdl )
						If bTransHdlConnected
							Call SqlDisconnect( hSqlTransHdl )
						Call SalSendClassMessage( SAM_Destroy, wParam, lParam )

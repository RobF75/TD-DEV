					Pushbutton: pbOk
						Class Child Ref Key: 0
						Class ChildKey: 11
						Class: OurPushbuttonClass
						Property Template:
						Class DLL Name:
						Title: &Ok
						Window Location and Size
							Left:   0.163"
							Top:    2.521"
							Width:  1.375"
							Width Editable? Class Default
							Height: Class Default
							Height Editable? Class Default
						Visible? Class Default
						Keyboard Accelerator: Class Default
						Font Name: Class Default
						Font Size: Class Default
						Font Enhancement: Class Default
						Picture File Name:
						Picture Transparent Color: Class Default
						Image Style: Class Default
						Text Color: Class Default
						Background Color: Class Default
						Message Actions
							On PAM_CLICK
								Set nYear = SalStrToNumber( ccYear.GetNumber( ) )
								Call lbMonth.GetSelectMonthBegEndDays( nMonth, nBegDay, nEndDay, nYear )
								Set dtRolloverDate = SalDateConstruct( nYear, nMonth, nEndDay, 0, 0, 0 )
								Call SalDateToStr( dtRolloverDate, sRolloverDate )
								Set sRolloverDate = SalNumberToStrX( SalDateDay( dtRolloverDate ), 0 ) || '/' || 
										SalNumberToStrX( SalDateMonth( dtRolloverDate ), 0 ) || '/' || 
										SalNumberToStrX( SalDateYear( dtRolloverDate ), 0 )
								If IDOK = SalMessageBox( 'Is the '||sRolloverDate||' the date you wish to use?', 'Verify', MB_OkCancel )
									If SalSendMsg( hWndItem, PAM_PUSHFIELDS, 0, 0 )
										Return SalSendMsg( pbCancel, SAM_Click, 0, TRUE )
							On PAM_PUSHFIELDS
								Call PushDateTime( dtRolloverDate )
								Return TRUE

				Text Color: Default
				Background Color: Default
				Message Actions
					On PAM_ENABLE
						Call SalShowWindow( hWndItem )
						Call SalEnableWindow( hWndItem )
					On PAM_DISABLE
						Call SalHideWindow( hWndItem )
						Call SalDisableWindow( hWndItem )
					On SAM_Create
						Call SalHideWindow( hWndItem )
						Call SalDisableWindow( hWndItem )
					On SAM_Click
						Call SalWaitCursor( TRUE )
						Set bShowQueryOk = FALSE
						Select Case nWhichTableActive
							Case nCustomerTbl
								Call SalSendMsg( tblQCustomer, PAM_SEARCH, 0, 0 )
								Break
							Case nCustAddrTbl
								Call SalSendMsg( tblQCustAddr, PAM_SEARCH, 0, 0 )
								Break
							Case nCustContTbl
								Call SalSendMsg( tblQCustCont, PAM_SEARCH, 0, 0 )
						Call SalSendMsg( pbQueryOk, PAM_DISABLE, 0, 0 )
						Call SalSendMsg( pbQuery, PAM_ENABLE, 0, 0 )
						Call SalSendMsgToChildren( hWndForm, PAM_QUERYDISABLE, FALSE, 0 )

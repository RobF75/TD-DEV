								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
							On PAM_SETINSTANCEVARS
								Set OurColumnClass.sSQLCOLNAME = ' OUTSTAND_DEPOSIT.DEP_SYSDATETIME '
								Set OurColumnClass.bInsert = FALSE
								Set OurColumnClass.bUpdate = FALSE
							On PAM_EDITCHECK
								If SalTblQueryRowFlags( hWndForm, lParam, ROW_New ) AND IsEditOkHere( )
									Return TRUE
								Else
									Return FALSE
					Column: colDepositSysDT
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class: OurColumnClass
						Property Template:
						Class DLL Name:
						Title: Deposit Date SysDT
						Visible? No
						Editable? Class Default
						Maximum Data Length: Class Default
						Data Type: Date/Time
						Justify: Class Default
						Width:  1.188"
						Width Editable? Class Default
						Format: DateTime
						Country: Class Default
						Input Mask: Class Default
						Cell Options
							Cell Type? Class Default
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? Class Default
								Vertical Scroll? Class Default
								Auto Drop Down? Class Default
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
							On PAM_SETINSTANCEVARS
								Set OurColumnClass.sSQLCOLNAME = ' OUTSTAND_DEPOSIT.DEP_SYSDATETIME '
								Set OurColumnClass.bOrderBy = TRUE
								Set OurColumnClass.bRenewRowId = TRUE
								Set OurColumnClass.bUpdate = FALSE
							On PAM_CHECKROWNEW
								Set dtTmp = GetUniqueCurrentSysDT(  )
								!
								If NOT SalIsNull( colUserViewDepositSysDT )
									! the bollow check is need over the GetUniqueCurrentSysDT( ) because SalDateSecond( ) only returns
											whole seconds between 0-59 and GetUniqueCurrentSysDT( ) gives unique in microseconds
									Set dtTmp = SalDateConstruct( SalDateYear( colUserViewDepositSysDT ), SalDateMonth( colUserViewDepositSysDT ), SalDateDay( colUserViewDepositSysDT ), SalDateHour( dtTmp ), SalDateMinute( 
											dtTmp ), SalDateSecond( dtTmp ) )
									While dtTmp = dtLastRow
										Set dtTmp = GetUniqueCurrentSysDT(  )
										Set dtTmp = SalDateConstruct( SalDateYear( colUserViewDepositSysDT ), SalDateMonth( colUserViewDepositSysDT ), SalDateDay( colUserViewDepositSysDT ), SalDateHour( dtTmp ), SalDateMinute( 
												dtTmp ), SalDateSecond( dtTmp ) )
									Set dtLastRow = dtTmp
								!
								Set colDepositSysDT = dtTmp
								Return TRUE
							On PAM_EDITCHECK
								If SalTblQueryRowFlags( hWndForm, lParam, ROW_New ) AND IsEditOkHere( )
									Return TRUE
								Else
									Return FALSE
					!

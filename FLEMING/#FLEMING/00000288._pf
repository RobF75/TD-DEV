								Menu Actions
									Call SalMessageBox( "Please run 'Deposit Listing - Company' from the main Cash Receipts screen for the month required", 'Cash Deposit Listing', MB_Ok )
								Menu Item Name:
							Menu Item: &Pulled but not Invoiced Listing
								Resource Id: 59480
								Keyboard Accelerator: (none)
								Status Text:
								Menu Settings
									Enabled when:
									Checked when:
								Menu Actions
									Call SalWaitCursor( TRUE )
									! If SqlDatabase = 'STOCK'
										              Set sTmp = 'g:\\apps\\gupta\\flemlive\\orpninv.exe'
									! Else
										              Set sTmp = 'g:\\apps\\gupta\\flemdev\\orpninvd.exe'
									Set sTmp = OurGetIniFileParameter( 'ACCOUNTS', 'PulledNotInvoiced', '' )
									Set sTmp = sTmp || ' ' || SqlDatabase || ' ' || SqlUser || ' ' || SqlPassword
									Call SalLoadAppAndWait( sTmp, Window_Normal, nTmp )
									Call SalWaitCursor( FALSE )
								Menu Item Name:
							Popup Menu: Aging exception report
								Resource Id: 59491
								Enabled when:
								Status Text:
								Menu Item Name:
								Menu Item: 60 Day and Over
									Resource Id: 59490
									Keyboard Accelerator: (none)
									Status Text:
									Menu Settings
										Enabled when:
										Checked when:
									Menu Actions
										Call SalWaitCursor( TRUE )
										Set nTBType = nSelectedCustomers
										Set bAutomatedTrialBalance = FALSE
										Set sAgingExceptionReportType = '61-90'
										Set nNumCust = 0
										Set nRow = TBL_MinRow
										Select Case nWhichTableActive
											Case nCustomerTbl
												If NOT SalTblAnyRows( tblQCustomer, ROW_Selected, 0 )
													Set nTBType = nAllCustomers
												Else
													While SalTblFindNextRow( tblQCustomer, nRow, ROW_Selected, 0 )
														Call SalTblFetchRow( tblQCustomer, nRow )
														Set nNumCust = nNumCust + 1
														Set nCustNos[nNumCust-1] = tblQCustomer.colCustNo
													Set nCustNos[nNumCust] = NUMBER_Null
												Break
											Case nCustAddrTbl
												If NOT SalTblAnyRows( tblQCustAddr, ROW_Selected, 0 )
													Set nTBType = nAllCustomers
												Else
													While SalTblFindNextRow( tblQCustAddr, nRow, ROW_Selected, 0 )
														Call SalTblFetchRow( tblQCustAddr, nRow )
														Set nNumCust = nNumCust + 1
														Set nCustNos[nNumCust-1] = tblQCustAddr.colCustNo
													Set nCustNos[nNumCust] = NUMBER_Null
												Break
											Case nCustContTbl
												If NOT SalTblAnyRows( tblQCustCont, ROW_Selected, 0 )
													Set nTBType = nAllCustomers
												Else
													While SalTblFindNextRow( tblQCustCont, nRow, ROW_Selected, 0 )
														Call SalTblFetchRow( tblQCustCont, nRow )
														Set nNumCust = nNumCust + 1
														Set nCustNos[nNumCust-1] = tblQCustCont.colCustNo
													Set nCustNos[nNumCust] = NUMBER_Null
										If dtRolloverDate = DATETIME_Null
											Call SalModalDialog( dlgNewGetDate, hWndForm )
											Call PopDateTime( dtRolloverDate, TRUE )
										Call SalCreateWindow( frmPrintAgingExceptionReport, hWndForm, dtRolloverDate, sAgingExceptionReportType )
										! If SalModalDialog( dlgNewGetDateSelect, hWndForm, nTBType )
											              Call PopDateTime( dtRolloverDate, TRUE )
											              If SalFileGetDateTime( GetTrialBalanceCSVFileName( dtRolloverDate ), dtTmp )
												              Call SalMessageBox( 'Please note that the last trial balance generated today will be used as the basis for this Aging Exception report.', 'NOTE', MB_Ok )
												              Call SalCreateWindow( frmPrintAgingExceptionReport, hWndForm, dtRolloverDate, sAgingExceptionReportType )
											              Else 
												              Call SalMessageBox( 'Please note that a trial balance will be generated first before the Aging Exception report.', 'NOTE', MB_Ok )
												              Set bAutomatedTrialBalance = TRUE
												              Call SalCreateWindow( frmPrintTrialBalance, hWndForm, nCustNos, nNumCust, dtRolloverDate, nPrintTrialBal, nTBType, FALSE )
										Call SalWaitCursor( FALSE )

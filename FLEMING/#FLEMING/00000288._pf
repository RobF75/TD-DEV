		Message Actions
			On SAM_Create
				! Call SalHideWindow( hWndForm )
				Call SalShowWindow( hWndForm )
				Return SalSendClassMessage( SAM_Create, wParam, lParam )
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
			On SAM_CreateComplete
				Call SalWaitCursor( TRUE )
				Call SalSendMsgToChildren( hWndForm, PAM_SHOW, 0, 0 )
				If SalSendMsg( tblTrialBalanceReport, PAM_POPULATE, 0, 0 )
					Call SalSendMsg( tblTrialBalanceReport, PAM_PRINTFULLTABLEREPORT, 0, 0 )
				Call SalWaitCursor( FALSE )
				! Call SalSendMsg( pbExit, SAM_Click, 0, 0 )
			On SAM_Destroy
				Call SalShowWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				Call SalPostMsg( SalParentWindow( hWndForm ), PAM_REPORTFINISHED, 0, SalHStringToNumber( 'AGING_EXCEPTION' ) )
	!

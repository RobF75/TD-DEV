		Functions
			Function: DeleteSelTransRecord
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					String: sUserId
					String: dDateTime
				Static Variables
				Local variables
					String: sSql
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Set sSql = 'DELETE FROM TRANSACTION WHERE TRANS_USER_ID = :'||sUserId
								||' AND TRANS_SYSDATETIME = :'||dDateTime
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						Return TRUE
					Else
						Set bHandlePrepared = FALSE
						Return FALSE
			Function: UpdateTransRecord
				Description:
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					Window Handle: hWndTable
					String: sWhere
				Static Variables
				Local variables
				Actions
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Call CallBuildSql( hWndTable, nUPDATE, PAM_UPDTRANSACTION, 'TRANSACTION', sWhere )
						If SqlPrepare( hSqlHandle, sgSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						Return TRUE
					Else
						Set bHandlePrepared = FALSE
						Return FALSE
		Window Parameters
			! Date/Time: dtApplyDate
		Window Variables
			Window Handle: hWndPushbutton
			Window Handle: hWndTable
			String: sHelpFileName
			Boolean: bEdit
			Boolean: bNextPbEnabled
			Boolean: bPrevPbEnabled
			Boolean: bUnApplied
			Boolean: bCRFound
			Boolean: bDRFound
			Number: nCRRow
			Number: nDRRow
			Number: nAmtCredit
			Number: nAmtToCredit
			Number: nAmtToBeCredited
			!
			Number: nTransAmount
			Number: nTransCode
			Number: nCount
			Number: nRow
			Number: nCashRcptRow
			Number: nOrgRow
			Boolean: bHaveAppliedRow
			Boolean: bHaveUnAppliedRow
			Boolean: bRowWrittenOff
			Boolean: bSaveOk
			Number: nTransRowsApplied
			Number: nOrgTransRowsApplied
			Date/Time: dtApplyDate
			!
			Sql Handle: hSqlDelTransHdl
			Boolean: bDelTransHdlConnected
			Boolean: bDelTransHdlPrepared
			Sql Handle: hSqlUpdTransHdl
			Boolean: bUpdTransHdlConnected
			Boolean: bUpdTransHdlPrepared
			Sql Handle: hSqlInsertCashAppHdl
			Boolean: bInsertCashAppHdlConnected
			Boolean: bInsertCashAppHdlPrepared
			Sql Handle: hSqlInsertCRDRCashAppHdl
			Boolean: bInsertCRDRCashAppHdlConnected
			Boolean: bInsertCRDRCashAppHdlPrepared
			String: sCRCompany
			Number: nAppRow
			Boolean: bCompanyMatch
		Message Actions
			On SAM_Create
				Set sHelpFileName = ''
				Call PopWndHdl( hWndTable, TRUE )
				Call PopWndHdl( hWndPushbutton, TRUE )
			On SAM_CreateComplete
				Set bEdit = FALSE
				Set nTransRowsApplied = 0
				Set bInsertCashAppHdlConnected = FALSE
				Set bInsertCashAppHdlPrepared = FALSE
				Set bInsertCRDRCashAppHdlConnected = FALSE
				Set bInsertCRDRCashAppHdlPrepared = FALSE
				!
				Call PopString( dfCustName, TRUE )
				Call PopNumber( dfCustNo, TRUE )
				Set dfCurrDate = SalDateCurrent(  )
				Set dtApplyDate = dfCurrDate
				Call SalSendMsg( pbWriteOff, PAM_WRITEOFFRESTRICTIONS, 0, 0 )
				Call SalSendMsg( tblTransaction, PAM_POPULATE, 0, 0 )
				Call SalSendMsg( tblUnAppCash, PAM_POPULATE, 0, 0 )
				Call SalDisableWindow( SalParentWindow( hWndForm ) )
			On SAM_Destroy
				Call SalEnableWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				If bInsertCashAppHdlConnected
					Call SqlDisconnect( hSqlInsertCashAppHdl )
				If bInsertCRDRCashAppHdlConnected
					Call SqlDisconnect( hSqlInsertCRDRCashAppHdl )
				If bDelTransHdlConnected
					Call SqlDisconnect( hSqlDelTransHdl )
				If bUpdTransHdlConnected
					Call SqlDisconnect( hSqlUpdTransHdl )
				Call SalSendMsg( hWndPushbutton, PAM_ENABLE, bEdit, 0 )
				Call GetCustARBalance( 0, dfCustARBalance, nDisconnect )
				Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nDisconnect )
				Call CheckForFinishedTrans( 0, '', '', 0, 0, DATETIME_Null, tblTransaction.colDaysToPay, nDisconnect )
				Call UpdtCustDaysOfCredAvg( 0, nDisconnect )
			On SAM_Close
				Call SalSendValidateMsg(  )
				If bEdit
					If NOT ForgetChanges(  )
						Return FALSE
					Else
						Set bEdit = FALSE
				Else If NOT TableForgetChanges( tblTransaction, frmTransaction.tblTransaction.bEdit )
					Return FALSE
				Call SalWaitCursor( TRUE )

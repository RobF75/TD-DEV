							Return '"'||sField||'"'
					! !
					Function: MakeStatementCSVLine
						Description:
						Returns
							String:
						Parameters
						Static Variables
						Local variables
							String: sCSVLine
						Actions
							Set sCSVLine = NumberField( frmPrintTrialBalance.tblTrialBalanceReport.colCustNo, 0 ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colCustName ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colBusName ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colAreaCode ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colPhone ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colAddressLine1 ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colAddressLine2 ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colSuburb ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colState ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colPostcode ) ||
									DateField( frmPrintTrialBalance.tblTrialBalanceReport.colRolloverDate ) ||
									NumberField( frmPrintTrialBalance.tblTrialBalanceReport.colServiceCharge, 2 ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colDebtCollect ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colARNotes ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colReferenceId ) ||
									DateField( frmPrintTrialBalance.tblTrialBalanceReport.colTransDate ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colTransType ) ||
									NumberField( frmPrintTrialBalance.tblTrialBalanceReport.colTransAmount, 2 ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colTransCode ) ||
									NumberField( frmPrintTrialBalance.tblTrialBalanceReport.colTransAmountOutstand, 2 ) ||
									NumberField( frmPrintTrialBalance.tblTrialBalanceReport.colDeposit, 2 ) ||
									NumberField( frmPrintTrialBalance.tblTrialBalanceReport.colOutstandDeposit, 2 ) ||
									NumberField( frmPrintTrialBalance.tblTrialBalanceReport.colCustARBalance, 2 ) ||
									NumberField( frmPrintTrialBalance.tblTrialBalanceReport.col0to30, 2 ) ||
									NumberField( frmPrintTrialBalance.tblTrialBalanceReport.col31to60, 2 ) ||
									NumberField( frmPrintTrialBalance.tblTrialBalanceReport.col61to90, 2 ) ||
									NumberField( frmPrintTrialBalance.tblTrialBalanceReport.col91plus, 2 ) ||
									NumberField( frmPrintTrialBalance.tblTrialBalanceReport.colTotalARAtStart, 2 ) ||
									StringField( frmPrintTrialBalance.tblTrialBalanceReport.colTransCancelled )
							Return sCSVLine
				Window Variables
					Number: nRow
					Number: nNoRows
					Number: nFileCurrRow
					Window Handle: hWndMeter
					Boolean: bPrint
					File Handle: hCustInvCSVFile
					Boolean: bCustCSVFileOpen
					String: sCSVFile
					!
					Number: nRowCustNo
					Number: nRowP1CustNo
					Number: nRemoveCustNo
					Number: nTotalAR
					Number: nCurrentAR
					Number: n30dayAR
					Number: n60dayAR
					Number: n90dayAR
					Number: nTotalInv
					Number: nTotalCash
					Number: nTotalCredit
					Number: nDepositUsed
					Number: nTotSvcChg
					Number: nTotDRJournal
					Number: nTotRefund
					Number: nTotBankCharge
					Number: nMiscGLDebit
					Number: nSvcChgWroff
					Number: nCRJournal
					Number: nWroffs
					Number: nCRTypes
					Number: nDiscounts
					Number: nCoopAdv
					Number: nMiscGLCredits
					Number: nDepRequest
					String: sTemp
					!
					Number: nLastCustNo
					Number: nLastCustNoARBalance
					Boolean: bMarkCust
					!
					: fcTrialBalanceCSVFile
						Class: clsStrFileHandle
					!
					String: sCSVFields[*]
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sReportFileName = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\cststat4.qrp'
					On PAM_ADDROW
						Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
						Call SalSendMsg( hWndForm, PAM_POPFIELDS, 0, 0 )
						! For cash colTransAmount is -ve already
						If colTransType = 'DEPOSIT'
							Set nTotalAR = nTotalAR + colDeposit
						Else
							Set nTotalAR = nTotalAR + colTransAmount
						! Else If colTransCode = 'DR'
							              Set nTotalAR = nTotalAR + colTransAmount
						! Else
							              Set nTotalAR = nTotalAR - colTransAmount
						If colTransType != 'OUTSTAND DEPOSIT'
							Set nCurrentAR = nCurrentAR + col0to30
							Set n30dayAR = n30dayAR + col31to60
							Set n60dayAR = n60dayAR + col61to90
							Set n90dayAR = n90dayAR + col91plus
						If colTransType = 'INVOICE'
							If NOT colTransCancelled = 'CANCELLED'
								Set nTotalInv = nTotalInv + col0to30
						If colTransType = 'CASH' OR colTransType = 'CHEQUE'
							If colTransDate >= SalDateMonthBegin( colRolloverDate ) AND colTransDate <= colRolloverDate
								Set nTotalCash = nTotalCash - colTransAmount
								! to get the cash to accumulate subtract the negative
								! Set nTotalCash = nTotalCash + colTransAmount
						If colTransType = 'CREDNOTE'
							Set nTotalCredit = nTotalCredit - col0to30
						If colTransType = 'DEPOSIT'
							Set nDepositUsed = nDepositUsed - col0to30
						If colTransType = 'SVC CHG'
							Set nTotSvcChg = nTotSvcChg + col0to30
						If colTransType = 'DR.JNL' OR colTransType = 'DEBIT'
							If NOT colTransCancelled = 'CANCELLED'
								Set nTotDRJournal = nTotDRJournal + col0to30
						If colTransType = 'REFUND'
							Set nTotRefund = nTotRefund + col0to30
						If colTransType = 'BANKCHG' OR colTransType = 'BNKCHG'
							Set nTotBankCharge = nTotBankCharge + col0to30
						Set sTemp = SalStrLeftX( colTransType, 2 )
						If sTemp = 'GL' AND colTransCode = 'DR'
							Set nMiscGLDebit = nMiscGLDebit + col0to30
						If colTransType = 'SVCWROFF'
							Set nSvcChgWroff = nSvcChgWroff - col0to30
						If colTransType = 'CR.JNL'
							Set nCRJournal = nCRJournal  - col0to30
						If colTransType = 'WRITEOFF'
							Set nWroffs = nWroffs - col0to30
						If colTransType = 'CREDIT'
							If NOT colTransCancelled = 'CANCELLED'
								Set nCRTypes = nCRTypes - col0to30
						If colTransType = 'GLDISCNT'
							Set nDiscounts = nDiscounts - col0to30
						If colTransType = 'GLCOPADV'
							Set nCoopAdv = nCoopAdv - col0to30
						If sTemp = 'GL' AND colTransCode = 'CR'
							Set nMiscGLCredits = nMiscGLCredits - col0to30
						If colTransType = 'OUTSTAND DEPOSIT'
							Set nDepRequest = nDepRequest + colOutstandDeposit
						!
						! ^^
						Set sTemp = NumberToStrXNullNull( colCustNo, 0 )||','||
								StringField( colCustName )||','||
								StringField( colBusName )||','||
								StringField( colAreaCode )||','||
								StringField( colPhone )||','||
								StringField( colAddressLine1 )||','||
								StringField( colAddressLine2 )||','||
								StringField( colSuburb )||','||
								StringField( colState )||','||
								StringField( colPostcode )||','||
								DateToStrX( colRolloverDate )||','||
								NumberToStrXNullNull( colServiceCharge, 2 )||','||
								StringField( colDebtCollect )||','||
								StringField( '' ) ||','||
								StringField( colReferenceId )||','||
								DateToStrX( colTransDate )||','||
								StringField( colTransType )||','||
								NumberToStrXNullNull( colTransAmount, 2 )||','||
								StringField( colTransCode )||','||
								NumberToStrXNullNull( colTransAmountOutstand, 2 )||','||
								NumberToStrXNullNull( colDeposit, 2 )||','||
								NumberToStrXNullNull( colOutstandDeposit, 2 )||','||
								NumberToStrXNullNull( colCustARBalance, 2 )||','||
								NumberToStrXNullNull( col0to30, 2 )||','||
								NumberToStrXNullNull( col31to60, 2 )||','||
								NumberToStrXNullNull( col61to90, 2 )||','||
								NumberToStrXNullNull( col91plus, 2 ) ||','||
								NumberToStrXNullNull( colTotalARAtStart, 2 ) ||','||
								StringField( colTransCancelled )
						Call frmPrintTrialBalance.fcTrialBalanceCSVFile.Write( sTemp )
						Return TRUE
					On PAM_POPFIELDS
						Call PopString( colTransCancelled, TRUE )
						Call PopNumber( colTotalARAtStart, TRUE )
						Call PopNumber( col91plus, TRUE )
						Call PopNumber( col61to90, TRUE )
						Call PopNumber( col31to60, TRUE )
						Call PopNumber( col0to30, TRUE )
						Call PopNumber( colCustARBalance, TRUE )
						Call PopNumber( colOutstandDeposit, TRUE )
						Call PopNumber( colDeposit, TRUE )
						Call PopNumber( colTransAmountOutstand, TRUE )
						Call PopString( colTransCode, TRUE )
						Call PopNumber( colTransAmount, TRUE )
						Call PopString( colTransType, TRUE )
						Call PopDateTime( colTransDate, TRUE )
						Call PopString( colReferenceId, TRUE )
						Call PopString( colARNotes, TRUE )
						Call PopNumber( colServiceCharge, TRUE )
						Call PopString( colDebtCollect, TRUE )
						Call PopDateTime( colRolloverDate, TRUE )
						Call PopString( colPostcode, TRUE )
						Call PopString( colState, TRUE )
						Call PopString( colSuburb, TRUE )
						Call PopString( colAddressLine2, TRUE )
						Call PopString( colAddressLine1, TRUE )
						Call PopString( colPhone, TRUE )
						Call PopString( colAreaCode, TRUE )
						Call PopString( colBusName, TRUE )
						Call PopString( colCustName, TRUE )
						Call PopNumber( colCustNo, TRUE )
						Return TRUE
					On PAM_DELETEROWS
						! The next while make all the colCustARBalance columns that are not the last
								  entry for a customer NULL.  So that a customers AR balance appears in this
								  table only once for each cust_No and on his last details line
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( hWndForm, nRow, 0, 0 )
							Call SalTblSetContext( hWndForm, nRow )
							Set nRowCustNo = colCustNo
							If SalTblSetContext( hWndForm, nRow + 1 )
								Set nRowP1CustNo = colCustNo
								If nRowCustNo = nRowP1CustNo
									Call SalTblSetContext( hWndForm, nRow )
									Set colCustARBalance = NUMBER_Null
						! The next while goes through and checks the colCustARBalance and if = 0
								  It works up the table and deletes this customers detail lines from the table!
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( hWndForm, nRow, 0, 0 )
							Call SalTblSetContext( hWndForm, nRow )
							If colCustARBalance = 0
								Set nRemoveCustNo = colCustNo
								While nRemoveCustNo = colCustNo
									Call SalTblDeleteRow( hWndForm, nRow, TBL_NoAdjust )
									Set nRow = nRow - 1
									Call SalTblSetContext( hWndForm, nRow )
					! New code for monthly AR control table accumulation
					On SAM_CreateComplete
						Set nTotalAR = NUMBER_Null
						Set nCurrentAR = NUMBER_Null
						Set n30dayAR = NUMBER_Null
						Set n60dayAR = NUMBER_Null
						Set n90dayAR = NUMBER_Null
						Set nTotalInv = NUMBER_Null
						Set nTotalCash = NUMBER_Null
						Set nTotalCredit = NUMBER_Null
						Set nDepositUsed = NUMBER_Null
						Set nTotSvcChg = NUMBER_Null
						Set nTotDRJournal = NUMBER_Null
						Set nTotRefund = NUMBER_Null
						Set nTotBankCharge = NUMBER_Null
						Set nMiscGLDebit = NUMBER_Null
						Set nSvcChgWroff = NUMBER_Null
						Set nCRJournal = NUMBER_Null
						Set nWroffs = NUMBER_Null
						Set nCRTypes = NUMBER_Null
						Set nDiscounts = NUMBER_Null
						Set nCoopAdv = NUMBER_Null
						Set nMiscGLCredits = NUMBER_Null
						Set nDepRequest = NUMBER_Null
					On PAM_PRINTFULLTABLEREPORT
						Set nLastCustNo = NUMBER_Null
						Set nLastCustNoARBalance = NUMBER_Null
						Set bMarkCust = FALSE
						Call MyTableLoop( hWndForm, hWndForm, PAM_CHECKEDIT, 0, 0, 'Checking to print balances greater than $5', nHiToLow )
						Call MyTableLoop( hWndForm, hWndForm, PAM_ROWACTION, 0, ROW_Selected, 'Removing Statements below $5 OR with Debt Collectors', nLowToHi )
						Return SalSendClassMessage( PAM_PRINTFULLTABLEREPORT, wParam, lParam )
					On PAM_CHECKEDIT
						If nLastCustNo != colCustNo
							Set nLastCustNo = colCustNo
							If colCustARBalance >= 5 OR colOutstandDeposit > 0
								Set bMarkCust = TRUE
							Else
								Set bMarkCust = FALSE
							! Want to check if the debt collection flag is on - cos if it is we dont want to print a statement for them
							If bMarkCust
								If colDebtCollect = 'Y'
									Set bMarkCust = FALSE
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_Selected, bMarkCust )
						Return TRUE
					On PAM_ROWACTION
						Call SalTblDeleteRow( hWndForm, lParam, TBL_NoAdjust )
						Return nRowDeleted
					On PAM_TABLEREPORTROWACTION
						If nLastCustNo != colCustNo
							Set nLastCustNo = colCustNo
							If bCustCSVFileOpen
								Call SalFileClose( hCustInvCSVFile )
								Set bCustCSVFileOpen = FALSE
							!
							Set sCSVFile = OurGetIniFileParameter( 'ACCOUNTS', 'StatementsCSVPath', 'c:\\temp' ) || '\\' || MakeCustStatementCSVFileName( colCustNo, SalDateYear( colRolloverDate ), sReportFileName )
							If SalFileOpen( hCustInvCSVFile, sCSVFile, OF_Create | OF_Write | OF_Text )
								Set bCustCSVFileOpen = TRUE
							Else
								Set bCustCSVFileOpen = FALSE
						!
						Set sTmp = MakeStatementCSVLine( )
						If bCustCSVFileOpen
							If NOT SalFilePutStr( hCustInvCSVFile, sTmp )
								Call SalFileClose( hCustInvCSVFile )
								Set bCustCSVFileOpen = FALSE
						!
						Return TRUE
					!
					! ^^
					On PAM_POPULATE
						If nFromCustNo > 0
							Set bPrint = FALSE
						Else
							Set bPrint = TRUE
						!
						Call fcTrialBalanceCSVFile.Setup( GetTrialBalanceCSVFileName( frmPrintTrialBalance.dtRolloverDate ), OF_ReadWrite | OF_Text, NUMBER_Null )
						If fcTrialBalanceCSVFile.Open( )
							Call SalTblReset( hWndForm )
							Call fcTrialBalanceCSVFile.Seek (0, FILE_SeekEnd )
							Set nNoRows = fcTrialBalanceCSVFile.Tell( )
							Call fcTrialBalanceCSVFile.Seek (0, FILE_SeekBegin )
							Set nFileCurrRow = 0
							If nNoRows >= nNumRowsToMeter
								Set hWndMeter = SalCreateWindow( dlgMeterProgress, frmPrintTrialBalance, 'Populating Table', nNoRows )
							Else
								Set hWndMeter = hWndNULL
							While fcTrialBalanceCSVFile.Read( sTemp ) AND NOT bCancel
								!
								Set sCSVFields[0] = ''
								Set sCSVFields[1] = ''
								Set sCSVFields[2] = ''
								Set sCSVFields[3] = ''
								Set sCSVFields[4] = ''
								Set sCSVFields[5] = ''
								Set sCSVFields[6] = ''
								Set sCSVFields[7] = ''
								Set sCSVFields[8] = ''
								Set sCSVFields[9] = ''
								Set sCSVFields[10] = ''
								Set sCSVFields[11] = ''
								Set sCSVFields[12] = ''
								Set sCSVFields[13] = ''
								Set sCSVFields[14] = ''
								Set sCSVFields[15] = ''
								Set sCSVFields[16] = ''
								Set sCSVFields[17] = ''
								Set sCSVFields[18] = ''
								Set sCSVFields[19] = ''
								Set sCSVFields[20] = ''
								Set sCSVFields[21] = ''
								Set sCSVFields[22] = ''
								Set sCSVFields[23] = ''
								Set sCSVFields[24] = ''
								Set sCSVFields[25] = ''
								Set sCSVFields[26] = ''
								Set sCSVFields[27] = ''
								Set sCSVFields[28] = ''
								Set sCSVFields[29] = ''
								Set sCSVFields[30] = ''
								!
								! Call SalStrTokenize( sTemp, '', ',', sCSVFields )
								Call StrCSVTokenize( sTemp, sCSVFields )
								!
								If NOT bPrint
									If nFromCustNo > 0 AND StrToNumberXNullNull( sCSVFields[0] ) = nFromCustNo
										Set bPrint = TRUE
								!
								If bPrint
									Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
									Call SalTblSetContext( hWndForm, nRow )
									!
									Set colCustNo =  StrToNumberXNullNull( sCSVFields[0] )
									Set colCustName = sCSVFields[1]
									Set colBusName = sCSVFields[2]
									Set colAreaCode = sCSVFields[3]
									Set colPhone = sCSVFields[4]
									Set colAddressLine1 = sCSVFields[5]
									Set colAddressLine2 = sCSVFields[6]
									Set colSuburb = sCSVFields[7]
									Set colState = sCSVFields[8]
									Set colPostcode = sCSVFields[9]
									Set colRolloverDate =  SalStrToDate( sCSVFields[10] )
									Set colServiceCharge =  StrToNumberXNullNull( sCSVFields[11] )
									Set colDebtCollect = sCSVFields[12]
									Set colARNotes = sCSVFields[13]
									Set colReferenceId = sCSVFields[14]
									Set colTransDate =  SalStrToDate( sCSVFields[15] )
									Set colTransType = sCSVFields[16]
									Set colTransAmount =  StrToNumberXNullNull( sCSVFields[17] )
									Set colTransCode = sCSVFields[18]
									Set colTransAmountOutstand =  StrToNumberXNullNull( sCSVFields[19] )
									Set colDeposit =  SalStrToNumber( sCSVFields[20] )
									Set colOutstandDeposit =  StrToNumberXNullNull( sCSVFields[21] )
									Set colCustARBalance =  StrToNumberXNullNull( sCSVFields[22] )
									Set col0to30 =  StrToNumberXNullNull( sCSVFields[23] )
									Set col31to60 =  StrToNumberXNullNull( sCSVFields[24] )
									Set col61to90 =  StrToNumberXNullNull( sCSVFields[25] )
									Set col91plus =  StrToNumberXNullNull( sCSVFields[26] )
									Set colTotalARAtStart =  StrToNumberXNullNull( sCSVFields[27] )
									Set colTransCancelled =  sCSVFields[28]
								! the size of the row
								Set nFileCurrRow = nFileCurrRow + 251
								!
								Call SalSendMsg( hWndMeter, PAM_SETPROGRESS, 0, nFileCurrRow )
								Call SalUpdateWindow( SalParentWindow( hWndForm ) )
							Call fcTrialBalanceCSVFile.Close( )
							Call SalSendMsg( hWndMeter, PAM_END, 0, 0 )
							Return TRUE
						Else
							Call SalMessageBox( 'Please check if you ran a trial balance WITH statements before this report, before trying again.', 'Warning', MB_Ok )
							Return FALSE
			!
			Data Field: dfCustNo
				Class Child Ref Key: 0
				Class ChildKey: 0

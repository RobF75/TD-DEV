					Column: colCustNo
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Cust No
						Visible? Yes
						Editable? Yes
						Maximum Data Length: Default
						Data Type: Number
						Justify: Center
						Width:  0.888"
						Width Editable? Yes
						Format: #0
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL( wParam,hWndItem,'CUSTOMER_MASTER.CUST_NO' )
							On PAM_QBE
								If NOT SalIsNull( hWndItem )
									Call PushNumber( colCustNo )
									Call PushString( EQOPERAND )
									Call PushString( NUMERICFOLLOWING )
									Call PushString( 'CUSTOMER_MASTER.CUST_NO' )
									Return TRUE
							On PAM_CANORDERBY
								Call PushNumber( 1 )
								Call SalTblGetColumnTitle( hWndItem, sQueryTmpStr, 30 )
								Call PushString( sQueryTmpStr )
								Return TRUE
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, 0 )
							On PAM_EDITCHECK
								If NOT SalTblQueryRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_New )
									Call SalTblKillEdit( hWndForm )
					! order by customer.master.customer_name is by column number position becuase
							  the name can be upper and lower case.  The colCustName must stay at its current position
							  otherwise the order by will need to be adjusted.
					Column: colCustName
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Customer Name
						Visible? Yes
						Editable? Yes
						Maximum Data Length: 60
						Data Type: String
						Justify: Left
						Width:  3.938"
						Width Editable? Yes
						Format: Unformatted
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL( wParam,hWndItem,'CUSTOMER_MASTER.CUST_NAME' )
							On PAM_QBE
								If NOT SalIsNull( hWndItem )
									Set sQueryTmpStr = colCustName
									Call SalStrUpper( sQueryTmpStr, sQueryTmpStr )
									Call MyStrReplace( sQueryTmpStr, '\'', '_' )
									Set sQueryTmpStr = '%'||sQueryTmpStr||'%'
									Call PushString( sQueryTmpStr )
									Call PushString( LIKEOPERAND )
									Call PushString( STRINGFOLLOWING )
									Call PushString( '@UPPER(CUSTOMER_MASTER.CUST_NAME)' )
									Return TRUE
							On PAM_CANORDERBY
								Call PushNumber( 2 )
								Call SalTblGetColumnTitle( hWndItem, sQueryTmpStr, 30 )
								Call PushString( sQueryTmpStr )
								Return TRUE
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, 0 )
							On PAM_EDITCHECK
								If NOT SalTblQueryRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_New )
									Call SalTblKillEdit( hWndForm )

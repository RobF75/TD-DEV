				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						Call MyTableLoop( tblDepositsTable, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Deleting Payments', nLowToHiWithPositioning )
						Call SalSendMsg( tblDepositsTable, PAM_REPOPULATE, 0, 0 )
					On PAM_ROWACTION
						! Have commented out the following if date statement - as we are not deleting the payment we
								are only unapplying the payment from the deposit so it is allowable no matter when
						! If SalDateMonth( tblDepositsTable.colDepositPaidDate ) != SalDateMonth( SalDateCurrent(  ) )
							              Call SalMessageBox( 'Can NOT delete payment on this deposit as it is not in the current month!', 'Warning', MB_Ok )
							              Return TRUE
						If tblDepositsTable.colDepositAmtPaid > 0
							Call DeleteDepositPayment( tblDepositsTable.colDepositUserId, 
									tblDepositsTable.colDepositSysDT, 
									tblDepositsTable.colDepositAmtPaid, 
									tblDepositsTable.colReceiptUserId, 
									tblDepositsTable.colReceiptSysDT, nExecute )
						Else
							Call SalMessageBox( 'Can NOT delete payment on this deposit as it is not paid!', 'Warning', MB_Ok )
						Return TRUE
			Pushbutton: pbExit
				Class Child Ref Key: 3
				Class ChildKey: 0

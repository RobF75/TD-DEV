						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
			Pushbutton: pbRecalcAR
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title:
				Window Location and Size
					Left:   Default
					Top:    Default
					Width:  1.2"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? No
				Keyboard Accelerator: (none)
				Font Name: Default
				Font Size: Default
				Font Enhancement: Default
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						If IDOK = SalMessageBox( 'Are you sure you wish to recalculate the AR Balance for 
								the selected customers??  ',
								 'Recalc AR', MB_OkCancel )
							Select Case nWhichTableActive
								Case nCustomerTbl
									If NOT SalTblAnyRows( tblQCustomer, ROW_Selected, 0 )
										Call SalMessageBox( 'No Customer selected', 'Query Customer', MB_Ok )
										Return FALSE
									Call SalWaitCursor( TRUE )
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblQCustomer, nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( tblQCustomer, nRow )
										If NOT RecalcAR( hSqlAR0Hdl, bHdlAR0Connected, bHdlAR0Prepared, hSqlARHdl, bHdlARConnected, bHdlARPrepared,hSqlUnHdl, bHdlUnConnected, bHdlUnPrepared, 'frmQCustomer.tblQCustomer.colCustNo', frmQCustomer.tblQCustomer.colCustNo )
											Call SalMessageBox( 'Error in recalculating customers AR Balance',
													 'Recalc AR', MB_Ok )
									Call SalSendMsg( tblQCustomer, PAM_REPOPULATE, 0, 0 )
									Break
								Case nCustAddrTbl
									If NOT SalTblAnyRows( tblQCustAddr, ROW_Selected, 0 )
										Call SalMessageBox( 'No Customer selected', 'Query Customer Address', MB_Ok )
										Return FALSE
									Call SalWaitCursor( TRUE )
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblQCustAddr, nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( tblQCustAddr, nRow )
										If NOT RecalcAR( hSqlAR0Hdl, bHdlAR0Connected, bHdlAR0Prepared, hSqlARHdl, bHdlARConnected, bHdlARPrepared,hSqlUnHdl, bHdlUnConnected, bHdlUnPrepared, 'frmQCustomer.tblQCustAddr.colCustNo', frmQCustomer.tblQCustAddr.colCustNo )
											Call SalMessageBox( 'Error in recalculating customers AR Balance',
													 'Recalc AR', MB_Ok )
									Call SalSendMsg( tblQCustAddr, PAM_REPOPULATE, 0, 0 )
									Break
								Case nCustContTbl
									If NOT SalTblAnyRows( tblQCustCont, ROW_Selected, 0 )
										Call SalMessageBox( 'No Customer selected', 'Query Customer Contacts', MB_Ok )
										Return FALSE
									Call SalWaitCursor( TRUE )
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblQCustCont, nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( tblQCustCont, nRow )
										If NOT RecalcAR( hSqlAR0Hdl, bHdlAR0Connected, bHdlAR0Prepared, hSqlARHdl, bHdlARConnected, bHdlARPrepared,hSqlUnHdl, bHdlUnConnected, bHdlUnPrepared, 'frmQCustomer.tblQCustCont.colCustNo', frmQCustomer.tblQCustCont.colCustNo )
											Call SalMessageBox( 'Error in recalculating customers AR Balance',
													 'Recalc AR', MB_Ok )
									Call SalSendMsg( tblQCustCont, PAM_REPOPULATE, 0, 0 )
							Call SalWaitCursor( FALSE )
					On PAM_ENABLE
						If wParam
							Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
						Else
							If lParam = nReturnToQCust
								Call SalPostMsg( pbQGeneral, SAM_Click, 0, 0 )
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )

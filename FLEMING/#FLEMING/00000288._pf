				Message Actions
		Functions
			Function: DeleteDepositPayment
				Description:
				Returns
					Boolean:
				Parameters
					String: sDepositUserId
					Date/Time: dtDepositSysDT
					Number: nDepAmountPaid
					String: sReceiptUserId
					Date/Time: dtReceiptSysDT
					Number: nActionType
				Static Variables
					: fcUpdtDepositHdl
						Class: hcSqlHandle
					: fcUpdtCashRecptHdl
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					!
					Number: nInd
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " UPDATE Cash_Receipt 
									SET 
									  Fully_Applied_Flag = 'N', 
									  Amount_Unapplied = Amount_Unapplied + :3 
									WHERE Receipt_User_Id = :1 AND Rcpt_Sysdatetime = :2 "
							Set sName = 'PAYDELCSH'
							Set sBind = ':sReceiptUserId, :dtReceiptSysDT, :nDepAmountPaid'
							Set sInto = ''
							Call fcUpdtDepositHdl.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcUpdtDepositHdl.hSqlHandle )
							!
							Set sSql = " UPDATE Outstand_Deposit 
									SET 
									  Receipt_User_Id = NULL, 
									  Rcpt_Sysdatetime = NULL, 
									  Dep_Amount_Paid = NULL, 
									  Deposit_Paid_Date = NULL 
									WHERE 
									  Dep_User_Id = :1 AND 
									  Dep_sysdatetime = :2 "
							Set sName = 'PAYDELOTDEP'
							Set sBind = ':sDepositUserId, :dtDepositSysDT'
							Set sInto = ''
							Call fcUpdtCashRecptHdl.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcUpdtCashRecptHdl.hSqlHandle )
							!
							If nDepAmountPaid = NUMBER_Null
								Set nDepAmountPaid = 0
							!
							If fcUpdtDepositHdl.Execute( )
								If fcUpdtCashRecptHdl.Execute( )
									Call fcUpdtDepositHdl.Commit( )
									Call fcUpdtCashRecptHdl.Commit( )
									Return TRUE
								Else
									Call fcUpdtDepositHdl.Rollback( )
									Return FALSE
							Else
								Return FALSE
						Case nDisconnect
							Call fcUpdtDepositHdl.Disconnect( )
							Call fcUpdtCashRecptHdl.Disconnect( )
							Return TRUE
		Window Parameters
		Window Variables
		Message Actions
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
				Set bAddRowsAllowed = TRUE
				Set bSaveRowsAllowed = TRUE
				Set bDeleteRowsAllowed = TRUE
				Set bUnDeleteRowsAllowed = TRUE
				Set bOrderTableAllowed = TRUE
				Set bQueryTableAllowed = FALSE
			On PAM_POPFIELDS
				Call PopNumber( dfCustNo, TRUE )
				Call PopString( dfCustName, TRUE )
			On SAM_CreateComplete
				Call SalHideWindow( SalParentWindow( hWndForm ) )
			On SAM_Destroy
				Call DeleteDepositPayment( '', DATETIME_Null, 0, '', DATETIME_Null, nDisconnect )
				Call SalShowWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
	!

			String: sRepInto
			String: sRepBind
			String: sReportFile
			Number: nError
			Number: nInd
			Number: nNextAction
			String: sSql
			Number: nHistRow
			Number: nTransRow
			Number: nTempRow
			Boolean: bProcessHist
			Boolean: bProcessTrans
			!
			!
			Sql Handle: hSqlFCHandle
			Boolean: bFCHdlConnected
			Boolean: bFCHdlPrepared
			Sql Handle: hSqlRPHandle
			Boolean: bRPHdlConnected
			Boolean: bRPHdlPrepared
			Sql Handle: hSqlNMHandle
			Boolean: bNMHdlConnected
			Boolean: bNMHdlPrepared
			Sql Handle: hSqlHPHandle
			Boolean: bHPHdlConnected
			Boolean: bHPHdlPrepared
		Message Actions
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
			On SAM_CreateComplete
				Call SalWaitCursor( TRUE )
				! Call SalHideWindow( hWndForm )
				Set dfReportFromDate = dtFromDate
				Set dfReportToDate = dtToDate
				Call SalSendMsgToChildren( hWndForm, PAM_POPULATE, 0, 0 )
				Call SalSendMsg( hWndForm, PAM_PRINT, 0, 0 )
				Call SalWaitCursor( FALSE )
			On PAM_PRINT
				Call SalWaitCursor( TRUE )
				Call CallBuildSql( hWndForm, nSELECT, PAM_CUSTFIELDS, '', '' )
				Set sRepInto = sColumns
				Set sRepBind = sIntoVars
				Call CallBuildSql( tblCashApp, nSELECT, PAM_CUSTFIELDS, '', '' )
				Set sRepInto = sRepInto||','||sColumns
				Set sRepBind = sRepBind||','||sIntoVars
				Set sReportFile = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\cashapp.qrp'
				! Set sReportFile = 'g:\\apps\\gupta\\reports\\cashapp.qrp'
				Set nError = 1
				Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, RPT_PrintAll,0,0, nError )
			On SAM_ReportStart
				Set nTransRow = TBL_MinRow
				Return TRUE
			On SAM_ReportFetchInit
				Set nTransRow = TBL_MinRow
				Return TRUE
			On SAM_ReportFetchNext
				Loop
					If SalTblFindNextRow( tblCashApp, nTransRow, 0, 0 )
						Set nNextAction = nProcess
						Call SalTblFetchRow( tblCashApp, nTransRow )
						If tblCashApp.colTransUserCred = '' 
							If tblCashApp.colTransHUserCred = ''
								If tblCashApp.colRcptDate = tblCashApp.colAppDate
									Set nNextAction = nSkip
								Else
									Set nNextAction = nProcess
								! Then we want to skip it as it was not the case of applying unapplied cash - which are the only instances
										in this report that we want
							Else
								Set nNextAction = nProcess
						Else
							Set nNextAction = nProcess
					Else
						Set nNextAction = nStop
					If nNextAction = nProcess
						Return TRUE
					Else If nNextAction = nStop
						Break
				! While SalTblFindNextRow( tblCashApp, nTransRow, 0, 0 )
					              Call SalTblFetchRow( tblCashApp, nTransRow )
					              Return TRUE
				! Return FALSE
				!
				Return FALSE
			On SAM_ReportFinish
				Call SalPostMsg( pbExit, SAM_Click, 0, 0 )
				Call SalWaitCursor( FALSE )
				Return TRUE
	!

							On PAM_COLOURRESET
								Call SalTblSetCellTextColor( hWndItem, COLOR_Default, TRUE )
							On PAM_ROWNEW
								If wParam
									Set colType = 'DEBIT'
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On SAM_SetFocus
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On PAM_EDITCHECK
								If NOT SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
									Call SalTblKillEdit( hWndForm )
								Else
									Call TransTypeColPop( hWndItem, nExecute )
							On SAM_Validate
								Call GetTransCode( colType, colTransCode, nExecute )
								Return VALIDATE_Ok
							On PAM_DATAVAL
								If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
									If colType = 'INVOICE'
										Call SalMessageBox( 'You cannot enter an Invoice transaction.  Use Debit instead', 'Error', MB_Ok )
										Return FALSE
									Else
										Return TRUE
								Else
									Return TRUE

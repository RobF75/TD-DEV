		Functions
			Function: GetCustMasterDetails
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Number: nActionType
				Static Variables
					! Sql Handle: hSqlHandle
					! Boolean: bHandleConnected
					! Boolean: bHandlePrepared
				Local variables
					String: sSql
					String: sWhere
					String: sTables
					Number: nInd
					Number: nSqlHandleNo
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetCustMasterDetails' )
					Select Case nActionType
						Case nExecute
							Set sSql = sgSql
							Set sTables = ' Customer_Master, CUST_ARNOTES '
							Set sWhere = ' WHERE Customer_Master.Cust_No = :nCustNo '
							Call CallBuildSql( hWndForm, nSELECT, PAM_CUSTDETAILS, sTables, sWhere )
							Set sSql = sgSql
							!
							Call haSqlHandles[ nSqlHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							If haSqlHandles[nSqlHandleNo ].PrepareAndExecute( )
								If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									Return TRUE
								Else
									Return FALSE
							Else
								Return FALSE
						Case nDisconnect
							Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
							Return TRUE
			!
			Function: GetCustProcessedDetails
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Receive Boolean: bSkipCust
					Number: nActionType
				Static Variables
				Local variables
				Actions
					Set bSkipCust = FALSE
					If nActionType = nSelectedCustomers
						Call GetCustMasterDetails( nCustNo, nExecute )
					If dfParentCust != NUMBER_Null
						Call GetParentCust( dfParentCust, bSkipCust, nExecute )
						If bSkipCust
							! no point  doing any more file access
							Return TRUE
					Call GetBusAddressHdlNewLogic( nCustNo, hWndForm, PAM_BUSADDRFIELDS, nExecute )
					Return TRUE
			Function: AdjustCustTotal
				Description:
				Returns
					Boolean:
				Parameters
					Receive Number: nCustTotal
					Receive Number: nTransAmount
					String: sTransCode
					String: sTransType
					Long String: sTransNotes
				Static Variables
				Local variables
				Actions
					If sTransCode = 'DR'
						Set nCustTotal = nCustTotal + nTransAmount
					Else If sTransCode = 'CR'
						If sTransType = 'INVOICE'
							If sTransNotes = 'Uninvoiced' OR sTransNotes = 'CANCELLED'
								Set nTransAmount = nTransAmount * -1
							! If sTransNotes = 'Uninvoiced'
								              Set nTransAmount = nTransAmount * -1
							Set nCustTotal = nCustTotal + nTransAmount
						Else
							Set nCustTotal = nCustTotal - nTransAmount
							Set nTransAmount = nTransAmount * -1
					Return TRUE
			!
			Function: UpdateCashAppRollTrans
				Description:
				Returns
					Boolean:
				Parameters
					String: sApplicUserId
					Date/Time: dtApplicSysdatetime
					String: sTransUserId
					Date/Time: dtTransSysdatetime
					String: sTransCreditUserId
					Date/Time: dtTransCreditSysdatetime
					!
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sName
					String: sBind
					String: sInto
					Number: nInd
					Boolean: bOk
					String: sHistTransUserId
					Date/Time: dtHistTransSysDt
					String: sHistCredUserId
					Date/Time: dtHistCredSysDt
					Boolean: bUpdCRDR
					Number: nSqlHandleNoCR
					Number: nSqlHandleNoDR
				Actions
					Set nSqlHandleNoCR = SqlHandlesGetReferenceNo( 'UpdateCashAppRollTransCR' )
					Set nSqlHandleNoDR = SqlHandlesGetReferenceNo( 'UpdateCashAppRollTransDR' )
					Select Case nActionType
						Case nExecute
							Set sSql = " UPDATE Cash_Application
									 SET 
									 Trans_User_Id_Cred = :3,
									 Trans_Sysdate_Cred = :4,
									 Trans_H_UserCred = :5,
									 Trans_H_dateCred = :6,
									 Trans_User_Id = :7, 
									 Trans_Sysdatetime = :8, 
									 Trans_Hist_User_Id = :9,
									 Trans_Hist_Sysdate =  :10    
									WHERE Applic_User_Id = :1 AND 
									  Applic_Sysdatetime = :2 "
							Set sName = 'UCshAppCR'
							Set sBind = ':sApplicUserId, :dtApplicSysdatetime, :sTransCreditUserId,  :dtTransCreditSysdatetime,
									:sHistCredUserId, :dtHistCredSysDt, :sTransUserId,  :dtTransSysdatetime,  :sHistTransUserId, :dtHistTransSysDt'
							Set sInto = ''
							!
							Call haSqlHandles[ nSqlHandleNoCR ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoCR ].hSqlHandle )
							!
							Set sSql = " UPDATE Cash_Application
									 SET Trans_User_Id = :3, 
									  Trans_Sysdatetime = :4,
									  Trans_Hist_User_Id = :5,
									  Trans_Hist_Sysdate = :6 
									WHERE Applic_User_Id = :1 AND 
									  Applic_Sysdatetime = :2 "
							Set sName = 'UCshAppDR'
							Set sBind = ':sApplicUserId, :dtApplicSysdatetime,  :sTransUserId,  :dtTransSysdatetime,
									  :sHistTransUserId, :dtHistTransSysDt'
							Set sInto = ''
							Call haSqlHandles[ nSqlHandleNoDR ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoDR ].hSqlHandle )
							! !
							Set bUpdCRDR = FALSE
							!
							If sTransCreditUserId != ''
								Set sHistCredUserId = sTransCreditUserId
								Set sTransCreditUserId = ''
								Set dtHistCredSysDt = dtTransCreditSysdatetime
								Set dtTransCreditSysdatetime = DATETIME_Null
								Set bUpdCRDR = TRUE
							Set sHistTransUserId = sTransUserId
							Set sTransUserId = ''
							Set dtHistTransSysDt = dtTransSysdatetime
							Set dtTransSysdatetime = DATETIME_Null
							!
							If bUpdCRDR
								If haSqlHandles[ nSqlHandleNoCR ].Execute( )
									Return TRUE
								Else
									Return FALSE
							Else
								If haSqlHandles[ nSqlHandleNoDR ].Execute( )
									Return TRUE
								Else
									Return FALSE
						Case nDisconnect
							Call haSqlHandles[ nSqlHandleNoCR ].Disconnect( )
							Call haSqlHandles[ nSqlHandleNoDR ].Disconnect( )
							Return TRUE
						Case nCommit
							Set bOk = TRUE
							Call haSqlHandles[ nSqlHandleNoCR ].Commit( )
							Call haSqlHandles[ nSqlHandleNoDR ].Commit( )
							Return bOk
						Case nRollback
							Set bOk = TRUE
							Call haSqlHandles[ nSqlHandleNoCR ].Rollback( )
							Call haSqlHandles[ nSqlHandleNoDR ].Rollback( )
							Return bOk
						Case nRePrepare
							Call haSqlHandles[ nSqlHandleNoCR ].RePrepare( )
							Call haSqlHandles[ nSqlHandleNoDR ].RePrepare( )
							Return TRUE
			Function: DeleteTransaction
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					String: sTransUserId
					Date/Time: dtTransSysDT
					!
					Number: nActionType
				Static Variables
				Local variables

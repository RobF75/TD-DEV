			Number: nNoInv
		Window Variables
			Window Handle: hWndPushButton
		Message Actions
			On SAM_CreateComplete
				Call PopWndHdl( hWndPushButton, TRUE )
				Set dfTotRail = nTotRail
				Set dfTotPostal = nTotPostal
				Set dfTotFreight = nTotFreight
				Set dfTotLabels = nTotLabels
				Set dfTotDeposits = nTotDeposits
				Set dfTotRoyalties = nTotRoyalties
				Set dfTotInvoices = nTotInvoices

							! On PAM_COPYROWINFOTO
								              Call SalTblFetchRow( hWndForm, lParam )
								              Select Case wParam
									              Case DT_DateTime
										              Set colWhere = dtTemp
										              Break 
									              Case DT_Number
										              Set colWhere = nTemp

								Status Text:
								Menu Settings
									Enabled when:
									Checked when:
								Menu Actions
									Call SalWaitCursor( TRUE )
									If SalModalDialog( dlgNewGetDate, hWndForm )
										Call PopDateTime( dtRolloverDate, TRUE )
										Set dtFromDate = SalDateConstruct( SalDateYear( dtRolloverDate ), SalDateMonth( dtRolloverDate ), 1, 0, 0, 0 )
										Call SalCreateWindow( frmPrintInvSummary, hWndForm,  dtFromDate, dtRolloverDate, FALSE )
									Call SalWaitCursor( FALSE )

			Pushbutton: pbDetails
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Details - F2
				Window Location and Size
					Left:   1.613"
					Top:    4.271"
					Width:  1.325"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: F2
				Font Name: Default
				Font Size: Default
				Font Enhancement: Default
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						Select Case nWhichTableActive
							Case nCustomerTbl
								If NOT SalTblAnyRows( tblQCustomer, ROW_Selected, 0 )
									Call SalMessageBox( 'No Customer selected', 'Query Customer', MB_Ok )
									Return FALSE
								Call SalWaitCursor( TRUE )
								Set nRow = TBL_MinRow
								Call SalTblFindNextRow( tblQCustomer, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblQCustomer, nRow )
								Call SalSendMsg( hWndItem, PAM_SENDDATATOCHILD, 0, 0 )
								Call PushWndHdl ( hWndItem)
								Call PushWndHdl( tblQCustomer )
								Call SalDisableWindow ( hWndItem ) 
								Call SalCreateWindow( frmCustTab, hWndForm )
								Break
							Case nCustAddrTbl
								If NOT SalTblAnyRows( tblQCustAddr, ROW_Selected, 0 )
									Call SalMessageBox( 'No Customer selected', 'Query Customer Address', MB_Ok )
									Return FALSE
								Call SalWaitCursor( TRUE )
								Set nRow = TBL_MinRow
								Call SalTblFindNextRow( tblQCustAddr, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblQCustAddr, nRow )
								Call SalSendMsg( hWndItem, PAM_SENDDATATOCHILD, 0, 0 )
								Call PushWndHdl ( hWndItem)
								Call PushWndHdl( tblQCustAddr )
								Call SalDisableWindow ( hWndItem ) 
								Call SalCreateWindow( frmCustTab, hWndForm )
								Break
							Case nCustContTbl
								If NOT SalTblAnyRows( tblQCustCont, ROW_Selected, 0 )
									Call SalMessageBox( 'No Customer selected', 'Query Customer Contacts', MB_Ok )
									Return FALSE
								Call SalWaitCursor( TRUE )
								Set nRow = TBL_MinRow
								Call SalTblFindNextRow( tblQCustCont, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblQCustCont, nRow )
								Call SalSendMsg( hWndItem, PAM_SENDDATATOCHILD, 0, 0 )
								Call PushWndHdl ( hWndItem)
								Call PushWndHdl( tblQCustCont )
								Call SalDisableWindow ( hWndItem ) 
								Call SalCreateWindow( frmCustTab, hWndForm )
					On PAM_ENABLE
						If wParam
							Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
						Else
							If lParam = nReturnToQCust
								Call SalPostMsg( pbQGeneral, SAM_Click, 0, 0 )
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
					On PAM_SENDDATATOCHILD
						Select Case nWhichTableActive
							Case nCustomerTbl
								Call PushNumber( frmQCustomer.tblQCustomer.colCustNo )
								Call PushNumber( PAM_DETREC )
								Return TRUE
							Case nCustAddrTbl
								Call PushNumber( frmQCustomer.tblQCustAddr.colCustNo )
								Call PushNumber( PAM_DETREC )
								Return TRUE
							Case nCustContTbl
								Call PushNumber( frmQCustomer.tblQCustCont.colCustNo )
								Call PushNumber( PAM_DETREC )
								Return TRUE
					On PAM_QUERYDISABLE
						If wParam
							Call SalDisableWindow( hWndItem )
						Else
							Call SalEnableWindow( hWndItem )
			Pushbutton: pbAdd
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Add Cust.
				Window Location and Size
					Left:   2.938"

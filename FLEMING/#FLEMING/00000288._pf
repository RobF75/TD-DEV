									Enabled when:
									Checked when:
								Menu Actions
									! If SqlDatabase = 'STOCKDEV'
										              Call SalLoadApp( 'CRNOTED.EXE', SqlDatabase||' '||SqlUser||' '||SqlPassword )
									! Else
										              Call SalLoadApp( 'CRNOTE.EXE', SqlDatabase||' '||SqlUser||' '||SqlPassword )
									Call SalLoadApp( OurGetIniFileParameter( 'ACCOUNTS', 'CreditNoteListing', '' ), SqlDatabase||' '||SqlUser||' '||SqlPassword )
								Menu Item Name:

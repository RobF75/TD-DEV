			Popup Menu: &Month End
				Resource Id: 13727
				Enabled when:
				Status Text:
				Menu Item Name:
				Popup Menu: Month &End
					Resource Id: 59493
					Enabled when:
					Status Text:
					Menu Item Name:
					Popup Menu: &Fleming's Month End
						Resource Id: 59494
						Enabled when:
						Status Text:
						Menu Item Name:
						Menu Item: &Add Service Charges
							Resource Id: 59495
							Keyboard Accelerator: (none)
							Status Text:
							Menu Settings
								Enabled when:
								Checked when: nMonthEndType = nCalcSvcChg OR nMonthEndType = nPrintTrialBalSt OR 
										nMonthEndType = nRolloverZeroCust
							Menu Actions
								Call SalWaitCursor( TRUE )
								If SalModalDialog( dlgNewGetDate, hWndForm )
									Call PopDateTime( dtRolloverDate, TRUE )
									Call SalCreateWindow( frmPrintTrialBalance, hWndForm, nCustNos, 0, dtRolloverDate, nCalcSvcChg, nAllCustomers, bSummaryTB )
									Set nMonthEndType = nCalcSvcChg
								! If SalModalDialog( dlgGetDate, hWndForm, 'Rollover Date', DATETIME_Null )
									              Call PopDateTime( dtRolloverDate, TRUE )
									              Call SalCreateWindow( frmPrintTrialBalance, hWndForm, nCustNos, 0, dtRolloverDate, nCalcSvcChg, nAllCustomers )
									              Set nMonthEndType = nCalcSvcChg
								Call SalWaitCursor( FALSE )
							Menu Item Name:
						Menu Item: &Print Trial Balance & Statements
							Resource Id: 59496
							Keyboard Accelerator: (none)
							Status Text:
							Menu Settings
								Enabled when:
								Checked when: nMonthEndType = nPrintTrialBalSt OR nMonthEndType = nRolloverZeroCust
							Menu Actions
								Call SalWaitCursor( TRUE )
								Set bSummaryTB = FALSE
								Set nTBType = nSelectedCustomers
								Set nNumCust = 0
								Set nRow = TBL_MinRow
								Select Case nWhichTableActive
									Case nCustomerTbl
										If NOT SalTblAnyRows( tblQCustomer, ROW_Selected, 0 )
											Set nTBType = nAllCustomers
										Else
											While SalTblFindNextRow( tblQCustomer, nRow, ROW_Selected, 0 )
												Call SalTblFetchRow( tblQCustomer, nRow )
												Set nNumCust = nNumCust + 1
												Set nCustNos[nNumCust-1] = tblQCustomer.colCustNo
											Set nCustNos[nNumCust] = NUMBER_Null
										Break
									Case nCustAddrTbl
										If NOT SalTblAnyRows( tblQCustAddr, ROW_Selected, 0 )
											Set nTBType = nAllCustomers
										Else
											While SalTblFindNextRow( tblQCustAddr, nRow, ROW_Selected, 0 )
												Call SalTblFetchRow( tblQCustAddr, nRow )
												Set nNumCust = nNumCust + 1
												Set nCustNos[nNumCust-1] = tblQCustAddr.colCustNo
											Set nCustNos[nNumCust] = NUMBER_Null
										Break
									Case nCustContTbl
										If NOT SalTblAnyRows( tblQCustCont, ROW_Selected, 0 )
											Set nTBType = nAllCustomers
										Else
											While SalTblFindNextRow( tblQCustCont, nRow, ROW_Selected, 0 )
												Call SalTblFetchRow( tblQCustCont, nRow )
												Set nNumCust = nNumCust + 1
												Set nCustNos[nNumCust-1] = tblQCustCont.colCustNo
											Set nCustNos[nNumCust] = NUMBER_Null
								If SalModalDialog( dlgNewGetDateSelect, hWndForm, nTBType )
									If nTBType = nSelectedCustomers
										If IDNO =  SalMessageBox( 'You will be unable to update the monthly AR table for the selected customers option.  
												 Do you wish to continue?', 'Month End', MB_YesNo )
											Call SalWaitCursor( FALSE )
										Else
											Call PopDateTime( dtRolloverDate, TRUE )
											Call SalCreateWindow( frmPrintTrialBalance, hWndForm, nCustNos, nNumCust, dtRolloverDate, nPrintTrialBalSt, nTBType, bSummaryTB )
									Else
										Call PopDateTime( dtRolloverDate, TRUE )
										Call SalCreateWindow( frmPrintTrialBalance, hWndForm, nCustNos, nNumCust, dtRolloverDate, nPrintTrialBalSt, nTBType, bSummaryTB )
								Call SalWaitCursor( FALSE )
							Menu Item Name:

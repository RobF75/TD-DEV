			Data Field: dfCustARBalance
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Data
					Maximum Data Length: Default
					Data Type: Number
					Editable? Yes
				Display Settings
					Window Location and Size
						Left:   Default
						Top:    Default
						Width:  Default
						Width Editable? Yes
						Height: Default
						Height Editable? Yes
					Visible? No
					Border? Yes
					Justify: Left
					Format: Unformatted
					Country: Default
					Font Name: Default
					Font Size: Default
					Font Enhancement: Default
					Text Color: Default
					Background Color: Default
					Input Mask: Unformatted
				Message Actions
					On PAM_UPDATECUST
						Call SalSetFieldEdit( hWndItem, TRUE )
						Call BuildSQL( wParam,hWndItem,'CUSTOMER_MASTER.CUST_AR_BALANCE' )
					! Adjustarbalance is sent to this field on a row new in tbltransaction so colTransAmount
							does apply whereas in all other instances we should be checking if something 
							exists in colAmtOuts
					On PAM_ADJUSTARBALANCE
						If GetCustARBalance( dfCustNo, dfCustARBalance, nExecute )
							If wParam = nDR
								Set dfCustARBalance = dfCustARBalance + hWndForm.nTransAmount
							Else If wParam = nCR
								Set dfCustARBalance = dfCustARBalance - hWndForm.nTransAmount
							Return TRUE
						Else
							Return FALSE
					On PAM_ADJUSTARBALANCEWROFF
						! If wParam = nDR
							              Set dfCustARBalance = dfCustARBalance + hWndForm.nTransAmount
						If GetCustARBalance( dfCustNo, dfCustARBalance, nExecute )
							If wParam = nCR
								If frmTransaction.tblTransaction.colAmtOuts > 0
									Set dfCustARBalance = dfCustARBalance - frmTransaction.tblTransaction.colAmtOuts
								Else
									Set dfCustARBalance = dfCustARBalance - frmTransaction.tblTransaction.colTransAmount
							Return TRUE

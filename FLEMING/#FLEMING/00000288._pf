		Functions
		Window Parameters
		Window Variables
			String: sReceiptUserId
			Date/Time: dtReceiptSysDT
		Message Actions
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
				Set bAddRowsAllowed = FALSE
				Set bSaveRowsAllowed = FALSE
				Set bDeleteRowsAllowed = FALSE
				Set bUnDeleteRowsAllowed = FALSE
				Set bOrderTableAllowed = FALSE
				Set bQueryTableAllowed = FALSE
			On PAM_POPFIELDS
				Call PopString( sReceiptUserId, TRUE )
				Call PopDateTime( dtReceiptSysDT, TRUE )
				Call PopNumber( dfCustNo, TRUE )
				Call PopString( dfCustName, TRUE )
				Call PopDateTime( dfReceiptDate, TRUE )
				Call PopString( dfReceiptType, TRUE )
				Call PopNumber( dfReceiptAmount, TRUE )
				Call PopNumber( dfUnAppliedAmount, TRUE )
			On SAM_Destroy
				Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
	!

								Resource Id: 59486
								Keyboard Accelerator: (none)
								Status Text:
								Menu Settings
									Enabled when:
									Checked when:
								Menu Actions
									! If SqlDatabase = 'STOCKDEV'
										              Call SalLoadApp( 'g:\\apps\\gupta\\flemdev\\DEPSUSED.EXE', SqlDatabase||' '||SqlUser||' '||SqlPassword )
									! Else
										              Call SalLoadApp( 'g:\\apps\\gupta\\flemlive\\DEPSUSE.EXE', SqlDatabase||' '||SqlUser||' '||SqlPassword )
									Call SalLoadApp( OurGetIniFileParameter( 'ACCOUNTS', 'DepositsUsedListing', '' ), SqlDatabase||' '||SqlUser||' '||SqlPassword )

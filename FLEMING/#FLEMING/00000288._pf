					Menu Item Name:
				Menu Separator
				Menu Item: Transaction &Ledger 
					Resource Id: 8038
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when:
						Checked when:
					Menu Actions
						If NOT SalModalDialog( dlgGetSummaryDates, hWndForm )
							Return FALSE
						Call PopDateTime( dtToDate, TRUE )
						Call PopDateTime( dtFromDate, TRUE )
						Select Case nWhichTableActive
							Case nCustomerTbl
								Set hWndCurrentTable = tblQCustomer
								Break
							Case nCustAddrTbl
								Set hWndCurrentTable = tblQCustAddr
								Break
							Case nCustContTbl
								Set hWndCurrentTable = tblQCustCont
						If hWndCurrentTable.colParent != NUMBER_Null
							If IDYES = SalMessageBox( 'This Customer is a child of another.   Would you like to do a ledger for the parent instead?', 'Child has parent', MB_YesNo )
								Set hWndCurrentTable.colCustNo = hWndCurrentTable.colParent
						!
						Set sParameterLine = SqlDatabase || ' ' || SqlUser || ' ' || SqlPassword || ' ' || SalNumberToStrX( hWndCurrentTable.colCustNo, 0 ) || ' ' || DateToStrX( dtFromDate ) || ' ' || DateToStrX( dtToDate )
						! If SqlDatabase = 'STOCK'
							              Call SalLoadApp( 'G:\\APPS\\GUPTA\\FLEMLIVE\\TRLEDGR.EXE', sParameterLine  )
						! Else
							              Call SalLoadApp( 'G:\\APPS\\GUPTA\\FLEMDEV\\TRLEDGRD.EXE', sParameterLine )
						Call SalLoadApp( OurGetIniFileParameter( 'ACCOUNTS', 'TransactionLedger', '' ), sParameterLine )

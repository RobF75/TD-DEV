										Return FALSE
									Call SalWaitCursor( TRUE )
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblQCustAddr, nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( tblQCustAddr, nRow )
										Call DeleteTransRecord( hSqlTransHdl, bHdlTransConnected, bHdlTransPrepared, 'frmQCustomer.tblQCustAddr.colCustNo' )
									Break

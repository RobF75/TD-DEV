			On SAM_Create
				Set sHelpFileName = ''
				Set bEdit = FALSE
				Call PopWndHdl( hWndTable, TRUE )
				Call PopWndHdl( hWndPushbutton, TRUE )
				! Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
			On SAM_CreateComplete
				Call PopString( dfCustName, TRUE )
				Call PopNumber( dfCustNo, TRUE )
				Set dfCurrDate = SalDateCurrent(  )
				Call SalSendMsg( tblTransHistory, PAM_POPULATE, 0, 0 )
				Call SalSendMsg( tblHistoryTrans, PAM_POPULATE, 0, 0 )
				Call SalHideWindow( SalParentWindow( hWndForm ) )
			On SAM_Destroy
				Call SalShowWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				Call SalSendMsg( hWndPushbutton, PAM_ENABLE, bEdit, 0 )
			On SAM_Close
				Call SalWaitCursor( TRUE )

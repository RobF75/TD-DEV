			!
			Function: StrCSVTokenize
				Description:
				Returns
					Number:
				Parameters
					String: sCSVLine
					Receive String: sCSVFields[*]
				Static Variables
				Local variables
					Number: nFieldPos
					Number: nCharPos
					Number: nNumChars
					String: sField
					String: sPosChar
					Boolean: bQuoteOpen
				Actions
					Set nNumChars = SalStrLength( sCSVLine )
					Set nFieldPos = 0
					Set sCSVFields[ nFieldPos ] = ''
					Set nCharPos = 0
					Set sField = ''
					While nCharPos < nNumChars
						Set sPosChar = SalStrMidX( sCSVLine, nCharPos, 1 )
						!
						If sPosChar = '"'
							If bQuoteOpen
								Set bQuoteOpen = FALSE
							Else
								Set bQuoteOpen = TRUE
						Else If sPosChar = ',' AND NOT bQuoteOpen
							Set bQuoteOpen = FALSE
							Set sCSVFields[ nFieldPos ] = sField
							Set nFieldPos = nFieldPos + 1
							Set sCSVFields[ nFieldPos ] = ''
							Set sField = ''
						Else
							Set sField = sField || sPosChar
						Set nCharPos = nCharPos + 1
					Set sCSVFields[ nFieldPos ] = sField
					Set nFieldPos = nFieldPos + 1
					Set sCSVFields[ nFieldPos ] = ''
					Return nFieldPos
			!
			Function: ValidRegion
				Description: Validate the region entered, if selected then this isnt called as this
						is done from a sam-validate message
				Returns
					Boolean:
				Parameters
				Static Variables
				Local variables
				Actions
					Set sgSql = 'SELECT REGION_ID FROM REGION
							 WHERE REGION_ID = :hWndForm.dfRegion'
					If NOT RowIdExists( sgSql )
						Call SalMessageBox( 'Region entered does not exist. Please select a region
								from the list of valid regions', 'Customer Master', MB_Ok )
						Return FALSE
					Else
						Return TRUE
			Function: ValidCustType
				Description: Validate the customer type entered, if selected then this isnt called as this
						is done from a sam-validate message
				Returns
					Boolean:
				Parameters
				Static Variables
				Local variables
				Actions
					Set sgSql = 'SELECT CUST_TYPE FROM CUSTOMER_TYPE
							 WHERE CUST_TYPE = :hWndForm.dfCusttype'
					If NOT RowIdExists( sgSql )
						Call SalMessageBox( 'Customer Type entered does not exist. Please select
								 a Customer Type from the list of valid types', 'Customer Master', MB_Ok )
						Return FALSE
					Else
						Return TRUE
			Function: GetCustomerNo
				Description: Dependent on the postcode the user entered for the new customer
						use the first byte of the postcode to read the customer file for the last
						customer no used for that prefix 
				Returns
					Boolean:
				Parameters
				Static Variables
				Local variables
					Number: nLoCustno
					Number: nHiCustno
					Number: nInd
					String: sLoCustno
					String: sHiCustno
					Boolean: bLocalSqlNext
					Sql Handle: hLocalSqlNext
				Actions
					! LOCAL SQL HANDLE CONNECTION, DISCONNECT on exit pointS
					Set bLocalSqlNext = SqlConnect( hLocalSqlNext ) 
					If bLocalSqlNext
						Call SqlSetLockTimeout( hLocalSqlNext, SQLTIMEOUT )
					Else
						Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						Return FALSE
					!
					! At this point we know that the state for this customer has been selected
					If frmCustTab.cmbState = 'NT'
						Set nLoCustno = 080000
						Set nHiCustno = 099999 
					Else If frmCustTab.cmbState = 'NSW'
						Set nLoCustno = 200000
						Set nHiCustno = 299999
					Else If frmCustTab.cmbState = 'ACT'
						Set nLoCustno = 200000
						Set nHiCustno = 299999
					Else If frmCustTab.cmbState = 'VIC'
						Set nLoCustno = 300000
						Set nHiCustno = 399999
					Else If frmCustTab.cmbState = 'QLD'
						Set nLoCustno = 400000
						Set nHiCustno = 499999
					Else If frmCustTab.cmbState = 'SA'
						Set nLoCustno = 500000
						Set nHiCustno = 599999
					Else If frmCustTab.cmbState = 'WA'
						Set nLoCustno = 600000
						Set nHiCustno = 699999
					Else If frmCustTab.cmbState = 'TAS'
						Set nLoCustno = 700000
						Set nHiCustno = 799999
					Call SalNumberToStr( nLoCustno, 0, sLoCustno )
					Call SalNumberToStr( nHiCustno, 0, sHiCustno )
					Set sgSql = 'SELECT MAX( CUST_NO ) + 1 FROM CUSTOMER_MASTER 
							INTO :frmCustTab.dfCustno WHERE CUSTOMER_MASTER.CUST_NO  
							BETWEEN '||sLoCustno||' AND '||sHiCustno
					If SqlPrepare( hLocalSqlNext, sgSql )
						If SqlExecute( hLocalSqlNext )
							Call SqlFetchNext( hLocalSqlNext, nInd )
							If SalIsNull( frmCustTab.dfCustno )
								Set frmCustTab.dfCustno = nLoCustno
							Call SalSetFieldEdit( frmCustTab.dfCustno, TRUE )
							If bLocalSqlNext
								Call SqlDisconnect( hLocalSqlNext )
							Return TRUE
						Else
							Call SalMessageBox( 'Unable to read Customer Master File for 
									customer number.',
									 'Stock Item', MB_Ok )
							If bLocalSqlNext
								Call SqlDisconnect( hLocalSqlNext )
							Return FALSE
					Else
						Call SalMessageBox( 'Unable to read Customer Master File for 
								customer number.',
								 'Stock Item', MB_Ok )
						If bLocalSqlNext
							Call SqlDisconnect( hLocalSqlNext )
						Return FALSE
			Function: GetCustomerState
				Description: Depending on the customer number the user entered for the new 
						customer we preset the state that this number falls into.
				Returns
					Boolean:
				Parameters
				Static Variables
				Local variables
				Actions
					! At this point we know that a customer number been entered
					If frmCustTab.dfCustno >= 080000 AND frmCustTab.dfCustno <= 099999
						Set frmCustTab.cmbState = 'NT'
					Else If frmCustTab.dfCustno >= 200000 AND frmCustTab.dfCustno <= 299999
						Set frmCustTab.cmbState = 'NSW'
					Else If frmCustTab.dfCustno >= 300000 AND frmCustTab.dfCustno <= 399999
						Set frmCustTab.cmbState = 'VIC'
					Else If frmCustTab.dfCustno >= 400000 AND frmCustTab.dfCustno <= 499999
						Set frmCustTab.cmbState = 'QLD'
					Else If frmCustTab.dfCustno >= 500000 AND frmCustTab.dfCustno <= 599999
						Set frmCustTab.cmbState = 'SA'
					Else If frmCustTab.dfCustno >= 600000 AND frmCustTab.dfCustno <= 699999
						Set frmCustTab.cmbState = 'WA'
					Else If frmCustTab.dfCustno >= 700000 AND frmCustTab.dfCustno <= 799999
						Set frmCustTab.cmbState = 'TAS'
					Call SalSetFieldEdit( frmCustTab.cmbState, TRUE )
					Call SalSetFocus( frmCustTab.dfCustname)
			!
			! FUNCTIONS TO APPLY AND UNAPPLY TRANSACTIONS
			Function: ApplyTransRow
				Description:
				Returns
					Boolean:
				Parameters
					Number: nColTransAmount
					Receive Number: nColAmtOuts
					Number: nColAmtApply
					Receive Number: ndfStillToApply
					Receive Date/Time: dtColAppDate
					Receive Date/Time: dtApplyDate
					Receive Number: nTotalUnApplied
				Static Variables
				Local variables
					Number: nTmpAmtOuts
					Number: nTmpStillToApply
					Number: nTmpTotalUnApplied
				Actions
					Set nTmpAmtOuts = nColAmtOuts
					Set nTmpStillToApply = ndfStillToApply
					Set nTmpTotalUnApplied = nTotalUnApplied
					If DoTransApply( nColTransAmount, nTmpAmtOuts, nColAmtApply, nTmpStillToApply, nTmpTotalUnApplied )
						Set nColAmtOuts = nTmpAmtOuts
						Set ndfStillToApply = nTmpStillToApply
						Set nTotalUnApplied = nTmpTotalUnApplied
						If dtColAppDate = DATETIME_Null
							Set dtColAppDate = dtApplyDate
						Else
							Set dtApplyDate = dtColAppDate
						Return TRUE
					Else
						Return FALSE
			Function: DoTransApply
				Description: Apply logic, returns true if we havent over applied
				Returns
					Boolean:
				Parameters
					Number: nColTransAmount
					Receive Number: nColAmtOuts
					Number: nColAmtApply
					Receive Number: ndfStillToApply
					Receive Number: nTotalUnApplied
				Static Variables
				Local variables
				Actions
					If nColAmtApply > 0
						Set ndfStillToApply = ndfStillToApply - nColAmtApply
						Set nTotalUnApplied = nTotalUnApplied - nColAmtApply
						If nColAmtOuts > 0
							Set nColAmtOuts = nColAmtOuts - nColAmtApply
						Else
							Set nColAmtOuts = nColTransAmount - nColAmtApply
					Else
						If nColAmtOuts > 0
							Set ndfStillToApply = ndfStillToApply - nColAmtOuts
							Set nTotalUnApplied = nTotalUnApplied - nColAmtOuts
						Else
							Set ndfStillToApply = ndfStillToApply - nColTransAmount
							Set nTotalUnApplied = nTotalUnApplied - nColTransAmount
						Set nColAmtOuts = 0
					If ndfStillToApply >= 0
						Return TRUE
					Else
						Return FALSE
			Function: UnApplyTransRow
				Description:
				Returns
					Boolean:
				Parameters
					Number: nColTransAmount
					Receive Number: nColAmtOuts
					Number: nColOrgAmtOuts
					Receive Number: nColAmtApply
					Receive Number: ndfStillToApply
					Receive Date/Time: dtColAppDate
					Number: nAmtReceipt
					Receive Number: nTotalUnApplied
				Static Variables
				Local variables
					Number: nTmpAmtOuts
					Number: nTmpStillToApply
					Number: nTmpAmtApply
					Number: nTmpTotalUnApplied
				Actions
					Set nTmpAmtOuts = nColAmtOuts
					Set nTmpStillToApply = ndfStillToApply
					Set nTmpAmtApply = nColAmtApply
					Set nTmpTotalUnApplied = nTotalUnApplied
					If DoTransUnApply( nColTransAmount, nTmpAmtOuts, nColOrgAmtOuts, nTmpAmtApply, nTmpStillToApply, nAmtReceipt, nTmpTotalUnApplied )
						Set nColAmtOuts = nTmpAmtOuts
						Set ndfStillToApply = nTmpStillToApply
						Set nTotalUnApplied = nTmpTotalUnApplied
						Set nColAmtApply = nTmpAmtApply
						Set dtColAppDate = DATETIME_Null
						Return TRUE
					Else
						Return FALSE
			Function: DoTransUnApply
				Description: Apply logic, returns true if we havent over applied
				Returns
					Boolean:
				Parameters
					Number: nColTransAmount
					Receive Number: nColAmtOuts
					Number: nColOrgAmtOuts
					Receive Number: nColAmtApply
					Receive Number: ndfStillToApply
					Number: nAmtReceipt
					Receive Number: nTotalUnApplied
				Static Variables
				Local variables
				Actions
					If nColAmtApply > 0
						Set ndfStillToApply = ndfStillToApply + nColAmtApply
						Set nTotalUnApplied = nTotalUnApplied + nColAmtApply
						Set nColAmtOuts = nColAmtOuts + nColAmtApply
						Set nColAmtApply = NUMBER_Null
					Else
						If nColOrgAmtOuts > 0
							Set ndfStillToApply = ndfStillToApply + nColOrgAmtOuts
							Set nTotalUnApplied = nTotalUnApplied + nColOrgAmtOuts
							Set nColAmtOuts = nColOrgAmtOuts
						Else
							Set ndfStillToApply = ndfStillToApply + nColTransAmount
							Set nTotalUnApplied = nTotalUnApplied + nColTransAmount
							Set nColAmtOuts = nColTransAmount
					If ndfStillToApply <= nAmtReceipt
						Return TRUE
					Else
						Return FALSE
			!
			Function: GetTrialBalanceCSVFileName
				Description:
				Returns
					String:
				Parameters
					Date/Time: dtRolloverDate
				Static Variables
				Local variables
					String: sPath
				Actions
					Set sPath = OurGetIniFileParameter( 'ACCOUNTS', 'TBCSVPath', OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'c:\\temp' ) )
					Set sPath = sPath||'\\tb'|| SalStrRightX( SalNumberToStrX( SalDateYear( dtRolloverDate ), 0 ), 1 ) || SalNumberToStrX( 
							SalDateConstruct( SalDateYear( dtRolloverDate ), 
							SalDateMonth( dtRolloverDate ), SalDateDay( dtRolloverDate ), 0, 0, 0 ) - 
							SalDateConstruct( SalDateYear( dtRolloverDate ), 1, 1, 0, 0, 0 ), 0 )||'.csv'
					Return sPath
					! Return 'c:\\temp\\tb'|| SalNumberToStrX( 
							SalDateConstruct( SalDateYear( dtRolloverDate ), 
							SalDateMonth( dtRolloverDate ), SalDateDay( dtRolloverDate ), 0, 0, 0 ) - 
							SalDateConstruct( SalDateYear( dtRolloverDate ), 1, 1, 0, 0, 0 ), 0 )||'.csv'

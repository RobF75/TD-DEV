			Pushbutton: pbWriteOff
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Write Off Transaction
				Window Location and Size
					Left:   5.938"
					Top:    4.177"
					Width:  1.8"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: (none)
				Font Name: Default
				Font Size: Default
				Font Enhancement: Default
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						Call SalWaitCursor( TRUE )
						Call SalDisableWindow( hWndItem )
						If SalTblAnyRows( tblTransaction, ROW_Selected, 0 )
							Set nRow = TBL_MinRow
							While SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblTransaction, nRow )
								Call SalSendMsg( frmTransaction.tblTransaction.colWriteOff, PAM_EDITCHECK, 0, nRow )
						Else
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'No Transactions are selected!  Please rectify!', 'Warning', MB_Ok )
							Call SalWaitCursor( TRUE )
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
					On PAM_WRITEOFFRESTRICTIONS
						If SalSendMsg( frmTransaction.tblTransaction.colWriteOff, PAM_WRITEOFFRESTRICTIONS, 0, 0 )
							Call SalEnableWindow( hWndItem )
						Else
							Call SalDisableWindow( hWndItem )
			Pushbutton: pbApply
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: A&pply - F6
				Window Location and Size
					Left:   4.725"
					Top:    4.5"
					Width:  1.175"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: F6
				Font Name: Default
				Font Size: Default
				Font Enhancement: Default
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					! Need to adjust this code to be able to apply a credit trans to a debit trans
					On SAM_Click
						If SalTblAnyRows( tblTransaction, ROW_New, 0 )
							Call SalMessageBox( 'Please save any new transactions first, before trying to apply.', 'Warning', MB_Ok )
							Return FALSE
						!
						Set bUnApplied = TRUE
						If NOT MyTableAnyRows( tblUnAppCash, ROW_Selected, 0, nCount )
							If NOT MyTableAnyRows( tblTransaction, ROW_Selected, 0, nCount )
								Call SalMessageBox( 'A receipt amount must be selected to be applied against first! Please rectify!', 'Warning', MB_Ok )
								Return FALSE
							Set bUnApplied = FALSE
							Set nRow = TBL_MinRow
							Set bCRFound = FALSE
							Set bDRFound = FALSE
							Set bCompanyMatch = TRUE
							While SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblTransaction, nRow )
								If frmTransaction.tblTransaction.colApplied = 'Y'
									Call SalMessageBox( 'One has already been applied', 'Apply credit to debit', MB_Ok )
									Return FALSE
								If frmTransaction.tblTransaction.colAmtOuts = 0
									Call SalMessageBox( 'Cannot apply a line which has no amount outstanding', 'Transactions', MB_Ok )
									Return FALSE
								If tblTransaction.colTransCode = 'CR'
									If bCRFound
										Call SalMessageBox( 'Only one credit can be selected to manually apply.  Please adjust', 'Apply credit to debit', MB_Ok )
										Return FALSE
									Else
										Set bCRFound = TRUE
										Set nCRRow = nRow
										Set nAmtToCredit = frmTransaction.tblTransaction.colAmtOuts 
										Set sCRCompany = frmTransaction.tblTransaction.colTransCompany
								If tblTransaction.colTransCode = 'DR'
									If bDRFound
										Call SalMessageBox( 'Only one debit can be selected to manually apply.  Please adjust', 'Apply credit to debit', MB_Ok )
										Return FALSE
									Else
										If frmTransaction.tblTransaction.colTransCompany != sCRCompany
											Set bCompanyMatch = FALSE
										Set bDRFound = TRUE
										Set nDRRow = nRow
										If SalIsNull( frmTransaction.tblTransaction.colAmtApply) OR frmTransaction.tblTransaction.colAmtApply = 0
											Set frmTransaction.tblTransaction.colAmtApply = frmTransaction.tblTransaction.colAmtOuts
										Set nAmtToBeCredited = frmTransaction.tblTransaction.colAmtApply
							If NOT bDRFound
								Call SalMessageBox( 'Please select a debit to be applied', 'Apply debit to credit', MB_Ok )
								Return FALSE
							Else If NOT bCRFound
								Call SalMessageBox( 'Please select a credit to be applied', 'Apply debit to credit', MB_Ok )
								Set frmTransaction.tblTransaction.colAppDate = dtApplyDate
								Return FALSE
							Else If nAmtToBeCredited > nAmtToCredit
								Call SalMessageBox( 'The amount you have entered to apply is greater than
										 the amount of the credit.   Please correct', 'Apply debit to credit', MB_Ok )
								Return FALSE
							Else If NOT bCompanyMatch
								Call SalMessageBox('Credit Company must match Debit Company. Please Rectify.', 'Credit Application error', MB_Ok)
								Return FALSE
						Else If nCount > 1
							Call SalMessageBox( 'Only one receipt amount must be selected for any one apply! Please rectify!', 'Warning', MB_Ok )
							Return FALSE
						!
						Call SalWaitCursor( TRUE )
						Call SalDisableWindow( hWndItem )
						!
						Set nAppRow = TBL_MinRow
						Call SalTblFindNextRow( tblUnAppCash, nAppRow, ROW_Selected, 0 )
						If SalTblFetchRow( tblUnAppCash, nAppRow )
							Set sCRCompany = tblUnAppCash.colRcptCompany
						If bUnApplied
							Set bHaveAppliedRow = FALSE
							Set nOrgRow = SalTblQueryContext( tblTransaction )
							Set nRow = TBL_MinRow
							While SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblTransaction, nRow )
								If tblTransaction.colTransCompany != sCRCompany
									Call SalWaitCursor( FALSE )
									Call SalMessageBox('Unapplied Cash Company must match Trnsaction Company. Please rectify.', 'Error Applying Unapplied Cash to Transaction.', MB_Ok)
									Call SalEnableWindow( hWndItem )
									Return FALSE
								Call SalTblSetFocusRow( tblTransaction, nRow )
								If frmTransaction.tblTransaction.colApplied = 'N'
									!
									If SalIsNull( frmTransaction.tblTransaction.colAmtApply ) 
										Set frmTransaction.tblTransaction.colAmtApply = frmTransaction.tblTransaction.colAmtOuts
									If frmTransaction.tblTransaction.colTransCode = 'CR'
										Call SalMessageBox( 'Cannot apply a Credit', 'Transactions', MB_Ok )
									Else If frmTransaction.tblTransaction.colAmtOuts = 0
										Call SalMessageBox( 'Cannot apply a line which has no amount outstanding', 'Transactions', MB_Ok )
									Else If ApplyTransRow( frmTransaction.tblTransaction.colTransAmount, frmTransaction.tblTransaction.colAmtOuts, 
											  frmTransaction.tblTransaction.colAmtApply, frmTransaction.tblUnAppCash.colAmtUnApplied, frmTransaction.tblTransaction.colAppDate, 
											  dtApplyDate, dfTotalUnapplied )
										Set nTransRowsApplied = nTransRowsApplied + 1
										Set bHaveAppliedRow = TRUE
										Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
							! If bHaveAppliedRow
								              If SalTblFindNextRow( tblTransaction, nRow, 0, 0 )
									              Call SalTblFetchRow( tblTransaction, nRow )
									              Call SalTblSetRowFlags( tblTransaction, nRow, ROW_Selected, TRUE )
									              Call SalTblSetFocusRow( tblTransaction, nRow )
							! Else 
								              Call SalTblFetchRow( tblTransaction, nOrgRow )
								              Call SalTblSetFocusRow( tblTransaction, nOrgRow )
							If nTransRowsApplied > 0
								Set bEdit = TRUE
								Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, TRUE, 0 )
						Else
							Set bHaveAppliedRow = FALSE
							! Set nOrgRow = SalTblQueryContext( tblTransaction )
							Set nRow = TBL_MinRow
							! Have now found the DR and CR rows and have their row numbers
							Call SalTblFetchRow( frmTransaction.tblTransaction, nCRRow )
							Set nAmtCredit = frmTransaction.tblTransaction.colAmtOuts
							Set dfTotalUnapplied = frmTransaction.tblTransaction.colAmtOuts
							Call SalTblFetchRow( frmTransaction.tblTransaction, nDRRow )
							! Up to here - If the customer has unapplied cash it is using those values not the credit
							If ApplyTransRow( frmTransaction.tblTransaction.colTransAmount, frmTransaction.tblTransaction.colAmtOuts, 
									  frmTransaction.tblTransaction.colAmtApply, nAmtCredit, frmTransaction.tblTransaction.colAppDate, 
									  dtApplyDate, dfTotalUnapplied )
								Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nDRRow )
								Set nTransRowsApplied = nTransRowsApplied + 2
								Set bHaveAppliedRow = TRUE
								Call SalTblFetchRow( tblTransaction, nCRRow )
								Set tblTransaction.colAmtOuts = nAmtCredit
								Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nCRRow )
							If nTransRowsApplied > 0
								Set bEdit = TRUE
								Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, TRUE, 0 )
						!
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
					! On SAM_Click
						              If NOT MyTableAnyRows( tblUnAppCash, ROW_Selected, 0, nCount )
							              Call SalMessageBox( 'A receipt amount must be selected to be applied against first! Please rectify!', 'Warning', MB_Ok )
							              Return FALSE
						              Else If nCount > 1
							              Call SalMessageBox( 'Only one receipt amount must be selected for any one apply! Please rectify!', 'Warning', MB_Ok )
							              Return FALSE
						!
						              Call SalWaitCursor( TRUE )
						              Call SalDisableWindow( hWndItem )
						!
						              Set bHaveAppliedRow = FALSE
						              Set nOrgRow = SalTblQueryContext( tblTransaction )
						              Set nRow = TBL_MinRow
						              While SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
							              Call SalTblFetchRow( tblTransaction, nRow )
							              Call SalTblSetFocusRow( tblTransaction, nRow )
							              If frmTransaction.tblTransaction.colApplied = 'N'
								!
								              If frmTransaction.tblTransaction.colTransCode = 'CR'
									              Call SalMessageBox( 'Cannot apply a Credit', 'Transactions', MB_Ok )
								              Else If frmTransaction.tblTransaction.colAmtOuts = 0
									              Call SalMessageBox( 'Cannot apply a line which has no amount outstanding', 'Transactions', MB_Ok )
								              Else If ApplyTransRow( frmTransaction.tblTransaction.colTransAmount, frmTransaction.tblTransaction.colAmtOuts, 
										  frmTransaction.tblTransaction.colAmtApply, frmTransaction.tblUnAppCash.colAmtUnApplied, frmTransaction.tblTransaction.colAppDate, 
										  dtApplyDate, dfTotalUnapplied )
									              Set nTransRowsApplied = nTransRowsApplied + 1
									              Set bHaveAppliedRow = TRUE
									              Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, TRUE, nRow )
						! If bHaveAppliedRow
							              If SalTblFindNextRow( tblTransaction, nRow, 0, 0 )
								              Call SalTblFetchRow( tblTransaction, nRow )
								              Call SalTblSetRowFlags( tblTransaction, nRow, ROW_Selected, TRUE )
								              Call SalTblSetFocusRow( tblTransaction, nRow )
						! Else 
							              Call SalTblFetchRow( tblTransaction, nOrgRow )
							              Call SalTblSetFocusRow( tblTransaction, nOrgRow )
						              If nTransRowsApplied > 0
							              Set bEdit = TRUE
							              Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, TRUE, 0 )
						!
						              Call SalEnableWindow( hWndItem )
						              Call SalWaitCursor( FALSE )
			Pushbutton: pbAdd
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Add Transaction
				Window Location and Size
					Left:   5.938"
					Top:    4.5"
					Width:  1.8"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: (none)
				Font Name: Default
				Font Size: Default
				Font Enhancement: Default
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						Call SalWaitCursor( TRUE )
						Call SalDisableWindow( hWndItem )
						Call SalSendMsg( tblTransaction, PAM_ADDROW, 0, 0 )
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
			Pushbutton: pbUnApply
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &UnApply - F4
				Window Location and Size
					Left:   4.725"
					Top:    4.833"
					Width:  1.175"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: F4
				Font Name: Default
				Font Size: Default
				Font Enhancement: Default
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					! On SAM_Click
						              Call SalWaitCursor( TRUE )
						              Call SalDisableWindow( hWndItem )
						!
						              Set bHaveUnAppliedRow = FALSE
						              Set nOrgRow = SalTblQueryContext( tblTransaction )
						              Set nRow = TBL_MinRow
						              While SalTblFindNextRow( tblTransaction, nRow, ROW_Selected, 0 )
							              Call SalTblFetchRow( tblTransaction, nRow )
							              Call SalTblSetFocusRow( tblTransaction, nRow )
							              If frmTransaction.tblTransaction.colApplied = 'Y'
								              Call SalTblFetchRow( tblUnAppCash, frmTransaction.tblTransaction.colAppliedAgainstRow )
								              If UnApplyTransRow( frmTransaction.tblTransaction.colTransAmount, frmTransaction.tblTransaction.colAmtOuts,
										  frmTransaction.tblTransaction.colOrgAmtOuts, frmTransaction.tblTransaction.colAmtApply, 
										  frmTransaction.tblUnAppCash.colAmtUnApplied, frmTransaction.tblTransaction.colAppDate, 
										  frmTransaction.tblUnAppCash.colOrgAmtUnApplied, dfTotalUnapplied )
									              Set bHaveUnAppliedRow = TRUE
									              Set nTransRowsApplied = nTransRowsApplied - 1
									              Call SalSendMsg( tblTransaction, PAM_SETROWEDITFLAG, FALSE, nRow )
									              Set bEdit = TRUE
						              If bHaveUnAppliedRow
							              If SalTblFindNextRow( tblTransaction, nRow, 0, 0 )
								              Call SalTblFetchRow( tblTransaction, nRow )
								              Call SalTblSetRowFlags( tblTransaction, nRow, ROW_Selected, TRUE )
								              Call SalTblSetFocusRow( tblTransaction, nRow )
						              Else 
							              Call SalTblFetchRow( tblTransaction, nOrgRow )
							              Call SalTblSetFocusRow( tblTransaction, nOrgRow )
						!
						              If nTransRowsApplied <= 0
							              Set bEdit = FALSE
							              Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, FALSE, 0 )
						              Call SalEnableWindow( hWndItem )
						              Call SalWaitCursor( FALSE )
					On SAM_Click
						Call SalWaitCursor( TRUE )
						Call SalDisableWindow( hWndItem )
						!
						Set bEdit = FALSE
						Call SalSendMsg( tblTransaction, PAM_POPULATE, 0, 0 )
						Call SalSendMsg( tblUnAppCash, PAM_POPULATE, 0, 0 )
						!
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
			Pushbutton: pbSave
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Save Changes - F5
				Window Location and Size
					Left:   5.938"
					Top:    4.823"
					Width:  1.8"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? Yes
				Keyboard Accelerator: F5
				Font Name: Default
				Font Size: Default
				Font Enhancement: Default
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						Call SalWaitCursor( TRUE )
						Call SalDisableWindow( hWndItem )
						!
						Set nOrgTransRowsApplied = nTransRowsApplied
						Set bSaveOk = TRUE
						!
						If SalTblAnyRows( tblTransaction, ROW_New, 0 )
							If NOT MyTableDataVal( tblTransaction )
								Call SalEnableWindow( hWndItem )
								Call SalWaitCursor( FALSE )
								Return FALSE
							Set nRow = TBL_MinRow
							While SalTblFindNextRow( tblTransaction, nRow, ROW_New, 0 )
								Call SalTblFetchRow( tblTransaction, nRow )
								!
								If tblTransaction.colTransCode = 'DR'
									Set nTransAmount = tblTransaction.colTransAmount
									Set nTransCode = nDR
								Else If tblTransaction.colTransCode = 'CR'
									Set nTransAmount = tblTransaction.colTransAmount
									Set nTransCode = nCR
								!
								If SalSendMsg( dfCustARBalance, PAM_ADJUSTARBALANCE, nTransCode, 0 )
									If UpdateCustARBalRecord( ' CUSTOMER_MASTER ', ' WHERE Cust_No = :frmTransaction.dfCustNo ', hWndForm, PAM_UPDATECUST, 0, nExecute )
										If MyInsertRecord( frmTransaction.tblTransaction.hSqlInsTransHdl, 
												  frmTransaction.tblTransaction.bInsTransHdlConnected, 
												  frmTransaction.tblTransaction.bInsTransHdlPrepared, ' TRANSACTION ', 
												  tblTransaction, PAM_INSERTTRANS, PAM_SETTRANSVALUES )
											Call SalTblSetRowFlags( tblTransaction, nRow, ROW_Edited, FALSE )
										Else
											Set bSaveOk = FALSE
									Else
										Set bSaveOk = FALSE
								Else
									Set bSaveOk = FALSE
						!
						Set nCashRcptRow = TBL_MinRow
						While SalTblFindNextRow( tblUnAppCash, nCashRcptRow, 0, 0 )
							Call SalTblFetchRow( tblUnAppCash, nCashRcptRow )
							If frmTransaction.tblUnAppCash.colApplied = 'Y'
								If MyUpdateRecord( frmTransaction.tblUnAppCash.hSqlUpdtCshRcptHdl, frmTransaction.tblUnAppCash.bUpdtCshRcptHdlConnected, frmTransaction.tblUnAppCash.bUpdtCshRcptHdlPrepared, ' CASH_RECEIPT ', 
										frmTransaction.tblUnAppCash.sWHEREUpdtCshRcpt, tblUnAppCash, 
										PAM_UPDATECSHRCPT, PAM_SETCSHRCPTVALUES )
									!
									Set nTransAmount = tblUnAppCash.colOrgAmtUnApplied - tblUnAppCash.colAmtUnApplied
									Set nTransCode = nCR
									! The updating of a customers AR Balance is done when the cash receipt
											has been made - it doesnt need to be done here as well
									If nTransRowsApplied > 0
										Set nRow = TBL_MinRow
										While SalTblFindNextRow( tblTransaction, nRow, 0, 0 )
											Call SalTblFetchRow( tblTransaction, nRow )
											If frmTransaction.tblTransaction.colApplied = 'Y' AND frmTransaction.tblTransaction.colAppliedAgainstRow = nCashRcptRow
												!
												Call CheckForFinishedTrans( tblTransaction.colCustNo, 
														tblTransaction.colType, 
														tblTransaction.colTransCode, 
														tblTransaction.colAmtOuts, 
														tblTransaction.colOrgAmtOuts, 
														tblTransaction.colTransDate, 
														tblTransaction.colDaysToPay, nExecute )
												!
												If MyUpdateRecord( frmTransaction.tblTransaction.hSqlUpdtTransHdl, frmTransaction.tblTransaction.bUpdtTransHdlConnected, frmTransaction.tblTransaction.bUpdtTransHdlPrepared, ' TRANSACTION ', 
														frmTransaction.tblTransaction.sWHERETransaction, frmTransaction.tblTransaction, PAM_UPDATETRANSACTION, 0 )
													If UpdtCustDaysOfCredAvg( tblTransaction.colCustNo, nExecute )
														If MyInsertRecord( hSqlInsertCashAppHdl, bInsertCashAppHdlConnected, bInsertCashAppHdlPrepared, ' CASH_APPLICATION ', hWndForm, PAM_INSERTCASHAPP, PAM_SETCASHAPPVALUES )
															Set nTransRowsApplied = nTransRowsApplied - 1
														Else
															Set bSaveOk = FALSE
													Else
														Set bSaveOk = FALSE
												Else
													Set bSaveOk = FALSE
									Else
										Set bSaveOk = FALSE
								Else
									Set bSaveOk = FALSE
						! To do the next code it should be able to save the 2 transaction lines when we
								are manually applying a credit to a debit
						If NOT bUnApplied
							Call SalTblFetchRow( tblTransaction, nCRRow )
							Set frmTransaction.tblTransaction.dtCreditTransSysDt = frmTransaction.tblTransaction.colTransSysDT
							Set frmTransaction.tblTransaction.sCreditTransUserId = frmTransaction.tblTransaction.colTransUserId
							If frmTransaction.tblTransaction.colApplied = 'Y'
								If MyUpdateRecord( frmTransaction.tblTransaction.hSqlUpdtTransHdl, 
										frmTransaction.tblTransaction.bUpdtTransHdlConnected,
										 frmTransaction.tblTransaction.bUpdtTransHdlPrepared, ' TRANSACTION ', 
										frmTransaction.tblTransaction.sWHERETransaction, frmTransaction.tblTransaction,
										 PAM_UPDATETRANSACTION, 0 )
									Call SalTblFetchRow( tblTransaction, nDRRow )
									!
									Call CheckForFinishedTrans( tblTransaction.colCustNo, 
											tblTransaction.colType, 
											tblTransaction.colTransCode, 
											tblTransaction.colAmtOuts, 
											tblTransaction.colOrgAmtOuts, 
											tblTransaction.colTransDate, 
											tblTransaction.colDaysToPay, nExecute )
									!
									If MyUpdateRecord(  frmTransaction.tblTransaction.hSqlUpdtTransHdl, 
											frmTransaction.tblTransaction.bUpdtTransHdlConnected,
											 frmTransaction.tblTransaction.bUpdtTransHdlPrepared, ' TRANSACTION ', 
											frmTransaction.tblTransaction.sWHERETransaction, frmTransaction.tblTransaction,
											 PAM_UPDATETRANSACTION, 0 )
										If UpdtCustDaysOfCredAvg( tblTransaction.colCustNo, nExecute )
											If MyInsertRecord( hSqlInsertCRDRCashAppHdl, bInsertCRDRCashAppHdlConnected, bInsertCRDRCashAppHdlPrepared, ' CASH_APPLICATION ', hWndForm, PAM_INSERTCRDRCASHAPP, PAM_SETCRDRCASHAPPVALUES )
												Set nTransRowsApplied = nTransRowsApplied - 1
											Else
												Set bSaveOk = FALSE
										Else
											Set bSaveOk = FALSE
									Else
										Set bOk = FALSE
								Else
									Set bOk = FALSE
						!
						Set bRowWrittenOff = FALSE
						Set nRow = TBL_MinRow
						! Write off transaction section.
						While SalTblFindNextRow( tblTransaction, nRow, ROW_UnusedFlag1, 0 )
							Call SalTblFetchRow( tblTransaction, nRow )
							If frmTransaction.tblTransaction.colApplied != 'Y' AND frmTransaction.tblTransaction.colWriteOff = 'Y'
								!
								If tblTransaction.colTransCode = 'DR'
									Set nTransAmount = tblTransaction.colTransAmount
									Set nTransCode = nCR
									! reverse type of entry
								!
								If SalSendMsg( dfCustARBalance, PAM_ADJUSTARBALANCEWROFF, nTransCode, 0 )
									If UpdateCustARBalRecord( ' CUSTOMER_MASTER ', ' WHERE Cust_No = :frmTransaction.dfCustNo ', hWndForm, PAM_UPDATECUST, 0, nExecute )
										! Call SalSendMsg( frmTransaction.tblTransaction.colAmtOuts, PAM_SETWROFFAMTOUTS, 0, 0 )
										Set frmTransaction.tblTransaction.colWrOffAmount = frmTransaction.tblTransaction.colAmtOuts
										! Set the amt outstanding of the original debit trans = 0 
										Set frmTransaction.tblTransaction.colAmtOuts = 0
										!
										Call CheckForFinishedTrans( tblTransaction.colCustNo, 
												tblTransaction.colType, 
												tblTransaction.colTransCode, 
												tblTransaction.colAmtOuts, 
												tblTransaction.colOrgAmtOuts, 
												tblTransaction.colTransDate, 
												tblTransaction.colDaysToPay, nExecute )
										!
										If MyUpdateRecord( frmTransaction.tblTransaction.hSqlUpdtTransHdl, frmTransaction.tblTransaction.bUpdtTransHdlConnected, frmTransaction.tblTransaction.bUpdtTransHdlPrepared, ' TRANSACTION ', 
												frmTransaction.tblTransaction.sWHERETransaction, frmTransaction.tblTransaction, PAM_UPDATETRANSACTION, 0 )
											If UpdtCustDaysOfCredAvg( tblTransaction.colCustNo, nExecute )
												! Write the credit transaction
												If MyInsertRecord( frmTransaction.tblTransaction.hSqlInsCrTransHdl, 
														  frmTransaction.tblTransaction.bInsCrTransHdlConnected, 
														  frmTransaction.tblTransaction.bInsCrTransHdlPrepared, ' TRANSACTION ', 
														  tblTransaction, PAM_INSERTCRTRANS, PAM_SETCRTRANSVALUES )
													! Write a cash app record to relate the credit trans to the debit trans
													If NOT MyInsertRecord( frmTransaction.tblTransaction.hSqlCshAppWOffHdl, 
															  frmTransaction.tblTransaction.bCshAppWOffHdlConnected, 
															  frmTransaction.tblTransaction.bCshAppWOffHdlPrepared, ' CASH_APPLICATION ', 
															  tblTransaction, PAM_INSERTCSHAPPWROFF, PAM_SETWRITEOFFCSHAPPVALUES )
														Set bSaveOk = FALSE
												Else
													Set bSaveOk = FALSE
											Else
												Set bSaveOk = FALSE
										Else
											Set bSaveOk = FALSE
									Else
										Set bSaveOk = FALSE
								Else
									Set bSaveOk = FALSE
						!
						If bSaveOk
							If frmTransaction.tblUnAppCash.bUpdtCshRcptHdlConnected
								Call SqlCommit( frmTransaction.tblUnAppCash.hSqlUpdtCshRcptHdl )
							! If frmTransaction.tblTransaction.bDeleteTransHdlConnected
								              Call SqlCommit( frmTransaction.tblTransaction.hSqlDeleteTransHdl )
							! If frmTransaction.tblTransaction.bInsertHistHdlConnected
								              Call SqlCommit( frmTransaction.tblTransaction.hSqlInsertHistHdl )
							If bInsertCashAppHdlConnected
								Call SqlCommit( hSqlInsertCashAppHdl )
							If bInsertCRDRCashAppHdlConnected
								Call SqlCommit( hSqlInsertCRDRCashAppHdl )
							If frmTransaction.tblTransaction.bUpdtTransHdlConnected
								Call SqlCommit( frmTransaction.tblTransaction.hSqlUpdtTransHdl )
							! If frmTransaction.tblTransaction.bInsertHistWOffHdlConnected
								              Call SqlCommit( frmTransaction.tblTransaction.hSqlInsertHistWOffHdl )
							If frmTransaction.tblTransaction.bCshAppWOffHdlConnected
								Call SqlCommit( frmTransaction.tblTransaction.hSqlCshAppWOffHdl )
							If frmTransaction.tblTransaction.bInsTransHdlConnected
								Call SqlCommit( frmTransaction.tblTransaction.hSqlInsTransHdl )
							Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nCommit )
							Call UpdtCustDaysOfCredAvg( 0, nCommit )
							!
							If SalTblAnyRows( tblTransaction, ROW_New, 0 )
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblTransaction, nRow, ROW_New, 0 )
									Call SalTblFetchRow( tblTransaction, nRow )
									Call SalTblSetRowFlags( tblTransaction, nRow, ROW_New, FALSE )
								Call SalSendMsgToChildren( tblTransaction, PAM_ROWNEW, FALSE, 0 )
							If nOrgTransRowsApplied > 0
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblTransaction, nRow, 0, 0 )
									Call SalTblFetchRow( tblTransaction, nRow )
									If frmTransaction.tblTransaction.colApplied = 'Y'
										Call SalSendMsg( tblTransaction, PAM_CLEARAPPLIEDROW, 0, nRow )
										Set nRow = nRow - 1
								!
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblUnAppCash, nRow, 0, 0 )
									Call SalTblFetchRow( tblUnAppCash, nRow )
									If frmTransaction.tblUnAppCash.colFullyAppliedFlag = 'Y'
										Call SalSendMsg( tblUnAppCash, PAM_CLEARAPPLIEDROW, 0, nRow )
										Set nRow = nRow - 1
							If bRowWrittenOff
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblTransaction, nRow, ROW_UnusedFlag1, 0 )
									Call SalTblFetchRow( tblTransaction, nRow )
									Call SalSendMsg( tblTransaction, PAM_CLEARAPPLIEDROW, 0, nRow )
									Set nRow = nRow - 1
							Set bEdit = FALSE
							Call SalSendMsgToChildren( hWndForm, PAM_FIELDPROTECT, FALSE, 0 )
							! Call SalSendMsg( pbClear, SAM_Click, 0, 0 )
						Else
							If frmTransaction.tblUnAppCash.bUpdtCshRcptHdlConnected
								Call SqlPrepareAndExecute( frmTransaction.tblUnAppCash.hSqlUpdtCshRcptHdl, 'ROLLBACK' )
							If frmTransaction.tblTransaction.bDeleteTransHdlConnected
								Call SqlPrepareAndExecute( frmTransaction.tblTransaction.hSqlDeleteTransHdl, 'ROLLBACK' )
							! If frmTransaction.tblTransaction.bInsertHistHdlConnected
								              Call SqlPrepareAndExecute( frmTransaction.tblTransaction.hSqlInsertHistHdl, 'ROLLBACK' )
							If bInsertCashAppHdlConnected
								Call SqlPrepareAndExecute( hSqlInsertCashAppHdl, 'ROLLBACK' )
							If bInsertCRDRCashAppHdlConnected
								Call SqlPrepareAndExecute( hSqlInsertCRDRCashAppHdl, 'ROLLBACK' )
							If frmTransaction.tblTransaction.bUpdtTransHdlConnected
								Call SqlPrepareAndExecute( frmTransaction.tblTransaction.hSqlUpdtTransHdl, 'ROLLBACK' )
							! If frmTransaction.tblTransaction.bInsertHistWOffHdlConnected
								              Call SqlPrepareAndExecute( frmTransaction.tblTransaction.hSqlInsertHistWOffHdl, 'ROLLBACK' )
							If frmTransaction.tblTransaction.bInsTransHdlConnected
								Call SqlPrepareAndExecute( frmTransaction.tblTransaction.hSqlInsTransHdl, 'ROLLBACK' )
							If frmTransaction.tblTransaction.bCshAppWOffHdlConnected
								Call SqlPrepareAndExecute( frmTransaction.tblTransaction.hSqlCshAppWOffHdl, 'ROLLBACK' )
							Call UpdateCustARBalRecord( '', '', hWndNULL, 0, 0, nRollback )
							Call GetCustARBalance( dfCustNo, dfCustARBalance, nRollback )
							Call UpdtCustDaysOfCredAvg( 0, nRollback )
							!
							Set nTransRowsApplied = nOrgTransRowsApplied
						!
						Call SalEnableWindow( hWndItem )
						Call SalSendMsg( tblTransaction, PAM_POPULATE, 0, 0 )
						Call SalSendMsg( tblUnAppCash, PAM_POPULATE, 0, 0 )
						Call SalWaitCursor( FALSE )
			Pushbutton: pbItemEnq
				Class Child Ref Key: 0

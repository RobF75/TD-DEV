							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On SAM_SetFocus
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On PAM_EDITCHECK
								If colApplied = 'Y'
									Call SalTblKillEdit( hWndForm )
							On SAM_Validate
								If colAmtApply > colOrgAmtOuts
									Call SalMessageBox( 'You cannot apply an amount greater than
											 what is outstanding.   Please adjust', 'Apply Error', MB_Ok )
									Return VALIDATE_Cancel
								If NOT SalIsNull( hWndItem ) AND colApplied = 'N'
									Call SalTblSetRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_Selected, TRUE )
									Call SalSendMsg( frmTransaction.pbApply, SAM_Click, 0, 0 )
							On PAM_COLOURYOURSELF
								Call SalTblSetCellTextColor( hWndItem, nAppliedColour, TRUE )
							On PAM_COLOURRESET
								Call SalTblSetCellTextColor( hWndItem, COLOR_Default, TRUE )
							On PAM_DATAVAL
								Return TRUE
					Column: colAppDate

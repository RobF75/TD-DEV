		Functions
			Function: GetTreeCounts
				Description:
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					If NOT bFCHdlConnected
						Set bFCHdlConnected = SqlConnect( hSqlFCHandle ) 
						If bFCHdlConnected
							Call SqlSetLockTimeout( hSqlFCHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlFCHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bFCHdlPrepared
						Set sSql = "select  sum(conf_amt) from customer_order 
								into :dfNoFCTrees where 
								  invoiced_date >= :dfReportFromDate AND 
								  invoiced_date <= :dfReportToDate AND   
								  invoiced_flag = 'Y' and 
								   (sale_cat = 'FC' or
								    contract_price = 0) "
						If SqlPrepare( hSqlFCHandle, sSql )
							Set bFCHdlPrepared = TRUE
						Else
							Set bFCHdlPrepared = FALSE
					If NOT bRPHdlConnected
						Set bRPHdlConnected = SqlConnect( hSqlRPHandle ) 
						If bRPHdlConnected
							Call SqlSetLockTimeout( hSqlRPHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlRPHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bRPHdlPrepared
						Set sSql = "select  sum(conf_amt) from customer_order 
								into :dfNoRPTrees where 
								  invoiced_date >= :dfReportFromDate AND 
								  invoiced_date <= :dfReportToDate AND   
								  invoiced_flag = 'Y' and 
								   sale_cat = 'RP' "
						If SqlPrepare( hSqlRPHandle, sSql )
							Set bRPHdlPrepared = TRUE
						Else
							Set bRPHdlPrepared = FALSE
					If NOT bNMHdlConnected
						Set bNMHdlConnected = SqlConnect( hSqlNMHandle ) 
						If bNMHdlConnected
							Call SqlSetLockTimeout( hSqlNMHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlNMHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bNMHdlPrepared
						Set sSql = "select  sum(conf_amt) from customer_order 
								into :dfNoNMTrees where 
								  invoiced_date >= :dfReportFromDate AND 
								  invoiced_date <= :dfReportToDate AND   
								  invoiced_flag = 'Y' and 
								   sale_cat = 'NM' "
						If SqlPrepare( hSqlNMHandle, sSql )
							Set bNMHdlPrepared = TRUE
						Else
							Set bNMHdlPrepared = FALSE
					If NOT bHPHdlConnected
						Set bHPHdlConnected = SqlConnect( hSqlHPHandle ) 
						If bHPHdlConnected
							Call SqlSetLockTimeout( hSqlHPHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHPHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHPHdlPrepared
						Set sSql = "select  sum(conf_amt) from customer_order 
								into :dfNoRPTrees where 
								  invoiced_date >= :dfReportFromDate AND 
								  invoiced_date <= :dfReportToDate AND   
								  invoiced_flag = 'Y' and 
								   sale_cat = 'HP' "
						If SqlPrepare( hSqlHPHandle, sSql )
							Set bHPHdlPrepared = TRUE
						Else
							Set bHPHdlPrepared = FALSE
					If SqlExecute( hSqlFCHandle )
						Call SqlFetchNext( hSqlFCHandle, nInd )
					Else
						Call SalMessageBox( 'Could not fetch all Free of Charge trees!', 'Error', MB_Ok )
						Return FALSE
					If SqlExecute( hSqlRPHandle )
						Call SqlFetchNext( hSqlRPHandle, nInd )
					Else
						Call SalMessageBox( 'Could not fetch all Replacement trees!', 'Error', MB_Ok )
						Return FALSE
					If SqlExecute( hSqlNMHandle )
						Call SqlFetchNext( hSqlNMHandle, nInd )
					Else
						Call SalMessageBox( 'Could not fetch a count of NM trees!', 'Error', MB_Ok )
						Return FALSE
					If SqlExecute( hSqlHPHandle )
						Call SqlFetchNext( hSqlHPHandle, nInd )
					Else
						Call SalMessageBox( 'Could not fetch all Half Price trees!', 'Error', MB_Ok )
						Return FALSE
					Set dfNoTrees = dfNoRPTrees + dfNoFCTrees + dfNoNMTrees + dfNoHPTrees
		Window Parameters
			Date/Time: dtFromDate
			Date/Time: dtToDate
			Boolean: bCostingReport
		Window Variables
			String: sRepInto
			String: sRepBind
			String: sReportFile
			Number: nError
			Number: nInd
			Number: nNextAction
			String: sSql
			Number: nTransRow
			Number: nTempRow
			!
			Sql Handle: hSqlFCHandle
			Boolean: bFCHdlConnected
			Boolean: bFCHdlPrepared
			Sql Handle: hSqlRPHandle
			Boolean: bRPHdlConnected
			Boolean: bRPHdlPrepared
			Sql Handle: hSqlNMHandle
			Boolean: bNMHdlConnected
			Boolean: bNMHdlPrepared
			Sql Handle: hSqlHPHandle
			Boolean: bHPHdlConnected
			Boolean: bHPHdlPrepared
		Message Actions
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
			On SAM_CreateComplete
				Call SalWaitCursor( TRUE )
				! Call SalHideWindow( hWndForm )
				Set dfReportFromDate = dtFromDate
				Set dfReportToDate = dtToDate
				Set dfTotRail = 0
				Set dfTotPostal = 0
				Set dfTotFreight = 0
				Set dfTotLabels = 0
				Set dfTotDeposits = 0
				Set dfTotRoyalties = 0
				Set dfTotInvoices = 0
				Set dfNoTrees = 0
				Set dfNoInv = 0
				Set dfTotUnInv = 0
				Call SalSendMsgToChildren( hWndForm, PAM_POPULATE, 0, 0 )
				Call GetTreeCounts(  )
				Call SalWaitCursor( FALSE )
			On PAM_PRINTINVSUMMARY
				Call SalWaitCursor( TRUE )
				Call CallBuildSql( hWndForm, nSELECT, PAM_ITEMFIELDS, '', '' )
				Set sRepInto = sColumns
				Set sRepBind = sIntoVars
				Call CallBuildSql( tblInvSummary, nSELECT, PAM_CUSTFIELDS, '', '' )
				Set sRepInto = sRepInto||','||sColumns
				Set sRepBind = sRepBind||','||sIntoVars
				Set sReportFile = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\invsumm3.qrp'
				! Set sReportFile = 'g:\\apps\\gupta\\reports\\invsumm3.qrp'
				Set nError = 1
				Call SalReportPrint( hWndForm, sReportFile, sRepBind, sRepInto, 1, RPT_PrintAll,0,0, nError )
			On SAM_ReportStart
				Set nTransRow = TBL_MinRow
				Return TRUE
			On SAM_ReportFetchInit
				Return TRUE
			On SAM_ReportFetchNext
				If SalTblFindNextRow( tblInvSummary, nTransRow, 0, 0 )
					Call SalTblFetchRow( tblInvSummary, nTransRow )
					Return TRUE
				Else
					Return FALSE
			On SAM_ReportFinish
				Call SalTblSetContext( tblInvSummary, 0 )
				Call SalTblFetchRow( tblInvSummary, 0 )
				Call SalWaitCursor( FALSE )
				Return TRUE
			On SAM_Destroy
				If bFCHdlConnected
					Call SqlDisconnect( hSqlFCHandle )
				If bRPHdlConnected
					Call SqlDisconnect( hSqlRPHandle )
				If bNMHdlConnected
					Call SqlDisconnect( hSqlNMHandle )
				If bHPHdlConnected
					Call SqlDisconnect( hSqlHPHandle )
				Call SalShowWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )

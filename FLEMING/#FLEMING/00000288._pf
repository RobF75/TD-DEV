					Column: colWriteOff
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Write Off
						Visible? No
						Editable? No
						Maximum Data Length: 1
						Data Type: String
						Justify: Center
						Width:  1.013"
						Width Editable? Yes
						Format: Uppercase
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Check Box
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value: Y
								Uncheck Value: N
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_COLOURYOURSELF
								Call SalTblSetCellTextColor( hWndItem, nAppliedColour, TRUE )
							On PAM_COLOURRESET
								Call SalTblSetCellTextColor( hWndItem, COLOR_Default, TRUE )
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On SAM_SetFocus
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, lParam )
							On PAM_EDITCHECK
								If colWriteOff = 'Y'
									Set colWriteOff = 'N'
									Set colWrOffDate = DATETIME_Null
									Call SalSendMsg( tblTransaction, PAM_WRITEOFFROW, FALSE, lParam )
								Else
									If colAmtOuts >= nMaxWriteOffAmt 
										Call SalNumberToStr( nMaxWriteOffAmt, 2, sMaxWriteOffAmt )
										If IDCANCEL = SalMessageBox( 'The write off amount is greater then the company default of $' || sMaxWriteOffAmt || '.
												Do you still want to write this amount off.', 'Warning', MB_OkCancel | MB_DefButton2 )
											Return FALSE
									! If colTransAmount >= nMaxWriteOffAmt
										              Call SalNumberToStr( nMaxWriteOffAmt, 2, sMaxWriteOffAmt )
										              If IDCANCEL = SalMessageBox( 'The write off amount is greater then the company default of $' || sMaxWriteOffAmt || '.
												Do you still want to write this amount off.', 'Warning', MB_OkCancel | MB_DefButton2 )
											              Return FALSE
									If colTransCode = 'CR'
										Call SalMessageBox( 'Cannot write off a credit entry', 'Write Off', MB_Ok )
										Return FALSE
									If colAmtOuts = 0
										Call SalMessageBox( 'Cannot write off a zero amount outstanding entry', 'Write Off', MB_Ok )
										Return FALSE
									Set colWriteOff = 'Y'
									! If colWriteOff = 'Y'
										! Call SalTblSetRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_Selected, TRUE )
										! Call SalSendMsg( frmReceipt.pbApply, SAM_Click, 0, 0 )
									Set colWrOffDate = dtApplyDate
									Call SalSendMsg( tblTransaction, PAM_WRITEOFFROW, TRUE, lParam )
									Call SalWaitCursor( FALSE )
							On PAM_ENABLE
								If wParam
									Call SalShowWindow( hWndItem )
								Else
									Call SalHideWindow( hWndItem )
							On PAM_WRITEOFFRESTRICTIONS
								If IsUserAccounts( SqlUser, FALSE )
									Call SalSendMsg( hWndItem, PAM_ENABLE, TRUE, 0 )
								Else
									Call SalSendMsg( hWndItem, PAM_ENABLE, FALSE, 0 )
									Return FALSE
								Return TRUE
							On PAM_DATAVAL
								Return TRUE
					Column: colApplied

								Call SalSendMsg( pbQueryOk, PAM_ENABLE, 0, 0 )
								Call SalSendMsgToChildren( hWndForm, PAM_QUERYDISABLE, TRUE, 0 )
								Call SalSendMsg( tblQCustAddr, PAM_RESET, 0, 0 )
								Break
							Case nCustContTbl
								Set bShowQueryOk = TRUE
								Call SalHideWindow( hWndItem )
								Call SalDisableWindow( hWndItem )
								Call SalSendMsg( pbQueryOk, PAM_ENABLE, 0, 0 )
								Call SalSendMsgToChildren( hWndForm, PAM_QUERYDISABLE, TRUE, 0 )
								Call SalSendMsg( tblQCustCont, PAM_RESET, 0, 0 )
					On PAM_ENABLE
						Call SalShowWindow( hWndItem )
						Call SalEnableWindow( hWndItem )

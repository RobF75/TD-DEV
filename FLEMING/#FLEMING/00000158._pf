		Window Variables
			String: sCompany
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set hWndChildTable = tblDeposits
				Set bAddAllowed = FALSE
				Set bSaveAllowed = FALSE
				Set bDeleteAllowed = FALSE
				Set bUnDeleteAllowed = FALSE
				Set bClearSelectAllowed = TRUE
				Set bQueryAllowed = FALSE
				Set bRepopulateAllowed = TRUE
				Set bReportAllowed = TRUE
				Set bOrderAllowed = FALSE
				Set nPopOrQueryOnStartUp = TBL_cls_PopulateOnStartUp
				!
				Set dfStartDate = SalDateMonthBegin( SalDateCurrent(  ) )
				Set dfEndDate = SalDateCurrent(  )
				Call SalWaitCursor( FALSE )
			On SAM_CreateComplete
				If strArgArray[0] = ''
					Set sCompany = 'F'
				Else
					Set sCompany = strArgArray[4]

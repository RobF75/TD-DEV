					On PAM_cls_SETINSTANCEVARS
						! Set sSQLPopHandle = "SELECT 
								  Deposit_History.Cust_No,
								  Customer_Master.Cust_Name, 
								  Deposit_History.DepHist_Amt_Reqd, 
								  Deposit_History.DepHist_Amt_Paid, 
								  Deposit_History.DepHist_Yr_Of_Sale, 
								  Transaction.Reference_Id, 
								  Cash_Application.Date_Applied
								FROM 
								  Deposit_History,
								  Customer_Master, 
								  Transaction, 
								  Cash_Application
								WHERE 
								  Deposit_History.Cust_No = Customer_Master.Cust_No AND 
								  Deposit_History.Trans_User_Id = Transaction.Trans_User_Id AND 
								  Deposit_History.Trans_SysDateTime = Transaction.Trans_SysDateTime AND 
								  Deposit_History.Trans_User_Id = Cash_Application.Trans_User_Id AND 
								  Deposit_History.Trans_SysDateTime = Cash_Application.Trans_SysDateTime AND 
								  Deposit_History.Receipt_User_Id = Cash_Application.Receipt_User_Id AND 
								  Deposit_History.Rcpt_Sysdatetime = Cash_Application.Receipt_Sysdatetim AND
								  Cash_Application.Date_Applied BETWEEN :1 AND :2 
								UNION ALL 
								SELECT 
								  Deposit_History.Cust_No,
								  Customer_Master.Cust_Name, 
								  Deposit_History.DepHist_Amt_Reqd, 
								  Deposit_History.DepHist_Amt_Paid, 
								  Deposit_History.DepHist_Yr_Of_Sale, 
								  Trans_History.Hist_Reference_Id, 
								  Cash_Application.Date_Applied
								FROM 
								  Deposit_History,
								  Customer_Master, 
								  Trans_History, 
								  Cash_Application
								WHERE 
								  Deposit_History.Cust_No = Customer_Master.Cust_No AND 
								  Deposit_History.Trans_Hist_User_Id = Trans_History.Trans_Hist_User_Id AND 
								  Deposit_History.Trans_Hist_SysDT = Trans_History.TrHist_Sysdatetime AND 
								  Deposit_History.Trans_Hist_User_Id = Cash_Application.Trans_Hist_User_Id AND 
								  Deposit_History.Trans_Hist_SysDT = Cash_Application.Trans_Hist_SysDate AND 
								  Deposit_History.Receipt_User_Id = Cash_Application.Receipt_User_Id AND 
								  Deposit_History.Rcpt_Sysdatetime = Cash_Application.Receipt_Sysdatetim AND
								  Cash_Application.Date_Applied BETWEEN :1 AND :2
								ORDER BY 2,1"
						! Change to report on case of invoices having deposits used against them and making the invoice a CR
						! Set sSQLPopHandle = "SELECT 
										  Deposit_History.Cust_No,
										  Customer_Master.Cust_Name, 
										  Deposit_History.DepHist_Amt_Reqd, 
										  Deposit_History.DepHist_Amt_Paid, 
										  Deposit_History.DepHist_Yr_Of_Sale, 
										  Transaction.Reference_Id, 
										  Cash_Application.Date_Applied
										FROM 
										  Deposit_History,
										  Customer_Master, 
										  Transaction, 
										  Cash_Application
										WHERE 
										  Deposit_History.Cust_No = Customer_Master.Cust_No AND 
										  Deposit_History.Trans_User_Id = Transaction.Trans_User_Id AND 
										  Deposit_History.Trans_SysDateTime = Transaction.Trans_SysDateTime AND 
								                (
										  Deposit_History.Trans_User_Id = Cash_Application.Trans_User_Id OR 
								                  Deposit_History.Trans_User_Id = Cash_Application.Trans_User_Id_Cred 
								                ) AND
								                ( 
										  Deposit_History.Trans_SysDateTime = Cash_Application.Trans_SysDateTime OR
								                  Deposit_History.Trans_SysDateTime = Cash_Application.Trans_sysdate_Cred 
								                ) AND 
										  Deposit_History.Receipt_User_Id = Cash_Application.Receipt_User_Id AND 
										  Deposit_History.Rcpt_Sysdatetime = Cash_Application.Receipt_Sysdatetim AND
										  Cash_Application.Date_Applied BETWEEN :1 AND :2 
										UNION ALL 
										SELECT 
										  Deposit_History.Cust_No,
										  Customer_Master.Cust_Name, 
										  Deposit_History.DepHist_Amt_Reqd, 
										  Deposit_History.DepHist_Amt_Paid, 
										  Deposit_History.DepHist_Yr_Of_Sale, 
										  Trans_History.Hist_Reference_Id, 
										  Cash_Application.Date_Applied
										FROM 
										  Deposit_History,
										  Customer_Master, 
										  Trans_History, 
										  Cash_Application
										WHERE 
										  Deposit_History.Cust_No = Customer_Master.Cust_No AND 
										  Deposit_History.Trans_Hist_User_Id = Trans_History.Trans_Hist_User_Id AND 
										  Deposit_History.Trans_Hist_SysDT = Trans_History.TrHist_Sysdatetime AND 
								                (
										  Deposit_History.Trans_Hist_User_Id = Cash_Application.Trans_Hist_User_Id OR 
								                  Deposit_History.Trans_Hist_User_Id = Cash_Application.Trans_H_UserCred 
								                ) AND 
										(
								                  Deposit_History.Trans_Hist_SysDT = Cash_Application.Trans_Hist_SysDate OR 
								                  Deposit_History.Trans_Hist_SysDT = Cash_Application.Trans_H_DateCred 
								                ) AND 
										  Deposit_History.Receipt_User_Id = Cash_Application.Receipt_User_Id AND 
										  Deposit_History.Rcpt_Sysdatetime = Cash_Application.Receipt_Sysdatetim AND
										  Cash_Application.Date_Applied BETWEEN :1 AND :2
										ORDER BY 2,1"
						! new command taken out the cash_application table.
						Set sSQLPopHandle = "   SELECT 
								      Deposit_History.Cust_No,
								      Customer_Master.Cust_Name, 
								      Deposit_History.DepHist_Amt_Reqd, 
								      Deposit_History.DepHist_Amt_Paid, 
								      Deposit_History.DepHist_Yr_Of_Sale, 
								      Transaction.Reference_Id, 
								      Transaction.Transaction_Date
								    FROM 
								      Deposit_History,
								      Customer_Master, 
								      Transaction
								    WHERE 
								      Deposit_History.Cust_No = Customer_Master.Cust_No AND 
								      Deposit_History.Trans_User_Id = Transaction.Trans_User_Id AND 
								      Deposit_History.Trans_SysDateTime = Transaction.Trans_SysDateTime AND 
								      Transaction.Transaction_Date BETWEEN :1 AND :2 and
								Transaction.Company = :3
								    UNION ALL 
								    SELECT 
								      Deposit_History.Cust_No,
								      Customer_Master.Cust_Name, 
								      Deposit_History.DepHist_Amt_Reqd, 
								      Deposit_History.DepHist_Amt_Paid, 
								      Deposit_History.DepHist_Yr_Of_Sale, 
								      Trans_History.Hist_Reference_Id, 
								      Trans_History.Hist_Trans_Date
								    FROM 
								      Deposit_History,
								      Customer_Master, 
								      Trans_History
								    WHERE 
								      Deposit_History.Cust_No = Customer_Master.Cust_No AND 
								      Deposit_History.Trans_Hist_User_Id = Trans_History.Trans_Hist_User_Id AND 
								      Deposit_History.Trans_Hist_SysDT = Trans_History.TrHist_Sysdatetime AND 
								      Trans_History.Hist_Trans_Date BETWEEN :1 AND :2  and
								Trans_History.Hist_Company = :3
								    ORDER BY 2,1 "
						Set sNAMEPopHandle = 'DEPUSEDPERIOD'
						Set sBINDPopHandle = ':frmDepositsUsed.dfStartDate, :frmDepositsUsed.dfEndDate, :sCompany'
						Set sINTOPopHandle = ':frmDepositsUsed.tblDeposits.colCustNo, 
								:frmDepositsUsed.tblDeposits.colCustName, 
								:frmDepositsUsed.tblDeposits.colDepAmtReqd, 
								:frmDepositsUsed.tblDeposits.colDepAmtPaid, 
								:frmDepositsUsed.tblDeposits.colDepYearOfSale, 
								:frmDepositsUsed.tblDeposits.colReferenceId,
								:frmDepositsUsed.tblDeposits.colDateApplied'
						!
						Set bAddAllowed = FALSE
						Set bSaveAllowed = FALSE
						Set bDeleteAllowed = FALSE
						Set bUnDeleteAllowed = FALSE
						Set bRepopulateAllowed = TRUE
						Set bClearSelectAllowed = TRUE
						Set bQueryAllowed = FALSE
						Set bReportAllowed = TRUE
						Set bOrderAllowed = TRUE
						!
						Set bSelectFirstRow = FALSE
						!
						Set sReportFileName = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\depsused1.qrp'
						Set sRepBind = ':frmDepositsUsed.dfStartDate, 
								:frmDepositsUsed.dfEndDate, 
								:frmDepositsUsed.tblDeposits.colCustNo, 
								:frmDepositsUsed.tblDeposits.colCustName, 
								:frmDepositsUsed.tblDeposits.colDepAmtReqd, 
								:frmDepositsUsed.tblDeposits.colDepAmtPaid, 
								:frmDepositsUsed.tblDeposits.colDepYearOfSale, 
								:frmDepositsUsed.tblDeposits.colReferenceId,
								:frmDepositsUsed.tblDeposits.colDateApplied,
								:sCompany'
						Set sRepInto = 'DateFrom, DateTo, CustNo, CustName, AmtReqd, AmtPaid, YearOfSale, InvoiceNo, DateApplied, Company'
						!
						Set sTableHeading = 'Deposits Used For a Period'
						!
						Set nTableFillType = TBL_FillAll
					On PAM_clsTBL_POPULATE
						Set frmDepositsUsed.dfPaidTotal = 0
						Return SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
					On PAM_clsTBL_REPOPULATE
						Return SalSendMsg( hWndForm, PAM_clsTBL_POPULATE, wParam, lParam )
					On SAM_FetchRowDone
						Set frmDepositsUsed.dfPaidTotal = frmDepositsUsed.dfPaidTotal + colDepAmtPaid
						Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
			!

.head 6 -  Set sSQLPopHandle = "SELECT 
  'N', 
  Stock_Item_Sale.Year_Of_Sale, 
  Stock_Item.Item_No, 
  @UPPER( Stock_Item.Variety_Type ), 
  @UPPER( Stock_Item.Variety ), 
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  @UPPER( Stock_Item.Tree_Type_Desc ), 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Generic_Stock_Item, 
  Stock_Item_Sale.Tot_Avail 
FROM 
  Stock_Item, 
  Stock_Item_Sale 
WHERE 
  Stock_Item.Item_No = Stock_Item_Sale.Stock_Item_No AND 
  Stock_Item_Sale.Year_Of_Sale = :1 AND 
  ( Stock_Item_Sale.Tot_Avail >= :2 OR 
    Stock_Item.Generic_Stock_Item = 'Y' ) 
ORDER BY 4 ASC, 5 ASC, 6 ASC, 7 ASC, 8 DESC, 3 ASC"
.head 6 -  Set sNAMEPopHandle = 'POPITMSPLST3'
.head 6 -  Set sBINDPopHandle = ':frmItemSupLst.nYearOfSale, :frmItemSupLst.dfTotAvail'

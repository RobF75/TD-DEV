.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'EraseCommands' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 +  If sType = 'CREATOR'

.head 8 +  While haSqlHandles[ nOurHandleNo ].FetchNext( nInd ) AND bOk
.head 9 +  If __EraseCommand( sGotCreator, sGotName, SH_cls_Execute )
.head 10 -  Call __EraseCommand( sGotCreator, sGotName, SH_cls_Commit )

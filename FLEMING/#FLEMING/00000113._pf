								Set cbContainer.hWndNotField = cbNOTContainer
							! On PAM_clsQUERYFIELD_QBE
								                                                   If SalIsButtonChecked( hWndItem )
									                                                   If SalSendMsg( hWndNotField, PAM_clsQUERYNOT_GETSTATE, 0, 0 )
										                                                   Set sField = ' NOT '
									                                                   Else 
										                                                   Set sField = ''
									                                                   Set sField = sField || ' ' || sSQLCOLNAME || ' ' || " = 'C' "
									                                                   Call PushString( sField )
									                                                   Return TRUE
								                                                   Else 
									                                                   Return FALSE

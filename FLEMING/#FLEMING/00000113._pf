					Discardable? No
				Contents
					Column: colEstAvailDate
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Est.Sale.Date
						Visible? Yes
						Editable? No
						Maximum Data Length: Default
						Data Type: Date/Time
						Justify: Left
						Width:  Default
						Width Editable? Yes
						Format: dd-MMM-yyyy
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
					Column: colAvailable
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Available
						Visible? Yes
						Editable? No
						Maximum Data Length: Default
						Data Type: Number
						Justify: Right
						Width:  Default
						Width Editable? Yes
						Format: #0
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
				Functions
					Function: Add
						Description:
						Returns
						Parameters
							Date/Time: dtEstAvailDate
							Number: nAvailable
						Static Variables
						Local variables
							Number: nRow
						Actions
							Set dtNewEstAvailDate = dtEstAvailDate
							Set nNewAvailable = nAvailable
							Set bFound = FALSE
							Call TableLoop( hWndForm, hWndForm, PAM_clsTBL_ROWACTION, 0, 0, 0, 'Collecting Availabilities', TBL_cls_LowToHi )
							If NOT bFound
								Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
								Call SalTblSetContext( hWndForm, nRow )
								Call SalTblSetRowFlags( hWndForm, nRow, ROW_HideMarks, TRUE )
								Set colEstAvailDate = dtNewEstAvailDate
								Set colAvailable = nNewAvailable
				Window Variables
					Date/Time: dtNewEstAvailDate
					Number: nNewAvailable
					Boolean: bFound
				Message Actions
					On PAM_clsTBL_ROWACTION
						If colEstAvailDate = dtNewEstAvailDate
							Set bFound = TRUE
							Set colAvailable = colAvailable + nNewAvailable
						Return TRUE
			!

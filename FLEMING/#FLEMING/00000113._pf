					String: sQuoteCultivarOptions
					String: sCultivar
				Functions
				Message Actions
					On SAM_Create
						Set nQueryType = STCKITMQ_QueryStockItemSale
						Return SalSendClassMessage( SAM_Create, wParam, lParam )
					On PAM_cls_SETINSTANCEVARS
						Set hWndChildTable = tblStockItems
						Set bAddAllowed = FALSE
						Set bSaveAllowed = FALSE
						Set bDeleteAllowed = FALSE
						Set bUnDeleteAllowed = FALSE
						Set bClearSelectAllowed = TRUE
						Set bQueryAllowed = TRUE
						Set bRepopulateAllowed = TRUE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = TRUE
						Set bPrintFormAllowed = TRUE
						Set bZoomTableAllowed = TRUE
						Set nPopOrQueryOnStartUp = TBL_cls_NothingOnStartUp
						Set nActionOnExit = FRM_HideOnExit
					On SAM_CreateComplete
						Call SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
						Return SalSendMsg( hWndChildTable, PAM_STCKITMQ_INITQUERYTYPE, nQueryType, 0 )
					On PAM_clsFRM_POPFIELDS
						Call PopString( sRootDesc, FALSE )
						Call PopString( sCultDesc, FALSE )
						Call PopString( sTreeTypeDesc, FALSE )
						Call PopNumber( nYear, FALSE )
						! nQueryType = STCKITMQ_QueryStockItemSale OR STCKITMQ_QueryStockItem
						Call PopNumber( nQueryType, FALSE )
						! nSelectType = PICK_SelectManyToMany = default OR PICK_SelectOneToMany
						Call PopNumber( nSelectType, FALSE )
						Call PopWndHdl( hWndActivateButton, FALSE )
						Return TRUE
					On PAM_cls_SETFIELDS
						Set tblStockItems.sTreeTypeDesc = sTreeTypeDesc
						Set tblStockItems.sCultDesc = sCultDesc
						Set tblStockItems.sRootDesc = sRootDesc
						Return TRUE

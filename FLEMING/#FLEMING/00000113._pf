							Message Actions
								On PAM_cls_SETINSTANCEVARS
									Set pbSelect.hWndTable = tblStockItems
									Set pbSelect.hWndSelectParent = hWndForm.clsFormChildTable.hWndActivateButton
									! Set pbSelect.nSelectType = PICK_SelectManyToMany
									Set pbSelect.nSelectType = hWndForm.clsfrmQueryStockItems.nSelectType
								On PAM_clsPICK_PUSHFIELDS
									Call PushNumber( tblStockItems.colItemNo )
									Call PushNumber( tblStockItems.colYear )
									Call PushString( tblStockItems.colRootDesc )
									Call PushString( tblStockItems.colRootId )
									Call PushString( tblStockItems.colCultDesc )
									Call PushString( tblStockItems.colCultId )
									Call PushString( tblStockItems.colTreeTypeDesc )
									Call PushString( tblStockItems.colTreeType )
									Call PushNumber( tblStockItems.colBatchYearOfSale )
									Call PushNumber( tblStockItems.colBatchLocationId )
									Return TRUE
								On PAM_clsPICK_POPFIELDS
									Call PopNumber( nTmp, TRUE )
									Call PopNumber( nTmp, TRUE )
									Call PopString( sTmp, TRUE )
									Call PopString( sTmp, TRUE )
									Call PopString( sTmp, TRUE )
									Call PopString( sTmp, TRUE )
									Call PopString( sTmp, TRUE )
									Call PopString( sTmp, TRUE )
									Call PopNumber( nTmp, TRUE )
									Call PopNumber( nTmp, TRUE )
									Return TRUE

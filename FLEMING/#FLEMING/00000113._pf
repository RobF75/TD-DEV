						Message Actions
							On PAM_cls_SETINSTANCEVARS
								! Set lbVarietyTypes.sSqlPopStatement = " SELECT DISTINCT 
										  Variety_Type 
										FROM 
										  Cultivar 
										ORDER BY 
										  Variety_Type"
								Set lbVarietyTypes.bPopulateOnce = FALSE
								Set lbVarietyTypes.bGetCountOnPopulate = TRUE
							On SAM_Click
								Call SalSendClassMessage( SAM_Click, wParam, lParam )
								Set sVarietyType = lbVarietyTypes.sCurrentSelectionString
								Call SalSendMsg( dfVarietyOptions, PAM_cls_INITIALISE, 0, 0 )
								Call SalSetFocus( dfVarietyOptions )
								Call SalSendMsg( dfCultivarOptions, PAM_cls_INITIALISE, 0, 0 )
								Call SalSendMsg( lbVariety, PAM_clsLB_POPULATE, 0, 0 )
							On PAM_clsLB_POPULATE
								Call SalSendMsg( dfVarietyOptions, PAM_cls_INITIALISE, 0, 0 )
								Call SalSendMsg( dfCultivarOptions, PAM_cls_INITIALISE, 0, 0 )
								Return SalSendClassMessage( PAM_clsLB_POPULATE, wParam, lParam )
							On PAM_clsLB_POPULATEDCOUNT
								If lParam = 1
									Call SalListSetSelect( hWndItem, 0 )
									Call SalPostMsg( hWndItem, SAM_Click, 0, 0 )

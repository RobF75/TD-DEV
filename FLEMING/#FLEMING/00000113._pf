						Functions
							Function: GetComments
								Description:
								Returns
									Boolean:
								Parameters
									Number: nItemNo
									Number: nYear
									Receive String: sSizeComments
									Receive String: sItemComments
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nInd
									Number: nOurHandleNo
									String: sGotSizeComments
									String: sGotItemComments
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SHOWCOMNTS' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Size_Of_Unit, Stock_Item_Comment
													  FROM Stock_Item_Sale
													  WHERE Stock_Item_No = :1 AND Year_Of_Sale = :2 "
											Set sName = 'SHOWCOMNTS'
											Set sBind = ':nItemNo, :nYear'
											Set sInto = ':sGotSizeComments, :sGotItemComments'
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set sSizeComments = ''
											Set sItemComments = ''
											Set sGotSizeComments = ''
											Set sGotItemComments = ''
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set sSizeComments = sGotSizeComments
													Set sItemComments = sGotItemComments
												Return TRUE
											Else
												Return FALSE
											Return TRUE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: SetTableQueryPassFields
								Description:
								Returns
								Parameters
									Receive String: sNewTreeTypeDesc
									Receive String: sNewCultDesc
									Receive String: sNewRootDesc
								Static Variables
								Local variables
								Actions
									Set sTreeTypeDesc = sNewTreeTypeDesc
									Set sCultDesc = sNewCultDesc
									Set sRootDesc = sNewRootDesc
							Function: GetItemGradedFlag
								Description:
								Returns
									Boolean:
								Parameters
									Number: nItemNo
									Number: nYear
									Receive Number: nItemGraded
									Receive String: sItemGradedFlag
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
								Local variables
									String: sSql
									String: sName
									String: sBind
									String: sInto
									Number: nOurHandleNo
									Boolean: bOk
									Number: nInd
									!
									Number: nGotItemGraded
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SIGETAMTGRAD' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT 
													  Amt_Graded 
													FROM 
													  Stock_Item_Sale 
													WHERE
													  Stock_Item_No = :1 AND 
													  Year_Of_Sale = :2 "
											Set sName = 'SIGETAMTGRAD'
											Set sBind = ':nItemNo, :nYear'
											Set sInto = ':nGotItemGraded'
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set nItemGraded = NUMBER_Null
											Set nGotItemGraded = NUMBER_Null
											Set sItemGradedFlag = ''
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set nItemGraded = nGotItemGraded
													If nGotItemGraded > 0
														Set sItemGradedFlag = 'Y'
													Else
														Set sItemGradedFlag = 'N'
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: GetItemAllocFlag
								Description:
								Returns
									Boolean:
								Parameters
									Number: nItemNo
									Number: nYear
									Receive String: sItemAllocFlag
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
								Local variables
									String: sSql
									String: sName
									String: sBind
									String: sInto
									Number: nOurHandleNo
									Boolean: bOk
									Number: nInd
									String: sGotItemAllocFlag
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SIGETALLOCFLG' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT 
													  Allocated_Flag 
													FROM 
													  Stock_Item_Sale 
													WHERE
													  Stock_Item_No = :1 AND 
													  Year_Of_Sale = :2 "
											Set sName = 'SIGETALLOCFLG'
											Set sBind = ':nItemNo, :nYear'
											Set sInto = ':sGotItemAllocFlag'
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set sItemAllocFlag = ''
											Set sGotItemAllocFlag = ''
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set sItemAllocFlag = sGotItemAllocFlag
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
						Window Variables
							Number: nQueryType
							! PRIVATE
							Number: nTmp
							Number: nYear
							Boolean: bExists
							Boolean: bActiveItem
							Boolean: bRowOk
							Number: nColor
							!
							String: sTreeTypeDesc
							String: sCultDesc
							String: sRootDesc
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set tblStockItems.sTreeTypeDesc = ''
								Set tblStockItems.sCultDesc = ''
								Set tblStockItems.sRootDesc = ''
								Set tblStockItems.sQueryDialogName = 'dlgQQStockItems'
								! Pop handle
								If TRUE
									Set tblStockItems.sSQLPopHandle = 'SELECT 
											  Item_No,
											  Variety_Type, 
											  @Upper( Variety ), 
											  @Upper( Cult_Desc ), 
											  @Upper( Root_Desc ),  
											  Tree_Type, 
											  Tree_Type_Desc, 
											  Type_Description, 
											  Cultivar_Id, 
											  Cult_Desc, 
											  Rootstock_Id, 
											  Root_Desc, 
											  Base_Price, 
											  Generic_Stock_Item, 
											  Stock_Type, 
											  Unit_Size, 
											  Price_Update, 
											  CV_Not_Sale_Flag, 
											  RT_Not_Sale_Flag, 
											  CV_Non_Prop_Flag, 
											  Prod_Royalty,
											  RT_Non_Prop_Flag, 
											  cv_on_trial_flag,
											  rt_on_trial_flag,
											  Bud_Disc_Perc, 
											  First_Sec_Disc_Per, 
											  Sec_Gr_Disc_Per, 
											  GC_Reserve, 
											  Item_Added_By, 
											  Item_Added_Date, 
											  Changed_By, 
											  Changed_Date, 
											  Top_Worked ,
											  Special_Price,
											  Price_Group
											FROM 
											  Stock_Item 
											ORDER BY 2,3,4,5,6 '
									Set tblStockItems.sNAMEPopHandle = 'POPSTCKITMQ'
									Set tblStockItems.sBINDPopHandle = ''
									Set tblStockItems.sINTOPopHandle = ':clsfrmQueryStockItems.tblStockItems.colItemNo, 
											:clsfrmQueryStockItems.tblStockItems.colVarietyType, 
											:clsfrmQueryStockItems.tblStockItems.colUpperVariety, 
											:clsfrmQueryStockItems.tblStockItems.colUpperCultDesc, 
											:clsfrmQueryStockItems.tblStockItems.colUpperRootDesc, 
											:clsfrmQueryStockItems.tblStockItems.colTreeType, 
											:clsfrmQueryStockItems.tblStockItems.colTreeTypeDesc, 
											:clsfrmQueryStockItems.tblStockItems.colTypeDescription, 
											:clsfrmQueryStockItems.tblStockItems.colCultId, 
											:clsfrmQueryStockItems.tblStockItems.colCultDesc, 
											:clsfrmQueryStockItems.tblStockItems.colRootId, 
											:clsfrmQueryStockItems.tblStockItems.colRootDesc, 
											:clsfrmQueryStockItems.tblStockItems.colBasePrice, 
											:clsfrmQueryStockItems.tblStockItems.colGenericFlag, 
											:clsfrmQueryStockItems.tblStockItems.colStockType, 
											:clsfrmQueryStockItems.tblStockItems.colUnitSize, 
											:clsfrmQueryStockItems.tblStockItems.colPriceUpdateFlag, 
											:clsfrmQueryStockItems.tblStockItems.colCVNotSale, 
											:clsfrmQueryStockItems.tblStockItems.colRTNotSale, 
											:clsfrmQueryStockItems.tblStockItems.colCVNPA, 
											:clsfrmQueryStockItems.tblStockItems.colProdRoy,
											:clsfrmQueryStockItems.tblStockItems.colRTNPA, 
											:clsfrmQueryStockItems.tblStockItems.colTest, 
											:clsfrmQueryStockItems.tblStockItems.colRTTest,
											:clsfrmQueryStockItems.tblStockItems.colBudDiscPerc, 
											:clsfrmQueryStockItems.tblStockItems.colFirstDiscPerc, 
											:clsfrmQueryStockItems.tblStockItems.colSecDiscPerc, 
											:clsfrmQueryStockItems.tblStockItems.colGCReserve, 
											:clsfrmQueryStockItems.tblStockItems.colAddedBy, 
											:clsfrmQueryStockItems.tblStockItems.colAddedDate, 
											:clsfrmQueryStockItems.tblStockItems.colChangedBy, 
											:clsfrmQueryStockItems.tblStockItems.colChangedDate, 
											:clsfrmQueryStockItems.tblStockItems.colTopWorked, 
											:clsfrmQueryStockItems.tblStockItems.colSpecial, 
											:clsfrmQueryStockItems.tblStockItems.colPriceGroup'
								! Refresh handle
								If TRUE
									Set tblStockItems.sSQLRefreshHandle = 'SELECT 
											  Item_No,
											  Variety_Type, 
											  @Upper( Variety ), 
											  @Upper( Cult_Desc ), 
											  @Upper( Root_Desc ),  
											  Tree_Type, 
											  Tree_Type_Desc, 
											  Type_Description, 
											  Cultivar_Id, 
											  Cult_Desc, 
											  Rootstock_Id, 
											  Root_Desc, 
											  Base_Price, 
											  Generic_Stock_Item, 
											  Stock_Type, 
											  Unit_Size, 
											  Price_Update, 
											  CV_Not_Sale_Flag, 
											  RT_Not_Sale_Flag, 
											  CV_Non_Prop_Flag, 
											  Prod_Royalty,
											  RT_Non_Prop_Flag, 
											  cv_on_trial_flag,
											  rt_on_trial_flag,
											  Bud_Disc_Perc, 
											  First_Sec_Disc_Per, 
											  Sec_Gr_Disc_Per, 
											  GC_Reserve, 
											  Item_Added_By, 
											  Item_Added_Date, 
											  Changed_By, 
											  Changed_Date, 
											  Top_Worked ,
											 Special_Price,
											Price_Group
											FROM 
											  Stock_Item 
											WHERE 
											  Item_No = :1 '
									Set tblStockItems.sNAMERefreshHandle = 'REFSTCKITMQ'
									Set tblStockItems.sBINDRefreshHandle = ':clsfrmQueryStockItems.tblStockItems.colItemNo'
									Set tblStockItems.sINTORefreshHandle = ':clsfrmQueryStockItems.tblStockItems.colItemNo, 
											:clsfrmQueryStockItems.tblStockItems.colVarietyType, 
											:clsfrmQueryStockItems.tblStockItems.colUpperVariety, 
											:clsfrmQueryStockItems.tblStockItems.colUpperCultDesc, 
											:clsfrmQueryStockItems.tblStockItems.colUpperRootDesc, 
											:clsfrmQueryStockItems.tblStockItems.colTreeType, 
											:clsfrmQueryStockItems.tblStockItems.colTreeTypeDesc, 
											:clsfrmQueryStockItems.tblStockItems.colTypeDescription, 
											:clsfrmQueryStockItems.tblStockItems.colCultId, 
											:clsfrmQueryStockItems.tblStockItems.colCultDesc, 
											:clsfrmQueryStockItems.tblStockItems.colRootId, 
											:clsfrmQueryStockItems.tblStockItems.colRootDesc, 
											:clsfrmQueryStockItems.tblStockItems.colBasePrice, 
											:clsfrmQueryStockItems.tblStockItems.colGenericFlag, 
											:clsfrmQueryStockItems.tblStockItems.colStockType, 
											:clsfrmQueryStockItems.tblStockItems.colUnitSize, 
											:clsfrmQueryStockItems.tblStockItems.colPriceUpdateFlag, 
											:clsfrmQueryStockItems.tblStockItems.colCVNotSale, 
											:clsfrmQueryStockItems.tblStockItems.colRTNotSale, 
											:clsfrmQueryStockItems.tblStockItems.colCVNPA, 
											:clsfrmQueryStockItems.tblStockItems.colProdRoy,
											:clsfrmQueryStockItems.tblStockItems.colRTNPA, 
											:clsfrmQueryStockItems.tblStockItems.colTest, 
											:clsfrmQueryStockItems.tblStockItems.colRTTest,
											:clsfrmQueryStockItems.tblStockItems.colBudDiscPerc, 
											:clsfrmQueryStockItems.tblStockItems.colFirstDiscPerc, 
											:clsfrmQueryStockItems.tblStockItems.colSecDiscPerc, 
											:clsfrmQueryStockItems.tblStockItems.colGCReserve, 
											:clsfrmQueryStockItems.tblStockItems.colAddedBy, 
											:clsfrmQueryStockItems.tblStockItems.colAddedDate, 
											:clsfrmQueryStockItems.tblStockItems.colChangedBy, 
											:clsfrmQueryStockItems.tblStockItems.colChangedDate, 
											:clsfrmQueryStockItems.tblStockItems.colTopWorked, 
											:clsfrmQueryStockItems.tblStockItems.colSpecial, 
											:clsfrmQueryStockItems.tblStockItems.colPriceGroup'
								!
								Set tblStockItems.sSQLInsertHandle = ''
								Set tblStockItems.sNAMEInsertHandle = ''
								Set tblStockItems.sBINDInsertHandle = ''
								Set tblStockItems.sINTOInsertHandle = ''
								!
								Set tblStockItems.sSQLUpdateHandle = ''
								Set tblStockItems.sNAMEUpdateHandle = ''
								Set tblStockItems.sBINDUpdateHandle = ''
								Set tblStockItems.sINTOUpdateHandle = ''
								!
								Set tblStockItems.sSQLDeleteHandle = ''
								Set tblStockItems.sNAMEDeleteHandle = ''
								Set tblStockItems.sBINDDeleteHandle = ''
								Set tblStockItems.sINTODeleteHandle = ''
								!
								Set tblStockItems.bAddAllowed = FALSE
								Set tblStockItems.bSaveAllowed = FALSE
								Set tblStockItems.bDeleteAllowed = FALSE
								Set tblStockItems.bUnDeleteAllowed = FALSE
								Set tblStockItems.bRepopulateAllowed = TRUE
								Set tblStockItems.bClearSelectAllowed = TRUE
								Set tblStockItems.bQueryAllowed = TRUE
								Set tblStockItems.bReportAllowed = FALSE
								Set tblStockItems.bOrderAllowed = TRUE
								!
								Set tblStockItems.nTableFillType = TBL_FillNormal
								!
								Set tblStockItems.bZoomTableAllowed = TRUE
								Set tblStockItems.nZoomTblTop = 0.281
								Set tblStockItems.nZoomTblHeight = 4.354
							On SAM_FetchRowDone
								If tblStockItems.nQueryType = STCKITMQ_QueryStockItemSale OR hWndParent.clsfrmQueryStockItems.cbActiveItemsOnly
									! Call CheckYearItemExists( colItemNo, nYear, bExists, colSoldOutFlag, SH_cls_Execute )
									Call GetSISQueryBasicInfo( colItemNo, nYear, bExists, bActiveItem, colSoldOutFlag, SH_cls_Execute )
									If bExists
										If hWndParent.clsfrmQueryStockItems.cbActiveItemsOnly
											If bActiveItem
												Set bRowOk = TRUE
											Else
												Set bRowOk = FALSE
										Else
											Set bRowOk = TRUE
									Else
										Set bRowOk = FALSE
								Else
									Set bRowOk = TRUE
									Set nYear = hWndParent.clsfrmQueryStockItems.ccSeasonYear.GetSeasonYear( )
								If bRowOk
									Set colYear = nYear
									If hWndParent.clsfrmQueryStockItems.cbCalcAvail
										Call SalSendMsg( hWndForm, PAM_STCKITMQ_CALCITEMAVAIL, wParam, lParam )
									If hWndParent.clsfrmQueryStockItems.cbCalcFutAvail
										Call SalSendMsg( hWndForm, PAM_STCKITMQ_CALCITEMFUTAVAIL, wParam, lParam )
									If hWndParent.clsfrmQueryStockItems.cbCalcPrice
										Call SalSendMsg( hWndForm, PAM_STCKITMQ_CALCITEMPRICE, wParam, lParam )
									If hWndParent.clsfrmQueryStockItems.cbShowComments
										Call SalSendMsg( hWndForm, PAM_STCKITMQ_GETCOMMENTS, wParam, lParam )
									If hWndParent.clsfrmQueryStockItems.cbShowGraded
										Call SalSendMsg( hWndForm, PAM_STCKITMQ_GETGRADED, wParam, lParam )
									If hWndParent.clsfrmQueryStockItems.cbShowAlloc
										Call SalSendMsg( hWndForm, PAM_STCKITMQ_GETALLOC, wParam, lParam )
								Else
									Call SalTblSetRowFlags( hWndForm, lParam, ROW_Hidden, TRUE )
								Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
							On PAM_clsTBL_POPULATE
								Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_SETCOLUMNCOLOR, 0, COLOR_Default )
								Return SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
							On PAM_clsTBL_REPOPULATE
								Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_SETCOLUMNCOLOR, 0, COLOR_Default )
								Return SalSendClassMessage( PAM_clsTBL_REPOPULATE, wParam, lParam )
							On PAM_clsTBL_SEARCH
								Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_SETCOLUMNCOLOR, 0, COLOR_Default )
								Return SalSendClassMessage( PAM_clsTBL_SEARCH, wParam, lParam )
							On PAM_STCKITMQ_CALCAVAIL
								If TableLoop( hWndForm, hWndForm, PAM_STCKITMQ_CALCITEMAVAIL, 0, ROW_Selected, 0, 'Calculating Availability', TBL_cls_LowToHi )
									Return TRUE
								Else
									Return FALSE
							On PAM_STCKITMQ_CALCITEMAVAIL
								If hWndParent.clsfrmQueryStockItems.nQueryType = STCKITMQ_QueryStockItem
									Call CalculateItemTotAvailForQueries( colItemNo, hWndParent.clsfrmQueryStockItems.ccSeasonYear.GetSeasonYear( ), colAvail, SH_cls_Execute )
								Else
									Call CalculateItemTotAvailForQueries( colItemNo, colYear, colAvail, SH_cls_Execute )
								Return TRUE
							On PAM_STCKITMQ_CALCFUTAVAIL
								If TableLoop( hWndForm, hWndForm, PAM_STCKITMQ_CALCITEMFUTAVAIL, 0, ROW_Selected, 0, 'Calculating Future Availability', TBL_cls_LowToHi )
									Return TRUE
								Else
									Return FALSE
							On PAM_STCKITMQ_CALCITEMFUTAVAIL
								If colStockType = 'C'
									If hWndParent.clsfrmQueryStockItems.nQueryType = STCKITMQ_QueryStockItem
										Call CalcItemTotFutAvailForQueries( colItemNo, hWndParent.clsfrmQueryStockItems.ccSeasonYear.GetSeasonYear( ), colFutAvail, SH_cls_Execute )
									Else
										Call CalcItemTotFutAvailForQueries( colItemNo, colYear, colFutAvail, SH_cls_Execute )
								Return TRUE
							On PAM_STCKITMQ_CALCPRICE
								If TableLoop( hWndForm, hWndForm, PAM_STCKITMQ_CALCITEMPRICE, 0, ROW_Selected, 0, 'Calculating Price', TBL_cls_LowToHi )
									Return TRUE
								Else
									Return FALSE
							On PAM_STCKITMQ_CALCITEMPRICE
								If hWndParent.clsfrmQueryStockItems.nQueryType = STCKITMQ_QueryStockItem
									Call CalcItemPriceForQueries( colItemNo, hWndParent.clsfrmQueryStockItems.ccSeasonYear.GetSeasonYear( ), colPrice, SH_cls_Execute )
								Else
									Call CalcItemPriceForQueries( colItemNo, colYear, colPrice, SH_cls_Execute )
								Return TRUE
							On PAM_STCKITMQ_SHOWCOMMENTS
								If TableLoop( hWndForm, hWndForm, PAM_STCKITMQ_GETCOMMENTS, 0, ROW_Selected, 0, 'Fetching Item Comments', TBL_cls_LowToHi )
									Return TRUE
								Else
									Return FALSE
							On PAM_STCKITMQ_GETCOMMENTS
								If hWndParent.clsfrmQueryStockItems.nQueryType = STCKITMQ_QueryStockItem
									Call GetComments( colItemNo, hWndParent.clsfrmQueryStockItems.ccSeasonYear.GetSeasonYear( ), colSizeComments, colItemComments, SH_cls_Execute )
								Else
									Call GetComments( colItemNo, colYear, colSizeComments, colItemComments, SH_cls_Execute )
								Return TRUE
							On PAM_STCKITMQ_SHOWGRADED
								If TableLoop( hWndForm, hWndForm, PAM_STCKITMQ_GETGRADED, 0, ROW_Selected, 0, 'Fetching Item Graded Flags', TBL_cls_LowToHi )
									Return TRUE
								Else
									Return FALSE
							On PAM_STCKITMQ_GETGRADED
								Call GetItemGradedFlag( colItemNo, hWndParent.clsfrmQueryStockItems.ccSeasonYear.GetSeasonYear( ), colGradedAmt, colGradedFlag, SH_cls_Execute )
								Return TRUE
							On PAM_STCKITMQ_SHOWALLOC
								If TableLoop( hWndForm, hWndForm, PAM_STCKITMQ_GETALLOC, 0, ROW_Selected, 0, 'Fetching Item Allocated Flags', TBL_cls_LowToHi )
									Return TRUE
								Else
									Return FALSE
							On PAM_STCKITMQ_GETALLOC
								Call GetItemAllocFlag( colItemNo, hWndParent.clsfrmQueryStockItems.ccSeasonYear.GetSeasonYear( ), colAllocFlag, SH_cls_Execute )
								Return TRUE
							On SAM_Destroy
								! Call CheckYearItemExists( 0, 0, bExists, colSoldOutFlag, SH_cls_Disconnect )
								Call GetSISQueryBasicInfo( 0, 0, bExists, bActiveItem, colSoldOutFlag, SH_cls_Disconnect )
								Call CalculateItemTotAvailForQueries( 0, 0, colAvail, SH_cls_Disconnect )
								Call CalcItemTotFutAvailForQueries( 0, 0, colFutAvail, SH_cls_Disconnect )
								Call CalcItemPriceForQueries( 0, 0, colPrice, SH_cls_Disconnect )
								Call tblStockItems.GetComments( 0, 0, colSizeComments, colItemComments, SH_cls_Disconnect )
								Call GetItemGradedFlag( 0, 0, colGradedAmt, colGradedFlag, SH_cls_Disconnect )
								Call GetItemAllocFlag( 0, 0, colAllocFlag, SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
							On PAM_clsTBL_PUSHFIELDS
								Call SalSendMsg( hWndForm, PAM_cls_SETFIELDS, 0, 0 )
								Call PushNumber( tblStockItems.nYear )
								Call PushString( tblStockItems.sTreeTypeDesc )
								Call PushString( tblStockItems.sCultDesc )
								Call PushString( tblStockItems.sRootDesc )
								Call PushNumber( hWndParent.clsfrmQueryStockItems.cbActiveItemsOnly )
								Return TRUE
							On PAM_clsTBL_POPFIELDS
								Call PopNumber( tblStockItems.nYear, FALSE )
								Call PopNumber( nTmp, FALSE )
								If nTmp
									Call SalSendMsg( hWndParent.clsfrmQueryStockItems.cbActiveItemsOnly, PAM_clsCB_SET, TRUE, 0 )
								Else
									Call SalSendMsg( hWndParent.clsfrmQueryStockItems.cbActiveItemsOnly, PAM_clsCB_SET, FALSE, 0 )
								Return TRUE
							On PAM_STCKITMQ_INITQUERYTYPE
								Set nQueryType = wParam
								Return SalSendMsgToChildren( hWndForm, PAM_STCKITMQ_INITQUERYTYPE, wParam, lParam )
							On PAM_cls_SETFIELDS
								Return SalSendMsg( hWndParent, PAM_cls_SETFIELDS, wParam, lParam )

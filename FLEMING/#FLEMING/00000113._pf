							On PAM_clsDF_CLEAR
								Set sCultivarOptions = '%'
								Set sQuoteCultivarOptions = '%'
								Set dfCultivarOptions = ''
								Return TRUE
							On SAM_AnyEdit
								Set sCultivarOptions = dfCultivarOptions || '%'
								Set sQuoteCultivarOptions = "'" || sCultivarOptions
								Call SalSendMsg( lbCultivars, PAM_clsLB_POPULATE, 0, 0 )
							On PAM_clsTBL_ZOOMTABLE
								If wParam
									Call SalHideWindow( hWndItem )

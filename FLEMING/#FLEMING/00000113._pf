						List Initialization
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set lbVariety.sSqlPopStatement = " SELECT DISTINCT 
										  Variety 
										FROM 
										  Cultivar 
										WHERE 
										  Variety_Type = :hWndForm.clsfrmQueryStockItems.sVarietyType AND 
										  @UPPER( Variety ) LIKE @UPPER( :hWndForm.clsfrmQueryStockItems.sVarietyOptions )
										ORDER BY 
										  Variety"
								Set lbVariety.bPopulateOnce = FALSE
								Set lbVariety.bGetCountOnPopulate = TRUE
							On SAM_Click
								Call SalSendClassMessage( SAM_Click, wParam, lParam )
								Set sVariety = lbVariety.sCurrentSelectionString
								Call SalSendMsg( dfCultivarOptions, PAM_cls_INITIALISE, 0, 0 )
								Call SalSetFocus( dfCultivarOptions )
								Call SalSendMsg( lbCultivars, PAM_clsLB_POPULATE, 0, 0 )
							On PAM_clsLB_POPULATE
								Call SalSendClassMessage( PAM_clsLB_POPULATE, wParam, lParam )
								Call SalSendMsg( lbCultivars, PAM_clsLB_RESET, 0, 0 )
							On PAM_clsLB_POPULATEDCOUNT
								If lParam = 1
									Call SalListSetSelect( hWndItem, 0 )
									Call SalPostMsg( hWndItem, SAM_Click, 0, 0 )
							On PAM_clsTBL_ZOOMTABLE
								If wParam
									Call SalHideWindow( hWndItem )
									Call SalDisableWindow( hWndItem )
								Else
									Call SalEnableWindow( hWndItem )
									Call SalShowWindow( hWndItem )

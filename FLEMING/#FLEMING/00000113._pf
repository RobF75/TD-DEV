					Message Actions
						On PAM_cls_SETINSTANCEVARS
							Set pbSelect.hWndTable = tblGrowSale
							Set pbSelect.hWndSelectParent = hWndSelectParent
							Set pbSelect.nSelectType = PICK_SelectManyToMany
						On PAM_clsPICK_PUSHFIELDS
							Call PushNumber( tblGrowSale.colLocationId )
							Call PushNumber( tblGrowSale.colYear )
							Call PushNumber( tblGrowSale.colItemNo )
							Call PushNumber( tblGrowSale.colSeasonTextColor )
							Call PushString( tblGrowSale.colSeason )
							Return TRUE
						On PAM_clsPICK_POPFIELDS
							Call PopString( sTmp, TRUE )
							Call PopNumber( nTmp, TRUE )
							Call PopNumber( nTmp, TRUE )
							Call PopNumber( nTmp, TRUE )
							Call PopNumber( nTmp, TRUE )
							Return TRUE

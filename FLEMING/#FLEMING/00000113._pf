				Picture File Name: C:\CENTURA\ICONS\STCKITMS.BMP
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				List in Tool Palette? Yes
				Property Template:
				Class DLL Name:
				Description:
				Derived From
					Class: clspbPickInto
				Class Variables
					String: sTmp
					Number: nTmp
					Window Handle: hWndTmp
				Instance Variables
					! PUBLIC
					Window Handle: hWndPickIntoTable
					! nQueryType = STCKITMQ_QueryStockItemSale = default OR STCKITMQ_QueryStockItem
					Number: nQueryType
					! nSelectType = PICK_SelectManyToMany = default OR PICK_SelectOneToMany
					Number: nSelectType
					! PRIVATE
					Number: nYear
					String: sTreeType
					String: sTreeTypeDesc
					String: sCultId
					String: sCultDesc
					String: sRootId
					String: sRootDesc
					Number: nItemNo
					Number: nBatchYearOfSale
					Number: nBatchLocationId
				Functions
					Function: SetStockItemsFields
						Description:
						Returns
							Boolean:
						Parameters
							Number: nNewYear
							String: sNewTreeTypeDesc
							String: sNewCultDesc
							String: sNewRootDesc
						Static Variables
						Local variables
						Actions
							Set nYear = nNewYear
							Set sTreeTypeDesc = sNewTreeTypeDesc
							Set sCultDesc = sNewCultDesc
							Set sRootDesc = sNewRootDesc
							Return TRUE
					Function: GetStockItemsFields
						Description:
						Returns
							Boolean:
						Parameters
							Receive Number: nNewItemNo
							Receive Number: nNewYear
							Receive String: sNewTreeType
							Receive String: sNewTreeTypeDesc
							Receive String: sNewCultId
							Receive String: sNewCultDesc
							Receive String: sNewRootId
							Receive String: sNewRootDesc
							Receive Number: nNewBatchYearOfSale
							Receive Number: nNewBatchLocationId
						Static Variables
						Local variables
						Actions
							Set nNewItemNo = nItemNo
							Set nNewYear = nYear
							Set sNewTreeType = sTreeType
							Set sNewTreeTypeDesc = sTreeTypeDesc
							Set sNewCultId = sCultId
							Set sNewCultDesc = sCultDesc
							Set sNewRootId = sRootId
							Set sNewRootDesc = sRootDesc
							Set nNewBatchYearOfSale = nBatchYearOfSale
							Set nNewBatchLocationId = nBatchLocationId
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Set nQueryType = STCKITMQ_QueryStockItemSale
						Set nSelectType = PICK_SelectManyToMany
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbStockItems.nActivateWindowType = ACTIVATE_FormWindow
						Set clspbStockItems.sActivateDialogName = 'frmQueryStockItems'
						Set clspbStockItems.hWndTable = hWndPickIntoTable
						Set clspbStockItems.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushWndHdl( hWndItem )
						Call PushNumber( nSelectType )
						Call PushNumber( nQueryType )
						Call PushNumber( nYear )
						Call PushString( sTreeTypeDesc )
						Call PushString( sCultDesc )
						Call PushString( sRootDesc )
						Return TRUE
					On PAM_clsPICK_LOOKUP
						Call PopNumber( nBatchLocationId, TRUE )
						Call PopNumber( nBatchYearOfSale, TRUE )
						Call PopString( sTreeType, TRUE )
						Call PopString( sTreeTypeDesc, TRUE )
						Call PopString( sCultId, TRUE )
						Call PopString( sCultDesc, TRUE )
						Call PopString( sRootId, TRUE )
						Call PopString( sRootDesc, TRUE )
						Call PopNumber( nYear, TRUE )
						Call PopNumber( nItemNo, TRUE )
						Call SalSendMsg( hWndItem, PAM_cls_GETFIELDS, 0, 0 )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopWndHdl( hWndTmp, TRUE )
						Return TRUE

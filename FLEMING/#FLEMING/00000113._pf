				Derived From
					Class: clsTblQueryDialog
				Class Variables
					Number: nTmp
				Instance Variables
				Functions
				Message Actions
					On SAM_Create
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set bMapEnterToTab = TRUE
						Set hWndFirstFocus = dfCultDesc
					On SAM_CreateComplete
						Set dfYear = ccSeasonYear.GetSeasonYear( )
						Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
					On PAM_clsDLG_POPFIELDS
						Call PopNumber( nTmp, FALSE )
						If nTmp
							Call SalSendMsg( cbActiveItemsOnly, PAM_clsCB_SET, TRUE, 0 )
						Else
							Call SalSendMsg( cbActiveItemsOnly, PAM_clsCB_SET, FALSE, 0 )
						Call PopString( dfRootDesc, FALSE )
						Call PopString( dfCultDesc, FALSE )
						Call PopString( dfTreeTypeDesc, FALSE )
						Call PopNumber( dfYear, FALSE )
						Return TRUE
					On PAM_clsDLG_PUSHFIELDS
						Call PushNumber( cbActiveItemsOnly )
						Call PushNumber( dfYear )
						Return TRUE

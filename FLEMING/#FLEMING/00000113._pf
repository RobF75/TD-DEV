						Background Color: Class Default
						Horizontal Scroll? Class Default
						List Initialization
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								! Set lbCultivars.sSqlPopStatement = " SELECT DISTINCT 
										  Cult_Desc 
										FROM 
										  Cultivar 
										WHERE 
										  Variety_Type = :hWndForm.clsfrmQueryStockItems.sVarietyType AND 
										  Variety = :hWndForm.clsfrmQueryStockItems.sVariety AND 
										  @UPPER( Cult_Desc ) LIKE @UPPER( :hWndForm.clsfrmQueryStockItems.sCultivarOptions )
										ORDER BY 
										  Cult_Desc "
								Set lbCultivars.sSqlPopStatement = ' SELECT DISTINCT 
										  Cult_Desc 
										FROM 
										  Cultivar 
										WHERE 
										  Variety_Type = :hWndForm.clsfrmQueryStockItems.sVarietyType AND 
										  Variety = :hWndForm.clsfrmQueryStockItems.sVariety AND 
										  ( 
										    @UPPER( Cult_Desc ) LIKE @UPPER( :hWndForm.clsfrmQueryStockItems.sCultivarOptions ) OR 
										    @UPPER( Cult_Desc ) LIKE @UPPER( :hWndForm.clsfrmQueryStockItems.sQuoteCultivarOptions ) 
										  )
										ORDER BY 
										  Cult_Desc '
								Set lbCultivars.bPopulateOnce = FALSE
								Set lbCultivars.bGetCountOnPopulate = TRUE
							On SAM_Click
								Call SalSendClassMessage( SAM_Click, wParam, lParam )
								Set sCultivar = lbCultivars.sCurrentSelectionString
								Set sQuickBuildWhere = " Variety_Type = :hWndForm.clsfrmQueryStockItems.sVarietyType AND 
										  Variety = :hWndForm.clsfrmQueryStockItems.sVariety AND 
										  Cult_Desc = :hWndForm.clsfrmQueryStockItems.sCultivar "
								Set nYear = ccSeasonYear.GetSeasonYear( )
								Call PushString( sQuickBuildWhere )
								Call PushNumber( cbActiveItemsOnly )
								Call PushNumber( nYear )
								If NOT SalSendMsg( tblStockItems, PAM_clsTBL_SEARCH, TRUE, 0 )
									Call PopString( sQuickBuildWhere, TRUE )
									Call PopNumber( nYear, TRUE )
							On PAM_clsLB_POPULATE
								Call SalSendClassMessage( PAM_clsLB_POPULATE, wParam, lParam )
								Call SalSendMsg( tblStockItems, PAM_clsTBL_RESET, 0, 0 )
							On PAM_clsLB_POPULATEDCOUNT
								If lParam = 1
									Call SalListSetSelect( hWndItem, 0 )
									Call SalPostMsg( hWndItem, SAM_Click, 0, 0 )
							On PAM_clsTBL_ZOOMTABLE
								If wParam
									Call SalHideWindow( hWndItem )
									Call SalDisableWindow( hWndItem )
								Else
									Call SalEnableWindow( hWndItem )
									Call SalShowWindow( hWndItem )

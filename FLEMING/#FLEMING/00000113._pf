				Functions
				Window Variables
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set sSQLPopHandle = "SELECT  
								  Growing_Sale.Stock_Item_No,  
								  Growing_Sale.Year_Of_Sale,  
								  Growing_Sale.Location_Id,  
								  Growing_Sale.Beg_Count,  
								  Growing_Sale.First_Count,  
								  Growing_Sale.Second_Count, 
								  NULL, 
								  Growing_Sale.Est_Sale_Date,  
								  NULL, 
								  Growing_Sale.Forward_Orders,  
								  NULL, 
								  Growing_Sale.Not_For_Sale  
								FROM   
								  Growing_Sale  
								WHERE 
								  Growing_Sale.Stock_Item_No = :1 AND 
								  Growing_Sale.Year_Of_Sale >= :2 AND 
								  ( Growing_Sale.Est_Sale_Date >= SYSDATE OR Growing_Sale.Not_For_Sale = 'Y' )  
								ORDER BY 
								  Growing_Sale.Est_Sale_Date"
						Set sNAMEPopHandle = 'PPFUTAVAIL2'
						Set sBINDPopHandle = ':dlgFutureAvail.nItemNo, :dlgFutureAvail.dfYear'
						Set sINTOPopHandle = ':dlgFutureAvail.tblGrowSale.colItemNo, 
								  :dlgFutureAvail.tblGrowSale.colYear, 
								  :dlgFutureAvail.tblGrowSale.colLocationId, 
								  :dlgFutureAvail.tblGrowSale.colBegCount, 
								  :dlgFutureAvail.tblGrowSale.colFirstCount, 
								  :dlgFutureAvail.tblGrowSale.colSecondCount, 
								  :dlgFutureAvail.tblGrowSale.colSeason, 
								  :dlgFutureAvail.tblGrowSale.colEstSaleDate, 
								  :dlgFutureAvail.tblGrowSale.colCurrentCount, 
								  :dlgFutureAvail.tblGrowSale.colForwardOrders, 
								  :dlgFutureAvail.tblGrowSale.colAvailable, 
								  :dlgFutureAvail.tblGrowSale.colNotForSale'
						!
						Set sSQLRefreshHandle = 'SELECT  
								  Growing_Sale.Stock_Item_No,  
								  Growing_Sale.Year_Of_Sale,  
								  Growing_Sale.Location_Id,  
								  Growing_Sale.Beg_Count,  
								  Growing_Sale.First_Count,  
								  Growing_Sale.Second_Count,  
								  NULL, 
								  Growing_Sale.Est_Sale_Date,  
								  NULL, 
								  Growing_Sale.Forward_Orders,  
								  NULL, 
								  Growing_Sale.Not_For_Sale  
								FROM   
								  Growing_Sale  
								WHERE 
								  Growing_Sale.Location_Id = :1 AND 
								  Growing_Sale.Year_Of_Sale = :2 '
						Set sNAMERefreshHandle = 'RFFUTAVAIL2'
						Set sBINDRefreshHandle = ':dlgFutureAvail.tblGrowSale.colLocationId, :dlgFutureAvail.tblGrowSale.colYear'
						Set sINTORefreshHandle = ':dlgFutureAvail.tblGrowSale.colItemNo, 
								  :dlgFutureAvail.tblGrowSale.colYear, 
								  :dlgFutureAvail.tblGrowSale.colLocationId, 
								  :dlgFutureAvail.tblGrowSale.colBegCount, 
								  :dlgFutureAvail.tblGrowSale.colFirstCount, 
								  :dlgFutureAvail.tblGrowSale.colSecondCount, 
								  :dlgFutureAvail.tblGrowSale.colSeason, 
								  :dlgFutureAvail.tblGrowSale.colEstSaleDate, 
								  :dlgFutureAvail.tblGrowSale.colCurrentCount, 
								  :dlgFutureAvail.tblGrowSale.colForwardOrders, 
								  :dlgFutureAvail.tblGrowSale.colAvailable, 
								  :dlgFutureAvail.tblGrowSale.colNotForSale'
						!
						Set sSQLInsertHandle = ''
						Set sNAMEInsertHandle = ''
						Set sBINDInsertHandle = ''
						Set sINTOInsertHandle = ''
						!
						Set sSQLUpdateHandle = ''
						Set sNAMEUpdateHandle = ''
						Set sBINDUpdateHandle = ''
						Set sINTOUpdateHandle = ''
						!
						Set sSQLDeleteHandle = ''
						Set sNAMEDeleteHandle = ''
						Set sBINDDeleteHandle = ''
						Set sINTODeleteHandle = ''
						!
						Set bAddAllowed = FALSE
						Set bSaveAllowed = FALSE
						Set bDeleteAllowed = FALSE
						Set bUnDeleteAllowed = FALSE
						Set bRepopulateAllowed = TRUE
						Set bClearSelectAllowed = TRUE
						Set bQueryAllowed = FALSE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = FALSE
						!
						Set bSelectFirstRow = FALSE
						Set nTableFillType = TBL_FillAll
						!
						Set sTableHeading = 'Future Available'
					On SAM_FetchRowDone
						If colSecondCount > 0
							Set colCurrentCount = colSecondCount
						Else If colFirstCount > 0
							Set colCurrentCount = colFirstCount
						Else
							Set colCurrentCount = colBegCount
						Set colAvailable = colCurrentCount - colForwardOrders
						!
						If SalIsNull( colEstSaleDate )
							If colNotForSale = 'Y'
								Set colSeason = 'Not for sale'
						Else
							Set colSeason = GetSeason( colEstSaleDate )
							Set colSeasonTextColor = GetSeasonColor( colSeason )
							Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_SETCOLUMNCOLOR, 0, colSeasonTextColor )
							If NOT SalIsNull( colEstSaleDate )
								Set colSeason = colSeason || ' ' || SalNumberToStrX( SalDateYear( colEstSaleDate ), 0 )
						If NOT colNotForSale = 'Y'
							Call tblSeasonAvail.Add( colEstSaleDate, colCurrentCount - colForwardOrders )
						Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )

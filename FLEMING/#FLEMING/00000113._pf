				Message Actions
					On PAM_cls_SETFIELDS
						Call clspbStckItmPickWhenAvail.SetFutureFields( clspbStckItmPickWhenAvail.hWndPickIntoTable.colItemNo, clspbStckItmPickWhenAvail.hWndPickIntoTable.colYear, 
								clspbStckItmPickWhenAvail.hWndPickIntoTable.colTreeTypeDesc, clspbStckItmPickWhenAvail.hWndPickIntoTable.colCultDesc, clspbStckItmPickWhenAvail.hWndPickIntoTable.colRootDesc )
						Return TRUE
					On PAM_cls_GETFIELDS
						Call clspbStckItmPickWhenAvail.GetFutureFields( clspbStckItmPickWhenAvail.hWndPickIntoTable.colSeason, 
								clspbStckItmPickWhenAvail.hWndPickIntoTable.nColor, 
								clspbStckItmPickWhenAvail.hWndPickIntoTable.colItemNo, 
								clspbStckItmPickWhenAvail.hWndPickIntoTable.colBatchYearOfSale, 
								clspbStckItmPickWhenAvail.hWndPickIntoTable.colBatchLocationId  )
						!
						Set clspbStckItmPickWhenAvail.hWndPickIntoTable.colYear = clspbStckItmPickWhenAvail.hWndPickIntoTable.colBatchYearOfSale
						Call SalSendMsgToChildren( clspbStckItmPickWhenAvail.hWndPickIntoTable, PAM_clsTBL_SETCOLUMNCOLOR, 0, clspbStckItmPickWhenAvail.hWndPickIntoTable.nColor )
						Return TRUE

							Set sCVNonPropFlag = ''
							!
							Set sGotVarietyType = ''
							Set sGotVariety = ''
							Set sGotCultDesc = ''
							Set sGotCVNotSaleFlag = ''
							Set sGotCVNonPropFlag = ''
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set sVarietyType = sGotVarietyType
									Set sVariety = sGotVariety
									Set sCultDesc = sGotCultDesc
									Set sCVNotSaleFlag = sGotCVNotSaleFlag
									Set sCVNonPropFlag = sGotCVNonPropFlag
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )

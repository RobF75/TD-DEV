					Receive String: sVarietyType
					Receive String: sVariety
					Receive String: sCultDesc
					Receive String: sCVNotSaleFlag
					Receive String: sCVNonPropFlag
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					String: sGotVarietyType
					String: sGotVariety
					String: sGotCultDesc
					String: sGotCVNotSaleFlag
					String: sGotCVNonPropFlag
					String: sGotCVProRoyFlag

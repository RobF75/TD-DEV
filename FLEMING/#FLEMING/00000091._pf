			Function: ExistsItemByItemFields
				Description:
				Returns
					Boolean:
				Parameters
					String: sTreeType
					String: sCultId
					String: sRootId
					Receive Boolean: bExists
					Number: nActionType
				Static Variables
					: fcOurCultRootHandle
						Class: hcSqlHandle
					: fcOurCultOnlyHandle
						Class: hcSqlHandle
					: fcOurRootOnlyHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					Number: nOurCultRootHandleNo
					Number: nOurCultOnlyHandleNo
					Number: nOurRootOnlyHandleNo
					Number: nInd
					Boolean: bOk
				Actions
					Set nOurCultRootHandleNo = SqlHandlesGetReferenceNo( 'ExistsItemByItemFields_CultRoot' )
					Set nOurCultOnlyHandleNo = SqlHandlesGetReferenceNo( 'ExistsItemByItemFields_CultOnly' )
					Set nOurRootOnlyHandleNo = SqlHandlesGetReferenceNo( 'ExistsItemByItemFields_RootOnly' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Item_No 
									FROM 
									  Stock_Item 
									WHERE 
									  Tree_Type = :sTreeType AND 
									  Cultivar_Id = :sCultId AND 
									  Rootstock_Id = :sRootId "
							Call haSqlHandles[ nOurCultRootHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurCultRootHandleNo ].hSqlHandle )
							!
							Set sSql = " SELECT 
									  Item_No 
									FROM 
									  Stock_Item 
									WHERE 
									  Tree_Type = :sTreeType AND 
									  Cultivar_Id = :sCultId AND 
									  Rootstock_Id IS NULL "
							Call haSqlHandles[ nOurCultOnlyHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurCultOnlyHandleNo ].hSqlHandle )
							!
							Set sSql = " SELECT 
									  Item_No 
									FROM 
									  Stock_Item 
									WHERE 
									  Tree_Type = :sTreeType AND 
									  Cultivar_Id IS NULL AND 
									  Rootstock_Id = :sRootId "
							Call haSqlHandles[ nOurRootOnlyHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurRootOnlyHandleNo ].hSqlHandle )
							!
							Set bExists = FALSE
							!
							If sCultId = ''
								If haSqlHandles[ nOurRootOnlyHandleNo ].PrepareAndExecute( )
									If haSqlHandles[ nOurRootOnlyHandleNo ].FetchNext( nInd )
										Set bExists = TRUE
									Return TRUE
								Else
									Return FALSE
							Else If sRootId = ''
								If haSqlHandles[ nOurCultOnlyHandleNo ].PrepareAndExecute( )
									If haSqlHandles[ nOurCultOnlyHandleNo ].FetchNext( nInd )
										Set bExists = TRUE
									Return TRUE
								Else
									Return FALSE
							Else
								If haSqlHandles[ nOurCultRootHandleNo ].PrepareAndExecute( )
									If haSqlHandles[ nOurCultRootHandleNo ].FetchNext( nInd )
										Set bExists = TRUE
									Return TRUE
								Else
									Return FALSE
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nOurCultRootHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurCultOnlyHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurRootOnlyHandleNo ].Disconnect( )
								Set bOk = FALSE
							Return bOk
			Function: CheckItemOnOrder
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Receive Boolean: bExists
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurOrderHandle

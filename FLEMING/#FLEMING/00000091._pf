			Function: CalcCreditedTreesReturned
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Number: nYear
					Receive Number: nAmtCreditedReturned
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcOurHistHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Number: nOurHistHandleNo
					Number: nInd

						Case SH_cls_Execute
							Set sSql = " SELECT MAX( Item_No )+1 FROM Stock_Item"
							Set sName = 'GTNXTNITMNO'
							Set sBind = ''
							Set sInto = ':nGotItemNo'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nItemNo = NUMBER_Null
							Set nGotItemNo = NUMBER_Null

								Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
								!
								Set bExists = FALSE
								!
								If haSqlHandles[ nOurHandleNo ].Execute( )
									If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
										Set bExists = TRUE
									Return TRUE
								Else
									Return FALSE
						Case SH_cls_Disconnect
							Call haSqlHandles[ nOurHandleNo ].Disconnect( )
							Call haSqlHandles[ nOurHistHandleNo ].Disconnect( )
							Return TRUE
			Function: CalcItemGrowSale
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Number: nYear
					Receive Number: naGrowSaleFwdOrds[*]
					Receive Number: naBatchLocationIds[*]
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Number: nInd
					!
					Number: nPos
					Number: nGotForwardOrders
					Number: nGotBatchLocationId
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETFWDORDCNT' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Forward_Orders, 
									  Location_Id   
									FROM 
									  Growing_Sale
									WHERE 
									  Stock_Item_No = :1 AND 
									  Year_Of_Sale = :2 AND 
									  ( Not_For_Sale = 'N' OR 
									  Not_For_Sale IS NULL ) AND 
									  Est_Sale_Date > SYSDATE  "
							Set sName = 'GETFWDORDCNT'
							Set sBind = ':nItemNo, :nYear'
							Set sInto = ':nGotForwardOrders, :nGotBatchLocationId'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nGotForwardOrders = NUMBER_Null
							Set nGotBatchLocationId = NUMBER_Null
							Set nPos = 0
							Set naBatchLocationIds[ nPos ] = NUMBER_Null
							Set naGrowSaleFwdOrds[ nPos ] = NUMBER_Null
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set naGrowSaleFwdOrds[nPos] = nGotForwardOrders
									Set naBatchLocationIds[ nPos ] = nGotBatchLocationId
									Set nPos = nPos + 1
									Set naBatchLocationIds[ nPos ] = NUMBER_Null
									Set naGrowSaleFwdOrds[nPos] = NUMBER_Null
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: CalcItemAmtFutureGrowing
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Number: nYear
					Receive Number: nEstFutureAvailCount
					Receive Number: nAmtFutureGrowing
					Receive Number: nAmtFwdOrders
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
					Number: nLastItemNo
					Number: nBudDiscPerc
					Number: nFirstSecDiscPerc
					Number: nSecGrDiscPerc
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Number: nInd
					!
					Boolean: bOk
					!
					Number: nBegCount
					Number: nFirstCount
					Number: nSecondCount
					Number: nGotForwardOrders
					Number: nGotLocationId
					!
					Number: nActualGrowing
					Number: nTotalAvail
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETITMFUTCNTS' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Beg_Count, 
									  First_Count, 
									  Second_Count, 
									  Forward_Orders, 
									  Location_Id  
									FROM 
									  Growing_Sale
									WHERE 
									  Stock_Item_No = :1 AND 
									  Year_Of_Sale = :2 AND 
									  ( Not_For_Sale = 'N' OR 
									  Not_For_Sale IS NULL ) AND 
									  Est_Sale_Date > SYSDATE "
							Set sName = 'GETITMFUTCNTS'
							Set sBind = ':nItemNo, :nYear'
							Set sInto = ':nBegCount, :nFirstCount, :nSecondCount, :nGotForwardOrders, :nGotLocationId'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nBegCount = NUMBER_Null
							Set nFirstCount = NUMBER_Null
							Set nSecondCount = NUMBER_Null
							Set nGotForwardOrders = NUMBER_Null
							!
							Set nActualGrowing = 0
							Set nTotalAvail = 0
							!
							Set nEstFutureAvailCount = 0
							Set nAmtFutureGrowing = 0
							Set nAmtFwdOrders = 0
							!
							If nItemNo = nLastItemNo
								Set bOk = TRUE
							Else
								Set bOk = GetItemDiscPerc( nItemNo, nBudDiscPerc, nFirstSecDiscPerc, nSecGrDiscPerc, SH_cls_Execute )
							If bOk
								Set nLastItemNo = nItemNo
								If haSqlHandles[ nOurHandleNo ].Execute( )
									While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
										If nSecondCount >= 0
											Set nTotalAvail = nTotalAvail + ( nSecondCount - ( ( nSecGrDiscPerc / 100 ) * nSecondCount ) ) 
											Set nActualGrowing = nActualGrowing + nSecondCount
										Else If nFirstCount >= 0
											Set nTotalAvail = nTotalAvail + ( nFirstCount - ( ( nFirstSecDiscPerc / 100 ) * nFirstCount ) ) 
											Set nActualGrowing = nActualGrowing + nFirstCount
										Else
											Set nTotalAvail = nTotalAvail + ( nBegCount - ( ( nBudDiscPerc / 100 ) * nBegCount ) ) 
											Set nActualGrowing = nActualGrowing + nBegCount
										Set nAmtFwdOrders = nAmtFwdOrders + nGotForwardOrders
									Set nEstFutureAvailCount = nTotalAvail
									Set nAmtFutureGrowing = nActualGrowing
									Return TRUE
								Else
									Return FALSE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT GetItemDiscPerc( nItemNo, nBudDiscPerc, nFirstSecDiscPerc, nSecGrDiscPerc, SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurHandleNo ].Disconnect( )
								Set bOk = FALSE
							Return bOk

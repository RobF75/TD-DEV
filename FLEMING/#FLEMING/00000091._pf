					Set nOurHistHandleNo = SqlHandlesGetReferenceNo( 'HEXSTFBTCHINVO' )
					Select Case nActionType
						Case SH_cls_Execute
							If nYear < WhichSeasonYear( SalDateCurrent(  ) ) AND nYear != 77
								Set sSql = " SELECT 
										  Cust_No 
										FROM 
										  Cust_Order_History
										WHERE 
										  Invoiced_Flag = 'Y' AND 
										  Batch_Year_Of_Sale = :2 AND 
										  Batch_Location_Id = :1 
										ORDER BY 
										  Batch_Year_Of_Sale, 
										  Batch_Location_Id "
								Set sName = 'HEXSTFBTCHINVO'
								Set sBind = ':nLocationId, :nYear'
								Set sInto = ''
								Call haSqlHandles[ nOurHistHandleNo ].Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( haSqlHandles[ nOurHistHandleNo ].hSqlHandle )
								!
								Set bExists = FALSE
								!
								If haSqlHandles[ nOurHistHandleNo ].Execute( )
									If haSqlHandles[ nOurHistHandleNo ].FetchNext( nInd )
										Set bExists = TRUE
									Return TRUE
								Else
									Return FALSE
							Else
								Set sSql = " SELECT 
										  Cust_No 
										FROM 
										  Customer_Order
										WHERE 
										  Invoiced_Flag = 'Y' AND 
										  Batch_Year_Of_Sale = :2 AND 
										  Batch_Location_Id = :1 "
								Set sName = 'EXSTFBTCHINVO'
								Set sBind = ':nLocationId, :nYear'

					Set nOurHistHandleNo = SqlHandlesGetReferenceNo( 'HAMTCREDRETURN' )
					Select Case nActionType
						Case SH_cls_Execute
							If nYear < WhichSeasonYear( SalDateCurrent(  ) ) AND nYear != 77
								Set sSql = " SELECT 
										  SUM( No_Trees_Credited )
										FROM 
										  Cust_Order_History
										WHERE 
										  Stock_Item_No = :1 AND 

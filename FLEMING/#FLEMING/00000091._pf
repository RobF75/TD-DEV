									Return FALSE
							Else
								Set sSql = " SELECT 
										  SUM( No_Trees_Credited )
										FROM 
										  Customer_Order
										WHERE 
										  Stock_Item_No = :1 AND 
										  Year_Of_Sale = :2 AND 

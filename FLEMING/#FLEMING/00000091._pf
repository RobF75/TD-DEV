							Set sInto = ':sGotVarietyType, :sGotVariety, :sGotCultDesc, :sGotCVNotSaleFlag, :sGotCVNonPropFlag, :sGotCVProRoyFlag'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )

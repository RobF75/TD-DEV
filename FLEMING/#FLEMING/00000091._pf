					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " UPDATE Stock_Item_Sale 
									SET  
									  Amt_Growing = :3,
									  Amt_Graded = :4, 
									  Amt_Shipped = :5, 
									  Amt_On_Order = :6, 
									  Tot_Avail = :7, 
									  On_Ord_As_Subs = :8, 
									  Amt_Subs_Shipped = :9, 
									  Est_Avail_Count = :10, 
									  Total_Graded = :11 
									WHERE 
									  Stock_Item_No = :1 AND Year_Of_Sale = :2 "
							Set sName = 'SISUPDTITMINV'
							Set sBind = ':nItemNo, 
									:nYear, 
									:nAmtGrowing, 
									:nAmtGraded, 
									:nAmtShipped, 
									:nAmtOnOrder, 
									:nTotAvail, 
									:nOnOrdAsSubs,
									:nAmtSubsShipped,
									:nEstAvailCount,
									:nTotalGraded'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Commit
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )

			Function: GetSISQueryBasicInfo
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Number: nYear
					Receive Boolean: bYearExists
					Receive Boolean: bActiveItem
					Receive String: sSoldOutFlag
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					!
					String: sGotSoldOutFlag
					Number: nGotAmtGrowing
					Number: nGotAmtGraded
					Number: nGotAmtShipped
					Number: nGotAmtSupplied
					Number: nGotAmtOnOrder
					Number: nGotOnOrdAsSubs
					Number: nGotAmtSubsShipped
					Number: nInd
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SISQBINFONW' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Amt_Growing, 
									  Amt_Graded, 
									  Amt_Shipped, 
									  Amt_Supplied, 
									  Amt_On_Order, 
									  On_Ord_As_Subs, 
									  Amt_Subs_Shipped, 
									  Sold_Out_Flag 
									FROM Stock_Item_Sale 
									WHERE Stock_Item_No = :1 AND Year_Of_Sale = :2 "
							Set sName = 'SISQBINFONW'
							Set sBind = ':nItemNo, :nYear'
							Set sInto = ':nGotAmtGrowing, :nGotAmtGraded, :nGotAmtShipped, :nGotAmtSupplied, 
									:nGotAmtOnOrder, :nGotOnOrdAsSubs, :nGotAmtSubsShipped, :sGotSoldOutFlag'
							!
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set bYearExists = FALSE
							Set bActiveItem = FALSE
							Set sSoldOutFlag = ''
							Set sGotSoldOutFlag = ''
							Set nGotAmtGrowing = NUMBER_Null
							Set nGotAmtGraded = NUMBER_Null
							Set nGotAmtShipped = NUMBER_Null
							Set nGotAmtSupplied = NUMBER_Null
							Set nGotAmtOnOrder = NUMBER_Null
							Set nGotOnOrdAsSubs = NUMBER_Null
							Set nGotAmtSubsShipped = NUMBER_Null
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set bYearExists = TRUE
									Set sSoldOutFlag = sGotSoldOutFlag
									If nGotAmtGrowing > 0 OR 
											nGotAmtGraded > 0 OR 
											nGotAmtShipped > 0 OR 
											nGotAmtSupplied > 0 OR 
											nGotAmtOnOrder > 0 OR 
											nGotOnOrdAsSubs > 0 OR 
											nGotAmtSubsShipped > 0
										Set bActiveItem = TRUE
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			!
			Function: CalcItemPriceForQueries
				Description: Calculates the price of trees for queries of stock items.
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Number: nYear
					Receive Number: nPrice
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Boolean: bOk
					Number: nInd
					Number: nGotPrice
					String: sCultId
					String: sRootId
					Number: nCultRoy
					Number: nRootRoy
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'CALCITMPRICE' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT Stock_Item.Base_Price, Cultivar_Id, Rootstock_Id 
									  FROM Stock_Item  
									  WHERE Stock_Item.Item_No = :1 "
							Set sName = 'CALCITMPRICE'
							Set sBind = ':nItemNo'
							Set sInto = ':nGotPrice, :sCultId, :sRootId'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nPrice = NUMBER_Null
							Set nGotPrice = NUMBER_Null
							Set sCultId = ''
							Set sRootId = ''
							Set nCultRoy = NUMBER_Null
							Set nRootRoy = NUMBER_Null
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set nPrice = nGotPrice
									If sCultId != ''
										Call CalcCultivarRoyalty( 0, sCultId, nItemNo, nCultRoy, SH_cls_Execute )
										Set nPrice =  nPrice + nCultRoy
									If sRootId != ''
										Call CalcRootstockRoyalty( 0, sRootId, nItemNo, nRootRoy, SH_cls_Execute )
										Set nPrice =  nPrice + nRootRoy
								Return TRUE
							Else
								Return FALSE
							Return TRUE
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nOurHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT CalcCultivarRoyalty( 0, '', 0, nCultRoy, SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT CalcRootstockRoyalty( 0, '', 0, nRootRoy, SH_cls_Disconnect )
								Set bOk = FALSE
							Return bOk
			Function: GetItemBasePrice
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Receive Number: nBasePrice
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nOurHandleNo
					!
					Number: nGotBasePrice
				Actions
					! Number: nOurHandleNo
					! haSqlHandles[ nOurHandleNo ]
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETITMBPRCE' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = ' SELECT 
									  Base_Price 
									FROM 
									  Stock_Item
									WHERE 
									   Item_No = :1 '
							Set sName = 'GETITMBPRCE'
							Set sBind = ':nItemNo'
							Set sInto = ':nGotBasePrice'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nBasePrice = NUMBER_Null
							Set nGotBasePrice = NUMBER_Null
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set nBasePrice = nGotBasePrice
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: CalcRootstockRoyalty
				Description: To find out if there are rootstock royalties applicable to this item
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					String: sRootId
					Number: nItemNo
					Receive Number: nTotRoy
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurFNAHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcOurRootHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSqlFNAHandle
					String: sBindFNAHandle
					String: sIntoFNAHandle
					String: sNameFNAHandle
					Number: nOurFNAHandleNo
					Number: nOurRootHandleNo
					!
					String: sSqlRootHandle
					String: sBindRootHandle
					String: sIntoRootHandle
					String: sNameRootHandle
					!
					Number: nInd
					Number: nFNARoy
					String: sRoyOwner
					Number: nRoy
					Number: nPercPayable
					Number: nBasePrice
					Boolean: bCallahans
					Boolean: bOwnsRoyalty
					String: sFNACust
					String: sFMNRoyPay
					String: sCstRoyOwnId
				Actions
					Set nOurFNAHandleNo = SqlHandlesGetReferenceNo( 'CUSTFMNFNAROY' )
					Set nOurRootHandleNo = SqlHandlesGetReferenceNo( 'ROOTROYAMT' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSqlFNAHandle = " SELECT 
									  Customer_Master.FNA_Flag, 
									  Customer_Master.Royalty_Owner_Code, 
									  Customer_Type.FMN_Roy_Payable 
									FROM Customer_Type, Customer_Master 
									WHERE Customer_Master.Cust_No = :1 AND 
									Customer_Master.Customer_Type = Customer_Type.Cust_Type "
							Set sNameFNAHandle = 'CUSTFMNFNAROY'
							Set sBindFNAHandle = ':nCustNo'
							Set sIntoFNAHandle = ':sFNACust, :sCstRoyOwnId, :sFMNRoyPay'
							!
							Set sSqlRootHandle = " SELECT Royalty_Owner_Id, Amount_Payable, Percentage_Payable 
									FROM Royalty_Payable
									WHERE Rootstock_Id = :1 "
							Set sNameRootHandle = 'ROOTROYAMT'
							Set sBindRootHandle = ':sRootId'
							Set sIntoRootHandle = ':sRoyOwner, :nRoy, :nPercPayable'
							!
							Set sRoyOwner = ' '
							Set sCstRoyOwnId = ' '
							Set nRoy = 0
							Set nTotRoy = 0
							Set nFNARoy = 0
							Set sFNACust = 'N'
							Set bCallahans = FALSE
							Set sFMNRoyPay = 'Y'
							Call haSqlHandles[ nOurFNAHandleNo ].Setup( sSqlFNAHandle, sNameFNAHandle, sBindFNAHandle, sIntoFNAHandle )
							Call SqlVarSetup( haSqlHandles[ nOurFNAHandleNo ].hSqlHandle )
							!
							If nCustNo > 0
								If haSqlHandles[ nOurFNAHandleNo ].Execute( )
									Call haSqlHandles[ nOurFNAHandleNo ].FetchNext( nInd )
								Else
									Return FALSE
							!
							Call GetItemBasePrice( nItemNo, nBasePrice, SH_cls_Execute )
							!
							Call haSqlHandles[ nOurRootHandleNo ].Setup( sSqlRootHandle, sNameRootHandle, sBindRootHandle, sIntoRootHandle )
							Call SqlVarSetup( haSqlHandles[ nOurRootHandleNo ].hSqlHandle )
							Set bOwnsRoyalty = FALSE
							If haSqlHandles[ nOurRootHandleNo ].Execute( )
								While haSqlHandles[ nOurRootHandleNo ].FetchNext( nInd )
									If nPercPayable > 0
										Set nRoy = nBasePrice * ( nPercPayable / 100 )
									!
									! This next Fna check is the one where the customer has his royalties accumulated
											if the owner is FMN or FNA 
									If sRoyOwner = sCstRoyOwnId
										Set bOwnsRoyalty = TRUE
									If sFNACust = 'Y'
										If (sRoyOwner = 'FMN' OR sRoyOwner = 'FNA')  
											Set nFNARoy = nFNARoy + nRoy
										Else
											Set nTotRoy = nTotRoy + nRoy
										If sRoyOwner = 'MC'
											Set bCallahans = TRUE
									Else If sRoyOwner = 'FMN'
										If sFMNRoyPay != 'N'
											Set nTotRoy = nTotRoy + nRoy
									Else If sRoyOwner = 'FNA'
										If sFNACust != 'Y'
											Set nTotRoy = nTotRoy + nRoy
									Else
										Set nTotRoy = nTotRoy + nRoy
								! We need to be able to code for the 94 season - FNA prices are to be a total
										of the FNA and FMN portion and halved as the FMN portion is the larger
										portion and Flemings want to give FNA customers cheaper trees than their
										portion deducted off the price would give - except for anything owned by Callahans
								If sFNACust = 'Y'
									If NOT bCallahans
										Set nFNARoy = nFNARoy/2
										! To round off to 2 decimal places
										Set nFNARoy = nFNARoy + .005
										Set nFNARoy = SalNumberTruncate( nFNARoy, 10, 2 )
									Set nTotRoy = nTotRoy + nFNARoy
								If bOwnsRoyalty
									Set nTotRoy = 0
								Set nTotRoy = RoundTo2Decimals( nTotRoy )
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Call haSqlHandles[ nOurFNAHandleNo ].Disconnect( )
							Call haSqlHandles[ nOurRootHandleNo ].Disconnect( )
							Call GetItemBasePrice( 0, nBasePrice, SH_cls_Disconnect )
							Return TRUE
			Function: CalcCultivarRoyalty
				Description: To find out if there are cultivar royalties applicable to this item
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					String: sCultId
					Number: nItemNo
					Receive Number: nTotRoy
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurFNAHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcOurCultHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSqlFNAHandle
					String: sBindFNAHandle
					String: sIntoFNAHandle
					String: sNameFNAHandle
					Number: nOurFNAHandleNo
					Number: nOurCultHandleNo
					!
					String: sSqlCultHandle
					String: sBindCultHandle
					String: sIntoCultHandle
					String: sNameCultHandle
					!
					Number: nInd
					Number: nFNARoy
					String: sRoyOwner
					String: sCstRoyOwnId
					Number: nRoy
					Number: nPercPayable
					Number: nBasePrice
					Boolean: bCallahans
					Boolean: bOwnsRoyalty
					String: sFNACust
					String: sFMNRoyPay
				Actions
					Set nOurFNAHandleNo = SqlHandlesGetReferenceNo( 'CUSTFMNFNAROY' )
					Set nOurCultHandleNo = SqlHandlesGetReferenceNo( 'CULTROYAMT' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSqlFNAHandle = " SELECT 
									  Customer_Master.FNA_Flag, 
									  Customer_Master.Royalty_Owner_Code, 
									  Customer_Type.FMN_Roy_Payable 
									FROM Customer_Type, Customer_Master 
									WHERE Customer_Master.Cust_No = :1 AND 
									Customer_Master.Customer_Type = Customer_Type.Cust_Type "
							Set sNameFNAHandle = 'CUSTFMNFNAROY'
							Set sBindFNAHandle = ':nCustNo'
							Set sIntoFNAHandle = ':sFNACust, :sCstRoyOwnId, :sFMNRoyPay'
							!
							Set sSqlCultHandle = " SELECT Royalty_Owner_Id, Amount_Payable, Percentage_Payable  
									FROM Royalty_Payable
									WHERE Cultivar_Id = :1 "
							Set sNameCultHandle = 'CULTROYAMT'
							Set sBindCultHandle = ':sCultId'
							Set sIntoCultHandle = ':sRoyOwner, :nRoy, :nPercPayable'
							!
							Set sRoyOwner = ' '
							Set sCstRoyOwnId = ' '
							Set nRoy = 0
							Set nTotRoy = 0
							Set nFNARoy = 0
							Set sFNACust = 'N'
							Set bCallahans = FALSE
							Set sFMNRoyPay = 'Y'
							Call haSqlHandles[ nOurFNAHandleNo ].Setup( sSqlFNAHandle, sNameFNAHandle, sBindFNAHandle, sIntoFNAHandle )
							Call SqlVarSetup( haSqlHandles[ nOurFNAHandleNo ].hSqlHandle )
							!
							If nCustNo > 0
								If haSqlHandles[ nOurFNAHandleNo ].Execute( )
									Call haSqlHandles[ nOurFNAHandleNo ].FetchNext( nInd )
								Else
									Return FALSE
							!
							Call GetItemBasePrice( nItemNo, nBasePrice, SH_cls_Execute )
							!
							Call haSqlHandles[ nOurCultHandleNo ].Setup( sSqlCultHandle, sNameCultHandle, sBindCultHandle, sIntoCultHandle )
							Call SqlVarSetup( haSqlHandles[ nOurCultHandleNo ].hSqlHandle )
							Set bOwnsRoyalty = FALSE
							If haSqlHandles[ nOurCultHandleNo ].Execute( )
								While haSqlHandles[ nOurCultHandleNo ].FetchNext( nInd )
									If nPercPayable > 0
										Set nRoy = nBasePrice * ( nPercPayable / 100 )
									!
									! This next Fna check is the one where the customer has his royalties accumulated
											if the owner is FMN or FNA 
									If sRoyOwner = sCstRoyOwnId
										Set bOwnsRoyalty = TRUE
									If sFNACust = 'Y'
										If (sRoyOwner = 'FMN' OR sRoyOwner = 'FNA')  
											Set nFNARoy = nFNARoy + nRoy
										Else
											Set nTotRoy = nTotRoy + nRoy
										If sRoyOwner = 'MC'
											Set bCallahans = TRUE
									Else If sRoyOwner = 'FMN'
										If sFMNRoyPay != 'N'
											Set nTotRoy = nTotRoy + nRoy
									Else If sRoyOwner = 'FNA'
										If sFNACust != 'Y'
											Set nTotRoy = nTotRoy + nRoy
									Else
										Set nTotRoy = nTotRoy + nRoy
								! We need to be able to code for the 94 season - FNA prices are to be a total
										of the FNA and FMN portion and halved as the FMN portion is the larger
										portion and Flemings want to give FNA customers cheaper trees than their
										portion deducted off the price would give
								If sFNACust = 'Y'
									If NOT bCallahans
										Set nFNARoy = nFNARoy/2
										! To round off to 2 decimal places
										Set nFNARoy = nFNARoy + .005
										Set nFNARoy = SalNumberTruncate( nFNARoy, 10, 2 )
									Set nTotRoy = nTotRoy + nFNARoy
								If bOwnsRoyalty
									Set nTotRoy = 0
								Set nTotRoy = RoundTo2Decimals( nTotRoy )
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Call haSqlHandles[ nOurFNAHandleNo ].Disconnect( )
							Call haSqlHandles[ nOurCultHandleNo ].Disconnect( )
							Call GetItemBasePrice( 0, nBasePrice, SH_cls_Disconnect )
							Return TRUE
			!

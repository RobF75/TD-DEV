					Select Case nActionType
						Case SH_cls_Execute
							If nYear < WhichSeasonYear( SalDateCurrent(  ) ) AND nYear != 77
								Set sSql = " UPDATE Cust_Order_History   
										  SET  
										    Batch_Year_Of_Sale = NULL, 
										    Batch_Location_Id = NULL 
										  WHERE 
										    Batch_Year_Of_Sale = :1 AND 
										    Batch_Location_Id = :2 AND 
										    Invoiced_Flag = 'Y' "
								Set sName = 'HCLRBCHCSTINVORD'
								Set sBind = ':nYear, :nLocationId'
								Set sInto = ''
								Call haSqlHandles[ nOurHistHandleNo ].Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( haSqlHandles[ nOurHistHandleNo ].hSqlHandle )
								!
								If haSqlHandles[ nOurHistHandleNo ].Execute( )
									Return TRUE
								Else
									Return FALSE
							Else
								Set sSql = " UPDATE Customer_Order  
										  SET  
										    Batch_Year_Of_Sale = NULL, 
										    Batch_Location_Id = NULL 
										  WHERE 
										    Batch_Year_Of_Sale = :1 AND 
										    Batch_Location_Id = :2 AND 
										    Invoiced_Flag = 'Y' "
								Set sName = 'CLRBCHCSTINVORD'
								Set sBind = ':nYear, :nLocationId'

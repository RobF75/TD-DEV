								Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
								!
								If haSqlHandles[ nOurHandleNo ].Execute( )
									Return TRUE
								Else
									Return FALSE
						Case SH_cls_Commit
							Call haSqlHandles[ nOurHandleNo ].Commit( )
							Call haSqlHandles[ nOurHistHandleNo ].Commit( )
							Return TRUE
						Case SH_cls_Rollback
							Call haSqlHandles[ nOurHandleNo ].Rollback( )
							Call haSqlHandles[ nOurHistHandleNo ].Rollback( )

			Function: DiffBWGrowSaleCustOrders
				Description:
				Returns
					Boolean:
				Parameters
					Number: nYear
					Number: nLocationId
					Receive Number: nForwardOrder
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcOurHistHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Number: nOurHistHandleNo
					Number: nInd
					Number: nGotSum
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETFWDCUSTORD' )
					Set nOurHistHandleNo = SqlHandlesGetReferenceNo( 'GETFWDCUSTORDH' )
					Select Case nActionType
						Case SH_cls_Execute
							If nYear < WhichSeasonYear( SalDateCurrent(  ) ) AND nYear != 77
								Set sSql = " SELECT 
										  SUM( @IF(@ISNA( Conf_Amt ), Ordered_Amount, Conf_Amt ) )
										FROM 
										  Cust_Order_History
										WHERE 
										  ( Invoiced_Flag = 'N' OR 
										    Invoiced_Flag IS NULL ) AND 
										  Batch_Year_Of_Sale = :1 AND 
										  Batch_Location_Id = :2 
										ORDER BY 
										  Batch_Year_Sale, 
										  Batch_Location_Id "
								Set sName = 'GETFWDCUSTORDH'
								Set sBind = ':nYear, :nLocationId'
								Set sInto = ':nGotSum'
								Call haSqlHandles[ nOurHistHandleNo ].Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( haSqlHandles[ nOurHistHandleNo ].hSqlHandle )
								!
								Set nGotSum = NUMBER_Null
								!
								If haSqlHandles[ nOurHistHandleNo ].Execute( )
									Call haSqlHandles[ nOurHistHandleNo ].FetchNext( nInd )
									If nGotSum != nForwardOrder
										Set nForwardOrder = nGotSum
										Return TRUE
									Else
										Return FALSE
								Else
									Return FALSE
							Else
								Set sSql = " SELECT 
										  SUM( @IF(@ISNA( Conf_Amt ), Ordered_Amount, Conf_Amt ) )
										FROM 
										  Customer_Order
										WHERE 
										      ( Invoiced_Flag = 'N' OR 
										    Invoiced_Flag IS NULL )
										AND BATCH_YEAR_OF_SALE = :1
										 AND BATCH_LOCATION_ID = :2 "
								Set sName = 'GETFWDCUSTORD'
								Set sBind = ':nYear, :nLocationId'
								Set sInto = ':nGotSum'
								Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
								!
								Set nGotSum = NUMBER_Null
								!
								If haSqlHandles[ nOurHandleNo ].Execute( )
									Call haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									If nGotSum != nForwardOrder
										Set nForwardOrder = nGotSum
										Return TRUE
									Else
										Return FALSE
								Else
									Return FALSE
						Case SH_cls_Disconnect
							Call haSqlHandles[ nOurHandleNo ].Disconnect( )
							Call haSqlHandles[ nOurHistHandleNo ].Disconnect( )
							Return TRUE
			Function: GetItemDiscPerc
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Receive Number: nBudDiscPerc
					Receive Number: nFirstSecDiscPerc
					Receive Number: nSecGrDiscPerc
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Number: nInd
					!
					Number: nGotBudDiscPerc
					Number: nGotFirstSecDiscPerc
					Number: nGotSecGrDiscPerc
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETITMDISCPERC' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = ' SELECT 
									  Bud_Disc_Perc, 
									  First_Sec_Disc_Per, 
									  Sec_Gr_Disc_Per 
									FROM 
									  Stock_Item
									WHERE 
									   Item_No = :1 '
							Set sName = 'GETITMDISCPERC'
							Set sBind = ':nItemNo'
							Set sInto = ':nGotBudDiscPerc, :nGotFirstSecDiscPerc, :nGotSecGrDiscPerc'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nBudDiscPerc = NUMBER_Null
							Set nFirstSecDiscPerc = NUMBER_Null
							Set nSecGrDiscPerc = NUMBER_Null
							Set nGotBudDiscPerc = NUMBER_Null
							Set nGotFirstSecDiscPerc = NUMBER_Null
							Set nGotSecGrDiscPerc = NUMBER_Null
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set nBudDiscPerc = nGotBudDiscPerc
									Set nFirstSecDiscPerc = nGotFirstSecDiscPerc
									Set nSecGrDiscPerc = nGotSecGrDiscPerc
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )

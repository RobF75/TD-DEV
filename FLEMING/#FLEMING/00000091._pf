			!
			Function: UpdtDenormStckItmFields
				Description:
				Returns
					Boolean:
				Parameters
					! naItemNos[*] is a number_null terminated array
					Number: naItemNos[*]
					! sItemType = 'SELECTED' Default OR 'ALL'
					String: sItemType
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurTrTypeHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcOurCultHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcOurRootHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcOurRoyPaidTrTypeHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcOurRoyPaidCultHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcOurRoyPaidRootHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcOurRoyPaidCltRtDescHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					Number: nOurTrTypeHandleNo
					Number: nOurCultHandleNo
					Number: nOurRootHandleNo
					Number: nOurRoyPaidTrTypeHandleNo
					Number: nOurRoyPaidCultHandleNo
					Number: nOurRoyPaidRootHandleNo
					Number: nOurRoyPaidCltRtDescHandleNo
					String: sSql
					Number: nInd
					Boolean: bOk
					: fcTotalMeter
						Class: clsMeterBar
					: fcTrTypeMeter
						Class: clsMeterBar
					: fcCultMeter
						Class: clsMeterBar
					: fcRootMeter
						Class: clsMeterBar
					: fcRoyPaidTrTypeMeter
						Class: clsMeterBar
					: fcRoyPaidCultMeter
						Class: clsMeterBar
					: fcRoyPaidRootMeter
						Class: clsMeterBar
					: fcRoyPaidCltRtDescMeter
						Class: clsMeterBar
					Number: nTotal
					String: sItemNoList
					!
					String: sGotTreeType
					String: sGotTreeTypeDesc
					String: sGotTypeDesc
					!
					String: sGotCultId
					String: sGotVarietyType
					String: sGotVariety
					String: sGotCultDesc
					String: sGotCVNotSaleFlag
					String: sGotCVNonPropFlag
					String: sGotCVProdRoy
					String: sGotCVTest
					String: sGotRTTest
					!
					String: sGotRootId
					String: sGotRootDesc
					String: sGotRTNotSaleFlag
					String: sGotRTNonPropFlag
					!
					String: sGotCultRootType
					String: sGotCultRootDesc
					String: sGotCustName
					Number: nGotInvNo
					String: sGotRoyaltyOwnerId
					Date/Time: dtGotPaidDateTime
				Actions
					Set nOurTrTypeHandleNo = SqlHandlesGetReferenceNo( 'TrType' )
					Set nOurCultHandleNo = SqlHandlesGetReferenceNo( 'Cult1' )
					Set nOurRootHandleNo = SqlHandlesGetReferenceNo( 'Root' )
					Set nOurRoyPaidTrTypeHandleNo = SqlHandlesGetReferenceNo( 'RoyPaidTrType' )
					Set nOurRoyPaidCultHandleNo = SqlHandlesGetReferenceNo( 'RoyPaidCult' )
					Set nOurRoyPaidRootHandleNo = SqlHandlesGetReferenceNo( 'RoyPaidRoot' )
					Set nOurRoyPaidCltRtDescHandleNo = SqlHandlesGetReferenceNo( 'RoyPaidCltRtDesc' )
					Select Case nActionType
						Case SH_cls_Execute
							If sItemType = 'SELECTED'
								Call MakeNumberList( naItemNos, 0, ', ', '', sItemNoList )
							Else
								Set sItemNoList =''
							!
							If sItemType = 'SELECTED'
								Set sSql = " SELECT DISTINCT 
										  Stock_Item.Tree_Type, 
										  Tree_Type.Tree_Type_Desc, 
										  Tree_Type.Type_Description 
										FROM 
										  Stock_Item, 
										  Tree_Type  
										INTO 
										  :sGotTreeType, 
										  :sGotTreeTypeDesc, 
										  :sGotTypeDesc 
										WHERE 
										  Stock_Item.Item_No IN ( " || sItemNoList || " ) AND 
										  Stock_Item.Tree_Type = Tree_Type.Tree_Type AND 
										  ( 
										    NOT Stock_Item.Tree_Type_Desc = Tree_Type.Tree_Type_Desc OR 
										    Stock_Item.Tree_Type_Desc IS NULL OR 
										    NOT Stock_Item.Type_Description = Tree_Type.Type_Description OR 
										    Stock_Item.Type_Description IS NULL 
										  ) "
							Else
								Set sSql = " SELECT DISTINCT 
										  Stock_Item.Tree_Type, 
										  Tree_Type.Tree_Type_Desc, 
										  Tree_Type.Type_Description 
										FROM 
										  Stock_Item, 
										  Tree_Type 
										INTO 
										  :sGotTreeType, 
										  :sGotTreeTypeDesc, 
										  :sGotTypeDesc 
										WHERE 
										  Stock_Item.Tree_Type = Tree_Type.Tree_Type AND 
										  ( 
										    NOT Stock_Item.Tree_Type_Desc = Tree_Type.Tree_Type_Desc OR 
										    Stock_Item.Tree_Type_Desc IS NULL OR 
										    NOT Stock_Item.Type_Description = Tree_Type.Type_Description OR 
										    Stock_Item.Type_Description IS NULL 
										  ) "
							Call haSqlHandles[ nOurTrTypeHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurTrTypeHandleNo ].hSqlHandle )
							!
							If sItemType = 'SELECTED'
								Set sSql = " SELECT DISTINCT 
										  Stock_Item.Cultivar_Id, 
										  Cultivar.Variety_Type, 
										  Cultivar.Variety, 
										  Cultivar.Cult_Desc, 
										  Cultivar.CV_Not_Sale_Flag, 
										  Cultivar.CV_Non_Prop_Flag,
										  Cultivar.Prod_Royalty,
										  Cultivar.cv_on_trial_flag
										FROM 
										  Stock_Item, 
										  Cultivar 
										INTO 
										  :sGotCultId, 
										  :sGotVarietyType, 
										  :sGotVariety, 
										  :sGotCultDesc, 
										  :sGotCVNotSaleFlag, 
										  :sGotCVNonPropFlag,
										  :sGotCVProdRoy,
										 :sGotCVTest
										WHERE 
										  Stock_Item.Item_No IN ( " || sItemNoList || " ) AND 
										  Stock_Item.Cultivar_Id = Cultivar.Cult_Id AND 
										( 
										  NOT Stock_Item.Variety_Type = Cultivar.Variety_Type OR 
										  Stock_Item.Variety_Type IS NULL OR 
										  NOT Stock_Item.Variety = Cultivar.Variety OR 
										  Stock_Item.Variety IS NULL OR 
										  NOT Stock_Item.Cult_Desc = Cultivar.Cult_Desc OR 
										  Stock_Item.Cult_Desc IS NULL OR 
										  NOT Stock_Item.CV_Not_Sale_Flag = Cultivar.CV_Not_Sale_Flag OR 
										  Stock_Item.CV_Not_Sale_Flag IS NULL OR 
										  NOT Stock_Item.CV_Non_Prop_Flag = Cultivar.CV_Non_Prop_Flag OR
										  Stock_Item.CV_Non_Prop_Flag IS NULL or
										  NOT Stock_Item.Prod_Royalty = Cultivar.Prod_Royalty OR
										  Stock_Item.Prod_Royalty IS NULL or
										  NOT Stock_Item.cv_on_trial_flag = Cultivar.cv_on_trial_flag OR
										  Stock_Item.cv_on_trial_flag IS NULL
										
										) "
							Else
								Set sSql = " SELECT DISTINCT 
										  Stock_Item.Cultivar_Id, 
										  Cultivar.Variety_Type, 
										  Cultivar.Variety, 
										  Cultivar.Cult_Desc, 
										  Cultivar.CV_Not_Sale_Flag, 
										  Cultivar.CV_Non_Prop_Flag,
										  Cultivar.Prod_Royalty ,
										 Cultivar.cv_on_trial_flag
										FROM 
										  Stock_Item, 
										  Cultivar 
										INTO 
										  :sGotCultId, 
										  :sGotVarietyType, 
										  :sGotVariety, 
										  :sGotCultDesc, 
										  :sGotCVNotSaleFlag, 
										  :sGotCVNonPropFlag,
										  :sGotCVProdRoy,
										:sGotCVTest
										WHERE 
										  Stock_Item.Cultivar_Id = Cultivar.Cult_Id AND 
										( 
										  NOT Stock_Item.Variety_Type = Cultivar.Variety_Type OR 
										  Stock_Item.Variety_Type IS NULL OR 
										  NOT Stock_Item.Variety = Cultivar.Variety OR 
										  Stock_Item.Variety IS NULL OR 
										  NOT Stock_Item.Cult_Desc = Cultivar.Cult_Desc OR 
										  Stock_Item.Cult_Desc IS NULL OR 
										  NOT Stock_Item.CV_Not_Sale_Flag = Cultivar.CV_Not_Sale_Flag OR 
										  Stock_Item.CV_Not_Sale_Flag IS NULL OR 
										  NOT Stock_Item.CV_Non_Prop_Flag = Cultivar.CV_Non_Prop_Flag OR 
										  Stock_Item.CV_Non_Prop_Flag IS NULL or
										  NOT Stock_Item.Prod_Royalty = Cultivar.Prod_Royalty OR
										  Stock_Item.Prod_Royalty IS NULL or
										 NOT Stock_Item.cv_on_trial_flag = Cultivar.cv_on_trial_flag OR
										  Stock_Item.cv_on_trial_flag IS NULL
										
										) "
							Call haSqlHandles[ nOurCultHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurCultHandleNo ].hSqlHandle )
							!
							If sItemType = 'SELECTED'
								Set sSql = " SELECT DISTINCT 
										  Stock_Item.Rootstock_Id, 
										  Rootstock.Root_Desc, 
										  Rootstock.RT_Not_Sale_Flag, 
										  Rootstock.RT_Non_Prop_Flag,
										Rootstock.RT_on_trial_Flag
										FROM 
										  Stock_Item, 
										  Rootstock 
										INTO 
										  :sGotRootId, 
										  :sGotRootDesc, 
										  :sGotRTNotSaleFlag, 
										  :sGotRTNonPropFlag,
										:sGotRTTest
										WHERE 
										  Stock_Item.Item_No IN ( " || sItemNoList || " ) AND 
										  Stock_Item.Rootstock_Id = Rootstock.Root_Id AND 
										( 
										  NOT Stock_Item.Root_Desc = Rootstock.Root_Desc OR 
										  Stock_Item.Root_Desc IS NULL OR 
										  NOT Stock_Item.RT_Not_Sale_Flag = Rootstock.RT_Not_Sale_Flag OR 
										  Stock_Item.RT_Not_Sale_Flag IS NULL OR 
										  NOT Stock_Item.RT_Non_Prop_Flag = Rootstock.RT_Non_Prop_Flag OR 
										  Stock_Item.RT_Non_Prop_Flag IS NULL OR 
										  NOT Stock_Item.RT_on_trial_Flag = Rootstock.RT_on_trial_Flag OR 
										  Stock_Item.RT_on_trial_Flag IS NULL 
										) "
							Else
								Set sSql = " SELECT DISTINCT 
										  Stock_Item.Rootstock_Id, 
										  Rootstock.Root_Desc, 
										  Rootstock.RT_Not_Sale_Flag, 
										  Rootstock.RT_Non_Prop_Flag ,
										Rootstock.RT_on_trial_Flag
										FROM 
										  Stock_Item, 
										  Rootstock 
										INTO 
										  :sGotRootId, 
										  :sGotRootDesc, 
										  :sGotRTNotSaleFlag, 
										  :sGotRTNonPropFlag,
										:sGotRTTest
										WHERE 
										  Stock_Item.Rootstock_Id = Rootstock.Root_Id AND 
										( 
										  NOT Stock_Item.Root_Desc = Rootstock.Root_Desc OR 
										  Stock_Item.Root_Desc IS NULL OR 
										  NOT Stock_Item.RT_Not_Sale_Flag = Rootstock.RT_Not_Sale_Flag OR 
										  Stock_Item.RT_Not_Sale_Flag IS NULL OR 
										  NOT Stock_Item.RT_Non_Prop_Flag = Rootstock.RT_Non_Prop_Flag OR 
										  Stock_Item.RT_Non_Prop_Flag IS NULL OR 
										  NOT Stock_Item.RT_on_trial_Flag = Rootstock.RT_on_trial_Flag OR 
										  Stock_Item.RT_on_trial_Flag IS NULL 
										) "
							Call haSqlHandles[ nOurRootHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurRootHandleNo ].hSqlHandle )
							!
							If sItemType = 'SELECTED'
								Set sSql = " SELECT DISTINCT 
										  Royalties_Paid.Tree_Type, 
										  Tree_Type.Tree_Type_Desc
										FROM 
										  Royalties_Paid, 
										  Tree_Type 
										INTO 
										  :sGotTreeType, 
										  :sGotTreeTypeDesc 
										WHERE 
										  Royalties_Paid.Stock_Item_No IN ( " || sItemNoList || " )  AND 
										  Royalties_Paid.Tree_Type = Tree_Type.Tree_Type AND 
										(
										  NOT Royalties_Paid.Tree_Type_Desc = Tree_Type.Tree_Type_Desc OR 
										  Royalties_Paid.Tree_Type_Desc IS NULL
										)"
							Else
								Set sSql = " SELECT DISTINCT 
										  Royalties_Paid.Tree_Type, 
										  Tree_Type.Tree_Type_Desc
										FROM 
										  Royalties_Paid, 
										  Tree_Type 
										INTO 
										  :sGotTreeType, 
										  :sGotTreeTypeDesc 
										WHERE 
										  Royalties_Paid.Tree_Type = Tree_Type.Tree_Type AND 
										(
										  NOT Royalties_Paid.Tree_Type_Desc = Tree_Type.Tree_Type_Desc OR 
										  Royalties_Paid.Tree_Type_Desc IS NULL
										)"
							Call haSqlHandles[ nOurRoyPaidTrTypeHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurRoyPaidTrTypeHandleNo ].hSqlHandle )
							!
							If sItemType = 'SELECTED'
								Set sSql = " SELECT DISTINCT 
										  Royalties_Paid.Cult_Root_Id, 
										  Cultivar.Cult_Desc
										FROM 
										  Royalties_Paid, 
										  Cultivar 
										INTO 
										  :sGotCultId, 
										  :sGotCultDesc 
										WHERE 
										    Royalties_Paid.Cult_Root_Type = 'C' AND
										    Royalties_Paid.Stock_Item_No IN ( " || sItemNoList || " ) AND 
										  Royalties_Paid.Cult_Root_Id = Cultivar.Cult_Id AND 
										(
										  NOT Royalties_Paid.Cult_Desc = Cultivar.Cult_Desc OR 
										  NOT Royalties_Paid.Cult_Root_Desc = Cultivar.Cult_Desc OR 
										  Royalties_Paid.Cult_Desc IS NULL OR 
										  Royalties_Paid.Cult_Root_Desc IS NULL
										) "
							Else
								Set sSql = " SELECT DISTINCT 
										  Royalties_Paid.Cult_Root_Id, 
										  Cultivar.Cult_Desc
										FROM 
										  Royalties_Paid, 
										  Cultivar 
										INTO 
										  :sGotCultId, 
										  :sGotCultDesc 
										WHERE 
										  Royalties_Paid.Cult_Root_Type = 'C' AND 
										  Royalties_Paid.Cult_Root_Id = Cultivar.Cult_Id AND 
										(
										  NOT Royalties_Paid.Cult_Desc = Cultivar.Cult_Desc OR 
										  NOT Royalties_Paid.Cult_Root_Desc = Cultivar.Cult_Desc OR 
										  Royalties_Paid.Cult_Desc IS NULL OR 
										  Royalties_Paid.Cult_Root_Desc IS NULL
										) "
							Call haSqlHandles[ nOurRoyPaidCultHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurRoyPaidCultHandleNo ].hSqlHandle )
							!
							If sItemType = 'SELECTED'
								Set sSql = " SELECT DISTINCT 
										  Royalties_Paid.Cult_Root_Id, 
										  Rootstock.Root_Desc
										FROM 
										  Royalties_Paid, 
										  Rootstock 
										INTO 
										  :sGotRootId, 
										  :sGotRootDesc 
										WHERE 
										  Royalties_Paid.Cult_Root_Type = 'R' AND 
										  Royalties_Paid.Stock_Item_No IN ( " || sItemNoList || " ) AND 
										  Royalties_Paid.Cult_Root_Id = Rootstock.Root_Id AND 
										(
										  NOT Royalties_Paid.Root_Desc = Rootstock.Root_Desc OR 
										  NOT Royalties_Paid.Cult_Root_Desc = Rootstock.Root_Desc OR 
										  Royalties_Paid.Root_Desc IS NULL OR 
										  Royalties_Paid.Cult_Root_Desc IS NULL
										) "
							Else
								Set sSql = " SELECT DISTINCT 
										  Royalties_Paid.Cult_Root_Id, 
										  Rootstock.Root_Desc
										FROM 
										  Royalties_Paid, 
										  Rootstock 
										INTO 
										  :sGotRootId, 
										  :sGotRootDesc 
										WHERE 
										  Royalties_Paid.Cult_Root_Type = 'R' AND 
										  Royalties_Paid.Cult_Root_Id = Rootstock.Root_Id AND 
										(
										  NOT Royalties_Paid.Root_Desc = Rootstock.Root_Desc OR 
										  NOT Royalties_Paid.Cult_Root_Desc = Rootstock.Root_Desc OR 
										  Royalties_Paid.Root_Desc IS NULL OR 
										  Royalties_Paid.Cult_Root_Desc IS NULL
										) "
							Call haSqlHandles[ nOurRoyPaidRootHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurRoyPaidRootHandleNo ].hSqlHandle )
							!
							If TRUE
								Set sSql = " SELECT 
										  Cult_Root_Type, 
										  Cult_Root_Desc, 
										  Cust_Name, 
										  Inv_No, 
										  Royalty_Owner_Id, 
										  Paid_Date_Time, 
										  Cult_Desc, 
										  Root_Desc 
										FROM 
										  Royalties_Paid 
										INTO 
										  :sGotCultRootType, 
										  :sGotCultRootDesc, 
										  :sGotCustName, 
										  :nGotInvNo, 
										  :sGotRoyaltyOwnerId, 
										  :dtGotPaidDateTime, 
										  :sGotCultDesc, 
										  :sGotRootDesc 
										WHERE 
										 (
										  Cult_Root_Type = 'C' AND 
										  NOT Cult_Root_Desc = Cult_Desc 
										 ) OR 
										 (
										  Cult_Root_Type = 'R' AND 
										  NOT Cult_Root_Desc = Root_Desc 
										 ) "
							Call haSqlHandles[ nOurRoyPaidCltRtDescHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurRoyPaidCltRtDescHandleNo ].hSqlHandle )
							!
							Set bOk = TRUE
							Call fcTotalMeter.Setup( 'Updating Denorm. Stock Items fields', 7 )
							!
							If haSqlHandles[ nOurTrTypeHandleNo ].PrepareAndExecute( )
								Call fcTotalMeter.Increment( 1 )
								Call haSqlHandles[ nOurTrTypeHandleNo ].ResultSetCount( nTotal )
								Call fcTrTypeMeter.Setup( 'Updating Denorm. Stock Items Tree Type fields', nTotal )
								While haSqlHandles[ nOurTrTypeHandleNo ].FetchNext( nInd ) AND bOk
									If UpdtStckItmTrTypeDenormFields( sGotTreeType, sGotTreeTypeDesc, sGotTypeDesc, SH_cls_Execute )
										Call UpdtStckItmTrTypeDenormFields( '', '', '', SH_cls_Commit )
									Else
										Set bOk = FALSE
									Call fcTrTypeMeter.Increment( 1 )
								Call fcTrTypeMeter.End( )
							Else
								Set bOk = FALSE
								Call fcTotalMeter.Increment( 1 )
							!
							If haSqlHandles[ nOurCultHandleNo ].PrepareAndExecute( )
								Call fcTotalMeter.Increment( 1 )
								Call haSqlHandles[ nOurCultHandleNo ].ResultSetCount( nTotal )
								Call fcCultMeter.Setup( 'Updating Denorm. Stock Items cultivar fields', nTotal )
								While haSqlHandles[ nOurCultHandleNo ].FetchNext( nInd ) AND bOk
									If UpdtStckItmCultDenormFields( sGotCultId, sGotVarietyType, sGotVariety, sGotCultDesc, sGotCVNotSaleFlag, sGotCVNonPropFlag, sGotCVProdRoy, sGotCVTest, SH_cls_Execute )
										Call UpdtStckItmCultDenormFields( '', '', '', '', '', '', '', '', SH_cls_Commit )
									Else
										Call SalMessageBox('Error Updating stock item fields','Error UpdtDenormStckItmFields',MB_Ok)
										Set bOk = FALSE
									Call fcCultMeter.Increment( 1 )
								Call fcCultMeter.End( )
							Else
								Set bOk = FALSE
								Call fcTotalMeter.Increment( 1 )
							!
							If haSqlHandles[ nOurRootHandleNo ].PrepareAndExecute( )
								Call fcTotalMeter.Increment( 1 )
								Call haSqlHandles[ nOurRootHandleNo ].ResultSetCount( nTotal )
								Call fcRootMeter.Setup( 'Updating Denorm. Stock Items rootstock fields', nTotal )
								While haSqlHandles[ nOurRootHandleNo ].FetchNext( nInd ) AND bOk
									If UpdtStckItmRootDenormFields( sGotRootId, sGotRootDesc, sGotRTNotSaleFlag, sGotRTNonPropFlag, sGotRTTest, SH_cls_Execute )
										Call UpdtStckItmRootDenormFields( '', '', '', '', '', SH_cls_Commit )
									Else
										Set bOk = FALSE
									Call fcRootMeter.Increment( 1 )
								Call fcRootMeter.End( )
							Else
								Set bOk = FALSE
								Call fcTotalMeter.Increment( 1 )
							!
							If haSqlHandles[ nOurRoyPaidTrTypeHandleNo ].PrepareAndExecute( )
								Call fcTotalMeter.Increment( 1 )
								Call haSqlHandles[ nOurRoyPaidTrTypeHandleNo ].ResultSetCount( nTotal )
								Call fcRoyPaidTrTypeMeter.Setup( 'Updating Denorm. Royalties Paid Tree Type fields', nTotal )
								While haSqlHandles[ nOurRoyPaidTrTypeHandleNo ].FetchNext( nInd ) AND bOk
									If UpdtRoyPaidTrTypeDenormFields( sGotTreeType, sGotTreeTypeDesc, SH_cls_Execute )
										Call UpdtRoyPaidTrTypeDenormFields( '', '', SH_cls_Commit )
									Else
										Set bOk = FALSE
									Call fcRoyPaidTrTypeMeter.Increment( 1 )
								Call fcRoyPaidTrTypeMeter.End( )
							Else
								Set bOk = FALSE
								Call fcTotalMeter.Increment( 1 )
							!
							If haSqlHandles[ nOurRoyPaidCultHandleNo ].PrepareAndExecute( )
								Call fcTotalMeter.Increment( 1 )
								Call haSqlHandles[ nOurRoyPaidCultHandleNo ].ResultSetCount( nTotal )
								Call fcRoyPaidCultMeter.Setup( 'Updating Denorm. Royalties Paid cultivar fields', nTotal )
								While haSqlHandles[ nOurRoyPaidCultHandleNo ].FetchNext( nInd ) AND bOk
									If UpdtRoyPaidCultDenormFields( sGotCultId, sGotCultDesc, SH_cls_Execute )
										Call UpdtRoyPaidCultDenormFields( '', '', SH_cls_Commit )
									Else
										Set bOk = FALSE
									Call fcRoyPaidCultMeter.Increment( 1 )
								Call fcRoyPaidCultMeter.End( )
							Else
								Set bOk = FALSE
								Call fcTotalMeter.Increment( 1 )
							!
							If haSqlHandles[ nOurRoyPaidRootHandleNo ].PrepareAndExecute( )
								Call fcTotalMeter.Increment( 1 )
								Call haSqlHandles[ nOurRoyPaidRootHandleNo ].ResultSetCount( nTotal )
								Call fcRoyPaidRootMeter.Setup( 'Updating Denorm. Royalties Paid rootstock fields', nTotal )
								While haSqlHandles[ nOurRoyPaidRootHandleNo ].FetchNext( nInd ) AND bOk
									If UpdtRoyPaidRootDenormFields( sGotRootId, sGotRootDesc, SH_cls_Execute )
										Call UpdtRoyPaidRootDenormFields( '', '', SH_cls_Commit )
									Else
										Set bOk = FALSE
									Call fcRoyPaidRootMeter.Increment( 1 )
								Call fcRoyPaidRootMeter.End( )
							Else
								Set bOk = FALSE
								Call fcTotalMeter.Increment( 1 )
							!
							If haSqlHandles[ nOurRoyPaidCltRtDescHandleNo ].PrepareAndExecute( )
								Call fcTotalMeter.Increment( 1 )
								Call haSqlHandles[ nOurRoyPaidCltRtDescHandleNo ].ResultSetCount( nTotal )
								Call fcRoyPaidCltRtDescMeter.Setup( 'Updating Denorm. Royalties Paid cultivar, rootstock key fields', nTotal )
								While haSqlHandles[ nOurRoyPaidCltRtDescHandleNo ].FetchNext( nInd ) AND bOk
									If UpdtRoyPaidCltRtDescDenormFields( sGotCultRootType, sGotCultRootDesc, sGotCustName, nGotInvNo, sGotRoyaltyOwnerId, dtGotPaidDateTime, sGotCultDesc, sGotRootDesc, SH_cls_Execute )
										Call UpdtRoyPaidCltRtDescDenormFields( '', '', '', 0, '', DATETIME_Null, '', '', SH_cls_Commit )
									Else
										Set bOk = FALSE
									Call fcRoyPaidCltRtDescMeter.Increment( 1 )
								Call fcRoyPaidCltRtDescMeter.End( )
							Else
								Set bOk = FALSE
								Call fcTotalMeter.Increment( 1 )
							!
							Call fcTotalMeter.End( )
							Return bOk
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nOurTrTypeHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurCultHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurRootHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurRoyPaidTrTypeHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurRoyPaidCultHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurRoyPaidRootHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurRoyPaidCltRtDescHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT UpdtStckItmTrTypeDenormFields( '', '', '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT UpdtStckItmCultDenormFields( '', '', '', '', '', '', '', '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT UpdtStckItmRootDenormFields( '', '', '', '', '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT UpdtRoyPaidTrTypeDenormFields( '', '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT UpdtRoyPaidCultDenormFields( '', '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT UpdtRoyPaidRootDenormFields( '', '', SH_cls_Disconnect )
								Set bOk = FALSE
							If NOT UpdtRoyPaidCltRtDescDenormFields( '', '', '', 0, '', DATETIME_Null, '', '', SH_cls_Disconnect )
								Set bOk = FALSE
							Return bOk
			Function: UpdtStckItmTrTypeDenormFields
				Description:
				Returns
					Boolean:
				Parameters
					String: sTreeType
					String: sTreeTypeDesc
					String: sTypeDesc
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					Number: nOurHandleNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'UpdtStckItmTrTypeDenormFields' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " UPDATE Stock_Item 
									SET 
									  Tree_Type_Desc = :sTreeTypeDesc, 
									  Type_Description = :sTypeDesc
									WHERE 
									  Stock_Item.Tree_Type = :sTreeType "
							Call haSqlHandles[ nOurHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Return haSqlHandles[ nOurHandleNo ].PrepareAndExecute( )
						Case SH_cls_Commit
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: UpdtStckItmCultDenormFields
				Description:
				Returns
					Boolean:
				Parameters
					String: sCultId
					String: sVarietyType
					String: sVariety
					String: sCultDesc
					String: sCVNotSaleFlag
					String: sCVNonPropFlag
					String: sCVProdRoy
					String: sCVTest
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sCultSql
					Number: nOurHandleNo
					Number: nOurCultHandleNo
					Boolean: bCult
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'UpdtStckItmCultDenormFields3' )
					Set nOurCultHandleNo = SqlHandlesGetReferenceNo( 'UpdtCultDenormFields3' )
					Set bCult = FALSE
					Select Case nActionType
						Case SH_cls_Execute
							! If sCVNotSaleFlag = STRING_Null
								  Set sCVNotSaleFlag = 'N'
								  Set bCult = TRUE
							! If sCVNonPropFlag = STRING_Null
								  Set sCVNonPropFlag = 'N'
								  Set bCult = TRUE
							! If sCVProdRoy = STRING_Null
								  Set sCVProdRoy = 'N'
								  Set bCult = TRUE
							! If sCVTest = STRING_Null
								  Set sCVTest = 'N'
								  Set bCult = TRUE
							! If sRTTest = STRING_Null
								  Set sRTTest = 'N'
								  Set bCult = TRUE
							If TRUE
								Set sSql = " UPDATE Stock_Item 
										SET 
										  Variety_Type = :sVarietyType, 
										  Variety = :sVariety, 
										  Cult_Desc = :sCultDesc, 
										  CV_Not_Sale_Flag = :sCVNotSaleFlag, 
										  CV_Non_Prop_Flag = :sCVNonPropFlag,
										  Prod_Royalty = :sCVProdRoy,
										 cv_on_trial_flag = :sCVTest
										WHERE 
										  Stock_Item.Cultivar_Id = :sCultId "
								! Set sCultSql = " UPDATE Cultivar 
										SET 
										  CV_Not_Sale_Flag = :sCVNotSaleFlag, 
										  CV_Non_Prop_Flag = :sCVNonPropFlag,
										  Prod_Royalty = :sCVProdRoy,
										 cv_on_trial_flag = :sCVTest
										WHERE 
										  Cultivar.Cult_Id = :sCultId "
							Call haSqlHandles[ nOurHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Return haSqlHandles[ nOurHandleNo ].PrepareAndExecute( )
							! Call haSqlHandles[ nOurCultHandleNo ].PrepareSetup( sCultSql )
							! Call SqlVarSetup( haSqlHandles[ nOurCultHandleNo ].hSqlHandle )
							!
							! Return haSqlHandles[ nOurCultHandleNo ].PrepareAndExecute( )
						Case SH_cls_Commit
							If haSqlHandles[ nOurHandleNo ].Commit( )
								Return haSqlHandles[ nOurCultHandleNo ].Commit( )
						Case SH_cls_Rollback
							If haSqlHandles[ nOurHandleNo ].Rollback( )
								Return haSqlHandles[ nOurCultHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							If haSqlHandles[ nOurHandleNo ].Disconnect( )
								Return haSqlHandles[ nOurCultHandleNo ].Disconnect( )

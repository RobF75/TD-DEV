				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set sSQLPopHandle = " SELECT Tree_Type, Tree_Type_Desc 
								FROM Tree_Type 
								WHERE @UPPER( Tree_Type_Desc ) LIKE '%WEEPING%' 
								ORDER BY Tree_Type "
						Set sNAMEPopHandle = 'BRKBNDLXTTYPE'
						Set sBINDPopHandle = ''
						Set sINTOPopHandle = ':frmBrokenBundlesDetails.tblSelectedTreeTypes.colType, :frmBrokenBundlesDetails.tblSelectedTreeTypes.colTypeDesc '
						!
						Set bAddAllowed = TRUE
						Set bSelectFirstRow = FALSE
					On SAM_FetchRowDone
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_New, TRUE )
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_HideMarks, TRUE )
						Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
					On PAM_BRKBNDLD_GETSELECTEDITEMS
						Set nTmp = 0
						Set saExcludingTreeTypes[ nTmp ] = ''
						If TableLoop( hWndForm, hWndForm, PAM_BRKBNDLD_GETSELECTED, 0, 0, 0, 'Extracting Tree Types to exclude.', TBL_cls_LowToHi )
							Return TRUE
						Else
							Return FALSE
					On PAM_BRKBNDLD_GETSELECTED
						Set saExcludingTreeTypes[ nTmp ] = tblSelectedTreeTypes.colType
						Set nTmp = nTmp + 1
						Set saExcludingTreeTypes[ nTmp ] = ''
						Return TRUE

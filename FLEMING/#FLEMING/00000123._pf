				Font Size: Class Default
				Font Enhancement: Class Default
				Text Color: Class Default
				Background Color: Class Default
			Contents
		Contents
		Functions
		Window Parameters
			String: saExcludingTreeTypes[*]
			Number: nCompPerc
			Number: nYear
		Window Variables
			Boolean: bProcessCustomers
			Boolean: bPopulateCustomers
			Boolean: bProcessOrders
			Boolean: bPopulateOrders
			String: sSql
			Number: nInd
			: fcBrkBndlCustHdl
				Class: hcSqlHandle
			: fcReportHdl
				Class: hcSqlHandle
			! hcSqlHandle: fcBrkBndlCustHdl
.winattr class :
				Class: hcSqlHandle
.end
			! Number: nBrkBndlCustNo
			! String: sBrkBndlCustNoList
			String: sExcludingTreeTypesList
			!
			String: sUpperCustName
			String: sVarietyType
			String: sUpperVariety
			String: sUpperCultDesc
			String: sUpperRootDesc
			! Report Columns
			Number: nCustNo
			String: sCustName
			String: sTreeTypeDesc
			String: sCultDesc
			String: sRootDesc
			Number: nOrdAmt
			Number: nConfAmt
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set sReportFileNameNoPath = 'brkbndl2.qrp'
				Set sReportBind = ':frmBrokenBundlesList.nYear, 
						:frmBrokenBundlesList.nCompPerc, 
						:frmBrokenBundlesList.nCustNo, 
						:frmBrokenBundlesList.sCustName, 
						:frmBrokenBundlesList.sTreeTypeDesc, 
						:frmBrokenBundlesList.sCultDesc, 
						:frmBrokenBundlesList.sRootDesc, 
						:frmBrokenBundlesList.nOrdAmt, 
						:frmBrokenBundlesList.nConfAmt'
				Set sReportInto = 'YearOfSale, 
						CompPerc, 
						CustNo, 
						CustName,  
						TreeTypeDesc, 
						CultDesc, 
						RootDesc, 
						OrdAmt, 
						ConfAmt'
				Set sReportType = 'VIEW'
			! On SAM_ReportStart
				 Set sExcludingTreeTypesList = ''
				 Call MakeStringList( saExcludingTreeTypes, ',', "'", sExcludingTreeTypesList )
				!
				 If sExcludingTreeTypesList = ''
					 Set sSql = " SELECT
							  Customer_Order.Cust_No 
							FROM 
							  Customer_Order, 
							  Stock_Item 
							INTO 
							  :frmBrokenBundlesList.nBrkBndlCustNo 
							WHERE
							  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
							  Customer_Order.Year_Of_Sale = :frmBrokenBundlesList.nYear  AND 
							  NOT Stock_Item.Tree_Type LIKE 'C%' 
							GROUP BY 1 
							HAVING 
							  ((SUM( @IF(@MOD( Customer_Order.Ordered_Amount, 5 ), 1, 0)))/
							  (COUNT( Customer_Order.Ordered_Amount ))*100)>= :frmBrokenBundlesList.nCompPerc "
				 Else 
					 Set sSql = " SELECT
							  Customer_Order.Cust_No 
							FROM 
							  Customer_Order, 
							  Stock_Item 
							INTO 
							  :frmBrokenBundlesList.nBrkBndlCustNo 
							WHERE
							  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
							  Customer_Order.Year_Of_Sale = :frmBrokenBundlesList.nYear  AND 
							  NOT Stock_Item.Tree_Type LIKE 'C%' AND 
							  NOT Stock_Item.Tree_Type IN ( " || sExcludingTreeTypesList || " ) 
							GROUP BY 1 
							HAVING 
							  ((SUM( @IF(@MOD( Customer_Order.Ordered_Amount, 5 ), 1, 0)))/
							  (COUNT( Customer_Order.Ordered_Amount ))*100)>= :frmBrokenBundlesList.nCompPerc "
				 Call fcBrkBndlCustHdl.PrepareSetup( sSql )
				 Call SqlVarSetup( fcBrkBndlCustHdl.hSqlHandle )
				 If fcBrkBndlCustHdl.PrepareAndExecute( )
					 Set sBrkBndlCustNoList = ''
					 While fcBrkBndlCustHdl.FetchNext( nInd )
						 If sBrkBndlCustNoList = ''
							 Set sBrkBndlCustNoList = SalNumberToStrX( nBrkBndlCustNo, 0 )
						 Else 
							 Set sBrkBndlCustNoList = sBrkBndlCustNoList || ', ' || SalNumberToStrX( nBrkBndlCustNo, 0 )
				 Else 
					 Return FALSE
				!
				 If sBrkBndlCustNoList = ''
					 Return FALSE
				 Else 
					 Set sSql = " SELECT
							  Customer_Master.Cust_No, 
							  Customer_Master.Cust_Name, 
							  @UPPER( Customer_Master.Cust_Name ), 
							  Stock_Item.Variety_Type, 
							  @UPPER( Stock_Item.Variety ), 
							  @UPPER( Stock_Item.Cult_Desc ), 
							  @UPPER( Stock_Item.Root_Desc ), 
							  Stock_Item.Tree_Type, 
							  Stock_Item.Cult_Desc, 
							  Stock_Item.Root_Desc, 
							  Customer_Order.Ordered_Amount, 
							  Customer_Order.Conf_Amt 
							FROM 
							  Customer_Master, 
							  Customer_Order, 
							  Stock_Item 
							INTO 
							  :frmBrokenBundlesList.nCustNo,
							  :frmBrokenBundlesList.sCustName,
							  :frmBrokenBundlesList.sUpperCustName,
							  :frmBrokenBundlesList.sVarietyType,
							  :frmBrokenBundlesList.sUpperVariety,
							  :frmBrokenBundlesList.sUpperCultDesc,
							  :frmBrokenBundlesList.sUpperRootDesc,
							  :frmBrokenBundlesList.sTreeType,
							  :frmBrokenBundlesList.sCultDesc,
							  :frmBrokenBundlesList.sRootDesc,
							  :frmBrokenBundlesList.nOrdAmt,
							  :frmBrokenBundlesList.nConfAmt 
							WHERE
							  Customer_Master.Cust_No IN ( " || sBrkBndlCustNoList || " ) AND 
							  Customer_Master.Cust_No = Customer_Order.Cust_No AND 
							  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
							  Customer_Order.Year_Of_Sale = :frmBrokenBundlesList.nYear AND 
							  NOT Stock_Item.Tree_Type LIKE 'C%' 
							ORDER BY
							  3,1,4,5,6,7,8 "
				!
				 Call fcReportHdl.PrepareSetup( sSql )
				 Call SqlVarSetup( fcReportHdl.hSqlHandle )
				!
				 Return fcReportHdl.PrepareAndExecute( )
			! On SAM_ReportStart
				 Set sExcludingTreeTypesList = ''
				 Call MakeStringList( saExcludingTreeTypes, ',', "'", sExcludingTreeTypesList )
				!
				 If sExcludingTreeTypesList = ''
					 Set sINSql = " SELECT
							  Customer_Order.Cust_No 
							FROM 
							  Customer_Order, 
							  Stock_Item 
							WHERE
							  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
							  Customer_Order.Year_Of_Sale = :frmBrokenBundlesList.nYear  AND 
							  NOT Stock_Item.Tree_Type LIKE 'C%' 
							GROUP BY 1 
							HAVING 
							  ((SUM( @IF(@MOD( Customer_Order.Ordered_Amount, 5 ), 1, 0)))/
							  (COUNT( Customer_Order.Ordered_Amount ))*100)>= :frmBrokenBundlesList.nCompPerc "
				 Else 
					 Set sINSql = " SELECT
							  Customer_Order.Cust_No 
							FROM 
							  Customer_Order, 
							  Stock_Item 
							WHERE
							  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
							  Customer_Order.Year_Of_Sale = :frmBrokenBundlesList.nYear  AND 
							  NOT Stock_Item.Tree_Type LIKE 'C%' AND 
							  NOT Stock_Item.Tree_Type IN ( " || sExcludingTreeTypesList || " ) 
							GROUP BY 1 
							HAVING 
							  ((SUM( @IF(@MOD( Customer_Order.Ordered_Amount, 5 ), 1, 0)))/
							  (COUNT( Customer_Order.Ordered_Amount ))*100)>= :frmBrokenBundlesList.nCompPerc "
				!
				 Set sSql = " SELECT
						  Customer_Master.Cust_No, 
						  Customer_Master.Cust_Name, 
						  @UPPER( Customer_Master.Cust_Name ), 
						  Stock_Item.Variety_Type, 
						  @UPPER( Stock_Item.Variety ), 
						  @UPPER( Stock_Item.Cult_Desc ), 
						  @UPPER( Stock_Item.Root_Desc ), 
						  Stock_Item.Tree_Type, 
						  Stock_Item.Cult_Desc, 
						  Stock_Item.Root_Desc, 
						  Customer_Order.Ordered_Amount, 
						  Customer_Order.Conf_Amt 
						FROM 
						  Customer_Master, 
						  Customer_Order, 
						  Stock_Item 
						INTO 
						  :frmBrokenBundlesList.nCustNo,
						  :frmBrokenBundlesList.sCustName,
						  :frmBrokenBundlesList.sUpperCustName,
						  :frmBrokenBundlesList.sVarietyType,
						  :frmBrokenBundlesList.sUpperVariety,
						  :frmBrokenBundlesList.sUpperCultDesc,
						  :frmBrokenBundlesList.sUpperRootDesc,
						  :frmBrokenBundlesList.sTreeType,
						  :frmBrokenBundlesList.sCultDesc,
						  :frmBrokenBundlesList.sRootDesc,
						  :frmBrokenBundlesList.nOrdAmt,
						  :frmBrokenBundlesList.nConfAmt 
						WHERE
						  Customer_Master.Cust_No IN ( " || sINSql || " ) AND 
						  Customer_Master.Cust_No = Customer_Order.Cust_No AND 
						  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
						  Customer_Order.Year_Of_Sale = :frmBrokenBundlesList.nYear AND 
						  NOT Stock_Item.Tree_Type LIKE 'C%' 
						ORDER BY
						  3,1,4,5,6,7,8 "
				!
				 Call fcReportHdl.PrepareSetup( sSql )
				 Call SqlVarSetup( fcReportHdl.hSqlHandle )
				!
				 Return fcReportHdl.PrepareAndExecute( )
			On SAM_ReportStart
				Set sExcludingTreeTypesList = ''
				Call MakeStringList( saExcludingTreeTypes, ',', "'", sExcludingTreeTypesList )
				Return TRUE
			On SAM_ReportFetchInit
				Set bProcessCustomers = TRUE
				Set bPopulateCustomers = TRUE
				Set bProcessOrders = FALSE
				Set bPopulateOrders = FALSE
				Return TRUE
			On SAM_ReportFetchNext
				Loop
					If bProcessCustomers
						If bPopulateCustomers
							If sExcludingTreeTypesList = ''
								Set sSql = " SELECT
										  Customer_Order.Cust_No 
										FROM 
										  Customer_Order, 
										  Stock_Item 
										INTO 
										  :frmBrokenBundlesList.nCustNo 
										WHERE
										  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
										  Customer_Order.Year_Of_Sale = :frmBrokenBundlesList.nYear  AND 
										  NOT Stock_Item.Tree_Type LIKE 'C%' 
										GROUP BY 1 
										HAVING 
										  ((SUM( @IF(@MOD( Customer_Order.Ordered_Amount, 5 ), 1, 0)))/
										  (COUNT( Customer_Order.Ordered_Amount ))*100)>= :frmBrokenBundlesList.nCompPerc "
							Else
								Set sSql = " SELECT
										  Customer_Order.Cust_No 
										FROM 
										  Customer_Order, 
										  Stock_Item 
										INTO 
										  :frmBrokenBundlesList.nCustNo 
										WHERE
										  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
										  Customer_Order.Year_Of_Sale = :frmBrokenBundlesList.nYear  AND 
										  NOT Stock_Item.Tree_Type LIKE 'C%' AND 
										  NOT Stock_Item.Tree_Type IN ( " || sExcludingTreeTypesList || " ) 
										GROUP BY 1 
										HAVING 
										  ((SUM( @IF(@MOD( Customer_Order.Ordered_Amount, 5 ), 1, 0)))/
										  (COUNT( Customer_Order.Ordered_Amount ))*100)>= :frmBrokenBundlesList.nCompPerc "
							Call fcBrkBndlCustHdl.PrepareSetup( sSql )
							Call SqlVarSetup( fcBrkBndlCustHdl.hSqlHandle )
							!
							Call fcBrkBndlCustHdl.PrepareAndExecute( )
							Set bPopulateCustomers = FALSE
						!
						If fcBrkBndlCustHdl.FetchNext( nInd )
							Set bProcessCustomers = FALSE
							Set bProcessOrders = TRUE
							Set bPopulateOrders = TRUE
						Else
							Return FALSE
					If bProcessOrders
						If bPopulateOrders
							Set sSql = " SELECT
									  Customer_Master.Cust_No, 
									  Customer_Master.Cust_Name, 
									  @UPPER( Customer_Master.Cust_Name ), 
									  Stock_Item.Variety_Type, 
									  @UPPER( Stock_Item.Variety ), 
									  @UPPER( Stock_Item.Cult_Desc ), 
									  @UPPER( Stock_Item.Root_Desc ), 
									  Stock_Item.Tree_Type_Desc, 
									  Stock_Item.Cult_Desc, 
									  Stock_Item.Root_Desc, 
									  Customer_Order.Ordered_Amount, 
									  Customer_Order.Conf_Amt 
									FROM 
									  Customer_Master, 
									  Customer_Order, 
									  Stock_Item 
									INTO 
									  :frmBrokenBundlesList.nCustNo,
									  :frmBrokenBundlesList.sCustName,
									  :frmBrokenBundlesList.sUpperCustName,
									  :frmBrokenBundlesList.sVarietyType,
									  :frmBrokenBundlesList.sUpperVariety,
									  :frmBrokenBundlesList.sUpperCultDesc,
									  :frmBrokenBundlesList.sUpperRootDesc,
									  :frmBrokenBundlesList.sTreeTypeDesc,
									  :frmBrokenBundlesList.sCultDesc,
									  :frmBrokenBundlesList.sRootDesc,
									  :frmBrokenBundlesList.nOrdAmt,
									  :frmBrokenBundlesList.nConfAmt 
									WHERE
									  Customer_Master.Cust_No = :frmBrokenBundlesList.nCustNo  AND 
									  Customer_Master.Cust_No = Customer_Order.Cust_No AND 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									  Customer_Order.Year_Of_Sale = :frmBrokenBundlesList.nYear AND 
									  NOT Stock_Item.Tree_Type LIKE 'C%' 
									ORDER BY
									  3,1,4,5,6,7,8 "
							!
							Call fcReportHdl.PrepareSetup( sSql )
							Call SqlVarSetup( fcReportHdl.hSqlHandle )
							!
							Call fcReportHdl.PrepareAndExecute( )
							Set bPopulateOrders = FALSE
						!
						If fcReportHdl.FetchNext( nInd )
							Return TRUE
						Else
							Set bProcessCustomers = TRUE
							Set bProcessOrders = FALSE
			On SAM_ReportFinish
				Call fcReportHdl.Disconnect( )
				Call fcBrkBndlCustHdl.Disconnect( )
				Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )

				Call SalSendMsg( tblSelectedTreeTypes, PAM_clsTBL_POPULATE, 0, 0 )
			On PAM_clsPB_OKACTION
				Call SalSendMsg( tblSelectedTreeTypes, PAM_BRKBNDLD_GETSELECTEDITEMS, 0, 0 )
				Call SalCreateWindow( frmBrokenBundlesList, hWndForm, saExcludingTreeTypes, SalStrToNumber( ccAllowablePerc.GetNumber( ) ), ccSeasonYear.GetSeasonYear( ) )
	Form Window: frmBrokenBundlesList
		Class: clsFormPrintReport
		Property Template:
		Class DLL Name:
		Title: Broken Bundles Report
		Icon File:
		Accesories Enabled? Class Default
		Visible? Class Default
		Display Settings
			Display Style? Class Default
			Visible at Design time? No
			Automatically Created at Runtime? Class Default
			Initial State: Class Default
			Maximizable? Class Default
			Minimizable? Class Default
			System Menu? Class Default
			Resizable? Class Default

.head 6 +  Actions
.head 7 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GSISGRDDTS' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = " SELECT 
  Amt_Shipped, 
  Amt_Subs_Shipped, 
  Total_Graded 
FROM 
  Stock_Item_Sale
WHERE 
  Stock_Item_No = :1 AND 
  Year_Of_Sale = :2 "
.head 9 -  Set sName = 'GSISGRDDTS'
.head 9 -  Set sBind = ':nItemNo, :nYear'
.head 9 -  Set sInto = ':nGotAmtShipped, :nGotAmtShippedAsSubs, :nGotTotalGraded'
.head 9 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 9 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 -  Set nGotAmtShipped = NUMBER_Null
.head 9 -  Set nGotAmtShippedAsSubs = NUMBER_Null
.head 9 -  Set nGotTotalGraded = NUMBER_Null
.head 9 -  Set nAmtGraded = 0
.head 9 -  Set bChanged = FALSE
.head 9 -  !
.head 9 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 10 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 11 +  If nGotTotalGraded >= 0
.head 12 +  If IDYES = SalMessageBox( "There is already a total graded figure of "||SalNumberToStrX( nGotTotalGraded, 0 )||". Do you want to change it to "||SalNumberToStrX( nTotalGraded, 0 )||".", 'Warning', MB_YesNo )
.head 13 -  Set bOk = TRUE
.head 12 +  Else
.head 13 -  Set bOk = FALSE
.head 11 +  Else
.head 12 -  Set bOk = TRUE
.head 11 +  If bOk
.head 12 -  Set nAmtGraded = nTotalGraded - nGotAmtShipped - nGotAmtShippedAsSubs
.head 12 +  If UpdtSISGradedNTotalGraded( nItemNo, nYear, nAmtGraded, nTotalGraded, SH_cls_Execute )
.head 13 -  Call UpdtSISGradedNTotalGraded( 0, 0, 0, 0, SH_cls_Commit )
.head 13 -  Set naItemNos[0] = nItemNo
.head 13 -  Set naItemNos[1] = NUMBER_Null
.head 13 -  Call RecalculateInventoryFigures( naItemNos, nYear, 'SELECTED', SH_cls_Execute )
.head 13 -  Set bChanged = TRUE
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Set bOk = TRUE
.head 9 +  If NOT UpdtSISGradedNTotalGraded( 0, 0, 0, 0, SH_cls_Disconnect )
.head 10 -  Set bOk = FALSE

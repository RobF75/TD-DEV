.head 6 -  Functions
.head 6 +  Window Variables
.head 7 -  Date/Time: dtTmp
.head 6 +  Message Actions
.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 -  Set sSQLPopHandle = " SELECT 
  Graded_Pallets.Pallet_Datetime, 
  Graded_Pallets.Processed_Date, 
  Graded_Pallets.Processed_By, 
  Pallet_Contents.Pallet_Count, 
  Graded_Pallets.Entered_By 
FROM 
  Graded_Pallets, Pallet_Contents 
WHERE 
  Graded_Pallets.Pallet_Datetime > :1 AND 
  Graded_Pallets.Pallet_Datetime < :2 AND 
  Pallet_Contents.Item_No = :3 AND 
  Pallet_Contents.Content_Datetime = Graded_Pallets.Pallet_Datetime    
ORDER BY 
  Pallet_Datetime "
.head 8 -  Set sNAMEPopHandle = 'POPSISGRAD'
.head 8 -  Set sBINDPopHandle = ':hWndParent.clsfrmSISGraded.dtYearBegin, 
:hWndParent.clsfrmSISGraded.dtYearEnd, 
:hWndParent.clsfrmSISGraded.nItemNo'
.head 8 -  Set sINTOPopHandle = ':clsfrmSISGraded.tblPallet.colPalletDate, 
:clsfrmSISGraded.tblPallet.colCountDate, 
:clsfrmSISGraded.tblPallet.colCountBy, 
:clsfrmSISGraded.tblPallet.colCount, 
:clsfrmSISGraded.tblPallet.colEnteredBy'
.head 8 -  !
.head 8 -  Set sSQLRefreshHandle = " SELECT 
  Graded_Pallets.Pallet_Datetime, 
  Graded_Pallets.Processed_Date, 
  Graded_Pallets.Processed_By, 
  Pallet_Contents.Pallet_Count, 
  Graded_Pallets.Entered_By 
FROM 
  Graded_Pallets, Pallet_Contents 
WHERE 
  Graded_Pallets.Pallet_Datetime = :1 AND 
  Pallet_Contents.Item_No = :2 AND 
  Pallet_Contents.Content_Datetime = Graded_Pallets.Pallet_Datetime "
.head 8 -  Set sNAMERefreshHandle = 'REFSISGRAD'

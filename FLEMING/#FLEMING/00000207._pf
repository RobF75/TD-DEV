			Font Size: Class Default
			Font Enhancement: Class Default
			Text Color: Class Default
			Background Color: Class Default
		Description:
		Named Menus
		Menu
		Tool Bar
			Display Settings
				Display Style? Class Default
				Location? Class Default
				Visible? Class Default
				Size: Class Default
				Size Editable? Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Text Color: Class Default
				Background Color: Class Default
			Contents
		Contents
		Functions
		Window Parameters
			! ! sSelectedFarmNameList is a comma separated list of Farms
			String: sSelectedFarmNameList
			Number: nYear
			! ! sFarmType = 'SELECTED' OR 'ALL'
			String: sFarmType
			! ! sReportPrintOrView = 'VIEW' OR 'PRINT'
			String: sReportPrintOrView
		Window Variables
			! REPORT COLUMNS
			String: sFarmName
			Number: nRowNo
			Number: nSeqNo
			! Number: nYear
			String: sVarietyType
			String: sUpperVariety
			String: sUpperCultDesc
			String: sUpperRootDesc
			String: sTreeTypeDesc
			String: sCultDesc
			String: sRootDesc
			Number: nBudCount
			Number: nFirstCount
			Number: nSecondCount
			Date/Time: dtDatePlanted
			Date/Time: dtDateBudded
			Date/Time: dtEstSaleDate
			Number: nForwardOrders
			String: sNotSaleFlag
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set sReportFileNameNoPath = 'potplan2.qrp'
				Set sReportBind = ':frmPotPlan.sFarmName, 
						  :frmPotPlan.nRowNo, 
						  :frmPotPlan.nSeqNo, 
						  :frmPotPlan.nYear, 
						  :frmPotPlan.sVarietyType, 
						  :frmPotPlan.sUpperVariety, 
						  :frmPotPlan.sUpperCultDesc, 
						  :frmPotPlan.sUpperRootDesc, 
						  :frmPotPlan.sTreeTypeDesc, 
						  :frmPotPlan.sCultDesc, 
						  :frmPotPlan.sRootDesc, 
						  :frmPotPlan.nBudCount, 
						  :frmPotPlan.nFirstCount, 
						  :frmPotPlan.nSecondCount, 
						  :frmPotPlan.dtDatePlanted, 
						  :frmPotPlan.dtDateBudded, 
						  :frmPotPlan.dtEstSaleDate, 
						  :frmPotPlan.nForwardOrders, 
						  :frmPotPlan.sNotSaleFlag'
				Set sReportInto = 'sFarmName, 
						  nRowNo, 
						  nSeqNo, 
						  nYear, 
						  sVarietyType, 
						  sUpperVariety, 
						  sUpperCultDesc, 
						  sUpperRootDesc, 
						  sTreeTypeDesc, 
						  sCultDesc, 
						  sRootDesc, 
						  nBudCount, 
						  nFirstCount, 
						  nSecondCount, 
						  dtDatePlanted, 
						  dtDateBudded, 
						  dtEstSaleDate, 
						  nForwardOrders, 
						  sNotSaleFlag'
				Set sReportType = sReportPrintOrView
				!
			On PAM_clsFRM_REPORTSTART
				If sFarmType = 'ALL'
					Set sReportSql = " SELECT 
							  Location.Farm_Name, 
							  Location.Row#, 
							  Location.Seq#, 
							  Growing_Sale.Year_Of_Sale, 
							  Stock_Item.Variety_Type, 
							  @UPPER( Stock_Item.Variety ), 
							  @UPPER( Stock_Item.Cult_Desc ), 
							  @UPPER( Stock_Item.Root_Desc ), 
							  Stock_Item.Tree_Type_Desc, 
							  Stock_Item.Cult_Desc, 
							  Stock_Item.Root_Desc, 
							  Growing_Sale.Beg_Count, 
							  Growing_Sale.First_Count, 
							  Growing_Sale.Second_Count, 
							  Growing_Sale.Date_Planted, 
							  Growing_Sale.Date_Budded, 
							  Growing_Sale.Est_Sale_Date, 
							  Growing_Sale.Forward_Orders, 
							  Growing_Sale.Not_For_Sale
							FROM 
							  Location, 
							  Growing_Sale, 
							  Stock_Item 
							INTO 
							  :frmPotPlan.sFarmName, 
							  :frmPotPlan.nRowNo, 
							  :frmPotPlan.nSeqNo, 
							  :frmPotPlan.nYear, 
							  :frmPotPlan.sVarietyType, 
							  :frmPotPlan.sUpperVariety, 
							  :frmPotPlan.sUpperCultDesc, 
							  :frmPotPlan.sUpperRootDesc, 
							  :frmPotPlan.sTreeTypeDesc, 
							  :frmPotPlan.sCultDesc, 
							  :frmPotPlan.sRootDesc, 
							  :frmPotPlan.nBudCount, 
							  :frmPotPlan.nFirstCount, 
							  :frmPotPlan.nSecondCount, 
							  :frmPotPlan.dtDatePlanted, 
							  :frmPotPlan.dtDateBudded, 
							  :frmPotPlan.dtEstSaleDate, 
							  :frmPotPlan.nForwardOrders, 
							  :frmPotPlan.sNotSaleFlag 
							WHERE 
							  Location.Location_Id = Growing_Sale.Location_Id AND 
							  Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
							  Location.Farm_Name LIKE 'C%'
							ORDER BY 
							  1,2,3,4,5,6,7,8,9 "
				Else
					Set sReportSql = " SELECT 
							  Location.Farm_Name, 
							  Location.Row#, 
							  Location.Seq#, 
							  Growing_Sale.Year_Of_Sale, 
							  Stock_Item.Variety_Type, 
							  @UPPER( Stock_Item.Variety ), 
							  @UPPER( Stock_Item.Cult_Desc ), 
							  @UPPER( Stock_Item.Root_Desc ), 
							  Stock_Item.Tree_Type_Desc, 
							  Stock_Item.Cult_Desc, 
							  Stock_Item.Root_Desc, 
							  Growing_Sale.Beg_Count, 
							  Growing_Sale.First_Count, 
							  Growing_Sale.Second_Count, 
							  Growing_Sale.Date_Planted, 
							  Growing_Sale.Date_Budded, 
							  Growing_Sale.Est_Sale_Date, 
							  Growing_Sale.Forward_Orders, 
							  Growing_Sale.Not_For_Sale
							FROM 
							  Location, 
							  Growing_Sale, 
							  Stock_Item 
							INTO 
							  :frmPotPlan.sFarmName, 
							  :frmPotPlan.nRowNo, 
							  :frmPotPlan.nSeqNo, 
							  :frmPotPlan.nYear, 
							  :frmPotPlan.sVarietyType, 
							  :frmPotPlan.sUpperVariety, 
							  :frmPotPlan.sUpperCultDesc, 
							  :frmPotPlan.sUpperRootDesc, 
							  :frmPotPlan.sTreeTypeDesc, 
							  :frmPotPlan.sCultDesc, 
							  :frmPotPlan.sRootDesc, 
							  :frmPotPlan.nBudCount, 
							  :frmPotPlan.nFirstCount, 
							  :frmPotPlan.nSecondCount, 
							  :frmPotPlan.dtDatePlanted, 
							  :frmPotPlan.dtDateBudded, 
							  :frmPotPlan.dtEstSaleDate, 
							  :frmPotPlan.nForwardOrders, 
							  :frmPotPlan.sNotSaleFlag 
							WHERE 
							  Location.Location_Id = Growing_Sale.Location_Id AND 
							  Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
							  Location.Farm_Name IN ( " || sSelectedFarmNameList || " )
							ORDER BY 
							  1,2,3,4,5,6,7,8,9 "
				Return TRUE

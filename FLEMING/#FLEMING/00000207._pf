				Window Variables
					String: sTmp
					Number: nTmp
					String: sFarmNameList
					Boolean: bPopulated
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set sSQLPopHandle = " SELECT
								  Farm_Master.Farm_Name,
								  Farm_Master.Farm_Description
								FROM
								  Farm_Master 
								WHERE 
								  Farm_Master.Farm_Name LIKE 'C%' 
								ORDER BY
								  Farm_Master.Farm_Name "
						Set sNAMEPopHandle = 'POPSELFRMS'
						Set sBINDPopHandle = ''
						Set sINTOPopHandle = ':frmPotPlanInterface.tblSelectedFarms.colFarmName,
								  :frmPotPlanInterface.tblSelectedFarms.colFarmDesc'
						!
						Set bAddAllowed = TRUE
						Set bPopulated = FALSE
					On PAM_clsTBL_POPULATE
						Set bPopulated = TRUE
						Return SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
					On PAM_clsPOTPLAND_GETSELFARMS
						Set sFarmNameList = ''
						If TableLoop( hWndForm, hWndForm, PAM_clsPOTPLAND_GETSELECTED, 0, ROW_UnusedFlag1, 0, 'Extracting Selected Regions', TBL_cls_LowToHi )
							If sFarmNameList = ''
								Return FALSE
							Else
								Call PushString( sFarmNameList )
								Return TRUE
						Else
							Return FALSE
					On PAM_clsPOTPLAND_GETSELECTED
						If sFarmNameList = ''
							Set sFarmNameList = "'" || colFarmName || "'"
						Else
							Set sFarmNameList = sFarmNameList || ', ' || "'" || colFarmName || "'"
						Return TRUE
			!

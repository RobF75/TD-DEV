				Message Actions
					On SAM_Create
						Set sCultId = ''
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbCultDetails.nActivateWindowType = ACTIVATE_FormWindow
						Set clspbCultDetails.sActivateDialogName = 'frmCultDetails'
					On PAM_clsFRMDETS_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushString( sCultId )
						Return TRUE

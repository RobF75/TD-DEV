						Message Actions
							On PAM_clsCB_VALIDATE
								! Means that they have checked the check box
								If wParam
									If IsCultOnOrder( dfCultId, SH_cls_Execute)
										Call SalCreateWindow( frmPrintOrders, hWndForm, dfCultId )
										If NOT SendMail( 'Not For Sale checked on cultivar', 'The attachment is a list of customers who
												have ordered the cultivar which has now been marked as Not For Sale by '||SqlUser, OurGetIniFileParameter( 'GENERAL', 'MailNotForSale', '' ), '', '', OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', '' )||'\\'||dfCultId||'.txt' )
											Call SalMessageBox( 'Send mail to Not For Sale Administrator failed.   Please contact programmers' , 'Error', MB_Ok )
								! If returning true from this routine we need to then prepare a report of all customers who have
										this cultivar on order and send the report to the user in charge of this via email
								Call SalSendClassMessage( PAM_clsCB_VALIDATE, wParam, lParam )
								Return VALIDATE_Ok

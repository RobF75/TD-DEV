						Call SalSendMsg( pbSavePaintCodes, SAM_Click, 0, 0 )
						Return TRUE
					On PAM_clsFRMDETS_CHECKCHANGES
						If SalTblAnyRows( tblPaintCodes, ROW_Edited|ROW_New|ROW_MarkDeleted, 0 )
							Set bEdit = TRUE
						Return SalSendClassMessage( PAM_clsFRMDETS_CHECKCHANGES, wParam, lParam )
					On SAM_Destroy

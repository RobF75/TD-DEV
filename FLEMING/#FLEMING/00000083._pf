					Data Field: dfCultId
						Class Child Ref Key: 0
						Class ChildKey: 82
						Class: clsdfFrmDets
						Property Template:
						Class DLL Name:
						Data
							Maximum Data Length: 8
							Data Type: Class Default
							Editable? Class Default
						Display Settings
							Window Location and Size
								Left:   1.363"
								Top:    0.427"
								Width:  0.938"
								Width Editable? Class Default
								Height: Class Default
								Height Editable? Class Default
							Visible? Class Default
							Border? Class Default
							Justify: Class Default
							Format: Uppercase
							Country: Class Default
							Font Name: Class Default
							Font Size: Class Default
							Font Enhancement: Class Default
							Text Color: Class Default
							Background Color: Class Default
							Input Mask: Class Default
						Message Actions
							On PAM_clsFRMDETS_DATAVAL
								If SalIsNull( hWndItem )
									Call SalMessageBox( 'Plase enter a Cultivar Id First!', 'Warning', MB_Ok )
									Call SalSetFocus( hWndItem )
									Return FALSE
								Else
									Return TRUE
							On PAM_clsFRMDETS_CHECKROWNEW
								Call ExistsCultId( dfCultId, bExists, SH_cls_Execute )
								If bExists
									Call SalMessageBox( 'This Cultivar ID already exists! Please change the ID first.', 'Warning', MB_Ok )
									Return FALSE
								Else
									Return TRUE
							On PAM_clsFRMDETS_CHECKROWDELETED
								Call ExistsStockItemCultId( dfCultId, bExists, SH_cls_Execute )
								If bExists
									Call SalMessageBox( 'This Cultivar ID is still used as a stock item! Please delete the stock items first.', 'Warning', MB_Ok )
									Return FALSE
								Else
									Return TRUE
							On PAM_clsFRMDETS_CHECKROWEDITED
								Return ExtractCultDenomEffectedDetails( dfCultId, sOldVarietyType, sOldVariety, sOldCultDesc, sOldNonPropFlag, sOldNotSaleFlag, sOldProdRoyFlag, SH_cls_Execute )
							On PAM_clsFRMDETS_ROWUPDATED
								Return CultivarDenormalise( dfCultId, dfVarietyType, cmbVariety, dfCultDesc, cbNonPropFlag.sFlagValue, cbNotSaleFlag.sFlagValue, cbProdRoyFlag.sFlagValue,
										 sOldVarietyType, sOldVariety, sOldCultDesc, sOldNonPropFlag, sOldNotSaleFlag, sOldProdRoyFlag, SH_cls_Execute )
							On PAM_clsFRMDETS_NEWPREC
								Return SalSendMsg( hWndItem, PAM_clsDF_ENABLE, 0, 0 )
							On PAM_clsFRMDETS_DISPREC
								Return SalSendMsg( hWndItem, PAM_clsDF_DISABLE, 0, 0 )

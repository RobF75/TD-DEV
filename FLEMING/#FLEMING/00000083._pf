						Functions
						Window Variables
							Number: nLastPaintNum
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = ' SELECT 
										  Cult_Paint_Used.Cult_Year_Used, 
										  Cult_Paint_Used.Paint_Id, 
										  Cult_Paint_Used.CV_Paint_Number, 
										  Paint_Master.Paint_Desc 
										FROM 
										  Cult_Paint_Used, 
										  Paint_Master 
										WHERE 
										  Cult_Paint_Used.Cultivar_Id = :1 AND 
										  Cult_Paint_Used.Paint_Id = Paint_Master.Paint_Id
										ORDER BY 
										  Cult_Paint_Used.Cult_Year_Used DESC, 
										  Cult_Paint_Used.CV_Paint_Number '
								Set sNAMEPopHandle = 'CULTPNTUSED'
								Set sBINDPopHandle = ':hWndParent.dfCultId'
								Set sINTOPopHandle = ':clsfrmCultDetails.tblPaintCodes.colYear, 
										:clsfrmCultDetails.tblPaintCodes.colPaintId, 
										:clsfrmCultDetails.tblPaintCodes.colPaintNum, 
										:clsfrmCultDetails.tblPaintCodes.colPaintDesc'
								!
								Set sSQLRefreshHandle = ' SELECT 
										  Cult_Paint_Used.Cult_Year_Used, 
										  Cult_Paint_Used.Paint_Id, 
										  Cult_Paint_Used.CV_Paint_Number, 
										  Paint_Master.Paint_Desc 
										FROM 
										  Cult_Paint_Used, 
										  Paint_Master 
										WHERE 
										  Cult_Paint_Used.Cultivar_Id = :1 AND 
										  Cult_Paint_Used.Cult_Year_Used = :2 AND 
										  Cult_Paint_Used.CV_Paint_Number = :3 AND 
										  Cult_Paint_Used.Paint_Id = Paint_Master.Paint_Id '
								Set sNAMERefreshHandle = 'REFCLTPUSD'
								Set sBINDRefreshHandle = ':hWndParent.dfCultId, 
										:clsfrmCultDetails.tblPaintCodes.colYear, 
										:clsfrmCultDetails.tblPaintCodes.colPaintNum'
								Set sINTORefreshHandle = ':clsfrmCultDetails.tblPaintCodes.colYear, 
										:clsfrmCultDetails.tblPaintCodes.colPaintId, 
										:clsfrmCultDetails.tblPaintCodes.colPaintNum, 
										:clsfrmCultDetails.tblPaintCodes.colPaintDesc'
								!
								Set sSQLInsertHandle = ' INSERT INTO Cult_Paint_Used 
										  ( Cultivar_Id, 
										    Cult_Year_Used, 
										    CV_Paint_Number, 
										    Paint_Id ) 
										  VALUES
										  ( :1, :2, :3, :4 ) '
								Set sNAMEInsertHandle = 'INSCLTPUSD'
								Set sBINDInsertHandle = ':hWndParent.dfCultId, 
										:clsfrmCultDetails.tblPaintCodes.colYear, 
										:clsfrmCultDetails.tblPaintCodes.colPaintNum, 
										:clsfrmCultDetails.tblPaintCodes.colPaintId'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE Cult_Paint_Used 
										  SET 
										    Paint_Id = :4 
										  WHERE 
										    Cult_Paint_Used.Cultivar_Id = :1 AND 
										    Cult_Paint_Used.Cult_Year_Used = :2 AND 
										    Cult_Paint_Used.CV_Paint_Number = :3 '
								Set sNAMEUpdateHandle = 'UPDTCLTPUSD'
								Set sBINDUpdateHandle = ':hWndParent.dfCultId, 
										:clsfrmCultDetails.tblPaintCodes.colYear, 
										:clsfrmCultDetails.tblPaintCodes.colPaintNum, 
										:clsfrmCultDetails.tblPaintCodes.colPaintId'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = ' DELETE FROM Cult_Paint_Used 
										  WHERE 
										    Cult_Paint_Used.Cultivar_Id = :1 AND 
										    Cult_Paint_Used.Cult_Year_Used = :2 AND 
										    Cult_Paint_Used.CV_Paint_Number = :3 '
								Set sNAMEDeleteHandle = 'DELCLTPUSD'
								Set sBINDDeleteHandle = ':hWndParent.dfCultId, 
										:clsfrmCultDetails.tblPaintCodes.colYear, 
										:clsfrmCultDetails.tblPaintCodes.colPaintNum'
								Set sINTODeleteHandle = ''
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								Set bQueryAllowed = FALSE
								Set bReportAllowed = FALSE
								Set bOrderAllowed = FALSE
								!
								Set bGetSaveConfirmation = FALSE
								!
								Set sTableHeading = 'Cultivar Paint Codes'
								Set bSelectFirstRow = FALSE
								Set hWndRowNewColumn = colYear
								!
								Set nLastPaintNum = 0
							On PAM_clsTBL_NOROWS
								Return TRUE
							On PAM_clsTBL_POPULATE
								Set nLastPaintNum = 0
								Return SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
							On SAM_FetchRowDone
								If colPaintNum > nLastPaintNum
									Set nLastPaintNum = colPaintNum
								Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
							On PAM_clsFRMDETS_DISPREC
								Return SalSendMsg( hWndForm, PAM_clsTBL_POPULATE, 0, 0 )
							On PAM_clsFRMDETS_NEWPREC
								Return SalSendMsg( hWndForm, PAM_clsTBL_RESET, 0, 0 )
							! On PAM_clsPICK_LOOKUP
								                            Call PopString( colPaintDesc, TRUE )
								                            Call PopString( colPaintId, TRUE )
								                            Set colYear = OurDateYear( SalDateCurrent(  ) )
								                            Call SalSetFieldEdit( colYear, TRUE )
								                            Return TRUE
							On PAM_clsTBL_WRITEINSERTSUPDATES
								Return SalSendClassMessage( PAM_clsTBL_WRITEINSERTSUPDATES, wParam, lParam )
					!
					Data Field: dfVarietyType
						Class Child Ref Key: 0
						Class ChildKey: 164
						Class: clsdfFrmDets
						Property Template:
						Class DLL Name:
						Data
							Maximum Data Length: 1
							Data Type: Class Default
							Editable? Class Default
						Display Settings
							Window Location and Size
								Left:   0.2"
								Top:    0.167"
								Width:  Default
								Width Editable? Class Default
								Height: Class Default
								Height Editable? Class Default
							Visible? No
							Border? Class Default
							Justify: Class Default
							Format: Class Default
							Country: Class Default
							Font Name: Class Default
							Font Size: Class Default
							Font Enhancement: Class Default
							Text Color: Class Default
							Background Color: Class Default
							Input Mask: Class Default
						Message Actions
							On PAM_clsRB_CLICK
								If lParam = 1
									Set dfVarietyType = 'F'
								Else
									Set dfVarietyType = 'O'
								Return SalSendClassMessage( PAM_clsRB_CLICK, wParam, lParam )
							On PAM_clsFRMDETS_NEWPREC
								Set dfVarietyType = 'F'
								Set rbFruit = TRUE
					!
				Class Variables
				Instance Variables
					Boolean: bExists
					String: sOldVarietyType
					String: sOldVariety
					String: sOldCultDesc
					String: sOldNonPropFlag
					String: sOldNotSaleFlag
					String: sOldProdRoyFlag
				Functions
					Function: ExtractCultDenomEffectedDetails
						Description:
						Returns
							Boolean:
						Parameters
							String: sCultId
							Receive String: sCultVarietyType
							Receive String: sCultVariety
							Receive String: sCultDesc
							Receive String: sNonPropFlag
							Receive String: sNotForSaleFlag
							Receive String: sProdRoyFlag
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							!
							String: sGotCultVarietyType
							String: sGotCultVariety
							String: sGotCultDesc
							String: sGotNonPropFlag
							String: sGotNotForSaleFlag
							String: sGotProdRoyFlag
							Number: nInd
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'DENOMCVDETS' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT 
											  Variety_Type, 
											  Variety, 
											  Cult_Desc, 
											  CV_Non_Prop_Flag, 
											  CV_Not_Sale_Flag,
											  Prod_Royalty
											FROM 
											  Cultivar 
											WHERE 
											  Cult_Id = :1 "
									Set sName = 'DENOMCVDETS'
									Set sBind = ':sCultId'
									Set sInto = ':sGotCultVarietyType, 
											:sGotCultVariety, 
											:sGotCultDesc, 
											:sGotNonPropFlag, 
											:sGotNotForSaleFlag,
											:sGotProdRoyFlag'
									!
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set sCultVarietyType = ''
									Set sCultVariety = ''
									Set sCultDesc = ''
									Set sNonPropFlag = ''
									Set sNotForSaleFlag = ''
									Set sProdRoyFlag = ''
									!
									Set sGotCultVarietyType = ''
									Set sGotCultVariety = ''
									Set sGotCultDesc = ''
									Set sGotNonPropFlag = ''
									Set sGotNotForSaleFlag = ''
									Set sGotProdRoyFlag = ''
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
											Set sCultVarietyType = sGotCultVarietyType
											Set sCultVariety = sGotCultVariety
											Set sCultDesc = sGotCultDesc
											Set sNonPropFlag = sGotNonPropFlag
											Set sNotForSaleFlag = sGotNotForSaleFlag
											Set sProdRoyFlag = sGotProdRoyFlag
										Return TRUE
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					Function: CultivarDenormalise
						Description:
						Returns
							Boolean:
						Parameters
							String: sCultId
							String: sCultVarietyType
							String: sCultVariety
							String: sCultDesc
							String: sNonPropFlag
							String: sNotForSaleFlag
							String: sProdRoyFlag
							!
							String: sOldCultVarietyType
							String: sOldCultVariety
							String: sOldCultDesc
							String: sOldNonPropFlag
							String: sOldNotForSaleFlag
							String: sOldProdRoyFlag
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							Boolean: bOk
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SIDENOMCV' )
							Select Case nActionType
								Case SH_cls_Execute
									If sCultVarietyType != sOldCultVarietyType OR 
											   sCultVariety != sOldCultVariety OR 
											   sCultDesc != sOldCultDesc OR 
											   sNonPropFlag != sOldNonPropFlag OR 
											   sNotForSaleFlag != sOldNotForSaleFlag OR
											   sProdRoyFlag != sOldProdRoyFlag
										Set sSql = " UPDATE Stock_Item 
												SET 
												  Variety_Type = :2, 
												  Variety = :3, 
												  Cult_Desc = :4, 
												  CV_Non_Prop_Flag = :5, 
												  CV_Not_Sale_Flag = :6 
												WHERE 
												  Cultivar_Id = :1 "
										Set sName = 'SIDENOMCV'
										Set sBind = ':sCultId, 
												:sCultVarietyType, 
												:sCultVariety, 
												:sCultDesc, 
												:sNonPropFlag, 
												:sNotForSaleFlag'
										Set sInto = ''
										Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
										Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
										!
										If haSqlHandles[ nOurHandleNo ].Execute( )
											Call haSqlHandles[ nOurHandleNo ].Commit( )
											Return TRUE
										Else
											Return FALSE
									Else
										Return TRUE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					Function: ExistsStockItemCultId
						Description:
						Returns
							Boolean:
						Parameters
							String: sCultId
							Receive Boolean: bExists
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							!
							Number: nInd
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'EXISTSSICVID' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT Cultivar_Id
											FROM Stock_Item 
											WHERE Cultivar_Id = :1"
									Set sName = 'EXISTSSICVID'
									Set sBind = ':sCultId'
									Set sInto = ''
									!
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set bExists = FALSE
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
											Set bExists = TRUE
										Return TRUE
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					Function: IsCultOnOrder
						Description:
						Returns
							Boolean:
						Parameters
							String: sCultId
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							!
							Number: nInd
							Number: nCustNo
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'CULTORD' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT Cust_No
											FROM Customer_Order, Stock_Item
											WHERE Stock_Item.Cultivar_Id = :1 and Customer_Order.Stock_Item_No = Stock_Item.Item_No
											and Sale_Cat = 'NM' "
									Set sName = 'CULTORD'
									Set sBind = ':sCultId'
									Set sInto = ':nCustNo'
									!
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
											Return TRUE
										Else
											Return FALSE
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )

		Description:
		Named Menus
		Menu
		Tool Bar
			Display Settings
				Display Style? Class Default
				Location? Class Default
				Visible? Class Default
				Size: Class Default
				Size Editable? Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Text Color: Class Default
				Background Color: Class Default
			Contents
		Contents
		Functions
		Window Parameters
			String: sCultId
		Window Variables
			Number: nCustNo
			String: sCustName
			Number: nSaleYear
			String: sCultDesc
			String: sRootDesc
			String: sTreeType
			Number: nOrdAmt
			Number: nConfAmt
			String: sSaleCat
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set frmPrintOrders.bReportBeginAutomatically = TRUE
				Set frmPrintOrders.sReportBind = ':frmPrintOrders.nCustNo,
						:frmPrintOrders.sCustName,
						:frmPrintOrders.nSaleYear,
						:frmPrintOrders.sCultDesc,
						:frmPrintOrders.sRootDesc,
						:frmPrintOrders.sTreeType,
						:frmPrintOrders.nOrdAmt,
						:frmPrintOrders.nConfAmt,
						:frmPrintOrders.sSaleCat'
				Set frmPrintOrders.sReportInto = 'CustNo, CustName, SaleYear,
						CultDesc, RootDesc, TreeType, OrdAmt, ConfAmt, SaleCat'
				Set frmPrintOrders.sReportFileNameNoPath = 'notsaleord.qrp'
				Set frmPrintOrders.sReportSql = "select customer_master.cust_no,
						 cust_Name,
						 Year_of_sale,
						 cult_Desc,
						 root_desc,
						 tree_type,
						Ordered_Amount,
						Conf_amt,
						sale_cat
						FROM customer_master, 
						customer_order, 
						stock_item
						WHERE stock_item.cultivar_id = :frmPrintOrders.sCultId and 
						stock_item.item_no = customer_order.stock_item_no 
						and customer_master.cust_no = customer_order.cust_no
						and sale_cat != 'FC' and sale_cat != 'RP'  
						INTO
						:frmPrintOrders.nCustNo,
						:frmPrintOrders.sCustName,
						:frmPrintOrders.nSaleYear,
						:frmPrintOrders.sCultDesc,
						:frmPrintOrders.sRootDesc,
						:frmPrintOrders.sTreeType,
						:frmPrintOrders.nOrdAmt,
						:frmPrintOrders.nConfAmt,
						:frmPrintOrders.sSaleCat  ORDER BY 3,1"
				Set frmPrintOrders.sReportType = 'FILE'
				Set frmPrintOrders.sDestinFileName = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', '' )||'\\'||sCultId||'.txt'

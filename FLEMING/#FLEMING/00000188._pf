						Functions
							! Function: ReBatchAllocateCustOrders
								              Description: 
								              Returns 
									              Boolean: 
								              Parameters 
									              Number: nCustNo
									              Date/Time: dtOrderDT
									              Number: nYear
									              Number: nLocationId
									              Number: nActionType
								              Static Variables 
								              Local variables 
									              String: sSql
									              String: sBind
									              String: sInto
									              String: sName
									              Number: nOurHandleNo
								              Actions 
									              Set nOurHandleNo = SqlHandlesGetReferenceNo( 'ReBatchAllocateCustOrders' )
									              Select Case nActionType
										              Case SH_cls_Execute
											              Set sSql = " UPDATE Customer_Order 
													SET 
													  Year_Of_Sale = :3, 
													  Batch_Year_Of_Sale = :3, 
													  Batch_Location_Id = :4 
													WHERE 
													  Cust_No = :1 AND 
													  Order_Date_Time = :2 "
											              Set sName = 'RALOCBTCORDS'
											              Set sBind = ':nCustNo, :dtOrderDT, :nYear, :nLocationId'
											              Set sInto = ''
											              Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											              Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											              Return haSqlHandles[ nOurHandleNo ].Execute( )
										              Case SH_cls_Commit
											              Return haSqlHandles[ nOurHandleNo ].Commit( )
										              Case SH_cls_Rollback
											              Return haSqlHandles[ nOurHandleNo ].Rollback( )
										              Case SH_cls_Disconnect
											              Return haSqlHandles[ nOurHandleNo ].Disconnect( )
						Window Variables
							: fcStrRecalcItemsStack
								Class: strStack
							: fcStrDailyChangesItemsStack
								Class: strStack
							Number: naItemNos[ 2 ]
							Number: nTmpYear
							String: sTmp
							Boolean: bOk
							!
							Number: nTmpCustNo
							String: sTmpCustName
							String: sTmpSaleCat
							String: sTmpPullFlag
							Number: nTmpLocationId
							Number: nTmpOrgLocationId
							Number: nTmpYearOfSale
							Number: nTmpOrgYearOfSale
							String: sTmpFarmName
							Number: nTmpRowNo
							Number: nTmpSeqNo
							Date/Time: dtTmpSplitFromOrderDT
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = " SELECT 
										  Customer_Order.Order_Date_Time, 
										  Customer_Order.Cust_No, 
										  Customer_Master.Cust_Name, 
										  Customer_Order.Ordered_Amount, 
										  Customer_Order.Conf_Amt, 
										  Customer_Order.Sale_Cat, 
										  Customer_Order.Pull_Sheet_Issued, 
										  Customer_Order.Batch_Location_Id, 
										  Customer_Order.Batch_Location_Id, 
										  Customer_Order.Batch_Year_Of_Sale, 
										  Customer_Order.Batch_Year_Of_Sale, 
										  Customer_Order.Stock_Item_No, 
										  Location.Farm_Name, 
										  Location.Row#, 
										  Location.Seq# 
										FROM 
										  Customer_Order, 
										  Customer_Master, 
										  Location 
										WHERE 
										  Customer_Order.Batch_Location_Id = :1 AND 
										  Customer_Order.Batch_Year_Of_Sale = :2 AND 
										  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
										  Customer_Order.Batch_Location_Id = Location.Location_Id AND 
										  ( Customer_Order.Invoiced_Flag = 'N' OR 
										  Customer_Order.Invoiced_Flag IS NULL )
										ORDER BY 
										  Customer_Order.Ord_Date, 
										  Customer_Order.Cust_No, 
										  Location.Farm_Name, 
										  Location.Row#, 
										  Location.Seq# "
								Set sNAMEPopHandle = 'PPBTCHALOCOR4'
								Set sBINDPopHandle = ':hWndParent.clsfrmAllocatedOrders.nLocationId, :hWndParent.clsfrmAllocatedOrders.nYear'
								Set sINTOPopHandle = ':clsfrmAllocatedOrders.tblAllocatedOrders.colOrderDT,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colCustNo,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colCustName, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colOrdAmt,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colConfAmt,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colSaleCat, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colPullFlag, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colLocationId,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colOrgLocationId,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colYearOfSale,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colOrgYearOfSale, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colItemNo, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colFarmName,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colRowNo,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colSeqNo'
								!
								Set sSQLRefreshHandle = " SELECT 
										  Customer_Order.Order_Date_Time, 
										  Customer_Order.Cust_No, 
										  Customer_Master.Cust_Name, 
										  Customer_Order.Ordered_Amount, 
										  Customer_Order.Conf_Amt, 
										  Customer_Order.Sale_Cat, 
										  Customer_Order.Pull_Sheet_Issued, 
										  Customer_Order.Batch_Location_Id, 
										  Customer_Order.Batch_Location_Id, 
										  Customer_Order.Batch_Year_Of_Sale, 
										  Customer_Order.Batch_Year_Of_Sale, 
										  Customer_Order.Stock_Item_No, 
										  Location.Farm_Name, 
										  Location.Row#, 
										  Location.Seq# 
										FROM 
										  Customer_Order, 
										  Customer_Master, 
										  Location 
										WHERE 
										  Customer_Order.Batch_Location_Id = :1 AND 
										  Customer_Order.Batch_Year_Of_Sale = :2 AND 
										  Customer_Order.Order_Date_Time = :3 AND 
										  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
										  Customer_Order.Batch_Location_Id = Location.Location_Id AND 
										  ( Customer_Order.Invoiced_Flag = 'N' OR 
										  Customer_Order.Invoiced_Flag IS NULL ) "
								Set sNAMERefreshHandle = 'REFBTCHALOCOR4'
								Set sBINDRefreshHandle = ':hWndParent.clsfrmAllocatedOrders.nLocationId, 
										:hWndParent.clsfrmAllocatedOrders.nYear, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colOrderDT'
								Set sINTORefreshHandle = ':clsfrmAllocatedOrders.tblAllocatedOrders.colOrderDT,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colCustNo,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colCustName,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colOrdAmt,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colConfAmt,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colSaleCat, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colPullFlag, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colLocationId,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colOrgLocationId,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colYearOfSale,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colOrgYearOfSale, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colItemNo, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colFarmName,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colRowNo,

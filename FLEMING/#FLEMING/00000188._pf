				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name: C:\Centura\icons\Farms.bmp
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				List in Tool Palette? Yes
				Property Template:
				Class DLL Name:
				Description:
				Derived From
					Class: clspbPickInto
				Class Variables
					String: sTmp
					Number: nTmp
					Window Handle: hWndTmp
				Instance Variables
					! ! PUBLIC
					Window Handle: hWndPickIntoTable
					! ! PRIVATE
				Functions
					Function: SetMoveFields
						Description:
						Returns
							Boolean:
						Parameters
							Number: nYear
							Number: nItemNo
							String: sTreeTypeDesc
							String: sCultDesc
							String: sRootDesc
							Number: nCount
							Date/Time: dtWhenAvail
							String: sNotForSale
							Number: nLocationId
							String: sFarmName
							Number: nRowNo
							Number: nSeqNo
						Static Variables
						Local variables
						Actions
							Call PushNumber( nYear )
							Call PushNumber( nItemNo )
							Call PushString( sTreeTypeDesc )
							Call PushString( sCultDesc )
							Call PushString( sRootDesc )
							Call PushNumber( nCount )
							Call PushDateTime( dtWhenAvail )
							Call PushString( sNotForSale )
							Call PushNumber( nLocationId )
							Call PushString( sFarmName )
							Call PushNumber( nRowNo )
							Call PushNumber( nSeqNo )
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbFarmLocations.nActivateWindowType = ACTIVATE_FormWindow
						Set clspbFarmLocations.sActivateDialogName = 'frmStockMovement'
						Set clspbFarmLocations.hWndTable = hWndPickIntoTable
						Set clspbFarmLocations.hWndParentTable = hWndPickIntoTable
						Set clspbFarmLocations.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushWndHdl( hWndItem )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopWndHdl( hWndTmp, TRUE )
						Return TRUE
					On PAM_clsFARMS_GETDATA
						Return FALSE

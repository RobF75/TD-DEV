		Named Menus
		Internal Functions
			Function: GetLocationId
				Description:
				Returns
					Boolean:
				Parameters
					String: sFarmName
					Number: nRow
					Number: nSeq
					Receive Number: nLocationId
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Number: nGotLocationId
					Number: nInd
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetLocationId' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  Location_Id 
									FROM 
									  Location 
									WHERE 
									  Farm_Name = :1 AND 
									  Row# = :2 AND 
									  Seq# = :3 "
							Set sName = 'GTFRMLOC'
							Set sBind = ':sFarmName, :nRow, :nSeq'
							Set sInto = ':nGotLocationId'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set nLocationId = NUMBER_Null
							Set nGotLocationId = NUMBER_Null
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									Set nLocationId = nGotLocationId
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
			Function: InsNewLocation
				Description:
				Returns
					Boolean:
				Parameters
					String: sFarmName
					Number: nRow
					Number: nSeq
					Receive Number: nLocationId
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
					Number: nOurInsHandleNo
					Number: nGotLocationId
					Number: nInd
					String: sAddedBy
					Date/Time: dtAddedDT
					Boolean: bOk
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'InsNewLocationSelect' )
					Set nOurInsHandleNo = SqlHandlesGetReferenceNo( 'InsNewLocationInsert' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " SELECT 
									  MAX( Location_Id ) + 1
									FROM 
									  Location "
							Set sName = 'GTMXLOC'
							Set sBind = ''
							Set sInto = ':nGotLocationId'
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Set sSql = " INSERT INTO Location 
									( 
									  Location_Id, 
									  Farm_Name, 
									  Row#, 
									  Seq#, 
									  Loc_Added_By, 
									  Loc_Added_Date 
									) VALUES ( :1, :2, :3, :4, :5, :6 ) "
							Set sName = 'INSLOCLOC'
							Set sBind = ':nGotLocationId, :sFarmName, :nRow, :nSeq, :sAddedBy, :dtAddedDT'
							Set sInto = ''
							Call haSqlHandles[ nOurInsHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurInsHandleNo ].hSqlHandle )
							!
							Set nLocationId = NUMBER_Null
							Set nGotLocationId = NUMBER_Null
							Set sAddedBy = SqlUser
							Set dtAddedDT = SalDateCurrent(  )
							If haSqlHandles[ nOurHandleNo ].Execute( )
								If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									If nGotLocationId >= 0
										Set nLocationId = nGotLocationId
									Else
										Set nGotLocationId = 1
										Set nLocationId = 1
									If haSqlHandles[ nOurInsHandleNo ].Execute( )
										Call haSqlHandles[ nOurInsHandleNo ].Commit( )
										Return TRUE
									Else
										Return FALSE
								Else
									Return FALSE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nOurHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nOurInsHandleNo ].Disconnect( )
								Set bOk = FALSE
							Return bOk
			Function: DeleteLocation
				Description:
				Returns
					Boolean:
				Parameters
					Number: nLocationId
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'DeleteLocation' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " DELETE FROM Location WHERE Location_Id = :1 "
							Set sName = 'DELLOCLOC'
							Set sBind = ':nLocationId'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							If haSqlHandles[ nOurHandleNo ].Execute( )
								Call haSqlHandles[ nOurHandleNo ].Commit( )
								Return TRUE
							Else
								Return FALSE
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )

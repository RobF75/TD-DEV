				Functions
					Function: SetBulkAddFarmLocationsFields
						Description:
						Returns
							Boolean:
						Parameters
							Window Handle: hWndNewTable
							Number: nNewPAM_ADDROWMESSAGE
						Static Variables
						Local variables
						Actions
							Set hWndTable = hWndNewTable
							Set nPAM_ADDROWMESSAGE = nNewPAM_ADDROWMESSAGE
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndTable = hWndItem
						Set nPAM_ADDROWMESSAGE = NUMBER_Null
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbBulkAddFarmLocations.nActivateWindowType = ACTIVATE_DialogModal
						Set clspbBulkAddFarmLocations.sActivateDialogName = 'dlgBulkAddFarmLocations'
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushNumber( nPAM_ADDROWMESSAGE )
						Call PushWndHdl( hWndTable )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopWndHdl( hWndTable, TRUE )
						Call PopNumber( nPAM_ADDROWMESSAGE, TRUE )
						Return TRUE

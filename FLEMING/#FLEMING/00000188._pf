										:clsfrmFarmLocations.tblFarmLocations.colChangedDate, 
										:clsfrmFarmLocations.tblFarmLocations.colLastEstSaleDate'
								!
								Set sSQLRefreshHandle = "SELECT 
										  Growing_Sale.Location_Id, 
										  Location.Farm_Name, 
										  Location.Row#, 
										  Location.Row#, 
										  Location.Seq#, 
										  Location.Seq#, 

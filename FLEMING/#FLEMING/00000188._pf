								Set bAddRowBellow = TRUE
							On PAM_clsTBL_SAVECHANGES
								Call OurWaitCursor( TRUE )
								Set bOk = TRUE
								Call fcStrRecalcItemsStack.StackInit( )
								Call fcStrDailyChangesItemsStack.StackInit( )
								If SalSendClassMessage( PAM_clsTBL_SAVECHANGES, wParam, lParam )
									While fcStrRecalcItemsStack.StackPop( sTmp ) AND bOk
										Call ExtractItemYearComb( sTmp, naItemNos[ 0 ], nTmpYear )
										Set naItemNos[ 1 ] = NUMBER_Null
										If NOT RecalculateInventoryFigures( naItemNos, nTmpYear, 'SELECTED', SH_cls_Execute )
											Set bOk = FALSE
									!
									While fcStrDailyChangesItemsStack.StackPop( sTmp ) AND bOk
										Call ExtractItemYearLocIdComb( sTmp, naItemNos[ 0 ], nTmpYear, naItemNos[ 1 ] )
										If InsertPotsDailyItemAffected( naItemNos[ 0 ], nTmpYear, naItemNos[ 1 ], SH_cls_Execute )
											Call InsertPotsDailyItemAffected( 0, 0, 0, SH_cls_Commit )
								Else
									Set bOk = FALSE
								Call OurWaitCursor( FALSE )
								Return bOk
							On PAM_clsTBL_SAVEROWEDITED
								Call fcStrRecalcItemsStack.StackPushUnique( MakeItemYearComb( hWndParent.clsfrmAllocatedOrders.nItemNo, colOrgYearOfSale ) )
								If colYearOfSale != colOrgYearOfSale
									Call fcStrRecalcItemsStack.StackPushUnique( MakeItemYearComb( hWndParent.clsfrmAllocatedOrders.nItemNo, colYearOfSale ) )
								! If ReBatchAllocateCustOrders( colCustNo, colOrderDT, colYearOfSale, colLocationId, SH_cls_Execute )
									              Call ReBatchAllocateCustOrders( 0, DATETIME_Null, 0, 0, SH_cls_Commit )
								Return SalSendClassMessage( PAM_clsTBL_SAVEROWEDITED, wParam, lParam )
							On SAM_Destroy
								! Call ReBatchAllocateCustOrders( 0, DATETIME_Null, 0, 0, SH_cls_Disconnect )
								Call InsertPotsDailyItemAffected( 0, 0, 0, SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

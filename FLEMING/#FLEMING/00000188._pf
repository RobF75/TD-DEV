					On PAM_clsDLG_POPFIELDS
						Call PopString( dfRootDesc, TRUE )
						Call PopString( dfCultDesc, TRUE )
						Call PopString( dfTreeTypeDesc, TRUE )
						Call PopNumber( dfSeqNo, TRUE )
						Call PopNumber( dfRowNo, TRUE )
						Return TRUE
					On PAM_clsDLG_PUSHFIELDS
						Call PushNumber( dfRowNo )
						Call PushNumber( dfSeqNo )
						Call PushString( dfTreeTypeDesc )
						Call PushString( dfCultDesc )
						Call PushString( dfRootDesc )
						Return TRUE

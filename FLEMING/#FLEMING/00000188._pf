								On PAM_cls_SETINSTANCEVARS
									Set pbAllocatedOrders.hWndPickIntoTable = tblFarmLocations
								On PAM_cls_SETFIELDS
									Call pbAllocatedOrders.SetAllocatedOrdersFields( tblFarmLocations.colOrgYear, 
											tblFarmLocations.colLocationId, 

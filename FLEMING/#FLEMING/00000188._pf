											  Growing_Sale.Year_Of_Sale, 
											  Growing_Sale.Stock_Item_No, 
											  Growing_Sale.Stock_Item_No, 
											  Stock_Item.Stock_Type, 
											  Stock_Item.Tree_Type_Desc, 
											  Stock_Item.Cult_Desc, 
											  Stock_Item.Root_Desc, 
											  'N', 
											  Growing_Sale.Beg_Count, 
											  Growing_Sale.First_Count, 
											  Growing_Sale.Second_Count, 
											  Growing_Sale.Second_Count, 
											  Growing_Sale.Est_Sale_Date, 
											  Growing_Sale.Est_Sale_Date, 
											  Growing_Sale.Future_Stock, 
											  Growing_Sale.Forward_Orders, 
											  Growing_Sale.Not_For_Sale, 
											  Growing_Sale.Date_Planted, 
											  Growing_Sale.Date_Budded, 
											  Growing_Sale.Growing_Comm, 
											  Growing_Sale.Added_By, 
											  Growing_Sale.Added_Date, 
											  Growing_Sale.Changed_By, 
											  Growing_Sale.Changed_Date, 
											  Growing_Sale.LastEstSaleDate 
											FROM 
											  Growing_Sale, 
											  Location, 
											  Stock_Item 
											WHERE 
											  Growing_Sale.Location_Id = Location.Location_Id AND 
											  Growing_Sale.Stock_Item_No = Stock_Item.Item_No(+) AND 
											  Location.Farm_Name = :1 
											ORDER BY 
											  Location.Row#, 
											  Location.Seq# "
									Set sNAMEPopHandle = 'PPFRMLOCGY4'
									Set sBINDPopHandle = ':hWndParent.clsfrmFarmLocations.dfFarmName'
								Else
									Set sSQLPopHandle = "SELECT 
											  Growing_Sale.Location_Id, 
											  Location.Farm_Name, 
											  Location.Row#, 
											  Location.Row#, 
											  Location.Seq#, 
											  Location.Seq#, 
											  Location.Loc_Added_By, 
											  Location.Loc_Added_Date, 
											  Growing_Sale.Year_Of_Sale, 
											  Growing_Sale.Year_Of_Sale, 
											  Growing_Sale.Stock_Item_No, 
											  Growing_Sale.Stock_Item_No, 
											  Stock_Item.Stock_Type, 
											  Stock_Item.Tree_Type_Desc, 
											  Stock_Item.Cult_Desc, 
											  Stock_Item.Root_Desc, 
											  'N', 
											  Growing_Sale.Beg_Count, 
											  Growing_Sale.First_Count, 
											  Growing_Sale.Second_Count, 
											  Growing_Sale.Second_Count, 
											  Growing_Sale.Est_Sale_Date, 
											  Growing_Sale.Est_Sale_Date, 
											  Growing_Sale.Future_Stock, 
											  Growing_Sale.Forward_Orders, 
											  Growing_Sale.Not_For_Sale, 
											  Growing_Sale.Date_Planted, 
											  Growing_Sale.Date_Budded, 
											  Growing_Sale.Growing_Comm, 
											  Growing_Sale.Added_By, 
											  Growing_Sale.Added_Date, 
											  Growing_Sale.Changed_By, 
											  Growing_Sale.Changed_Date, 
											  Growing_Sale.LastEstSaleDate 
											FROM 
											  Growing_Sale, 
											  Location, 
											  Stock_Item 
											WHERE 
											  Growing_Sale.Location_Id = Location.Location_Id AND 
											  Growing_Sale.Stock_Item_No = Stock_Item.Item_No(+) AND 
											  Location.Farm_Name = :1 AND 
											  Growing_Sale.Year_Of_Sale = :2 
											ORDER BY 
											  Location.Row#, 
											  Location.Seq# "
									Set sNAMEPopHandle = 'PPFRMLOCOY3'
									Set sBINDPopHandle = ':hWndParent.clsfrmFarmLocations.dfFarmName, :hWndParent.clsfrmFarmLocations.nYear'
								Set sINTOPopHandle = ':clsfrmFarmLocations.tblFarmLocations.colLocationId,
										:clsfrmFarmLocations.tblFarmLocations.colFarmName,
										:clsfrmFarmLocations.tblFarmLocations.colRowNo,
										:clsfrmFarmLocations.tblFarmLocations.colOrgRowNo,

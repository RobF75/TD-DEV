										:clsfrmAllocatedOrders.tblAllocatedOrders.colConfAmt, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colYearOfSale, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colLocationId, 
										:SqlUser'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE Customer_Order 
										SET 
										  Ordered_Amount = :3, 
										  Conf_Amt = :4, 
										  Year_Of_Sale = :5, 
										  Batch_Year_Of_Sale = :5, 
										  Batch_Location_Id = :6 
										WHERE 
										  Cust_No = :1 AND 
										  Order_Date_Time = :2 '
								Set sNAMEUpdateHandle = 'UPDBTCHALOCOR3'
								Set sBINDUpdateHandle = ':clsfrmAllocatedOrders.tblAllocatedOrders.colCustNo, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colOrderDT, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colOrdAmt,
										:clsfrmAllocatedOrders.tblAllocatedOrders.colConfAmt, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colYearOfSale, 
										:clsfrmAllocatedOrders.tblAllocatedOrders.colLocationId'
								Set sINTOUpdateHandle = ''

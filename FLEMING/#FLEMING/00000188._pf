		Functions
		Window Parameters
			Number: nTotalAmount
		Window Variables
		Message Actions
			On SAM_CreateComplete
				Set dfTotalAmount = nTotalAmount
				Set dfSplitOne = SalNumberTruncate( nTotalAmount / 2 + 0.5 , 5, 0 )
				Set dfSplitTwo = nTotalAmount - dfSplitOne
				! Call OurWaitCursorOverride( FALSE, TRUE )
				Call SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
			On PAM_clsPB_OKACTION
				Call PushNumber( dfSplitTwo )
				Call PushNumber( dfSplitOne)
				Return SalSendMsg( pbExit, SAM_Click, TRUE, 0 )

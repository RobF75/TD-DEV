										WHERE 
										  Cust_No = :1 AND 
										  Order_Date_Time = :2 '
								Set sNAMEInsertHandle = 'INSBTCHALOCOR3'
								Set sBINDInsertHandle = ':clsfrmAllocatedOrders.tblAllocatedOrders.colCustNo, 

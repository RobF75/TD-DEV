								On PAM_clsPB_CLICK
									Set bFirst = TRUE
									Return SalSendClassMessage( PAM_clsPB_CLICK, wParam, lParam )
								On PAM_clsFARMS_GETDATA
									If bFirst
										Set bFirst = FALSE
										Set nRow = TBL_MinRow
									If SalTblFindNextRow( tblFarmLocations, nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( tblFarmLocations, nRow )
										Call pbStockMovement.SetMoveFields( tblFarmLocations.colOrgYear, 
												tblFarmLocations.colOrgItemNo, 
												tblFarmLocations.colTreeTypeDesc, 
												tblFarmLocations.colCultDesc, 

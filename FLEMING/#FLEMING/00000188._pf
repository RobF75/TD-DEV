							Column: colToFarmName
								Class Child Ref Key: 0
								Class ChildKey: 48
								Class: clsColDropListGeneral
								Property Template:
								Class DLL Name:
								Title: Farm Name
								Visible? Class Default
								Editable? Class Default
								Maximum Data Length: 8
								Data Type: Class Default
								Justify: Class Default
								Width:  Class Default
								Width Editable? Class Default
								Format: Uppercase
								Country: Class Default
								Input Mask: Class Default
								Cell Options
									Cell Type? Class Default
									Multiline Cell? Class Default
									Cell DropDownList
										Sorted? Class Default
										Vertical Scroll? Class Default
										Auto Drop Down? Class Default
										Allow Text Editing? Class Default
									Cell CheckBox
										Check Value:
										Uncheck Value:
										Ignore Case? Class Default
								List Values
								Message Actions
									On PAM_clsTBL_DATAVAL
										If SalIsNull( hWndItem )
											Call ErrorMessage( 'Please enter a Farm Name First!', hWndForm, lParam )
											Return FALSE
										Else
											Call ExistsFarmName( colToFarmName, bOk, SH_cls_Execute )
											If bOk
												Return TRUE
											Else
												Call ErrorMessage( 'The TO Farm does not exists.  Please verify the farm name first!', hWndForm, lParam )
												Return FALSE
									On PAM_cls_SETINSTANCEVARS
										Set colToFarmName.sSqlPopStatement = 'SELECT DISTINCT Farm_Name FROM Farm_Master'
										Set colToFarmName.bPopulateOnce = TRUE
							Column: colToRowNo

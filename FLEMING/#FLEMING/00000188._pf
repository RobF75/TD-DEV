						Functions
							Function: GetPickListLocationExtras
								Description:
								Returns
									Boolean:
								Parameters
									Number: nLocationId
									Number: nItemNo
									Number: nYear
									Receive Number: nCount
									Receive Number: nSold
									Number: nActionType
								Static Variables
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									Number: nInd
									Number: nGotCount
									Number: nGotSold
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetPickListLocationExtras' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT 
													  Growing_Sale.Second_Count, 
													  Growing_Sale.Forward_Orders 
													FROM 
													  Growing_Sale 
													WHERE 
													  Growing_Sale.Location_Id = :1 AND 
													  Growing_Sale.Stock_Item_No = :2 AND 
													  Growing_Sale.Year_Of_Sale = :3 "
											Set sName = 'GPKLSTLOCEX2'
											Set sBind = ':nLocationId, :nItemNo, :nYear'
											Set sInto = ':nGotCount, :nGotSold'
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set nCount = NUMBER_Null
											Set nSold = NUMBER_Null
											Set nGotCount = NUMBER_Null
											Set nGotSold = NUMBER_Null
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set nCount = nGotCount
													Set nSold = nGotSold
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
						Window Variables
							: fcStrRecalcItemsStack
								Class: strStack
							Number: naItemNos[ 2 ]
							Number: nTmpYear
							String: sTmp
							Boolean: bOk
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = " SELECT 
										  Day_Pts_Pck_Lst.List_No, 
										  Day_Pts_Pck_Lst.Row_No, 
										  Day_Pts_Pck_Lst.Stock_Item_No, 
										  Stock_Item.Tree_Type_Desc, 
										  Stock_Item.Cult_Desc, 
										  Stock_Item.Root_Desc, 
										  Day_Pts_Pck_Lst.Location_Id, 
										  Day_Pts_Pck_Lst.Year_Of_Sale, 
										  Location.Farm_Name, 
										  Location.Row#, 
										  Location.Seq#, 
										  Day_Pts_Pck_Lst.Quantity, 
										  NULL, 
										  NULL 
										FROM 
										  Day_Pts_Pck_Lst, 
										  Stock_Item, 
										  Location 
										WHERE 
										  Day_Pts_Pck_Lst.Stock_Item_No = Stock_Item.Item_No AND 
										  Day_Pts_Pck_Lst.Location_Id = Location.Location_Id AND 
										  Day_Pts_Pck_Lst.List_No = :1 
										ORDER BY 
										  Day_Pts_Pck_Lst.Row_No "
								Set sNAMEPopHandle = 'POPDOPL2'
								Set sBINDPopHandle = ':hWndParent.clsfrmDailyChangesList.dfListNo'
								Set sINTOPopHandle = ':clsfrmDailyChangesList.tblDailyChangesList.colListNo,
										:clsfrmDailyChangesList.tblDailyChangesList.colLineNo,
										:clsfrmDailyChangesList.tblDailyChangesList.colItemNo,
										:clsfrmDailyChangesList.tblDailyChangesList.colTreeTypeDesc,
										:clsfrmDailyChangesList.tblDailyChangesList.colCultDesc,
										:clsfrmDailyChangesList.tblDailyChangesList.colRootDesc,
										:clsfrmDailyChangesList.tblDailyChangesList.colLocationId,
										:clsfrmDailyChangesList.tblDailyChangesList.colYearOfSale,
										:clsfrmDailyChangesList.tblDailyChangesList.colFarmName,
										:clsfrmDailyChangesList.tblDailyChangesList.colRowNo,
										:clsfrmDailyChangesList.tblDailyChangesList.colSeqNo,
										:clsfrmDailyChangesList.tblDailyChangesList.colCountPerList, 
										:clsfrmDailyChangesList.tblDailyChangesList.colCountPerDB, 
										:clsfrmDailyChangesList.tblDailyChangesList.colSoldPerDB'
								!
								Set sSQLRefreshHandle = "SELECT 
										  Day_Pts_Pck_Lst.List_No, 
										  Day_Pts_Pck_Lst.Row_No, 
										  Day_Pts_Pck_Lst.Stock_Item_No, 
										  Stock_Item.Tree_Type_Desc, 
										  Stock_Item.Cult_Desc, 
										  Stock_Item.Root_Desc, 
										  Day_Pts_Pck_Lst.Location_Id, 
										  Day_Pts_Pck_Lst.Year_Of_Sale, 
										  Location.Farm_Name, 
										  Location.Row#, 
										  Location.Seq#, 
										  Day_Pts_Pck_Lst.Quantity, 
										  Growing_Sale.Second_Count, 
										  Growing_Sale.Forward_Orders  
										FROM 
										  Day_Pts_Pck_Lst, 
										  Stock_Item, 
										  Location, 
										  Growing_Sale 
										WHERE 
										  Day_Pts_Pck_Lst.Stock_Item_No = Stock_Item.Item_No AND 
										  Day_Pts_Pck_Lst.Location_Id = Location.Location_Id AND 
										  Day_Pts_Pck_Lst.Stock_Item_No = Growing_Sale.Stock_Item_No AND 
										  Day_Pts_Pck_Lst.Location_Id = Growing_Sale.Location_Id AND 
										  Day_Pts_Pck_Lst.Year_Of_Sale = Growing_Sale.Year_Of_Sale AND 
										  Day_Pts_Pck_Lst.List_No = :1 AND 
										  Day_Pts_Pck_Lst.Row_No = :2 
										ORDER BY 
										  Day_Pts_Pck_Lst.Row_No "
								Set sNAMERefreshHandle = 'REFDOPL2'
								Set sBINDRefreshHandle = ':clsfrmDailyChangesList.tblDailyChangesList.colListNo, 
										:clsfrmDailyChangesList.tblDailyChangesList.colLineNo'
								Set sINTORefreshHandle = ':clsfrmDailyChangesList.tblDailyChangesList.colListNo,
										:clsfrmDailyChangesList.tblDailyChangesList.colLineNo,
										:clsfrmDailyChangesList.tblDailyChangesList.colItemNo,
										:clsfrmDailyChangesList.tblDailyChangesList.colTreeTypeDesc,
										:clsfrmDailyChangesList.tblDailyChangesList.colCultDesc,
										:clsfrmDailyChangesList.tblDailyChangesList.colRootDesc,
										:clsfrmDailyChangesList.tblDailyChangesList.colLocationId,
										:clsfrmDailyChangesList.tblDailyChangesList.colYearOfSale,
										:clsfrmDailyChangesList.tblDailyChangesList.colFarmName,
										:clsfrmDailyChangesList.tblDailyChangesList.colRowNo,
										:clsfrmDailyChangesList.tblDailyChangesList.colSeqNo, 
										:clsfrmDailyChangesList.tblDailyChangesList.colCountPerList, 
										:clsfrmDailyChangesList.tblDailyChangesList.colCountPerDB, 
										:clsfrmDailyChangesList.tblDailyChangesList.colSoldPerDB'
								!
								Set sSQLInsertHandle = ''
								Set sNAMEInsertHandle = ''
								Set sBINDInsertHandle = ''
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE Growing_Sale 
										SET 
										  Second_Count = :4 
										WHERE 
										  Stock_Item_No = :1 AND 
										  Year_Of_Sale = :2 AND 
										  Location_Id = :3 '
								Set sNAMEUpdateHandle = 'UPDTDOPPLGS'
								Set sBINDUpdateHandle = ':clsfrmDailyChangesList.tblDailyChangesList.colItemNo,
										:clsfrmDailyChangesList.tblDailyChangesList.colYearOfSale,
										:clsfrmDailyChangesList.tblDailyChangesList.colLocationId,
										:clsfrmDailyChangesList.tblDailyChangesList.colCountPerDB'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = ''
								Set sNAMEDeleteHandle = ''
								Set sBINDDeleteHandle = ''
								!
								Set bAddAllowed = FALSE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = FALSE
								Set bUnDeleteAllowed = FALSE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								Set bQueryAllowed = FALSE
								Set bReportAllowed = FALSE
								Set bOrderAllowed = FALSE
							On PAM_clsTBL_SAVECHANGES
								Call fcStrRecalcItemsStack.StackInit( )
								If SalSendClassMessage( PAM_clsTBL_SAVECHANGES, wParam, lParam )
									Set bOk = TRUE
									While fcStrRecalcItemsStack.StackPop( sTmp ) AND bOk
										Call ExtractItemYearComb( sTmp, naItemNos[ 0 ], nTmpYear )
										Set naItemNos[ 1 ] = NUMBER_Null
										If NOT RecalculateInventoryFigures( naItemNos, nTmpYear, 'SELECTED', SH_cls_Execute )
											Set bOk = FALSE
									Return bOk
								Else
									Return FALSE
							On PAM_clsTBL_SAVEROWEDITED
								Call fcStrRecalcItemsStack.StackPushUnique( MakeItemYearComb( colItemNo, colYearOfSale ) )
								Return SalSendClassMessage( PAM_clsTBL_SAVEROWEDITED, wParam, lParam )
							On SAM_FetchRowDone
								Call GetPickListLocationExtras( colLocationId, colItemNo, colYearOfSale, colCountPerDB, colSoldPerDB, SH_cls_Execute )
								Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
							On SAM_Destroy
								Call RecalculateInventoryFigures( naItemNos, 0, '', SH_cls_Disconnect )
								Call GetPickListLocationExtras( 0, 0, 0, colCountPerDB, colSoldPerDB, SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
				Class Variables
				Instance Variables
				Functions
					Function: GetPickListDateRange
						Description:
						Returns
							Boolean:
						Parameters
							Number: nListNo
							Receive Date/Time: dtFromDate
							Receive Date/Time: dtToDate
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							Number: nInd
							Date/Time: dtGotFromDate
							Date/Time: dtGotToDate
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetPickListDateRange' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT 
											  From_Date, 
											  To_Date  
											FROM 
											  Day_Pts_Pck_Lst  
											WHERE 
											  List_No = :1 "
									Set sName = 'GTDOPPLDR'
									Set sBind = ':nListNo'
									Set sInto = ':dtGotFromDate, :dtGotToDate'
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set dtFromDate = DATETIME_Null
									Set dtToDate = DATETIME_Null
									Set dtGotFromDate = DATETIME_Null
									Set dtGotToDate = DATETIME_Null
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
											Set dtFromDate = dtGotFromDate
											Set dtToDate = dtGotToDate
										Return TRUE
									Else
										Return TRUE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set bQueryAllowed = FALSE
						Set bAddAllowed = FALSE
						Set bSaveAllowed = TRUE
						Set bDeleteAllowed = FALSE
						Set bUnDeleteAllowed = FALSE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = FALSE
						Set hWndChildTable = tblDailyChangesList
					On PAM_clsFRM_POPFIELDS
						Call PopNumber( dfListNo, TRUE )
						Call PopWndHdl( hWndActivateButton, TRUE )
						Return TRUE
					On SAM_CreateComplete
						Call GetPickListDateRange( dfListNo, dfFromDate, dfToDate, SH_cls_Execute )
						Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
					On SAM_Destroy
						Call GetPickListDateRange( 0, dfFromDate, dfToDate, SH_cls_Disconnect )
						Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
			!

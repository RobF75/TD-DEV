				Derived From
					Class: clsDialogGeneral
				Class Variables
					Number: nRow
					Number: nRowEnd
					Number: nRowInc
					Number: nSeq
					Number: nTmp
					Boolean: bOk
				Instance Variables
					Window Handle: hWndTable
					Number: nPAM_ADDROWMESSAGE
				Functions
				Message Actions
					On PAM_clsDLG_POPFIELDS
						Call PopWndHdl( hWndTable, TRUE )
						Call PopNumber( nPAM_ADDROWMESSAGE, TRUE )
						Return TRUE
					On PAM_clsPB_OKACTION
						Set nRow = SalStrToNumber( ccStartingRowNo.GetNumber( ) )
						Set nRowEnd = SalStrToNumber( ccEndingRowNo.GetNumber( ) )
						Set nRowInc = SalStrToNumber( ccIncrementRowBy.GetNumber( ) )
						Set nSeq = SalStrToNumber( ccSequenceNo.GetNumber( ) )
						Set bOk = TRUE
						While nRow <= nRowEnd AND bOk
							If SalSendMsg( hWndTable, nPAM_ADDROWMESSAGE, nSeq, nRow )
								Set nRow = nRow + nRowInc
							Else
								Set bOk = FALSE
						Return bOk
			!
			Pushbutton Class: clspbDailyChangesList
				Title: DayList
				Window Location and Size
					Left:  
					Top:   
					Width:  Class Default
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default

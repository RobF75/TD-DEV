		Functions
		Window Parameters
			Receive Number: nListNo
		Window Variables
		Message Actions
			On SAM_CreateComplete
				Set nListNo = NUMBER_Null
				Call SalSetFocus( dfDailyPickListNo )
				Call SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
				Call OurWaitCursorOverride( FALSE, TRUE )
			On PAM_clsPB_OKACTION
				If SalIsNull( dfDailyPickListNo )
					Call SalMessageBox( 'Please enter a List No first!', 'Warning', MB_Ok )
					Return FALSE
				Else
					Set nListNo = dfDailyPickListNo
					Return SalSendMsg( pbExit, SAM_Click, TRUE, 0 )

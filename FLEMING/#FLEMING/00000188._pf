						Functions
							Function: CheckFarmIdExists
								Description:
								Returns
									Boolean:
								Parameters
									String: sFarmId
									Receive Boolean: bExists
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'CheckFarmIdExists' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Farm_Name 
													FROM Farm_Master  
													WHERE Farn_Name = :1"
											Set sName = 'FARMEXISTS'
											Set sBind = ':sFarmId'
											Set sInto = ''
											!
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set bExists = FALSE
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set bExists = TRUE
												Else
													Set bExists = FALSE
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: CheckFarmLocationsExists
								Description:
								Returns
									Boolean:
								Parameters
									String: sFarmId
									Receive Boolean: bExists
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'CheckFarmLocationsExists' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Farm_Name 
													FROM Location  
													WHERE Farm_Name = :1"
											Set sName = 'FARMLOCEXISTS'
											Set sBind = ':sFarmId'
											Set sInto = ''
											!
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set bExists = FALSE
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set bExists = TRUE
												Else
													Set bExists = FALSE
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
						Window Variables
							Boolean: bExists
							String: sQueryFarmId
							String: sQueryFarmDescription
							String: sQueryFarmPostcode
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = " SELECT 
										  Farm_Name, 
										  Farm_Description, 
										  Farm_Address_1, 
										  Farm_Address_2, 
										  Farm_Suburb,
										  Farm_Postcode 
										FROM 
										  Farm_Master 
										WHERE 
										  Farm_Name LIKE 'C%' 
										ORDER BY 
										  Farm_Name "
								Set sNAMEPopHandle = 'POPFARMSN'
								Set sBINDPopHandle = ''
								Set sINTOPopHandle = ':clsfrmFarms.tblFarms.colFarmId, 
										:clsfrmFarms.tblFarms.colFarmDescription, 
										:clsfrmFarms.tblFarms.colFarmAdd1, 
										:clsfrmFarms.tblFarms.colFarmAdd2, 
										:clsfrmFarms.tblFarms.colFarmSuburb, 
										:clsfrmFarms.tblFarms.colFarmPostcode'
								!
								Set sSQLRefreshHandle = ' SELECT 
										  Farm_Description, 
										  Farm_Address_1, 
										  Farm_Address_2, 
										  Farm_Suburb,
										  Farm_Postcode 
										FROM 
										  Farm_Master 
										WHERE 
										  Farm_Name = :1 '
								Set sNAMERefreshHandle = 'REFFARMSN'
								Set sBINDRefreshHandle = ':clsfrmFarms.tblFarms.colFarmId'
								Set sINTORefreshHandle = ':clsfrmFarms.tblFarms.colFarmDescription, 
										:clsfrmFarms.tblFarms.colFarmAdd1, 
										:clsfrmFarms.tblFarms.colFarmAdd2, 
										:clsfrmFarms.tblFarms.colFarmSuburb, 
										:clsfrmFarms.tblFarms.colFarmPostcode'
								!
								Set sSQLInsertHandle = ' INSERT INTO Farm_Master 
										( Farm_Name, 
										  Farm_Description, 
										  Farm_Address_1, 
										  Farm_Address_2, 
										  Farm_Suburb,
										  Farm_Postcode )
										VALUES ( :1, :2, :3, :4, :5, :6 ) '
								Set sNAMEInsertHandle = 'INSFARMSN'
								Set sBINDInsertHandle = ':clsfrmFarms.tblFarms.colFarmId, 
										:clsfrmFarms.tblFarms.colFarmDescription, 
										:clsfrmFarms.tblFarms.colFarmAdd1, 
										:clsfrmFarms.tblFarms.colFarmAdd2, 
										:clsfrmFarms.tblFarms.colFarmSuburb, 
										:clsfrmFarms.tblFarms.colFarmPostcode'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE Farm_Master 
										SET  
										  Farm_Description = :2, 
										  Farm_Address_1 = :3, 
										  Farm_Address_2 = :4, 
										  Farm_Suburb = :5, 
										  Farm_Postcode = :6 
										WHERE 
										  Farm_Name = :1 '
								Set sNAMEUpdateHandle = 'UPDTFARMSN'
								Set sBINDUpdateHandle = ':clsfrmFarms.tblFarms.colFarmId, 
										:clsfrmFarms.tblFarms.colFarmDescription, 
										:clsfrmFarms.tblFarms.colFarmAdd1, 
										:clsfrmFarms.tblFarms.colFarmAdd2, 
										:clsfrmFarms.tblFarms.colFarmSuburb, 
										:clsfrmFarms.tblFarms.colFarmPostcode'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = 'DELETE FROM Farm_Master 
										WHERE 
										  Farm_Name = :1 '
								Set sNAMEDeleteHandle = 'DELFARMSN'
								Set sBINDDeleteHandle = ':clsfrmFarms.tblFarms.colFarmId'
								Set sINTODeleteHandle = ''
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								Set bQueryAllowed = TRUE
								Set bReportAllowed = FALSE
								Set bOrderAllowed = TRUE
								!
								Set sQueryDialogName = 'dlgQueryFarms'
								Set hWndRowNewColumn = colFarmId
							On PAM_clsTBL_PUSHFIELDS
								Call PushString( sQueryFarmId )
								Call PushString( sQueryFarmDescription )
								Call PushString( sQueryFarmPostcode )
								Return TRUE
							On PAM_clsTBL_POPFIELDS
								Call PopString( sQueryFarmPostcode, TRUE )
								Call PopString( sQueryFarmDescription, TRUE )
								Call PopString( sQueryFarmId, TRUE )
								Return TRUE
							On SAM_Destroy
								Call CheckFarmIdExists( '', bExists, SH_cls_Disconnect )
								Call CheckFarmLocationsExists( '', bExists, SH_cls_Disconnect )
								Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
				Class Variables
					String: sChildButtonChanged
				Instance Variables
				Functions
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set bQueryAllowed = TRUE
						Set bOrderAllowed = TRUE
						Set hWndChildTable = tblFarms
					On PAM_cls_REFRESHAFTRCHILDCHANGE
						Set sChildButtonChanged = SalNumberToHString( lParam )
						If sChildButtonChanged = 'pbFarmLocationsAllYears' OR sChildButtonChanged = 'pbFarmLocationsAllYears' OR sChildButtonChanged = 'pbDailyPickList'
							Return FALSE
						Else
							Return TRUE

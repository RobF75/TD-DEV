						Functions
						Window Variables
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = " SELECT 
										  Growing_Sale.Year_Of_Sale, 
										  Growing_Sale.Location_Id, 
										  Location.Farm_Name, 
										  Location.Row#, 
										  Location.Seq#, 
										  Growing_Sale.Second_Count, 
										  Growing_Sale.Est_Sale_Date, 
										  Growing_Sale.Not_For_Sale, 
										  Growing_Sale.Forward_Orders 
										FROM 
										  Growing_Sale, 
										  Location 
										WHERE 
										  Growing_Sale.Location_Id = Location.Location_Id AND 
										  Growing_Sale.Stock_Item_No = :1 AND 
										  ( Growing_Sale.Not_For_Sale = 'N' OR 
										  Growing_Sale.Not_For_Sale IS NULL ) 
										ORDER BY 
										  Growing_Sale.Est_Sale_Date "
								Set sNAMEPopHandle = 'POPPITMBTCHS'
								Set sBINDPopHandle = ':hWndParent.clsfrmItemBatches.nItemNo'
								Set sINTOPopHandle = ':clsfrmItemBatches.tblItemBatches.colYearOfSale, 
										:clsfrmItemBatches.tblItemBatches.colLocationId, 
										:clsfrmItemBatches.tblItemBatches.colFarmName, 
										:clsfrmItemBatches.tblItemBatches.colRowNo, 
										:clsfrmItemBatches.tblItemBatches.colSeqNo, 
										:clsfrmItemBatches.tblItemBatches.colSecondCount, 
										:clsfrmItemBatches.tblItemBatches.colWhenAvail, 
										:clsfrmItemBatches.tblItemBatches.colNotForSale, 
										:clsfrmItemBatches.tblItemBatches.colForwardOrders'
								!
								Set sSQLRefreshHandle = " SELECT 
										  Growing_Sale.Year_Of_Sale, 
										  Growing_Sale.Location_Id, 
										  Location.Farm_Name, 
										  Location.Row#, 
										  Location.Seq#, 
										  Growing_Sale.Second_Count, 
										  Growing_Sale.Est_Sale_Date, 
										  Growing_Sale.Not_For_Sale, 
										  Growing_Sale.Forward_Orders 
										FROM 
										  Growing_Sale, 
										  Location 
										WHERE 
										  Growing_Sale.Location_Id = Location.Location_Id AND 
										  Growing_Sale.Stock_Item_No = :1 AND 
										  Growing_Sale.Year_Of_Sale = :2 AND 
										  Growing_Sale.Location_Id = :3 "
								Set sNAMERefreshHandle = 'REFPITMBTCHS'
								Set sBINDRefreshHandle = ':hWndParent.clsfrmItemBatches.nItemNo, 
										:clsfrmItemBatches.tblItemBatches.colYearOfSale, 
										:clsfrmItemBatches.tblItemBatches.colLocationId'
								Set sINTORefreshHandle = ':clsfrmItemBatches.tblItemBatches.colYearOfSale, 
										:clsfrmItemBatches.tblItemBatches.colLocationId, 
										:clsfrmItemBatches.tblItemBatches.colFarmName, 
										:clsfrmItemBatches.tblItemBatches.colRowNo, 
										:clsfrmItemBatches.tblItemBatches.colSeqNo, 
										:clsfrmItemBatches.tblItemBatches.colSecondCount, 
										:clsfrmItemBatches.tblItemBatches.colWhenAvail, 
										:clsfrmItemBatches.tblItemBatches.colNotForSale, 
										:clsfrmItemBatches.tblItemBatches.colForwardOrders'
								!
								Set sSQLInsertHandle = ''
								Set sNAMEInsertHandle = ''
								Set sBINDInsertHandle = ''
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ''
								Set sNAMEUpdateHandle = ''
								Set sBINDUpdateHandle = ''
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = ''
								Set sNAMEDeleteHandle = ''
								Set sBINDDeleteHandle = ''
								!
								Set bAddAllowed = FALSE
								Set bSaveAllowed = FALSE
								Set bDeleteAllowed = FALSE
								Set bUnDeleteAllowed = FALSE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								Set bQueryAllowed = FALSE
								Set bReportAllowed = FALSE
								Set bOrderAllowed = FALSE
				Class Variables
				Instance Variables
					Number: nItemNo
				Functions
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set bQueryAllowed = FALSE
						Set bAddAllowed = FALSE
						Set bSaveAllowed = FALSE
						Set bDeleteAllowed = FALSE
						Set bUnDeleteAllowed = FALSE
						Set bReportAllowed = FALSE
						Set bOrderAllowed = FALSE
						Set hWndChildTable = tblItemBatches
					On PAM_clsFRM_POPFIELDS
						Call PopString( dfRootDesc, TRUE )
						Call PopString( dfCultDesc, TRUE )
						Call PopString( dfTreeTypeDesc, TRUE )
						Call PopNumber( nItemNo, TRUE )
						Call PopWndHdl( hWndActivateButton, TRUE )
						Return TRUE
			!

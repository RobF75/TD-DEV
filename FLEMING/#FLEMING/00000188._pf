										  Invoiced_flag,
										  Invoice_no,
										  Invoiced_date,
										  Invoiced_by,
										  Alloc_flag,
										  Conf_flag,
										  :5,
										  :8,
										  Pull_sheet_issued,
										  Pull_sheet_date,
										  Pull_sheet_by,
										  Npa_sent_flag,
										  Npa_sent_date,
										  Npa_recd_flag,
										  Npa_recd_date,
										  Ack_flag,
										  Spec_requirement,
										  Order_comments,
										  Lbl_pullsh_printed,
										  Ass_cust_no,
										  Associated_date,
										  Subs_item_no,
										  Cont_price_flag,
										  Custom_bud_flag,
										  Cb_deposit_reqd,
										  Cb_full_pay_flag,
										  Cb_own_buds_supp,
										  Cb_comments,

			Pushbutton Class: clspbFarmLocations
				Title: On Farm
				Window Location and Size
					Left:  
					Top:   
					Width:  Class Default
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name: C:\Centura\icons\Farms.bmp
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				List in Tool Palette? Yes
				Property Template:
				Class DLL Name:
				Description:
				Derived From
					Class: clspbPickInto
				Class Variables
					String: sTmp
					Number: nTmp
					Window Handle: hWndTmp
				Instance Variables
					! ! PUBLIC
					Window Handle: hWndPickIntoTable
					! ! PRIVATE
					String: sFarmName
					String: sFarmDescription
					Number: nYear
					Boolean: bAndAllGreaterYears
				Functions
					Function: SetFarmLocationsFields
						Description:
						Returns
							Boolean:
						Parameters
							String: sNewFarmName
							String: sNewFarmDescription
							Number: nNewYear
							Boolean: bNewAndAllGreaterYears
						Static Variables
						Local variables
						Actions
							Set sFarmName = sNewFarmName
							Set sFarmDescription = sNewFarmDescription
							Set nYear = nNewYear
							Set bAndAllGreaterYears = bNewAndAllGreaterYears
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbFarmLocations.nActivateWindowType = ACTIVATE_FormWindow
						Set clspbFarmLocations.sActivateDialogName = 'frmFarmLocations'
						Set clspbFarmLocations.hWndTable = hWndPickIntoTable
						Set clspbFarmLocations.hWndParentTable = hWndPickIntoTable
						Set clspbFarmLocations.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushWndHdl( hWndItem )
						Call PushString( sFarmName )
						Call PushString( sFarmDescription )
						Call PushNumber( nYear )
						Call PushNumber( bAndAllGreaterYears )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopWndHdl( hWndTmp, TRUE )
						Return TRUE

										  Cont_price_flag,
										  Custom_bud_flag,
										  Cb_deposit_reqd,
										  Cb_full_pay_flag,
										  Cb_own_buds_supp,
										  Cb_comments,
										  Contract_price,
										  Contract_exists,
										  Contract_comments,
										  Contract_terms,
										  Contract_dep_reqd,
										  Credit_note_no,
										  No_trees_credited,
										  Trialpack_reqd,
										  Trialpack_sentflag,
										  Trialpack_sentdate,
										  Trialpack_recdflag,
										  Trialpack_recddate,
										  Credited_amount,
										  Purchase_order_no,
										  Hold_order_date,
										  No_subs_reason,
										  Batch_year_of_sale,
										  Batch_location_id,
										  Invoice_tree_price,
										  Inv_tree_roy_ownr,
										  Inv_tree_fmn,
										  Inv_tree_fna,
										  Cr_base_price_only,
										  Picklist_no 
										) 
										SELECT 
										  :1,
										  :3,
										  Stock_item_no,
										  :6,
										  Load_id,
										  Subs_ok_flag,
										  :4,
										  Ord_date,

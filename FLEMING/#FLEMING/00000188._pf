				Instance Variables
					! ! PUBLIC
					Window Handle: hWndPickIntoTable
					! ! PRIVATE
					Number: nYear
					Number: nLocationId
					Number: nItemNo
					String: sTreeTypeDesc
					String: sCultDesc
					String: sRootDesc
				Functions
					Function: SetAllocatedOrdersFields
						Description:
						Returns
							Boolean:
						Parameters
							Number: nNewYear
							Number: nNewLocationId
							Number: nNewItemNo
							String: sNewTreeTypeDesc
							String: sNewCultDesc
							String: sNewRootDesc
						Static Variables
						Local variables
						Actions
							Set nYear = nNewYear
							Set nLocationId = nNewLocationId
							Set nItemNo = nNewItemNo
							Set sTreeTypeDesc = sNewTreeTypeDesc
							Set sCultDesc = sNewCultDesc
							Set sRootDesc = sNewRootDesc
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbAllocatedOrders.nActivateWindowType = ACTIVATE_FormWindow
						Set clspbAllocatedOrders.sActivateDialogName = 'frmAllocatedOrders'
						Set clspbAllocatedOrders.hWndTable = hWndPickIntoTable
						Set clspbAllocatedOrders.hWndParentTable = hWndPickIntoTable
						Set clspbAllocatedOrders.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushWndHdl( hWndItem )
						Call PushNumber( nYear )
						Call PushNumber( nLocationId )
						Call PushNumber( nItemNo )
						Call PushString( sTreeTypeDesc )
						Call PushString( sCultDesc )
						Call PushString( sRootDesc )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopWndHdl( hWndTmp, TRUE )
						Return TRUE

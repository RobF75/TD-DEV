								Cell Options
									Cell Type? Class Default
									Multiline Cell? Class Default
									Cell DropDownList
										Sorted? Class Default
										Vertical Scroll? Class Default
										Auto Drop Down? Class Default
										Allow Text Editing? Class Default
									Cell CheckBox
										Check Value:
										Uncheck Value:
										Ignore Case? Class Default
								List Values
								Message Actions
									On PAM_cls_SETINSTANCEVARS
										Set colFarmId.bOrderBy = TRUE
									On PAM_clsTBL_EDITCHECK
										If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
											Return TRUE
										Else
											Return FALSE
									On PAM_clsTBL_DATAVAL
										If SalIsNull( hWndItem )
											Call ErrorMessage( 'Please enter a Farm ID first!', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE
									On PAM_clsTBL_CHECKROWNEW
										Call CheckFarmIdExists( colFarmId, bExists, SH_cls_Disconnect )
										If bExists
											Call ErrorMessage( 'Farm Id is already exists.  Cannot add.', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE
									On PAM_clsTBL_CHECKROWDELETED
										Call CheckFarmLocationsExists( colFarmId, bExists, SH_cls_Disconnect )
										If bExists
											Call ErrorMessage( 'Farm Id still has Locations allocated to it.  Cannot delete.', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE

								List Values
								Message Actions
									On SAM_DoubleClick
										If NOT colPullFlag = 'Y' AND NOT SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
											If SalModalDialog( dlgSplitOrder, hWndItem, colConfAmt )
												Set bOk = tblAllocatedOrders.bAddAllowed
												Set tblAllocatedOrders.bAddAllowed = TRUE
												!
												Set nTmpCustNo = colCustNo
												Set sTmpCustName = colCustName
												Call PopNumber( colConfAmt, TRUE )
												Call SalSetFieldEdit( colConfAmt, TRUE )
												Set colOrdAmt = colConfAmt
												Set sTmpSaleCat = colSaleCat
												Set sTmpPullFlag = colPullFlag
												Set nTmpLocationId = colLocationId
												Set nTmpOrgLocationId = colOrgLocationId
												Set nTmpYearOfSale = colYearOfSale
												Set nTmpOrgYearOfSale = colOrgYearOfSale
												Set sTmpFarmName = colFarmName
												Set nTmpRowNo = colRowNo
												Set nTmpSeqNo = colSeqNo
												Set dtTmpSplitFromOrderDT = colOrderDT
												If SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
													Set colCustNo = nTmpCustNo
													Set colCustName = sTmpCustName
													Call PopNumber( colConfAmt, TRUE )
													Set colOrdAmt = colConfAmt
													Set colSaleCat = sTmpSaleCat
													Set colPullFlag = sTmpPullFlag
													Set colLocationId = nTmpLocationId
													Set colOrgLocationId = nTmpOrgLocationId
													Set colYearOfSale = nTmpYearOfSale
													Set colOrgYearOfSale = nTmpOrgYearOfSale
													Set colFarmName = sTmpFarmName
													Set colRowNo = nTmpRowNo
													Set colSeqNo = nTmpSeqNo
													Set colSplitFromOrderDT = dtTmpSplitFromOrderDT
												Set tblAllocatedOrders.bAddAllowed = bOk

				List in Tool Palette? Yes
				Property Template:
				Class DLL Name:
				Description:
				Derived From
					Class: clspbPickInto
				Class Variables
					Number: nTmp
					Window Handle: hWndTmp
				Instance Variables
					! ! PUBLIC
					Window Handle: hWndPickIntoTable
					! ! PRIVATE
					Number: nListNo
				Functions
					Function: SetDailyPickListFields
						Description:
						Returns
							Boolean:
						Parameters
							Number: nNewListNo
						Static Variables
						Local variables
						Actions
							Set nListNo = nNewListNo
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbDailyChangesList.nActivateWindowType = ACTIVATE_FormWindow
						Set clspbDailyChangesList.sActivateDialogName = 'frmDailyChangesList'
						Set clspbDailyChangesList.hWndTable = hWndPickIntoTable
						Set clspbDailyChangesList.hWndParentTable = hWndPickIntoTable
						Set clspbDailyChangesList.hWndFieldLookUp = hWndItem
					On PAM_clsPB_CLICK
						If SalModalDialog( dlgGetDailyListNo, hWndItem, nListNo )
							Return SalSendClassMessage( PAM_clsPB_CLICK, wParam, lParam )
						Else
							Return FALSE
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushWndHdl( hWndItem )
						Call PushNumber( nListNo )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopNumber( nTmp, TRUE )
						Call PopWndHdl( hWndTmp, TRUE )
						Return TRUE

.head 5 -  Call GetItemFullBasicDetails( naItemNos[ nPos ], tblSelectedItems.colTreeType, sTmp, tblSelectedItems.colCultDesc, sTmp, tblSelectedItems.colRootDesc, nExecute )
.head 5 +  If bSelectedQuantities

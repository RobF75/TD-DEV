.head 5 +  On PAM_CLICK
.head 6 +  If rbFieldCount
.head 7 -  Set sLabelUse = 'FC'
.head 6 +  Else If rbBarCode
.head 7 -  Set sLabelUse = 'BC'
.head 6 +  Else 
.head 7 -  Set sLabelUse = 'HG'
.head 6 -  !
.head 6 -  Set bOk = TRUE
.head 6 -  Set nPos = 0
.head 6 -  Set naItemNos[ nPos ] = NUMBER_Null
.head 6 -  Set naQuantities[ nPos ] = NUMBER_Null
.head 6 -  Call MyTableLoop( tblSelectedItems, hWndItem, PAM_ROWACTION, 0, 0, 'Collecting Quantites', nLowToHi )
.head 6 -  !
.head 6 +  If bOk 
.head 7 -  Call PrintStockItemsLabels( nCustNo, sCustName, naItemNos, naQuantities, sLabelUse, sTMPFILE, nExecute )
.head 6 +  Else 
.head 7 -  Call SalMessageBox( 'Please make sure that all quantites are greater than zero first!', 'Warning', MB_Ok )
.head 5 +  On PAM_ROWACTION
.head 6 +  If tblSelectedItems.colQuantity <= 0
.head 7 -  Set bOk = FALSE
.head 6 -  Set naItemNos[ nPos ] = tblSelectedItems.colItemNo
.head 6 -  Set naQuantities[ nPos ] = tblSelectedItems.colQuantity
.head 6 -  Set nPos = nPos + 1
.head 6 -  Set naItemNos[ nPos ] = NUMBER_Null
.head 6 -  Set naQuantities[ nPos ] = NUMBER_Null
.head 6 -  Return TRUE

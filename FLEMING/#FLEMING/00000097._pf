.head 5 -  Number: nGotFieldValue
.head 5 -  String: sPrioSpacesString
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetFieldValue' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Call SalStrLeft( sDataDesc, SalStrScan( sDataDesc, '.' ), sTable )
.head 7 -  Set bNumber = FALSE
.head 7 -  Set nOffSet = NUMBER_Null
.head 7 +  If sTable = 'CULTIVAR'
.head 8 +  If sDataDesc = 'CULTIVAR.CV_LABEL_LINE_1'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||', CV_LL1_OFFSET '||' 
FROM Stock_Item, Cultivar 
INTO :sGotFieldValue, :nOffSet
WHERE 
  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Cultivar_Id = Cultivar.Cult_Id'
.head 8 +  Else If sDataDesc = 'CULTIVAR.CV_LABEL_LINE_2'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||', CV_LL2_OFFSET '||' 
FROM Stock_Item, Cultivar 
INTO :sGotFieldValue, :nOffSet
WHERE 
  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Cultivar_Id = Cultivar.Cult_Id'
.head 8 +  Else If sDataDesc = 'CULTIVAR.CV_LABEL_LINE_3'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||', CV_LL3_OFFSET '||' 
FROM Stock_Item, Cultivar 
INTO :sGotFieldValue, :nOffSet
WHERE 
  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Cultivar_Id = Cultivar.Cult_Id'
.head 8 +  Else If sDataDesc = 'CULTIVAR.CV_LABEL_LINE_4'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||', CV_LL4_OFFSET '||' 
FROM Stock_Item, Cultivar 
INTO :sGotFieldValue, :nOffSet
WHERE 
  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Cultivar_Id = Cultivar.Cult_Id'
.head 8 +  Else If sDataDesc = 'CULTIVAR.CV_LABEL_LINE_5'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||', CV_LL5_OFFSET '||' 
FROM Stock_Item, Cultivar 
INTO :sGotFieldValue, :nOffSet
WHERE 
  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Cultivar_Id = Cultivar.Cult_Id'
.head 8 +  Else If sDataDesc = 'CULTIVAR.VARIETY'
.head 9 -  Set sSql = 'SELECT Variety 
FROM Stock_Item 
INTO :sGotFieldValue 
WHERE 
  Stock_Item.Item_No = :nItemNo '
.head 8 +  Else If sDataDesc = 'CULTIVAR.CULT_DESC'
.head 9 -  Set sSql = 'SELECT Cult_Desc 
FROM Stock_Item 
INTO :sGotFieldValue 
WHERE 
  Stock_Item.Item_No = :nItemNo '
.head 8 +  Else
.head 9 -  Set sSql = 'SELECT '||sDataDesc||
' FROM Stock_Item, Cultivar 
INTO :sGotFieldValue 
WHERE 
  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Cultivar_Id = Cultivar.Cult_Id'
.head 7 +  Else If sTable = 'ROOTSTOCK'
.head 8 +  If sDataDesc = 'ROOTSTOCK.RT_LABEL_LINE_1'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||', RT_LL1_OFFSET '||' 
FROM Stock_Item, Rootstock 
INTO :sGotFieldValue, :nOffSet
WHERE 
  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Rootstock_Id = Rootstock.Root_Id'
.head 8 +  Else If sDataDesc = 'ROOTSTOCK.RT_LABEL_LINE_2'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||', RT_LL2_OFFSET '||' 
FROM Stock_Item, Rootstock 
INTO :sGotFieldValue, :nOffSet
WHERE 
  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Rootstock_Id = Rootstock.Root_Id'
.head 8 +  Else If sDataDesc = 'ROOTSTOCK.RT_LABEL_LINE_3'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||', RT_LL3_OFFSET '||' 
FROM Stock_Item, Rootstock 
INTO :sGotFieldValue, :nOffSet
WHERE 
  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Rootstock_Id = Rootstock.Root_Id'
.head 8 +  Else If sDataDesc = 'ROOTSTOCK.RT_LABEL_LINE_4'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||', RT_LL4_OFFSET '||' 
FROM Stock_Item, Rootstock 
INTO :sGotFieldValue, :nOffSet
WHERE 
  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Rootstock_Id = Rootstock.Root_Id'
.head 8 +  Else If sDataDesc = 'ROOTSTOCK.RT_LABEL_LINE_5'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||', RT_LL5_OFFSET '||' 
FROM Stock_Item, Rootstock 
INTO :sGotFieldValue, :nOffSet
WHERE 
  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Rootstock_Id = Rootstock.Root_Id'
.head 8 +  Else If sDataDesc = 'ROOTSTOCK.ROOT_DESC'
.head 9 -  Set sSql = 'SELECT Root_Desc
FROM Stock_Item 
INTO :sGotFieldValue 
WHERE 
  Stock_Item.Item_No = :nItemNo'
.head 8 +  Else
.head 9 -  Set sSql = 'SELECT '||sDataDesc||
' FROM Stock_Item, Rootstock 
INTO :sGotFieldValue 
WHERE 
  Stock_Item.Item_No = :nItemNo AND 
  Stock_Item.Rootstock_Id = Rootstock.Root_Id'
.head 7 +  Else If sTable = 'FARM_MASTER'
.head 8 -  Set sSql = 'SELECT '||sDataDesc||
' FROM Farm_Master, Location 
INTO :sGotFieldValue
WHERE 
  Farm_Master.Farm_Name = Location.Farm_Name AND Location.Location_Id = :nLocId'
.head 7 +  Else If sTable = 'LOCATION'
.head 8 +  If sDataDesc = 'LOCATION.ROW#' OR sDataDesc = 'LOCATION.SEQ#'
.head 9 -  Set bNumber = TRUE
.head 9 -  Set sSql = 'SELECT '||sDataDesc||
' FROM Location 
INTO :nGotFieldValue
WHERE 
  Location_Id = :nLocId'
.head 8 +  Else
.head 9 -  Set sSql = 'SELECT '||sDataDesc||
' FROM Location 
INTO :sGotFieldValue
WHERE 
  Location_Id = :nLocId'
.head 7 +  Else If sTable = 'STOCK_ITEM'
.head 8 +  If sDataDesc = 'STOCK_ITEM.ITEM_NO'
.head 9 -  Set sSql = 'SELECT '||sDataDesc||
' FROM Stock_Item 
INTO :nGotFieldValue
WHERE Item_No = :nItemNo'
.head 9 -  Set nGotFieldValue = nItemNo
.head 9 -  Set bNumber = TRUE
.head 8 +  Else
.head 9 -  Set sSql = 'SELECT '||sDataDesc||
' FROM Stock_Item 
INTO :sGotFieldValue
WHERE Item_No = :nItemNo'
.head 7 +  Else If sTable = 'TREE_TYPE'
.head 8 -  Set sSql = 'SELECT '||sDataDesc||
' FROM Stock_Item, Tree_Type 
INTO :sGotFieldValue
WHERE Stock_Item.Item_No = :nItemNo AND 
Stock_Item.Tree_Type = Tree_Type.Tree_Type '
.head 7 +  Else If sTable = 'CUSTOMER_MASTER'
.head 8 +  If sDataDesc = 'CUSTOMER_MASTER.CUST_NO'
.head 9 -  Set sFieldValue = SalNumberToStrX( nCustNo, 0 )
.head 9 -  Return TRUE
.head 8 +  Else If sDataDesc = 'CUSTOMER_MASTER.CUST_NAME'
.head 9 -  Set sFieldValue = sCustName
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Set sSql = 'SELECT '||sDataDesc||
' FROM Customer_Master 
INTO :sGotFieldValue
WHERE Cust_No = :nCustNo '
.head 7 +  Else
.head 8 -  Call SalMessageBox( 'Undefined lookup table for datafield. Error retrieving Data', 'Labels', MB_Ok )
.head 8 -  Return FALSE
.head 7 -  !
.head 7 -  Call haSqlHandles[ nOurHandleNo ].RePrepare( )
.head 7 -  Call haSqlHandles[ nOurHandleNo ].PrepareSetup( sSql )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set sFieldValue = ''
.head 7 -  Set sGotFieldValue = ''
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].PrepareAndExecute( )
.head 8 -  Call haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 8 +  If nOffSet > 0
.head 9 -  Set sPrioSpacesString = ''
.head 9 -  Call SalStrRepeat( ' ', nOffSet, sPrioSpacesString )
.head 9 -  Set sGotFieldValue = sPrioSpacesString || sGotFieldValue
.head 8 +  If bNumber
.head 9 -  Set sGotFieldValue = SalNumberToStrX( nGotFieldValue, 0 )
.head 8 -  Set sFieldValue = sGotFieldValue
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 3 +  Function: ReplaceAtCharToRegisteredChar
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Receive String: sFormatString
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sRegisteredMark
.head 4 +  Actions
.head 5 -  Set sRegisteredMark = ' '
.head 5 -  ! Call CStructPutByte( sRegisteredMark, 0, 169 )
.head 5 -  Set sRegisteredMark = SalNumberToChar( 169 )
.head 5 -  !
.head 5 -  Call StringReplace( sFormatString, '@', sRegisteredMark )
.head 3 +  Function: PicIsLoaded
.head 4 -  Description: Checks if the picture file has been loaded before into the saLabelPics array.
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: sPicFileName
.head 5 -  String: saLabelPics[*]
.head 5 -  Number: nNumLabelPics
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nCount
.head 5 -  Boolean: bFound
.head 4 +  Actions
.head 5 +  If nNumLabelPics > 0
.head 6 -  Set nCount = 1
.head 6 +  While ( nCount <= nNumLabelPics AND NOT bFound ) 
.head 7 +  If saLabelPics[ nCount ] = sPicFileName
.head 8 -  Set bFound = TRUE
.head 7 +  Else
.head 8 -  Set nCount = nCount + 1
.head 6 +  If bFound
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  Else
.head 6 -  Return FALSE
.head 3 +  Function: ExtractPicName
.head 4 -  Description: ! The next blocked code extracts the flem3 part of a filename f:\apps\ezilabl\flem3.img
NOTE must specify full drive:\\path\\filename.extension eg f:\apps\ezilabl\flem3.img
NOTE This will extract the name regardless of the file extension'
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: sPicFile
.head 5 -  Receive String: sPicName
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nDotPos
.head 5 -  Number: nBackSlashPos
.head 4 +  Actions
.head 5 -  Set nDotPos = FindCharInFileNameFromEnd( sPicFile, '.' )
.head 5 -  Set nBackSlashPos = FindCharInFileNameFromEnd( sPicFile, '\\' )
.head 5 +  If nDotPos >= 0 AND nBackSlashPos >= 0
.head 6 -  Set sPicName = SalStrMidX( sPicFile, nBackSlashPos+1, nDotPos - nBackSlashPos - 1 )
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Set sPicName = ''
.head 6 -  Return FALSE
.head 3 +  Function: FindCharInFileNameFromEnd
.head 4 -  Description: Returns a positive integer representing the seach character and -1 for not found
.head 4 +  Returns
.head 5 -  Number:
.head 4 +  Parameters
.head 5 -  String: sPicFile
.head 5 -  String: sFindChar
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nPos
.head 5 -  Boolean: bFound
.head 4 +  Actions
.head 5 -  Set bFound = FALSE
.head 5 -  Set nPos = SalStrLength( sPicFile ) - 1
.head 5 +  While nPos >= 0 AND NOT bFound
.head 6 +  If SalStrMidX( sPicFile, nPos, 1 ) = sFindChar
.head 7 -  Set bFound = TRUE
.head 6 +  Else
.head 7 -  Set nPos = nPos - 1
.head 5 +  If bFound
.head 6 -  Return nPos
.head 5 +  Else
.head 6 -  Return -1

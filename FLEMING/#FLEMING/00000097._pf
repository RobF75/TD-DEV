.head 5 -  !
.head 5 -  ! Direct printing to Barcode using a DC (device context)
.head 5 -  ! Refer to the Microsoft SDK manuals
.head 5 -  !
.head 5 -  ! Set hWndPrinterDC = CreateDC( 'EPSON9', 'Epson DFX-5000 Barcode','LPT3',0 )
.head 5 +  If hWndPrinterDC = hWndNULL
.head 6 -  Call SalMessageBox('Create DC failed','Message',MB_Ok)
.head 6 -  Call SalWaitCursor( FALSE )
.head 6 -  Return FALSE
.head 5 -  Set strBuffer = sLabelFile
.head 5 -  Set nLength = SalStrLength(strBuffer)
.head 5 -  ! Set nReturn = Escape(hWndPrinterDC, 10, nLength+1, strBuffer,0)
.head 5 -  !
.head 5 -  Set nLength = 100
.head 5 -  ! Set nLength = 4500
.head 5 -  !
.head 5 -  Set nTotalBytesRead = 0
.head 5 +  While nTotalBytesRead < nFileSize
.head 6 -  Set nBytesRead = SalFileRead( hOutFile, sLabelFormat, nLength )
.head 6 -  Set nTotalBytesRead = nTotalBytesRead + nBytesRead
.head 6 -  Set sLength = '00'
.head 6 -  Call CStructPutWord( sLength, 0, nBytesRead )
.head 6 -  Set sLabelFormat = sLength || sLabelFormat
.head 6 -  ! Set nReturn = Escape(hWndPrinterDC, 19, nBytesRead, sLabelFormat,0)
.head 5 -  !
.head 5 -  Call SalFileClose( hOutFile )
.head 5 -  !
.head 5 -  Set nLength = SalStrLength(strBuffer)
.head 5 -  ! Set nReturn = Escape(hWndPrinterDC, 11, nLength, strBuffer,0)

.head 4 +  While naItemNos[ nPos ] != NUMBER_Null
.head 5 -  !
.head 5 -  Set nRow = SalTblInsertRow( tblSelectedItems, TBL_MaxRow )
.head 5 -  Call SalTblSetContext( tblSelectedItems, nRow )
.head 5 -  Call SalTblSetRowFlags( tblSelectedItems, nRow, ROW_HideMarks, TRUE )
.head 5 -  Set tblSelectedItems.nTotalRows = tblSelectedItems.nTotalRows + 1

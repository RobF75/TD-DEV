			Sql Handle: hSqlCustHandle
			Boolean: bCustHdlConnected
			Boolean: bCustHdlPrepared
			File Handle: fhBarcode
			String: sFileString
			: fcCustOrders[*]
				Class: fcCustomerOrders
			Number: nCustCount
			Number: nMaxCustCount
			Boolean: bFirstCust
			Number: nYear
			String: sCultDesc
			String: sBitMap
		Message Actions
			On SAM_CreateComplete
				! Set sReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', 'k:\Centura\Reports' ) || ' \\Barcode.qrp'
				! Set sCustNo = '510089'
				! Set sCustName = 'Pike River'
				Set sReportVars = 'nCustNo, sCustName, sItemNo, sCultDesc, sBitMap'
				Set sReportInto = 'CustNo, CustName, ItemNo, CultDesc, BitMap'
				If NOT SalReportPrint( hWndForm,  'k:\\Centura\\Reports\\Barcode.qrp', sReportVars, sReportInto, 1, RPT_PrintAll, 0, 0, nErr )
					Call SalMessageBox(SalNumberToStrX( nErr, 0 ), 'Error', MB_Ok)
			On SAM_Create
			On SAM_ReportStart
				! If NOT bCustHdlConnected
					                        Set bAllCustHdlConnected = SqlConnect( hSqlCustHandle )
					                        If bAllCustHdlConnected
						                        Call SqlSetLockTimeout( hSqlCustHandle, SQLTIMEOUT )
						                        Call SqlSetParameter( hSqlCustHandle, DBP_PRESERVE, TRUE, ''  )
					                        Else 
						                        Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						                        Return FALSE
				! If NOT bCustHdlPrepared
					                        If TRUE
						                        Set sSql = " SELECT 
									
								FROM
								  Customer_Master,
								  Customer_Type,
								  Customer_Order,
								  Stock_Item
								INTO :frmPrintCustomerTAs.dfCustno
								WHERE
								  Customer_Master.Cust_No = Customer_Order.Cust_No AND
								  Customer_Order.Year_Of_Sale = :frmPrintCustomerTAs.dfYr AND
								  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND
								  Customer_Master.Customer_Type = Customer_Type.Cust_Type AND
								  Customer_Master.Customer_Type LIKE '%OR%' AND
								  Customer_Type.NPA_Required = 'Y' AND
								  ( NOT Customer_Master.FNA_Flag = 'Y' OR
								    Customer_Master.FNA_Flag IS NULL ) AND
								 Customer_Order.Conf_Amt > 0 AND
								  ( NOT Customer_Order.TA_Recd_Flag = 'Y' OR
								    Customer_Order.TA_Recd_Flag IS NULL ) AND
								   (Stock_Item.cv_on_trial_flag = 'Y'  or Stock_Item.rt_on_trial_flag = 'Y' or
								  customer_order.sale_cat in ('FC', 'TT')) AND
								  NOT Customer_Order.Sale_Cat != 'RP' "
					                        If SqlPrepare( hSqlCustHandle, sSql )
						                        Set bCustHdlPrepared = TRUE
					                        Else 
						                        Set bCustHdlPrepared = FALSE
				If NOT SalFileOpen( fhBarcode, 'c:\\centura\\graham\\barcode.txt', OF_ReadWrite | OF_Create )
					Call SalMessageBox('File Open Error', 'Error', MB_Ok)
					Return FALSE
			On SAM_ReportFetchInit
				Set nCount = 0
				Set nCustCount = 0
				Set nQuantityCount = 0
				Set nQuantity = 0
				If TRUE
					Set sSelect = 
							"Select
								customer_master.cust_no,
								cust_name,
								stock_item_no,
								cult_desc,
								conf_amt,
								bitmap
							into
								:nCustNo,
								:sCustName,
								:nItemNo,
								:sCultDesc,
								:nConfAmt,
								:sCustLogoFile
							from
								customer_master,
								customer_order,
								stock_item,
								load_customers
							where
								customer_order.stock_item_no = stock_item.item_no and
								load_customers.cust_no = customer_order.cust_no and
								customer_master.cust_no = customer_order.cust_no and
								load_customers.load_id = :sLoadId and
								customer_order.conf_amt > 0 and
								year_of_sale = :nYear
							order by 
								load_customers.sequence_no,
								customer_master.cust_no
							"
				! Set nCopies = 0
				! Set nOptions = RPT_PrintAll
				Set bSqlConnect = SqlConnect( hSqlItem)
				Set nCount = 0
				Set nCustCount = 0
				Set nYear = SalDateYear( dtYearOfSale )
				! Call SalReportPrint( hWndForm, 'c:\\centura\\graham\\testbarcode.qrp', 
						'sVariety, sCultDesc, sPvr', 'Variety, Cult_Desc, Pvr', nCopies, nOptions, nFirstPage, nLastPage, nErr )
				If not SqlPrepare( hSqlItem, sSelect )
					Call SalMessageBox('Prepare error', 'Error', MB_Ok)
				If NOT SqlExecute( hSqlItem )
					Call SalMessageBox('Execute','Error', MB_Ok)
				While SqlFetchNext( hSqlItem, nInd )
					Set fcCustOrders[nCustCount].fnCustNo = nCustNo
					Set fcCustOrders[nCustCount].fsCustName = sCustName
					Set fcCustOrders[nCustCount].fnItemNo = nItemNo
					Set fcCustOrders[nCustCount].fnConfAmt = nConfAmt
					Set fcCustOrders[nCustCount].fsCultDesc = sCultDesc
					Set fcCustOrders[nCustCount].fsCustBitmap = sCustLogoFile
					Set nCustCount = nCustCount + 1
				Set nMaxCustCount = nCustCount
				Set nCustCount = 0
				! Set nPrevCust = NUMBER_Null
				! Call SalModalDialog( dlgPrintBarCodeLabels, hWndForm, 510081, 'Pike River', naItemNo, naQuantity, 'BC' )
			On SAM_ReportFetchNext
				If nMaxCustCount >= nCustCount
					If nQuantityCount = nQuantity
						! If nPrevCust != fcCustOrders.fnCustNo[nCustCount]
						If fcCustOrders[nCustCount].fnConfAmt > 2
							Set nQuantity = 2
						Else
							Set nQuantity = fcCustOrders[nCustCount].fnConfAmt
						Set nQuantityCount = 0
						Set sTemp =  SalNumberToStrX( nItemNo, 0)
						Set sTmp =  SalNumberToStrX( nCustNo, 0)
						Set sFileString = sTmp || ' ' || sCustName || ' ' || sTemp || ''
						If not SalFilePutStr( fhBarcode, sFileString )
							Call SalMessageBox('File Open Error', 'Error', MB_Ok)
							Return FALSE
						Set nCustNo = fcCustOrders[nCustCount] .fnCustNo
						Set sCustName = fcCustOrders[nCustCount].fsCustName
						Set sItemNo = SalFmtFormatNumber( fcCustOrders[nCustCount].fnItemNo, '00000' )
						Set sItemNo = '9317036' || sItemNo
						Set sCultDesc =  fcCustOrders[nCustCount].fsCultDesc
						If fcCustOrders[nCustCount].fsCustBitmap = STRING_Null
							If NOT SalPicSetFile( picCustLogo, OurGetIniFileParameter( 'GENERAL', 'CustLogos', 'J:\\DATA\\LOGOS' ) || '\\' || 'flemings.bmp' )
								Call SalMessageBox('Error','Error', MB_Ok)
								Return FALSE
						Else
							If NOT SalPicSetFile( picCustLogo, OurGetIniFileParameter( 'GENERAL', 'CustLogos', 'J:\\DATA\\LOGOS' ) || '\\' || fcCustOrders[nCustCount].fsCustBitmap )
								Call SalMessageBox('Error','Error', MB_Ok)
								Return FALSE
						If Not SalPicGetString( picCustLogo, PIC_FormatBitmap,  sBitMap )
							Call SalMessageBox('Error','Error',MB_Ok)
							Return FALSE
						! Set nPrevCust = fcCustOrders.fnCustNo[nCustCount]
						Set nCustCount = nCustCount + 1
						Return TRUE
						! If SqlFetchNext( hSqlItem, nInd )
						! Else
							         Set nCustCount = nCustCount + 1
							         If fcCustOrders.fnCustNo[nCustCount]  != NUMBER_Null
								         Return TRUE
							         Else 
								         Return FALSE
					Else
						Set nQuantityCount = nQuantityCount + 1
						Set sTemp =  SalNumberToStrX( nItemNo, 0)
						Set sTmp =  SalNumberToStrX( nCustNo, 0)
						Set sFileString = sTmp || ' ' || sCustName || ' ' || sTemp || ''
						If not  SalFilePutStr( fhBarcode, sFileString )
							Call SalMessageBox('File Open Error', 'Error', MB_Ok)
							Return FALSE
						Return TRUE
				Else
					Return FALSE
			On SAM_ReportFinish
				! Set sTemp =  SalNumberToStrX( nErr, 0)
				! If NOT SalMessageBox(sTemp, 'Error', MB_Ok)
					            Call SalMessageBox('Error', 'Error', MB_Ok)
				Call SalFileClose( fhBarcode )
				Call SalDestroyWindow( hWndForm )
			On SAM_Destroy
				Call SqlDisconnect( hSqlItem )
			On SAM_ReportNotify
				! If lParam = RPT_OutputDetail
					            Set sTemp =  SalNumberToStrX( nItemNo, 0)
					            Call SalMessageBox(sCustNo||' '||sCustName||' '||sTemp,'Detail',MB_Ok)

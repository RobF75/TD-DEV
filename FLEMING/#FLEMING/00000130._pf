					String: sBind
					String: sInto
					String: sName
					Number: nOurHandleNo
				Actions
					Set nOurHandleNo = SqlHandlesGetReferenceNo( 'UpdtGrowSaleRecUsedOnRep' )
					Select Case nActionType
						Case SH_cls_Execute
							Set sSql = " UPDATE Growing_Sale 
									SET 
									  Prntd_Chng_Date = :4 
									WHERE 
									  Stock_Item_No = :1 AND 
									  Year_Of_Sale = :2 AND 
									  Location_Id = :3  "
							Set sName = 'UPDTGSPCNGDT'
							Set sBind = ':nItemNo, :nYear, :nLocationId, :dtUsedDate'
							Set sInto = ''
							Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							Return haSqlHandles[ nOurHandleNo ].Execute( )
						Case SH_cls_Commit
							Return haSqlHandles[ nOurHandleNo ].Commit( )
						Case SH_cls_Rollback
							Return haSqlHandles[ nOurHandleNo ].Rollback( )
						Case SH_cls_Disconnect
							Return haSqlHandles[ nOurHandleNo ].Disconnect( )
		Window Parameters
			String: sReportTypeParam
		Window Variables
			Number: nYear
			Date/Time: dtUsedDate
			Boolean: bFirst
			Number: nLocationId
			! REPORT COLUMNS
			String: sUpperVarietyType
			String: sUpperVariety
			String: sUpperCultDesc
			String: sUpperRootDesc
			String: sUpperTreeTypeDesc
			Number: nItemNo
			String: sVariety
			String: sTreeTypeDesc
			String: sCultDesc
			String: sRootDesc
			Date/Time: dtEstSaleDate
			Date/Time: dtLastEstSaleDate
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				If sReportTypeParam = 'VIEW'
					Set nReportPrintFlags = nReportPrintFlags | RPT_NoPrint
				Set sReportFileNameNoPath = 'ChangedEstSaleDate.qrp'
				Set sReportBind = ':frmChangedEstSaleDate.sUpperVarietyType, 
						  :frmChangedEstSaleDate.sUpperVariety, 
						  :frmChangedEstSaleDate.sUpperCultDesc, 
						  :frmChangedEstSaleDate.sUpperRootDesc, 
						  :frmChangedEstSaleDate.sUpperTreeTypeDesc, 
						  :frmChangedEstSaleDate.nItemNo, 
						  :frmChangedEstSaleDate.sVariety, 
						  :frmChangedEstSaleDate.sTreeTypeDesc, 
						  :frmChangedEstSaleDate.sCultDesc, 
						  :frmChangedEstSaleDate.sRootDesc, 
						  :frmChangedEstSaleDate.dtEstSaleDate, 
						  :frmChangedEstSaleDate.dtLastEstSaleDate'
				Set sReportInto = 'sUpperVarietyType, 
						sUpperVariety, 
						sUpperCultDesc, 
						sUpperRootDesc, 
						sUpperTreeTypeDesc, 
						nItemNo, 
						sVariety, 
						sTreeTypeDesc, 
						sCultDesc, 
						sRootDesc, 
						dtEstSaleDate, 
						dtLastEstSaleDate'
				Set sReportType = 'VIEW'
				!
				Set sReportSql = " SELECT DISTINCT 
						  @UPPER( Stock_Item.Variety_Type ), 
						  @UPPER( Stock_Item.Variety ), 
						  @UPPER( Stock_Item.Cult_Desc ), 
						  @UPPER( Stock_Item.Root_Desc ), 
						  @UPPER( Stock_Item.Tree_Type_Desc ), 
						  Growing_Sale.Stock_Item_No, 
						  Growing_Sale.Location_Id, 
						  Stock_Item.Variety, 
						  Stock_Item.Tree_Type_Desc, 
						  Stock_Item.Cult_Desc, 
						  Stock_Item.Root_Desc, 
						  Growing_Sale.Est_Sale_Date, 
						  Growing_Sale.LastEstSaleDate
						FROM 
						  Growing_Sale, 
						  Stock_Item 
						INTO 
						  :frmChangedEstSaleDate.sUpperVarietyType, 
						  :frmChangedEstSaleDate.sUpperVariety, 
						  :frmChangedEstSaleDate.sUpperCultDesc, 
						  :frmChangedEstSaleDate.sUpperRootDesc, 
						  :frmChangedEstSaleDate.sUpperTreeTypeDesc, 
						  :frmChangedEstSaleDate.nItemNo, 
						  :frmChangedEstSaleDate.nLocationId, 
						  :frmChangedEstSaleDate.sVariety
						  :frmChangedEstSaleDate.sTreeTypeDesc, 
						  :frmChangedEstSaleDate.sCultDesc, 
						  :frmChangedEstSaleDate.sRootDesc, 
						  :frmChangedEstSaleDate.dtEstSaleDate, 
						  :frmChangedEstSaleDate.dtLastEstSaleDate
						WHERE 
						  Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
						  Growing_Sale.Year_Of_Sale >= :frmChangedEstSaleDate.nYear AND 
						  ( Growing_Sale.Est_Sale_Date IS NOT NULL OR 
						    Growing_Sale.LastEstSaleDate IS NOT NULL ) AND 
						  NOT Growing_Sale.LastEstSaleDate = Growing_Sale.Est_Sale_Date AND 
						  Growing_Sale.Prntd_Chng_Date IS NULL AND 
						  Stock_Item.Stock_Type = 'C' 
						ORDER BY 
						  1,2,3,4,5,6,7 "
			On PAM_clsFRM_REPORTSTART
				Set nYear = WhichSeasonYear( SalDateCurrent(  ) )
				Set bFirst = TRUE
				Return TRUE
			On PAM_clsFRM_REPORTFETCHNEXT
				Set bOk = TRUE
				If sReportTypeParam = 'PRINT'
					If bFirst
						Set dtUsedDate = SalDateCurrent(  )
						Set bFirst = FALSE
					If UpdtGrowSaleRecUsedOnRep( nItemNo, nYear, nLocationId, dtUsedDate, SH_cls_Execute )
						Call UpdtGrowSaleRecUsedOnRep( 0, 0, 0, DATETIME_Null, SH_cls_Commit )
					Else
						Set bOk = FALSE
				Return bOk
			On PAM_clsFRM_REPORTFINISH
				Call UpdtGrowSaleRecUsedOnRep( 0, 0, 0, DATETIME_Null, SH_cls_Disconnect )
				Return TRUE

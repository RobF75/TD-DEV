		Window Parameters
		Window Variables
			String: sReportType
		Message Actions
			On PAM_clsPB_OKACTION
				If rbView
					Set sReportType = 'VIEW'
				Else
					Set sReportType = 'PRINT'
				Call SalCreateWindow( frmChangedEstSaleDate, hWndForm, sReportType )
			On PAM_clsFRM_REPORTCLOSED
				Return SalSendMsg( pbExit, SAM_Click, TRUE, 0 )

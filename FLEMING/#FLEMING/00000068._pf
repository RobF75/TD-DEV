.head 4 +  Instance Variables
.head 5 -  ! PUBLIC
.head 5 -  Window Handle: hWndTable
.head 5 -  ! hWndSelectParent the handle of the button or form that will receive the PAM_clsPICK_SENDROW
  Ussualy the clspbPickInto
.head 5 -  Window Handle: hWndSelectParent
.head 5 -  ! nSelectType = PICK_SelectOneToMany by default OR PICK_SelectManyToMany
.head 5 -  Number: nSelectType
.head 5 -  ! nSelectDirection = TBL_cls_LowToHi by default OR TBL_cls_HiToLow
.head 5 -  Number: nSelectDirection
.head 4 -  Functions
.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Set hWndTable = hWndNULL
.head 6 -  Set hWndSelectParent = hWndNULL
.head 6 -  Set nSelectType = PICK_SelectOneToMany
.head 6 -  Set nSelectDirection = TBL_cls_LowToHi
.head 6 -  Call SalSendClassMessage( SAM_Create, wParam, lParam )
.head 6 +  If NOT hWndSelectParent
.head 7 -  Call SalSendMsg( hWndItem, PAM_clsPB_HIDE, 0, 0 )
.head 5 +  On PAM_clsPB_CLICK
.head 6 -  Set bFirst = TRUE
.head 6 +  If nSelectType = PICK_SelectOneToMany
.head 7 -  Set bContinue = TRUE
.head 7 -  Set bFound = FALSE
.head 7 -  !
.head 7 +  While bContinue
.head 8 -  Set nRow = TBL_MinRow
.head 8 +  If SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
.head 9 -  Call SalTblFetchRow( hWndTable, nRow )
.head 9 +  If NOT SalSendMsg( hWndItem, PAM_clsTBL_ROWACTION, nSelectType, nRow )
.head 10 -  Set bContinue = FALSE
.head 8 +  Else
.head 9 -  Call SalMessageBox( 'Row Not Selected', 'Warning', MB_Ok )
.head 9 -  Set bContinue = FALSE
.head 7 -  !
.head 7 -  ! Set bFound = FALSE
.head 7 +  ! If NOT TableLoop( hWndTable, hWndItem, PAM_clsTBL_ROWACTION, nSelectType, ROW_Selected, 0, 'Selecting One to Many Rows', TBL_cls_LowToHi )
.head 8 +  If NOT bFound
.head 9 -  Call SalMessageBox( 'Row Not Selected', 'Warning', MB_Ok )
.head 6 +  Else If nSelectType = PICK_SelectManyToMany
.head 7 -  Set bFound = FALSE
.head 7 +  If NOT TableLoop( hWndTable, hWndItem, PAM_clsTBL_ROWACTION, nSelectType, ROW_Selected, 0, 'Selecting Many to Many Rows', nSelectDirection )
.head 8 +  If NOT bFound
.head 9 -  Call SalMessageBox( 'Row Not Selected', 'Warning', MB_Ok )
.head 6 +  If bFound
.head 7 -  Call SalPostMsg( hWndForm, PAM_cls_CLOSE, TRUE, 0 )
.head 5 +  On PAM_clsTBL_ROWACTION
.head 6 -  Set bFound = TRUE
.head 6 +  If bFirst
.head 7 -  Call SalSendMsg( hWndSelectParent, PAM_clsPICK_READYFORFIRSTROW, 0, 0 )
.head 7 -  Set bFirst = FALSE
.head 6 -  Return SalSendMsg( hWndItem, PAM_clsPICK_SENDROW, wParam, lParam )
.head 5 +  On PAM_clsPICK_SENDROW
.head 6 +  If SalSendMsg( hWndItem, PAM_clsPICK_PUSHFIELDS, 0, 0 )
.head 7 +  If SalSendMsg( hWndSelectParent, PAM_clsPICK_RECEIVEROW, nSelectType, nSelectDirection )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Call SalSendMsg( hWndItem, PAM_clsPICK_POPFIELDS, 0, 0 )
.head 8 -  Return FALSE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  On PAM_clsPICK_PUSHFIELDS
.head 6 -  Return FALSE
.head 5 +  On PAM_clsPICK_POPFIELDS
.head 6 -  Return FALSE

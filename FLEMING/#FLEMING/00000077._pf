		Internal Functions
			Function: UserTableActions
				Description:
				Returns
					Boolean:
				Parameters
					Window Handle: hWndChildTable
					Number: wParam
					Number: lParam
				Static Variables
				Local variables
				Actions
					Select Case wParam
						Case TBL_cls_AddRow
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_ADDROW, wParam, lParam )
						Case TBL_cls_SaveRow
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_SAVECHANGES, wParam, lParam )
						Case TBL_cls_ClearRow
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_CLEARSELECTIONS, wParam, lParam )
						Case TBL_cls_DeleteRow
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_DELETEROWS, wParam, lParam )
						Case TBL_cls_UnDeleteRow
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_UNDELETEROWS, wParam, lParam )
						Case TBL_cls_Query
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_QUERY, wParam, lParam )
						Case TBL_cls_OrderTable
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_ORDERTABLE, wParam, lParam )
						Case TBL_cls_RePopTable
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_REPOPULATE, wParam, lParam )
						Case TBL_cls_TableReport
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_PRINTTABLEREPORT, wParam, lParam )
						Case TBL_cls_MoveUpOne
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_MOVEUPONE, wParam, lParam )
						Case TBL_cls_MoveDownOne
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_MOVEDOWNONE, wParam, lParam )
						Case TBL_cls_MakeCSVFile
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_SAVECSVFILE, wParam, lParam )
						Case TBL_cls_ZoomTable
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_ZOOMTABLE, wParam, 0 )
						Case TBL_cls_CountSelected
							Return SalSendMsg( hWndChildTable, PAM_clsTBL_COUNTSELECTEDROWS, wParam, 0 )
			!
			! Function: TableAnyRows
				                        Description: Determines if any table rows are on and or off and a count of how many.
				                        Returns 
					                        Boolean: 
				                        Parameters 
					                        Window Handle: hWndTable
					                        Number: nRowFlagsOn
					                        Number: nRowFlagsOff
					                        Receive Number: nCount
				                        Static Variables 
				                        Local variables 
					                        Number: nRow
					                        Boolean: bFoundRow
				                        Actions 
					                        Call OurWaitCursor( TRUE )
					                        Set bFoundRow = FALSE
					                        Set nCount = 0
					                        Set nRow = TBL_MinRow
					                        While SalTblFindNextRow( hWndTable, nRow, nRowFlagsOn, nRowFlagsOff )
						                        Set nCount = nCount + 1
						                        Set bFoundRow = TRUE
					                        Call OurWaitCursor( FALSE )
					                        Return bFoundRow
			! Function: TableLoop
				                        Description: This function performs a loop thourgh table rows and for each row
						a message is sent to the table for some action per row.  The lParam
						of the message has the row position. nPAM_ROWACTION is a 
						parameter which should have a message passed.  nFlagsOn and 
						nFlagsOff are the Row Flag parameters as found the SalTblFindNexRow( ).
						The sHeading is a heading which will appear on the meter dialog if more
						than nTBL_cls_NumRowsToMeter constant ( set to 10 ) rows.  nDirection is either 
						TBL_cls_LowToHi or TBL_cls_HiToLow and represent the order in which the table will be 
						looped.  A TRUE must be returned to the nPAM_ROWACTION message,
						if not the loop will terminate.
						NOTE: If in the case that under nPAM_ROWACTION a row is deleted
						with TBL_Adjust then the row count needs to be decremented or 
						incremented so that normal loop continuation occurs.  To achieve this
						the constant TBL_cls_RowDeleted must be returned to the nPAM_ROWACTION
						message and this routine will adjust the row position variable 
						accordingly.
						NEW FEATURE AS OF 2/3/95: Use 
						TBL_cls_LowToHiWithPositioning OR TBL_cls_HiToLowWithPositioning to have the
						current processing row set the focus row and change the text color
						to RED as its processing rows!
				                        Returns 
					                        Boolean: 
				                        Parameters 
					                        Window Handle: hWndTable
					                        Window Handle: hWndRowAction
					                        Number: nPAM_ROWACTION
					                        Number: nMSG_wParam
					                        Number: nFlagsOn
					                        Number: nFlagsOff
					                        String: sHeading
					                        Number: nDirection
				                        Static Variables 
				                        Local variables 
					                        : Meter
					                        Number: nRow
					                        Number: nTotalRows
					                        Number: nActionReturn
					                        Number: nError
					                        Number: nLastRow
					                        Number: nOrgColor
				                        Actions 
					                        If SalSendMsg( hWndTable, PAM_clsTBL_SETTBLLOOPTOTAL, nMSG_wParam, nPAM_ROWACTION )
						                        Call PopNumber( nTotalRows, TRUE )
					                        Else 
						                        Call TableAnyRows( hWndTable, nFlagsOn, nFlagsOff, nTotalRows )
					!
					                        If nTotalRows > 0
						                        Call OurWaitCursor( TRUE )
						                        Set nError = FALSE
						                        If nTotalRows >= TBL_cls_NumRowsToMeter
							                        Call Meter.Setup( sHeading, nTotalRows )
						!
						! If nDirection = TBL_cls_LowToHiWithPositioning OR nDirection = TBL_cls_HiToLowWithPositioning
							                          Set nOrgColor = SalColorGet( hWndTable, COLOR_IndexWindowText )
						!
						                        If nDirection = TBL_cls_LowToHi OR nDirection = TBL_cls_LowToHiWithPositioning
							                        Set nRow = TBL_MinRow
							                        Set nLastRow = TBL_MinRow
							                        While SalTblFindNextRow( hWndTable, nRow, nFlagsOn, nFlagsOff )
								                        Call SalTblFetchRow( hWndTable, nRow )
								!
								                        If nDirection = TBL_cls_LowToHiWithPositioning
									                        If nLastRow = TBL_MinRow
										                        Set nOrgColor = SalColorGet( hWndTable, COLOR_IndexWindowText )
									                        Else 
										                        Call SalTblFetchRow( hWndTable, nLastRow )
										                        Call SalSendMsgToChildren( hWndTable, PAM_clsTBL_SETCOLUMNCOLOR, 0, nOrgColor )
										                        Call SalTblFetchRow( hWndTable, nRow )
									! Call SalTblSetFocusRow( hWndTable, nRow )
									                        Call SalSendMsgToChildren( hWndTable, PAM_clsTBL_SETCOLUMNCOLOR, 0, COLOR_Red )
								!
								                        Call Meter.Increment( 1 )
								                        Set nActionReturn = SalSendMsg( hWndRowAction, nPAM_ROWACTION, nMSG_wParam, nRow )
								                        If nActionReturn = FALSE
									                        Set nError = TRUE
									                        Break 
								                        Else If nActionReturn = TBL_cls_RowDeleted
									                        Set nRow = nRow - 1
								!
								                        Set nLastRow = nRow
							                        If nDirection = TBL_cls_LowToHiWithPositioning
								                        Call SalSendMsgToChildren( hWndTable, PAM_clsTBL_SETCOLUMNCOLOR, 0, nOrgColor )
						                        Else 
							                        Set nRow = TableLocateLastRow( hWndTable, nFlagsOn, nFlagsOff ) + 1
							                        Set nLastRow = nRow
							                        While SalTblFindPrevRow( hWndTable, nRow, nFlagsOn, nFlagsOff )
								                        Call SalTblFetchRow( hWndTable, nRow )
								                        If nDirection = TBL_cls_HiToLowWithPositioning
									                        If nLastRow = TBL_MinRow
										                        Set nOrgColor = SalColorGet( hWndTable, COLOR_IndexWindowText )
									                        Else 
										                        Call SalTblFetchRow( hWndTable, nLastRow )
										                        Call SalSendMsgToChildren( hWndTable, PAM_clsTBL_SETCOLUMNCOLOR, 0, nOrgColor )
										                        Call SalTblFetchRow( hWndTable, nRow )
									! Call SalTblSetFocusRow( hWndTable, nRow )
									                        Call SalSendMsgToChildren( hWndTable, PAM_clsTBL_SETCOLUMNCOLOR, 0, COLOR_Red )
								                        Call Meter.Increment( 1 )
								                        Set nActionReturn = SalSendMsg( hWndRowAction, nPAM_ROWACTION, nMSG_wParam, nRow )
								                        If nActionReturn = FALSE
									                        Set nError = TRUE
									                        Break 
								                        Else If nActionReturn = TBL_cls_RowDeleted
									                        Set nRow = nRow + 1
								!
								                        Set nLastRow = nRow
							                        If nDirection = TBL_cls_HiToLowWithPositioning
								                        Call SalSendMsgToChildren( hWndTable, PAM_clsTBL_SETCOLUMNCOLOR, 0, nOrgColor )
						                        Call Meter.End( )
						                        Call OurWaitCursor( FALSE )
						                        If nError
							                        Return FALSE
						                        Else 
							                        Return TRUE
					                        Else 
						                        Return FALSE
			Function: TableLoop
				Description: This function performs a loop thourgh table rows and for each row
						a message is sent to the table for some action per row.  The lParam
						of the message has the row position. nPAM_ROWACTION is a 
						parameter which should have a message passed.  nFlagsOn and 
						nFlagsOff are the Row Flag parameters as found the SalTblFindNexRow( ).
						The sHeading is a heading which will appear on the meter dialog if more
						than nTBL_cls_NumRowsToMeter constant ( set to 10 ) rows.  nDirection is either 
						TBL_cls_LowToHi or TBL_cls_HiToLow and represent the order in which the table will be 
						looped.  A TRUE must be returned to the nPAM_ROWACTION message,
						if not the loop will terminate.
						NOTE: If in the case that under nPAM_ROWACTION a row is deleted
						with TBL_Adjust then the row count needs to be decremented or 
						incremented so that normal loop continuation occurs.  To achieve this
						the constant TBL_cls_RowDeleted must be returned to the nPAM_ROWACTION
						message and this routine will adjust the row position variable 
						accordingly.
						NEW FEATURE AS OF 2/3/95: Use 
						TBL_cls_LowToHiWithPositioning OR TBL_cls_HiToLowWithPositioning to have the
						current processing row set the focus row and change the text color
						to RED as its processing rows!
				Returns
					Boolean:
				Parameters
					Window Handle: hWndTable
					Window Handle: hWndRowAction
					Number: nPAM_ROWACTION
					Number: nMSG_wParam
					Number: nFlagsOn
					Number: nFlagsOff
					String: sHeading
					Number: nDirection
				Static Variables
				Local variables
					String: sDirection
				Actions
					If nDirection = TBL_cls_LowToHi
						Set sDirection = 'LOW_TO_HIGH'
					Else If nDirection = TBL_cls_LowToHiWithPositioning
						Set sDirection = 'LOW_TO_HIGH_WITH_POSITIONING'
					Else If nDirection = TBL_cls_HiToLow
						Set sDirection = 'HIGH_TO_LOW'
					Else
						Set sDirection = 'HIGH_TO_LOW_WITH_POSITIONING'
					Return PrivateTableLoop( hWndTable, hWndRowAction, nPAM_ROWACTION, nMSG_wParam, nFlagsOn, nFlagsOff, 
							sHeading, sDirection, PAM_clsTBL_SETTBLLOOPTOTAL, PAM_clsTBL_SETCOLUMNCOLOR, TBL_cls_RowDeleted, 
							TBL_cls_NumRowsToMeter, PAM_clsTBL_METERSETUP, PAM_clsTBL_METERINCROW, PAM_clsTBL_METEREND )
			! Function: TableLocateLastRow
				                        Description: 
				                        Returns 
					                        Number: 
				                        Parameters 
					                        Window Handle: hWndTable
					                        Number: nFlagsOn
					                        Number: nFlagsOff
				                        Static Variables 
				                        Local variables 
					                        Number: nRow
					                        Number: nLastRow
				                        Actions 
					                        Set nLastRow = TBL_MinRow
					                        Set nRow = TBL_MinRow
					                        While SalTblFindNextRow( hWndTable, nRow, nFlagsOn, nFlagsOff )
						                        Set nLastRow = nRow
					                        Return nLastRow
			!
			Function: ErrorMessage
				Description: Displays error message box with the message string 
						passed to this function and from the table handle and 
						error row passed to it, it also selects the row by setting
						its row_selected flag to TRUE and brings this row into
						the users view.
				Returns
				Parameters
					String: sErrorMessage
					Window Handle: hWndTable
					Number: nRow
				Static Variables
				Local variables
				Actions
					Call SalTblFetchRow( hWndTable, nRow )
					Call SalTblSetRowFlags( hWndTable, nRow, ROW_Selected, TRUE )
					Call SalTblScroll( hWndTable, nRow, hWndItem, TBL_AutoScroll )
					Call SalMessageBox( sErrorMessage, 'Warning', MB_Ok | MB_IconExclamation )
			!
			! Function: CopyTblRowFromTo
				                        Description: 
				                        Returns 
					                        Boolean: 
				                        Parameters 
					                        Window Handle: hWndTable
					                        Number: nFromRow
					                        Number: nToRow
					                        Boolean: bCopyRowFlags
					                        Number: nFlagsToCopy
					                        Boolean: bCopyRowColumns
				                        Static Variables 
				                        Local variables 
				                        Actions 
					                        Call OurWaitCursor( TRUE )
					                        If bCopyRowFlags
						                        If IsFlagSet( nFlagsToCopy, ROW_Edited )
							                        Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_Edited )
						                        If IsFlagSet( nFlagsToCopy, ROW_Hidden )
							                        Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_Hidden )
						                        If IsFlagSet( nFlagsToCopy, ROW_HideMarks )
							                        Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_HideMarks )
						                        If IsFlagSet( nFlagsToCopy, ROW_MarkDeleted )
							                        Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_MarkDeleted )
						                        If IsFlagSet( nFlagsToCopy, ROW_New )
							                        Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_New )
						                        If IsFlagSet( nFlagsToCopy, ROW_Selected )
							                        Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_Selected )
						                        If IsFlagSet( nFlagsToCopy, ROW_UnusedFlag1 )
							                        Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_UnusedFlag1 )
						                        If IsFlagSet( nFlagsToCopy, ROW_UnusedFlag2 )
							                        Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_UnusedFlag2 )
					                        If bCopyRowColumns
						                        Call CopyRowColumnsFromTo( hWndTable, nFromRow, nToRow )
					                        Call OurWaitCursor( FALSE )
					                        Return TRUE
			! Function: CopyRowColumnsFromTo
				                        Description: 
				                        Returns 
					                        Boolean: 
				                        Parameters 
					                        Window Handle: hWndTable
					                        Number: nFromRow
					                        Number: nToRow
				                        Static Variables 
				                        Local variables 
					                        Window Handle: hWndChild
					                        String: sGotText
					                        Boolean: bRowFlag
				                        Actions 
					                        Set hWndChild = SalGetFirstChild( hWndTable, TYPE_TableColumn )
					                        While hWndChild != hWndNULL
						                        Call SalTblFetchRow( hWndTable, nFromRow )
						                        Call SalFmtFieldToStr( hWndChild, sGotText, TRUE )
						!
						                        Call SalTblFetchRow( hWndTable, nToRow )
						                        Call SalFmtStrToField( hWndChild, sGotText, TRUE )
						!
						                        Set hWndChild = SalGetNextChild( hWndChild, TYPE_TableColumn )
			! Function: CopyRowFlagsFromTo
				                        Description: 
				                        Returns 
				                        Parameters 
					                        Window Handle: hWndTable
					                        Number: nFromRow
					                        Number: nToRow
					                        Number: nROWFlag
				                        Static Variables 
				                        Local variables 
					                        Boolean: bRowFlag
				                        Actions 
					                        Call SalTblFetchRow( hWndTable, nFromRow )
					                        Set bRowFlag = SalTblQueryRowFlags( hWndTable, nFromRow, nROWFlag )
					                        Call SalTblFetchRow( hWndTable, nToRow )
					                        Call SalTblSetRowFlags( hWndTable, nToRow, nROWFlag, bRowFlag )
			! the following has been reinserted from ctable.apl to get migration going
			Function: TableAnyRows  
				Description: Determines if any table rows are on and or off and a count of how many.
				Returns
					Boolean:
				Parameters
					Window Handle: hWndTable  
					Number: nRowFlagsOn  
					Number: nRowFlagsOff  
					Receive Number: nCount  
				Static Variables
				Local variables
					Number: nRow  
					Boolean: bFoundRow  
				Actions
					Call OurWaitCursor( TRUE )
					Set bFoundRow = FALSE
					Set nCount = 0
					Set nRow = TBL_MinRow
					While SalTblFindNextRow( hWndTable, nRow, nRowFlagsOn, nRowFlagsOff )
						Set nCount = nCount + 1
						Set bFoundRow = TRUE
					Call OurWaitCursor( FALSE )
					Return bFoundRow
			Function: PrivateTableLoop  
				Description:
				Returns
					Boolean:
				Parameters
					Window Handle: hWndTable  
					Window Handle: hWndRowAction  
					Number: nPAM_ROWACTION  
					Number: nMSG_wParam  
					Number: nFlagsOn  
					Number: nFlagsOff  
					String: sHeading  
					! sDirection = 'LOW_TO_HIGH' OR 'HIGH_TO_LOW' OR 'LOW_TO_HIGH_WITH_POSITIONING' OR 'HIGH_TO_LOW_WITH_POSITIONING'
					String: sDirection  
					Number: nPAM_SETTBLLOOPTOTAL  
					Number: nPAM_SETCOLUMNCOLOR  
					Number: nTBL_cls_RowDeleted  
					Number: nTBL_cls_NumRowsToMeter  
					Number: nPAM_METERSETUP  
					Number: nPAM_METERINCROW  
					Number: nPAM_METEREND  
				Static Variables
				Local variables
					Number: nRow  
					Number: nTotalRows  
					Number: nActionReturn  
					Number: nError  
					Number: nLastRow  
					Number: nOrgColor  
				Actions
					If SalSendMsg( hWndTable, nPAM_SETTBLLOOPTOTAL, nMSG_wParam, nPAM_ROWACTION )
						Call PopNumber( nTotalRows, TRUE )
					Else
						Call TableAnyRows( hWndTable, nFlagsOn, nFlagsOff, nTotalRows )
					!
					If nTotalRows > 0
						Call OurWaitCursor( TRUE )
						Set nError = FALSE
						If nTotalRows >= nTBL_cls_NumRowsToMeter
							Call PushString( sHeading )
							If NOT SalSendMsg( hWndTable, nPAM_METERSETUP, 0, nTotalRows )
								Call PopString( sHeading, FALSE )
						!
						If sDirection = 'LOW_TO_HIGH' OR sDirection = 'LOW_TO_HIGH_WITH_POSITIONING'
							Set nRow = TBL_MinRow
							Set nLastRow = TBL_MinRow
							While SalTblFindNextRow( hWndTable, nRow, nFlagsOn, nFlagsOff )
								Call SalTblFetchRow( hWndTable, nRow )
								!
								If sDirection = 'LOW_TO_HIGH_WITH_POSITIONING'
									If nLastRow = TBL_MinRow
										! Set nOrgColor = SalColorGet( hWndTable, COLOR_IndexWindowText )
										Set nOrgColor = SalColorGet( SalTblGetColumnWindow( hWndTable, 1, COL_GetID ), COLOR_IndexCellText )
									Else
										Call SalTblFetchRow( hWndTable, nLastRow )
										If SalColorGet( SalTblGetColumnWindow( hWndTable, 1, COL_GetID ), COLOR_IndexCellText ) = COLOR_Red
											Call SalSendMsgToChildren( hWndTable, nPAM_SETCOLUMNCOLOR, 0, nOrgColor )
										Call SalTblFetchRow( hWndTable, nRow )
									Call SalSendMsgToChildren( hWndTable, nPAM_SETCOLUMNCOLOR, 0, COLOR_Red )
								!
								Call SalSendMsg( hWndTable, nPAM_METERINCROW, 0, 1 )
								Set nActionReturn = SalSendMsg( hWndRowAction, nPAM_ROWACTION, nMSG_wParam, nRow )
								If nActionReturn = FALSE
									Set nError = TRUE
									Break
								Else If nActionReturn = nTBL_cls_RowDeleted
									Set nRow = nRow - 1
								!
								Set nLastRow = nRow
							If sDirection = 'LOW_TO_HIGH_WITH_POSITIONING'
								If SalColorGet( SalTblGetColumnWindow( hWndTable, 1, COL_GetID ), COLOR_IndexCellText ) = COLOR_Red
									Call SalSendMsgToChildren( hWndTable, nPAM_SETCOLUMNCOLOR, 0, nOrgColor )
						Else
							Set nRow = TableLocateLastRow( hWndTable, nFlagsOn, nFlagsOff ) + 1
							Set nLastRow = nRow
							While SalTblFindPrevRow( hWndTable, nRow, nFlagsOn, nFlagsOff )
								Call SalTblFetchRow( hWndTable, nRow )
								If sDirection = 'HIGH_TO_LOW_WITH_POSITIONING'
									If nLastRow = TBL_MinRow
										! Set nOrgColor = SalColorGet( hWndTable, COLOR_IndexWindowText )
										Set nOrgColor = SalColorGet( SalTblGetColumnWindow( hWndTable, 1, COL_GetID ), COLOR_IndexCellText )
									Else
										Call SalTblFetchRow( hWndTable, nLastRow )
										If SalColorGet( SalTblGetColumnWindow( hWndTable, 1, COL_GetID ), COLOR_IndexCellText ) = COLOR_Red
											Call SalSendMsgToChildren( hWndTable, nPAM_SETCOLUMNCOLOR, 0, nOrgColor )
										Call SalTblFetchRow( hWndTable, nRow )
									Call SalSendMsgToChildren( hWndTable, nPAM_SETCOLUMNCOLOR, 0, COLOR_Red )
								Call SalSendMsg( hWndTable, nPAM_METERINCROW, 0, 1 )
								Set nActionReturn = SalSendMsg( hWndRowAction, nPAM_ROWACTION, nMSG_wParam, nRow )
								If nActionReturn = FALSE
									Set nError = TRUE
									Break
								Else If nActionReturn = nTBL_cls_RowDeleted
									Set nRow = nRow + 1
								!
								Set nLastRow = nRow
							If sDirection = 'HIGH_TO_LOW_WITH_POSITIONING'
								If SalColorGet( SalTblGetColumnWindow( hWndTable, 1, COL_GetID ), COLOR_IndexCellText ) = COLOR_Red
									Call SalSendMsgToChildren( hWndTable, nPAM_SETCOLUMNCOLOR, 0, nOrgColor )
						Call SalSendMsg( hWndTable, nPAM_METEREND, 0, 0 )
						Call OurWaitCursor( FALSE )
						If nError
							Return FALSE
						Else
							Return TRUE
					Else
						Return FALSE
			Function: TableLocateLastRow  
				Description:
				Returns
					Number:
				Parameters
					Window Handle: hWndTable  
					Number: nFlagsOn  
					Number: nFlagsOff  
				Static Variables
				Local variables
					Number: nRow  
					Number: nLastRow  
				Actions
					Set nLastRow = TBL_MinRow
					Set nRow = TBL_MinRow
					While SalTblFindNextRow( hWndTable, nRow, nFlagsOn, nFlagsOff )
						Set nLastRow = nRow
					Return nLastRow
			! !
			Function: CopyTblRowFromTo  
				Description:
				Returns
					Boolean:
				Parameters
					Window Handle: hWndTable  
					Number: nFromRow  
					Number: nToRow  
					Boolean: bCopyRowFlags  
					Number: nFlagsToCopy  
					Boolean: bCopyRowColumns  
				Static Variables
				Local variables
				Actions
					Call OurWaitCursor( TRUE )
					If bCopyRowFlags
						If IsFlagSet( nFlagsToCopy, ROW_Edited )
							Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_Edited )
						If IsFlagSet( nFlagsToCopy, ROW_Hidden )
							Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_Hidden )
						If IsFlagSet( nFlagsToCopy, ROW_HideMarks )
							Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_HideMarks )
						If IsFlagSet( nFlagsToCopy, ROW_MarkDeleted )
							Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_MarkDeleted )
						If IsFlagSet( nFlagsToCopy, ROW_New )
							Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_New )
						If IsFlagSet( nFlagsToCopy, ROW_Selected )
							Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_Selected )
						If IsFlagSet( nFlagsToCopy, ROW_UnusedFlag1 )
							Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_UnusedFlag1 )
						If IsFlagSet( nFlagsToCopy, ROW_UnusedFlag2 )
							Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_UnusedFlag2 )
					If bCopyRowColumns
						Call CopyRowColumnsFromTo( hWndTable, nFromRow, nToRow )
					Call OurWaitCursor( FALSE )
					Return TRUE
			Function: CopyRowColumnsFromTo  
				Description:
				Returns
					Boolean:
				Parameters
					Window Handle: hWndTable  
					Number: nFromRow  
					Number: nToRow  
				Static Variables
				Local variables
					Window Handle: hWndChild  
					String: sGotText  
					Boolean: bRowFlag  
				Actions
					Set hWndChild = SalGetFirstChild( hWndTable, TYPE_TableColumn )
					While hWndChild != hWndNULL
						Call SalTblFetchRow( hWndTable, nFromRow )
						Call SalFmtFieldToStr( hWndChild, sGotText, TRUE )
						!
						Call SalTblFetchRow( hWndTable, nToRow )
						Call SalFmtStrToField( hWndChild, sGotText, TRUE )
						!
						Set hWndChild = SalGetNextChild( hWndChild, TYPE_TableColumn )
			Function: CopyRowFlagsFromTo  
				Description:
				Returns
				Parameters
					Window Handle: hWndTable  
					Number: nFromRow  
					Number: nToRow  
					Number: nROWFlag  
				Static Variables
				Local variables
					Boolean: bRowFlag  
				Actions
					Call SalTblFetchRow( hWndTable, nFromRow )
					Set bRowFlag = SalTblQueryRowFlags( hWndTable, nFromRow, nROWFlag )
					Call SalTblFetchRow( hWndTable, nToRow )
					Call SalTblSetRowFlags( hWndTable, nToRow, nROWFlag, bRowFlag )
			!
			Function: TableAnyColumns
				Description:
				Returns
					Boolean:
				Parameters
					Window Handle: hWndTable
					Number: nColFlags
				Static Variables
				Local variables
					Window Handle: hWndCol
					Boolean: bColFlags
				Actions
					Set bColFlags = FALSE
					Set hWndCol = SalGetFirstChild( hWndTable, TYPE_TableColumn )
					While hWndCol != hWndNULL AND NOT bColFlags
						If SalTblQueryColumnFlags( hWndCol, nColFlags )
							Set bColFlags = TRUE
						Set hWndCol = SalGetNextChild( hWndCol, TYPE_TableColumn )
					Return bColFlags
			Function: TableAnyColumnsIDs
				Description:
				Returns
					Boolean:
				Parameters
					Window Handle: hWndTable
					Number: nColFlags
					! naColumnIDs is a NUMBER_Null terminated array
					Number: naColumnIDs[*]
				Static Variables
				Local variables
					Window Handle: hWndCol
					Boolean: bColFlags
					Number: nPos
				Actions
					Set nPos = 0
					Set naColumnIDs[ nPos ] = NUMBER_Null
					Set bColFlags = FALSE
					Set hWndCol = SalGetFirstChild( hWndTable, TYPE_TableColumn )
					While hWndCol != hWndNULL
						If SalTblQueryColumnFlags( hWndCol, nColFlags )
							Set bColFlags = TRUE
							Set naColumnIDs[ nPos ] = SalTblQueryColumnID( hWndCol )
							Set nPos = nPos + 1
							Set naColumnIDs[ nPos ] = NUMBER_Null
						Set hWndCol = SalGetNextChild( hWndCol, TYPE_TableColumn )
					Return bColFlags
			Function: SelectedColumnTableSort
				Description:
				Returns
					Boolean:
				Parameters
					Window Handle: hWndTable
					! nDirection = TBL_SortIncreasing or TBL_SortDecreasing
					Number: nDirection
				Static Variables
				Local variables
					Number: naSelectedColumnIDs[*]
					Boolean: bOk
				Actions
					Set bOk = TRUE
					If TableAnyColumnsIDs( hWndTable, COL_Selected, naSelectedColumnIDs )
						If naSelectedColumnIDs[ 1 ] = NUMBER_Null
							If NOT SalTblSortRows( hWndTable, naSelectedColumnIDs[ 0 ], nDirection )
								Set bOk = FALSE
						Else
							Call SalMessageBox( 'Please select one column at a time!', 'Warning', MB_Ok )
							Set bOk = FALSE
					Else
						Call SalMessageBox( 'Please select a column first!', 'Warning', MB_Ok )
						Set bOk = FALSE
					Return bOk
			!

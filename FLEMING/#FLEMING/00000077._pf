			Column: colPk3
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title:
				Visible? Yes
				Editable? Yes
				Maximum Data Length: Default
				Data Type: String
				Justify: Left
				Width:  Default
				Width Editable? Yes
				Format: Unformatted
				Country: Default
				Input Mask: Unformatted
				Cell Options
					Cell Type? Standard
					Multiline Cell? No
					Cell DropDownList
						Sorted? Yes
						Vertical Scroll? Yes
						Auto Drop Down? No
						Allow Text Editing? Yes
					Cell CheckBox
						Check Value:
						Uncheck Value:
						Ignore Case? Yes
				List Values
				Message Actions
		Functions
		Window Parameters
			Window Handle: hWndTable
			Window Handle: hWndPkCol1
			Window Handle: hWndPkCol2
			Window Handle: hWndPkCol3
		Window Variables
			Boolean: bFound
			Boolean: bInitialise
			Number: nRow
			Number: nNewRow
			String: sCompCol1
			String: sCompCol2
			String: sCompCol3
		Message Actions
			On SAM_Create
				Call SalHideWindow( hWndForm )
			On PAM_clsTBL_INITIALISE
				Call OurWaitCursor( TRUE )
				Call SalTblReset( hWndForm )
				Set nRow = TBL_MinRow
				While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
					Call SalTblFetchRow( hWndTable, nRow )
					Set nNewRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
					Call SalTblSetContext( hWndForm, nNewRow )
					Call SalFmtFieldToStr( hWndPkCol1, colPk1, FALSE )
					Call SalFmtFieldToStr( hWndPkCol2, colPk2, FALSE )
					Call SalFmtFieldToStr( hWndPkCol3, colPk3, FALSE )
				Call OurWaitCursor( FALSE )
			On PAM_clsTBL_LOOKUP
				Call OurWaitCursor( TRUE )
				Set bFound = FALSE
				Set nRow = TBL_MinRow
				While SalTblFindNextRow( hWndForm, nRow, ROW_New, 0 ) AND NOT bFound
					Call SalTblFetchRow( hWndForm, nRow )
					Call SalFmtFieldToStr( hWndPkCol1, sCompCol1, FALSE )
					Call SalFmtFieldToStr( hWndPkCol2, sCompCol2, FALSE )
					Call SalFmtFieldToStr( hWndPkCol3, sCompCol3, FALSE )
					If sCompCol1 = colPk1 AND sCompCol2 = colPk2 AND sCompCol3 = colPk3
						Call SalTblSetRowFlags( hWndForm, nRow, ROW_New, FALSE )
						Set bFound = TRUE
				Call OurWaitCursor( FALSE )
				Return bFound
	!

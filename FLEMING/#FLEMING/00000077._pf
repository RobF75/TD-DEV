						List Values
						Message Actions
							On SAM_Validate
								If MyValue = 'Y'
									Call SalTblSetRowFlags( hWndForm, lParam, nSelectedRowFlag, TRUE )
								Else
									Call SalTblSetRowFlags( hWndForm, lParam, nSelectedRowFlag, FALSE )
								Return VALIDATE_Ok
							On PAM_clsTBL_ROWACTION
								If wParam
									Set MyValue = 'Y'
									Call SalTblSetRowFlags( hWndForm, lParam, nSelectedRowFlag, TRUE )
								Else
									Set MyValue = 'N'
									Call SalTblSetRowFlags( hWndForm, lParam, nSelectedRowFlag, FALSE )
								Call SalSetFieldEdit( hWndItem, TRUE )
								Return TRUE
				Class Variables
				Instance Variables
					Number: nSelectedRowFlag
					Boolean: bHideMarks
				Functions
					Function: SetSelectedForTable
						Description:
						Returns
							Boolean:
						Parameters
							Number: nFlagsOn
							Number: nFlagsOff
							Boolean: bSelected
						Static Variables
						Local variables
						Actions
							Return TableLoop( hWndForm, colSelected, PAM_clsTBL_ROWACTION, bSelected, nFlagsOn, nFlagsOff, 'Setting Selected', TBL_cls_LowToHi )
					Function: ProcessSelected
						Description:
						Returns
							Boolean:
						Parameters
							! if hWndProcess is NULL then child table will receive processing messages
							Window Handle: hWndProcess
							! if nPAM_ProcessMessage is 0 or NULL then 
									  nPAM_ProcessMessage = PAM_clsTBL_PROCESSSELCOLACTION
							Number: nPAM_ProcessMessage
							Boolean: bSelected
						Static Variables
						Local variables
						Actions
							If nPAM_ProcessMessage = 0 OR nPAM_ProcessMessage = NUMBER_Null
								Set nPAM_ProcessMessage = PAM_clsTBL_PROCESSSELCOLACTION
							If hWndProcess = hWndNULL
								Set hWndProcess = hWndForm
							Return TableLoop( hWndForm, hWndProcess, nPAM_ProcessMessage, bSelected, nSelectedRowFlag, 0, 'Processing Selected', TBL_cls_LowToHi )
					Function: ToggleRowSelectedColumn
						Description:
						Returns
							Boolean:
						Parameters
							Number: nRow
							Boolean: bSelected
						Static Variables
						Local variables
						Actions
							Call SalTblFetchRow( hWndForm, nRow )
							Return SalSendMsg( colSelected, PAM_clsTBL_ROWACTION, bSelected, nRow )
				Message Actions
					On SAM_Create
						Set nSelectedRowFlag = ROW_UnusedFlag1
						Set bHideMarks = TRUE
						Return SalSendClassMessage( SAM_Create, wParam, lParam )
					On SAM_FetchRowDone
						Call SalTblSetRowFlags( hWndForm, lParam, ROW_HideMarks, bHideMarks )
						Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )

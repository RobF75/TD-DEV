		Window Parameters
			String: sHeading
			Number: nReportPrintView
		Window Variables
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Call SalSetWindowText( hWndForm, sHeading )
				If nReportPrintView = TBL_cls_ReportPrint
					Set rbPrint = TRUE
				Else
					Set rbView = TRUE
			On PAM_clsPB_OKACTION
				If rbPrint
					Call SalSendMsg( pbExit, SAM_Click, TBL_cls_ReportPrint, 0 )
				Else
					Call SalSendMsg( pbExit, SAM_Click, TBL_cls_ReportView, 0 )
			On SAM_CreateComplete
				Call OurWaitCursorOverride( FALSE, TRUE )
				Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )

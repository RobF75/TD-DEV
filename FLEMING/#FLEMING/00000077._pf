					                        Function: ExtractSELECTPart
						                        Description: 
						                        Returns 
						                        Parameters 
							                        String: sSqlStatement
							                        Receive String: sSELECTPart
						                        Static Variables 
						                        Local variables 
						                        Actions 
							                        Set sSELECTPart = SalStrLeftX( sSqlStatement, StringScan( sSqlStatement, 'FROM', TRUE ) )
					                        Function: ExtractFROMPart
						                        Description: 
						                        Returns 
						                        Parameters 
							                        String: sSqlStatement
							                        Receive String: sFROMPart
						                        Static Variables 
						                        Local variables 
							                        Number: nFromStart
							                        Number: nWhereStart
							                        Number: nOrderStart
						                        Actions 
							                        Set nFromStart = StringScan( sSqlStatement, 'FROM', TRUE )
							                        Set nWhereStart = StringScan( sSqlStatement, 'WHERE', TRUE )
							                        If nWhereStart = -1
								                        Set nOrderStart = StringScan( sSqlStatement, 'ORDER BY', TRUE )
								                        If nOrderStart = -1
									                        Set nOrderStart = StringScan( sSqlStatement, 'GROUP BY', TRUE )
									                        If nOrderStart = -1
										                        Set sFROMPart = SalStrRightX( sSqlStatement, SalStrLength( sSqlStatement ) - nFromStart )
									                        Else 
										                        Set sFROMPart = SalStrMidX( sSqlStatement, nFromStart, nOrderStart - nFromStart )
								                        Else 
									                        Set sFROMPart = SalStrMidX( sSqlStatement, nFromStart, nOrderStart - nFromStart )
							                        Else 
								                        Set sFROMPart = SalStrMidX( sSqlStatement, nFromStart, nWhereStart - nFromStart )
					                        Function: ExtractWHEREPart
						                        Description: 
						                        Returns 
						                        Parameters 
							                        String: sSqlStatement
							                        Receive String: sWHEREPart
						                        Static Variables 
						                        Local variables 
							                        Number: nWhereStart
							                        Number: nOrderStart
						                        Actions 
							                        Set nWhereStart = StringScan( sSqlStatement, 'WHERE', TRUE )
							                        If nWhereStart = -1
								                        Set sWHEREPart = ''
							                        Else 
								                        Set nOrderStart = StringScan( sSqlStatement, 'ORDER BY', TRUE )
								                        If nOrderStart = -1
									                        Set nOrderStart = StringScan( sSqlStatement, 'GROUP BY', TRUE )
									                        If nOrderStart = -1
										                        Set sWHEREPart = SalStrRightX( sSqlStatement, SalStrLength( sSqlStatement ) - nWhereStart )
									                        Else 
										                        Set sWHEREPart = SalStrMidX( sSqlStatement, nWhereStart, nOrderStart - nWhereStart )
								                        Else 
									                        Set sWHEREPart = SalStrMidX( sSqlStatement, nWhereStart, nOrderStart - nWhereStart )
					                        Function: ExtractORDERGROUPPart
						                        Description: 
						                        Returns 
						                        Parameters 
							                        String: sSqlStatement
							                        Receive String: sORDERPart
						                        Static Variables 
						                        Local variables 
							                        Number: nOrderStart
						                        Actions 
							                        Set nOrderStart = StringScan( sSqlStatement, 'ORDER BY', TRUE )
							                        If nOrderStart = -1
								                        Set nOrderStart = StringScan( sSqlStatement, 'GROUP BY', TRUE )
								                        If nOrderStart = -1
									                        Set sORDERPart = ''
								                        Else 
									                        Set sORDERPart = SalStrRightX( sSqlStatement, SalStrLength( sSqlStatement ) - nOrderStart )
							                        Else 
								                        Set sORDERPart = SalStrRightX( sSqlStatement, SalStrLength( sSqlStatement ) - nOrderStart )
					                        Function: MatchUpNFillBinds
						                        Description: 
						                        Returns 
						                        Parameters 
							                        String: sWHEREStatement
							                        String: sBINDFields
							                        Receive String: sFilledWhere
						                        Static Variables 
						                        Local variables 
							                        String: saTokens[*]
							                        Number: nNumTokens
							                        Number: nTokenPos
							                        String: sBind
						                        Actions 
							                        Set nNumTokens = SalStrTokenize( sBINDFields, '', ',', saTokens )
							                        Set sFilledWhere = sWHEREStatement
							                        If nNumTokens > 0
								                        Set nTokenPos = 0
								                        While nTokenPos < nNumTokens
									                        Set sBind = ':' || SalNumberToStrX( nTokenPos + 1, 0 )
									                        Call StringReplace( sFilledWhere, sBind, saTokens[ nTokenPos ] )
									                        Set nTokenPos = nTokenPos + 1
					!
					                        Function: ForgetChanges
						                        Description: Prompts the user that they forgot to save their changes,
								and asks if they want the CHANCE to save them.
								If they click YES (they want to save their changes) this 
								functions returns FALSE because we do not want to 
								forget the changes.  Else it returns TRUE indicating
								stuff the changes.
						                        Returns 
							                        Boolean: 
						                        Parameters 
						                        Static Variables 
						                        Local variables 
						                        Actions 
							                        If IDYES = SalMessageBox( 'Your current changes have not been saved.
									Would you like the chance to save them to the database?', 'Warning',
									MB_YesNo )
								                        Call SalMessageBox( 'Please SAVE your changes!', 'NOTE', MB_Ok )
								                        Return FALSE
							                        Else 
								                        Return TRUE
					                        Function: TableAddRow
						                        Description: Inserts a row new at the current context row and sets the focus
								to the column passed in.
						                        Returns 
							                        Number: 
						                        Parameters 
							                        Window Handle: hWndTable
							                        Window Handle: hWndFocusCol
							                        Number: nRow
						                        Static Variables 
						                        Local variables 
						                        Actions 
							                        Call OurWaitCursor( TRUE )
							                        Set nRow = SalTblInsertRow( hWndTable, nRow )
							                        Call SalTblSetContext( hWndTable, nRow )
							                        Call SalTblSetFocusRow( hWndTable, nRow )
							                        Call SalSendMsg( hWndTable, PAM_clsTBL_ROWNEWINIT, 0, nRow )
							                        Call SalSendMsgToChildren( hWndTable, PAM_clsTBL_ROWNEWINIT, 0, nRow )
							                        If NOT hWndFocusCol = hWndNULL
								                        Call SalTblSetFocusCell( hWndTable, nRow, hWndFocusCol, -1, -1 )
							                        Call OurWaitCursor( FALSE )
							                        Return nRow
					! Function: TableAddRowNew
						                        Description: Inserts a row new at the current context row and sets the focus
								to the column passed in.
						                        Returns 
							                        Number: 
						                        Parameters 
							                        Window Handle: hWndTable
							                        Window Handle: hWndFocusCol
						                        Static Variables 
						                        Local variables 
							                        Number: nRow
							                        Window Handle: hWndCol
						                        Actions 
							                        Call OurWaitCursor( TRUE )
							! If NOT hWndCol = hWndNULL
								                        Call SalTblQueryFocus( hWndTable, nRow, hWndCol )
							                        Call SalTblQueryFocus( hWndTable, nRow, hWndCol )
							                        Set nRow = SalTblInsertRow( hWndTable, nRow )
							                        Call SalTblSetContext( hWndTable, nRow )
							                        Call SalTblSetFocusRow( hWndTable, nRow )
							                        Call SalSendMsg( hWndTable, PAM_clsTBL_ROWNEWINIT, 0, nRow )
							                        Call SalSendMsgToChildren( hWndTable, PAM_clsTBL_ROWNEWINIT, 0, nRow )
							                        If NOT hWndCol = hWndNULL
								                        Call SalTblSetFocusCell( hWndTable, nRow, hWndFocusCol, -1, -1 )
							                        Call OurWaitCursor( FALSE )
							                        Return nRow
					! Function: TableAddRowNewBellow
						                        Description: Inserts a row new at the current context row and sets the focus
								to the column passed in.
						                        Returns 
							                        Number: 
						                        Parameters 
							                        Window Handle: hWndTable
							                        Window Handle: hWndFocusCol
						                        Static Variables 
						                        Local variables 
							                        Number: nRow
							                        Window Handle: hWndCol
						                        Actions 
							                        Call OurWaitCursor( TRUE )
							! If NOT hWndCol = hWndNULL
								                        Call SalTblQueryFocus( hWndTable, nRow, hWndCol )
							                        Call SalTblQueryFocus( hWndTable, nRow, hWndCol )
							                        Set nRow = SalTblInsertRow( hWndTable, nRow + 1 )
							                        Call SalTblSetContext( hWndTable, nRow )
							                        Call SalTblSetFocusRow( hWndTable, nRow )
							                        Call SalSendMsg( hWndTable, PAM_clsTBL_ROWNEWINIT, 0, nRow )
							                        Call SalSendMsgToChildren( hWndTable, PAM_clsTBL_ROWNEWINIT, 0, nRow )
							                        If NOT hWndCol = hWndNULL
								                        Call SalTblSetFocusCell( hWndTable, nRow, hWndFocusCol, -1, -1 )
							                        Call OurWaitCursor( FALSE )
							                        Return nRow
					                        Function: TableAddRowNew
						                        Description: 
						                        Returns 
							                        Number: 
						                        Parameters 
							                        Window Handle: hWndTable
							                        Window Handle: hWndFocusCol
						                        Static Variables 
						                        Local variables 
							                        Number: nRow
							                        Window Handle: hWndCol
						                        Actions 
							                        Call SalTblQueryFocus( hWndTable, nRow, hWndCol )
							                        Return TableAddRow( hWndTable, hWndCol, nRow )
					                        Function: TableAddRowNewBellow
						                        Description: 
						                        Returns 
							                        Number: 
						                        Parameters 
							                        Window Handle: hWndTable
							                        Window Handle: hWndFocusCol
						                        Static Variables 
						                        Local variables 
							                        Number: nRow
							                        Window Handle: hWndCol
						                        Actions 
							                        Call SalTblQueryFocus( hWndTable, nRow, hWndCol )
							                        Return TableAddRow( hWndTable, hWndCol, nRow + 1 )
					                        Function: TableEmpty
						                        Description: Goes through the 0 table rows children and if one of those
								childrens value is not null then it returns FALSE for TableEmpty
								otherwise TRUE for TableEmpty
						                        Returns 
							                        Boolean: 
						                        Parameters 
							                        Window Handle: hWndTable
							                        Number: nRow
						                        Static Variables 
						                        Local variables 
							                        Window Handle: hWndChild
							                        Boolean: bFound
						                        Actions 
							                        Call OurWaitCursor( TRUE )
							                        Call SalTblSetContext( hWndTable, nRow )
							                        Set bFound = FALSE
							                        Set hWndChild = SalGetFirstChild( hWndTable, TYPE_TableColumn )
							                        While (NOT hWndChild = hWndNULL) AND (NOT bFound)
								                        If NOT SalIsNull( hWndChild )
									                        Set bFound = TRUE
								                        Set hWndChild = SalGetNextChild( hWndChild, TYPE_TableColumn )
							                        Call OurWaitCursor( FALSE )
							                        If bFound
								                        Return FALSE
							                        Else 
								                        Return TRUE
					!
					                        Function: TableReportPrint
						                        Description: Starts the report processing by using the report columns message
								passed to this function to extract the bind variables for report
								windows.  It uses the children of the window passed to it.  If need be
								to get another child from somewhere else, include a dummy child that
								does not just call BuildSql(..) but sends a message to the correct
								data field.  Remember to pass wParam in this SalSendMessage.
						                        Returns 
						                        Parameters 
							                        Window Handle: hWndTable
							                        String: sReportFileName
							                        String: sRepBind
							                        String: sRepInto
							                        Number: nReportPrintOrView
						                        Static Variables 
						                        Local variables 
							                        Number: nError
							                        Window Handle: hWndReport
						                        Actions 
							                        Call OurWaitCursor( TRUE )
							                        Set nError = 1
							                        If nReportPrintOrView = TBL_cls_ReportView
								                        Set hWndReport = SalReportView( hWndTable, hWndNULL, sReportFileName, sRepBind, sRepInto, nError )
							                        Else 
								                        Set hWndReport = SalReportPrint( hWndTable, sReportFileName, sRepBind, sRepInto, 1, RPT_PrintAll | RPT_PrintDraft, 0, 0, nError )
							                        Call OurWaitCursor( FALSE )
					                        Function: TableReportFetchInit
						                        Description: Initialises the table row number variable given to this function to
								start at the beginning of the table.  And also determines if the user
								is after a Selected rows report or with every table row.  The two
								parameters nTableRow and bSelectedRowsOnly need to be local
								variables in the table that is referenced by hWndTable parameter.
						                        Returns 
							                        Boolean: 
						                        Parameters 
							                        Window Handle: hWndTable
							                        Receive Number: nTableRow
							                        Receive Boolean: bSelectedRowsOnly
							                        String: sHeading
						                        Static Variables 
						                        Local variables 
						                        Actions 
							                        Set nTableRow = TBL_MinRow
							                        If SalTblAnyRows( hWndTable, ROW_Selected, 0 )
								                        If IDYES = SalMessageBox( 'Print SELECT rows ONLY.', sHeading, MB_YesNo )
									                        Set bSelectedRowsOnly = TRUE
								                        Else 
									                        Set bSelectedRowsOnly = FALSE
							                        Else 
								                        Set bSelectedRowsOnly = FALSE
							                        Return TRUE
					                        Function: TableReportFetchNext
						                        Description: This functions fetches the next row from the report table supplied
								and returns TRUE if we had another row else FALSE and therefore
								the report is finished.  This function checks the parameter 
								nSelectedRowsOnly if it should find the next ROW_Selected or
								just the next sequential row.
						                        Returns 
							                        Boolean: 
						                        Parameters 
							                        Window Handle: hWndTable
							                        Receive Number: nTableRow
							                        Boolean: bSelectedRowsOnly
						                        Static Variables 
						                        Local variables 
						                        Actions 
							                        If bSelectedRowsOnly
								                        If SalTblFindNextRow( hWndTable, nTableRow, ROW_Selected, 0 )
									                        Call SalTblFetchRow( hWndTable, nTableRow )
									                        Call SalSendMsg( hWndTable, PAM_clsTBL_TABLEREPORTROWACTION, 0, nTableRow )
									                        Return TRUE
								                        Else 
									                        Return FALSE
							                        Else 
								                        If SalTblFindNextRow( hWndTable, nTableRow, 0, 0 )
									                        Call SalTblFetchRow( hWndTable, nTableRow )
									                        Call SalSendMsg( hWndTable, PAM_clsTBL_TABLEREPORTROWACTION, 0, nTableRow )
									                        Return TRUE
								                        Else 
									                        Return FALSE
					!
					                        Function: TableCheckMessageOk
						                        Description: Send a check message to all children of a window and if one returns
								false then this function returns false otherwise true
						                        Returns 
							                        Boolean: 
						                        Parameters 
							                        Window Handle: hWndTable
							                        Number: nPamMessage
							                        Number: nRow
						                        Static Variables 
						                        Local variables 
							                        Window Handle: hWndChild
							                        Boolean: bError
						                        Actions 
							                        Call OurWaitCursor( TRUE )
							                        Set bError = FALSE
							                        Set hWndChild = SalGetFirstChild( hWndTable, TYPE_TableColumn )
							                        While (NOT hWndChild = hWndNULL) AND (NOT bError)
								                        If NOT SalSendMsg( hWndChild, nPamMessage, 0, nRow )
									                        Set bError = TRUE
								                        Set hWndChild = SalGetNextChild( hWndChild, TYPE_TableColumn )
							                        Call OurWaitCursor( FALSE )
							                        If bError
								                        Return FALSE
							                        Else 
								                        Return TRUE
					                        Function: TableForgetChanges
						                        Description: Checks if the table has any row_new, row_edited or row_markdeleted
								rows and if yes then as if the user wants to save the changes
						                        Returns 
							                        Boolean: 
						                        Parameters 
							                        Window Handle: hWndTable
							                        Receive Boolean: bEdit
						                        Static Variables 
						                        Local variables 
						                        Actions 
							                        If SalTblAnyRows( hWndTable, ROW_Edited|ROW_New|ROW_MarkDeleted, 0 )
								                        If NOT ForgetChanges(  )
									                        Return FALSE
								                        Else 
									                        Set bEdit = FALSE
							                        Return TRUE
					!
					! Function: GetOrderByColumns
						                          Description: 
						                          Returns 
						                          Parameters 
							                          Window Handle: hWndTable
							                          Receive String: saTitles[*]
							                          Receive Number: naPositions[*]
						                          Static Variables 
						                          Local variables 
							                          Window Handle: hWndChild
							                          Number: nColPosition
							                          Number: nPos
							                          String: sColumn
						                          Actions 
							                          Set nPos = 0
							                          Set saTitles[ nPos ] = ''
							                          Set naPositions[ nPos ] = NUMBER_Null
							                          Set nColPosition = 0
							                          Set hWndChild = SalGetFirstChild( hWndTable, TYPE_TableColumn )
							                          While hWndChild != hWndNULL
								                          If SalSendMsg( hWndChild, PAM_clsTBL_ORDERBYCOLUMN, 0, 0 )
									                          Set nColPosition = nColPosition + 1
									                          Set sColumn = ''
									                          Call SalTblGetColumnTitle( hWndChild, sColumn, 100 )
									                          Set saTitles[ nPos ] = sColumn
									                          Set naPositions[ nPos ] = nColPosition
									                          Set nPos = nPos + 1
									                          Set saTitles[ nPos ] = ''
									                          Set naPositions[ nPos ] = NUMBER_Null
								                          Set hWndChild = SalGetNextChild( hWndChild, TYPE_TableColumn )
					                        Function: GetOrderByColumns
						                        Description: 
						                        Returns 
						                        Parameters 
							                        Window Handle: hWndTable
							                        String: sIntoPopHandle
							                        Receive String: saTitles[*]
							                        Receive Number: naPositions[*]
						                        Static Variables 
						                        Local variables 
							                        Window Handle: hWndChild
							                        Number: nColCount
							                        Number: nPos
							                        Number: nColPosition
							                        String: sChildColumn
							                        Boolean: bFound
							                        String: sColumn
							                        String: sIntoCols[*]
						                        Actions 
							                        Set nColCount = SalStrTokenize( sIntoPopHandle, ':', ',', sIntoCols )
							                        Set nColPosition = 0
							                        While nColPosition < nColCount
								                        Call StringReplace( sIntoCols[ nColPosition ], ':', '' )
								                        Call StringReplace( sIntoCols[ nColPosition ], ',', '' )
								                        Call StringReplace( sIntoCols[ nColPosition ], ' ', '' )
								                        Call StringReplace( sIntoCols[ nColPosition ], '
										', '' )
								                        Set nColPosition = nColPosition + 1
							!
							                        Set nPos = 0
							                        Set saTitles[ nPos ] = ''
							                        Set naPositions[ nPos ] = NUMBER_Null
							                        Set hWndChild = SalGetFirstChild( hWndTable, TYPE_TableColumn )
							                        While hWndChild != hWndNULL
								                        If SalSendMsg( hWndChild, PAM_clsTBL_ORDERBYCOLUMN, 0, 0 )
									                        Call SalGetItemName( hWndChild, sChildColumn )
									                        Set nColPosition = 0
									                        Set bFound = FALSE
									                        While nColPosition < nColCount AND NOT bFound
										! If sIntoCols[ nColPosition ] = sChildColumn
											                          Set bFound = TRUE
										                        If StringScan( sIntoCols[ nColPosition ], sChildColumn, TRUE ) >= 0
											                        Set bFound = TRUE
										                        Set nColPosition = nColPosition + 1
									                        If bFound
										                        Set sColumn = ''
										                        Call SalTblGetColumnTitle( hWndChild, sColumn, 100 )
										                        Set saTitles[ nPos ] = sColumn
										                        Set naPositions[ nPos ] = nColPosition
										                        Set nPos = nPos + 1
										                        Set saTitles[ nPos ] = ''
										                        Set naPositions[ nPos ] = NUMBER_Null
								                        Set hWndChild = SalGetNextChild( hWndChild, TYPE_TableColumn )
					!
					                        Function: TableAnyColumns
						                        Description: 
						                        Returns 
							                        Boolean: 
						                        Parameters 
							                        Window Handle: hWndTable
							                        Number: nColFlags
						                        Static Variables 
						                        Local variables 
							                        Window Handle: hWndCol
							                        Boolean: bColFlags
						                        Actions 
							                        Set bColFlags = FALSE
							                        Set hWndCol = SalGetFirstChild( hWndTable, TYPE_TableColumn )
							                        While hWndCol != hWndNULL AND NOT bColFlags
								                        If SalTblQueryColumnFlags( hWndCol, nColFlags )
									                        Set bColFlags = TRUE
								                        Set hWndCol = SalGetNextChild( hWndCol, TYPE_TableColumn )
							                        Return bColFlags
					                        Function: MakeCSVColumnsLine
						                        Description: 
						                        Returns 
							                        String: 
						                        Parameters 
							                        Window Handle: hWndTable
							                        Boolean: bSelectedColumns
						                        Static Variables 
						                        Local variables 
							                        Window Handle: hWndCol
							                        String: sColText
							                        String: sCSVLine
							                        Boolean: bFirst
							                        Boolean: bColumnOk
						                        Actions 
							                        Set sCSVLine = ''
							                        Set bFirst = TRUE
							                        Set hWndCol = SalGetFirstChild( hWndTable, TYPE_TableColumn )
							                        While hWndCol != hWndNULL
								                        If bSelectedColumns
									                        If SalTblQueryColumnFlags( hWndCol, COL_Selected )
										                        Set bColumnOk = TRUE
									                        Else 
										                        Set bColumnOk = FALSE
								                        Else 
									                        Set bColumnOk = TRUE
								!
								                        If bColumnOk
									                        Call SalFmtFieldToStr( hWndCol, sColText, TRUE )
									!
									                        Select Case SalGetDataType( hWndCol )
										                        Case DT_LongString
											                        Set sColText = '"' || sColText || '"'
											                        Break 
										                        Case DT_String
											                        Set sColText = '"' || sColText || '"'
											                        Break 
									                        If bFirst
										                        Set sCSVLine = sColText
										                        Set bFirst = FALSE
									                        Else 
										                        Set sCSVLine = sCSVLine || ', ' || sColText
								                        Set hWndCol = SalGetNextChild( hWndCol, TYPE_TableColumn )
							                        Return sCSVLine
				                        Message Actions 
					                        On SAM_Create
						                        Call OurWaitCursor( TRUE )
						                        Set sSQLPopHandle = ''
						                        Set sNAMEPopHandle = ''
						                        Set sBINDPopHandle = ''
						                        Set sINTOPopHandle = ''
						!
						                        Set sSQLRefreshHandle = ''
						                        Set sNAMERefreshHandle = ''
						                        Set sBINDRefreshHandle = ''
						                        Set sINTORefreshHandle = ''
						!
						                        Set sSQLInsertHandle = ''
						                        Set sNAMEInsertHandle = ''
						                        Set sBINDInsertHandle = ''
						                        Set sINTOInsertHandle = ''
						!
						                        Set sSQLUpdateHandle = ''
						                        Set sNAMEUpdateHandle = ''
						                        Set sBINDUpdateHandle = ''
						                        Set sINTOUpdateHandle = ''
						!
						                        Set sSQLDeleteHandle = ''
						                        Set sNAMEDeleteHandle = ''
						                        Set sBINDDeleteHandle = ''
						                        Set sINTODeleteHandle = ''
						!
						                        Set bAddAllowed = FALSE
						                        Set bSaveAllowed = FALSE
						           Set __bDELETEAllowed = FALSE
						                        Set bUnDeleteAllowed = FALSE
						                        Set bRepopulateAllowed = TRUE
						                        Set bClearSelectAllowed = TRUE
						                        Set bQueryAllowed = FALSE
						                        Set bReportAllowed = FALSE
						                        Set bOrderAllowed = FALSE
						                        Set bSelectingColumnsAllowed = FALSE
						                        Set bMakeCSVFileAllowed = FALSE
						                        Set bZoomTableAllowed = FALSE
						!
						                        Set bEdit = FALSE
						                        Set bChanged = FALSE
						                        Set bGetSaveConfirmation = TRUE
						!
						                        Call SalGetWindowText( SalParentWindow( hWndForm ), sTableHeading, 60 )
						                        Set sReportFileName = ''
						                        Set nReportPrintOrView = TBL_cls_ReportPrint
						                        Set bGiveUserPrintViewChoice = TRUE
						!
						                        Set bSelectFirstRow = TRUE
						                        Set bAddRowBellow = FALSE
						                        Set bAddRowAtEnd = FALSE
						                        Set bKeepSelectRowsOnRePop = FALSE
						                        Set nTableFillType = TBL_FillAll
						                        Set hWndRowNewColumn = hWndNULL
						                        Set sQueryDialogName = ''
						!
						                        Set sLastBuildWhere = ''
						                        Set sLastOrderBy = ''
						!
						                        Set hWndKeepSelRowsCol1 = hWndNULL
						                        Set hWndKeepSelRowsCol2 = hWndNULL
						                        Set hWndKeepSelRowsCol3 = hWndNULL
						                        Set hWndTblKeepSelRows = hWndNULL
						!
						                        Set nMinRowNo = 0
						                        Set nMaxRowNo = TBL_MaxRow
						!
						                        Set nCurrentContextRow = 0
						!
						                        Set hWndParent = SalParentWindow( hWndForm )
						                        Set hWndThisTable = hWndForm
						!
						                        Call SalGetWindowLoc( hWndForm, nOrgTblLeft, nOrgTblTop )
						                        Call SalGetWindowSize( hWndForm, nOrgTblWidth, nOrgTblHeight )
						                        Set nZoomTblLeft = nOrgTblLeft
						                        Set nZoomTblTop = nOrgTblTop
						                        Set nZoomTblWidth = nOrgTblWidth
						                        Set nZoomTblHeight = nOrgTblHeight
						                        Set bTableZoom = FALSE
						!
						                        Call SalSendMsg( hWndForm, PAM_cls_SETINSTANCEVARS, 0, 0 )
						                        If sNAMEPopHandle != ''
							                        Set __nSqlPopHandleNo = SqlHandlesGetReferenceNo( GetFullItemName( hWndNULL, SalParentWindow( hWndForm ), hWndForm ) || 'TBLPOP' )
							                        Call haSqlHandles[ __nSqlPopHandleNo ].Setup( sSQLPopHandle, sNAMEPopHandle, sBINDPopHandle, sINTOPopHandle )
							                        Call SqlVarSetup( haSqlHandles[ __nSqlPopHandleNo ].hSqlHandle )
						!
						                        If sNAMERefreshHandle != ''
							                        Set __nSqlRefreshHandleNo = SqlHandlesGetReferenceNo( GetFullItemName( hWndNULL, SalParentWindow( hWndForm ), hWndForm ) || 'TBLREF' )
							! Call haSqlHandles[ __nSqlRefreshHandleNo ].SetFetchThrough( TRUE )
							                        Call haSqlHandles[ __nSqlRefreshHandleNo ].Setup( sSQLRefreshHandle, sNAMERefreshHandle, sBINDRefreshHandle, sINTORefreshHandle )
							                        Call SqlVarSetup( haSqlHandles[ __nSqlRefreshHandleNo ].hSqlHandle )
						!
						                        Set __nSqlQueryHandleNo = SqlHandlesGetReferenceNo( GetFullItemName( hWndNULL, SalParentWindow( hWndForm ), hWndForm ) || 'TBLQBE' )
						                        Call haSqlHandles[ __nSqlQueryHandleNo ].Connect( )
						!
						                        If sNAMEInsertHandle != ''
							                        Set __nSqlInsertHandleNo = SqlHandlesGetReferenceNo( GetFullItemName( hWndNULL, SalParentWindow( hWndForm ), hWndForm ) || 'TBLINS' )
							                        Call haSqlHandles[ __nSqlInsertHandleNo ].Setup( sSQLInsertHandle, sNAMEInsertHandle, sBINDInsertHandle, sINTOInsertHandle )
							                        Call SqlVarSetup( haSqlHandles[ __nSqlInsertHandleNo ].hSqlHandle )
						!
						                        If sNAMEUpdateHandle != ''
							                        Set __nSqlUpdateHandleNo = SqlHandlesGetReferenceNo( GetFullItemName( hWndNULL, SalParentWindow( hWndForm ), hWndForm ) || 'TBLUPDT' )
							                        Call haSqlHandles[ __nSqlUpdateHandleNo ].Setup( sSQLUpdateHandle, sNAMEUpdateHandle, sBINDUpdateHandle, sINTOUpdateHandle )
							                        Call SqlVarSetup( haSqlHandles[ __nSqlUpdateHandleNo ].hSqlHandle )
						!
						                        If sNAMEDeleteHandle != ''
							                        Set __nSqlDeleteHandleNo = SqlHandlesGetReferenceNo( GetFullItemName( hWndNULL, SalParentWindow( hWndForm ), hWndForm ) || 'TBLDEL' )
							                        Call haSqlHandles[ __nSqlDeleteHandleNo ].Setup( sSQLDeleteHandle, sNAMEDeleteHandle, sBINDDeleteHandle, sINTODeleteHandle )
							                        Call SqlVarSetup( haSqlHandles[ __nSqlDeleteHandleNo ].hSqlHandle )
						!
						                        Call SalTblSetTableFlags( hWndForm, TBL_Flag_SelectableCols, bSelectingColumnsAllowed )
						!
						                        Call OurWaitCursor( FALSE )
					                        On SAM_Destroy
						                        Call haSqlHandles[ __nSqlPopHandleNo ].Disconnect( )
						                        Call haSqlHandles[ __nSqlRefreshHandleNo ].Disconnect( )
						                        Call haSqlHandles[ __nSqlQueryHandleNo ].Disconnect( )
						                        Call haSqlHandles[ __nSqlInsertHandleNo ].Disconnect( )
						                        Call haSqlHandles[ __nSqlUpdateHandleNo ].Disconnect( )
						                        Call haSqlHandles[ __nSqlDeleteHandleNo ].Disconnect( )
					                        On WM_RBUTTONUP
						                        Set __nhWndForm = SalWindowHandleToNumber( hWndForm )
						                        Call SalSendMsg( SalParentWindow( hWndForm ), WM_RBUTTONUP, __nhWndForm, lParam )
					                        On SAM_FetchRowDone
						                        If NOT wParam = PAM_clsTBL_REFRESHROW
							                        Set nTableTotalRows = nTableTotalRows + 1
							                        If hWndTblKeepSelRows != hWndNULL
								                        If SalSendMsg( hWndTblKeepSelRows, PAM_clsTBL_LOOKUP, 0, 0 )
									                        Call SalTblSetRowFlags( hWndForm, lParam, ROW_Selected, TRUE )
									                        Call SalSendMsg( hWndForm, PAM_clsTBL_LOCATESELROW, 0, lParam )
					                        On PAM_clsTBL_USERACTIONS
						                        Return UserTableActions( hWndForm, wParam, lParam )
					! Dynamic column creation
					                        On PAM_clsCOL_GETFIELDS
						                        Set __nColPos = 1
						                        Set __nDispWidth = 1
						                        Set __nMaxChars = 1
						                        Set __sTitle = ''
					                        On PAM_clsTBL_ADDCOLUMN
						                        Set __hWndCalledFrom = SalNumberToWindowHandle( wParam )
						                        Call SalSendMsg( __hWndCalledFrom, PAM_clsCOL_SETFIELDS, 0, 0 )
						                        Call SalSendMsg( hWndForm, PAM_clsCOL_GETFIELDS, 0, 0 )
						                        Set __nColId = SalTblCreateColumn( hWndForm, __nColPos, __nDispWidth, __nMaxChars, __sTitle )
						                        Set __hWndCol = SalTblGetColumnWindow( hWndForm, __nColId, COL_GetID )
					                        On PAM_clsTBL_DYNAMICCOLVAL
						                        Set __sValue = SalFmtFormatNumber( lParam, '$#,##0.00;($#,##0.00)' )
						                        Call SalSetWindowText( __hWndCol, __sValue )
					                        On PAM_clsTBL_GETCOLUMNID
						                        Return SalTblQueryColumnID( __hWndCol )
					!
					! Table summing column message processing
					                        On WM_LBUTTONUP
						                        If bSelectingColumnsAllowed
							                        Call SalTblSetFlagsAnyRows( hWndForm, ROW_UnusedFlag1, FALSE, 0, 0 )
							                        Call SalTblSetFlagsAnyRows( hWndForm, ROW_UnusedFlag1, TRUE, ROW_Selected, 0 )
					                        On SAM_ColumnSelectClick
						                        Set __hWndSum = SalNumberToWindowHandle( wParam )
						                        Set __nSum = 0
						                        Set __nColId = SalTblQueryColumnID( __hWndSum )
						                        If SalGetDataType( __hWndSum ) = DT_Number
							                        If __nNewRow = 0
								                        Call SalTblDefineSplitWindow( hWndForm, 1, TRUE )
								                        Set __nNewRow = SalTblInsertRow( hWndForm, TBL_MinSplitRow )
								                        Call SalTblSetRowFlags( hWndForm, __nNewRow, ROW_HideMarks, TRUE )
								                        Call SalTblSetRowFlags( hWndForm, __nNewRow, ROW_New, FALSE )
							                        If NOT SalTblAnyRows( hWndForm, ROW_UnusedFlag1, 0 )
								                        Call SalTblSetFlagsAnyRows( hWndForm, ROW_UnusedFlag1, TRUE, 0, 0 )
								! Dont want to set the row unused flag on the minsplit row
								                        Call SalTblSetRowFlags( hWndForm, __nNewRow, ROW_UnusedFlag1, FALSE )
							                        Call TableLoop( hWndForm, hWndForm, PAM_clsTBL_SUMROW, 0, ROW_UnusedFlag1, 0, 'Summing Rows', TBL_cls_LowToHi )
							                        Call SalTblSetContext( hWndForm, __nNewRow )
							                        Call SalFmtGetPicture( __hWndSum, __sPicFormat )
							                        Set __sTempNum = SalFmtFormatNumber( __nSum, __sPicFormat )
							! Set __sTempNum = SalNumberToStrX( __nSum, 2 )
							                        Call SalTblSetColumnText( hWndForm, __nColId, __sTempNum )
							! Call SalSendMsg( __hWndSum, PAM_clsTBL_PASSVALUE, __nSum, 0 )
						                        Call SalTblSetFlagsAnyRows( hWndForm, ROW_Selected, TRUE, ROW_UnusedFlag1, 0 )
						                        Call SalTblSetFlagsAnyRows( hWndForm, ROW_UnusedFlag1, FALSE, 0, 0 )
						                        Call SalTblSetColumnFlags( __hWndSum, COL_Selected, FALSE )
					                        On PAM_clsTBL_SUMROW
						                        Call SalTblGetColumnText( hWndForm, __nColId, __sTempNum )
						                        Set __nSum = __nSum + SalStrToNumber( __sTempNum )
						                        Return TRUE
					!
					                        On PAM_clsTBL_SETTBLLOOPTOTAL
						                        If nTableFillType = TBL_FillAll
							                        If lParam = PAM_clsTBL_REFRESHROW OR 
									lParam = PAM_clsTBL_DATAVAL OR 
									lParam = PAM_clsTBL_WRITEINSERTSUPDATES
								                        Return FALSE
							                        Else If wParam = PICK_SelectManyToMany OR wParam = PICK_SelectOneToMany
								                        Call TableAnyRows( hWndForm, ROW_Selected, 0, nCount )
								                        Call PushNumber( nCount )
								                        Return TRUE
							                        Else 
								                        Call PushNumber( nTableTotalRows )
								                        Return TRUE
						                        Else 
							                        If lParam = PAM_clsTBL_LOCATESELROW
								                        Call PushNumber( nTableTotalRows )
								                        Return TRUE
							                        Else 
								                        Return FALSE
					!
					                        On PAM_clsTBL_POPULATE
						                        Call OurWaitCursor( TRUE )
						                        Set bOk = TRUE
						                        Set nTableTotalRows = 0
						                        Call SalSendMsg( hWndForm, PAM_clsTBL_RESET, 0, 0 )
						                        If haSqlHandles[ __nSqlPopHandleNo ].TablePopulate( hWndForm, nTableFillType )
							                        If TableEmpty( hWndForm, 0 )
								                        Call SalSendMsg( hWndForm, PAM_clsTBL_NOROWS, 0, 0 )
							                        Else 
								                        Call SalTblFetchRow( hWndForm, 0 )
								                        Call SalTblSetContext( hWndForm, 0 )
								                        Call SalTblSetFocusRow( hWndForm, 0 )
								                        If bSelectFirstRow
									                        Call SalTblSetRowFlags( hWndForm, 0, ROW_Selected, TRUE )
								                        Call SalSendMsg( hWndForm, PAM_clsTBL_POPULATED, 0, 0 )
								                        Call SalTblFetchRow( hWndForm, 0 )
								                        Call SalTblSetContext( hWndForm, 0 )
								                        Call SalTblSetFocusRow( hWndForm, 0 )
						                        Else 
							                        Set bOk = FALSE
						                        Call OurWaitCursor( FALSE )
						                        Return bOk
					                        On PAM_clsTBL_REPOPULATE
						! Use wParam = TBL_cls_RePopulateSelected if automatically want to repop only selected rows
						! Use wParam = TBL_cls_RePopByRowsRefreshOnly if want to refresh rows in table and preserve positioning
						                        If bRepopulateAllowed
							                        If wParam = TBL_cls_RePopulateOrderBy
								                        Set bRePopSelected = FALSE
							                        Else If SalTblAnyRows( hWndForm, ROW_Selected, 0 )
								                        If wParam = TBL_cls_RePopulateSelected OR wParam = TBL_cls_RePopByRowsRefreshOnly
									                        Set bRePopSelected = TRUE
								                        Else If sNAMERefreshHandle != ''
									                        Set nTmpRow = SalMessageBox( 'Do you want to only repopulate the selected rows?', 'NOTE', MB_YesNoCancel )
									                        If nTmpRow = IDYES
										                        Set bRePopSelected = TRUE
									                        Else If nTmpRow = IDNO
										                        Set bRePopSelected = FALSE
									                        Else 
										                        Return FALSE
								                        Else 
									                        Set bRePopSelected = FALSE
							                        Else If wParam = TBL_cls_RePopTable AND lParam = TBL_cls_ChildChanged
								                        If IDYES = SalMessageBox( 'This table may have different information at this point.  Do you want to repopulate?', 'NOTE', MB_YesNo )
									                        Set bRePopSelected = FALSE
								                        Else 
									                        Return FALSE
							                        Else 
								                        Set bRePopSelected = FALSE
							                        If bRePopSelected AND sNAMERefreshHandle != ''
								                        If wParam = TBL_cls_RePopByRowsRefreshOnly
									                        If TableLoop( hWndForm, hWndForm, PAM_clsTBL_REFRESHROW, 0, 0, 0, 'Repopulating Table Rows', TBL_cls_LowToHiWithPositioning )
										                        Set bOk = TRUE
									                        Else 
										                        Set bOk = FALSE
									                        If nCurrentContextRow >= 0
										                        Call SalTblFetchRow( hWndForm, nCurrentContextRow )
										                        Call SalTblSetContext( hWndForm, nCurrentContextRow )
										                        Call SalTblSetFocusRow( hWndForm, nCurrentContextRow )
									                        Return bOk
								                        Else 
									                        If TableLoop( hWndForm, hWndForm, PAM_clsTBL_REFRESHROW, 0, ROW_Selected, 0, 'Repopulating Selected Rows', TBL_cls_LowToHiWithPositioning )
										                        Return TRUE
									                        Else 
										                        Return FALSE
							                        Else 
								                        Return SalSendMsg( hWndForm, PAM_clsTBL_SEARCH, wParam, lParam )
						                        Else 
							                        Return FALSE
					                        On PAM_clsTBL_NOROWS
						                        Call SalMessageBox( 'Table is empty', sTableHeading, MB_Ok )
					!
					! Code in here changed to deleting split window rows on a reset
					                        On PAM_clsTBL_RESET
						                        Call SalTblQuerySplitWindow( hWndForm, __nSplitRows, __bReceive )
						                        If __nSplitRows > 0
							                        Set __i = 0
							                        While __i < __nSplitRows
								                        Call SalTblDeleteRow( hWndForm, TBL_MinSplitRow + __i, TBL_Adjust )
								                        Set __i = __i + 1
						                        Set __nNewRow = 0
						                        If SalTblReset( hWndForm )
							                        Set nTableTotalRows = 0
							                        Return TRUE
						                        Else 
							                        Return FALSE
					                        On PAM_clsTBL_ISTABLECHANGED
						                        Return bChanged
					!
					                        On PAM_clsTBL_DELETEROWS
						           If __bDELETEAllowed
							                        If TableLoop( hWndForm, hWndForm, PAM_clsTBL_DELROW, 0, ROW_New|ROW_Selected, 0, 'Deleting Rows', TBL_cls_LowToHi )
								                        Return TRUE
							                        Else 
								                        Return FALSE
						                        Else 
							                        Return FALSE
					                        On PAM_clsTBL_DELROW
						                        If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
							                        If SalTblQueryRowFlags( hWndForm, lParam, ROW_Selected )
								                        Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
								                        Set nTableTotalRows = nTableTotalRows - 1
								                        Return TBL_cls_RowDeleted
							                        Else 
								                        Return TRUE
						                        Else 
							                        Call SalTblSetRowFlags( hWndForm, lParam, ROW_MarkDeleted, TRUE )
							                        Return TRUE
					                        On PAM_clsTBL_UNDELETEROWS
						                        If bUnDeleteAllowed
							                        If TableLoop( hWndForm, hWndForm, PAM_clsTBL_UNDELROW, 0, ROW_New|ROW_Selected, 0, 'Undeleting Rows', TBL_cls_LowToHi )
								                        Return TRUE
							                        Else 
								                        Return FALSE
						                        Else 
							                        Return FALSE
					                        On PAM_clsTBL_UNDELROW
						                        If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
							                        If SalTblQueryRowFlags( hWndForm, lParam, ROW_Selected )
								                        Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
								                        Set nTableTotalRows = nTableTotalRows - 1
								                        Return TBL_cls_RowDeleted
							                        Else 
								                        Return TRUE
						                        Else 
							                        Call SalTblSetRowFlags( hWndForm, lParam, ROW_MarkDeleted, FALSE )
							                        Return TRUE
					!
					                        On PAM_clsTBL_CLEARSELECTIONS
						                        If bClearSelectAllowed
							                        If TableLoop( hWndForm, hWndForm, PAM_clsTBL_CLEARROW, 0, ROW_Selected, 0, 'Clearing Rows', TBL_cls_LowToHi )
								                        Return TRUE
							                        Else 
								                        Return FALSE
						                        Else 
							                        Return FALSE
					                        On PAM_clsTBL_CLEARROW
						                        If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
							                        Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
							                        Set nTableTotalRows = nTableTotalRows - 1
							                        Return TBL_cls_RowDeleted
						                        Else 
							                        Call SalTblSetRowFlags( hWndForm, lParam, ROW_Selected, FALSE )
							                        Return TRUE
					!
					                        On PAM_clsTBL_CHECKCHANGES
						                        Return TableForgetChanges( hWndForm, bEdit )
					!
					                        On PAM_clsTBL_POPFROMSQL
						                        Call OurWaitCursor( TRUE )
						                        If hWndKeepSelRowsCol1 != hWndNULL
							                        Set hWndTblKeepSelRows = SalCreateWindow( tblKeepSelRows, hWndForm, 
									      hWndForm, hWndKeepSelRowsCol1, hWndKeepSelRowsCol2, hWndKeepSelRowsCol3 )
							                        If hWndTblKeepSelRows != hWndNULL
								                        Set bKeepSelRowsLocated = FALSE
								                        Call SalSendMsg( hWndTblKeepSelRows, PAM_clsTBL_INITIALISE, 0, 0 )
						! lParam is the whole sql statement for the populate
						                        Set sQuerySqlStatement = SalNumberToHString( lParam )
						!
						                        Call SalSendMsg( hWndForm, PAM_clsTBL_RESET, 0, 0 )
						                        Call SalTblPopulate( hWndForm, haSqlHandles[ __nSqlQueryHandleNo ].hSqlHandle, sQuerySqlStatement, nTableFillType )
						                        If TableEmpty( hWndForm, 0 )
							                        Call SalSendMsg( hWndForm, PAM_clsTBL_NOROWS, 0, 0 )
						                        Else 
							                        Call SalTblFetchRow( hWndForm, 0 )
							                        Call SalTblSetContext( hWndForm, 0 )
							                        Call SalTblSetFocusRow( hWndForm, 0 )
							                        If bSelectFirstRow
								                        Call SalTblSetRowFlags( hWndForm, 0, ROW_Selected, TRUE )
							                        Call SalSendMsg( hWndForm, PAM_clsTBL_POPULATED, 0, 0 )
							                        Call SalTblFetchRow( hWndForm, 0 )
							                        Call SalTblSetContext( hWndForm, 0 )
							                        Call SalTblSetFocusRow( hWndForm, 0 )
						                        If hWndTblKeepSelRows != hWndNULL
							                        If NOT bKeepSelRowsLocated
								                        Call TableLoop( hWndForm, hWndForm, PAM_clsTBL_LOCATESELROW, 0, 0, 0, 'Locating Selected Rows', TBL_cls_LowToHi )
							                        If SalDestroyWindow( hWndTblKeepSelRows )
								                        Set hWndTblKeepSelRows = hWndNULL
						                        Call OurWaitCursor( FALSE )
						                        Return TRUE
					!
					                        On PAM_clsTBL_SEARCH
						                        Call OurWaitCursor( TRUE )
						                        If hWndKeepSelRowsCol1 != hWndNULL
							                        Set hWndTblKeepSelRows = SalCreateWindow( tblKeepSelRows, hWndForm, 
									      hWndForm, hWndKeepSelRowsCol1, hWndKeepSelRowsCol2, hWndKeepSelRowsCol3 )
							                        If hWndTblKeepSelRows != hWndNULL
								                        Set bKeepSelRowsLocated = FALSE
								                        Call SalSendMsg( hWndTblKeepSelRows, PAM_clsTBL_INITIALISE, 0, 0 )
						! wParam = TRUE means this is comming from the dlgQueryTable
						                        If wParam = TRUE
							                        Call PopString( sBuildWhere, TRUE )
							                        Set sLastBuildWhere = sBuildWhere
							                        Call SalSendMsg( hWndForm, PAM_clsTBL_POPFIELDS, 0, 0 )
						                        Else 
							                        Set sBuildWhere = sLastBuildWhere
						!
						                        Set sQuerySqlStatement = ''
						                        Call ExtractSELECTPart( sSQLPopHandle, sSelectPart )
						                        Call ExtractFROMPart( sSQLPopHandle, sFromPart )
						                        Call ExtractWHEREPart( sSQLPopHandle, sWherePart )
						                        Call MatchUpNFillBinds( sWherePart, sBINDPopHandle, sWherePart )
						                        If sLastOrderBy = ''
							                        Call ExtractORDERGROUPPart( sSQLPopHandle, sOrderPart )
						                        Else 
							                        Set sOrderPart = sLastOrderBy
						!
						                        If NOT sBuildWhere = ''
							                        If sWherePart = ''
								                        Set sWherePart = ' WHERE ' || sBuildWhere
							                        Else 
								                        Set sWherePart = sWherePart || ' AND ' || sBuildWhere
						                        Set sQuerySqlStatement = sSelectPart || ' ' || sFromPart || ' INTO ' || sINTOPopHandle || ' ' || sWherePart || ' ' || sOrderPart
						!
						                        Call SalSendMsg( hWndForm, PAM_clsTBL_RESET, 0, 0 )
						                        Call SalTblPopulate( hWndForm, haSqlHandles[ __nSqlQueryHandleNo ].hSqlHandle, sQuerySqlStatement, nTableFillType )
						                        If TableEmpty( hWndForm, 0 )
							                        Call SalSendMsg( hWndForm, PAM_clsTBL_NOROWS, 0, 0 )
						                        Else 
							                        Call SalTblFetchRow( hWndForm, 0 )
							                        Call SalTblSetContext( hWndForm, 0 )
							                        Call SalTblSetFocusRow( hWndForm, 0 )
							                        If bSelectFirstRow
								                        Call SalTblSetRowFlags( hWndForm, 0, ROW_Selected, TRUE )
							                        Call SalSendMsg( hWndForm, PAM_clsTBL_POPULATED, 0, 0 )
							                        Call SalTblFetchRow( hWndForm, 0 )
							                        Call SalTblSetContext( hWndForm, 0 )
							                        Call SalTblSetFocusRow( hWndForm, 0 )
						                        If hWndTblKeepSelRows != hWndNULL
							                        If NOT bKeepSelRowsLocated
								                        Call TableLoop( hWndForm, hWndForm, PAM_clsTBL_LOCATESELROW, 0, 0, 0, 'Locating Selected Rows', TBL_cls_LowToHi )
							                        If SalDestroyWindow( hWndTblKeepSelRows )
								                        Set hWndTblKeepSelRows = hWndNULL
						                        Call OurWaitCursor( FALSE )
						                        Return TRUE
					                        On PAM_clsTBL_QUERY
						                        If bQueryAllowed
							                        If NOT SalSendMsg( hWndForm, PAM_clsTBL_CHECKCHANGES, 0, 0 )
								                        Return FALSE
							                        If sQueryDialogName != ''
								                        Call SalSendMsg( hWndForm, PAM_clsTBL_PUSHFIELDS, 0, 0 )
								                        Call PushWndHdl( hWndForm )
								                        Call SalModalDialogFromStr( sQueryDialogName, hWndForm )
								                        Return TRUE
						                        Else 
							                        Return FALSE
					                        On PAM_clsTBL_LOCATESELROW
						                        If SalTblQueryRowFlags( hWndForm, lParam, ROW_Selected )
							                        Call SalTblSetContext( hWndForm, lParam )
							                        Call SalTblSetFocusRow( hWndForm, lParam )
							                        Call SalInvalidateWindow( hWndForm )
							                        Set bKeepSelRowsLocated = TRUE
							                        Return FALSE
						                        Else 
							                        Return TRUE
					!
					                        On PAM_clsTBL_SAVECHANGES
						                        If bSaveAllowed
							                        If bGetSaveConfirmation
								                        If IDNO = SalMessageBox( 'Are you ready to insert/update/delete the modified rows?', sTableHeading, MB_YesNo|MB_IconExclamation )
									                        Return FALSE
							                        Call OurWaitCursor( TRUE )
							                        If TableLoop( hWndForm, hWndForm, PAM_clsTBL_DATAVAL, 0, ROW_Edited|ROW_New|ROW_MarkDeleted, 0, 'Checking Changes', TBL_cls_LowToHiWithPositioning )
								                        If TableLoop( hWndForm, hWndForm, PAM_clsTBL_WRITEINSERTSUPDATES, 0, ROW_Edited|ROW_New|ROW_MarkDeleted, 0, 'Saving Changes', TBL_cls_LowToHiWithPositioning )
									                        Call OurWaitCursor( FALSE )
									                        Return TRUE
								                        Else 
									                        Call OurWaitCursor( FALSE )
									                        Return FALSE
							                        Else 
								                        Call OurWaitCursor( FALSE )
								                        Return FALSE
						                        Else 
							                        Return FALSE
					! On PAM_clsTBL_WRITEINSERTSUPDATES
						                        If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
							                        If TableCheckMessageOk( hWndForm, PAM_clsTBL_CHECKROWNEW, lParam )
								                        If haSqlHandles[ n__nSqlInsertHandleNo].Execute( )
									                        Call haSqlHandles[ n__nSqlInsertHandleNo].Commit( )
									                        Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_ROWINSERTED, 0, lParam )
									                        Call SalTblSetRowFlags( hWndForm, lParam, ROW_New, FALSE )
									                        Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, FALSE )
									                        Call SalSendMsg( hWndForm, PAM_clsTBL_REFRESHROW, 0, lParam ) 
									                        Set bChanged = TRUE
								                        Return TRUE
							                        Else 
								                        Return FALSE
						                        If SalTblQueryRowFlags( hWndForm, lParam, ROW_Edited )
							                        If TableCheckMessageOk( hWndForm, PAM_clsTBL_CHECKROWEDITED, lParam )
								                        If haSqlHandles[ n__nSqlUpdateHandleNo].Execute( )
									                        Call haSqlHandles[ n__nSqlUpdateHandleNo].Commit( )
									                        Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_ROWUPDATED, 0, lParam )
									                        Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, FALSE )
									                        Call SalSendMsg( hWndForm, PAM_clsTBL_REFRESHROW, 0, lParam ) 
									                        Set bChanged = TRUE
								                        Return TRUE
							                        Else 
								                        Return FALSE
						                        If SalTblQueryRowFlags( hWndForm, lParam, ROW_MarkDeleted )
							                        If TableCheckMessageOk( hWndForm, PAM_clsTBL_CHECKROWDELETED, lParam )
								                        If haSqlHandles[ n__nSqlDeleteHandleNo].Execute( )
									                        Call haSqlHandles[ n__nSqlDeleteHandleNo].Commit( )
									                        Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_ROWDELETED, 0, lParam )
									                        Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
									                        Set bChanged = TRUE
									                        Return TBL_cls_RowDeleted
								                        Return TRUE
							                        Else 
								                        Return FALSE
						                        Return TRUE
					                        On PAM_clsTBL_WRITEINSERTSUPDATES
						                        If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
							                        If TableCheckMessageOk( hWndForm, PAM_clsTBL_CHECKROWNEW, lParam )
								                        If SalSendMsg( hWndForm, PAM_clsTBL_SAVEROWNEW, 0, lParam )
									                        Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_ROWINSERTED, 0, lParam )
									                        Call SalTblSetRowFlags( hWndForm, lParam, ROW_New, FALSE )
									                        Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, FALSE )
									                        Call SalSendMsg( hWndForm, PAM_clsTBL_REFRESHROW, 0, lParam )
									                        Set bChanged = TRUE
								                        Return TRUE
							                        Else 
								                        Return FALSE
						                        If SalTblQueryRowFlags( hWndForm, lParam, ROW_Edited )
							                        If TableCheckMessageOk( hWndForm, PAM_clsTBL_CHECKROWEDITED, lParam )
								                        If SalSendMsg( hWndForm, PAM_clsTBL_SAVEROWEDITED, 0, lParam )
									                        Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_ROWUPDATED, 0, lParam )
									                        Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, FALSE )
									                        Call SalSendMsg( hWndForm, PAM_clsTBL_REFRESHROW, 0, lParam )
									                        Set bChanged = TRUE
								                        Return TRUE
							                        Else 
								                        Return FALSE
						                        If SalTblQueryRowFlags( hWndForm, lParam, ROW_MarkDeleted )
							                        If TableCheckMessageOk( hWndForm, PAM_clsTBL_CHECKROWDELETED, lParam )
								                        If SalSendMsg( hWndForm, PAM_clsTBL_SAVEROWDELETED, 0, lParam )
									                        Call SalSendMsgToChildren( hWndForm, PAM_clsTBL_ROWDELETED, 0, lParam )
									                        Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
									                        Set bChanged = TRUE
									                        Return TBL_cls_RowDeleted
								                        Return TRUE
							                        Else 
								                        Return FALSE
						                        Return TRUE
					                        On PAM_clsTBL_SAVEROWNEW
						                        If haSqlHandles[ __nSqlInsertHandleNo ].Execute( )
							                        Call haSqlHandles[ __nSqlInsertHandleNo ].Commit( )
							                        Return TRUE
						                        Else 
							                        Return FALSE
					                        On PAM_clsTBL_SAVEROWEDITED
						                        If haSqlHandles[ __nSqlUpdateHandleNo ].Execute( )
							                        Call haSqlHandles[ __nSqlUpdateHandleNo ].Commit( )
							                        Return TRUE
						                        Else 
							                        Return FALSE
					                        On PAM_clsTBL_SAVEROWDELETED
						                        If haSqlHandles[ __nSqlDeleteHandleNo ].Execute( )
							                        Call haSqlHandles[ __nSqlDeleteHandleNo ].Commit( )
							                        Return TRUE
						                        Else 
							                        Return FALSE
					                        On PAM_clsTBL_DATAVAL
						                        Return TableCheckMessageOk( hWndForm, PAM_clsTBL_DATAVAL, lParam )
					                        On PAM_clsTBL_ADDROW
						                        If bAddAllowed
							                        If bAddRowAtEnd
								                        If TableAddRow( hWndForm, hWndRowNewColumn, TBL_MaxRow ) >= 0
									                        Set nTableTotalRows = nTableTotalRows + 1
									                        Return TRUE
								                        Else 
									                        Return FALSE
							                        Else If bAddRowBellow
								                        If TableAddRowNewBellow( hWndForm, hWndRowNewColumn ) >= 0
									                        Set nTableTotalRows = nTableTotalRows + 1
									                        Return TRUE
								                        Else 
									                        Return FALSE
							                        Else 
								                        If TableAddRowNew( hWndForm, hWndRowNewColumn ) >= 0
									                        Set nTableTotalRows = nTableTotalRows + 1
									                        Return TRUE
								                        Else 
									                        Return FALSE
						                        Else 
							                        Return FALSE
					                        On PAM_clsTBL_REFRESHROW
						                        If haSqlHandles[ __nSqlRefreshHandleNo ].Execute( )
							                        Call haSqlHandles[ __nSqlRefreshHandleNo ].FetchNext( nInd )
							                        Call SalSendMsg( hWndForm, SAM_FetchRowDone, PAM_clsTBL_REFRESHROW, lParam )
							                        Return TRUE
						                        Else 
							                        Call SalMessageBox( 'Could not refresh this ROW!', 'Warning', MB_Ok )
							                        Return FALSE
					!
					                        On PAM_clsTBL_ORDERTABLE
						                        If NOT SalSendMsg( hWndForm, PAM_clsTBL_CHECKCHANGES, 0, 0 )
							                        Return FALSE
						                        If sLastOrderBy = ''
							                        Call ExtractORDERGROUPPart( sSQLPopHandle, sOrderPart )
						                        Else 
							                        Set sOrderPart = sLastOrderBy
						                        Call GetOrderByColumns( hWndForm, sINTOPopHandle, saOrderByColumns, naOrderByPositions )
						                        Set nOrderByPos = 0
						                        If SalModalDialog( dlgOrderTable, hWndForm, hWndForm, sOrderPart )
							                        Call PopString( sLastOrderBy, TRUE )
							                        Call SalSendMsg( hWndForm, PAM_clsTBL_REPOPULATE, TBL_cls_RePopulateOrderBy, 0 )
					                        On PAM_clsTBL_GETNEXTORDERBYCOL
						                        If naOrderByPositions[ nOrderByPos ] != NUMBER_Null
							                        Call PushString( saOrderByColumns[ nOrderByPos ] )
							                        Call PushNumber( naOrderByPositions[ nOrderByPos ] )
							                        Set nOrderByPos = nOrderByPos + 1
							                        Return TRUE
						                        Else 
							                        Return FALSE
					!
					                        On PAM_clsTBL_MOVEUPONE
						                        Call OurWaitCursor( TRUE )
						                        Set bOk = FALSE
						                        Set nRow = TBL_MinRow
						                        If SalTblFindNextRow( hWndForm, nRow, ROW_Selected, 0 )
							                        If nRow > 0
								                        Call CopyTblRowFromTo( hWndForm, nRow - 1, TBL_TempRow, FALSE, 0, TRUE )
								                        Call CopyTblRowFromTo( hWndForm, nRow, nRow - 1, FALSE, 0, TRUE )
								                        Call CopyTblRowFromTo( hWndForm, TBL_TempRow, nRow, FALSE, 0, TRUE )
								                        Set bOk = TRUE
						                        Call OurWaitCursor( FALSE )
						                        Return bOk
					                        On PAM_clsTBL_MOVEDOWNONE
						                        Call OurWaitCursor( TRUE )
						                        Set bOk = FALSE
						                        Set nRow = TBL_MinRow
						                        If SalTblFindNextRow( hWndForm, nRow, ROW_Selected, 0 )
							                        Set nTmpRow = nRow
							                        If SalTblFindNextRow( hWndForm, nTmpRow, 0, 0 )
								                        Call CopyTblRowFromTo( hWndForm, nRow + 1, TBL_TempRow, FALSE, 0, TRUE )
								                        Call CopyTblRowFromTo( hWndForm, nRow, nRow + 1, FALSE, 0, TRUE )
								                        Call CopyTblRowFromTo( hWndForm, TBL_TempRow, nRow, FALSE, 0, TRUE )
								                        Set bOk = TRUE
						                        Call OurWaitCursor( FALSE )
						                        Return bOk
					!
					                        On PAM_clsTBL_PRINTTABLEREPORT
						                        If bReportAllowed
							                        If bGiveUserPrintViewChoice
								                        Set nChoice = SalModalDialog( dlgReportPrintViewChoice, hWndForm, sTableHeading, nReportPrintOrView )
								                        If NOT nChoice = FALSE
									                        Set nReportPrintOrView = nChoice
							                        Call TableReportPrint( hWndForm, OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\'||sReportFileName, sRepBind, sRepInto, nReportPrintOrView )
						                        Else 
							                        Return FALSE
					                        On SAM_ReportStart
						                        Return TRUE
					                        On SAM_ReportFetchInit
						                        Return TableReportFetchInit( hWndForm, nReportTableRow, bReportTableSelectedRowsOnly, sTableHeading )
					                        On SAM_ReportFetchNext
						                        Return TableReportFetchNext( hWndForm, nReportTableRow, bReportTableSelectedRowsOnly )
					                        On PAM_clsTBL_TABLEREPORTROWACTION
						                        Return TRUE
					                        On SAM_ReportFinish
						                        Call SalSendMsg( hWndForm, PAM_clsTBL_REPORTFINISHED, 0, 0 )
						                        Call SalShowWindow( hWndForm )
						                        Call SalBringWindowToTop( hWndForm )
						                        Return TRUE
					                        On PAM_clsTBL_REPORTFINISHED
						                        Return TRUE
					!
					                        On PAM_clsTBL_SAVECSVFILE
						                        If bMakeCSVFileAllowed
							                        Set bOk = FALSE
							!
							                        If SalTblAnyRows( hWndForm, ROW_Selected, 0 )
								                        Set nFileHandlingType = TBL_cls_RowsSelected
								                        If TableAnyColumns( hWndForm, COL_Selected )
									                        Set nFileHandlingType = nFileHandlingType | TBL_cls_ColumnsSelected
								                        If SalModalDialog( dlgSaveTblCSVFile, hWndForm, sCSVFileName, nFileHandlingType )
									                        Set bOk = TRUE
							                        Else 
								                        Set nFileHandlingType = TBL_cls_NoRowsSelected
								                        If TableAnyColumns( hWndForm, COL_Selected )
									                        Set nFileHandlingType = nFileHandlingType | TBL_cls_ColumnsSelected
								                        If SalModalDialog( dlgSaveTblCSVFile, hWndForm, sCSVFileName, nFileHandlingType )
									                        Set bOk = TRUE
							!
							                        If bOk
								                        If IsFlagSet( nFileHandlingType, TBL_cls_CreateOverwrite )
									                        If NOT SalFileOpen( hCSVFileHandle, sCSVFileName, OF_Text | OF_Write | OF_Create )
										                        Call SalMessageBox( 'A problem has occoured opening your CSV File. Please try again!', 'Error', MB_Ok )
										                        Set bOk = FALSE
								                        Else If IsFlagSet( nFileHandlingType, TBL_cls_AppendRows )
									                        If NOT SalFileOpen( hCSVFileHandle, sCSVFileName, OF_Text | OF_Write | OF_Append )
										                        Call SalMessageBox( 'A problem has occoured opening your CSV File. Please try again!', 'Error', MB_Ok )
										                        Set bOk = FALSE
								                        Else If IsFlagSet( nFileHandlingType, TBL_cls_AppendColumns )
									                        If NOT SalFileOpen( hCSVFileHandle, sCSVFileName, OF_Text | OF_ReadWrite )
										                        Call SalMessageBox( 'A problem has occoured opening your CSV File. Please try again!', 'Error', MB_Ok )
										                        Set bOk = FALSE
								!
								                        If bOk
									                        If IsFlagSet( nFileHandlingType, TBL_cls_RowsSelected )
										                        Call TableLoop( hWndForm, hWndForm, PAM_clsTBL_SAVECSVROW, 0, ROW_Selected, 0, 'Saving Selected rows into CSV File', TBL_cls_LowToHi )
									                        Else 
										                        Call TableLoop( hWndForm, hWndForm, PAM_clsTBL_SAVECSVROW, 0, 0, 0, 'Saving table into CSV File', TBL_cls_LowToHi )
									                        Call SalFileClose( hCSVFileHandle )
							                        Return bOk
						                        Else 
							                        Return FALSE
					                        On PAM_clsTBL_SAVECSVROW
						                        If IsFlagSet( nFileHandlingType, TBL_cls_CreateOverwrite ) OR 
								   IsFlagSet( nFileHandlingType, TBL_cls_AppendRows )
							                        If IsFlagSet( nFileHandlingType, TBL_cls_ColumnsSelected )
								                        Call SalFilePutStr( hCSVFileHandle, MakeCSVColumnsLine( hWndForm, TRUE ) )
							                        Else 
								                        Call SalFilePutStr( hCSVFileHandle, MakeCSVColumnsLine( hWndForm, FALSE ) )
						! Else If IsFlagSet( nFileHandlingType, TBL_cls_AppendColumns )
						                        Return TRUE
					!
					                        On PAM_clsTBL_FETCHFIRSTROW
						                        If SalTblAnyRows( hWndForm, ROW_Selected, 0 )
							                        Set nTmpRow = TBL_MinRow
							                        If SalTblFindNextRow( hWndForm, nTmpRow, ROW_Selected, 0 )
								                        Call SalTblFetchRow( hWndForm, nTmpRow )
								                        Call SalTblSetContext( hWndForm, nTmpRow )
								                        Call SalTblSetFocusRow( hWndForm, nTmpRow )
								                        Return TRUE
							                        Else 
								                        Return FALSE
						                        Else 
							                        Call SalTblFetchRow( hWndForm, 0 )
							                        Call SalTblSetContext( hWndForm, 0 )
							                        Call SalTblSetFocusRow( hWndForm, 0 )
							                        Return TRUE
					                        On PAM_clsTBL_FETCHPREVROW
						                        Set nTmpRow = SalTblQueryContext( hWndForm )
						                        If SalTblAnyRows( hWndForm, ROW_Selected, 0 )
							                        If SalTblFindPrevRow( hWndForm, nTmpRow, ROW_Selected, 0 )
								                        Call SalTblFetchRow( hWndForm, nTmpRow )
								                        Call SalTblSetContext( hWndForm, nTmpRow )
								                        Call SalTblSetFocusRow( hWndForm, nTmpRow )
								                        Return TRUE
							                        Else 
								                        Call SalMessageBox( 'No more rows!', 'Previous', MB_Ok )
								                        Return FALSE
						                        Else 
							                        If SalTblFindPrevRow( hWndForm, nTmpRow, 0, 0 )
								                        Call SalTblFetchRow( hWndForm, nTmpRow )
								                        Call SalTblSetContext( hWndForm, nTmpRow )
								                        Call SalTblSetFocusRow( hWndForm, nTmpRow )
								                        Return TRUE
							                        Else 
								                        Call SalMessageBox( 'No more rows!', 'Previous', MB_Ok )
								                        Return FALSE
					                        On PAM_clsTBL_FETCHNEXTROW
						                        Set nTmpRow = SalTblQueryContext( hWndForm )
						                        If SalTblAnyRows( hWndForm, ROW_Selected, 0 )
							                        If SalTblFindNextRow( hWndForm, nTmpRow, ROW_Selected, 0 )
								                        Call SalTblFetchRow( hWndForm, nTmpRow )
								                        Call SalTblSetContext( hWndForm, nTmpRow )
								                        Call SalTblSetFocusRow( hWndForm, nTmpRow )
								                        Return TRUE
							                        Else 
								                        Call SalMessageBox( 'No more rows!', 'Next', MB_Ok )
								                        Return FALSE
						                        Else 
							                        If SalTblFindNextRow( hWndForm, nTmpRow, 0, 0 )
								                        Call SalTblFetchRow( hWndForm, nTmpRow )
								                        Call SalTblSetContext( hWndForm, nTmpRow )
								                        Call SalTblSetFocusRow( hWndForm, nTmpRow )
								                        Return TRUE
							                        Else 
								                        Call SalMessageBox( 'No more rows!', 'Next', MB_Ok )
								                        Return FALSE
					                        On PAM_clsTBL_FETCHLASTROW
						                        If SalTblAnyRows( hWndForm, ROW_Selected, 0 )
							                        Set nTmpRow = TableLocateLastRow( hWndForm, ROW_Selected, 0 )
							                        Call SalTblFetchRow( hWndForm, nTmpRow )
							                        Call SalTblSetContext( hWndForm, nTmpRow )
							                        Call SalTblSetFocusRow( hWndForm, nTmpRow )
							                        Return TRUE
						                        Else 
							                        Set nTmpRow = TableLocateLastRow( hWndForm, 0, 0 )
							                        Call SalTblFetchRow( hWndForm, nTmpRow )
							                        Call SalTblSetContext( hWndForm, nTmpRow )
							                        Call SalTblSetFocusRow( hWndForm, nTmpRow )
							                        Return TRUE
					!
					                        On PAM_clsTBL_ALLOWEDACTIONS
						                        Set nChoice = 0
						                        If bMakeCSVFileAllowed
							                        Set nChoice = nChoice | TBL_cls_MakeCSVFile
						                        Return nChoice
					!
					                        On PAM_clsTBL_ZOOMTABLE
						                        If bZoomTableAllowed
							                        If lParam
								                        Return TRUE
							                        Else 
								                        If bTableZoom
									                        Set bTableZoom = FALSE
									                        Call SalSetWindowSize( hWndForm, nOrgTblWidth, nOrgTblHeight )
									                        Call SalSetWindowLoc( hWndForm, nOrgTblLeft, nOrgTblTop )
									                        Call SalSendMsgToChildren( hWndParent, PAM_clsTBL_ZOOMTABLE, bTableZoom, 2 )
								                        Else 
									                        Set bTableZoom = TRUE
									                        Call SalSetWindowLoc( hWndForm, nZoomTblLeft, nZoomTblTop )
									                        Call SalSetWindowSize( hWndForm, nZoomTblWidth, nZoomTblHeight )
									                        Call SalSendMsgToChildren( hWndParent, PAM_clsTBL_ZOOMTABLE, bTableZoom, 2 )
						                        Else 
							                        Return FALSE
					!
					                        On SAM_SetFocus
						                        Call SalSendMsg( hWndForm, PAM_clsTBL_CHKCONTEXTROW, 0, 0 )
						                        Return TRUE
					                        On SAM_RowValidate
						                        Call SalPostMsg( hWndForm, PAM_clsTBL_CHKCONTEXTROW, 0, 0 )
						                        Return VALIDATE_Ok
					                        On PAM_clsTBL_CHKCONTEXTROW
						                        Call SalTblQueryFocus( hWndForm, nCurrentContextRow, hWndTmp )
						                        If nCurrentContextRow != nLastContextRow
							                        Set nLastContextRow = nCurrentContextRow
							                        Call SalSendMsg( hWndForm, PAM_clsTBL_CONTEXTROWCHANGED, 0, nCurrentContextRow )
					!
					                        On PAM_clsTBL_METERSETUP
						                        Call PopString( sTmp, TRUE )
						                        Call fcTableMeter.Setup( sTmp, lParam )
						                        Return TRUE
					                        On PAM_clsTBL_METERINCROW
						                        Return fcTableMeter.Increment( lParam )
					                        On PAM_clsTBL_METEREND
						                        Return fcTableMeter.End( )

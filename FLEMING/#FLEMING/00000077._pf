			General Window Class: clsTblMakeSelectedRowKeyArray
				Description:
				Derived From
				Class Variables
					String: __saStringArray[*]
					Number: __nArrayPos
					Boolean: __bFound
					String: __sColText
				Instance Variables
					! PUBLIC
					Window Handle: hWndTable
					Window Handle: hWndColKey
					Number: nTableRowOnFlags
					Number: nTableRowOffFlags
					! PRIVATE
				Functions
					! PUBLIC
					Function: GetStringArrayList
						Description:
						Returns
							Boolean:
						Parameters
							Receive String: saList[*]
						Static Variables
						Local variables
							Number: nArrayPos
						Actions
							If __MakeArrayList( )
								Set nArrayPos = 0
								While __saStringArray[ nArrayPos ] != ''
									Set saList[ nArrayPos ] = __saStringArray[ nArrayPos ]
									Set nArrayPos = nArrayPos + 1
									Set saList[ nArrayPos ] = ''
								Return TRUE
							Else
								Return FALSE
					Function: GetNumberArrayList
						Description:
						Returns
							Boolean:
						Parameters
							Receive Number: naList[*]
						Static Variables
						Local variables
							Number: nArrayPos
						Actions
							If __MakeArrayList( )
								Set nArrayPos = 0
								While __saStringArray[ nArrayPos ] != ''
									Set naList[ nArrayPos ] = SalStrToNumber( __saStringArray[ nArrayPos ] )
									Set nArrayPos = nArrayPos + 1
									Set naList[ nArrayPos ] = NUMBER_Null
								Return TRUE
							Else
								Return FALSE
					Function: GetDateTimeArrayList
						Description:
						Returns
							Boolean:
						Parameters
							Receive Date/Time: dtaList[*]
						Static Variables
						Local variables
							Number: nArrayPos
						Actions
							If __MakeArrayList( )
								Set nArrayPos = 0
								While __saStringArray[ nArrayPos ] != ''
									Set dtaList[ nArrayPos ] = SalStrToDate( __saStringArray[ nArrayPos ] )
									Set nArrayPos = nArrayPos + 1
									Set dtaList[ nArrayPos ] = DATETIME_Null
								Return TRUE
							Else
								Return FALSE
					! PRIVATE
					Function: __MakeArrayList
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
						Actions
							Set __nArrayPos = 0
							Set __saStringArray[ __nArrayPos ] = ''
							Set __bFound = FALSE
							Call TableLoop( hWndTable, hWndItem, PAM_clsTBL_ROWACTION, 0, nTableRowOnFlags, nTableRowOffFlags, 'Collecting selections', TBL_cls_LowToHi )
							Return __bFound
				Message Actions
					On SAM_Create
						Set nTableRowOnFlags = ROW_Selected
						Set nTableRowOffFlags = 0
						Set hWndTable = hWndNULL
						Set hWndColKey = hWndNULL
						Return SalSendMsg( hWndItem, PAM_cls_SETINSTANCEVARS, 0, 0 )
					On PAM_clsTBL_ROWACTION
						Call SalFmtFieldToStr( hWndColKey, __sColText, TRUE )
						Set __saStringArray[ __nArrayPos ]  = __sColText
						Set __nArrayPos = __nArrayPos + 1
						Set __saStringArray[ __nArrayPos ]  = ''
						Set __bFound = TRUE
						Return TRUE

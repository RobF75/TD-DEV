						Sorted? Class Default
						Vertical Scroll? Class Default
						Auto Drop Down? Class Default
						Allow Text Editing? Class Default
					Cell CheckBox
						Check Value:
						Uncheck Value:
						Ignore Case? Class Default
				Description:
				Derived From
					Class: clsColumnGeneral
				Class Variables
				Instance Variables
					String: sSqlPopStatement
					Boolean: bPopulateOnce
					Boolean: bGetCountOnPopulate
					String: sCurrentSelectionString
					! PRIVATE
					Boolean: __bListPopulated
					Number: __nOurHandleNo
					Boolean: __bOk
					Number: __nRowCount
				Functions
				List Values
				Message Actions
					On SAM_Create
						Set sSqlPopStatement = ''
						Set __bListPopulated = FALSE
						Set bPopulateOnce = TRUE
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set __nOurHandleNo = SqlHandlesGetReferenceNo( GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndItem ) || 'COLLB' )
					! On PAM_clsTBLCOL_POPULATE
						                        If bPopulateOnce
							                        If NOT sSqlPopStatement = '' AND NOT bListPopulated
								                        Set bOk = TRUE
							                        Else 
								                        Set bOk = FALSE
						                        Else 
							                        If NOT sSqlPopStatement = ''
								                        Set bOk = TRUE
							                        Else 
								                        Set bOk = FALSE
						                        If bOk
							                        Call OurWaitCursor( TRUE )
							                        If fcOurHandle.Connect( )
								                        If SalListPopulate( hWndItem, fcOurHandle.hSqlHandle, sSqlPopStatement )
									                        Set bListPopulated = TRUE
							                        Call OurWaitCursor( FALSE )
					On PAM_clsTBLCOL_RESET
						Set __bListPopulated = FALSE
						Return SalListClear( hWndItem )
					On SAM_Destroy
						Return haSqlHandles[ __nOurHandleNo ].Disconnect( )
					On SAM_DropDown
						If bPopulateOnce
							If NOT sSqlPopStatement = '' AND NOT __bListPopulated
								Set __bOk = TRUE
							Else
								Set __bOk = FALSE
						Else
							If NOT sSqlPopStatement = ''
								Set __bOk = TRUE
							Else
								Set __bOk = FALSE
						If __bOk
							Call OurWaitCursor( TRUE )
							If haSqlHandles[ __nOurHandleNo ].Connect( )
								If SalListPopulate( hWndItem, haSqlHandles[ __nOurHandleNo ].hSqlHandle, sSqlPopStatement )
									Set __bListPopulated = TRUE
							Call OurWaitCursor( FALSE )
			Column Class: clsColDropListCache
				Title:
				Visible? Class Default
				Editable? Class Default
				Maximum Data Length: Class Default
				Data Type: Class Default
				Justify: Class Default
				Width:  Class Default
				Width Editable? Class Default

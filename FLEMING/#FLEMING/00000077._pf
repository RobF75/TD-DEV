		Functions
		Window Parameters
			Window Handle: hWndParent
		Window Variables
			Boolean: bOk
			Number: nReturn
		Message Actions
			On SAM_Create
				Set nReturn = SalSendMsg( hWndParent, PAM_clsTBL_ALLOWEDACTIONS, 0, 0 ) 
				If NOT IsFlagSet( nReturn, TBL_cls_AddRow )
					Call SalSendMsg( pbTblAddRows, PAM_clsPB_DISABLE, 0, 0 )
				If NOT IsFlagSet( nReturn, TBL_cls_SaveRow )
					Call SalSendMsg( pbTblSaveRows, PAM_clsPB_DISABLE, 0, 0 )
				If NOT IsFlagSet( nReturn, TBL_cls_ClearRow )
					Call SalSendMsg( pbTblClearRows, PAM_clsPB_DISABLE, 0, 0 )
				If NOT IsFlagSet( nReturn, TBL_cls_DeleteRow )
					Call SalSendMsg( pbTblDeleteRows, PAM_clsPB_DISABLE, 0, 0 )
				If NOT IsFlagSet( nReturn, TBL_cls_UnDeleteRow )
					Call SalSendMsg( pbTblUnDeleteRows, PAM_clsPB_DISABLE, 0, 0 )
				If NOT IsFlagSet( nReturn, TBL_cls_Query )
					Call SalSendMsg( pbTblQuery, PAM_clsPB_DISABLE, 0, 0 )
				If NOT IsFlagSet( nReturn, TBL_cls_OrderTable )
					Call SalSendMsg( pbTblOrderTable, PAM_clsPB_DISABLE, 0, 0 )
				If NOT IsFlagSet( nReturn, TBL_cls_RePopTable )
					Call SalSendMsg( pbTblRePopTable, PAM_clsPB_DISABLE, 0, 0 )
				If NOT IsFlagSet( nReturn, TBL_cls_TableReport )
					Call SalSendMsg( pbTblTableReport, PAM_clsPB_DISABLE, 0, 0 )
				If NOT IsFlagSet( nReturn, TBL_cls_MoveUpOne )
					Call SalSendMsg( pbTblMoveUpOne, PAM_clsPB_DISABLE, 0, 0 )
				If NOT IsFlagSet( nReturn, TBL_cls_MoveDownOne )
					Call SalSendMsg( pbTblMoveDownOne, PAM_clsPB_DISABLE, 0, 0 )
				If NOT IsFlagSet( nReturn, TBL_cls_MakeCSVFile )
					Call SalSendMsg( pbTblMakeCSVFile, PAM_clsPB_DISABLE, 0, 0 )
				If NOT IsFlagSet( nReturn, TBL_cls_ZoomTable )
					Call SalSendMsg( pbTblZoomTable, PAM_clsPB_DISABLE, 0, 0 )
				!
				Return SalSendClassMessage( SAM_Create, wParam, lParam )
			On SAM_CreateComplete
				Set bOk = SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
				Call OurWaitCursorOverride( FALSE, TRUE )
				Return bOk
			On PAM_clsTBL_USERACTIONS
				Call SalPostMsg( hWndParent, PAM_clsTBL_USERACTIONS, wParam, lParam )
				Return SalSendMsg( pbExit, SAM_Click, TRUE, 0 )

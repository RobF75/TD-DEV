								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
					Column: colTitle
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Columns
						Visible? Yes
						Editable? No
						Maximum Data Length: Default
						Data Type: String
						Justify: Left
						Width:  2.2"
						Width Editable? Yes
						Format: Unformatted
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
					Column: colDirection
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Direction
						Visible? Yes
						Editable? No
						Maximum Data Length: Default
						Data Type: String
						Justify: Left
						Width:  0.813"
						Width Editable? Yes
						Format: Unformatted
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On SAM_Click
								If colDirection = 'ASC'
									Set colDirection = 'DESC'
								Else
									Set colDirection = 'ASC'
				Functions
					Function: IsRowSelected
						Description:
						Returns
							Boolean:
						Parameters
							Window Handle: hWndTable
						Static Variables
						Local variables
							Number: nRow
							Boolean: bFound
						Actions
							Call OurWaitCursor( TRUE )
							Set nRow = TBL_MinRow
							Set bFound = FALSE
							While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
								If bFound
									Call SalTblSetRowFlags( hWndTable, nRow, ROW_Selected, FALSE )
								Else
									Set bFound = TRUE
							Call OurWaitCursor( FALSE )
							Return bFound
				Window Variables
					Number: nRow
					Number: nTmpRow
					Boolean: bOk
					!
					Number: nFromPosition
					String: sFromTitle
					String: sFromDirection
					!
					Number: nToPosition
					String: sToTitle
					String: sToDirection
					!
					String: sOrderBy
					String: sTmp
				Message Actions
					On PAM_clsTBL_ORDERTABLE
						Call OurWaitCursor( TRUE )
						Set sOrderBy = ' ORDER BY '
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( tblSortColumns, nRow, 0, 0 )
							Call SalTblFetchRow( tblSortColumns, nRow )
							Call SalNumberToStr( tblSortColumns.colPosition, 0, sTmp )
							If nRow = 0
								Set sOrderBy = sOrderBy || sTmp || ' ' || tblSortColumns.colDirection
							Else
								Set sOrderBy = sOrderBy || ',' || sTmp || ' ' || tblSortColumns.colDirection
						If sOrderBy = ' ORDER BY '
							Call OurWaitCursor( FALSE )
							Call SalPostMsg( pbExit, SAM_Click, FALSE, 0 )
						Else
							Call PushString( sOrderBy )
							Call OurWaitCursor( FALSE )
							Call SalPostMsg( pbExit, SAM_Click, TRUE, 0 )
					On PAM_clsTBL_POPULATE
						While SalSendMsg( dlgOrderTable.hWndParentTable, PAM_clsTBL_GETNEXTORDERBYCOL, 0, 0 )
							Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
							Call SalTblSetRowFlags( hWndForm, nRow, ROW_HideMarks, TRUE )
							Call PopString( colTitle, TRUE )
							Call PopNumber( colPosition, TRUE )
							Set colDirection = 'ASC'
					On PAM_clsTBL_MOVEUPONE
						If IsRowSelected( hWndForm )
							Call OurWaitCursor( TRUE )
							Set bOk = FALSE
							Set nRow = TBL_MinRow
							If SalTblFindNextRow( hWndForm, nRow, ROW_Selected, 0 )
								If nRow > 0
									Call SalTblFetchRow( hWndForm, nRow )
									Set nFromPosition = colPosition
									Set sFromTitle = colTitle
									Set sFromDirection = colDirection
									Call SalTblFetchRow( hWndForm, nRow - 1 )
									Set nToPosition = colPosition
									Set sToTitle = colTitle
									Set sToDirection = colDirection
									Set colPosition = nFromPosition
									Set colTitle = sFromTitle
									Set colDirection = sFromDirection
									Call SalTblFetchRow( hWndForm, nRow )
									Set colPosition = nToPosition
									Set colTitle = sToTitle
									Set colDirection = sToDirection
									Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, FALSE )
									Call SalTblSetRowFlags( hWndForm, nRow - 1, ROW_Selected, TRUE )
									Call SalTblSetFocusRow( hWndForm, nRow - 1 )
									Set bOk = TRUE
							Call OurWaitCursor( FALSE )
							Return bOk
						Else
							Return FALSE
					On PAM_clsTBL_MOVEDOWNONE
						If IsRowSelected( hWndForm )
							Call OurWaitCursor( TRUE )
							Set bOk = FALSE
							Set nRow = TBL_MinRow
							If SalTblFindNextRow( hWndForm, nRow, ROW_Selected, 0 )
								Set nTmpRow = nRow
								If SalTblFindNextRow( hWndForm, nTmpRow, 0, 0 )
									Call SalTblFetchRow( hWndForm, nRow )
									Set nFromPosition = colPosition
									Set sFromTitle = colTitle
									Set sFromDirection = colDirection
									Call SalTblFetchRow( hWndForm, nRow + 1 )
									Set nToPosition = colPosition
									Set sToTitle = colTitle
									Set sToDirection = colDirection
									Set colPosition = nFromPosition
									Set colTitle = sFromTitle
									Set colDirection = sFromDirection
									Call SalTblFetchRow( hWndForm, nRow )
									Set colPosition = nToPosition
									Set colTitle = sToTitle
									Set colDirection = sToDirection
									Call SalTblSetRowFlags( hWndForm, nRow, ROW_Selected, FALSE )
									Call SalTblSetRowFlags( hWndForm, nRow + 1, ROW_Selected, TRUE )
									Call SalTblSetFocusRow( hWndForm, nRow + 1 )
									Set bOk = TRUE
							Call OurWaitCursor( FALSE )
							Return bOk
						Else
							Return FALSE

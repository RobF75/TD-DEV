		Functions
		Window Parameters
			Receive String: sCSVFileName
			Receive Number: nCSVFileHandling
		Window Variables
		Message Actions
			On SAM_CreateComplete
				Call OurWaitCursorOverride( FALSE, TRUE )
				If IsFlagSet( nCSVFileHandling, TBL_cls_RowsSelected )
					Set cbSelectedRows = TRUE
					Call SalSendMsg( cbSelectedRows, PAM_clsCB_ENABLE, 0, 0 )
				Else
					Call SalSendMsg( cbSelectedRows, PAM_clsCB_DISABLE, 0, 0 )
				If IsFlagSet( nCSVFileHandling, TBL_cls_ColumnsSelected )
					Set cbSelectedColumns = TRUE
					Call SalSendMsg( cbSelectedColumns, PAM_clsCB_ENABLE, 0, 0 )
				Else
					Call SalSendMsg( cbSelectedColumns, PAM_clsCB_DISABLE, 0, 0 )
				Call SalSendMsg( rbAppendSide, PAM_clsRB_DISABLE, 0, 0 )
				Call SalSetFocus( dfFileName )
				Set rbCreate = TRUE
				Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
			On PAM_clsPB_OKACTION
				If SalIsNull( dfFileName )
					Call SalMessageBox( 'Please enter a file name first!', 'Warning', MB_Ok )
				Else
					Set sCSVFileName = dfFileName
					If cbSelectedRows
						Set nCSVFileHandling = TBL_cls_RowsSelected
					Else
						Set nCSVFileHandling = TBL_cls_NoRowsSelected
					If cbSelectedColumns
						Set nCSVFileHandling = nCSVFileHandling | TBL_cls_ColumnsSelected
					Else
						Set nCSVFileHandling = nCSVFileHandling | TBL_cls_NoColumnsSelected
					!
					If rbCreate
						Set nCSVFileHandling = nCSVFileHandling | TBL_cls_CreateOverwrite
					Else If rbAppendEnd
						Set nCSVFileHandling = nCSVFileHandling | TBL_cls_AppendRows
					Else
						Set nCSVFileHandling = nCSVFileHandling | TBL_cls_AppendColumns
					!
					Call SalSendMsg( pbExit, SAM_Click, TRUE, 0 )

				Description: This should be type of column used with clsTableGeneral.
				Derived From
				Class Variables
					String: sTmp
					Number: nTmp
				Instance Variables
					Boolean: bOrderBy
				Functions
				List Values
				Message Actions
					On SAM_Create
						Set bOrderBy = FALSE
						Call SalSendMsg( hWndItem, PAM_cls_SETINSTANCEVARS, 0, 0 )
						! If NOT SalGetWindowState( hWndItem ) = Window_NotVisible
						Set sTmp = OurGetIniFileParameter( 'GENERAL', GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndItem )||'.Width', '' )
						If NOT sTmp = ''
							Set nTmp = SalStrToNumber( sTmp )
							If nTmp > 0
								Call SalTblSetColumnWidth( hWndItem, nTmp )
					On SAM_Click
						Return SalPostMsg( hWndItem, PAM_clsTBL_CHECKEDIT, wParam, lParam )
					On SAM_SetFocus
						Call SalPostMsg( hWndItem, PAM_clsTBL_CHECKEDIT, wParam, lParam )
					On PAM_clsTBL_CHECKEDIT
						If SalSendMsg( hWndItem, PAM_clsTBL_EDITCHECK, wParam, lParam )
							Return TRUE
						Else
							Call SalTblKillEdit( hWndForm )
							Return FALSE
					On PAM_clsTBL_EDITCHECK
						Return TRUE
					On PAM_clsTBL_DATAVAL
						Return TRUE
					On PAM_clsTBL_CHECKROWNEW
						Return TRUE
					On PAM_clsTBL_CHECKROWEDITED
						Return TRUE
					On PAM_clsTBL_CHECKROWDELETED
						Return TRUE
					On PAM_clsTBL_ENABLECHILDSELECTPB
						Return TRUE
					!
					On PAM_clsTBL_SETCOLUMNCOLOR
						! wParam = back ground color
						! lParam = text color
						If wParam != 0
							Call SalColorSet( hWndItem, COLOR_IndexWindow, wParam )
						If lParam != 0
							Call SalColorSet( hWndItem, COLOR_IndexCellText, lParam )
						Return TRUE
					!
					On PAM_clsTBL_ORDERBYCOLUMN
						If bOrderBy
							Return TRUE
						Else
							Return FALSE
					! On PAM_clsTBL_PASSVALUE
						                        Set MyValue = wParam
					! On PAM_clsTBL_SUMVALUE
						                        Return MyValue
					On SAM_CaptionDoubleClick
						Call SalTblQueryColumnWidth( hWndItem, nTmp )
						Call SalTblGetColumnTitle( hWndItem, sTmp, 60 )
						Call OurSetIniFileParameter( 'GENERAL', GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndItem )||'.Width', SalNumberToStrX( nTmp, 4 ) )
						Call SalMessageBox( 'Default width for this column is now set.', sTmp, MB_Ok )
			Column Class: clsColDropListGeneral
				Title:
				Visible? Class Default
				Editable? Class Default
				Maximum Data Length: Class Default
				Data Type: Class Default
				Justify: Class Default
				Width:  Class Default
				Width Editable? Class Default

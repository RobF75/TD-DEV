				Class DLL Name:
.end
				                          Description: 
				                          Derived From 
				                          Contents 
				                          Class Variables 
					                          Number: nInd
				                          Instance Variables 
					! PUBLIC
					! sPopulateType = 'STOREDCOMMAND' OR 'SQLSTATEMENT'
							  'STOREDCOMMAND' = sSQLPopHandle, sNAMEPopHandle, sBINDPopHandle, sINTOPopHandle are used.
							  'SQLSTATEMENT' = only sSQLPopHandle is used as the sql statement
					                          String: sPopulateType
					!
					                          String: sSQLPopHandle
					                          String: sNAMEPopHandle
					                          String: sBINDPopHandle
					                          String: sINTOPopHandle
					!
					! PRIVATE
					                          : hSqlPopHandle
					                          Number: nTableTotalRows
				                          Functions 
				                          Message Actions 
					                          On SAM_Create
						                          Set sPopulateType = 'STOREDCOMMAND'
						                          Set sSQLPopHandle = ''
						                          Set sNAMEPopHandle = ''
						                          Set sBINDPopHandle = ''
						                          Set sINTOPopHandle = ''
						                          Return SalSendMsg( hWndForm, PAM_cls_SETINSTANCEVARS, 0, 0 ) 
					                          On SAM_CreateComplete
						                          If sPopulateType = 'STOREDCOMMAND'
							                          If hSqlPopHandle.Setup( sSQLPopHandle, sNAMEPopHandle, sBINDPopHandle, sINTOPopHandle )
								                          Return TRUE
							                          Else 
								                          Return FALSE
						                          Else 
							                          If hSqlPopHandle.PrepareSetup( sSQLPopHandle )
								                          Return TRUE
							                          Else 
								                          Return FALSE
					                          On PAM_clsTBL_POPULATE
						                          Set nTableTotalRows = NUMBER_Null
						! wParam = TRUE then reprepare and first.  Used for queries
						                          If wParam
							                          Call hSqlPopHandle.RePrepare( )
						                          If sPopulateType = 'STOREDCOMMAND'
							                          If hSqlPopHandle.Execute( )
								                          Call SalTblReset( hWndForm )
								                          Return SalTblSetRange( hWndForm, 0, 50 )
							                          Else 
								                          Return FALSE
						                          Else 
							                          If hSqlPopHandle.PrepareAndExecute( )
								                          Call SalTblReset( hWndForm )
								                          Return SalTblSetRange( hWndForm, 0, 50 )
							                          Else 
								                          Return FALSE
					                          On PAM_clsTBL_RESET
						                          If SalTblReset( hWndForm )
							                          Set nTableTotalRows = NUMBER_Null
							                          Return TRUE
						                          Else 
							                          Return FALSE
					                          On SAM_FetchRow
						                          If hSqlPopHandle.FetchRow( lParam, nInd )
							                          Return TBL_RowFetched
						                          Else 
							                          Return TBL_NoMoreRows
					                          On SAM_CountRows
						                          If nTableTotalRows = NUMBER_Null
							                          Call hSqlPopHandle.ResultSetCount( nTableTotalRows )
						                          Return nTableTotalRows
					                          On SAM_Destroy
						                          Call hSqlPopHandle.Disconnect( )

.head 2 +  Message Actions
.head 3 +  On SAM_CreateComplete
.head 4 -  Set dfBalance = 20
.head 4 -  Call SalSendMsg( cbLessThan, PAM_clsCB_SET, TRUE, 0 )
.head 4 -  Call SalSendMsg( cbEqualTo, PAM_clsCB_SET, TRUE, 0 )
.head 4 -  Call SalSendMsg( cbGreaterThan, PAM_clsCB_SET, FALSE, 0 )
.head 4 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 3 +  On PAM_clsPB_OKACTION
.head 4 +  If SalIsNull( dfBalance )
.head 5 -  Call SalMessageBox( 'Please enter a balance first!', 'Warning', MB_Ok )
.head 4 +  Else
.head 5 -  Call PushNumber( dfBalance )
.head 5 -  Set sSymbol = ''
.head 5 +  If cbLessThan
.head 6 -  Set sSymbol = '<'
.head 5 +  Else If cbGreaterThan
.head 6 -  Set sSymbol = '>'
.head 5 +  If cbEqualTo
.head 6 -  Set sSymbol = sSymbol || '='
.head 5 -  Call PushString( sSymbol )
.head 5 -  Return SalSendMsg( pbExit, SAM_Click, TRUE, 0 )

.head 4 +  Functions
.head 5 +  Function: GetCultivarTreesInvoicedSince
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  String: sCultId
.head 7 -  Date/Time: dtSince
.head 7 -  Receive Number: nInvoiced
.head 7 -  Number: nActionType
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  String: sBind
.head 7 -  String: sInto
.head 7 -  String: sName
.head 7 -  Number: nOurHandleNo
.head 7 -  !
.head 7 -  Number: nGotInvoiced
.head 7 -  Number: nInd
.head 6 +  Actions
.head 7 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetCultivarTreesInvoicedSince' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = " SELECT 
  SUM( Customer_Order.Conf_Amt )
FROM 
  Customer_Order, 
  Customer_Master, 
  Stock_Item 
WHERE 
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
  ( 
    NOT Customer_Master.Customer_Type LIKE '%OR%' AND 
    NOT Customer_Master.Customer_Type IN ( 'DED', 'DPI', 'HOB', 'NUT' ) 
  ) AND 
  Stock_Item.Cultivar_Id = :1 AND 
  Customer_Order.Invoiced_Flag = 'Y' AND 
  Customer_Order.Invoiced_Date >= :2
UNION ALL 
SELECT 
  SUM( Cust_Order_History.Conf_Amt )
FROM 
  Cust_Order_History, 
  Customer_Master, 
  Stock_Item 
WHERE 
  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
  Cust_Order_History.Cust_No = Customer_Master.Cust_No AND 
  ( 
    NOT Customer_Master.Customer_Type LIKE '%OR%' AND 
    NOT Customer_Master.Customer_Type IN ( 'DED', 'DPI', 'HOB', 'NUT' ) 
  ) AND 
  Stock_Item.Cultivar_Id = :1 AND 
  Cust_Order_History.Invoiced_Flag = 'Y' AND 
  Cust_Order_History.Invoiced_Date >= :2 "
.head 9 -  Set sName = 'GCLTLBINVSNC2'
.head 9 -  Set sBind = ':sCultId, :dtSince'
.head 9 -  Set sInto = ':nGotInvoiced'
.head 9 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 9 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 -  Set nInvoiced = NUMBER_Null
.head 9 -  Set nGotInvoiced = NUMBER_Null
.head 9 -  !
.head 9 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 10 +  While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 11 -  Set nInvoiced = nInvoiced + nGotInvoiced
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 5 +  Function: CalcCultivarTreesTotalAvailable
.head 6 -  Description: Modified by Graham 24-8-98 to get future actual growing for
sale figures not just future available.
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  String: sCultId
.head 7 -  Number: nYear
.head 7 -  Receive Number: nTotalAvailable
.head 7 -  Number: nActionType
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  String: sBind
.head 7 -  String: sInto
.head 7 -  String: sName
.head 7 -  Number: nOurHandleNo
.head 7 -  !
.head 7 -  Number: nItemNo
.head 7 -  String: sStockType
.head 7 -  Number: nGotCurrAvailable
.head 7 -  Number: nGotFutAvailable
.head 7 -  Number: nInd
.head 7 -  Boolean: bOk
.head 7 -  ! New bits Graham 24-8-98
.head 7 -  Number: nGotAmtGrowing
.head 7 -  Number: nGotForwardOrds
.head 7 -  Number: naGotGrowSaleLoc[*]
.head 7 -  Number: naGotInvFutBatchLoc[*]
.head 7 -  Number: nFutureOrds
.head 7 -  Number: nForwardOrds
.head 6 +  Actions
.head 7 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'CalcCultivarTreesTotalAvailable' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = " SELECT 
  Item_No, 
  Stock_Type 
FROM 
  Stock_Item 
WHERE 
  Cultivar_Id = :1 "
.head 9 -  Set sName = 'GCLTITMNUM2'
.head 9 -  Set sBind = ':sCultId'
.head 9 -  Set sInto = ':nItemNo, :sStockType'
.head 9 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 9 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 -  Set nTotalAvailable = NUMBER_Null
.head 9 -  Set nItemNo = NUMBER_Null
.head 9 -  Set sStockType = ''
.head 9 -  Set nGotCurrAvailable = NUMBER_Null
.head 9 -  Set nGotFutAvailable = NUMBER_Null
.head 9 -  !
.head 9 +  If haSqlHandles[ nOurHandleNo ].Execute( )

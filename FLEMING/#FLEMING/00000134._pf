.head 3 +  On SAM_Create
.head 4 -  Call SalHideWindow( hWndForm )
.head 3 +  On PAM_clsTBL_INITIALISE
.head 4 -  Call OurWaitCursor( TRUE )
.head 4 -  Call SalTblReset( hWndForm )
.head 4 -  Set nRow = TBL_MinRow
.head 4 +  While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
.head 5 -  Call SalTblFetchRow( hWndTable, nRow )
.head 5 -  Set nNewRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
.head 5 -  Call SalTblSetContext( hWndForm, nNewRow )
.head 5 -  Call SalFmtFieldToStr( hWndPkCol1, colPk1, FALSE )
.head 5 -  Call SalFmtFieldToStr( hWndPkCol2, colPk2, FALSE )
.head 5 -  Call SalFmtFieldToStr( hWndPkCol3, colPk3, FALSE )
.head 4 -  Call OurWaitCursor( FALSE )
.head 3 +  On PAM_clsTBL_LOOKUP
.head 4 -  Call OurWaitCursor( TRUE )
.head 4 -  Set bFound = FALSE
.head 4 -  Set nRow = TBL_MinRow
.head 4 +  While SalTblFindNextRow( hWndForm, nRow, ROW_New, 0 ) AND NOT bFound
.head 5 -  Call SalTblFetchRow( hWndForm, nRow )
.head 5 -  Call SalFmtFieldToStr( hWndPkCol1, sCompCol1, FALSE )
.head 5 -  Call SalFmtFieldToStr( hWndPkCol2, sCompCol2, FALSE )
.head 5 -  Call SalFmtFieldToStr( hWndPkCol3, sCompCol3, FALSE )
.head 5 +  If sCompCol1 = colPk1 AND sCompCol2 = colPk2 AND sCompCol3 = colPk3
.head 6 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_New, FALSE )
.head 6 -  Set bFound = TRUE
.head 4 -  Call OurWaitCursor( FALSE )
.head 4 -  Return bFound

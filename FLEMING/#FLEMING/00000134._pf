.head 4 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 3 +  On PAM_clsPB_OKACTION
.head 4 +  If SalIsNull( dfFileName )
.head 5 -  Call SalMessageBox( 'Please enter a file name first!', 'Warning', MB_Ok )
.head 4 +  Else
.head 5 -  Set sCSVFileName = dfFileName
.head 5 +  If cbSelectedRows
.head 6 -  Set nCSVFileHandling = TBL_cls_RowsSelected
.head 5 +  Else
.head 6 -  Set nCSVFileHandling = TBL_cls_NoRowsSelected
.head 5 +  If cbSelectedColumns
.head 6 -  Set nCSVFileHandling = nCSVFileHandling | TBL_cls_ColumnsSelected
.head 5 +  Else
.head 6 -  Set nCSVFileHandling = nCSVFileHandling | TBL_cls_NoColumnsSelected
.head 5 -  !
.head 5 +  If rbCreate
.head 6 -  Set nCSVFileHandling = nCSVFileHandling | TBL_cls_CreateOverwrite
.head 5 +  Else If rbAppendEnd
.head 6 -  Set nCSVFileHandling = nCSVFileHandling | TBL_cls_AppendRows
.head 5 +  Else
.head 6 -  Set nCSVFileHandling = nCSVFileHandling | TBL_cls_AppendColumns
.head 5 -  !
.head 5 -  Call SalSendMsg( pbExit, SAM_Click, TRUE, 0 )

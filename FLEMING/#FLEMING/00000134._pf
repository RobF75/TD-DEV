.head 5 -    : hSqlPopHandle
.head 5 -    Number: nTableTotalRows
.head 4 -    Functions 
.head 4 +    Message Actions 
.head 5 +    On SAM_Create
.head 6 -    Set sPopulateType = 'STOREDCOMMAND'
.head 6 -    Set sSQLPopHandle = ''
.head 6 -    Set sNAMEPopHandle = ''
.head 6 -    Set sBINDPopHandle = ''
.head 6 -    Set sINTOPopHandle = ''
.head 6 -    Return SalSendMsg( hWndForm, PAM_cls_SETINSTANCEVARS, 0, 0 ) 
.head 5 +    On SAM_CreateComplete
.head 6 +    If sPopulateType = 'STOREDCOMMAND'
.head 7 +    If hSqlPopHandle.Setup( sSQLPopHandle, sNAMEPopHandle, sBINDPopHandle, sINTOPopHandle )
.head 8 -    Return TRUE
.head 7 +    Else 
.head 8 -    Return FALSE
.head 6 +    Else 
.head 7 +    If hSqlPopHandle.PrepareSetup( sSQLPopHandle )
.head 8 -    Return TRUE
.head 7 +    Else 
.head 8 -    Return FALSE
.head 5 +    On PAM_clsTBL_POPULATE
.head 6 -    Set nTableTotalRows = NUMBER_Null
.head 6 -  ! wParam = TRUE then reprepare and first.  Used for queries
.head 6 +    If wParam
.head 7 -    Call hSqlPopHandle.RePrepare( )
.head 6 +    If sPopulateType = 'STOREDCOMMAND'
.head 7 +    If hSqlPopHandle.Execute( )
.head 8 -    Call SalTblReset( hWndForm )
.head 8 -    Return SalTblSetRange( hWndForm, 0, 50 )
.head 7 +    Else 
.head 8 -    Return FALSE
.head 6 +    Else 
.head 7 +    If hSqlPopHandle.PrepareAndExecute( )
.head 8 -    Call SalTblReset( hWndForm )
.head 8 -    Return SalTblSetRange( hWndForm, 0, 50 )
.head 7 +    Else 
.head 8 -    Return FALSE
.head 5 +    On PAM_clsTBL_RESET
.head 6 +    If SalTblReset( hWndForm )
.head 7 -    Set nTableTotalRows = NUMBER_Null
.head 7 -    Return TRUE
.head 6 +    Else 
.head 7 -    Return FALSE
.head 5 +    On SAM_FetchRow
.head 6 +    If hSqlPopHandle.FetchRow( lParam, nInd )
.head 7 -    Return TBL_RowFetched
.head 6 +    Else 
.head 7 -    Return TBL_NoMoreRows
.head 5 +    On SAM_CountRows
.head 6 +    If nTableTotalRows = NUMBER_Null
.head 7 -    Call hSqlPopHandle.ResultSetCount( nTableTotalRows )
.head 6 -    Return nTableTotalRows
.head 5 +    On SAM_Destroy
.head 6 -    Call hSqlPopHandle.Disconnect( )

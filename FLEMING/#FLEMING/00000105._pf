						!
						Set sSQLInsertHandle = ' INSERT INTO Rootstock 
								( Root_Id,
								  PVR_No,
								  Root_desc,
								  Rt_Vfree_Flag,
								  Rt_Not_sale_Flag,
								  Bud_disc_perc,

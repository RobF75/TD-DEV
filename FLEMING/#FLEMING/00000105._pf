						Actions
							Set sRootId = sNewRootId
							Return TRUE
				Message Actions
					On SAM_Create
						Set sRootId = ''
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbRootDetNewRec.nActivateWindowType = ACTIVATE_FormWindow
						Set clspbRootDetNewRec.sActivateDialogName = 'frmRootDetails'
					On PAM_clsFRMDETS_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushString( sRootId )
						Return TRUE

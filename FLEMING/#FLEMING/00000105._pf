				Class Variables
				Instance Variables
					Boolean: bExists
					String: sOldRootDesc
					String: sOldNonPropFlag
					String: sOldNotForSaleFlag
				Functions
					Function: ExtractRootDenomEffectedDetails
						Description:
						Returns
							Boolean:
						Parameters
							String: sRootId
							Receive String: sRootDesc
							Receive String: sNonPropFlag
							Receive String: sNotForSaleFlag
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							!
							String: sGotRootDesc
							String: sGotNonPropFlag
							String: sGotNotForSaleFlag
							Number: nInd
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'DENOMRTDETS' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT 
											  Root_Desc, 
											  RT_Non_Prop_Flag, 
											  RT_Not_Sale_Flag 
											FROM 
											  Rootstock 
											WHERE 
											  Root_Id = :1 "
									Set sName = 'DENOMRTDETS'
									Set sBind = ':sRootId'
									Set sInto = ':sGotRootDesc, 
											:sGotNonPropFlag, 
											:sGotNotForSaleFlag'
									!
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set sRootDesc = ''
									Set sNonPropFlag = ''
									Set sNotForSaleFlag = ''
									!
									Set sGotRootDesc = ''
									Set sGotNonPropFlag = ''
									Set sGotNotForSaleFlag = ''
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
											Set sRootDesc = sGotRootDesc
											Set sNonPropFlag = sGotNonPropFlag
											Set sNotForSaleFlag = sGotNotForSaleFlag
										Return TRUE
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					Function: RootstockDenormalise
						Description:
						Returns
							Boolean:
						Parameters
							String: sRootId
							String: sRootDesc
							String: sNonPropFlag
							String: sNotForSaleFlag
							!
							String: sOldRootDesc
							String: sOldNonPropFlag
							String: sOldNotForSaleFlag
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SIDENOMRT' )
							Select Case nActionType
								Case SH_cls_Execute
									If sRootDesc != sOldRootDesc OR 
											   sNonPropFlag != sOldNonPropFlag OR 
											   sNotForSaleFlag != sOldNotForSaleFlag
										Set sSql = " UPDATE Stock_Item 
												SET 
												  Root_Desc = :2, 
												  RT_Non_Prop_Flag = :3, 
												  RT_Not_Sale_Flag = :4 
												WHERE 
												  Rootstock_Id = :1 "
										Set sName = 'SIDENOMRT'
										Set sBind = ':sRootId, 
												:sRootDesc, 
												:sNonPropFlag, 
												:sNotForSaleFlag'
										Set sInto = ''
										Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
										Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
										!
										If haSqlHandles[ nOurHandleNo ].Execute( )
											Call haSqlHandles[ nOurHandleNo ].Commit( )
											Return TRUE
										Else
											Return FALSE
									Else
										Return TRUE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
										Set bOk = FALSE
					Function: ExistsStockItemRootId
						Description:
						Returns
							Boolean:
						Parameters
							String: sRootId
							Receive Boolean: bExists
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							!
							Number: nInd
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'EXISTSSIRTID' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT Rootstock_Id
											FROM Stock_Item 
											WHERE Rootstock_Id = :1"
									Set sName = 'EXISTSSIRTID'
									Set sBind = ':sRootId'
									Set sInto = ''
									!
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set bExists = FALSE
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
											Set bExists = TRUE
										Return TRUE
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )

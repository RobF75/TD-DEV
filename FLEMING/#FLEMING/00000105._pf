				 Message Actions 
					 On PAM_clsFRMDETS_DATAVAL
						 If SalIsNull( hWndItem )
							 Call SalMessageBox( 'Plase enter a Rootstock Id First!', 'Warning', MB_Ok )
							 Call SalSetFocus( hWndItem )
							 Return FALSE
						 Else 
							 Return TRUE
					 On PAM_clsFRMDETS_CHECKROWNEW
						 Call ExistsRootId( dfRootId, bExists, SH_cls_Execute )
						 If bExists
							 Call SalMessageBox( 'This Rootstock ID already exists! Please change the ID first.', 'Warning', MB_Ok )
							 Return FALSE
						 Else 
							 Return TRUE
					 On PAM_clsFRMDETS_CHECKROWDELETED
						 Call ExistsStockItemRootId( dfRootId, bExists, SH_cls_Execute )
						 If bExists
							 Call SalMessageBox( 'This Rootstock ID is still used as a stock item! Please delete the stock items first.', 'Warning', MB_Ok )
							 Return FALSE
						 Else 
							 Return TRUE
					 On PAM_clsFRMDETS_CHECKROWEDITED
						 Return ExtractRootDenomEffectedDetails( dfRootId, sOldRootDesc, sOldNonPropFlag, sOldNotForSaleFlag, SH_cls_Execute )
					 On PAM_clsFRMDETS_ROWUPDATED
						 Return RootstockDenormalise( dfRootId, dfRootDesc, cbNonPropFlag.sFlagValue, cbNotSaleFlag.sFlagValue, 
								sOldRootDesc, sOldNonPropFlag, sOldNotForSaleFlag, SH_cls_Execute )
					 On PAM_clsFRMDETS_NEWPREC
						 Return SalSendMsg( hWndItem, PAM_clsDF_ENABLE, 0, 0 )
					 On PAM_clsFRMDETS_DISPREC
						 Return SalSendMsg( hWndItem, PAM_clsDF_DISABLE, 0, 0 )
			 Data Field: dfRootDesc

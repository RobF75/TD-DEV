								  :hWndForm.clsfrmRootDetails.dfLL5OffSet,
								  :hWndForm.clsfrmRootDetails.dfFirstSaleDate,
								  :hWndForm.clsfrmRootDetails.cbOnTrialFlag.sFlagValue'
						Set sINTOUpdateHandle = ''
						!
						Set sSQLDeleteHandle = 'DELETE FROM Rootstock 
								WHERE 
								  Root_Id = :1 '
						Set sNAMEDeleteHandle = 'DELROOTDETS'
						Set sBINDDeleteHandle = ':hWndForm.clsfrmRootDetails.dfRootId'
						Set sINTODeleteHandle = ''
						!
						Set bFirstRecAllowed = TRUE
						Set bPrevRecAllowed = TRUE
						Set bNextRecAllowed = TRUE
						Set bLastRecAllowed = TRUE
						!
						Set bMapEnterToTab = TRUE
					On PAM_clsFRMDETS_POPFIELDS
						Call PopString( dfRootId, TRUE )
						Return TRUE
					On PAM_clsFRMDETS_SAVE
						If SalTblAnyRows( tblPaintCodes, ROW_Edited|ROW_New|ROW_MarkDeleted, 0 )
							Set bEdit = TRUE
						Call SalSendClassMessage( PAM_clsFRMDETS_SAVE, wParam, lParam )
						Call SalSendMsg( pbSavePaintCodes, SAM_Click, 0, 0 )
						Return TRUE
					On PAM_clsFRMDETS_CHECKCHANGES
						If SalTblAnyRows( tblPaintCodes, ROW_Edited|ROW_New|ROW_MarkDeleted, 0 )
							Set bEdit = TRUE
						Return SalSendClassMessage( PAM_clsFRMDETS_CHECKCHANGES, wParam, lParam )
					On SAM_Destroy
						Call ExistsRootId( '', bExists, SH_cls_Disconnect )
						Call ExistsStockItemRootId( '', bExists, SH_cls_Disconnect )
						Call ExtractRootDenomEffectedDetails( '', sOldRootDesc, sOldNonPropFlag, sOldNotForSaleFlag, SH_cls_Disconnect )
						Call RootstockDenormalise( '', '', '', '', '', '', '', SH_cls_Disconnect )
						Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

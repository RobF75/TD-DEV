						Functions
						Window Variables
							Number: nLastPaintNum
						Message Actions
							On PAM_cls_SETINSTANCEVARS
								Set sSQLPopHandle = ' SELECT 
										  Rtstck_Paint_Used.RT_Year_Used, 
										  Rtstck_Paint_Used.Paint_Id, 
										  Rtstck_Paint_Used.RT_Paint_Number, 
										  Paint_Master.Paint_Desc 
										FROM 
										  Rtstck_Paint_Used, 
										  Paint_Master 
										WHERE 
										  Rtstck_Paint_Used.Rootstock_Id = :1 AND 
										  Rtstck_Paint_Used.Paint_Id = Paint_Master.Paint_Id
										ORDER BY 
										  Rtstck_Paint_Used.RT_Year_Used DESC, 
										  Rtstck_Paint_Used.RT_Paint_Number '
								Set sNAMEPopHandle = 'ROOTPNTUSED'
								Set sBINDPopHandle = ':hWndParent.dfRootId'
								Set sINTOPopHandle = ':clsfrmRootDetails.tblPaintCodes.colYear, 
										:clsfrmRootDetails.tblPaintCodes.colPaintId, 
										:clsfrmRootDetails.tblPaintCodes.colPaintNum, 
										:clsfrmRootDetails.tblPaintCodes.colPaintDesc'
								!
								Set sSQLRefreshHandle = ' SELECT 
										  Rtstck_Paint_Used.RT_Year_Used, 
										  Rtstck_Paint_Used.Paint_Id, 
										  Rtstck_Paint_Used.RT_Paint_Number, 
										  Paint_Master.Paint_Desc 
										FROM 
										  Rtstck_Paint_Used, 
										  Paint_Master 
										WHERE 
										  Rtstck_Paint_Used.Rootstock_Id = :1 AND 
										  Rtstck_Paint_Used.RT_Year_Used = :2 AND 
										  Rtstck_Paint_Used.RT_Paint_Number = :3 AND 
										  Rtstck_Paint_Used.Paint_Id = Paint_Master.Paint_Id '
								Set sNAMERefreshHandle = 'REFRTPUSD'
								Set sBINDRefreshHandle = ':hWndParent.dfRootId, 
										:clsfrmRootDetails.tblPaintCodes.colYear, 
										:clsfrmRootDetails.tblPaintCodes.colPaintNum'
								Set sINTORefreshHandle = ':clsfrmRootDetails.tblPaintCodes.colYear, 
										:clsfrmRootDetails.tblPaintCodes.colPaintId, 
										:clsfrmRootDetails.tblPaintCodes.colPaintNum, 
										:clsfrmRootDetails.tblPaintCodes.colPaintDesc'
								!
								Set sSQLInsertHandle = ' INSERT INTO Rtstck_Paint_Used 
										  ( Rootstock_Id, 
										    RT_Year_Used, 
										    RT_Paint_Number, 
										    Paint_Id ) 
										  VALUES
										  ( :1, :2, :3, :4 ) '
								Set sNAMEInsertHandle = 'INSRTPUSD'
								Set sBINDInsertHandle = ':hWndParent.dfRootId, 
										:clsfrmRootDetails.tblPaintCodes.colYear, 
										:clsfrmRootDetails.tblPaintCodes.colPaintNum, 
										:clsfrmRootDetails.tblPaintCodes.colPaintId'
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ' UPDATE Rtstck_Paint_Used 
										  SET 
										    Paint_Id = :4 
										  WHERE 
										    Rtstck_Paint_Used.Rootstock_Id = :1 AND 
										    Rtstck_Paint_Used.RT_Year_Used = :2 AND 
										    Rtstck_Paint_Used.RT_Paint_Number = :3 '
								Set sNAMEUpdateHandle = 'UPDTRTPUSD'
								Set sBINDUpdateHandle = ':hWndParent.dfRootId, 
										:clsfrmRootDetails.tblPaintCodes.colYear, 
										:clsfrmRootDetails.tblPaintCodes.colPaintNum, 
										:clsfrmRootDetails.tblPaintCodes.colPaintId'
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = ' DELETE FROM Rtstck_Paint_Used 
										  WHERE 
										    Rtstck_Paint_Used.Rootstock_Id = :1 AND 
										    Rtstck_Paint_Used.RT_Year_Used = :2 AND 
										    Rtstck_Paint_Used.RT_Paint_Number = :3 '
								Set sNAMEDeleteHandle = 'DELRTPUSD'
								Set sBINDDeleteHandle = ':hWndParent.dfRootId, 
										:clsfrmRootDetails.tblPaintCodes.colYear, 
										:clsfrmRootDetails.tblPaintCodes.colPaintNum'
								Set sINTODeleteHandle = ''
								!
								Set bAddAllowed = TRUE
								Set bSaveAllowed = TRUE
								Set bDeleteAllowed = TRUE
								Set bUnDeleteAllowed = TRUE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								Set bQueryAllowed = FALSE
								Set bReportAllowed = FALSE
								Set bOrderAllowed = FALSE
								!
								Set bGetSaveConfirmation = FALSE
								!
								Set sTableHeading = 'Rootstock Paint Codes'
								Set bSelectFirstRow = FALSE
								Set hWndRowNewColumn = colYear
								!
								Set nLastPaintNum = 0
							On PAM_clsTBL_NOROWS
								Return TRUE
							On PAM_clsTBL_POPULATE
								Set nLastPaintNum = 0
								Return SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
							On SAM_FetchRowDone
								If colPaintNum > nLastPaintNum
									Set nLastPaintNum = colPaintNum
								Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
							On PAM_clsFRMDETS_DISPREC
								Return SalSendMsg( hWndForm, PAM_clsTBL_POPULATE, 0, 0 )
							On PAM_clsFRMDETS_NEWPREC
								Return SalSendMsg( hWndForm, PAM_clsTBL_RESET, 0, 0 )
							! On PAM_clsPICK_LOOKUP
								 Call PopString( colPaintDesc, TRUE )
								 Call PopString( colPaintId, TRUE )
								 Set colYear = OurDateYear( SalDateCurrent(  ) )
								 Call SalSetFieldEdit( colYear, TRUE )
								 Return TRUE
							On PAM_clsTBL_WRITEINSERTSUPDATES
								Return SalSendClassMessage( PAM_clsTBL_WRITEINSERTSUPDATES, wParam, lParam )
					!

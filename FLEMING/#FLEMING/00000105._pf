					 On PAM_cls_GETFIELDS
						 Call pbPickPaintCodes.GetPaintMasterFields( tblPaintCodes.colPaintId, tblPaintCodes.colPaintDesc  )
						 Set tblPaintCodes.colYear = ccSeasonYear.GetSeasonYear( )
						 Call SalSetFieldEdit( tblPaintCodes.colYear, TRUE )
						 Return TRUE
					 On PAM_cls_SETFIELDS
						 Call pbPickPaintCodes.SetPaintMasterFields( tblPaintCodes.colPaintId, tblPaintCodes.colPaintDesc  )
						 Return TRUE

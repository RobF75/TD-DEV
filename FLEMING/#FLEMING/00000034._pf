.head 4 -     Functions 
.head 4 +     Message Actions 
.head 5 +     On SAM_Create
.head 6 -     Set nTimerNo = 1
.head 6 -     Set nCount = 0
.head 6 -     Set nPulseWidth = 0.02
.head 6 -     Set nPulseHeight = 0.02
.head 6 -     Set nDelay = 500
.head 6 -     Call SalSendClassMessage( SAM_Create, wParam, lParam )
.head 6 -     Call SalGetWindowSize( hWndItem, nOrgWidth, nOrgHeight )
.head 6 -     Call SalGetWindowLoc( hWndItem, nOrgLocX, nOrgLocY )
.head 5 +     On SAM_Timer
.head 6 -     Set nCount = nCount + 1
.head 6 +     Select Case nCount
.head 7 +     Case 1
.head 8 -     Call SalSetWindowLoc( hWndItem, nOrgLocX, nOrgLocY )
.head 8 -     Call SalSetWindowSize( hWndItem, nOrgWidth, nOrgHeight )
.head 8 -     Break 
.head 7 +     Case 2
.head 8 -     Call SalSetWindowLoc( hWndItem, nOrgLocX - nPulseWidth / 2, nOrgLocY - nPulseHeight / 2 )
.head 8 -     Call SalSetWindowSize( hWndItem, nOrgWidth + nPulseWidth, nOrgHeight + nPulseHeight )
.head 8 -     Set nCount = 0
.head 8 -     Break 
.head 7 +     Default 
.head 8 -     Set nCount = 0
.head 5 +     On SAM_SetFocus
.head 6 -     Call SalTimerSet( hWndItem, nTimerNo, nDelay )
.head 5 +     On SAM_KillFocus
.head 6 -     Call SalTimerKill( hWndItem, nTimerNo )

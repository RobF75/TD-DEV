.head 4 +  Message Actions
.head 5 +  On PAM_clsPB_CLICK
.head 6 +  If ccSeasonYear.GetSeasonYear( ) = WhichSeasonYear( SalDateCurrent(  ) )
.head 7 +  If IDCANCEL = SalMessageBox( 'YOU WANT TO ROLL THE CURRENT SEASON!', 'Huhhhh..', MB_OkCancel | MB_DefButton2 )
.head 8 -  Return FALSE
.head 6 +  If IDYES = SalMessageBox( 'The season showing is the rolling over season?', 'Warning', MB_YesNo | MB_DefButton2 )
.head 7 +  If IDNO = SalMessageBox( 'Will anyone invoice any orders in the rolling season?', 'Warning', MB_YesNo | MB_DefButton1 )
.head 8 +  If IDYES = SalMessageBox( 'The database server has heaps of room for log files?', 'Warning', MB_YesNo | MB_DefButton2 )
.head 9 +  If IDYES = SalMessageBox( 'Final chance!  Continue?', 'Warning', MB_YesNo | MB_DefButton2 )
.head 10 -  Call SalListAdd( lbStatus, 'Action 1 of 5, Connecting to database.' )
.head 10 -  Call SalUpdateWindow( hWndForm )
.head 10 -  !
.head 10 -  Set sYear = SalNumberToStrX( ccSeasonYear.GetSeasonYear( ), 0 )
.head 10 -  Call GetTableFields( 'CUSTOMER_ORDER', sCustOrderColumns, SH_cls_Execute )
.head 10 -  !
.head 10 -  Set sSql = " INSERT INTO CUST_ORDER_HISTORY 
  ( " || sCustOrderColumns || " ) 
 SELECT " || sCustOrderColumns || " FROM  
    CUSTOMER_ORDER  
  WHERE  
    Year_of_Sale = " || sYear || " AND 
    Invoiced_Flag = 'Y' "
.head 10 -  Call fcCopyHdl.PrepareSetup( sSql )
.head 10 -  !
.head 10 -  Set sSql = " DELETE FROM Customer_Order 
WHERE 
  Year_of_sale = " || sYear || " AND 
  Invoiced_flag = 'Y' "
.head 10 -  Call fcDeleteHdl.PrepareSetup( sSql )
.head 10 -  !
.head 10 -  Call SalListAdd( lbStatus, 'Action 2 of 5, Copying invoiced orders to order history.' )
.head 10 -  Call SalUpdateWindow( hWndForm )
.head 10 -  Set bOk = TRUE
.head 10 +  If fcCopyHdl.PrepareAndExecute( )
.head 11 -  Call SalListAdd( lbStatus, 'Action 3 of 5, Deleting invoiced orders.' )
.head 11 -  Call SalUpdateWindow( hWndForm )
.head 11 +  If fcDeleteHdl.PrepareAndExecute( )
.head 12 -  Call SalListAdd( lbStatus, 'Action 4 of 5, Commiting transaction.' )
.head 12 -  Call SalUpdateWindow( hWndForm )
.head 12 +  If NOT fcCopyHdl.Commit( )
.head 13 -  Set bOk = FALSE
.head 12 +  If NOT fcDeleteHdl.Commit( )
.head 13 -  Set bOk = FALSE
.head 11 +  Else
.head 12 -  Set bOk = FALSE
.head 12 -  Call SalListAdd( lbStatus, 'Action 3.1 of 5, Rolling back copy of invoiced orders.' )
.head 12 -  Call SalUpdateWindow( hWndForm )
.head 12 -  Call fcCopyHdl.Rollback( )
.head 10 +  Else
.head 11 -  Set bOk = FALSE
.head 10 -  !
.head 10 -  Call SalListAdd( lbStatus, 'Action 5 of 5, Disconnecting from database.' )
.head 10 -  Call SalUpdateWindow( hWndForm )
.head 10 -  Call fcCopyHdl.Disconnect( )
.head 10 -  Call fcDeleteHdl.Disconnect( )
.head 10 -  Call GetTableFields( '', sCustOrderColumns, SH_cls_Disconnect )
.head 10 -  !
.head 10 +  If bOk
.head 11 -  Call SalListAdd( lbStatus, 'Rolling over was a success!' )
.head 11 -  Call SalListAdd( lbStatus, 'Now a log backup is needed' )
.head 11 -  Call SalListAdd( lbStatus, 'Check the total size of logs generated and make changes to log backup path as needed.' )
.head 10 +  Else
.head 11 -  Call SalListAdd( lbStatus, 'Rolling over has not completed!' )
.head 11 -  Call SalListAdd( lbStatus, 'The database should be in a identical state as prior to rollover.' )
.head 10 -  Call SalUpdateWindow( hWndForm )
.head 10 -  Call SqlHandlesDisconnectClose(  )
.head 10 +  If cbExitOnFinish
.head 11 -  Return SalSendMsg( pbExit, SAM_Click, 0, 0 )

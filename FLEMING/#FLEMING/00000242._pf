.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETTBLCOLS' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sOrgUser = SqlUser
.head 7 -  Set sOrgPassword = SqlPassword
.head 7 -  !
.head 7 -  Set SqlUser = 'SYSADM'
.head 7 -  Set SqlPassword = 'DANI'
.head 7 -  !
.head 7 -  Set sSql = " SELECT NAME 
FROM SYSCOLUMNS 
WHERE 
  TBNAME = :1 
ORDER BY COLNO "
.head 7 -  Set sName = 'GETTBLCOLS'
.head 7 -  Set sBind = ':sTableName'
.head 7 -  Set sInto = ':sGotColumn'
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set sTableName = SalStrUpperX( sTableName )
.head 7 -  Set sGotColumn = ''
.head 7 -  Set sColumns = ''
.head 7 -  !
.head 7 -  Set bOk = TRUE
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 -  Set bFirst = TRUE
.head 8 +  While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 +  If bFirst
.head 10 -  Set bFirst = FALSE
.head 10 -  Set sColumns = sGotColumn
.head 9 +  Else
.head 10 -  Set sColumns = sColumns || ', ' || sGotColumn
.head 7 +  Else
.head 8 -  Set bOk = FALSE
.head 8 -  Return FALSE
.head 7 -  !
.head 7 -  Set SqlUser = sOrgUser
.head 7 -  Set SqlPassword = sOrgPassword
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )

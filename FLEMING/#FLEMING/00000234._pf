				Functions
				Window Variables
					String: sTmp
					Number: nTmp
					String: sItemNoList
					Number: nSelectedItemYear
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set bAddAllowed = TRUE
					On PAM_PTASSINV_GETSELECTEDITEMS
						Set sItemNoList = ''
						Set nSelectedItemYear = NUMBER_Null
						If TableLoop( hWndForm, hWndForm, PAM_PTASSINV_GETSELECTED, 0, 0, 0, 'Extracting Selected Items', TBL_cls_LowToHi )
							If hWndParent.ccSeasonYear.GetSeasonYear( ) != nSelectedItemYear
								Call SalMessageBox( 'Selected Items Year does not match report Year. Please match up first!', 'Warning', MB_Ok )
								Set sItemNoList = 'YEARMISMATCH'
							Call PushString( sItemNoList )
							Return TRUE
						Else
							Return FALSE
					On PAM_PTASSINV_GETSELECTED
						If SalStrLeftX( colTreeType, 1 ) = 'C'
							If sItemNoList = ''
								Set sItemNoList = SalNumberToStrX( colItemNo, 0 ) 
							Else
								Set sItemNoList = sItemNoList || ', ' || SalNumberToStrX( colItemNo, 0 ) 
						If nSelectedItemYear = NUMBER_Null
							Set nSelectedItemYear = colYear
						Return TRUE
			!

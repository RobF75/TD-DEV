						List Values
						Message Actions
				Functions
					Function: GetPotSizeCurrentCountNOrd
						Description:
						Returns
							Boolean:
						Parameters
							String: sTreeType
							Number: nYear
							Receive Number: nCurrCount
							Receive Number: nCurrOrd
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							!
							Number: nInd
							Number: nGotCount
							Number: nGotOrd
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetPotSizeCurrentCountNOrd' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT 
											  SUM( Growing_Sale.Second_Count ), 
											  SUM( Growing_Sale.Forward_Orders ) 
											FROM 
											  Growing_Sale, 
											  Stock_Item 
											WHERE 
											  Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
											  Stock_Item.Stock_Type = 'C' AND 
											  Stock_Item.Tree_Type = :1 AND 
											  Growing_Sale.Year_Of_Sale >= :2 AND 
											  ( Growing_Sale.Est_Sale_Date <= SYSDATE OR 
											    Growing_Sale.Est_Sale_Date IS NULL ) AND 
											  ( Growing_Sale.Not_For_Sale = 'N' OR 
											    Growing_Sale.Not_For_Sale IS NULL )"
									Set sName = 'GTPTSZCRDTS'
									Set sBind = ':sTreeType, :nYear'
									Set sInto = ':nGotCount, :nGotOrd'
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set nCurrCount = NUMBER_Null
									Set nGotCount = NUMBER_Null
									Set nCurrOrd = NUMBER_Null
									Set nGotOrd = NUMBER_Null
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
											Set nCurrCount = nGotCount
											Set nCurrOrd = nGotOrd
										Return TRUE
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					Function: GetPotSizeFutureCountNOrd
						Description:
						Returns
							Boolean:
						Parameters
							String: sTreeType
							Number: nYear
							Window Handle: hWndTable
							Number: nPAMTableMessage
							Number: nPAMTableMessageWParam
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							!
							Number: nInd
							Date/Time: dtGotEstSaleDate
							Number: nGotCount
							Number: nGotOrd
							Boolean: bOk
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetPotSizeFutureCountNOrd' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT 
											  Growing_Sale.Est_Sale_Date, 
											  SUM( Growing_Sale.Second_Count ), 
											  SUM( Growing_Sale.Forward_Orders ) 
											FROM 
											  Growing_Sale, 
											  Stock_Item 
											WHERE 
											  Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
											  Stock_Item.Stock_Type = 'C' AND 
											  Stock_Item.Tree_Type = :1 AND 
											  Growing_Sale.Year_Of_Sale >= :2 AND 
											  Growing_Sale.Est_Sale_Date > SYSDATE AND 
											  ( Growing_Sale.Not_For_Sale = 'N' OR 
											    Growing_Sale.Not_For_Sale IS NULL )
											GROUP BY 
											  Growing_Sale.Est_Sale_Date 
											ORDER BY 
											  Growing_Sale.Est_Sale_Date"
									Set sName = 'GTPTSZFTDTS'
									Set sBind = ':sTreeType, :nYear'
									Set sInto = ':dtGotEstSaleDate, :nGotCount, :nGotOrd'
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set dtGotEstSaleDate = DATETIME_Null
									Set nGotCount = NUMBER_Null
									Set nGotOrd = NUMBER_Null
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										Set bOk = TRUE
										While haSqlHandles[ nOurHandleNo ].FetchNext( nInd ) AND bOk
											Call PushDateTime( dtGotEstSaleDate )
											Call PushNumber( nGotCount )
											Call PushNumber( nGotOrd )
											If NOT SalSendMsg( hWndTable, nPAMTableMessage, nPAMTableMessageWParam, 0 )
												Call PopNumber( nGotOrd, TRUE )
												Call PopNumber( nGotCount, TRUE )
												Call PopDateTime( dtGotEstSaleDate, TRUE )
												Set bOk = FALSE
										Return bOk
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					!
					Function: GetPotSizeFutureDates
						Description:
						Returns
							Boolean:
						Parameters
							Number: nYear
							Window Handle: hWndTable
							Number: nPAMTableMessage
							Number: nPAMTableMessageWParam
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nOurHandleNo
							!
							Number: nInd
							Date/Time: dtGotEstSaleDate
							Boolean: bOk
						Actions
							Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetPotSizeFutureDates' )
							Select Case nActionType
								Case SH_cls_Execute
									Set sSql = " SELECT DISTINCT 
											  Growing_Sale.Est_Sale_Date 
											FROM 
											  Growing_Sale, 
											  Stock_Item 
											WHERE 
											  Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
											  Stock_Item.Stock_Type = 'C' AND 
											  Growing_Sale.Year_Of_Sale >= :1 AND 
											  Growing_Sale.Est_Sale_Date > SYSDATE AND 
											  ( Growing_Sale.Not_For_Sale = 'N' OR 
											    Growing_Sale.Not_For_Sale IS NULL ) 
											ORDER BY 
											  Growing_Sale.Est_Sale_Date"
									Set sName = 'GTPTSZFTDDTS'
									Set sBind = ':nYear'
									Set sInto = ':dtGotEstSaleDate'
									Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
									!
									Set dtGotEstSaleDate = DATETIME_Null
									!
									If haSqlHandles[ nOurHandleNo ].Execute( )
										Set bOk = TRUE
										While haSqlHandles[ nOurHandleNo ].FetchNext( nInd ) AND bOk
											Call PushDateTime( dtGotEstSaleDate )
											If NOT SalSendMsg( hWndTable, nPAMTableMessage, nPAMTableMessageWParam, 0 )
												Call PopDateTime( dtGotEstSaleDate, TRUE )
												Set bOk = FALSE
										Return bOk
									Else
										Return FALSE
								Case SH_cls_Disconnect
									Return haSqlHandles[ nOurHandleNo ].Disconnect( )
					!
					Function: FormatFigures
						Description:
						Returns
							String:
						Parameters
							Number: nCount
							Number: nOrd
						Static Variables
						Local variables
						Actions
							If NOT nCount >= 0
								Set nCount = 0
							If NOT nOrd >= 0
								Set nOrd = 0
							Return SalNumberToStrX( nCount, 0 ) || ', ( ' || SalNumberToStrX( nOrd, 0 ) || ' )'
					Function: FormatFutureDatesColTitles
						Description:
						Returns
							String:
						Parameters
							Date/Time: dtEstSaleDate
						Static Variables
						Local variables
						Actions
							Return SalNumberToStrX( SalDateDay( dtEstSaleDate ), 0 ) || '-' || 
									WordMonth( SalDateMonth( dtEstSaleDate ) ) || '-' || 
									SalNumberToStrX( SalDateYear( dtEstSaleDate ), 0 )
					Function: WordMonth
						Description:
						Returns
							String:
						Parameters
							Number: nMonth
						Static Variables
						Local variables
						Actions
							Select Case nMonth
								Case 1
									Return 'Jan'
								Case 2
									Return 'Feb'
								Case 3
									Return 'Mar'
								Case 4
									Return 'Apr'
								Case 5
									Return 'May'
								Case 6
									Return 'Jun'
								Case 7
									Return 'Jul'
								Case 8
									Return 'Aug'
								Case 9
									Return 'Sep'
								Case 10
									Return 'Oct'
								Case 11
									Return 'Nov'
								Case 12
									Return 'Dec'
								Default
									Return SalNumberToStrX( nMonth, 0 )
					Function: SetEstSaleDateColumn
						Description:
						Returns
						Parameters
							Window Handle: hWndTable
							Date/Time: dtEstSaleDate
							Number: nCount
							Number: nOrd
						Static Variables
						Local variables
							String: sColTitle
							String: sEstSaleDate
							Boolean: bFound
							Number: nColId
							Number: nPos
							Window Handle: hWndCol
						Actions
							Set nPos = 0
							Set sEstSaleDate = FormatFutureDatesColTitles( dtEstSaleDate )
							Set bFound = FALSE
							Set hWndCol = SalGetFirstChild( hWndTable, TYPE_TableColumn )
							While hWndCol AND NOT bFound
								Set nPos = nPos + 1
								Call SalTblGetColumnTitle( hWndCol, sColTitle, 12 )
								If sColTitle = sEstSaleDate
									Set bFound = TRUE
									Call SalSetWindowText( hWndCol, FormatFigures( nCount, nOrd ) )
								Else
									Set hWndCol = SalGetNextChild( hWndCol, TYPE_TableColumn )
							If NOT bFound
								Set nColId = SalTblCreateColumn( hWndTable, nPos + 1, 1.433, 12, sEstSaleDate )
								Set hWndCol = SalTblGetColumnWindow( hWndTable, nColId, COL_GetID ) 
								Call SalTblSetColumnFlags( hWndCol, COL_CenterJustify, TRUE )
								Call SalTblSetColumnFlags( hWndCol, COL_Editable, FALSE )
								Call SalTblSetColumnText( hWndTable, nColId, FormatFigures( nCount, nOrd ) )
				Window Variables
					Number: nYear
					Date/Time: dtEstSaleDate
					Number: nCount
					Number: nOrd
					Number: nNumColumns
					String: sEstSaleDate
					Window Handle: hWndCol
					Number: nColId
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set sSQLPopHandle = " SELECT DISTINCT 
								  Stock_Item.Tree_Type, 
								  @UPPER( Stock_Item.Tree_Type_Desc ), 
								  Stock_Item.Tree_Type_Desc 
								FROM 
								  Stock_Item 
								WHERE 
								  Stock_Item.Stock_Type = 'C' AND 
								  EXISTS 
								  ( 
								    SELECT 
								      Growing_Sale.Stock_Item_No 
								    FROM 
								      Growing_Sale 
								    WHERE 
								      Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
								      Growing_Sale.Year_Of_Sale >= :1 AND 
								      ( Growing_Sale.Not_For_Sale = 'N' OR 
								        Growing_Sale.Not_For_Sale IS NULL )
								  ) 
								ORDER BY 2 "
						Set sNAMEPopHandle = 'POPPTSSIZEINV'
						Set sBINDPopHandle = ':dlgPotsSizeInv.tblPotsSizeInv.nYear'
						Set sINTOPopHandle = ':dlgPotsSizeInv.tblPotsSizeInv.colTreeType,
								:dlgPotsSizeInv.tblPotsSizeInv.colUpperTreeTypeDesc,
								:dlgPotsSizeInv.tblPotsSizeInv.colTreeTypeDesc'
						!
						Set bAddAllowed = FALSE
						Set bSaveAllowed = FALSE
						Set bDeleteAllowed = FALSE
						Set bUnDeleteAllowed = FALSE
						Set bRepopulateAllowed = TRUE
						Set bClearSelectAllowed = TRUE
						Set bReportAllowed = TRUE
						!
						Set sTableHeading = 'Pots Size Inventory'
						Set bSelectFirstRow = FALSE
					On PAM_clsTBL_POPULATE
						Set nYear = hWndParent.ccSeasonYear.GetSeasonYear( )
						Set nNumColumns = 4
						Call GetPotSizeFutureDates( nYear, hWndForm, PAM_clsTBL_ROWACTION, 3, SH_cls_Execute )
						Call SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
						Return TableLoop( hWndForm, hWndForm, PAM_clsTBL_ROWACTION, 1, 0, 0, 'Fetching Future Figures', TBL_cls_LowToHi )
					On PAM_clsTBL_ROWACTION
						If wParam = 1
							Return GetPotSizeFutureCountNOrd( colTreeType, nYear, hWndForm, PAM_clsTBL_ROWACTION, 2, SH_cls_Execute )
						Else If wParam = 2
							Call PopNumber( nOrd, TRUE )
							Call PopNumber( nCount, TRUE )
							Call PopDateTime( dtEstSaleDate, TRUE )
							Call SetEstSaleDateColumn( hWndForm, dtEstSaleDate, nCount, nOrd )
							Return TRUE
						Else
							Call PopDateTime( dtEstSaleDate, TRUE )
							Set nNumColumns = nNumColumns + 1
							! Set sEstSaleDate = SalNumberToStrX( SalDateDay( dtEstSaleDate ), 0 ) || '-' || 
									WordMonth( SalDateMonth( dtEstSaleDate ) ) || '-' || 
									SalNumberToStrX( SalDateYear( dtEstSaleDate ), 0 )
							Set nColId = SalTblCreateColumn( hWndForm, nNumColumns, 1.433, 12, FormatFutureDatesColTitles( dtEstSaleDate ) )
							Set hWndCol = SalTblGetColumnWindow( hWndForm, nColId, COL_GetID ) 
							Call SalTblSetColumnFlags( hWndCol, COL_CenterJustify, TRUE )
							Call SalTblSetColumnFlags( hWndCol, COL_Editable, FALSE )
							Return TRUE
					On PAM_clsTBL_REPOPULATE
						Call SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
						Return TableLoop( hWndForm, hWndForm, PAM_clsTBL_ROWACTION, 1, 0, 0, 'Fetching Future Figures', TBL_cls_LowToHi )
					On SAM_FetchRowDone
						Call GetPotSizeCurrentCountNOrd( colTreeType, nYear, nCount, nOrd, SH_cls_Execute )
						Set colCurrentFigures = FormatFigures( nCount, nOrd )
						Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
					On PAM_clsTBL_NOROWS
						Return TRUE
					On SAM_Destroy
						Call GetPotSizeCurrentCountNOrd( '', 0, nCount, nOrd, SH_cls_Disconnect )
						Call GetPotSizeFutureCountNOrd( '', 0, hWndNULL, 0, 2, SH_cls_Disconnect )
						Call GetPotSizeFutureDates( 0, hWndNULL, 0, 0, SH_cls_Disconnect )
						Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
					On PAM_clsTBL_PRINTTABLEREPORT
						Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'c:\\temp' )||'\\'||'ptszinv.qrp'
						Set nColId = 1
						If SalReportTableCreate( sReportFileName, hWndForm, nColId )
							Call SalReportTableView( hWndForm, hWndNULL, sReportFileName, nColId )
						Return TRUE
			Background Text: All numerical columns are represented as Count, ( Sold )

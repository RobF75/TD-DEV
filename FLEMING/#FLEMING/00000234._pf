					Font Enhancement: Class Default
					Text Color: Class Default
					Background Color: Class Default
					DLL Settings
				Message Actions
		Functions
			Function: ResetReportFields
				Description:
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Set nItemNo = NUMBER_Null
					Set sVarietyType= ''
					Set sUpperVariety= ''
					Set sUpperCultDesc= ''
					Set sUpperRootDesc= ''
					Set sVariety= ''
					Set sTreeTypeDesc= ''
					Set sCultDesc= ''
					Set sRootDesc= ''
					Set sGenFlag= ''
					Set nPrice = NUMBER_Null
					Set sSoldOutFlag= ''
					Set sAllocatedFlag= ''
					Set sNotForSale= ''
					Set nCurrentAvailable = NUMBER_Null
					Set nCurrentOrdered = NUMBER_Null
					Set nFutAvailAmtCol1 = NUMBER_Null
					Set dtFutAvailDateCol1 = DATETIME_Null
					Set sFutAvailSeasonCol1= ''
					Set nFutOrderedCol1 = NUMBER_Null
					Set nFutAvailAmtCol2 = NUMBER_Null
					Set dtFutAvailDateCol2 = DATETIME_Null
					Set sFutAvailSeasonCol2= ''
					Set nFutOrderedCol2 = NUMBER_Null
					Set nFutAvailAmtCol3 = NUMBER_Null
					Set dtFutAvailDateCol3 = DATETIME_Null
					Set sFutAvailSeasonCol3= ''
					Set nFutOrderedCol3 = NUMBER_Null
			! Function: GetSeasonAndYear
				        Description: 
				        Returns 
					        String: 
				        Parameters 
					        Date/Time: dtEstSaleDate
				        Static Variables 
				        Local variables 
				        Actions 
					        Return GetSeason( dtEstSaleDate )||' '||SalNumberToStrX( SalDateYear( dtEstSaleDate ), 0 )
			Function: GrowingSaleActions
				Description:
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					If dtEstSaleDate = DATETIME_Null
						If sNotForSale = 'Y'
							Set sSeason = ''
					Else
						Set sSeason = GetSeason( dtEstSaleDate )
					!
					If nSecondCount > 0
						Set nFutureAvailable = nSecondCount - nForwardOrders
					Else If nFirstCount > 0
						Set nFutureAvailable = nFirstCount - nForwardOrders
					Else If nBegCount > 0
						Set nFutureAvailable = nBegCount - nForwardOrders
					Else
						Set nFutureAvailable = 0
			! Function: HasItemYearOfSale
				        Description: 
				        Returns 
					        Boolean: 
				        Parameters 
					        Number: nItemNo
					        Number: nYear
					        Receive Boolean: bExists
					        Number: nActionType
				        Static Variables 
					! hcSqlHandle: fcOurHandle
				        Local variables 
					        String: sSql
					        String: sBind
					        String: sInto
					        String: sName
					        Number: nOurHandleNo
					        Number: nInd
				        Actions 
					        Set nOurHandleNo = SqlHandlesGetReferenceNo( 'EXSTSITMSALE' )
					        Select Case nActionType
						        Case SH_cls_Execute
							        Set sSql = " SELECT 
									  Stock_Item_No 
									FROM 
									  Stock_Item_Sale
									WHERE 
									  Stock_Item_No = :1 AND 
									  Year_Of_Sale >= :2 "
							        Set sName = 'EXSTSITMSALE'
							        Set sBind = ':nItemNo, :nYear'
							        Set sInto = ''
							        Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
							        Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
							!
							        Set bExists = FALSE
							!
							        If haSqlHandles[ nOurHandleNo ].Execute( )
								        If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
									        Set bExists = TRUE
								        Return TRUE
							        Else 
								        Return FALSE
						        Case SH_cls_Disconnect
							        Return haSqlHandles[ nOurHandleNo ].Disconnect( )
		Window Parameters
		Window Variables
			Number: nYear
			String: sSelectedItemNoList
			String: sSelectedDateList
			!
			String: sSql
			Number: nInd
			!
			String: sReportFileName
			String: sReportBind
			String: sReportInto
			Number: nError
			Window Handle: hWndReport
			!
			: hSqlItems
				Class: hcSqlHandle
			: hSqlItemSale
				Class: hcSqlHandle
			: hSqlGrowSale
				Class: hcSqlHandle
			! Report fields
			Number: nItemNo
			String: sVarietyType
			String: sUpperVariety
			String: sUpperCultDesc
			String: sUpperRootDesc
			String: sVariety
			String: sTreeTypeDesc
			String: sCultDesc
			String: sRootDesc
			String: sGenFlag
			Number: nPrice
			String: sSoldOutFlag
			String: sAllocatedFlag
			String: sNotForSale
			Number: nCurrentAvailable
			Number: nCurrentOrdered
			Number: nFutAvailAmtCol1
			Date/Time: dtFutAvailDateCol1
			String: sFutAvailSeasonCol1
			Number: nFutOrderedCol1
			Number: nFutAvailAmtCol2
			Date/Time: dtFutAvailDateCol2
			String: sFutAvailSeasonCol2
			Number: nFutOrderedCol2
			Number: nFutAvailAmtCol3
			Date/Time: dtFutAvailDateCol3
			String: sFutAvailSeasonCol3
			Number: nFutOrderedCol3
			! end report fields
			!
			Number: nStockItemSaleYear
			Number: nTotAvail
			Number: nSubsTotAvail
			Number: nForwardOrders
			Number: nFutureAvailable
			Number: nAmtGrowing
			Number: nAmtGraded
			Number: nAmtShipped
			Number: nAmtOnOrder
			Number: nOnOrdAsSubs
			Number: nAmtSubsShipped
			Number: nEstAvailCount

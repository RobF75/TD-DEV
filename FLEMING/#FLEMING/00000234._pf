				Functions
				Window Variables
					String: sDateList
					Boolean: bFound
					Date/Time: dtCheckDate
				Message Actions
					On PAM_cls_SETINSTANCEVARS
						Set tblFutureIncEstAvailDates.bAddAllowed = TRUE
						Set tblFutureIncEstAvailDates.bSaveAllowed = FALSE
						Set tblFutureIncEstAvailDates.bDeleteAllowed = FALSE
						Set tblFutureIncEstAvailDates.bUnDeleteAllowed = FALSE
						Set tblFutureIncEstAvailDates.bRepopulateAllowed = FALSE
						Set tblFutureIncEstAvailDates.bClearSelectAllowed = TRUE
						Set tblFutureIncEstAvailDates.bQueryAllowed = FALSE
						Set tblFutureIncEstAvailDates.bReportAllowed = FALSE
						Set tblFutureIncEstAvailDates.bOrderAllowed = FALSE
						Set tblFutureIncEstAvailDates.bSelectingColumnsAllowed = FALSE
						Set tblFutureIncEstAvailDates.bMakeCSVFileAllowed = FALSE
						Set tblFutureIncEstAvailDates.bZoomTableAllowed = FALSE
					On PAM_PTASSINV_GETSELECTEDDATES
						Set sDateList = ''
						If TableLoop( hWndForm, hWndForm, PAM_PTASSINV_GETSELECTED, 0, 0, 0, 'Extracting Selected Items', TBL_cls_LowToHi )
							Call PushString( sDateList )
							Return TRUE
						Else
							Return FALSE
					On PAM_PTASSINV_GETSELECTED
						If sDateList = ''
							Set sDateList = DateToStrX( colEstAvailDate )
						Else
							Set sDateList = sDateList || ', ' || DateToStrX( colEstAvailDate )
						Return TRUE
					! On PAM_clsTBL_ROWNEWINIT
						        Call SalTblSetRowFlags( hWndForm, lParam, ROW_HideMarks, TRUE )
						        Return TRUE
					On PAM_PTASSINV_FINDSELECTEDDATE
						Set bFound = FALSE
						Set dtCheckDate = SalStrToDate( SalNumberToHString( lParam ) )
						Call TableLoop( hWndForm, hWndForm, PAM_PTASSINV_CHECKSELECTEDDATE, 0, 0, 0, 'Matching Selected Date', TBL_cls_LowToHi )
						Return bFound
					On PAM_PTASSINV_CHECKSELECTEDDATE
						If colEstAvailDate = dtCheckDate
							Set bFound = TRUE
							Return FALSE
						Else
							Return TRUE

			!
			Boolean: bLoop
			Boolean: bReturn
			Boolean: bValid
			Boolean: bFetched
			Boolean: bFutureBindDateFilled
			Number: nAccumFutAvail
			Date/Time: dtPrevEstSaleDate
			Number: nBindFutDatePos
			Number: nAccumFutOrdered
			Number: naAccumFutAvailBind[*]
			Date/Time: dtaEstSaleDateBind[*]
			String: saSeasonEstSaleDateBind[*]
			Number: naAccumFutOrderedBind[*]
		Message Actions
			On SAM_CreateComplete
				Set rbPrint = FALSE
				Set rbAllItems = TRUE
				Set hWndReport = hWndNULL
				Call SalSendMsg( cbFutureStock, PAM_clsCB_SET, TRUE, 0 )
				Set rbSelectedFutureDates = FALSE
				Set rbAllFutureStock = TRUE
				Call SalSendMsg( cbExcludeC15, PAM_clsCB_SET, TRUE, 0 )
				!
				Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
			On PAM_clsPTASSINV_REPORT
				If rbSelectedItems
					If SalSendMsg( tblSelectedItems, PAM_PTASSINV_GETSELECTEDITEMS, 0, 0 )
						Call PopString( sSelectedItemNoList, TRUE )
					Else
						Call SalMessageBox( 'Please select some items first, or choose All Items.', 'Warning', MB_Ok )
						Return FALSE
				!
				Call OurWaitCursor( TRUE )
				Set nYear = ccSeasonYear.GetSeasonYear( )
				!
				Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\ptassin8.qrp'
				Set sReportBind = ':frmPotsAssInv.nYear, 
						:frmPotsAssInv.nItemNo,
						:frmPotsAssInv.sVarietyType,
						:frmPotsAssInv.sUpperVariety,
						:frmPotsAssInv.sUpperCultDesc,
						:frmPotsAssInv.sUpperRootDesc,
						:frmPotsAssInv.sVariety,
						:frmPotsAssInv.sTreeTypeDesc,
						:frmPotsAssInv.sCultDesc,
						:frmPotsAssInv.sRootDesc,
						:frmPotsAssInv.sGenFlag,
						:frmPotsAssInv.nPrice,
						:frmPotsAssInv.sSoldOutFlag,
						:frmPotsAssInv.sAllocatedFlag,
						:frmPotsAssInv.sNotForSale,
						:frmPotsAssInv.nCurrentAvailable,
						:frmPotsAssInv.nCurrentOrdered, 
						:frmPotsAssInv.nFutAvailAmtCol1,
						:frmPotsAssInv.dtFutAvailDateCol1,
						:frmPotsAssInv.sFutAvailSeasonCol1, 
						:frmPotsAssInv.nFutOrderedCol1, 
						:frmPotsAssInv.nFutAvailAmtCol2,
						:frmPotsAssInv.dtFutAvailDateCol2,
						:frmPotsAssInv.sFutAvailSeasonCol2, 
						:frmPotsAssInv.nFutOrderedCol2, 
						:frmPotsAssInv.nFutAvailAmtCol3,
						:frmPotsAssInv.dtFutAvailDateCol3,
						:frmPotsAssInv.sFutAvailSeasonCol3, 
						:frmPotsAssInv.nFutOrderedCol3'
				Set sReportInto = 'nYear, 
						nItemNo,
						sVarietyType,
						sUpperVariety,
						sUpperCultDesc,
						sUpperRootDesc,
						sVariety,
						sTreeTypeDesc,
						sCultDesc,
						sRootDesc,
						sGenFlag,
						nPrice,
						sSoldOutFlag,
						sAllocatedFlag,
						sNotForSale,
						nCurrentAvailable, 
						nCurrentOrdered, 
						nFutAvailAmtCol1,
						dtFutAvailDateCol1,
						sFutAvailSeasonCol1, 
						nFutOrderedCol1, 
						nFutAvailAmtCol2,
						dtFutAvailDateCol2,
						sFutAvailSeasonCol2,
						nFutOrderedCol2, 
						nFutAvailAmtCol3,
						dtFutAvailDateCol3,
						sFutAvailSeasonCol3, 
						nFutOrderedCol3'
				!
				Set nError = 1
				If rbView
					Set hWndReport = SalReportView( hWndForm, hWndNULL, sReportFileName, sReportBind, sReportInto, nError )
				Else
					Set hWndReport = SalReportPrint( hWndForm, sReportFileName, sReportBind, sReportInto, 1, RPT_PrintAll | RPT_PrintDraft, 0, 0, nError )
				Call OurWaitCursor( FALSE )
			On SAM_ReportStart
				If rbSelectedItems
					If cbExcludeC15
						Set sSql = "SELECT
								  Stock_Item.Item_No, 
								  Stock_Item.Variety_Type,
								  Stock_Item.Variety,
								  Stock_Item.Tree_Type_Desc, 
								  Stock_Item.Cult_Desc, 
								  Stock_Item.Root_Desc,
								  @UPPER(Stock_Item.Variety),
								  @UPPER(Stock_Item.Cult_Desc),
								  @UPPER(Stock_Item.Root_Desc),
								  Stock_Item.Generic_Stock_Item 
								FROM 
								  Stock_Item
								INTO 
								  :frmPotsAssInv.nItemNo, 
								  :frmPotsAssInv.sVarietyType, 
								  :frmPotsAssInv.sVariety, 
								  :frmPotsAssInv.sTreeTypeDesc, 
								  :frmPotsAssInv.sCultDesc,
								  :frmPotsAssInv.sRootDesc,
								  :frmPotsAssInv.sUpperVariety, 
								  :frmPotsAssInv.sUpperCultDesc,
								  :frmPotsAssInv.sUpperRootDesc,
								  :frmPotsAssInv.sGenFlag
								WHERE 
								  Stock_Item.Item_No IN ( " || sSelectedItemNoList || " ) AND 
								  Stock_Item.Stock_Type = 'C' AND 
								  NOT Stock_Item.Tree_Type LIKE 'C15%'
								ORDER BY 2,7,8,9,4"
					Else
						Set sSql = "SELECT
								  Stock_Item.Item_No, 
								  Stock_Item.Variety_Type,
								  Stock_Item.Variety,
								  Stock_Item.Tree_Type_Desc, 
								  Stock_Item.Cult_Desc, 
								  Stock_Item.Root_Desc,
								  @UPPER(Stock_Item.Variety),
								  @UPPER(Stock_Item.Cult_Desc),
								  @UPPER(Stock_Item.Root_Desc),
								  Stock_Item.Generic_Stock_Item
								FROM 
								  Stock_Item
								INTO 
								  :frmPotsAssInv.nItemNo, 
								  :frmPotsAssInv.sVarietyType, 
								  :frmPotsAssInv.sVariety, 
								  :frmPotsAssInv.sTreeTypeDesc, 
								  :frmPotsAssInv.sCultDesc,
								  :frmPotsAssInv.sRootDesc,
								  :frmPotsAssInv.sUpperVariety, 
								  :frmPotsAssInv.sUpperCultDesc,
								  :frmPotsAssInv.sUpperRootDesc,
								  :frmPotsAssInv.sGenFlag
								WHERE 
								  Stock_Item.Item_No IN ( " || sSelectedItemNoList || " ) AND 
								  Stock_Item.Stock_Type = 'C'
								ORDER BY 2,7,8,9,4"
					Call hSqlItems.PrepareSetup( sSql )
				Else
					If cbExcludeC15
						Set sSql = "SELECT
								  Stock_Item.Item_No, 
								  Stock_Item.Variety_Type,
								  Stock_Item.Variety,
								  Stock_Item.Tree_Type_Desc, 
								  Stock_Item.Cult_Desc, 
								  Stock_Item.Root_Desc,
								  @UPPER(Stock_Item.Variety),
								  @UPPER(Stock_Item.Cult_Desc),
								  @UPPER(Stock_Item.Root_Desc),
								  Stock_Item.Generic_Stock_Item
								FROM 
								  Stock_Item
								INTO 
								  :frmPotsAssInv.nItemNo, 
								  :frmPotsAssInv.sVarietyType, 
								  :frmPotsAssInv.sVariety, 
								  :frmPotsAssInv.sTreeTypeDesc, 
								  :frmPotsAssInv.sCultDesc,
								  :frmPotsAssInv.sRootDesc,
								  :frmPotsAssInv.sUpperVariety, 
								  :frmPotsAssInv.sUpperCultDesc,
								  :frmPotsAssInv.sUpperRootDesc,
								  :frmPotsAssInv.sGenFlag
								WHERE 
								  Stock_Item.Stock_Type = 'C' AND 
								  NOT Stock_Item.Tree_Type LIKE 'C15%' 
								ORDER BY 2,7,8,9,4"
					Else
						Set sSql = "SELECT
								  Stock_Item.Item_No, 
								  Stock_Item.Variety_Type,
								  Stock_Item.Variety,
								  Stock_Item.Tree_Type_Desc, 
								  Stock_Item.Cult_Desc, 
								  Stock_Item.Root_Desc,
								  @UPPER(Stock_Item.Variety),
								  @UPPER(Stock_Item.Cult_Desc),
								  @UPPER(Stock_Item.Root_Desc),
								  Stock_Item.Generic_Stock_Item
								FROM 
								  Stock_Item
								INTO 
								  :frmPotsAssInv.nItemNo, 
								  :frmPotsAssInv.sVarietyType, 
								  :frmPotsAssInv.sVariety, 
								  :frmPotsAssInv.sTreeTypeDesc, 
								  :frmPotsAssInv.sCultDesc,
								  :frmPotsAssInv.sRootDesc,
								  :frmPotsAssInv.sUpperVariety, 
								  :frmPotsAssInv.sUpperCultDesc,
								  :frmPotsAssInv.sUpperRootDesc,
								  :frmPotsAssInv.sGenFlag
								WHERE 
								  Stock_Item.Stock_Type = 'C'
								ORDER BY 2,7,8,9,4"
					Call hSqlItems.PrepareSetup( sSql )
				!
				Set sSql = "SELECT 
						  Stock_Item_Sale.Year_Of_Sale, 
						  Stock_Item_Sale.Sold_Out_Flag,
						  Stock_Item_Sale.Allocated_Flag, 
						  Stock_Item_Sale.Amt_Growing,
						  Stock_Item_Sale.Amt_Graded,
						  Stock_Item_Sale.Amt_Shipped,
						  Stock_Item_Sale.Amt_On_Order,
						  Stock_Item_Sale.Tot_Avail,
						  Stock_Item_Sale.On_Ord_As_Subs, 
						  Stock_Item_Sale.Amt_Subs_Shipped,
						  Stock_Item_Sale.Est_Avail_Count
						FROM 
						  Stock_Item_Sale 
						INTO 
						  :frmPotsAssInv.nStockItemSaleYear, 
						  :frmPotsAssInv.sSoldOutFlag,
						  :frmPotsAssInv.sAllocatedFlag,
						  :frmPotsAssInv.nAmtGrowing,
						  :frmPotsAssInv.nAmtGraded,
						  :frmPotsAssInv.nAmtShipped,
						  :frmPotsAssInv.nAmtOnOrder,
						  :frmPotsAssInv.nTotAvail,
						  :frmPotsAssInv.nOnOrdAsSubs,
						  :frmPotsAssInv.nAmtSubsShipped,
						  :frmPotsAssInv.nEstAvailCount 
						WHERE 
						  Stock_Item_Sale.Stock_Item_No = :frmPotsAssInv.nItemNo AND 
						  Stock_Item_Sale.Year_Of_Sale >= :frmPotsAssInv.nYear 
						ORDER BY 
						  Stock_Item_Sale.Year_Of_Sale "
				Call hSqlItemSale.PrepareSetup( sSql )
				!
				If cbFutureStock
					! If cbOnlyNotForSale
						        If rbAllFutureStock
							        Set sSql = " SELECT
									  Growing_Sale.Beg_Count,
									  Growing_Sale.First_Count,
									  Growing_Sale.Second_Count,
									  Growing_Sale.Est_Sale_Date,
									  Growing_Sale.Forward_Orders,
									  Growing_Sale.Not_For_Sale
									FROM 
									  Growing_Sale 
									INTO 
									  :frmPotsAssInv.nBegCount,
									  :frmPotsAssInv.nFirstCount,
									  :frmPotsAssInv.nSecondCount,
									  :frmPotsAssInv.dtEstSaleDate,
									  :frmPotsAssInv.nForwardOrders,
									  :frmPotsAssInv.sNotForSale
									WHERE 
									  Growing_Sale.Stock_Item_No = :frmPotsAssInv.nItemNo AND 
									  Growing_Sale.Year_Of_Sale >= :frmPotsAssInv.nYear AND 
									  Growing_Sale.Future_Stock = 'Y' AND 
									  Growing_Sale.Not_For_Sale = 'Y'  
									ORDER BY 
									  Est_Sale_Date"
						        Else 
							        If SalSendMsg( tblFutureIncEstAvailDates, PAM_PTASSINV_GETSELECTEDDATES, 0, 0 )
								        Call PopString( sSelectedDateList, TRUE )
								        Set sSql = " SELECT
										  Growing_Sale.Beg_Count,
										  Growing_Sale.First_Count,
										  Growing_Sale.Second_Count,
										  Growing_Sale.Est_Sale_Date,
										  Growing_Sale.Forward_Orders,
										  Growing_Sale.Not_For_Sale
										FROM 
										  Growing_Sale 
										INTO 
										  :frmPotsAssInv.nBegCount,
										  :frmPotsAssInv.nFirstCount,
										  :frmPotsAssInv.nSecondCount,
										  :frmPotsAssInv.dtEstSaleDate,
										  :frmPotsAssInv.nForwardOrders,
										  :frmPotsAssInv.sNotForSale
										WHERE 
										  Growing_Sale.Stock_Item_No = :frmPotsAssInv.nItemNo AND 
										  Growing_Sale.Year_Of_Sale >= :frmPotsAssInv.nYear AND 
										  Growing_Sale.Future_Stock = 'Y' AND 
										  Growing_Sale.Est_Sale_Date IN ( " || sSelectedDateList || " ) AND 
										  Growing_Sale.Not_For_Sale = 'Y' 
										ORDER BY 
										  Est_Sale_Date"
							        Else 
								        Call SalMessageBox( 'Please enter some dates first, or choose All future dates.', 'Warning', MB_Ok )
								        Return FALSE
					! Else
						        If rbAllFutureStock
							        Set sSql = " SELECT
									  Growing_Sale.Beg_Count,
									  Growing_Sale.First_Count,
									  Growing_Sale.Second_Count,
									  Growing_Sale.Est_Sale_Date,
									  Growing_Sale.Forward_Orders,
									  Growing_Sale.Not_For_Sale
									FROM 
									  Growing_Sale 
									INTO 
									  :frmPotsAssInv.nBegCount,
									  :frmPotsAssInv.nFirstCount,
									  :frmPotsAssInv.nSecondCount,
									  :frmPotsAssInv.dtEstSaleDate,
									  :frmPotsAssInv.nForwardOrders,
									  :frmPotsAssInv.sNotForSale
									WHERE 
									  Growing_Sale.Stock_Item_No = :frmPotsAssInv.nItemNo AND 
									  Growing_Sale.Year_Of_Sale >= :frmPotsAssInv.nYear AND 
									  Growing_Sale.Future_Stock = 'Y' AND
									  NOT Growing_Sale.Not_For_Sale = 'Y' 
									ORDER BY 
									  Est_Sale_Date"
						        Else 
							        If SalSendMsg( tblFutureIncEstAvailDates, PAM_PTASSINV_GETSELECTEDDATES, 0, 0 )
								        Call PopString( sSelectedDateList, TRUE )
								        Set sSql = " SELECT
										  Growing_Sale.Beg_Count,
										  Growing_Sale.First_Count,
										  Growing_Sale.Second_Count,
										  Growing_Sale.Est_Sale_Date,
										  Growing_Sale.Forward_Orders,
										  Growing_Sale.Not_For_Sale
										FROM 
										  Growing_Sale 
										INTO 
										  :frmPotsAssInv.nBegCount,
										  :frmPotsAssInv.nFirstCount,
										  :frmPotsAssInv.nSecondCount,
										  :frmPotsAssInv.dtEstSaleDate,
										  :frmPotsAssInv.nForwardOrders,
										  :frmPotsAssInv.sNotForSale
										WHERE 
										  Growing_Sale.Stock_Item_No = :frmPotsAssInv.nItemNo AND 
										  Growing_Sale.Year_Of_Sale >= :frmPotsAssInv.nYear AND 
										  Growing_Sale.Future_Stock = 'Y' AND 
										  Growing_Sale.Est_Sale_Date IN ( " || sSelectedDateList || " ) AND 
										  NOT Growing_Sale.Not_For_Sale = 'Y' 
										ORDER BY 
										  Est_Sale_Date"
							        Else 
								        Call SalMessageBox( 'Please enter some dates first, or choose All future dates.', 'Warning', MB_Ok )
								        Return FALSE
					If rbAllFutureStock
						Set sSql = " SELECT
								  Growing_Sale.Beg_Count,
								  Growing_Sale.First_Count,
								  Growing_Sale.Second_Count,
								  Growing_Sale.Est_Sale_Date,
								  Growing_Sale.Forward_Orders,
								  Growing_Sale.Not_For_Sale
								FROM
								  Growing_Sale
								INTO
								  :frmPotsAssInv.nBegCount,
								  :frmPotsAssInv.nFirstCount,
								  :frmPotsAssInv.nSecondCount,
								  :frmPotsAssInv.dtEstSaleDate,
								  :frmPotsAssInv.nForwardOrders,
								  :frmPotsAssInv.sNotForSale
								WHERE
								  Growing_Sale.Stock_Item_No = :frmPotsAssInv.nItemNo AND
								  Growing_Sale.Year_Of_Sale >= :frmPotsAssInv.nYear AND
								  ( Growing_Sale.Est_Sale_Date > SYSDATE OR
								    Growing_Sale.Not_For_Sale = 'Y' )
								ORDER BY
								  Est_Sale_Date"
					Else
						If SalSendMsg( tblFutureIncEstAvailDates, PAM_PTASSINV_GETSELECTEDDATES, 0, 0 )
							Call PopString( sSelectedDateList, TRUE )
							If cbNOTSelectedFutureDate
								Set sSql = " SELECT
										  Growing_Sale.Beg_Count,
										  Growing_Sale.First_Count,
										  Growing_Sale.Second_Count,
										  Growing_Sale.Est_Sale_Date,
										  Growing_Sale.Forward_Orders,
										  Growing_Sale.Not_For_Sale
										FROM
										  Growing_Sale
										INTO
										  :frmPotsAssInv.nBegCount,
										  :frmPotsAssInv.nFirstCount,
										  :frmPotsAssInv.nSecondCount,
										  :frmPotsAssInv.dtEstSaleDate,
										  :frmPotsAssInv.nForwardOrders,
										  :frmPotsAssInv.sNotForSale
										WHERE
										  Growing_Sale.Stock_Item_No = :frmPotsAssInv.nItemNo AND
										  Growing_Sale.Year_Of_Sale >= :frmPotsAssInv.nYear AND
										  ( NOT Growing_Sale.Est_Sale_Date IN ( " || sSelectedDateList || " ) OR 
										    Growing_Sale.Est_Sale_Date IS NULL ) 
										ORDER BY
										  Est_Sale_Date"
							Else
								Set sSql = " SELECT
										  Growing_Sale.Beg_Count,
										  Growing_Sale.First_Count,
										  Growing_Sale.Second_Count,
										  Growing_Sale.Est_Sale_Date,
										  Growing_Sale.Forward_Orders,
										  Growing_Sale.Not_For_Sale
										FROM
										  Growing_Sale
										INTO
										  :frmPotsAssInv.nBegCount,
										  :frmPotsAssInv.nFirstCount,
										  :frmPotsAssInv.nSecondCount,
										  :frmPotsAssInv.dtEstSaleDate,
										  :frmPotsAssInv.nForwardOrders,
										  :frmPotsAssInv.sNotForSale
										WHERE
										  Growing_Sale.Stock_Item_No = :frmPotsAssInv.nItemNo AND
										  Growing_Sale.Year_Of_Sale >= :frmPotsAssInv.nYear AND
										  ( Growing_Sale.Est_Sale_Date IN ( " || sSelectedDateList || " ) OR
										    Growing_Sale.Not_For_Sale = 'Y' )
										ORDER BY
										  Est_Sale_Date"
						Else
							Call SalMessageBox( 'Please enter some dates first, or choose All future dates.', 'Warning', MB_Ok )
							Return FALSE
					Call hSqlGrowSale.PrepareSetup( sSql )
				Return TRUE
			On SAM_ReportFetchInit
				Call ResetReportFields(  )
				!
				If hSqlItems.PrepareAndExecute( )
					Return TRUE
				Else
					Return FALSE
			On SAM_ReportFetchNext
				Set bLoop = TRUE
				Set bReturn = TRUE
				While bLoop 
					Call ResetReportFields(  )
					If hSqlItems.FetchNext( nInd )
						If hSqlItemSale.PrepareAndExecute( )
							If hSqlItemSale.FetchNext( nInd )
								If nStockItemSaleYear = nYear
									Call CalculateSubstitutes( nItemNo, nYear, nSubsTotAvail, SH_cls_Execute )
									Set nCurrentAvailable = nTotAvail + nSubsTotAvail
								Else
									Set nCurrentAvailable = NUMBER_Null
								Set nCurrentOrdered = nAmtOnOrder + nOnOrdAsSubs
								If nCurrentOrdered = 0
									Set nCurrentOrdered = NUMBER_Null
								Call CalcItemPriceForQueries( nItemNo, nYear, nPrice, SH_cls_Execute )
								!
								If cbFutureStock
									If hSqlGrowSale.PrepareAndExecute( )
										If hSqlGrowSale.FetchNext( nInd )
											Set nAccumFutAvail = NUMBER_Null
											Set dtPrevEstSaleDate = DATETIME_Null
											Set nAccumFutOrdered = NUMBER_Null
											!
											Set nBindFutDatePos = 0
											While nBindFutDatePos <= MAX_NoFutBindCols
												Set naAccumFutAvailBind[ nBindFutDatePos ] = NUMBER_Null
												Set dtaEstSaleDateBind[ nBindFutDatePos ] = DATETIME_Null
												Set saSeasonEstSaleDateBind[ nBindFutDatePos ] = ''
												Set naAccumFutOrderedBind[ nBindFutDatePos ] = NUMBER_Null
												Set nBindFutDatePos = nBindFutDatePos + 1
											Set nBindFutDatePos = 0
											!
											Set bFutureBindDateFilled = FALSE
											Set bFetched = TRUE
											While bFetched
												Set bValid = TRUE
												If rbSelectedFutureDates
													If SalSendMsg( tblFutureIncEstAvailDates, PAM_PTASSINV_FINDSELECTEDDATE, 0, SalHStringToNumber( DateToStrX( dtEstSaleDate ) ) )
														If cbOnlyNotForSale
															If sNotForSale = 'Y'
																Call GrowingSaleActions(  )
															Else
																Set bValid = FALSE
														Else
															If sNotForSale = 'Y'
																Set bValid = FALSE
															Else
																Call GrowingSaleActions(  )
													Else
														Set bValid = FALSE
												Else
													If cbOnlyNotForSale
														If sNotForSale = 'Y'
															Call GrowingSaleActions(  )
														Else
															Set bValid = FALSE
													Else
														If sNotForSale = 'Y'
															Set bValid = FALSE
														Else
															Call GrowingSaleActions(  )
												!
												If bValid
													Set bFutureBindDateFilled = TRUE
													If dtPrevEstSaleDate = dtEstSaleDate
														Set nAccumFutAvail = nAccumFutAvail + nFutureAvailable
														Set naAccumFutAvailBind[ nBindFutDatePos - 1 ] = nAccumFutAvail
														Set nAccumFutOrdered = nAccumFutOrdered + nForwardOrders
														Set naAccumFutOrderedBind[ nBindFutDatePos - 1 ] = nAccumFutOrdered
													Else
														Set nAccumFutAvail = nFutureAvailable
														Set dtPrevEstSaleDate = dtEstSaleDate
														Set nAccumFutOrdered = nForwardOrders
														!
														Set naAccumFutAvailBind[ nBindFutDatePos ] = nAccumFutAvail
														Set dtaEstSaleDateBind[ nBindFutDatePos ] = dtEstSaleDate
														Set saSeasonEstSaleDateBind[ nBindFutDatePos ] = sSeason
														Set naAccumFutOrderedBind[ nBindFutDatePos ] = nAccumFutOrdered
														Set nBindFutDatePos = nBindFutDatePos + 1
														Set naAccumFutAvailBind[ nBindFutDatePos ] = NUMBER_Null
														Set dtaEstSaleDateBind[ nBindFutDatePos ] = DATETIME_Null
														Set saSeasonEstSaleDateBind[ nBindFutDatePos ] = ''
														Set naAccumFutOrderedBind[ nBindFutDatePos ] = NUMBER_Null
												!
												Set bFetched = hSqlGrowSale.FetchNext( nInd )
											!
											If bFutureBindDateFilled
												Set nFutAvailAmtCol1 = naAccumFutAvailBind[0]
												Set dtFutAvailDateCol1 = dtaEstSaleDateBind[0]
												Set sFutAvailSeasonCol1 = saSeasonEstSaleDateBind[0]
												Set nFutOrderedCol1 = naAccumFutOrderedBind[0]
												!
												Set nFutAvailAmtCol2 = naAccumFutAvailBind[1]
												Set dtFutAvailDateCol2 = dtaEstSaleDateBind[1]
												Set sFutAvailSeasonCol2 = saSeasonEstSaleDateBind[1]
												Set nFutOrderedCol2 = naAccumFutOrderedBind[1]
												!
												Set nFutAvailAmtCol3 = naAccumFutAvailBind[2]
												Set dtFutAvailDateCol3 = dtaEstSaleDateBind[2]
												Set sFutAvailSeasonCol3 = saSeasonEstSaleDateBind[2]
												Set nFutOrderedCol3 = naAccumFutOrderedBind[3]
												!
												Set bLoop = FALSE
											Else If NOT nCurrentAvailable = NUMBER_Null
												Set bLoop = FALSE
										Else If NOT nCurrentAvailable = NUMBER_Null AND NOT cbNOTSelectedFutureDate
											Set bLoop = FALSE
									Else
										Set bLoop = FALSE
								Else
									Set bLoop = FALSE
						Else
							Set bLoop = FALSE
					Else
						Set bReturn = FALSE
						Set bLoop = FALSE
				Return bReturn
			On SAM_ReportFinish
				Call SalShowWindow( hWndForm )
				Call SalBringWindowToTop( hWndForm )
				Return TRUE
			On SAM_Destroy
				Call hSqlItems.Disconnect( )
				Call hSqlItemSale.Disconnect( )
				Call hSqlGrowSale.Disconnect( )
				! Call HasItemYearOfSale( 0, 0, bExists, SH_cls_Disconnect )
				Call CalculateSubstitutes( 0, 0, nSubsTotAvail, SH_cls_Disconnect )
				Call CalcItemPriceForQueries( 0, 0, nPrice, SH_cls_Disconnect )
				Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

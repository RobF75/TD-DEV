			: haSqlHandles[*]
				Class: hcSqlHandle
		Named Menus
		Internal Functions
			Function: SqlHandlesSetup
				Description:
				Returns
				Parameters
				Static Variables
				Local variables
				Actions
					Set haSqlHandles[ 0 ].sHandleIdKey = ''
			Function: SqlHandlesGetReferenceNo
				Description:
				Returns
					Number:
				Parameters
					String: sKey
				Static Variables
				Local variables
					Number: nPos
					Boolean: bFound
					Number: nAllocPos
				Actions
					Call OurWaitCursor( TRUE )
					Set sKey = sKey || GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndItem )
					Set nAllocPos = 0
					Set bFound = FALSE
					Set nPos = 0
					While haSqlHandles[ nPos ].sHandleIdKey != '' AND NOT bFound
						If haSqlHandles[ nPos ].sHandleIdKey = sKey
							Set bFound = TRUE
						Else
							Set nPos = nPos + 1
					If bFound
						Set nAllocPos = nPos
					Else
						!
						Set nPos = 0
						While haSqlHandles[ nPos ].sHandleIdKey != '' AND NOT bFound
							If haSqlHandles[ nPos ].sHandleIdKey = ' ' AND haSqlHandles[ nPos ].bHandleConnected = TRUE
								Set bFound = TRUE
							Else
								Set nPos = nPos + 1
						!
						If bFound
							Call haSqlHandles[ nPos ].ReuseInit( )
							Set haSqlHandles[ nPos ].sHandleIdKey = sKey
							Set nAllocPos = nPos
						Else
							!
							Set nPos = 0
							While haSqlHandles[ nPos ].sHandleIdKey != '' AND NOT bFound
								If haSqlHandles[ nPos ].sHandleIdKey = ' '
									Set bFound = TRUE
								Else
									Set nPos = nPos + 1
							!
							If bFound
								Call haSqlHandles[ nPos ].ReuseInit( )
								Set haSqlHandles[ nPos ].sHandleIdKey = sKey
								Set nAllocPos = nPos
							Else
								Call haSqlHandles[ nPos ].Init( )
								Set haSqlHandles[ nPos ].sHandleIdKey = sKey
								Set nPos = nPos + 1
								Call haSqlHandles[ nPos ].Init( )
								Set haSqlHandles[ nPos ].sHandleIdKey = ''
								Set nAllocPos = nPos - 1
					Call OurWaitCursor( FALSE )
					Return nAllocPos
			Function: SqlHandlesDisconnectClose
				Description:
				Returns
				Parameters
				Static Variables
				Local variables
					Number: nPos
				Actions
					Call OurWaitCursor( TRUE )
					Set nPos = 0
					While haSqlHandles[ nPos ].sHandleIdKey != ''
						Call haSqlHandles[ nPos ].DisconnectClose( )
						Set nPos = nPos + 1
					Call OurWaitCursor( FALSE )
			Function: GetSqlHandlesStats
				Description:
				Returns
					Number:
				Parameters
					Receive Number: nTotalUsedConnected
					Receive Number: nTotalReuseConnected
					Receive Number: nTotalHandles
					Receive Number: nTotalReuseHandles
				Static Variables
				Local variables
					Number: nPos
				Actions
					Call OurWaitCursor( TRUE )
					Set nTotalUsedConnected = 0
					Set nTotalReuseConnected = 0
					Set nTotalHandles = 0
					Set nTotalReuseHandles = 0
					!
					Set nPos = 0
					While haSqlHandles[ nPos ].sHandleIdKey != ''
						If haSqlHandles[ nPos ].sHandleIdKey = ' '
							Set nTotalHandles = nTotalHandles + 1
							Set nTotalReuseHandles = nTotalReuseHandles + 1
							If haSqlHandles[ nPos ].bHandleConnected = TRUE
								Set nTotalReuseConnected = nTotalReuseConnected + 1
						Else If haSqlHandles[ nPos ].sHandleIdKey != ''
							Set nTotalHandles = nTotalHandles + 1
							If haSqlHandles[ nPos ].bHandleConnected = TRUE
								Set nTotalUsedConnected = nTotalUsedConnected + 1
						!
						Set nPos = nPos + 1
					Call OurWaitCursor( FALSE )
					Return nPos
			!
			! uncomment bellow function when ConvertSql can handle UPDATES, INSERST AND DELETES
			! Function: GetTempCommandName
				    Description: 
				    Returns 
					    String: 
				    Parameters 
				    Static Variables 
					    Number: nLastValue
				    Local variables 
					    String: sNewName
					    Number: nPos
					    Number: nTotalValue
					    Number: nLength
				    Actions 
					    Set sNewName = SalNumberToStrX( SalDateDay( SalDateCurrent( ) ), 0 ) || 
							SalNumberToStrX( SalDateMonth( SalDateCurrent( ) ), 0 ) || 
							SalNumberToStrX( SalDateYear( SalDateCurrent( ) ), 0 ) || 
							SalNumberToStrX( SalDateHour( SalDateCurrent( ) ), 0 )  || 
							SalNumberToStrX( SalDateMinute( SalDateCurrent( ) ), 0 ) || 
							SalNumberToStrX( SalDateSecond( SalDateCurrent( ) ), 0 ) 
					    Set nPos = 0
					    Set nTotalValue = SalNumberRandom(  )
					    Set nLength = SalStrLength( sNewName )
					    While nPos < nLength
						    Set nTotalValue = nTotalValue + SalStrToNumber( SalStrMidX( sNewName, nPos, 1 ) )
						    Set nPos = nPos + 1
					    While nTotalValue = nLastValue 
						    Set nTotalValue = nTotalValue + SalNumberRandom(  )
					    Set nLastValue = nTotalValue
					    Return 'T' || SalNumberToStrX( nTotalValue, 0 )
			! !
		Class Definitions
.data RESOURCE 0 0 1 3014280054

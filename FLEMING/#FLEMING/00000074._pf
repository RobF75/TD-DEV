										    Else 
											    Set nEndTokenStart = SalStrScan( sSqlStatement, 'FOR UPDATE OF' )
											    If nEndTokenStart >= 0
												    Return PrivateExtractBetweenTokens( nSelectStart, 'WHERE', nEndTokenStart, 'FOR UPDATE OF', sSqlStatement )
											    Else 
												    Set nEndTokenStart = SalStrScan( sSqlStatement, 'INTO' )
												    If nEndTokenStart >= nSelectStart
													    Return PrivateExtractBetweenTokens( nSelectStart, 'WHERE', nEndTokenStart, 'INTO', sSqlStatement )
												    Else 
													    Return SalStrMidX( sSqlStatement, nSelectStart + SalStrLength( 'WHERE' ), SalStrLength( sSqlStatement ) - ( nSelectStart + SalStrLength( 'WHERE' ) ) )
							    Else 
								    Return ''
					! Function: ExtractGROUPBYPart
						    Description: 
						    Returns 
							    String: 
						    Parameters 
							    String: sSqlStatement
						    Static Variables 
						    Local variables 
							    Number: nSelectStart
							    Number: nEndTokenStart
						    Actions 
							    Set nSelectStart = SalStrScan( sSqlStatement, 'GROUP BY' )
							    If nSelectStart >= 0
								    Set nEndTokenStart = SalStrScan( sSqlStatement, 'HAVING' )
								    If nEndTokenStart >= 0
									    Return PrivateExtractBetweenTokens( nSelectStart, 'GROUP BY', nEndTokenStart, 'HAVING', sSqlStatement )
								    Else 
									    Set nEndTokenStart = SalStrScan( sSqlStatement, 'ORDER BY' )
									    If nEndTokenStart >= 0
										    Return PrivateExtractBetweenTokens( nSelectStart, 'GROUP BY', nEndTokenStart, 'ORDER BY', sSqlStatement )
									    Else 
										    Set nEndTokenStart = SalStrScan( sSqlStatement, 'FOR UPDATE OF' )
										    If nEndTokenStart >= 0
											    Return PrivateExtractBetweenTokens( nSelectStart, 'GROUP BY', nEndTokenStart, 'FOR UPDATE OF', sSqlStatement )
										    Else 
											    Set nEndTokenStart = SalStrScan( sSqlStatement, 'INTO' )
											    If nEndTokenStart >= nSelectStart
												    Return PrivateExtractBetweenTokens( nSelectStart, 'GROUP BY', nEndTokenStart, 'INTO', sSqlStatement )
											    Else 
												    Return SalStrMidX( sSqlStatement, nSelectStart + SalStrLength( 'GROUP BY' ), SalStrLength( sSqlStatement ) - ( nSelectStart + SalStrLength( 'GROUP BY' ) ) )
							    Else 
								    Return ''
					! Function: ExtractHAVINGPart
						    Description: 
						    Returns 
							    String: 
						    Parameters 
							    String: sSqlStatement
						    Static Variables 
						    Local variables 
							    Number: nSelectStart
							    Number: nEndTokenStart
						    Actions 
							    Set nSelectStart = SalStrScan( sSqlStatement, 'HAVING' )
							    If nSelectStart >= 0
								    Set nEndTokenStart = SalStrScan( sSqlStatement, 'ORDER BY' )
								    If nEndTokenStart >= 0
									    Return PrivateExtractBetweenTokens( nSelectStart, 'HAVING', nEndTokenStart, 'ORDER BY', sSqlStatement )
								    Else 
									    Set nEndTokenStart = SalStrScan( sSqlStatement, 'FOR UPDATE OF' )
									    If nEndTokenStart >= 0
										    Return PrivateExtractBetweenTokens( nSelectStart, 'HAVING', nEndTokenStart, 'FOR UPDATE OF', sSqlStatement )
									    Else 
										    Set nEndTokenStart = SalStrScan( sSqlStatement, 'INTO' )
										    If nEndTokenStart >= nSelectStart
											    Return PrivateExtractBetweenTokens( nSelectStart, 'HAVING', nEndTokenStart, 'INTO', sSqlStatement )
										    Else 
											    Return SalStrMidX( sSqlStatement, nSelectStart + SalStrLength( 'HAVING' ), SalStrLength( sSqlStatement ) - ( nSelectStart + SalStrLength( 'HAVING' ) ) )
							    Else 
								    Return ''
					! Function: ExtractORDERBYPart
						    Description: 
						    Returns 
							    String: 
						    Parameters 
							    String: sSqlStatement
						    Static Variables 
						    Local variables 
							    Number: nSelectStart
							    Number: nEndTokenStart
						    Actions 
							    Set nSelectStart = SalStrScan( sSqlStatement, 'ORDER BY' )
							    If nSelectStart >= 0
								    Set nEndTokenStart = SalStrScan( sSqlStatement, 'FOR UPDATE OF' )
								    If nEndTokenStart >= 0
									    Return PrivateExtractBetweenTokens( nSelectStart, 'ORDER BY', nEndTokenStart, 'FOR UPDATE OF', sSqlStatement )
								    Else 
									    Set nEndTokenStart = SalStrScan( sSqlStatement, 'INTO' )
									    If nEndTokenStart >= nSelectStart
										    Return PrivateExtractBetweenTokens( nSelectStart, 'ORDER BY', nEndTokenStart, 'INTO', sSqlStatement )
									    Else 
										    Return SalStrMidX( sSqlStatement, nSelectStart + SalStrLength( 'ORDER BY' ), SalStrLength( sSqlStatement ) - ( nSelectStart + SalStrLength( 'ORDER BY' ) ) )
							    Else 
								    Return ''
					! Function: ExtractFORUPDATEOFPart
						    Description: 
						    Returns 
							    String: 
						    Parameters 
							    String: sSqlStatement
						    Static Variables 
						    Local variables 
							    Number: nSelectStart
							    Number: nEndTokenStart
						    Actions 
							    Set nSelectStart = SalStrScan( sSqlStatement, 'FOR UPDATE OF' )
							    If nSelectStart >= 0
								    Set nEndTokenStart = SalStrScan( sSqlStatement, 'INTO' )
								    If nEndTokenStart >= nSelectStart
									    Return PrivateExtractBetweenTokens( nSelectStart, 'FOR UPDATE OF', nEndTokenStart, 'INTO', sSqlStatement )
								    Else 
									    Return SalStrMidX( sSqlStatement, nSelectStart + SalStrLength( 'FOR UPDATE OF' ), SalStrLength( sSqlStatement ) - ( nSelectStart + SalStrLength( 'FOR UPDATE OF' ) ) )
							    Else 
								    Return ''
					! Function: PrivateExtractBetweenTokens
						    Description: 
						    Returns 
							    String: 
						    Parameters 
							    Number: nFirstTokenStart
							    String: sFirstToken
							    Number: nSecondTokenStart
							    String: sSecondToken
							    String: sSqlStatement
						    Static Variables 
						    Local variables 
						    Actions 
							    Return SalStrMidX( sSqlStatement, nFirstTokenStart + SalStrLength( sFirstToken ), nSecondTokenStart - ( nFirstTokenStart + SalStrLength( sFirstToken ) ) )
					! Function: ExtractSqlWHEREBinds
						    Description: 
						    Returns 
						    Parameters 
							    String: sWHEREPart
							    Receive String: saBindVars[*]
						    Static Variables 
						    Local variables 
							    String: sTmpWHEREPart
							    Number: nWHEREPartLength
							    Number: nColonPos
							    String: sToken
							    String: sCurrentChar
							    Number: nPos
							    Boolean: bStop
						    Actions 
							    Set saBindVars[ 0 ] = ''
							    Set sTmpWHEREPart = sWHEREPart
							    While nColonPos >= 0
								    Set nColonPos = SalStrScan( sTmpWHEREPart, ':' )
								    If nColonPos >= 0
									    Set bStop = FALSE
									    Set sToken = ''
									    Set nPos = nColonPos + 1
									    Set nWHEREPartLength = SalStrLength( sTmpWHEREPart )
									    While nPos <= nWHEREPartLength AND NOT bStop
										    Set sCurrentChar = SalStrMidX( sTmpWHEREPart, nPos, 1 )
										    If sCurrentChar = ' ' OR sCurrentChar = ''
											    Set bStop = TRUE
										    Else 
											    Set sToken = sToken || sCurrentChar
										    Set nPos = nPos + 1
									!
									    Set sTmpWHEREPart = SalStrMidX( sTmpWHEREPart, nPos, SalStrLength( sTmpWHEREPart ) - nPos )
									!
									! insert sToken into a unique list
									    Set nPos = 0
									    Set bStop = FALSE
									    While saBindVars[ nPos ] != '' AND NOT bStop
										    If saBindVars[ nPos ] = sToken
											    Set bStop = TRUE
										    Set nPos = nPos + 1
									    If NOT bStop
										    Set saBindVars[ nPos ] = sToken
										    Set saBindVars[ nPos + 1 ] = ''
									!
					! Function: ConvertSqlSELECTToCommand
						    Description: 
						    Returns 
						    Parameters 
							    String: sSqlFullSELECTStatement
							    Receive String: sSqlStatement
							    Receive String: sName
							    Receive String: sBind
							    Receive String: sInto
						    Static Variables 
						    Local variables 
							    String: sSELECTPart
							    String: sFROMPart
							    String: sINTOPart
							    String: sWHEREPart
							    String: sGROUPBYPart
							    String: sHAVINGPart
							    String: sORDERBYPart
							    String: sFORUPDATEOFPart
							    String: saBindVars[*]
							    Number: nBindStartPos
							    Number: nPos
						    Actions 
							    Call OurWaitCursor( TRUE )
							    Set sSELECTPart = ExtractSELECTPart( sSqlFullSELECTStatement )
							    Set sFROMPart = ExtractFROMPart( sSqlFullSELECTStatement )
							    Set sINTOPart = ExtractINTOPart( sSqlFullSELECTStatement )
							    Set sWHEREPart = ExtractWHEREPart( sSqlFullSELECTStatement )
							    Set sGROUPBYPart = ExtractGROUPBYPart( sSqlFullSELECTStatement )
							    Set sHAVINGPart = ExtractHAVINGPart( sSqlFullSELECTStatement )
							    Set sORDERBYPart = ExtractORDERBYPart( sSqlFullSELECTStatement )
							    Set sFORUPDATEOFPart = ExtractFORUPDATEOFPart( sSqlFullSELECTStatement )
							!
							    Call ExtractSqlWHEREBinds( sWHEREPart, saBindVars )
							    Set sBind = ''
							!
							    Set nPos = 0
							    While saBindVars[ nPos ] != ''
								!
								    Set nBindStartPos = SalStrScan( sWHEREPart, saBindVars[ nPos ] )
								    If nBindStartPos >= 0
									    If sBind = ''
										    Set sBind = ':' || saBindVars[ nPos ]
									    Else 
										    Set sBind = sBind || ', :' || saBindVars[ nPos ]
									!
									! replace saBindVars[ nPos ] with nPos + 1 in sWHEREPart
									    Set sWHEREPart = SalStrMidX( sWHEREPart, 0, nBindStartPos ) || 
											SalNumberToStrX( nPos + 1, 0 ) || ' ' || 
											SalStrMidX( sWHEREPart, nBindStartPos + SalStrLength( saBindVars[ nPos ] ) + 1, SalStrLength( sWHEREPart ) - ( nBindStartPos + SalStrLength( saBindVars[ nPos ] )  ) )
								!
								    Set nPos = nPos + 1
							!
							    Set sName = GetTempCommandName( )
							    Set sInto = sINTOPart
							!
							    Set sSqlStatement = ''
							    If NOT sSELECTPart = ''
								    Set sSqlStatement = ' SELECT ' || sSELECTPart 
							    If NOT sFROMPart = ''
								    Set sSqlStatement = sSqlStatement || ' FROM ' || sFROMPart 
							    If NOT sWHEREPart = ''
								    Set sSqlStatement = sSqlStatement || ' WHERE ' || sWHEREPart 
							    If NOT sGROUPBYPart = ''
								    Set sSqlStatement = sSqlStatement || ' GROUP BY ' || sGROUPBYPart 
							    If NOT sHAVINGPart = ''
								    Set sSqlStatement = sSqlStatement || ' HAVING ' || sHAVINGPart 
							    If NOT sORDERBYPart = ''
								    Set sSqlStatement = sSqlStatement || ' ORDER BY ' || sORDERBYPart 
							    If NOT sFORUPDATEOFPart = ''
								    Set sSqlStatement = sSqlStatement || ' FOR UPDATE OF ' || sFORUPDATEOFPart 
							    Call OurWaitCursor( FALSE )

		Functions
		Window Parameters
		Window Variables
			Number: nPos
			Number: nRow
		Message Actions
			On SAM_CreateComplete
				Call OurWaitCursor( TRUE )
				Set nPos = 0
				While haSqlHandles[ nPos ].sHandleIdKey != ''
					If haSqlHandles[ nPos ].sHandleIdKey != ''
						Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
						Call SalTblSetContext( hWndForm, nRow )
						Call SalTblSetRowFlags( hWndForm, nRow, ROW_HideMarks, TRUE )
						!
						Set colPos = nPos
						Set colHandleIdKey = haSqlHandles[ nPos ].sHandleIdKey
						Set colHandleConnected = haSqlHandles[ nPos ].bHandleConnected
						Set colHandleRetrieved = haSqlHandles[ nPos ].bHandleRetrieved
						Set colHandleIDName = haSqlHandles[ nPos ].sIdName
						!
						If colHandleIdKey = ' '
							Set colHandleIdKey = '>' || colHandleIdKey || '<'
					Set nPos = nPos + 1
				Call OurWaitCursor( FALSE )

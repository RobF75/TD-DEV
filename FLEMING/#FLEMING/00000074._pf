			Functional Class: hcSqlHandle
				Description: Use : STORED COMMANDS METHOD
						  1 - hcSqlHandle.Setup( 'SELECT..', 'GETTOTAVAIL', ':nItemNo',':nGotTotAvail' ) 
						  2 - OPTIONAL hcSqlHandle.SetParam( timeout 30, resultset TRUE, preserve TRUE, fetchthroughFALSE )
						  3 - hcSqlHandle.SqlVarSetup( hcSqlHandle.hSqlHandle )
						  4 - hcSqlHandle.Execute( )
						  5 - hcSqlHandle.Commit OR Rollback OR FetchNext etc.
						  6 - hcSqlHandle.Disconnect( ) 
						OR SQL STATEMENT METHOD
						  1 - hcSqlHandle.PrepareSetup( 'SELECT..' )
						  2 - OPTIONAL hcSqlHandle.SetParam( timeout 30, resultset TRUE, preserve TRUE, fetchthroughFALSE )
						  3 - hcSqlHandle.SqlVarSetup( hcSqlHandle.hSqlHandle )
						  4 - hcSqlhandle.PrepareAndExecute( )
						  5 - hcSqlHandle.Commit OR Rollback OR FetchNext etc.
						  6 - hcSqlHandle.Disconnect( ) 
				Derived From
				Class Variables
				Instance Variables
					! Bellow instance variables are PUBLIC
					String: sIsolationLevel
					String: sSqlStatement
					Number: nCursorLockTimeout
					Boolean: bCursorResultSetMode
					Boolean: bCursorPreserve
					Boolean: bCursorFetchThrough
					! Bellow instance variable should ONLY be treated as public for the SqlVarSetup( )
					Sql Handle: hSqlHandle
					! Bellow instance variables should be treated as private
					String: sHandleIdKey
					Boolean: bHandleConnected
					Boolean: bHandleRetrieved
					Boolean: bHandleConverted
					String: sIdName
					String: sSqlBind
					String: sSqlInto
					!
					Boolean: bDefaultCursorParamSet
					Boolean: bIsolationLevelSet
				Functions
					! Bellow functions should be treated as public
					Function: Setup
						Description:
						Returns
							Boolean:
						Parameters
							String: sStatement
							String: sName
							String: sBind
							String: sInto
						Static Variables
						Local variables
							Boolean: bOk
						Actions
							Call OurWaitCursor( TRUE )
							Set bOk = TRUE
							Set sSqlStatement = sStatement
							Set sIdName = sName
							Set sSqlBind = sBind
							Set sSqlInto = sInto
							If Connect(  )
								If NOT Retrieve(  )
									Set bOk = FALSE
							Else
								Set bOk = FALSE
							Call OurWaitCursor( FALSE )
							Return bOk
					Function: PrepareSetup
						Description:
						Returns
							Boolean:
						Parameters
							String: sStatement
						Static Variables
						Local variables
							Boolean: bOk
						Actions
							Call OurWaitCursor( TRUE )
							Set bOk = TRUE
							If Connect(  )
								Set sSqlStatement = sStatement
								If NOT Prepare( )
									Set bOk = FALSE
								! bellow 2 line replace with 2 above line when ConvertSql can handle UPDATEs INSERTS and DELETES 
										and traps case of changing SqlStatement on repedative calls. ( needs to drop current command and create a new one )
								! If NOT bHandleConverted
									    Call ConvertSqlSELECTToCommand( sStatement, sSqlStatement, sIdName, sSqlBind, sSqlInto )
									    Set bHandleConverted = TRUE
								! If NOT Retrieve(  )
									    Set bOk = FALSE
							Else
								Set bOk = FALSE
							Call OurWaitCursor( FALSE )
							Return bOk
					Function: SetParam
						Description:
						Returns
							Boolean:
						Parameters
							Number: nTimeout
							Boolean: bResultSetMode
							Boolean: bPreserve
							Boolean: bFetchThrough
							String: sNewIsolationLevel
						Static Variables
						Local variables
							Boolean: bOk
						Actions
							Set nCursorLockTimeout = nTimeout
							Set bCursorResultSetMode = bResultSetMode
							Set bCursorPreserve = bPreserve
							Set bCursorFetchThrough = bFetchThrough
							Set sIsolationLevel = sNewIsolationLevel
							!
							Set bOk = TRUE
							If NOT bIsolationLevelSet = TRUE
								If SetIsolationLevel( sIsolationLevel )
									Set bIsolationLevelSet = TRUE
								Else
									Set bOk = FALSE
							If NOT SetTimeOut( nCursorLockTimeout )
								Set bOk = FALSE
							! If NOT bCursorResultSetMode = TRUE
								    If NOT SetResultSetMode( bCursorResultSetMode )
									    Set bOk = FALSE
							!
							If NOT SetResultSetMode( bCursorResultSetMode )
								Set bOk = FALSE
							!
							If NOT SetContextPreserve( bCursorPreserve )
								Set bOk = FALSE
							If NOT SetFetchThrough( bCursorFetchThrough )
								Set bOk = FALSE
							Return bOk
					Function: SetTimeOut
						Description:
						Returns
							Boolean:
						Parameters
							Number: nTimeout
						Static Variables
						Local variables
						Actions
							Set nCursorLockTimeout = nTimeout
							If Connect( )
								Return SqlSetLockTimeout( hSqlHandle, nCursorLockTimeout )
							Else
								Return FALSE
					Function: SetResultSetMode
						Description:
						Returns
							Boolean:
						Parameters
							Boolean: bResultSetMode
						Static Variables
						Local variables
						Actions
							Set bCursorResultSetMode = bResultSetMode
							If Connect( )
								Return SqlSetResultSet( hSqlHandle, bCursorResultSetMode )
							Else
								Return FALSE
					Function: SetContextPreserve
						Description:
						Returns
							Boolean:
						Parameters
							Boolean: bPreserve
						Static Variables
						Local variables
						Actions
							Set bCursorPreserve = bPreserve
							If Connect( )
								Return SqlSetParameter( hSqlHandle, DBP_PRESERVE, bCursorPreserve, ''  )
							Else
								Return FALSE
					Function: SetFetchThrough
						Description:
						Returns
							Boolean:
						Parameters
							Boolean: bFetchThrough
						Static Variables
						Local variables
						Actions
							Set bCursorFetchThrough = bFetchThrough
							If Connect( )
								Return SqlSetParameter( hSqlHandle, DBP_FETCHTHROUGH, bCursorFetchThrough, ''  )
							Else
								Return FALSE
					Function: SetIsolationLevel
						Description:
						Returns
							Boolean:
						Parameters
							String: sNewIsolationLevel
						Static Variables
						Local variables
						Actions
							Set sIsolationLevel = sNewIsolationLevel
							If Connect( )
								Return SqlSetIsolationLevel( hSqlHandle, sIsolationLevel )
							Else
								Return FALSE
					Function: Execute
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
							Boolean: bOk
							Boolean: bFirst
							Boolean: bErrorTrapped
							Number: nHandleError
							Number: nPos
						Actions
							Call OurWaitCursor( TRUE )
							Set bFirst = TRUE
							Set bErrorTrapped = FALSE
							Set bOk = TRUE
							Loop Execute
								If Connect(  )
									If Retrieve(  )
										When SqlError
											Call SqlExtractArgs( wParam, lParam, hSqlHandle, nHandleError, nPos )
											! timeout, deadlock, no compiled command
											If nHandleError = -1805 OR nHandleError = 1805 OR 
													   nHandleError = -1801 OR nHandleError = 1801 OR 
													   nHandleError = -201 OR nHandleError = 201
												Set bErrorTrapped = TRUE
												Return FALSE
										If SqlExecute( hSqlHandle )
											Break Execute
										Else
											If bErrorTrapped = TRUE
												If nHandleError = 1805 OR nHandleError = -1805
													! time out
													If IDNO = SalMessageBox( 'TIME OUT has occurred! Please contact Computer Services to resolve this! RETRY?', 'Error', MB_YesNo )
														Set bOk = FALSE
														Break Execute
													Else
														Set bHandleRetrieved = FALSE
												Else If nHandleError = 1801 OR nHandleError = -1801
													! dead lock -1801
													If IDNO = SalMessageBox( 'DEAD LOCK has occurred! Please contact Computer Services to resolve this! RETRY?', 'Error', MB_YesNo )
														Set bOk = FALSE
														Break Execute
													Else
														Set bHandleRetrieved = FALSE
												Else If nHandleError = 201 OR nHandleError = -201
													! no compiled command  201
													If bFirst
														Set bHandleRetrieved = FALSE
														Set bFirst = FALSE
													Else
														If IDNO = SalMessageBox( 'NO COMPILED COMMAND has occurred! Please contact Computer Services to resolve this! RETRY?', 'Error', MB_YesNo )
															Set bOk = FALSE
															Break Execute
														Else
															Set bHandleRetrieved = FALSE
											Else
												If IDNO = SalMessageBox( 'Could not execute Statement Named '||sIdName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													Set bOk = FALSE
													Break Execute
												Else
													Set bHandleRetrieved = FALSE
									Else
										Set bOk = FALSE
										Break Execute
								Else
									Set bOk = FALSE
									Break Execute
							Call OurWaitCursor( FALSE )
							Return bOk
					! Function: PrepareAndExecute
						    Description: 
						    Returns 
							    Boolean: 
						    Parameters 
						    Static Variables 
						    Local variables 
						    Actions 
							    Return Execute( )
					! uncomment above function and comment bellow function when ConvertSql can handle UPDATE, INSERTS AND DELETES
					Function: PrepareAndExecute
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
							Boolean: bOk
							Boolean: bFirst
							Boolean: bErrorTrapped
							Number: nHandleError
							Number: nPos
						Actions
							Call OurWaitCursor( TRUE )
							Set bFirst = TRUE
							Set bErrorTrapped = FALSE
							Set bOk = TRUE
							Loop Execute
								If Connect(  )
									If Prepare(  )
										When SqlError
											Call SqlExtractArgs( wParam, lParam, hSqlHandle, nHandleError, nPos )
											! timeout, deadlock, no compiled command
											If nHandleError = -1805 OR nHandleError = 1805 OR 
													   nHandleError = -1801 OR nHandleError = 1801 OR 
													   nHandleError = -201 OR nHandleError = 201
												Set bErrorTrapped = TRUE
												Return FALSE
										If SqlExecute( hSqlHandle )
											Break Execute
										Else
											If bErrorTrapped = TRUE
												If nHandleError = 1805 OR nHandleError = -1805
													! time out
													If IDNO = SalMessageBox( 'TIME OUT has occurred! Please contact Computer Services to resolve this! RETRY?', 'Error', MB_YesNo )
														Set bOk = FALSE
														Break Execute
													Else
														Set bHandleRetrieved = FALSE
												Else If nHandleError = 1801 OR nHandleError = -1801
													! dead lock -1801
													If IDNO = SalMessageBox( 'DEAD LOCK has occurred! Please contact Computer Services to resolve this! RETRY?', 'Error', MB_YesNo )
														Set bOk = FALSE
														Break Execute
													Else
														Set bHandleRetrieved = FALSE
												Else If nHandleError = 201 OR nHandleError = -201
													! no compiled command  201
													If bFirst
														Set bHandleRetrieved = FALSE
														Set bFirst = FALSE
													Else
														If IDNO = SalMessageBox( 'NO COMPILED COMMAND has occurred! Please contact Computer Services to resolve this! RETRY?', 'Error', MB_YesNo )
															Set bOk = FALSE
															Break Execute
														Else
															Set bHandleRetrieved = FALSE
											Else
												If IDNO = SalMessageBox( 'Could not execute Statement Named '||sSqlStatement||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													Set bOk = FALSE
													Break Execute
												Else
													Set bHandleRetrieved = FALSE
									Else
										Set bOk = FALSE
										Break Execute
								Else
									Set bOk = FALSE
									Break Execute
							Call OurWaitCursor( FALSE )
							Return bOk
					Function: RePrepare
						Description:
						Returns
						Parameters
						Static Variables
						Local variables
						Actions
							Set bHandleRetrieved = FALSE
					!
					Function: Disconnect
						Description:
						Returns
						Parameters
						Static Variables
						Local variables
							Number: nTotalReuseConnected
							Number: nTmp
						Actions
							If bHandleConnected AND bHandleConverted
								If DropStoredCmd( )
									Call Commit(  )
							Call GetSqlHandlesStats( nTmp, nTotalReuseConnected, nTmp, nTmp )
							If nTotalReuseConnected  > 5
								Call DisconnectClose(  )
							Else
								Call ReuseInit(  )
								Call Commit(  )
					Function: Commit
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
							Boolean: bOk
						Actions
							Call OurWaitCursor( TRUE )
							Set bOk = TRUE
							Loop Commit
								If bHandleConnected = TRUE
									If SqlCommit( hSqlHandle )
										Break Commit
									Else
										If IDNO = SalMessageBox( 'Could not commit handle for '||sSqlStatement||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
											Set bOk = FALSE
											Break Commit
								Else
									Break Commit
							Call OurWaitCursor( FALSE )
							Return bOk
					Function: Rollback
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
							Boolean: bOk
						Actions
							Call OurWaitCursor( TRUE )
							Set bOk = TRUE
							Loop Rollback
								If bHandleConnected = TRUE
									Set bHandleRetrieved = FALSE
									If SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
										Break Rollback
									Else
										If IDNO = SalMessageBox( 'Could not rollback handle in function '||sSqlStatement||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
											Set bOk = FALSE
											Break Rollback
								Else
									Break Rollback
							Call OurWaitCursor( FALSE )
							Return bOk
					!
					Function: FetchFirst
						Description:
						Returns
							Boolean:
						Parameters
							Receive Number: nInd
						Static Variables
						Local variables
						Actions
							Return SqlFetchRow( hSqlHandle, 0, nInd )
					Function: FetchNext
						Description:
						Returns
							Boolean:
						Parameters
							Receive Number: nInd
						Static Variables
						Local variables
						Actions
							Return SqlFetchNext( hSqlHandle, nInd )
					Function: FetchPrevious
						Description:
						Returns
							Boolean:
						Parameters
							Receive Number: nInd
						Static Variables
						Local variables
						Actions
							Return SqlFetchPrevious( hSqlHandle, nInd )
					Function: FetchRow
						Description:
						Returns
							Boolean:
						Parameters
							Number: nRow
							Receive Number: nInd
						Static Variables
						Local variables
						Actions
							Return SqlFetchRow( hSqlHandle, nRow, nInd )
					Function: GetModifiedRows
						Description:
						Returns
							Number:
						Parameters
						Static Variables
						Local variables
							Number: nModifiedRows
						Actions
							Call SqlGetModifiedRows( hSqlHandle, nModifiedRows )
							Return nModifiedRows
					!
					! Bellow function should be treated as private
					!
					Function: Init
						Description:
						Returns
						Parameters
						Static Variables
						Local variables
						Actions
							Set sSqlStatement = ''
							Set sHandleIdKey = ' '
							Set bHandleConnected = FALSE
							Set bHandleRetrieved = FALSE
							Set bHandleConverted = FALSE
							Set sIdName = ''
							Set sSqlBind = ''
							Set sSqlInto = ''
					Function: ReuseInit
						Description:
						Returns
						Parameters
						Static Variables
						Local variables
						Actions
							Set sSqlStatement = ''
							Set sHandleIdKey = ' '
							Set bHandleRetrieved = FALSE
							Set bHandleConverted = FALSE
							Set sIdName = ''
							Set sSqlBind = ''
							Set sSqlInto = ''
							Call SetDefaultParam(  )
							If SetParam( nCursorLockTimeout, bCursorResultSetMode, bCursorPreserve, bCursorFetchThrough, sIsolationLevel )
								Set bDefaultCursorParamSet = TRUE
					Function: Connect
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
							Boolean: bOk
						Actions
							Call OurWaitCursor( TRUE )
							Set bOk = TRUE
							Loop Connect
								If bHandleConnected = TRUE
									Break Connect
								Else
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected = TRUE
										If NOT bDefaultCursorParamSet = TRUE
											Call SetDefaultParam(  )
										If SetParam( nCursorLockTimeout, bCursorResultSetMode, bCursorPreserve, bCursorFetchThrough, sIsolationLevel )
											Set bDefaultCursorParamSet = TRUE
										Set bHandleRetrieved = FALSE
										Break Connect
									Else
										If IDNO = SalMessageBox( 'Could not connect handle for Command '||sIdName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
											Set bOk = FALSE
											Break Connect
							Call OurWaitCursor( FALSE )
							Return bOk
					Function: SetDefaultParam
						Description:
						Returns
						Parameters
						Static Variables
						Local variables
						Actions
							Set nCursorLockTimeout = SH_cls_SQLTIMEOUT
							Set bCursorResultSetMode = TRUE
							Set bCursorPreserve = TRUE
							Set bCursorFetchThrough = FALSE
							Set sIsolationLevel = 'RL'
					Function: DisconnectClose
						Description:
						Returns
						Parameters
						Static Variables
						Local variables
						Actions
							Call OurWaitCursor( TRUE )
							Loop Disconnect
								If bHandleConnected
									If SqlDisconnect( hSqlHandle )
										Call Init( )
										Break Disconnect
									Else
										If IDNO = SalMessageBox( 'Could not disconnect handle in function '||sSqlStatement||'Contact programmers! RETRY?', 'Error', MB_YesNo )
											Break Disconnect
								Else
									Call Init(  )
									Break Disconnect
							Call OurWaitCursor( FALSE )
					Function: DropStoredCmd
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
							Boolean: bOk
						Actions
							Call OurWaitCursor( TRUE )
							Set bOk = TRUE
							Loop Drop
								If bHandleConnected = TRUE
									If SqlDropStoredCmd( hSqlHandle, sIdName )
										Break Drop
									Else
										If IDNO = SalMessageBox( 'Could not drop stored command for '||sSqlStatement||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
											Set bOk = FALSE
											Break Drop
								Else
									Break Drop
							Call OurWaitCursor( FALSE )
							Return bOk
					!
					Function: Retrieve
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
							Boolean: bOk
							Boolean: bFirst
						Actions
							Call OurWaitCursor( TRUE )
							Set bOk = TRUE
							Set bFirst = TRUE
							Loop Retrieve
								If bHandleRetrieved = TRUE
									Break Retrieve
								Else
									When SqlError
										Return FALSE
									If SqlRetrieve( hSqlHandle, sIdName, sSqlBind, sSqlInto )
										Set bHandleRetrieved = TRUE
										Break Retrieve
									Else
										If bFirst
											Set bFirst = FALSE
											Call Store(  )
										Else
											If IDNO = SalMessageBox( 'Could not Retrieve Command '||sIdName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												Set bOk = FALSE
												Break Retrieve
							Call OurWaitCursor( FALSE )
							Return bOk
					Function: Prepare
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
							Boolean: bOk
						Actions
							Call OurWaitCursor( TRUE )
							Set bOk = TRUE
							Loop Prepare
								If bHandleRetrieved = TRUE
									Break Prepare
								Else
									When SqlError
										Return FALSE
									If SqlPrepare( hSqlHandle, sSqlStatement )
										Set bHandleRetrieved = TRUE
										Break Prepare
									Else
										If IDNO = SalMessageBox( 'Could not Prepare Command '||sSqlStatement||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
											Set bOk = FALSE
											Break Prepare
							Call OurWaitCursor( FALSE )
							Return bOk
					Function: Store
						Description:
						Returns
							Boolean:
						Parameters
						Static Variables
						Local variables
							Boolean: bOk
						Actions
							Call OurWaitCursor( TRUE )
							Set bOk = TRUE
							Loop Store
								If SqlStore( hSqlHandle, sIdName, sSqlStatement )
									Call SqlCommit( hSqlHandle )
									Break Store
								Else
									If IDNO = SalMessageBox( 'Could not Store Command '||sIdName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
										Set bOk = FALSE
										Break Store
							Call OurWaitCursor( FALSE )
							Return bOk
					!
					Function: TablePopulate
						Description: Assumes that Setup( ) and SetSqlVars( ) and Execute( ) have been run before.
						Returns
							Boolean:
						Parameters
							Window Handle: hWndTable
							Number: nMethod
						Static Variables
						Local variables
							Boolean: bOk
						Actions
							Call OurWaitCursor( TRUE )
							Set bOk = TRUE
							Call SalTblReset( hWndTable )
							If NOT SalTblPopulate( hWndTable, hSqlHandle, '', nMethod )
								Set bOk = FALSE
							Call OurWaitCursor( FALSE )
							Return bOk
					Function: ResultSetCount
						Description:
						Returns
							Boolean:
						Parameters
							Receive Number: nCount
						Static Variables
						Local variables
							Boolean: bOk
						Actions
							Call OurWaitCursor( TRUE )
							Set bOk = SqlGetResultSetCount( hSqlHandle, nCount )
							Call OurWaitCursor( FALSE )
							Return bOk
					!
					! uncomment bellow functions when ConvertSql can handle UPDATES, INSERTS, and DELETES
					! Function: ExtractSELECTPart
						    Description: 
						    Returns 
							    String: 
						    Parameters 
							    String: sSqlStatement
						    Static Variables 
						    Local variables 
							    Number: nSelectStart
							    Number: nEndTokenStart
						    Actions 
							    Set nSelectStart = SalStrScan( sSqlStatement, 'SELECT' )
							    If nSelectStart >= 0
								    Set nEndTokenStart = SalStrScan( sSqlStatement, 'FROM' )
								    If nEndTokenStart >= 0
									    Return PrivateExtractBetweenTokens( nSelectStart, 'SELECT', nEndTokenStart, 'FROM', sSqlStatement )
								    Else 
									    Set nEndTokenStart = SalStrScan( sSqlStatement, 'INTO' )
									    If nEndTokenStart >= 0
										    Return PrivateExtractBetweenTokens( nSelectStart, 'SELECT', nEndTokenStart, 'INTO', sSqlStatement )
									    Else 
										    Set nEndTokenStart = SalStrScan( sSqlStatement, 'WHERE' )
										    If nEndTokenStart >= 0
											    Return PrivateExtractBetweenTokens( nSelectStart, 'SELECT', nEndTokenStart, 'WHERE', sSqlStatement  )
										    Else 
											    Set nEndTokenStart = SalStrScan( sSqlStatement, 'GROUP BY' )
											    If nEndTokenStart >= 0
												    Return PrivateExtractBetweenTokens( nSelectStart, 'SELECT', nEndTokenStart, 'GROUP BY', sSqlStatement )
											    Else 
												    Set nEndTokenStart = SalStrScan( sSqlStatement, 'HAVING' )
												    If nEndTokenStart >= 0
													    Return PrivateExtractBetweenTokens( nSelectStart, 'SELECT', nEndTokenStart, 'HAVING', sSqlStatement )
												    Else 
													    Set nEndTokenStart = SalStrScan( sSqlStatement, 'ORDER BY' )
													    If nEndTokenStart >= 0
														    Return PrivateExtractBetweenTokens( nSelectStart, 'SELECT', nEndTokenStart, 'ORDER BY', sSqlStatement )
													    Else 
														    Set nEndTokenStart = SalStrScan( sSqlStatement, 'FOR UPDATE OF' )
														    If nEndTokenStart >= 0
															    Return PrivateExtractBetweenTokens( nSelectStart, 'SELECT', nEndTokenStart, 'FOR UPDATE OF', sSqlStatement )
														    Else 
															    Return SalStrMidX( sSqlStatement, nSelectStart + SalStrLength( 'SELECT' ), SalStrLength( sSqlStatement ) - ( nSelectStart + SalStrLength( 'SELECT' ) ) )
							    Else 
								    Return ''
					! Function: ExtractFROMPart
						    Description: 
						    Returns 
							    String: 
						    Parameters 
							    String: sSqlStatement
						    Static Variables 
						    Local variables 
							    Number: nSelectStart
							    Number: nEndTokenStart
						    Actions 
							    Set nSelectStart = SalStrScan( sSqlStatement, 'FROM' )
							    If nSelectStart >= 0
								    Set nEndTokenStart = SalStrScan( sSqlStatement, 'INTO' )
								    If nEndTokenStart >= 0
									    Return PrivateExtractBetweenTokens( nSelectStart, 'FROM', nEndTokenStart, 'INTO', sSqlStatement )
								    Else 
									    Set nEndTokenStart = SalStrScan( sSqlStatement, 'WHERE' )
									    If nEndTokenStart >= 0
										    Return PrivateExtractBetweenTokens( nSelectStart, 'FROM', nEndTokenStart, 'WHERE', sSqlStatement  )
									    Else 
										    Set nEndTokenStart = SalStrScan( sSqlStatement, 'GROUP BY' )
										    If nEndTokenStart >= 0
											    Return PrivateExtractBetweenTokens( nSelectStart, 'FROM', nEndTokenStart, 'GROUP BY', sSqlStatement )
										    Else 
											    Set nEndTokenStart = SalStrScan( sSqlStatement, 'HAVING' )
											    If nEndTokenStart >= 0
												    Return PrivateExtractBetweenTokens( nSelectStart, 'FROM', nEndTokenStart, 'HAVING', sSqlStatement )
											    Else 
												    Set nEndTokenStart = SalStrScan( sSqlStatement, 'ORDER BY' )
												    If nEndTokenStart >= 0
													    Return PrivateExtractBetweenTokens( nSelectStart, 'FROM', nEndTokenStart, 'ORDER BY', sSqlStatement )
												    Else 
													    Set nEndTokenStart = SalStrScan( sSqlStatement, 'FOR UPDATE OF' )
													    If nEndTokenStart >= 0
														    Return PrivateExtractBetweenTokens( nSelectStart, 'FROM', nEndTokenStart, 'FOR UPDATE OF', sSqlStatement )
													    Else 
														    Return SalStrMidX( sSqlStatement, nSelectStart + SalStrLength( 'FROM' ), SalStrLength( sSqlStatement ) - ( nSelectStart + SalStrLength( 'FROM' ) ) )
							    Else 
								    Return ''
					! Function: ExtractINTOPart
						    Description: 
						    Returns 
							    String: 
						    Parameters 
							    String: sSqlStatement
						    Static Variables 
						    Local variables 
							    Number: nSelectStart
							    Number: nEndTokenStart
						    Actions 
							    Set nSelectStart = SalStrScan( sSqlStatement, 'INTO' )
							    If nSelectStart >= 0
								    Set nEndTokenStart = SalStrScan( sSqlStatement, 'WHERE' )
								    If nEndTokenStart >= 0
									    Return PrivateExtractBetweenTokens( nSelectStart, 'INTO', nEndTokenStart, 'WHERE', sSqlStatement  )
								    Else 
									    Set nEndTokenStart = SalStrScan( sSqlStatement, 'GROUP BY' )
									    If nEndTokenStart >= 0
										    Return PrivateExtractBetweenTokens( nSelectStart, 'INTO', nEndTokenStart, 'GROUP BY', sSqlStatement )
									    Else 
										    Set nEndTokenStart = SalStrScan( sSqlStatement, 'HAVING' )
										    If nEndTokenStart >= 0
											    Return PrivateExtractBetweenTokens( nSelectStart, 'INTO', nEndTokenStart, 'HAVING', sSqlStatement )
										    Else 
											    Set nEndTokenStart = SalStrScan( sSqlStatement, 'ORDER BY' )
											    If nEndTokenStart >= 0
												    Return PrivateExtractBetweenTokens( nSelectStart, 'INTO', nEndTokenStart, 'ORDER BY', sSqlStatement )
											    Else 
												    Set nEndTokenStart = SalStrScan( sSqlStatement, 'FOR UPDATE OF' )
												    If nEndTokenStart >= 0
													    Return PrivateExtractBetweenTokens( nSelectStart, 'INTO', nEndTokenStart, 'FOR UPDATE OF', sSqlStatement )
												    Else 
													    Return SalStrMidX( sSqlStatement, nSelectStart + SalStrLength( 'INTO' ), SalStrLength( sSqlStatement ) - ( nSelectStart + SalStrLength( 'INTO' ) ) )
							    Else 
								    Return ''
					! Function: ExtractWHEREPart
						    Description: 
						    Returns 
							    String: 
						    Parameters 
							    String: sSqlStatement
						    Static Variables 
						    Local variables 
							    Number: nSelectStart
							    Number: nEndTokenStart
						    Actions 
							    Set nSelectStart = SalStrScan( sSqlStatement, 'WHERE' )
							    If nSelectStart >= 0
								    Set nEndTokenStart = SalStrScan( sSqlStatement, 'GROUP BY' )
								    If nEndTokenStart >= 0

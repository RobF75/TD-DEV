		Application Actions
			On SAM_AppStartup
				!
				! ASSUMPTION FOR Command Line arguments
						Argument 1 - SqlDatabase
						Argument 2 - SqlUser
						Argument 3 - SqlPassword
						Argument 4 - File Name for list of selected item numbers
						Argument 5 - Number of Customers (number)
						Argument 6 - Customer No (only if 1 Customer selected)
						Argument 7 - Year ( number )
						Argument 8 - bCount (Boolean)
						Argument 9 - Action Type ( string ) = ( 'SELECTED' OR 'ALL' OR 'ORCHADISTS' OR 'GARDENCENTRES' )
						Argument 10 - Report Type CONF or ACK or NPA or PRC
						Argument 11 - TreeType ( string ) = ('ALLTREES', 'ALLTRESSNOCONT', 'CONTONLY' )
						Argument 12 - ForceItemisedAck ( boolean )
				!
				!
				! Set strArgArray[1] = 'STOCKDEV'
				! Set strArgArray[2] = 'GRAHAM'
				! Set strArgArray[3] = 'GRAHAM'
				! Set strArgArray[4] = 'C:\\TEMP\\CUSTOMER.TMP'
				! Set strArgArray[5] = '1'
				! Set strArgArray[6] = '0'
				! Set strArgArray[7] = '1998'
				! Set strArgArray[8] = '1'
				! Set strArgArray[9] = '44'
				! Set strArgArray[10] = 'CONF'
				! Set strArgArray[11] = 'ALLTREES'
				! Set strArgArray[12] = '0'
				!
				!
				! Set strArgArray[1] = 'STOCKDEV'
				! Set strArgArray[2] = 'GRAHAM'
				! Set strArgArray[3] = 'GRAHAM'
				! Set strArgArray[4] = 'BLANK'
				! Set strArgArray[5] = '0'
				! Set strArgArray[6] = '0'
				! Set strArgArray[7] = '1998'
				! Set strArgArray[8] = '1'
				! Set strArgArray[9] = '45'
				! Set strArgArray[10] = 'NPA'
				! Set strArgArray[11] = 'ALLTREES'
				! Set strArgArray[12] = '0'
				!
				Set strArgArray[1] = 'STOCKDEV'
				Set strArgArray[2] = 'GRAHAM'
				Set strArgArray[3] = 'GRAHAM'
				Set strArgArray[4] = 'BLANK'
				Set strArgArray[5] = '0'
				Set strArgArray[6] = '0'
				Set strArgArray[7] = '1998'
				Set strArgArray[8] = '1'
				Set strArgArray[9] = '45'
				Set strArgArray[10] = 'PRC'
				Set strArgArray[11] = 'ALLTREES'
				Set strArgArray[12] = '0'
				!
				! Set strArgArray[1] = 'STOCKDEV'
				! Set strArgArray[2] = 'GRAHAM'
				! Set strArgArray[3] = 'GRAHAM'
				! Set strArgArray[4] = 'ONECUST'
				! Set strArgArray[5] = '1'
				! Set strArgArray[6] = '210615'
				! Set strArgArray[7] = '1998'
				! Set strArgArray[8] = '1'
				! Set strArgArray[9] = '85'
				! Set strArgArray[10] = 'ACK'
				! Set strArgArray[11] = 'ALLTREES'
				! Set strArgArray[12] = '0'
				!
				!
				! Set strArgArray[1] = 'STOCK'
				! Set strArgArray[2] = 'JAN'
				! Set strArgArray[3] = 'JAN'
				! Set strArgArray[4] = 'ONECUST'
				! Set strArgArray[5] = '1'
				! Set strArgArray[6] = '611287'
				! Set strArgArray[7] = '1997'
				! Set strArgArray[8] = '0'
				! Set strArgArray[9] = '59'
				! Set strArgArray[10] = 'CONF'
				! Set strArgArray[11] = 'ALLTREESNOCONT'
				! Set strArgArray[12] = '0'
				!
				! Set strArgArray[1] = 'STOCKDEV'
				! Set strArgArray[2] = 'GRAHAM'
				! Set strArgArray[3] = 'GRAHAM'
				! Set strArgArray[4] = 'BLANK'
				! Set strArgArray[5] = '0'
				! Set strArgArray[6] = '0'
				! Set strArgArray[7] = '1998'
				! Set strArgArray[8] = '1'
				! Set strArgArray[9] = '85'
				! Set strArgArray[10] = 'CONF'
				! Set strArgArray[11] = 'ALLTREES'
				! Set strArgArray[12] = '0'
				!
				! Set strArgArray[1] = 'STOCKDEV'
				! Set strArgArray[2] = 'GRAHAM'
				! Set strArgArray[3] = 'GRAHAM'
				! Set strArgArray[4] = 'ONECUST'
				! Set strArgArray[5] = '1'
				! Set strArgArray[6] = '333451'
				! Set strArgArray[7] = '1998'
				! Set strArgArray[8] = '0'
				! Set strArgArray[9] = '59'
				! Set strArgArray[10] = 'NPA'
				! Set strArgArray[11] = 'ALLTREES'
				! Set strArgArray[12] = '0'
				!
				! Set strArgArray[1] = 'STOCK'
				! Set strArgArray[2] = 'JAN'
				! Set strArgArray[3] = 'JAN'
				! Set strArgArray[4] = 'D:\\TEMP\\AMANDACONF.TXT'
				! Set strArgArray[5] = '27'
				! Set strArgArray[6] = ''
				! Set strArgArray[7] = '1997'
				! Set strArgArray[8] = '0'
				! Set strArgArray[9] = '44'
				! Set strArgArray[10] = 'CONF'
				! Set strArgArray[11] = 'ALLTREESNOCONT'
				! Set strArgArray[12] = '0'
				!
				Set SqlDatabase = strArgArray[ 1 ]
				Set SqlUser = strArgArray[ 2 ]
				Set SqlPassword = strArgArray[ 3 ]
				!
				Set bghSqlDetail = SqlConnect( hSqlDetail )
				If bghSqlDetail
					Call SqlSetIsolationLevel( hSqlDetail,'RL')
					Call SqlSetLockTimeout( hSqlDetail, SQLTIMEOUT )
				!
				Set sFileName = strArgArray[ 4 ]
				Set nNumCust = SalStrToNumber( strArgArray[ 5 ] )
				Set nCustNumber = SalStrToNumber( strArgArray[ 6 ] )
				If sFileName = 'ONECUST'
					Set nCustNos[0] = nCustNumber
				Set nYear = SalStrToNumber( strArgArray[ 7 ] )
				If strArgArray[ 8 ] = '1'
					Set bCount = TRUE
				Else
					Set bCount = FALSE
				Set nActionType= SalStrToNumber( strArgArray[ 9 ] )
				If nActionType = nSelectedCustomers
					If NOT ReadNumArrayListFromFile( sFileName, nCustNos )
						Call SalMessageBox('Error in Printing Customer Reports.
								Contact Programmers','System Message',MB_Ok)
						Return FALSE
				Set sType = strArgArray[ 10 ]
				Set sTreeTypes = strArgArray[ 11 ]
				If strArgArray[ 12 ] = '1'
					Set bForceItemisedAck = TRUE
				Else
					Set bForceItemisedAck = FALSE
				!
				If sType = 'CONF'
					If nActionType = nSingleCustomer
						Set nActionType = nSelectedCustomers
					Call SalCreateWindow( frmPrintConfs, hWndNULL, nCustNos,
							nNumCust, nYear, bCount, nActionType, sTreeTypes, FALSE )
				Else If sType = 'ACK'
					If nActionType = nSingleCustomer
						Set nActionType = nSelectedCustomers
					Call SalCreateWindow( frmPrintAcknowlegments, hWndNULL, nCustNos,
							nNumCust, nYear, bCount, nActionType, sTreeTypes, bForceItemisedAck )
				Else If sType = 'NPA'
					If nActionType = nSingleCustomer
						Set nActionType = nSelectedCustomers
					Call SalCreateWindow( frmPrintCustomerNPAs, hWndNULL, nCustNos, nNumCust, nYear, nActionType )
				Else If sType = 'PRC'
					If nActionType = nSingleCustomer
						Set nActionType = nSelectedCustomers
					Call SalCreateWindow( frmPrintCustomerPRCs, hWndNULL, nCustNos, nNumCust, nYear, nActionType )
				Else
					Call SalMessageBox('Error in Printing Customer Reports.
							Contact Programmers','System Message',MB_Ok)
					Call SalQuit(  )
			On SAM_AppExit
				If bghSqlDetail
					Call SqlDisconnect( hSqlDetail )

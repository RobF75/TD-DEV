					Column: colMeetId
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class: OurColumnClass
						Property Template:
						Class DLL Name:
						Title: Meet Id
						Visible? No
						Editable? No
						Maximum Data Length: Class Default

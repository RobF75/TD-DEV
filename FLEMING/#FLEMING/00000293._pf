							On PAM_SETINSTANCEVARS
								Set OurColumnClass.sSQLCOLNAME = ' LOAD.LOAD_ID '
								Set OurColumnClass.bRenewRowId = TRUE
								Set OurColumnClass.bUpdate = FALSE
								Set OurColumnClass.bReportColumn = TRUE
								Set OurColumnClass.bOrderBy = TRUE
							On PAM_EDITCHECK
								If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
									Return TRUE
								Else
									Return FALSE
							On PAM_CHECKROWNEW
								If LoadIdExists( colLoadId, nExecute )
									Call ErrorMessage( 'This Load Id already exists in this table! Please rectify!', hWndForm, lParam )
									Return FALSE
								Else
									Return TRUE
							On PAM_CHECKROWDELETED
								Call CheckLoadCustExist( colLoadId, bExists, nExecute )
								If bExists
									Call ErrorMessage( 'This Load still has customers allocated to it.  Cannot delete! Please rectify!', hWndForm, lParam )
									Return FALSE
								Else
									Return TRUE

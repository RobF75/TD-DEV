								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
							On PAM_SETINSTANCEVARS
								Set OurColumnClass.sSQLCOLNAME = ' LOAD_CUSTOMERS.FREIGHT_CODE '
							On PAM_CHECKROWNEW
								If NOT SalIsNull( hWndItem )
									If FreightCodeIdExists( colOverrideFreight, nExecute )
										Return TRUE
									Else
										Call ErrorMessage( 'This Freight Code Id does not exists in the Freight Codes table! Please rectify!', hWndForm, lParam )
										Return FALSE
								Else
									Return TRUE
							On PAM_CHECKROWEDITED
								If NOT SalIsNull( hWndItem )
									If FreightCodeIdExists( colOverrideFreight, nExecute )
										Return TRUE
									Else
										Call ErrorMessage( 'This Freight Code Id does not exists in the Freight Codes table! Please rectify!', hWndForm, lParam )
										Return FALSE
								Else
									Return TRUE
							On PAM_LOOKUPFREIGHT
								Call PopString( colOverrideFreight, TRUE )
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call PopString( sTmp, TRUE )
							On PAM_COPYROWINFOFROM
								Call SalTblFetchRow( hWndForm, lParam )
								Set sTemp = colOverrideFreight
							On PAM_COPYROWINFOTO
								Call SalTblFetchRow( hWndForm, lParam )
								Set colOverrideFreight = sTemp
				Functions
					Function: CustNoExists
						Description:
						Returns
							Boolean:
						Parameters
							Number: nCustNo
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Cust_No FROM Customer_Master WHERE Cust_No = :nCustNo '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									If nInd = FETCH_EOF
										Return FALSE
									Else
										Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in LoadIdExists, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
					Function: LoadIdCustNoExists
						Description:
						Returns
							Boolean:
						Parameters
							String: sLoadId
							Number: nCustNo
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Cust_No FROM Load_Customers WHERE Cust_No = :nCustNo AND Load_Id = :sLoadId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									If nInd = FETCH_EOF
										Return FALSE
									Else
										Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in LoadIdExists, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
					Function: GetCustomerDetails
						Description:
						Returns
							Boolean:
						Parameters
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								Set sSql = ' SELECT Cust_Name, Region_Id FROM Customer_Master 
										  INTO :frmNewLoadCust.tblCustOnLoad.colCustName,
										   :frmNewLoadCust.tblCustOnLoad.sCustRegionId
										  WHERE Cust_No = :frmNewLoadCust.tblCustOnLoad.colCustNo '
								Return MySelectRecord( hSqlHandle, bHandleConnected, bHandlePrepared, sSql, nFetchFirst, nInd )
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
					Function: FreightCodeIdExists
						Description:
						Returns
							Boolean:
						Parameters
							String: sFreightCodeId
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Freight_Code FROM Freight_Codes WHERE Freight_Code = :sFreightCodeId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									If nInd = FETCH_EOF
										Return FALSE
									Else
										Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in LoadIdExists, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
					Function: GetDeliveryAddress
						Description:
						Returns
							Boolean:
						Parameters
							Number: nCustNo
							Date/Time: dtAddrDT
							Receive String: sAddressType
							Receive String: sAddressLine1
							Receive String: sAddressLine2
							Receive String: sSuburb
							Receive String: sState
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
							!
							Sql Handle: hSqlMeetHandle
							Boolean: bMeetHandleConnected
							Boolean: bMeetHandlePrepared
						Local variables
							String: sSql
							String: sGotAddressType
							String: sGotAddressLine1
							String: sGotAddressLine2
							String: sGotSuburb
							String: sGotState
							String: sGotMeetId
							Number: nInd
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Address_Type, Address_1, Address_2, Suburb, State, Address_Meet_Id
											  FROM Customer_Address 
											  INTO :sGotAddressType, :sGotAddressLine1, :sGotAddressLine2, :sGotSuburb, :sGotState, :sGotMeetId
											  WHERE Cust_No = :nCustNo AND Add_Added_DT = :dtAddrDT '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								Set sAddressType = ''
								Set sAddressLine1 = ''
								Set sAddressLine2 = ''
								Set sSuburb = ''
								Set sState = ''
								Set sGotAddressType = ''
								Set sGotAddressLine1 = ''
								Set sGotAddressLine2 = ''
								Set sGotSuburb = ''
								Set sGotState = ''
								Set sGotMeetId = ''
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									Set sAddressType = sGotAddressType
									Set sAddressLine1 = sGotAddressLine1
									Set sAddressLine2 = sGotAddressLine2
									Set sSuburb = sGotSuburb
									Set sState = sGotState
									Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in GetDeliveryAddress, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Call SqlDisconnect( hSqlHandle )
								!
								Set bMeetHandlePrepared = FALSE
								If bMeetHandleConnected
									Set bMeetHandleConnected = FALSE
									Call SqlDisconnect( hSqlMeetHandle )
								Return TRUE
					Function: GetCustDefDelivInstruct
						Description:
						Returns
							Boolean:
						Parameters
							Number: nCustNo
							Receive String: sDefDelivInstruct
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							String: sGotDefDelivInstruct
							Number: nInd
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Def_Deliv_Instruct 
											  FROM Customer_Master 
											  INTO :sGotDefDelivInstruct 
											  WHERE Cust_No = :nCustNo '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								Set sDefDelivInstruct = ''
								Set sGotDefDelivInstruct = ''
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									Set sDefDelivInstruct = sGotDefDelivInstruct
									Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in GetCustDefDelivInstruct!, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Call SqlDisconnect( hSqlHandle )
								Return TRUE
					!
					Function: RemoveUnPullCustOrdersFromLoad
						Description:
						Returns
							Boolean:
						Parameters
							String: sLoadId
							Number: nCustNo
							Number: nYear
							Number: nActionType
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							String: sFuncName
						Actions
							Set sFuncName = 'RemoveUnPullCustOrdersFromLoad'
							Select Case nActionType
								Case nExecute
									Loop Execute
										Loop Connect
											If bHandleConnected
												Break Connect
											Else
												Set bHandleConnected = SqlConnect( hSqlHandle ) 
												If bHandleConnected
													Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
													Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
													Break Connect
												Else
													If IDNO = SalMessageBox( 'Could not connect handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
														Break Connect
										Loop Prepare
											If bHandlePrepared
												Break Prepare
											Else
												Set sSql = "UPDATE Customer_Order Set Load_Id = NULL, 
														Pull_Sheet_Issued = 'N', Pull_Sheet_Date = NULL, Pull_Sheet_By = NULL 
														WHERE Cust_No = :nCustNo AND Load_Id = :sLoadId AND 
														Year_Of_Sale = :nYear AND NOT Invoiced_Flag = 'Y' "
												If SqlPrepare( hSqlHandle, sSql )
													Set bHandlePrepared = TRUE
													Break Prepare
												Else
													Set bHandlePrepared = FALSE
													If IDNO = SalMessageBox( 'Could not prepare handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
														Break Prepare
										!
										If SqlExecute( hSqlHandle )
											Call RemoveUnPullCustOrdersFromLoad( '', 0, 0, nCommit )
											Return TRUE
										Else
											Call RemoveUnPullCustOrdersFromLoad( '', 0, 0, nRollback )
											Set bHandlePrepared = FALSE
											If IDNO = SalMessageBox( 'Could not execute handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												Return FALSE
								Case nCommit
									Loop Commit
										If bHandleConnected
											If SqlCommit( hSqlHandle )
												Return TRUE
											Else
												If IDNO = SalMessageBox( 'Could not commit handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													Return FALSE
										Else
											Return TRUE
								Case nRollback
									Loop Rollback
										If bHandleConnected
											Set bHandlePrepared = FALSE
											If SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
												Return TRUE
											Else
												If IDNO = SalMessageBox( 'Could not rollback handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													Return FALSE
										Else
											Return TRUE
								Case nDisconnect
									Loop Disconnect
										If bHandleConnected
											If SqlDisconnect( hSqlHandle )
												Set bHandleConnected = FALSE
												Set bHandlePrepared = FALSE
												Return TRUE
											Else
												If IDNO = SalMessageBox( 'Could not disconnect handle in function '||sFuncName||'Contact programmers! RETRY?', 'Error', MB_YesNo )
													Return FALSE
										Else
											Return TRUE
								Case nRePrepare
									Set bHandlePrepared = FALSE
									Return TRUE
					Function: TakeOffCustOrdersFromLoad
						Description:
						Returns
							Boolean:
						Parameters
							String: sLoadId
							Number: nCustNo
							Number: nYear
							Number: nActionType
						Static Variables
						Local variables
							Number: nSqlHandleNo
							String: sSql
							String: sBind
							String: sInto
							String: sName
						Actions
							Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'TKOFFCSTORDLD' )
							Select Case nActionType
								Case nExecute
									Set sSql = " UPDATE Customer_Order Set Load_Id = @IF(@EXACT(Invoiced_Flag,'Y'), 'GONE','')  
											WHERE Load_Id = :1 AND Cust_No = :2 AND Year_Of_Sale = :3 "
									Set sName = 'TKOFFCSTORDLD'
									Set sBind = ':sLoadId, :nCustNo, :nYear'
									Set sInto = ''
									!
									Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
									!
									If haSqlHandles[ nSqlHandleNo ].Execute( )
										Return TRUE
									Else
										Return FALSE
								Case nCommit
									Return haSqlHandles[ nSqlHandleNo ].Commit( )
								Case nRollback
									Return haSqlHandles[ nSqlHandleNo ].Rollback( )
								Case nDisconnect
									Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
					!
					! Function: CalcLoadCustTotalTrees
						                                                                                                                              Description: 
						                                                                                                                              Returns 
							                                                                                                                              Boolean: 
						                                                                                                                              Parameters 
							                                                                                                                              String: sLoadId
							                                                                                                                              Number: nCustNo
							                                                                                                                              Number: nYear
							                                                                                                                              Receive Number: nTotalTrees
							                                                                                                                              Number: nActionType
						                                                                                                                              Static Variables 
							                                                                                                                              Sql Handle: hSqlHandle
							                                                                                                                              Boolean: bHandleConnected
							                                                                                                                              Boolean: bHandlePrepared
						                                                                                                                              Local variables 
							                                                                                                                              String: sSql
							                                                                                                                              String: sFuncName
							                                                                                                                              Boolean: bOk
							                                                                                                                              Number: nInd
							                                                                                                                              Number: nGotTotalTrees
						                                                                                                                              Actions 
							                                                                                                                              Set sFuncName = 'CalcLoadCustTotalTrees'
							                                                                                                                              Select Case nActionType
								                                                                                                                              Case nExecute
									                                                                                                                              Loop Execute
										                                                                                                                              Loop Connect
											                                                                                                                              If bHandleConnected
												                                                                                                                              Break Connect
											                                                                                                                              Else 
												                                                                                                                              Set bHandleConnected = SqlConnect( hSqlHandle ) 
												                                                                                                                              If bHandleConnected
													                                                                                                                              Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
													                                                                                                                              Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
													                                                                                                                              Break Connect
												                                                                                                                              Else 
													                                                                                                                              If IDNO = SalMessageBox( 'Could not connect handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
														                                                                                                                              Break Connect
										                                                                                                                              Loop Prepare
											                                                                                                                              If bHandlePrepared
												                                                                                                                              Break Prepare
											                                                                                                                              Else 
												                                                                                                                              Set sSql = 'SELECT 
														  sum(Conf_Amt)
														FROM 
														  Customer_Order 
														INTO :nGotTotalTrees 
														WHERE 
														  Load_Id = :sLoadId AND
														  Cust_No = :nCustNo AND 
														  Year_Of_Sale = :nYear '
												                                                                                                                              If SqlPrepare( hSqlHandle, sSql )
													                                                                                                                              Set bHandlePrepared = TRUE
													                                                                                                                              Break Prepare
												                                                                                                                              Else 
													                                                                                                                              Set bHandlePrepared = FALSE
													                                                                                                                              If IDNO = SalMessageBox( 'Could not prepare handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
														                                                                                                                              Break Prepare
										!
										                                                                                                                              Set nTotalTrees = NUMBER_Null
										                                                                                                                              Set nGotTotalTrees = NUMBER_Null
										!
										                                                                                                                              If SqlExecute( hSqlHandle )
											                                                                                                                              Call SqlFetchNext( hSqlHandle, nInd )
											                                                                                                                              Set nTotalTrees = nGotTotalTrees
											                                                                                                                              Return TRUE
										                                                                                                                              Else 
											                                                                                                                              Set bHandlePrepared = FALSE
											                                                                                                                              If IDNO = SalMessageBox( 'Could not execute handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												                                                                                                                              Return FALSE
								                                                                                                                              Case nCommit
									                                                                                                                              Set bOk = TRUE
									                                                                                                                              Loop Commit
										                                                                                                                              If bHandleConnected
											                                                                                                                              If SqlCommit( hSqlHandle )
												                                                                                                                              Break Commit
											                                                                                                                              Else 
												                                                                                                                              If IDNO = SalMessageBox( 'Could not commit handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													                                                                                                                              Set bOk = FALSE
													                                                                                                                              Break Commit
										                                                                                                                              Else 
											                                                                                                                              Break Commit
									                                                                                                                              Return bOk
								                                                                                                                              Case nRollback
									                                                                                                                              Set bOk = TRUE
									                                                                                                                              Loop Rollback
										                                                                                                                              If bHandleConnected
											                                                                                                                              Set bHandlePrepared = FALSE
											                                                                                                                              If SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
												                                                                                                                              Break Rollback
											                                                                                                                              Else 
												                                                                                                                              If IDNO = SalMessageBox( 'Could not rollback handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													                                                                                                                              Set bOk = FALSE
													                                                                                                                              Break Rollback
										                                                                                                                              Else 
											                                                                                                                              Break Rollback
									                                                                                                                              Return bOk
								                                                                                                                              Case nDisconnect
									                                                                                                                              Set bOk = TRUE
									                                                                                                                              Loop Disconnect
										                                                                                                                              If bHandleConnected
											                                                                                                                              If SqlDisconnect( hSqlHandle )
												                                                                                                                              Set bHandleConnected = FALSE
												                                                                                                                              Set bHandlePrepared = FALSE
												                                                                                                                              Break Disconnect
											                                                                                                                              Else 
												                                                                                                                              If IDNO = SalMessageBox( 'Could not disconnect handle in function '||sFuncName||'Contact programmers! RETRY?', 'Error', MB_YesNo )
													                                                                                                                              Set bOk = FALSE
													                                                                                                                              Break Disconnect
										                                                                                                                              Else 
											                                                                                                                              Break Disconnect
									                                                                                                                              Return bOk
								                                                                                                                              Case nRePrepare
									                                                                                                                              Set bHandlePrepared = FALSE
									                                                                                                                              Return TRUE
					Function: CalcLoadCustTotalTrees
						Description:
						Returns
							Boolean:
						Parameters
							String: sLoadId
							Number: nCustNo
							Number: nYear
							Receive Number: nTotalTrees
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nInd
							Number: nSqlHandleNo
							Number: nSqlHandleNoHist
							!
							Number: nGotTotalTrees
						Actions
							Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CalcLoadCustTotalTreesLDCSTTTREE' )
							Set nSqlHandleNoHist = SqlHandlesGetReferenceNo( 'CalcLoadCustTotalTreesLDCSTTTRHST' )
							Select Case nActionType
								Case nExecute
									If nYear < WhichSeasonYear( SalDateCurrent(  ) ) AND nYear != 77
										Set sSql = 'SELECT 
												  sum(Conf_Amt)
												FROM 
												  Cust_Order_History 
												WHERE 
												  Load_Id = :1 AND
												  Cust_No = :2 AND 
												  Year_Of_Sale = :3 '
										Set sName = 'LDCSTTTRHST'
										Set sBind = ':sLoadId, :nCustNo, :nYear'
										Set sInto = ':nGotTotalTrees'
										Call haSqlHandles[ nSqlHandleNoHist ].Setup( sSql, sName, sBind, sInto )
										Call SqlVarSetup( haSqlHandles[ nSqlHandleNoHist ].hSqlHandle )
										!
										Set nTotalTrees = NUMBER_Null
										Set nGotTotalTrees = NUMBER_Null
										!
										If haSqlHandles[ nSqlHandleNoHist ].Execute( )
											If haSqlHandles[ nSqlHandleNoHist ].FetchNext( nInd )
												Set nTotalTrees = nGotTotalTrees
											Return TRUE
										Else
											Return FALSE
									Else
										Set sSql = 'SELECT 
												  sum(Conf_Amt)
												FROM 
												  Customer_Order 
												WHERE 
												  Load_Id = :1 AND
												  Cust_No = :2 AND 
												  Year_Of_Sale = :3 '
										Set sName = 'LDCSTTTREE'
										Set sBind = ':sLoadId, :nCustNo, :nYear'
										Set sInto = ':nGotTotalTrees'
										Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
										Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
										!
										Set nTotalTrees = NUMBER_Null
										Set nGotTotalTrees = NUMBER_Null
										!
										If haSqlHandles[ nSqlHandleNo ].Execute( )
											If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
												Set nTotalTrees = nGotTotalTrees
											Return TRUE
										Else
											Return FALSE
								Case nDisconnect
									Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
									Call haSqlHandles[ nSqlHandleNoHist ].Disconnect( )
									Return TRUE
					!
				Window Variables
					Number: nLowerSeq
					Number: nUpperSeq
					Number: nTmpRow
					Number: nTemp
					Date/Time: dtTemp
					Number: nSeqNo
					Number: nTmpSeq
					String: sTmp
					Boolean: bAny
					String: sCustRegionId
					Number: nOrderType
					Window Handle: hWndCol
					Boolean: bPickUpAddress
					! Boolean: bCalcCustTrees
					Boolean: bOk
					!
					! Window Handle: hWndMoveToDlg
					! Number: nRowFrom
					! Number: nToRow
					! Number: nActionType
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' LOAD_CUSTOMERS '
						Set sSQLPOPTABLENAME= ' LOAD_CUSTOMERS,  CUSTOMER_MASTER'
						Set sSQLWHERE =  ' WHERE LOAD_CUSTOMERS.LOAD_ID 
								= :frmNewLoadCust.dfLoadId AND CUSTOMER_MASTER.CUST_NO = 
								LOAD_CUSTOMERS.CUST_NO '
						Set sORDERBY = ' ORDER BY LOAD_CUSTOMERS.SEQUENCE_NO '
						Set sROWID = ' LOAD_CUSTOMERS.ROWID '
						Set sSQLWHEREROWID = ' WHERE LOAD_CUSTOMERS.LOAD_ID = :frmNewLoadCust.dfLoadId AND 
								LOAD_CUSTOMERS.CUST_NO = :frmNewLoadCust.tblCustOnLoad.colCustNo AND 
								LOAD_CUSTOMERS.SEQUENCE_NO = :frmNewLoadCust.tblCustOnLoad.colOrgSeq '
						Set sTableHeading = 'Customers on Load'
						Set sQueryDialogName = 'dlgQueryTblLoadCust'
						Set bAddRowBellow = TRUE
						Set hWndRowNewColumn = colCustNo
						! Set bCalcCustTrees = FALSE
						Set nTableFillType = TBL_FillAll
						Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\ldcstqck2.qrp'
					On PAM_DONTREFRESHROWID
						Return TRUE
					On PAM_POPULATE
						Call SalSendClassMessage( PAM_POPULATE, wParam, lParam )
						Call SalTblSetLockedColumns( hWndForm, 5 )
						Call SalTblReset( tblAddCustOrdToLoad )
						!
						Call SalSendMsgToChildren( SalParentWindow( hWndForm ), PAM_POPULATE_CAPACITY, 0, 0 )
					On PAM_REPOPULATE
						Call SalSendClassMessage( PAM_REPOPULATE, wParam, lParam )
						Call SalTblSetLockedColumns( hWndForm, 5 )
						Call SalTblReset( tblAddCustOrdToLoad )
						!
						Call SalSendMsgToChildren( SalParentWindow( hWndForm ), PAM_POPULATE_CAPACITY, 1, 0 )
					On PAM_SEARCH
						Call SalSendClassMessage( PAM_SEARCH, wParam, lParam )
						Call SalTblSetLockedColumns( hWndForm, 5 )
						Call SalTblReset( tblAddCustOrdToLoad )
						!
						Call SalSendMsgToChildren( SalParentWindow( hWndForm ), PAM_POPULATE_CAPACITY, 1, 0 )
					! On PAM_ADDROW
						                                                                                                                              Call SalTblQueryFocus( hWndForm, nTmpRow, hWndCol )
						                                                                                                                              Call SalTblFetchRow( hWndForm, nTmpRow )
						                                                                                                                              Set nLowerSeq = colSeq
						                                                                                                                              If nTmpRow > 0
							                                                                                                                              Call SalTblFetchRow( hWndForm, nTmpRow - 1 )
							                                                                                                                              Call SalTblSetContext( hWndForm, nTmpRow - 1 )
							                                                                                                                              If SalIsNull( colSeq )
								                                                                                                                              Set nUpperSeq = nLowerSeq
							                                                                                                                              Else 
								                                                                                                                              Set nUpperSeq = colSeq
						                                                                                                                              Else 
							                                                                                                                              Set nUpperSeq = 0
						                                                                                                                              Call SalTblFetchRow( hWndForm, nTmpRow )
						                                                                                                                              Call SalTblSetContext( hWndForm, nTmpRow )
						                                                                                                                              Call SalSendClassMessage( PAM_ADDROW, wParam, lParam )
						                                                                                                                              Set nTmpSeq = nUpperSeq + SalNumberRound( ( nLowerSeq - nUpperSeq ) / 2 )
						                                                                                                                              If nTmpSeq = nLowerSeq OR nLowerSeq = NUMBER_Null
							                                                                                                                              Set colSeq = NUMBER_Null
						                                                                                                                              Else 
							                                                                                                                              Set colSeq = nTmpSeq
						                                                                                                                              Set colOrdType = ''
						                                                                                                                              Set colCustPulled = 'N'
						                                                                                                                              Return TRUE
					On PAM_ADDROW
						Call SalTblQueryFocus( hWndForm, nTmpRow, hWndCol )
						Call SalTblFetchRow( hWndForm, nTmpRow )
						Set nUpperSeq = colSeq
						If SalTblFetchRow( hWndForm, nTmpRow + 1 )
							Call SalTblSetContext( hWndForm, nTmpRow + 1 )
							If SalIsNull( colSeq )
								Set nLowerSeq = nUpperSeq
							Else
								Set nLowerSeq = colSeq
						Else
							Set nLowerSeq = nUpperSeq + 10
						Call SalTblFetchRow( hWndForm, nTmpRow )
						Call SalTblSetContext( hWndForm, nTmpRow )
						Call SalSendClassMessage( PAM_ADDROW, wParam, lParam )
						!
						If nUpperSeq = NUMBER_Null
							Set colSeq = NUMBER_Null
						Else
							Set nTmpSeq = nUpperSeq + SalNumberRound( ( nLowerSeq - nUpperSeq ) / 2 )
							If nTmpSeq = nLowerSeq OR nLowerSeq = NUMBER_Null
								Set colSeq = NUMBER_Null
							Else
								Set colSeq = nTmpSeq
						!
						Set colOrdType = 'ANC'
						Set colCustPulled = 'N'
						Set colCustInvoiced = 'N'
						Return TRUE
					On SAM_FetchRowDone
						If NOT SalIsNull( colDelivAddressDT )
							Call GetDeliveryAddress( colCustNo, colDelivAddressDT, colDelivAddressType, colAddressLine1, colAddressLine2, colSuburb, colState, nExecute )
						Set colOrdTypeChanged = 0
						! If frmNewLoadCust.cbCalcUnits
							                                                                                                                              Call SalSendMsg( hWndForm, PAM_CALCUNITS, 0, lParam )
						If frmNewLoadCust.cbCalcTrees
							Call SalSendMsg( hWndForm, PAM_CALCTREES, 0, lParam )
					On PAM_GETSHIPADDRESS
						! Call GetShipAddressHdlNewLogic2( colCustNo, frmNewLoadCust.cSeasonYear.GetSeasonYear( ), hWndForm, PAM_SHIPADDRFIELDS, bPickUpAddress, nExecute )
						Call GetShipAddress( colCustNo, 
								frmNewLoadCust.cSeasonYear.GetSeasonYear( ), 
								colDelivAddressDT, 
								colDelivAddressType, 
								colAddressLine1, 
								colAddressLine2, 
								colSuburb, 
								sTmp, 
								colState, 
								sTmp, 
								sTmp, 
								sTmp, 
								sTmp, 
								sTmp, 
								sTmp, 
								sTmp, 
								sTmp, 
								bPickUpAddress, 
								nExecute )
						If bPickUpAddress
							Set colAddressLine1 = sPICKUPADDRESSLINE1
							Set colAddressLine2 = sPICKUPADDRESSLINE2
						Call SalSetFieldEdit( colDelivAddressDT, TRUE )
						Return TRUE
					On PAM_WRITEINSERTSUPDATES
						Call SalSendClassMessage( PAM_WRITEINSERTSUPDATES, wParam, lParam )
						Call SalSendMsg( tblAddCustOrdToLoad, PAM_WRITEINSERTSUPDATES, 0, 0 )
						!
						Call SalSendMsgToChildren( SalParentWindow( hWndForm ), PAM_POPULATE_CAPACITY, 1, 0 )
						Return TRUE
					On PAM_MOVESELECTEDROWSUPONE
						If MyTableAnyRows( hWndForm, ROW_Selected, 0, nRow )
							If nRow > 1
								Call SalMessageBox( 'Please select only one row!', 'Warning', MB_Ok )
							Else
								Set nRow = TBL_MinRow
								If SalTblFindNextRow( hWndForm, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( hWndForm, nRow )
									If nRow > 0
										Call CopyTblRowFromTo( hWndForm, nRow-1, TBL_TempRow, TRUE, ROW_Edited|ROW_MarkDeleted|ROW_New|ROW_Selected, TRUE )
										Call CopyTblRowFromTo( hWndForm, nRow, nRow - 1, TRUE, ROW_Edited|ROW_MarkDeleted|ROW_New|ROW_Selected, TRUE )
										Call CopyTblRowFromTo( hWndForm, TBL_TempRow, nRow, TRUE, ROW_Edited|ROW_MarkDeleted|ROW_New|ROW_Selected, TRUE )
										Call SalTblFetchRow( hWndForm, nRow-1 )
										Call SalTblSetContext( hWndForm, nRow-1 )
						Else
							Call SalMessageBox( 'Please select a row first!', 'Warning', MB_Ok )
					On PAM_MOVESELECTEDROWSDOWNONE
						If MyTableAnyRows( hWndForm, ROW_Selected, 0, nRow )
							If nRow > 1
								Call SalMessageBox( 'Please select only one row!', 'Warning', MB_Ok )
							Else
								Set nRow = TBL_MinRow
								If SalTblFindNextRow( hWndForm, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( hWndForm, nRow )
									Set nTmpRow = nRow
									If SalTblFindNextRow( hWndForm, nTmpRow, 0, 0 )
										Call CopyTblRowFromTo( hWndForm, nRow+1, TBL_TempRow, TRUE, ROW_Edited|ROW_MarkDeleted|ROW_New|ROW_Selected, TRUE )
										Call CopyTblRowFromTo( hWndForm, nRow, nRow + 1, TRUE, ROW_Edited|ROW_MarkDeleted|ROW_New|ROW_Selected, TRUE )
										Call CopyTblRowFromTo( hWndForm, TBL_TempRow, nRow, TRUE, ROW_Edited|ROW_MarkDeleted|ROW_New|ROW_Selected, TRUE )
										Call SalTblFetchRow( hWndForm, nRow+1 )
										Call SalTblSetContext( hWndForm, nRow+1 )
						Else
							Call SalMessageBox( 'Please select a row first!', 'Warning', MB_Ok )
					! On PAM_REFRESHCUSTOMERSONLOAD
						                                                                                                                              Call SalWaitCursor( TRUE )
						                                                                                                                              Set nRow = TBL_MinRow
						                                                                                                                              While SalTblFindNextRow( hWndForm, nRow, ROW_Selected, 0 )
							                                                                                                                              Call SalTblFetchRow( hWndForm, nRow )
							                                                                                                                              If NOT colCustInvoiced = 'Y'
								                                                                                                                              If colOrdType = 'A' OR colOrdType = 'E'
									                                                                                                                              Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nAllOrders, colCustNo )
								                                                                                                                              Else If colOrdType = 'F'
									                                                                                                                              Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nFruitOrders, colCustNo )
								                                                                                                                              Else If colOrdType = 'O'
									                                                                                                                              Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nOrnamOrders, colCustNo )
								                                                                                                                              Else If colOrdType = 'ANC'
									                                                                                                                              Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nAllOrders | nWithOutContainers, colCustNo )
								                                                                                                                              Else If colOrdType = 'FNC'
									                                                                                                                              Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nFruitOrders | nWithOutContainers, colCustNo )
								                                                                                                                              Else If colOrdType = 'ONC'
									                                                                                                                              Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nOrnamOrders | nWithOutContainers, colCustNo )
								                                                                                                                              Else If colOrdType = 'C'
									                                                                                                                              Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nContainerOrders, colCustNo )
						                                                                                                                              Call SalSendMsg( tblAddCustOrdToLoad, PAM_WRITEINSERTSUPDATES, 0, 0 )
						                                                                                                                              Call SalWaitCursor( FALSE )
					On PAM_ADJUSTSEQCUSTOMERSONLOAD
						Call SalWaitCursor( TRUE )
						Set nSeqNo = 5
						Set nRow = TBL_MinRow
						While SalTblFindNextRow( hWndForm, nRow, 0, 0 )
							Call SalTblFetchRow( hWndForm, nRow )
							Set colSeq = nSeqNo
							Call SalSetFieldEdit( colSeq, TRUE )
							Set nSeqNo = nSeqNo + 5
						Call SalWaitCursor( FALSE )
					On PAM_VALIDATESELECTION
						If SalTblAnyRows( hWndForm, ROW_Selected, 0 )
							If SalTblAnyRows( hWndForm, ROW_New, 0 )
								Call SalMessageBox( 'Please SAVE your changes first!', 'Warning', MB_Ok )
								Return FALSE
							Else
								Return TRUE
						Else
							Call SalMessageBox( 'No Rows Selected!', 'Warning', MB_Ok )
							Return FALSE
					On PAM_SETORDTYPE
						Set colOrdType = sDefaultOrdType
						Call SalSetFieldEdit( colOrdType, TRUE )
						Call SalSendMsg( colOrdType, SAM_Validate, 0, 0 )
						Return TRUE
					!
					! On PAM_CALCSELECTEDTREES
						! If bCalcCustTrees
							                                                                                                                              Set bCalcCustTrees = FALSE
						! Else
							                                                                                                                              Set bCalcCustTrees = TRUE
						                                                                                                                              Call MyTableLoop( hWndForm, hWndForm, PAM_CALCTREES, ROW_Selected, 0, 'Calculating Trees', nLowToHi )
					On PAM_CALCTREES
						Set bOk = TRUE
						If NOT CalcLoadCustTotalTrees( frmNewLoadCust.dfLoadId, colCustNo, frmNewLoadCust.cSeasonYear.GetSeasonYear( ), colNoOnLoad, nExecute )
							Set bOk = FALSE
						If NOT GetLoadCustTotalUnits( colCustNo, frmNewLoadCust.dfLoadId, frmNewLoadCust.cSeasonYear.GetSeasonYear( ), colUnits, nExecute )
							Set bOk = FALSE
						If bOk
							Set colTreesCalculated = 'Y'
						Return bOk
					! On PAM_CALCUNITS
						                                                                                                                              If GetLoadCustTotalUnits( colCustNo, frmNewLoadCust.dfLoadId, frmNewLoadCust.cSeasonYear.GetSeasonYear( ), colUnits, nExecute )
							                                                                                                                              Return TRUE
						                                                                                                                              Else 
							                                                                                                                              Return FALSE
					On SAM_Destroy
						Call CustNoExists( 0, nDisconnect )
						Call FreightCodeIdExists( '', nDisconnect )
						Call GetCustomerDetails( nDisconnect )
						Call LoadIdRegionIdExists( '', '', nDisconnect )
						Call AddCustRegionToLoad( '', '', nDisconnect )
						Call LoadIdCustNoExists( '', 0, nDisconnect )
						Call RemoveCustOrdersFromLoad( '', 0, 0, nDisconnect )
						Call RemoveUnPullCustOrdersFromLoad( '', 0, 0, nDisconnect )
						Call GetShipAddressHdlNewLogic2( 0, 0, hWndNULL, 0, bPickUpAddress, nDisconnect )
						Call GetDeliveryAddress( 0, DATETIME_Null, colDelivAddressType, colAddressLine1, colAddressLine2, colSuburb, colState, nDisconnect )
						Call GetCustDefDelivInstruct( 0, colDelivIns, nDisconnect )
						Call CalcLoadCustTotalTrees( '', 0, 0, colNoOnLoad, nDisconnect )
						Call AnyPullnNotInvCustOrdsOnLoad( '', 0, 0, bAny, nDisconnect ) 
						Call TakeOffCustOrdersFromLoad( '', 0, 0, nDisconnect )
						Call GetShipAddress( 0, 0, 
								colDelivAddressDT, 
								colDelivAddressType, 
								colAddressLine1, 
								colAddressLine2, 
								colSuburb, 
								sTmp, 
								colState, 
								sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, bPickUpAddress, nDisconnect )
						Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
					On PAM_TABLEREPORTROWACTION
						If colTreesCalculated = 'Y'
							Return TRUE
						Else
							Return SalSendMsg( hWndForm, PAM_CALCTREES, wParam, lParam )
					!
					! On SAM_RowHeaderDoubleClick
						                                                                                                                              If hWndMoveToDlg != hWndNULL
							                                                                                                                              If SalSendMsg( hWndMoveToDlg, PAM_SHOW, 0, 0 )
								! Mark Row to Move or Swap here
								                                                                                                                              Call VisTblSetRowColor( hWndForm, lParam, COLOR_Red )
								                                                                                                                              Set nRowFrom = lParam
						                                                                                                                              Else 
							                                                                                                                              Set hWndMoveToDlg = SalCreateWindow( dlgTableMoveRowTo, hWndForm )
							                                                                                                                              If hWndMoveToDlg != hWndNULL
								! Mark Row to Move or Swap here
								                                                                                                                              Call VisTblSetRowColor( hWndForm, lParam, COLOR_Red )
								                                                                                                                              Set nRowFrom = lParam
					! On SAM_RowHeaderClick
						                                                                                                                              If hWndMoveToDlg != hWndNULL
							                                                                                                                              Call VisTblSetRowColor( hWndForm, lParam, COLOR_Red )
							                                                                                                                              Set nActionType = SalSendMsg( hWndMoveToDlg, PAM_ROWACTION, 0, 0 )
							                                                                                                                              If nActionType = nMoveRows
								! Move the rows
								                                                                                                                              Call SalSendMsg( hWndForm, PAM_ADDROW, 0, 0 )
								                                                                                                                              Call SalTblQueryFocus( hWndForm, nToRow, hWndCol )
								                                                                                                                              Call CopyTblRowFromTo( hWndForm, nRowFrom, nToRow, TRUE, ROW_Edited|ROW_MarkDeleted|ROW_New|ROW_Selected, TRUE )
								                                                                                                                              Call SalTblDeleteRow( hWndForm, nRowFrom, TBL_NoAdjust )
								                                                                                                                              Call VisTblSetRowColor( hWndForm, nToRow-1, COLOR_Default )
								                                                                                                                              Call VisTblSetRowColor( hWndForm, nRowFrom, COLOR_Default )
							                                                                                                                              Else If nActionType = nSwapRows
								! Swap the rows
								                                                                                                                              Set nToRow = lParam
								                                                                                                                              Call CopyTblRowFromTo( hWndForm, nRowFrom, nToRow, TRUE, ROW_Edited|ROW_MarkDeleted|ROW_New|ROW_Selected, TRUE )
								                                                                                                                              Call VisTblSetRowColor( hWndForm, nRowFrom, COLOR_Default )
								                                                                                                                              Call VisTblSetRowColor( hWndForm, nToRow, COLOR_Default )
							                                                                                                                              Else 
								                                                                                                                              Call VisTblSetRowColor( hWndForm, nToRow, COLOR_Default )
			Child Table: tblAddCustOrdToLoad

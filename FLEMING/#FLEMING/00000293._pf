								Set OurColumnClass.bUpdate = FALSE
							On PAM_CHECKROWNEW
								Set colLoadId = dfLoadId
								If LoadIdRegionIdExists( colLoadId, colRegionId, nExecute )
									Call ErrorMessage( 'This region Id already exists in this table!', hWndForm, lParam )
									Return FALSE
								Else
									Return TRUE
							On PAM_EDITCHECK
								If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
									Return FALSE
								Else
									Return TRUE
							On PAM_LOOKUP
								Call PopString( colRegionId, TRUE )
								Call SalSetFieldEdit( hWndItem, TRUE )

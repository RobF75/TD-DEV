					Input Mask: Class Default
				Message Actions
					On PAM_SETINSTANCEVARS
						Set OurTblQBEDataField.sSQLCOLNAME = 'STOCK_ITEM.VARIETY_TYPE'
						Set OurTblQBEDataField.sQBEOperand = EQOPERAND
					On PAM_QBE
						If rbFruitOrders
							Set dfVarietyType = 'F'
						Else If rbOrnamOrders
							Set dfVarietyType = 'O'
						Else If rbAllOrders
							Set dfVarietyType = ''
						Else
							Set dfVarietyType = ''
						Call SalSendClassMessage( PAM_QBE, wParam, lParam )
			Data Field: dfStockType
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurTblQBEDataField
				Property Template:
				Class DLL Name:
				Data
					Maximum Data Length: Default
					Data Type: Class Default
					Editable? Class Default
				Display Settings
					Window Location and Size
						Left:   Default
						Top:    Default
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? No
					Border? Class Default
					Justify: Class Default
					Format: Class Default
					Country: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Input Mask: Class Default
				Message Actions
					On PAM_SETINSTANCEVARS
						Set OurTblQBEDataField.sSQLCOLNAME = 'STOCK_ITEM.STOCK_TYPE'
						Set OurTblQBEDataField.sQBEOperand = EQOPERAND
					On PAM_QBE
						If rbContainerOrdersAll OR rbContainerOrdersReady
							Set dfStockType = 'C'
							Set sgStockType = 'C'
						Else If cbWithOutContainers
							Set dfStockType = 'B'
							Set sgStockType = 'B'
						Else
							Set dfStockType = ''
						Call SalSendClassMessage( PAM_QBE, wParam, lParam )
			Data Field: dfContainerOrdersReady
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurTblQBEDataField
				Property Template:
				Class DLL Name:
				Data
					Maximum Data Length: Default
					Data Type: Class Default
					Editable? Class Default
				Display Settings
					Window Location and Size
						Left:   Default
						Top:    Default
						Width:  Class Default
						Width Editable? Class Default
						Height: Class Default
						Height Editable? Class Default
					Visible? No
					Border? Class Default
					Justify: Class Default
					Format: Class Default
					Country: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Text Color: Class Default
					Background Color: Class Default
					Input Mask: Class Default
				Message Actions
					On PAM_QBE
						If rbContainerOrdersReady
							Call PushString( '' )
							Call PushString( '' )
							Call PushString( STRINGHDLFOLLOWING )
							Call PushString( " EXISTS 
									( 
									  SELECT 
									    Growing_Sale.Location_Id 
									  FROM 
									    Growing_Sale 
									  WHERE 
									    Growing_Sale.Stock_Item_No = Customer_Order.Stock_Item_No AND 
									    Growing_Sale.Year_Of_Sale = Customer_Order.Year_Of_Sale AND 
									    ( Growing_Sale.Est_Sale_Date IS NULL OR 
									      Growing_Sale.Est_Sale_Date <= SYSDATE ) AND 
									    ( Growing_Sale.Not_For_Sale IS NULL OR 
									      Growing_Sale.Not_For_Sale = 'N' )  AND 
									    Growing_Sale.Location_Id = Customer_Order.Batch_Location_Id 
									) " )
							!
							Call PushString( '' )
							Call PushString( '' )
							Call PushString( STRINGHDLFOLLOWING )
							Call PushString( " ( CUSTOMER_ORDER.HOLD_ORDER_DATE <= SYSDATE OR CUSTOMER_ORDER.HOLD_ORDER_DATE IS NULL ) " )
							Return TRUE
						Else
							Return FALSE
			!

				Message Actions
					On PAM_CLICK
						!
						If rbOrdTypeAll
							Call PushString( 'A' )
						Else If rbOrdTypeFruit
							Call PushString( 'F' )
						Else If rbOrdTypeOrnam
							Call PushString( 'O' )
						Else If rbOrdTypeANC
							Call PushString( 'ANC' )
						Else If rbOrdTypeFNC
							Call PushString( 'FNC' )
						Else If rbOrdTypeONC
							Call PushString( 'ONC' )
						Else If rbOrdTypeCont
							Call PushString( 'C' )
						Else If rbOrdTypeSelect
							Call PushString( 'S' )
						Else If rbOrdTypeExtra
							Call PushString( 'E' )
						Else
							Call PushString( 'A' )
						Return SalSendMsg( pbCancel, SAM_Click, TRUE, TRUE )

						Set OurTblQBEDataField.sSQLCOLNAME = 'CUSTOMER_MASTER.CUSTOMER_TYPE'
					On PAM_QBE
						If rbGCTypes
							Call PushString( NOTHINGFOLLOWING )
							Call PushString( " NOT Customer_Master.Customer_Type LIKE 'O%'  " )
						Else If rbORCHTypes
							Call PushString( NOTHINGFOLLOWING )
							Call PushString( " NOT ( Customer_Master.Customer_Type LIKE 'GC%' OR Customer_Master.Customer_Type = 'NGC' ) " )
						Else
							Set dfCustType = ''
							Call SalSendClassMessage( PAM_QBE, wParam, lParam )
			!

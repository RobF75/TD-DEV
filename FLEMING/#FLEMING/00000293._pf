				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblLoads, PAM_VALIDATESELECTION, 0, 0 )
							Set nYear = cSeasonYear.GetSeasonYear( )
							Call MyTableLoop( tblLoads, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Unpulling Loads', nLowToHiWithPositioning )
							! Call SalSendMsg( tblLoads, PAM_REPOPULATE, 0, 0 )
							Call SalSendMsg( hWndForm, PAM_REPORTFINISHED, 0, 0 )
					On PAM_ROWACTION
						If tblLoads.colInvoicedFlag = 'Y'
							Call SalMessageBox( 'Can NOT UNpull a load thats already invoiced!', 'Warning', MB_Ok )
							Return TRUE
						Else If tblLoads.colPulledFlag = 'N'
							Call SalMessageBox( 'Load is NOT pulled! No need to UNpull it!', 'Warning', MB_Ok )
							Return TRUE
						Else
							If JanUnPullLoad( tblLoads.colLoadId, nYear, nExecute )
								Call SalSendMsg( tblLoads, PAM_ROWUPDATED, 0, lParam )
								Return TRUE
							Else
								Return FALSE

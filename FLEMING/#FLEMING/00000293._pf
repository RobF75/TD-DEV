					Column: colConfAmt
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class: OurColumnClass
						Property Template:
						Class DLL Name:
						Title: Conf Amt
						Visible? Class Default
						Editable? No
						Maximum Data Length: Class Default
						Data Type: Number
						Justify: Class Default
						Width:  0.9"
						Width Editable? Class Default
						Format: Class Default
						Country: Class Default
						Input Mask: Class Default
						Cell Options
							Cell Type? Class Default
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? Class Default
								Vertical Scroll? Class Default
								Auto Drop Down? Class Default
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
							On PAM_SETINSTANCEVARS
								Set colConfAmt.sSQLCOLNAME = ' CUSTOMER_ORDER.CONF_AMT '
								Set colConfAmt.bInsert = FALSE
								Set colConfAmt.bUpdate = FALSE
				Functions
				Window Variables
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' CUSTOMER_ORDER '
						Set sSQLPOPTABLENAME = ' CUSTOMER_ORDER, STOCK_ITEM'
						If sgStockType = 'C'
							Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO =
									 :dlgCustOutstandOrders.dfCustNo AND 
									 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
									 CUSTOMER_ORDER.CONF_AMT > 0 AND 
									 ( CUSTOMER_ORDER.INVOICED_FLAG = 'N' OR 
									 CUSTOMER_ORDER.INVOICED_FLAG IS NULL ) AND 
									 CUSTOMER_ORDER.YEAR_OF_SALE = :dlgCustOutstandOrders.nYear AND
									 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND
									 Stock_Item.Stock_Type = 'C' "
						Else If sgStockType = 'B'
							Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO =
									 :dlgCustOutstandOrders.dfCustNo AND 
									 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
									 CUSTOMER_ORDER.CONF_AMT > 0 AND 
									 ( CUSTOMER_ORDER.INVOICED_FLAG = 'N' OR 
									 CUSTOMER_ORDER.INVOICED_FLAG IS NULL ) AND 
									 CUSTOMER_ORDER.YEAR_OF_SALE = :dlgCustOutstandOrders.nYear AND
									 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND
									 Stock_Item.Stock_Type = 'B' "
						Else
							Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO =
									 :dlgCustOutstandOrders.dfCustNo AND 
									 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
									 CUSTOMER_ORDER.CONF_AMT > 0 AND 
									 ( CUSTOMER_ORDER.INVOICED_FLAG = 'N' OR 
									 CUSTOMER_ORDER.INVOICED_FLAG IS NULL ) AND 
									 CUSTOMER_ORDER.YEAR_OF_SALE = :dlgCustOutstandOrders.nYear AND
									 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO "
						!
						Set sORDERBY = ' ORDER BY STOCK_ITEM.VARIETY_TYPE, STOCK_ITEM.VARIETY, 
								STOCK_ITEM.CULT_DESC, STOCK_ITEM.TREE_TYPE '
						Set sROWID = ' CUSTOMER_ORDER.ROWID '
						Set sTableHeading = 'Customer Outstanding Orders'
						Set hWndRowNewColumn = colOrderDate
						Set bSelectFirstRow = FALSE
			!

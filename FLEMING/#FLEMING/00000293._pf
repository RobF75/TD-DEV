		Application Actions
			On SAM_AppStartup
				! Note - for the 95 season we need to adjust the label charge calculation in tblCust
						so that it calulates correctly again and not incorrectly as the AS400 does in 94
				! Also in frmRegLoad.tblOrd.colExtPrice - for POS freight charges error to be fixed
						in 95
				! Also in nextinv and printinvoice we need to change so that pos is invoiced at the
						point of the first load
				! Royalty need to be worked on to accumulate for a roy owner, what they currently
						  need to be paid instead of doing at year end.
				! No base price on invoicing message has cult_desc, root_desc and cust_no.
				!
				! WHEN MAKING EXECUTABLE erase the commands CUSTPOSORDINV, ORDERPOS, POSEXISTSNOTINV
				!
				If strArgArray[0] = ''
					Set SqlDatabase = 'STOCKDEV'
					Set SqlUser = 'GRAHAM'
					Set SqlPassword = 'GRAHAM'
				Else
					Set SqlDatabase = strArgArray[1]
					Set SqlUser = strArgArray[2]
					Set SqlPassword = strArgArray[3]
				!
				Call SqlHandlesSetup(  )
				!
				Set bShowSql = FALSE
				Set bghSqlDetail = SqlConnect( hSqlDetail )
				If bghSqlDetail
					Call SqlSetIsolationLevel( hSqlDetail,'RL')
					Call SqlSetLockTimeout( hSqlDetail, SQLTIMEOUT )
				! Set CallProgStr = strArgArray[4]
				! Set CallProgNum = SalHStringToNumber(CallProgStr )
				! Set hWndCallProg = SalNumberToWindowHandle( CallProgNum )
			On SAM_SqlError
				Call SqlExtractArgs( wParam, lParam, hSqlError, nSqlError, nErrorPos )
				! Going to comments the return false line and put in others to do error processing
				! Return FALSE
				Call SqlGetErrorText( nSqlError, sErrmsg )
				Call SalNumberToStr( nSqlError, 0, sNum )
				Call SalSendMsg( hWndSqlError, PAM_RESETPREPAREDHDLS, 0, 0 )
				Call SalMessageBox( sNum || '-' || sErrmsg || '.
						Choose OK to quit.', 'Load', MB_Ok | MB_IconStop )
				! Call SalQuit(  )
				Return FALSE
			On SAM_AppExit
				If bghSqlDetail
					Call SqlDisconnect( hSqlDetail )

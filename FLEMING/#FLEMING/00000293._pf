					Column: colCustNo
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class: OurColumnClass
						Property Template:
						Class DLL Name:
						Title: Cust No
						Visible? Class Default
						Editable? Yes
						Maximum Data Length: Class Default
						Data Type: Number
						Justify: Class Default
						Width:  1.038"
						Width Editable? Class Default
						Format: Class Default
						Country: Class Default
						Input Mask: Class Default
						Cell Options
							Cell Type? Class Default
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? Class Default
								Vertical Scroll? Class Default
								Auto Drop Down? Class Default
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
							On PAM_SETINSTANCEVARS
								Set OurColumnClass.sSQLCOLNAME = ' LOAD_CUSTOMERS.CUST_NO '
								Set OurColumnClass.bRenewRowId = TRUE
								Set OurColumnClass.bUpdate = FALSE
								Set OurColumnClass.bOrderBy = TRUE
								Set OurColumnClass.bReportColumn = TRUE
							On PAM_EDITCHECK
								If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
									Return TRUE
								Else
									Return FALSE
							On PAM_CHECKROWNEW
								If CustNoExists( colCustNo, nExecute )
									If LoadIdCustNoExists( frmNewLoadCust.dfLoadId, colCustNo, nExecute )
										Call ErrorMessage( 'This Customer No. already exists on this load! Please rectify!', hWndForm, lParam )
										Return FALSE
									Else If CheckCustomersNotes( colCustNo, 'Load Notes', nExecute )
										Return TRUE
									Else
										Return FALSE
								Else
									Call ErrorMessage( 'This Customer No. is not valid! Please rectify!', hWndForm, lParam )
									Return FALSE
							On PAM_ROWINSERTED
								Call GetCustomerDetails( nExecute )
								If NOT LoadIdRegionIdExists( frmNewLoadCust.dfLoadId, sCustRegionId, nExecute )
									If AddCustRegionToLoad( frmNewLoadCust.dfLoadId, sCustRegionId, nExecute )
										Call AddCustRegionToLoad( '', '', nCommit )
									Else
										Call SalMessageBox( 'Could not add customers region to load!  Please let programmers know of this!', 'Error', MB_Ok )
										Call AddCustRegionToLoad( '', '', nRollback )
								If SalIsNull( colDelivIns )
									Call GetCustDefDelivInstruct( colCustNo, colDelivIns, nExecute )
								Return SalSendClassMessage( PAM_ROWINSERTED, wParam, lParam )
							On PAM_ROWDELETED
								! Call RemoveUnPullCustOrdersFromLoad( frmNewLoadCust.dfLoadId, colCustNo, OurDateYear( frmNewLoadCust.dfShippingDate ), nExecute )
								Call SalSendClassMessage( PAM_ROWDELETED, wParam, lParam )
							On PAM_LOOKUPCUST
								Call PopNumber( colCustNo, TRUE )
								Call SalSetFieldEdit( hWndItem, TRUE )
								If SalIsNull( colDelivIns )
									Call GetCustDefDelivInstruct( colCustNo, colDelivIns, nExecute )
							On PAM_COPYROWINFOFROM
								Call SalTblFetchRow( hWndForm, lParam )
								Set nTemp = colCustNo
							On PAM_COPYROWINFOTO
								Call SalTblFetchRow( hWndForm, lParam )
								Set colCustNo = nTemp
					Column: colCustName

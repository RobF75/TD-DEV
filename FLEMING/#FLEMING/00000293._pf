				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If IsUserAccounts( SqlUser, TRUE )
							If SalSendMsg( tblCustOnLoad, PAM_VALIDATESELECTION, 0, 0 )
								If SalMessageBox( 'Are you sure?','Uninvoice',MB_YesNo ) = IDNO
									Return FALSE
								Call SalWaitCursor( TRUE )
								Set bRowsChanged = FALSE
								Set nYr = cSeasonYear.GetSeasonYear( )
								Call MyTableLoop( tblCustOnLoad, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'UnInvoicing', nLowToHiWithPositioning )
								If bRowsChanged
									Call SalSendMsg( tblCustOnLoad, PAM_REPOPULATE, 0, 0 )
								Call SalWaitCursor( FALSE )
					On PAM_ROWACTION
						If GetCustOrdOnLoadInvNo( dfLoadId, tblCustOnLoad.colCustNo, nYr, nInvoiceNo, nExecute )
							If nInvoiceNo > 0
								If VerifyInvoiceForCust(  tblCustOnLoad.colCustNo, nInvoiceNo, nExecute )
									If UnInvInvNo( tblCustOnLoad.colCustNo, nInvoiceNo, nExecute )
										Call NewUpdateLoadCustInvFlag( dfLoadId, tblCustOnLoad.colCustNo, 'N', nExecute )
										Set bRowsChanged = TRUE
						Return TRUE

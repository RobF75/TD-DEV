			Pushbutton: pbDelLoads
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Remove Loads
				Window Location and Size
					Left:   2.638"
					Top:    0.219"
					Width:  1.113"
					Width Editable? Class Default
					Height: 0.177"
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Arial
				Font Size: 8
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If IDYES = SalMessageBox( 'This function will remove any trace of the selected loads of the system! Continue?', 'Warning', MB_YesNo | MB_DefButton2 )
							Set nYear = cSeasonYear.GetSeasonYear( )
							Call MyTableLoop( tblLoads, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Deleting Loads', nLowToHiWithPositioning )
							Call SalSendMsg( tblLoads, PAM_REPOPULATE, 0, 0 )
					On PAM_ROWACTION
						If AnyPullnNotInvOrdsOnLoad( tblLoads.colLoadId, nYear, bAny, nExecute )
							If bAny
								Call SalMessageBox( 'A Load encountered that cannot be deleted as it has pulled but not invoiced orders on it!', 'Note', MB_Ok )
								Return TRUE
							Else
								If DeleteCustOrdersFromLoad( tblLoads.colLoadId, nYear, nExecute )
									If DeleteCustFromLoad( tblLoads.colLoadId, nExecute )
										If DeleteLoadFromRegion( tblLoads.colLoadId, nExecute )
											If DeleteLoad( tblLoads.colLoadId, nExecute )
												Call DeleteLoad( '', nCommit )
												Call DeleteLoadFromRegion( '', nCommit )
												Call DeleteCustFromLoad( '', nCommit )
												Call DeleteCustOrdersFromLoad( '', 0, nCommit )
												Return TRUE
											Else
												Call DeleteLoadFromRegion( '', nRollback )
												Call DeleteCustFromLoad( '', nRollback )
												Call DeleteCustOrdersFromLoad( '', 0, nRollback )
												Return FALSE
										Else
											Call DeleteCustFromLoad( '', nRollback )
											Call DeleteCustOrdersFromLoad( '', 0, nRollback )
											Return FALSE
									Else
										Call DeleteCustOrdersFromLoad( '', 0, nRollback )
										Return FALSE
								Else
									Return FALSE
						Else
							Return FALSE
			Pushbutton: pbReclaimOrders
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Reclaim Orders
				Window Location and Size
					Left:   5.25"
					Top:    0.115"
					Width:  1.113"
					Width Editable? Class Default
					Height: 0.177"
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Arial
				Font Size: 8
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If IDYES = SalMessageBox( 'This function may take a couple of hours. Continue?', 'Warning', MB_YesNo | MB_DefButton2 )
							! Call MyTableLoop( tblLoads, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Deleting Loads', nLowToHiWithPositioning )
							! Call SalSendMsg( tblLoads, PAM_REPOPULATE, 0, 0 )
							Set nYear = cSeasonYear.GetSeasonYear( )
							If ReclaimOrders(nYear, nExecute)
								Return TRUE
							Else
								Call SalMessageBox( 'This function has failed?', 'Warning', MB_YesNo | MB_DefButton2 )
					! On PAM_ROWACTION
						                                                                                                                    If AnyPullnNotInvOrdsOnLoad( tblLoads.colLoadId, nYear, bAny, nExecute )
							                                                                                                                    If bAny
								                                                                                                                    Call SalMessageBox( 'A Load encountered that cannot be deleted as it has pulled but not invoiced orders on it!', 'Note', MB_Ok )
								                                                                                                                    Return TRUE
							                                                                                                                    Else 
								                                                                                                                    If DeleteCustOrdersFromLoad( tblLoads.colLoadId, nYear, nExecute )
									                                                                                                                    If DeleteCustFromLoad( tblLoads.colLoadId, nExecute )
										                                                                                                                    If DeleteLoadFromRegion( tblLoads.colLoadId, nExecute )
											                                                                                                                    If DeleteLoad( tblLoads.colLoadId, nExecute )
												                                                                                                                    Call DeleteLoad( '', nCommit )
												                                                                                                                    Call DeleteLoadFromRegion( '', nCommit )
												                                                                                                                    Call DeleteCustFromLoad( '', nCommit )
												                                                                                                                    Call DeleteCustOrdersFromLoad( '', 0, nCommit )
												                                                                                                                    Return TRUE
											                                                                                                                    Else 
												                                                                                                                    Call DeleteLoadFromRegion( '', nRollback )
												                                                                                                                    Call DeleteCustFromLoad( '', nRollback )
												                                                                                                                    Call DeleteCustOrdersFromLoad( '', 0, nRollback )
												                                                                                                                    Return FALSE
										                                                                                                                    Else 
											                                                                                                                    Call DeleteCustFromLoad( '', nRollback )
											                                                                                                                    Call DeleteCustOrdersFromLoad( '', 0, nRollback )
											                                                                                                                    Return FALSE
									                                                                                                                    Else 
										                                                                                                                    Call DeleteCustOrdersFromLoad( '', 0, nRollback )
										                                                                                                                    Return FALSE
								                                                                                                                    Else 
									                                                                                                                    Return FALSE
						                                                                                                                    Else 
							                                                                                                                    Return FALSE
			Pushbutton: pbDeeZee
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: DeeZee Load
				Window Location and Size
					Left:   6.55"
					Top:    0.115"
					Width:  1.113"
					Width Editable? Class Default
					Height: 0.177"
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Arial
				Font Size: 8
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblLoads, PAM_VALIDATESELECTION, 0, 0 )
							If MyTableAnyRows( tblLoads, ROW_Selected, 0, nLoadIdCount )
								If nLoadIdCount > 1
									Call SalWaitCursor( FALSE )
									Call SalMessageBox( 'Please select one load to Dee Zee!', 'Warning', MB_Ok )
									Call SalWaitCursor( TRUE )
								Else
									Set nYear = cSeasonYear.GetSeasonYear( )
									If tblLoads.colPulledFlag = 'Y'
										Call SalMessageBox( 'Can NOT Dee Zee a load thats already pulled!', 'Warning', MB_Ok )
									Else If tblLoads.colInvoicedFlag = 'Y'
										Call SalMessageBox( 'Can NOTDee Zee a load thats already invoiced!', 'Warning', MB_Ok )
									Else
										If Not SalCreateWindow( frmRemoveZeeOrders,  hWndForm, tblLoads.colLoadId, naCustNos, dtaOrdDT, nYear, nAllCustOnLoad )
											Call SalMessageBox( 'Could not start the Dee Zee screen yell for help!  Most likely because to many things are open at the one time!', 'Error', MB_Ok )
										! Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'RemoveZeeSweetOrders' )
										! Set sSql = " UPDATE
														Customer_order
													SET
														load_id = null
													WHERE
														load_id = :tblLoads.colLoadId  "
										! Call haSqlHandles[ nSqlHandleNo ].PrepareSetup( sSql )
										! Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
										!
										! If haSqlHandles[ nSqlHandleNo ].PrepareAndExecute( )
											                                                                       If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
												                                                                       Call PushNumber( nCustNo )
												                                                                       Call PushDateTime( dtOrderSysDT )
												                                                                       Call PushString( sTreeTypeDesc )
												                                                                       Call PushString( sCultDesc )
												                                                                       Call PushString( sRootDesc )
												                                                                       Call PushNumber( nConfAmt )
												                                                                       Call PushString( sLoadId )
												                                                                       If NOT SalSendMsg( hWndTable, PAM_ADDROW, 0, SalHStringToNumber( 'INCLUDE_ORDERS' ) )
													                                                                       Call PopString( sLoadId, TRUE )
													                                                                       Call PopNumber( nConfAmt, TRUE )
													                                                                       Call PopString( sRootDesc, TRUE )
													                                                                       Call PopString( sCultDesc, TRUE )
													                                                                       Call PopString( sTreeTypeDesc, TRUE )
													                                                                       Call PopDateTime( dtOrderSysDT, TRUE )
													                                                                       Call PopNumber( nCustNo, TRUE )
											                                                                       Return TRUE
						! Select Case nActionType
							                                                                         Case nAllCustOnLoad
								                                                                         Call CheckLoadForwardOrders( sLoadId, nYear, hWndTblPullSuspectItems, bOk, nExecute )
								                                                                         Break 
							                                                                         Case nSelectedCustOnLoad
								                                                                         Call MakeNumberList( naCustNos, 0, ' , ', '', sTmp )
								                                                                         Call CheckLoadCustForwardOrders( sLoadId, nYear, sTmp, hWndTblPullSuspectItems, bOk, nExecute )
								                                                                         Break 
							                                                                         Case nSelectedCustOrdOnLoad
								                                                                         Call MakeDateTimeList( dtaOrdDT, ' , ', '', sTmp )
								                                                                         Call CheckCustForwardOrders( sLoadId, naCustNos[0], nYear, sTmp, hWndTblPullSuspectItems, bOk, nExecute )
								                                                                         Break 
						! If NOT bOk
						! If NOT SalModalDialog( dlgPullShtDisplaySuspectItems, hWndForm, hWndTblPullSuspectItems, 'Items which possibly should not be pulled!' )
							                                                                         Return SalDestroyWindow( hWndForm )
						! !
						! Call SalTblReset( hWndTblRemoveZeeItems )
						! Select Case nActionType
							                                                                         Case nAllCustOnLoad
								                                                                         Call ChkLoadForForgotOrds( sLoadId, nYear, hWndTblPullSuspectItems, bFound, nExecute )
								                                                                         Break 
							                                                                         Case nSelectedCustOnLoad
								                                                                         Call ChkLoadCustForForgotOrds( sLoadId, naCustNos, nYear, hWndTblPullSuspectItems, bFound, nExecute )
								                                                                         Break 
							                                                                         Default 
								                                                                         Set bFound = FALSE
						! If bFound
							                                                                         If NOT SalModalDialog( dlgPullShtPossiblyIncludeOrds, hWndForm, hWndTblPullSuspectItems )
								                                                                         Return SalDestroyWindow( hWndForm )
						! !
						! Call SalDestroyWindow( hWndTblRemoveZeeItems )
					! On PAM_ROWACTION
						                                                                                                                    If AnyPullnNotInvOrdsOnLoad( tblLoads.colLoadId, nYear, bAny, nExecute )
							                                                                                                                    If bAny
								                                                                                                                    Call SalMessageBox( 'A Load encountered that cannot be deleted as it has pulled but not invoiced orders on it!', 'Note', MB_Ok )
								                                                                                                                    Return TRUE
							                                                                                                                    Else 
								                                                                                                                    If DeleteCustOrdersFromLoad( tblLoads.colLoadId, nYear, nExecute )
									                                                                                                                    If DeleteCustFromLoad( tblLoads.colLoadId, nExecute )
										                                                                                                                    If DeleteLoadFromRegion( tblLoads.colLoadId, nExecute )
											                                                                                                                    If DeleteLoad( tblLoads.colLoadId, nExecute )
												                                                                                                                    Call DeleteLoad( '', nCommit )
												                                                                                                                    Call DeleteLoadFromRegion( '', nCommit )
												                                                                                                                    Call DeleteCustFromLoad( '', nCommit )
												                                                                                                                    Call DeleteCustOrdersFromLoad( '', 0, nCommit )
												                                                                                                                    Return TRUE
											                                                                                                                    Else 
												                                                                                                                    Call DeleteLoadFromRegion( '', nRollback )
												                                                                                                                    Call DeleteCustFromLoad( '', nRollback )
												                                                                                                                    Call DeleteCustOrdersFromLoad( '', 0, nRollback )
												                                                                                                                    Return FALSE
										                                                                                                                    Else 
											                                                                                                                    Call DeleteCustFromLoad( '', nRollback )
											                                                                                                                    Call DeleteCustOrdersFromLoad( '', 0, nRollback )
											                                                                                                                    Return FALSE
									                                                                                                                    Else 
										                                                                                                                    Call DeleteCustOrdersFromLoad( '', 0, nRollback )
										                                                                                                                    Return FALSE
								                                                                                                                    Else 
									                                                                                                                    Return FALSE
						                                                                                                                    Else 
							                                                                                                                    Return FALSE
			!

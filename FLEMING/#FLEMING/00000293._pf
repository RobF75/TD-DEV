			Function: InsertRegion
				Description: Inserts region into the saAllRegions array without duplicates being there.
				Returns
				Parameters
					Receive String: saAllRegions[*]
					String: sRegion
				Static Variables
				Local variables
					Number: nPos
					Boolean: bFound
				Actions
					Set bFound = FALSE
					Set nPos = 0
					While saAllRegions[ nPos ] != '' AND NOT bFound 
						If saAllRegions[ nPos ] = sRegion
							Set bFound = TRUE
						Set nPos = nPos + 1
					If NOT bFound
						Set saAllRegions[ nPos ] = sRegion
						Set nPos = nPos + 1
						Set saAllRegions[ nPos ] = ''
			Function: GetCustNoOnLoads
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					String: sSql
					String: sFuncName
					Number: nInd
					Number: nGotCustNo
				Actions
					Set sFuncName = 'GetCustNoOnLoads'
					Select Case nActionType
						Case nExecute
							Loop Execute
								Loop Connect
									If bHandleConnected
										Break Connect
									Else
										Set bHandleConnected = SqlConnect( hSqlHandle ) 
										If bHandleConnected
											Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
											Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
											Break Connect
										Else
											If IDNO = SalMessageBox( 'Could not connect handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												Break Connect
								Loop Prepare
									If bHandlePrepared
										Break Prepare
									Else
										Set sSql = ' SELECT Cust_No 
												FROM Load_Customers
												INTO :nGotCustNo 
												WHERE 
												  Load_Customers.Load_Id = :sLoadId  order by sequence_no'
										If SqlPrepare( hSqlHandle, sSql )
											Set bHandlePrepared = TRUE
											Break Prepare
										Else
											Set bHandlePrepared = FALSE
											If IDNO = SalMessageBox( 'Could not prepare handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												Break Prepare
								!
								Set nGotCustNo = NUMBER_Null
								!
								If SqlExecute( hSqlHandle )
									While SqlFetchNext( hSqlHandle, nInd )
										Set naCustNos[ nCount ] = nGotCustNo
										Set nCount = nCount + 1
										Set naCustNos[ nCount ] = NUMBER_Null
									Return TRUE
								Else
									Set bHandlePrepared = FALSE
									If IDNO = SalMessageBox( 'Could not execute handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
										Return FALSE
						Case nCommit
							Loop Commit
								If bHandleConnected
									If SqlCommit( hSqlHandle )
										Return TRUE
									Else
										If IDNO = SalMessageBox( 'Could not commit handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
											Return FALSE
								Else
									Return TRUE
						Case nRollback
							Loop Rollback
								If bHandleConnected
									Set bHandlePrepared = FALSE
									If SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
										Return TRUE
									Else
										If IDNO = SalMessageBox( 'Could not rollback handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
											Return FALSE
								Else
									Return TRUE
						Case nDisconnect
							Loop Disconnect
								If bHandleConnected
									If SqlDisconnect( hSqlHandle )
										Set bHandleConnected = FALSE
										Set bHandlePrepared = FALSE
										Return TRUE
									Else
										If IDNO = SalMessageBox( 'Could not disconnect handle in function '||sFuncName||'Contact programmers! RETRY?', 'Error', MB_YesNo )
											Return FALSE
								Else
									Return TRUE
						Case nRePrepare
							Set bHandlePrepared = FALSE
							Return TRUE
			!
			Function: DeleteLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nSqlHandleNo
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'DELLOAD' )
					Select Case nActionType
						Case nExecute
							Set sSql = " DELETE FROM Load 
									WHERE Load_Id = :1 "
							Set sName = 'DELLOAD'
							Set sBind = ':sLoadId'
							Set sInto = ''
							!
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								Return TRUE
							Else
								Return FALSE
						Case nCommit
							Return haSqlHandles[ nSqlHandleNo ].Commit( )
						Case nRollback
							Return haSqlHandles[ nSqlHandleNo ].Rollback( )
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			Function: ReclaimOrders
				Description:
				Returns
					Boolean:
				Parameters
					Number: nYear
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					Date/Time: dtaOrdDT[*]
					Date/Time: dtaTemp
					String: sName
					Number: nSqlHandleNo
					Number: nCustNo
					Number: nInd
					Number: nCount
					String: sLoadId
					String: sPrevLoadId
					Number: nPrevCust
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'RECLAIMORDS6' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT
										cust_no,
										load_id,
										order_date_time
									FROM
										customer_order
									WHERE
										NOT load_id is NULL and 
										year_of_sale = :1 and
										conf_amt > 0
									ORDER BY
										cust_no,
										load_id "
							Set sName = 'RECLAIMORDS6'
							Set sBind = ':nYear'
							Set sInto = ':nCustNo, :sLoadId, :dtaTemp'
							!
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							Set nCount = 0
							Set nPrevCust = NUMBER_Null
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								If haSqlHandles[ nSqlHandleNo ].FetchNext(nInd)
									Set nPrevCust = nCustNo
									Set sPrevLoadId = sLoadId
									Set dtaOrdDT[nCount] = dtaTemp
									Set dtaOrdDT[nCount + 1] = DATETIME_Null
									While (nCustNo = nPrevCust) and (sPrevLoadId = sLoadId)
										If haSqlHandles[ nSqlHandleNo ].FetchNext(nInd)
											If (nCustNo = nPrevCust) and (sPrevLoadId = sLoadId)
												Set nCount = nCount + 1
												Set dtaOrdDT[nCount] = dtaTemp
											Else If (sPrevLoadId != sLoadId) and (nCustNo = nPrevCust)
												If NOT CheckForCustOnLoad(nPrevCust, sPrevLoadId, nExecute)
													Call InsertCustToReclaimLoad(nPrevCust, sPrevLoadId, nExecute)
													Call InsertCustToReclaimLoad(0, sPrevLoadId, nCommit)
													Call UpdateCustOrdToReclaim(nPrevCust, sPrevLoadId, dtaOrdDT, nExecute)
													Call UpdateCustOrdToReclaim(0, '', dtaOrdDT, nCommit)
												Set sPrevLoadId = sLoadId
												Set nCount = 0
												Set dtaOrdDT[nCount] = dtaTemp
												Set dtaOrdDT[nCount + 1] = DATETIME_Null
											Else
												If NOT CheckForCustOnLoad(nPrevCust, sPrevLoadId, nExecute)
													Call InsertCustToReclaimLoad(nPrevCust, sPrevLoadId, nExecute)
													Call InsertCustToReclaimLoad(0, sPrevLoadId, nCommit)
													Call UpdateCustOrdToReclaim(nPrevCust, sPrevLoadId, dtaOrdDT, nExecute)
													Call UpdateCustOrdToReclaim(0, '', dtaOrdDT, nCommit)
												Set nPrevCust = nCustNo
												Set sPrevLoadId = sLoadId
												Set nCount = 0
												Set dtaOrdDT[nCount] = dtaTemp
												Set dtaOrdDT[nCount + 1] = DATETIME_Null
										Else
											Return FALSE
								Return TRUE
							Else
								Return FALSE
						Case nCommit
							Return haSqlHandles[ nSqlHandleNo ].Commit( )
						! Case nRollback
							                                                  Return haSqlHandles[ nSqlHandleNo ].Rollback( )
						! Case nDisconnect
							                                                  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			Function: CheckForCustOnLoad
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					String: sLoadId
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nSqlHandleNo
					Number: nTmp
					Number: nInd
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CHECKCUSTONLOAD' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT
										cust_no
									FROM
										load_customers
									WHERE
										load_id = :2 and
										cust_no = :1 "
							Set sName = 'CHECKCUSTONLOAD'
							Set sBind = ':nCustNo, :sLoadId'
							Set sInto = ' :nTmp'
							!
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								If haSqlHandles[ nSqlHandleNo ].FetchNext(nInd )
									Return TRUE
								Else
									Return FALSE
							Else
								Return FALSE
						! Case nCommit
							                                                  Return haSqlHandles[ nSqlHandleNo ].Commit( )
						! Case nRollback
							                                                  Return haSqlHandles[ nSqlHandleNo ].Rollback( )
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			Function: LoadPulledOrInvoiced
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nSqlHandleNo
					Number: nInd
					String: sPulled
					String: sInv
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CHECKLOADPULLORINV' )
					Select Case nActionType
						Case nExecute
							If sLoadId = 'GONE'
								Return FALSE
							Set sSql = " SELECT
										load_pulled_flag,
										load_invoiced_flag
									FROM
										load
									WHERE
										load_id = :1 "
							Set sName = 'CHECKLOADPULLORINV'
							Set sBind = ' :sLoadId'
							Set sInto = ' :sPulled, :sInv'
							!
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								If haSqlHandles[ nSqlHandleNo ].FetchNext(nInd )
									If sPulled = 'Y' or sInv = 'Y'
										Return TRUE
								Else
									Return FALSE
							Else
								Return FALSE
						! Case nCommit
							                                                  Return haSqlHandles[ nSqlHandleNo ].Commit( )
						! Case nRollback
							                                                  Return haSqlHandles[ nSqlHandleNo ].Rollback( )
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			Function: InsertCustToReclaimLoad
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Receive String: sLoadId
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nSqlHandleNo
					Number: nSeqNo
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'INSCSTTORECLLD' )
					Select Case nActionType
						Case nExecute
							Set sSql = " INSERT INTO
										load_customers(load_id, cust_no, sequence_no, cust_pulled_flag,
											cust_inv_flag, load_order_type)
									VALUES
										(:2, :1, :3, 'N', 'N', 'A') "
							Set sName = 'INSCSTTORECLLD'
							Set sBind = ':nCustNo, :sLoadId, :nSeqNo'
							Set sInto = ''
							!
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							If LoadPulledOrInvoiced(sLoadId,nExecute)
								Set sLoadId = 'RECLAIM'
							If NOT CheckForCustOnLoad(nCustNo, sLoadId, nExecute)
								If Not GetLoadMaxSeq(sLoadId, nSeqNo, nExecute)
									Set nSeqNo = 5
								Else
									Set nSeqNo = nSeqNo + 5
								If haSqlHandles[ nSqlHandleNo ].Execute( )
									Return TRUE
								Else
									Return FALSE
							Else
								Return TRUE
						Case nCommit
							Return haSqlHandles[ nSqlHandleNo ].Commit( )
						! Case nRollback
							                                                  Return haSqlHandles[ nSqlHandleNo ].Rollback( )
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			Function: UpdateCustOrdToReclaim
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					String: sLoadId
					Date/Time: dtaOrdDT[*]
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nSqlHandleNo
					Number: nCount
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'UPDCSTTORECLLD' )
					Select Case nActionType
						Case nExecute
							Set sSql = " UPDATE
											customer_order
										SET
											load_id = :2
										WHERE
											cust_no = :1 and
											order_date_time = :3
										 "
							Set sName = 'UPDCSTTORECLLD'
							Set sBind = ':nCustNo, :sLoadId, :dtaOrdDT[nCount]'
							Set sInto = ''
							!
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set nCount = 0
							While dtaOrdDT[nCount] != DATETIME_Null
								If NOT haSqlHandles[ nSqlHandleNo ].Execute( )
									Call SalMessageBox('Error updateing load','Message' , MB_Ok)
									Return FALSE
								Set nCount = nCount + 1
								! Call haSqlHandles[ nSqlHandleNo ].Commit( )
							Return TRUE
							! Else
							! If LoadPulledOrInvoiced(sLoadId,nExecute)
								                                                 Set sLoadId = 'RECLAIM'
							! If NOT CheckForCustOnLoad(nCustNo, sLoadId, nExecute)
								                                                 If Not GetLoadMaxSeq(sLoadId, nSeqNo, nExecute)
									                                                 Set nSeqNo = 5
								                                                 Else 
									                                                 Set nSeqNo = nSeqNo + 5
							! Else
								                                                 Return TRUE
						Case nCommit
							Return haSqlHandles[ nSqlHandleNo ].Commit( )
						! Case nRollback
							                                                  Return haSqlHandles[ nSqlHandleNo ].Rollback( )
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )

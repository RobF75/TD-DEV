							On PAM_EDITCHECK
								If colInvoicedFlag = 'Y'
									Return FALSE
								Else
									Return TRUE
							On PAM_DATAVAL
								If SalIsNull( hWndItem )
									Set colPulledFlag = 'N'
								!

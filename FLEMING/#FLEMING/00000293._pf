			Function: GetLoadTableDets
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Receive String: sLoadDesc
					Receive String: sTransportId
					Receive Date/Time: dtShipDate
					Receive Date/Time: dtExptReturnDate
					Receive String: sLoadPrimaryType
					Receive String: sPullFlag
					Receive String: sInvFlag
					Receive Date/Time: dtInvoiceByDate
					Receive String: sLoadDriver
					Receive String: sLoadComments
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nSqlHandleNo
					!
					String: sGotLoadDesc
					String: sGotTransportId
					Date/Time: dtGotShipDate
					Date/Time: dtGotExptReturnDate
					String: sGotLoadPrimaryType
					String: sGotPullFlag
					String: sGotInvFlag
					Date/Time: dtGotInvoiceByDate
					String: sGotLoadDriver
					String: sGotLoadComments
				Actions
					! Number: nSqlHandleNo
					! haSqlHandles[ nSqlHandleNo ]
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'LDTBLREPOP' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Load_Description, 
									  Transport_Id, 
									  Shipping_Date, 
									  Exp_Return_Date, 
									  Load_Primary_Type, 
									  Load_Pulled_Flag, 
									  Load_Invoiced_Flag, 
									  Invoice_By_Date, 
									  Load_Driver, 
									  Load_Comments 
									FROM 
									  Load 
									WHERE 
									  Load_Id = :1 "
							Set sName = 'LDTBLREPOP'
							Set sBind = ':sLoadId'
							Set sInto = ' :sGotLoadDesc, 
									:sGotTransportId, 
									:dtGotShipDate, 
									:dtGotExptReturnDate, 
									:sGotLoadPrimaryType, 
									:sGotPullFlag, 
									:sGotInvFlag, 
									:dtGotInvoiceByDate, 
									:sGotLoadDriver, 
									:sGotLoadComments'
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set sLoadDesc = ''
							Set sTransportId = ''
							Set dtShipDate = DATETIME_Null
							Set dtExptReturnDate = DATETIME_Null
							Set sLoadPrimaryType = ''
							Set sPullFlag = ''
							Set sInvFlag = ''
							Set dtInvoiceByDate = DATETIME_Null
							Set sLoadDriver = ''
							Set sLoadComments = ''
							!
							Set sGotLoadDesc = ''
							Set sGotTransportId = ''
							Set dtGotShipDate = DATETIME_Null
							Set dtGotExptReturnDate = DATETIME_Null
							Set sGotLoadPrimaryType = ''
							Set sGotPullFlag = ''
							Set sGotInvFlag = ''
							Set dtGotInvoiceByDate = DATETIME_Null
							Set sGotLoadDriver = ''
							Set sGotLoadComments = ''
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									Set sLoadDesc = sGotLoadDesc
									Set sTransportId = sGotTransportId
									Set dtShipDate = dtGotShipDate
									Set dtExptReturnDate = dtGotExptReturnDate
									Set sLoadPrimaryType = sGotLoadPrimaryType
									Set sPullFlag = sGotPullFlag
									Set sInvFlag = sGotInvFlag
									Set dtInvoiceByDate = dtGotInvoiceByDate
									Set sLoadDriver = sGotLoadDriver
									Set sLoadComments = sGotLoadComments
								Return TRUE
							Else
								Return FALSE
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			!
			Function: ResetLoadsForNewSeason
				Description: A decision was made that when user selects loads, the 
						shipping date range for prior season criteria will be 
						disregarded.  Else for no load selections ie: ALL the 
						shipping date criteria is inforced. Likewise for the 
						load_invoiced_flag.  For selected loads it is ignored else 
						it must be 'Y' for the ALL operations.
				Returns
					Boolean:
				Parameters
					Number: nYear
					! saLoads[*] is assumed to be null terminated.
					String: saLoads[*]
					! sLoadsType = 'SELECTED' OR 'ALL'
					String: sLoadsType
					Number: nActionType
				Static Variables
				Local variables
					Number: nSqlHandleNoL
					Number: nSqlHandleNoLC
					String: sSql
					Boolean: bOk
					Number: nYearMinOne
					Number: nYearMinTwo
					String: sSelectionLoads
				Actions
					Set nSqlHandleNoL = SqlHandlesGetReferenceNo( 'ResetLoadsForNewSeason' )
					Set nSqlHandleNoLC = SqlHandlesGetReferenceNo( 'ResetLoadsForNewSeason2' )
					Select Case nActionType
						Case nExecute
							If sLoadsType = 'ALL'
								Set sSql = "UPDATE Load 
										SET 
										  Shipping_Date = 
										     @IF(@DAY(Load.Shipping_Date)-29,
										        @DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)), 
										        @IF(@MONTH(Load.Shipping_Date)-2, 
										        @DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)), 
										        @DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)-1))), 
										  Load_Pulled_Flag = 'N', 
										  Load_Invoiced_Flag = 'N', 
										  Invoice_By_Date = NULL
										WHERE 
										  Shipping_Date < @DATE(:nYearMinOne, 9, 1) AND 
										  Shipping_Date >= @DATE(:nYearMinTwo, 9, 1) AND 
										  Load_Invoiced_Flag = 'Y' "
							Else
								Call MakeStringList( saLoads, ',', "'", sSelectionLoads )
								Set sSql = "UPDATE Load 
										SET 
										  Shipping_Date = 
										     @IF(@DAY(Load.Shipping_Date)-29,
										        @DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)), 
										        @IF(@MONTH(Load.Shipping_Date)-2, 
										        @DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)), 
										        @DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)-1))), 
										  Load_Pulled_Flag = 'N', 
										  Load_Invoiced_Flag = 'N', 
										  Invoice_By_Date = NULL
										WHERE 
										  Load_Id IN ( " || sSelectionLoads || " ) "
							Call haSqlHandles[ nSqlHandleNoL ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoL ].hSqlHandle )
							!
							If sLoadsType = 'ALL'
								Set sSql = "UPDATE Load_Customers 
										SET 
										  Anticip_Del_Date = 
										    @IF(@DAY(Anticip_Del_Date)-29,
										        @DATE(:nYear, @MONTH(Anticip_Del_Date), @DAY(Anticip_Del_Date)), 
										        @IF(@MONTH(Anticip_Del_Date)-2, 
										        @DATE(:nYear, @MONTH(Anticip_Del_Date), @DAY(Anticip_Del_Date)), 
										        @DATE(:nYear, @MONTH(Anticip_Del_Date), @DAY(Anticip_Del_Date)-1))), 
										  Cust_Pulled_Flag = 'N',
										  Cust_Inv_Flag = 'N', 
										  Cust_Cont_Flag = 'N' 
										WHERE
										  Load_Customers.Load_Id IN 
										(
										  SELECT 
										    Load.Load_Id 
										  FROM 
										    Load 
										  WHERE 
										    Load.Shipping_Date < @DATE(:nYearMinOne, 9, 1) AND 
										    Load.Shipping_Date >= @DATE(:nYearMinTwo, 9, 1) AND 
										    Load.Load_Invoiced_Flag = 'Y'
										)"
							Else
								Set sSql = "UPDATE Load_Customers 
										SET 
										  Anticip_Del_Date = 
										    @IF(@DAY(Anticip_Del_Date)-29,
										        @DATE(:nYear, @MONTH(Anticip_Del_Date), @DAY(Anticip_Del_Date)), 
										        @IF(@MONTH(Anticip_Del_Date)-2, 
										        @DATE(:nYear, @MONTH(Anticip_Del_Date), @DAY(Anticip_Del_Date)), 
										        @DATE(:nYear, @MONTH(Anticip_Del_Date), @DAY(Anticip_Del_Date)-1))), 
										  Cust_Pulled_Flag = 'N',
										  Cust_Inv_Flag = 'N', 
										  Cust_Cont_Flag = 'N' 
										WHERE
										  Load_Customers.Load_Id IN ( " || sSelectionLoads || " ) "
							Call haSqlHandles[ nSqlHandleNoLC ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoLC ].hSqlHandle )
							!
							Set nYearMinOne = nYear - 1
							Set nYearMinTwo = nYear - 2
							!
							If haSqlHandles[ nSqlHandleNoLC ].Execute( )
								If haSqlHandles[ nSqlHandleNoL ].Execute( )
									Call haSqlHandles[ nSqlHandleNoLC ].Commit( )
									Call haSqlHandles[ nSqlHandleNoL ].Commit( )
									Return TRUE
								Else
									Call haSqlHandles[ nSqlHandleNoLC ].Rollback( )
									Return FALSE
							Else
								Return FALSE
						Case nCommit
							Set bOk = TRUE
							If NOT haSqlHandles[ nSqlHandleNoL ].Commit( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nSqlHandleNoLC ].Commit( )
								Set bOk = FALSE
							Return bOk
						Case nRollback
							Set bOk = TRUE
							If NOT haSqlHandles[ nSqlHandleNoL ].Rollback( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nSqlHandleNoLC ].Rollback( )
								Set bOk = FALSE
							Return bOk
						Case nDisconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nSqlHandleNoL ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nSqlHandleNoLC ].Disconnect( )
								Set bOk = FALSE
							Return bOk
			! bellow copy prior to change as per specs 
					  In reset loads for new season - have where a selection of rows to be 
					  done - not all.
			! Function: ResetLoadsForNewSeason
				                                                                                                                              Description: 
				                                                                                                                              Returns 
					                                                                                                                              Boolean: 
				                                                                                                                              Parameters 
					                                                                                                                              Number: nYear
					                                                                                                                              Number: nActionType
				                                                                                                                              Static Variables 
				                                                                                                                              Local variables 
					                                                                                                                              Number: nSqlHandleNoL
					                                                                                                                              Number: nSqlHandleNoLC
					                                                                                                                              String: sSql
					                                                                                                                              Boolean: bOk
					                                                                                                                              Number: nYearMinOne
					                                                                                                                              Number: nYearMinTwo
				                                                                                                                              Actions 
					                                                                                                                              Set nSqlHandleNoL = SqlHandlesGetReferenceNo( 'ResetLoadsForNewSeason' )
					                                                                                                                              Set nSqlHandleNoLC = SqlHandlesGetReferenceNo( 'ResetLoadsForNewSeason2' )
					                                                                                                                              Select Case nActionType
						                                                                                                                              Case nExecute
							                                                                                                                              Set sSql = "UPDATE Load 
									SET 
									  Shipping_Date = 
									     @IF(@DAY(Load.Shipping_Date)-29,
									        @DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)), 
									        @IF(@MONTH(Load.Shipping_Date)-2, 
									        @DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)), 
									        @DATE(:nYear, @MONTH(Load.Shipping_Date), @DAY(Load.Shipping_Date)-1))), 
									  Load_Pulled_Flag = 'N', 
									  Load_Invoiced_Flag = 'N', 
									  Invoice_By_Date = NULL
									WHERE 
									  Shipping_Date < @DATE(:nYearMinOne, 9, 1) AND 
									  Shipping_Date >= @DATE(:nYearMinTwo, 9, 1) AND 
									  Load_Invoiced_Flag = 'Y' "
							                                                                                                                              Call haSqlHandles[ nSqlHandleNoL ].PrepareSetup( sSql )
							                                                                                                                              Call SqlVarSetup( haSqlHandles[ nSqlHandleNoL ].hSqlHandle )
							!
							                                                                                                                              Set sSql = "UPDATE Load_Customers 
									SET 
									  Anticip_Del_Date = 
									    @IF(@DAY(Anticip_Del_Date)-29,
									        @DATE(:nYear, @MONTH(Anticip_Del_Date), @DAY(Anticip_Del_Date)), 
									        @IF(@MONTH(Anticip_Del_Date)-2, 
									        @DATE(:nYear, @MONTH(Anticip_Del_Date), @DAY(Anticip_Del_Date)), 
									        @DATE(:nYear, @MONTH(Anticip_Del_Date), @DAY(Anticip_Del_Date)-1))), 
									  Cust_Pulled_Flag = 'N',
									  Cust_Inv_Flag = 'N'
									WHERE
									  Load_Customers.Load_Id IN 
									(
									  SELECT 
									    Load.Load_Id 
									  FROM 
									    Load 
									  WHERE 
									    Load.Shipping_Date < @DATE(:nYearMinOne, 9, 1) AND 
									    Load.Shipping_Date >= @DATE(:nYearMinTwo, 9, 1) AND 
									    Load.Load_Invoiced_Flag = 'Y'
									)"
							                                                                                                                              Call haSqlHandles[ nSqlHandleNoLC ].PrepareSetup( sSql )
							                                                                                                                              Call SqlVarSetup( haSqlHandles[ nSqlHandleNoLC ].hSqlHandle )
							!
							                                                                                                                              Set nYearMinOne = nYear - 1
							                                                                                                                              Set nYearMinTwo = nYear - 2
							!
							                                                                                                                              If haSqlHandles[ nSqlHandleNoLC ].Execute( )
								                                                                                                                              If haSqlHandles[ nSqlHandleNoL ].Execute( )
									                                                                                                                              Call haSqlHandles[ nSqlHandleNoLC ].Commit( )
									                                                                                                                              Call haSqlHandles[ nSqlHandleNoL ].Commit( )
									                                                                                                                              Return TRUE
								                                                                                                                              Else 
									                                                                                                                              Call haSqlHandles[ nSqlHandleNoLC ].Rollback( )
									                                                                                                                              Return FALSE
							                                                                                                                              Else 
								                                                                                                                              Return FALSE
						                                                                                                                              Case nCommit
							                                                                                                                              Set bOk = TRUE
							                                                                                                                              If NOT haSqlHandles[ nSqlHandleNoL ].Commit( )
								                                                                                                                              Set bOk = FALSE
							                                                                                                                              If NOT haSqlHandles[ nSqlHandleNoLC ].Commit( )
								                                                                                                                              Set bOk = FALSE
							                                                                                                                              Return bOk
						                                                                                                                              Case nRollback
							                                                                                                                              Set bOk = TRUE
							                                                                                                                              If NOT haSqlHandles[ nSqlHandleNoL ].Rollback( )
								                                                                                                                              Set bOk = FALSE
							                                                                                                                              If NOT haSqlHandles[ nSqlHandleNoLC ].Rollback( )
								                                                                                                                              Set bOk = FALSE
							                                                                                                                              Return bOk
						                                                                                                                              Case nDisconnect
							                                                                                                                              Set bOk = TRUE
							                                                                                                                              If NOT haSqlHandles[ nSqlHandleNoL ].Disconnect( )
								                                                                                                                              Set bOk = FALSE
							                                                                                                                              If NOT haSqlHandles[ nSqlHandleNoLC ].Disconnect( )
								                                                                                                                              Set bOk = FALSE
							                                                                                                                              Return bOk
			Function: CheckLoadHasPRCs
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nYear
					Receive Boolean: bNeedPRC
					! Receive Number: naPRCNeededCustNos[*]
					! Receive Number: nPRCNeededCustNosCount
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nSqlHandleNo
					Number: nGotCustNo
					Number: nPos
					Number: naPRCNeededCustNos[*]
					Number: nPRCNeededCustNosCount
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'LDCHKNDZEINV4' )
					Select Case nActionType
						Case nExecute
							If TRUE
								Set sSql = " SELECT DISTINCT
										  Load_Customers.Cust_No
										FROM
										  Load_Customers,
										  Customer_Order,
										  Stock_Item,
										  Customer_Master,
										  Customer_Type
										WHERE
										  customer_order.Load_Id = :1 AND
										  Load_Customers.Cust_No = Customer_Order.Cust_No AND
										  Customer_Order.Year_Of_Sale = :2 AND
										  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND
										  Load_Customers.Cust_No = Customer_Master.Cust_No AND
										   Customer_Order.Conf_Amt > 0 AND
										   Stock_Item.Prod_Royalty = 'Y' and
										   Customer_order.invoiced_flag = 'N' 
										ORDER BY
										  Load_Customers.Sequence_No "
								Set sName = 'LDCHKNDZEINV4'
								Set sBind = ':sLoadId, :nYear'
								Set sInto = ':nGotCustNo'
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set bNeedPRC = FALSE
							Set nPos = 0
							Set naPRCNeededCustNos[ nPos ] = NUMBER_Null
							Set nPRCNeededCustNosCount = 0
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									Set bNeedPRC = TRUE
									!
									Set naPRCNeededCustNos[ nPos ] = nGotCustNo
									Set nPos = nPos + 1
									Set naPRCNeededCustNos[ nPos ] = NUMBER_Null
									!
									Set nPRCNeededCustNosCount = nPRCNeededCustNosCount + 1
									Set bNeedPRC = TRUE
								! Return TRUE
							Else
								! Return FALSE
								Set bNeedPRC = FALSE
							Return bNeedPRC
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			Function: CheckLoadHasNormal
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nYear
					Receive Boolean: bNeedNormal
					! Receive Number: naPRCNeededCustNos[*]
					! Receive Number: nPRCNeededCustNosCount
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nSqlHandleNo
					Number: nGotCustNo
					Number: nPos
					Number: naNoPRCNeededCustNos[*]
					Number: nNoPRCNeededCustNosCount
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'LDCHKNDFLEMINV1' )
					Select Case nActionType
						Case nExecute
							If TRUE
								Set sSql = " SELECT DISTINCT
										  Load_Customers.Cust_No
										FROM
										  Load_Customers,
										  Customer_Order,
										  Stock_Item,
										  Customer_Master,
										  Customer_Type
										WHERE
										  customer_order.Load_Id = :1 AND
										  Load_Customers.Cust_No = Customer_Order.Cust_No AND
										  Customer_Order.Year_Of_Sale = :2 AND
										  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND
										  Load_Customers.Cust_No = Customer_Master.Cust_No AND
										   Customer_Order.Conf_Amt > 0 AND
										   Stock_Item.Prod_Royalty != 'Y' and
										   Customer_order.invoiced_flag = 'N'
										ORDER BY
										  Load_Customers.Sequence_No "
								Set sName = 'LDCHKNDFLEMINV1'
								Set sBind = ':sLoadId, :nYear'
								Set sInto = ':nGotCustNo'
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set bNeedNormal = FALSE
							Set nPos = 0
							Set naPRCNeededCustNos[ nPos ] = NUMBER_Null
							Set nNoPRCNeededCustNosCount = 0
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									Set bNeedNormal = TRUE
									!
									Set naPRCNeededCustNos[ nPos ] = nGotCustNo
									Set nPos = nPos + 1
									Set naPRCNeededCustNos[ nPos ] = NUMBER_Null
									!
									Set nNoPRCNeededCustNosCount = nNoPRCNeededCustNosCount + 1
									Set bNeedNormal = TRUE
								! Return TRUE
							Else
								! Return FALSE
								Set bNeedNormal = FALSE
							Return bNeedNormal
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			! Function: CheckLoadZeeOrders
				                                                                        Description: 
				                                                                        Returns 
					                                                                        Boolean: 
				                                                                        Parameters 
					                                                                        String: sLoadId
					                                                                        Number: nYear
					                                                                        String: sCustNos
					                                                                        Window Handle: hWndTable
					                                                                        Receive Boolean: bOk
					                                                                        Number: nActionType
				                                                                        Static Variables 
					! hcSqlHandle: fcOurHandle
				                                                                        Local variables 
					                                                                        String: sSql
					!
					                                                                        Number: nGotCustNo
					                                                                        String: sTreeTypeDesc
					                                                                        String: sCultDesc
					                                                                        String: sRootDesc
					                                                                        Number: nSqlHandleNo
					!
					                                                                        String: sTmp
					                                                                        Number: nInd
				                                                                        Actions 
					                                                                        Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CheckLoadZeeOrders' )
					                                                                        Select Case nActionType
						                                                                        Case nExecute
							                                                                        Set sSql = " SELECT
									  Customer_Order.Cust_No,
									  Stock_Item.Tree_Type_Desc,
									  Stock_Item.Cult_Desc,
									  Stock_Item.Root_Desc
									FROM
									  Customer_Order,
									  Stock_Item,
									load_Customers
									INTO
									  :nGotCustNo,
									  :sTreeTypeDesc,
									  :sCultDesc,
									  :sRootDesc
									WHERE
									  Customer_Order.Cust_No IN ( " || sCustNos || " ) AND
									  Customer_Order.Load_Id = :sLoadId AND
									  Customer_Order.Year_Of_Sale = :nYear AND
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND
									  Customer_Order.Conf_Amt > 0 AND
									  Customer_Order.Batch_Year_Of_Sale > 0 AND
									  Customer_Order.Batch_Location_Id > 0 AND
									  NOT Customer_Order.Pull_Sheet_Issued = 'Y' AND
									  NOT Customer_Order.Invoiced_Flag = 'Y' "
							!
							                                                                        Set bOk = TRUE
							!
							                                                                        Call haSqlHandles[ nSqlHandleNo ].PrepareSetup( sSql )
							                                                                        Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							                                                                        If haSqlHandles[ nSqlHandleNo ].PrepareAndExecute( )
								                                                                        While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									                                                                        Call PushNumber( nGotCustNo )
									                                                                        Call PushString( sTreeTypeDesc )
									                                                                        Call PushString( sCultDesc )
									                                                                        Call PushString( sRootDesc )
									                                                                        Call PushString( 'Forward Orders' )
									                                                                        If NOT SalSendMsg( hWndTable, PAM_ADDROW, 0, 0 )
										                                                                        Call PopString( sTmp, TRUE )
										                                                                        Call PopString( sTmp, TRUE )
										                                                                        Call PopString( sTmp, TRUE )
										                                                                        Call PopString( sTmp, TRUE )
										                                                                        Call PopNumber( nCustNo, TRUE )
									                                                                        Set bOk = FALSE
								                                                                        Return TRUE
							                                                                        Else 
								                                                                        Return FALSE
						                                                                        Case nDisconnect
							                                                                        Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
		Window Parameters
		Window Variables
			Number: nRowsSelected
			String: saLoadIds[*]
			Date/Time: dtaLoadsShipDates[*]
			!
			Number: nLoadRegionsPos
			String: saLoadRegions[*]
			Number: nAllRegionPos
			String: saAllRegions[*]
			String: sArguments
			Number: nLoadIdCount
			Number: nYear
			Number: nType
			Boolean: bContWanted
			Boolean: bContinue
			Boolean: bExists
			Boolean: bIncludeInvoiced
			!
			Number: naCustNos[*]
			Number: nCount
			Date/Time: dtaOrdDT[*]
			!
			Date/Time: dtTmp
			Date/Time: dtInvoiceDate
			Date/Time: dtaOrderDT[*]
			! String: sIncludeContainers
			String: sStockType
			String: sTmp
			Number: nTmp
			Window Handle: hWndTmp
			Boolean: bAny
			Boolean: bAnyPRCOnLoad
			Boolean: bAnyNormalOnLoad
			Number: naPRCNeededCustNos[*]
			Window Handle: hWndTblRemoveZeeItems
		Message Actions
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
				Set bQueryTableAllowed = FALSE
				Set bTablePrintReportAllowed = TRUE
				Set bOrderTableAllowed = TRUE
			On SAM_CreateComplete
				Call SalWaitCursor( FALSE )
			On SAM_Destroy
				Call UpdateCustRegionsOnLoads( saLoadIds, nDisconnect )
				Call JanUnPullLoad( '', 0, nDisconnect )
				Call MaintainLoadsOrders( saLoadIds, dtaLoadsShipDates, 0, '', nDisconnect )
				Call GetLoadTableDets( '', sTmp, sTmp, dtTmp, dtTmp, sTmp, sTmp, sTmp, dtTmp, sTmp, sTmp, nDisconnect )
				Call ResetLoadsForNewSeason( 0, saLoadIds, '', nDisconnect )
				Call AnyPullnNotInvOrdsOnLoad( '', 0, bAny, nDisconnect )
				Call UpdtCustDenormMeetAddrs( 0, '', nDisconnect )
				Call CheckLoadDupSeqNo( '', bExists, nDisconnect )
				Call CheckLoadHasPRCs('', 0, bAnyPRCOnLoad, nDisconnect)
				Call CheckLoadHasNormal('', 0, bAnyNormalOnLoad, nDisconnect)
				Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
			On PAM_REPORTFINISHED
				! If wParam = nPrintPulls OR wParam = nInvoice
					                                                                                                                              Call GetLoadInvPullFlags( tblLoads.colLoadId, tblLoads.colPulledFlag, tblLoads.colInvoicedFlag, nExecute )
				! Else
					                                                                                                                              Call SalSendMsg( tblLoads, PAM_REPOPULATE, 0, 0 )
				If wParam = nLabelPullSheet
					Call SalSendMsg( pbPrintLblPull, PAM_REPORTFINISHED, wParam, lParam )
				Else
					Call GetLoadTableDets( tblLoads.colLoadId, tblLoads.colDescription, tblLoads.colTransportId, tblLoads.colShipDate, 
							tblLoads.colExpReturnDate, tblLoads.colLoadType, tblLoads.colPulledFlag, tblLoads.colInvoicedFlag, tblLoads.colInvByDate, 
							tblLoads.colLoadDriver, tblLoads.colComments, nExecute )
			On PAM_INVOICECOMPLETE
				Call SalMessageBox('Continue with Zee Sweet Invoices', 'Message', MB_Ok)
				Call SalCreateWindow( TblPrintInvoices, hWndForm, dtInvoiceDate, 0, dtaOrderDT, cSeasonYear.GetSeasonYear( ), tblLoads.colLoadId, 'LOAD', naPRCNeededCustNos, 'Z' )
			On SAM_Close
				If IDCANCEL = SalMessageBox( 'You are about to EXIT the LOADS program, Do you want to do this?', 'Warning', MB_OkCancel )
					Return FALSE
			!
			On PAM_ALLREGONSELLOADS
				Set saAllRegions[ 0 ] = ''
				Set saAllRegions[ 1 ] = ''
				Call MyTableLoop( tblLoads, hWndItem, PAM_REGSONLOAD, ROW_Selected, 0, 'Collecting Regions On Load', nLowToHi )
			On PAM_REGSONLOAD
				If GetListRegionsOnLoad( tblLoads.colLoadId, saLoadRegions, nExecute )
					Set nLoadRegionsPos = 0
					While saLoadRegions[ nLoadRegionsPos ] != ''
						Call InsertRegion( saAllRegions, saLoadRegions[ nLoadRegionsPos ] )
						Set nLoadRegionsPos = nLoadRegionsPos + 1
				Return TRUE
			!
			! bellow message used by Reset Loads for new season menu item.
			On PAM_ROWACTION
				Set saLoadIds[ nLoadIdCount ] = tblLoads.colLoadId
				Set nLoadIdCount = nLoadIdCount + 1
				Set saLoadIds[ nLoadIdCount ] = ''
				Return TRUE

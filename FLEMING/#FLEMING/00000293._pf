		Functions
			Function: RegionIdExists
				Description:
				Returns
					Boolean:
				Parameters
					String: sRegionId
					Number: nExecuteOrDisconnect
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					String: sSql
					Number: nInd
					Boolean: bOk
				Actions
					If nExecuteOrDisconnect != nDisconnect
						If NOT bHandleConnected
							Set bHandleConnected = SqlConnect( hSqlHandle ) 
							If bHandleConnected
								Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
								Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
							Else
								Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
								Return FALSE
						If NOT bHandlePrepared
							Set sSql = ' SELECT Region_Id FROM Region WHERE Region_Id = :sRegionId '
							If SqlPrepare( hSqlHandle, sSql )
								Set bHandlePrepared = TRUE
							Else
								Set bHandlePrepared = FALSE
						If SqlExecute( hSqlHandle )
							If SqlFetchNext( hSqlHandle, nInd )
								Return TRUE
							Else
								Return FALSE
						Else
							Set bHandlePrepared = FALSE
							Call SalMessageBox( 'SqlExecute had a error in LoadIdExists, Contact programmers please!', 'ERROR', MB_Ok )
							Return FALSE
					Else
						Set bOk = TRUE
						Set bHandlePrepared = FALSE
						If bHandleConnected
							Set bHandleConnected = FALSE
							Set bOk = SqlDisconnect( hSqlHandle )
						Return bOk
			! Function: NewRegionIdExists
				                                                                                                                              Description: Use this templet for any new SQL functions as of 12th April 1995
				                                                                                                                              Returns 
					                                                                                                                              Boolean: 
				                                                                                                                              Parameters 
					                                                                                                                              String: sRegionId
					                                                                                                                              Number: nActionType
				                                                                                                                              Static Variables 
					                                                                                                                              OurSqlHandle: fcOurHandle
				                                                                                                                              Local variables 
					                                                                                                                              String: sSql
					                                                                                                                              Number: nInd
					                                                                                                                              Boolean: bOk
				                                                                                                                              Actions 
					                                                                                                                              Select Case nActionType
						                                                                                                                              Case nExecute
							                                                                                                                              Set sSql = ' SELECT Region_Id FROM Region WHERE Region_Id = :dlgOutstandOrdOnOrAllRegions.NewRegionIdExixts.sRegionId '
							                                                                                                                              Set bOk = fcOurHandle.Execute( sSql )
							                                                                                                                              If bOk
								                                                                                                                              Return fcOurHandle.FetchNext( nInd )
							                                                                                                                              Else 
								                                                                                                                              Return bOk
						                                                                                                                              Case nCommit
							                                                                                                                              Return fcOurHandle.Commit( )
						                                                                                                                              Case nRollback
							                                                                                                                              Return fcOurHandle.Rollback( )
						                                                                                                                              Case nDisconnect
							                                                                                                                              Return fcOurHandle.Disconnect( )
						                                                                                                                              Case nRePrepare
							                                                                                                                              Return fcOurHandle.RePrepare( )
		Window Parameters
		Window Variables
			String: sTmp
			String: sSql
			! OurSqlHandle: fcRegionExists
		Message Actions
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
			On SAM_CreateComplete
				Set rbForAllRegions = TRUE
				Set rbContNOTWanted = TRUE
				Call SalSendMsgToChildren( hWndForm, PAM_REGIONTYPE, nAllRegions, 0 )
				Call SalWaitCursor( FALSE )
			On SAM_Destroy
				Call RegionIdExists( '', nDisconnect )
				! Call NewRegionIdExists( '', nDisconnect )

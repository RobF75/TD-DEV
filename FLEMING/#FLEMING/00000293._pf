				Functions
					Function: LoadIdRegionIdExists
						Description:
						Returns
							Boolean:
						Parameters
							String: sLoadId
							String: sRegionId
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Load_Id, Region_Id FROM Region_Load WHERE Load_Id = :sLoadId AND Region_Id = :sRegionId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									If nInd = FETCH_EOF
										Return FALSE
									Else
										Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in LoadIdRegionIdExists, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
				Window Variables
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' REGION_LOAD '
						Set sSQLPOPTABLENAME = ' REGION_LOAD, REGION, FREIGHT_CODES '
						Set sSQLWHERE = ' WHERE Region_Load.Region_Id = Region.Region_Id AND 
								  Region.Freight_Code = Freight_Codes.Freight_Code(+) AND 
								  Region_Load.Load_Id = :frmRegionsOnLoad.dfLoadId'
						Set sORDERBY = ' ORDER BY Region_Load.Region_Id '
						Set sROWID = ' REGION_LOAD.ROWID '
						Set sTableHeading = 'Regions On Load'
						Set hWndRowNewColumn = colRegionId
						Set nTableFillType = TBL_FillAll
					On SAM_Destroy
						Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
						Call LoadIdRegionIdExists( '', '', nDisconnect )

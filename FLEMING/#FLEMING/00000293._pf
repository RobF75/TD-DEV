			Pushbutton: pbUpdCustRegOnLoads
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Update Customer Regions On Loads
				Window Location and Size
					Left:   2.638"
					Top:    0.031"
					Width:  2.375"
					Width Editable? Class Default
					Height: 0.156"
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Arial
				Font Size: 8
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblLoads, PAM_VALIDATESELECTION, 0, 0 )
							Set nLoadIdCount = 0
							Set nRowsSelected = TBL_MinRow
							While SalTblFindNextRow( tblLoads, nRowsSelected, ROW_Selected, 0 )
								Call SalTblFetchRow( tblLoads, nRowsSelected )
								Set saLoadIds[ nLoadIdCount ] = tblLoads.colLoadId
								Set nLoadIdCount = nLoadIdCount + 1
								Set saLoadIds[ nLoadIdCount ] = ''
							Call UpdateCustRegionsOnLoads( saLoadIds, nExecute )
			Pushbutton: pbOutstandOrders

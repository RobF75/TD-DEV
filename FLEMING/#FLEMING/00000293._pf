						Input Mask: Class Default
						Cell Options
							Cell Type? Class Default
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? Class Default
								Vertical Scroll? Class Default
								Auto Drop Down? Class Default
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
							On PAM_SETINSTANCEVARS
								Set colConfAmt.sSQLCOLNAME = ' CUSTOMER_ORDER.CONF_AMT '
								Set colConfAmt.bInsert = FALSE
								Set colConfAmt.bUpdate = FALSE
							On PAM_COPYROWINFOFROM
								Call SalTblFetchRow( hWndForm, lParam )
								Set nTemp = colConfAmt
							On PAM_COPYROWINFOTO
								Call SalTblFetchRow( hWndForm, lParam )
								Set colConfAmt = nTemp
							On SAM_AnyEdit
								If SalIsNull( hWndItem )
									Set colAllocFlag = 'N'
								Else
									Set colAllocFlag = 'Y'
								Call SalSetFieldEdit( colAllocFlag, TRUE )
							On PAM_EDITCHECK
								If colInvoiced = 'Y'
									Return FALSE
								Else
									Return TRUE
							On PAM_DATAVAL
								If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
									If colConfAmt > 0
										Return TRUE
									Else
										Call SalMessageBox( 'Please ensure that all the new orders have a valid Confirmed Amount!.', 'Warning', MB_Ok )
										Return FALSE
								Else If SalTblQueryRowFlags( hWndForm, lParam, ROW_Edited )
									If colConfAmt >= 0
										Return TRUE
									Else
										Call SalMessageBox( 'Please ensure that all the orders have all valid Confirmed Amount!.', 'Warning', MB_Ok )
										Return FALSE
								Else
									Return TRUE
							On PAM_SETFWDCOLUMNCOLOR
								! wParam = back ground color
								! lParam = text color
								If wParam != 0
									Call SalColorSet( hWndItem, COLOR_IndexWindow, wParam )
								If lParam != 0
									Call SalColorSet( hWndItem, COLOR_IndexCellText, lParam )
								Return TRUE

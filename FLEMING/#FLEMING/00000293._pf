				Functions
					Function: LoadIdExists
						Description:
						Returns
							Boolean:
						Parameters
							String: sLoadId
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Load_Id FROM Load WHERE Load_Id = :sLoadId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									If nInd = FETCH_EOF
										Return FALSE
									Else
										Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in LoadIdExists, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
					Function: TransportIdExists
						Description:
						Returns
							Boolean:
						Parameters
							String: sTransportId
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Transport_Id FROM Transport_Method WHERE Transport_Id = :sTransportId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									If nInd = FETCH_EOF
										Return FALSE
									Else
										Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in LoadIdExists, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
					!
					Function: GetLoadTreeGroups
						Description:
						Returns
							Boolean:
						Parameters
							String: sLoadId
							Number: nYear
							Boolean: bIncludeInvoiced
							Receive Number: nLoadFruitTrees
							Receive Number: nLoadMSTrees
							Receive Number: nLoadMDTrees
							Receive Number: nLoadSmallFruitTrees
							Receive Number: nLoadOrnamTrees
							Receive Number: nLoadXlgOrnamTrees
							Receive Number: nLoadWeeperTrees
							Receive Number: nLoadContTrees
							Receive Number: nLoadTotalTrees
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							!
							Number: nCustNo
							!
							Number: nCustFruitTrees
							Number: nCustMSTrees
							Number: nCustMDTrees
							Number: nCustSmallFruitTrees
							Number: nCustOrnamTrees
							Number: nCustXlgOrnamTrees
							Number: nCustWeeperTrees
							Number: nCustContTrees
							Number: nCustTotalTrees
							Number: nSqlHandleNo
							!
							Boolean: bOk
							Number: nInd
						Actions
							Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CUSTONLOAD' )
							Select Case nActionType
								Case nExecute
									Set sSql = " SELECT Cust_No 
											FROM Load_Customers
											WHERE Load_Id = :1 "
									Set sName = 'CUSTONLOAD'
									Set sBind = ':sLoadId'
									Set sInto = ':nCustNo'
									!
									Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
									!
									Set nLoadFruitTrees = 0
									Set nLoadMSTrees = 0
									Set nLoadMDTrees = 0
									Set nLoadSmallFruitTrees = 0
									Set nLoadOrnamTrees = 0
									Set nLoadXlgOrnamTrees = 0
									Set nLoadWeeperTrees = 0
									Set nLoadContTrees = 0
									Set nLoadTotalTrees = 0
									!
									If haSqlHandles[ nSqlHandleNo ].Execute( )
										Set bOk = TRUE
										While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
											If GetCustTreeGroupsOnLoad( nCustNo, sLoadId, nYear, bIncludeInvoiced, nCustFruitTrees, nCustMSTrees, nCustMDTrees, 
													nCustSmallFruitTrees, nCustOrnamTrees, nCustXlgOrnamTrees, nCustWeeperTrees, nCustContTrees, 
													nCustTotalTrees, nExecute )
												Set nLoadFruitTrees = nLoadFruitTrees + nCustFruitTrees
												Set nLoadMSTrees = nLoadMSTrees + nCustMSTrees
												Set nLoadMDTrees = nLoadMDTrees + nCustMDTrees
												Set nLoadSmallFruitTrees = nLoadSmallFruitTrees + nCustSmallFruitTrees
												Set nLoadOrnamTrees = nLoadOrnamTrees + nCustOrnamTrees
												Set nLoadXlgOrnamTrees = nLoadXlgOrnamTrees + nCustXlgOrnamTrees
												Set nLoadWeeperTrees = nLoadWeeperTrees + nCustWeeperTrees
												Set nLoadContTrees = nLoadContTrees + nCustContTrees
												Set nLoadTotalTrees = nLoadTotalTrees + nCustTotalTrees
											Else
												Set bOk = FALSE
										Return bOk
									Else
										Return FALSE
								Case nDisconnect
									Call GetCustTreeGroupsOnLoad( 0, '', 0, FALSE, nCustFruitTrees, nCustMSTrees, nCustMDTrees, 
											nCustSmallFruitTrees, nCustOrnamTrees, nCustXlgOrnamTrees, nCustWeeperTrees, nCustContTrees, 
											nCustTotalTrees, nDisconnect )
									Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
					Function: GetTranspDesc
						Description:
						Returns
							Boolean:
						Parameters
							String: sTransportId
							Receive String: sTranspDesc
							Number: nActionType
						Static Variables
							! hcSqlHandle: fcOurHandle
.winattr class :
								Class: hcSqlHandle
.end
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							!
							String: sGotTranspDesc
							Number: nSqlHandleNo
							!
							Number: nInd
						Actions
							Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'TRANSPDESC' )
							Select Case nActionType
								Case nExecute
									Set sSql = " SELECT Transp_Desc 
											FROM Transport_Method 
											WHERE Transport_Id = :1 "
									Set sName = 'TRANSPDESC'
									Set sBind = ':sTransportId'
									Set sInto = ':sGotTranspDesc'
									!
									Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
									!
									Set sTranspDesc = ''
									Set sGotTranspDesc = ''
									!
									If haSqlHandles[ nSqlHandleNo ].Execute( )
										Call haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
										Set sTranspDesc = sGotTranspDesc
										Return TRUE
									Else
										Return FALSE
								Case nDisconnect
									Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
					!
					Function: CheckLoadCustExist
						Description:
						Returns
							Boolean:
						Parameters
							String: sLoadId
							Receive Boolean: bExists
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							Number: nInd
							Number: nSqlHandleNo
						Actions
							Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CheckLoadCustExist' )
							Select Case nActionType
								Case nExecute
									Set sSql = " SELECT 
											  Load_Customers.Cust_No 
											FROM 
											  Load_Customers 
											WHERE
											  Load_Customers.Load_Id = :1 "
									Set sName = 'CHKLDCSTEXST'
									Set sBind = ':sLoadId'
									Set sInto = ''
									Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
									!
									Set bExists = FALSE
									!
									If haSqlHandles[ nSqlHandleNo ].Execute( )
										If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
											Set bExists = TRUE
										Return TRUE
									Else
										Return FALSE
								Case nDisconnect
									Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
				Window Variables
					Number: nInd
					! Boolean: bCalcLoadTrees
					Boolean: bIncludeInvoiced
					Boolean: bOk
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' LOAD '
						Set sSQLPOPTABLENAME = ' LOAD '
						Set sSQLWHERE = ''
						Set sORDERBY = ' ORDER BY LOAD_ID '
						Set sTableHeading = 'Loads'
						Set hWndRowNewColumn = colLoadId
						Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\loadsum2.qrp'
						! Set nReportPrintOrView = nReportView
						Set nTableFillType = TBL_FillAll
						!
						! Set bCalcLoadTrees = FALSE
						Set bIncludeInvoiced = FALSE
						Call SqlSetParameter( hLocalSqlPopTbl, DBP_FETCHTHROUGH, TRUE, '' )
					On PAM_ADDROW
						Call SalSendClassMessage( PAM_ADDROW, wParam, lParam )
						Set colShipDate = SalDateConstruct( SalDateYear( SalDateCurrent(  ) ), 6, 31, 0, 0, 0 )
						Set colPulledFlag = 'N'
						Set colInvoicedFlag = 'N'
						Return TRUE
					On PAM_VALIDATESELECTION
						If SalTblAnyRows( hWndForm, ROW_Selected, 0 )
							If SalTblAnyRows( hWndForm, ROW_New, 0 )
								Call SalMessageBox( 'Please SAVE your changes first!', 'Warning', MB_Ok )
								Return FALSE
							Else
								Return TRUE
						Else
							Call SalMessageBox( 'No Rows Selected!', 'Warning', MB_Ok )
							Return FALSE
					On PAM_PRINTFULLTABLEREPORT
						If IDYES = SalMessageBox( 'Include Invoiced Orders?', 'Load Summary Report', MB_YesNo )
							Set bIncludeInvoiced = TRUE
						Else
							Set bIncludeInvoiced = FALSE
						!
						Return SalSendClassMessage( PAM_PRINTFULLTABLEREPORT, wParam, lParam )
					On PAM_TABLEREPORTROWACTION
						Call GetTranspDesc( colTransportId, colTranspDesc, nExecute )
						! If NOT ( colLoadFruitTrees > 0 OR colLoadMSTrees > 0 OR colLoadMDTrees > 0 OR 
								  colLoadSmallTrees > 0 OR colLoadOrnamTrees > 0 OR colLoadXlgOrnamTrees > 0 OR 
								  colLoadWeeperTrees > 0 OR colLoadContTrees > 0 OR colLoadTotalTrees > 0 )
						Call SalSendMsg( hWndForm, PAM_CALCTREES, 0, lParam )
					On SAM_Destroy
						Call LoadIdExists( '', nDisconnect )
						Call TransportIdExists( '', nDisconnect )
						Call GetTranspDesc( '', colTranspDesc, nDisconnect )
						Call GetLoadTreeGroups( '', 0, FALSE, colLoadFruitTrees, colLoadMSTrees, colLoadMDTrees, 
								colLoadSmallTrees, colLoadOrnamTrees, colLoadXlgOrnamTrees, colLoadWeeperTrees, 
								colLoadContTrees, colLoadTotalTrees, nDisconnect )
						Call GetLoadTotalUnits( '', 0, colLoadTotalTrees, colLoadTotalUnits, nDisconnect )
						Call GetLoadTotalUnitsExInvoiced( '', 0, colLoadTotalTrees, colLoadTotalUnits, nDisconnect )
						Call CheckLoadCustExist( '', bExists, nDisconnect )
						Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
					! On SAM_FetchRowDone
						                                                                                                                              If bCalcLoadTrees
							                                                                                                                              Call SalSendMsg( hWndForm, PAM_CALCTREES, 0, lParam )
					! On PAM_CALCSELECTEDTREES
						! BIG PROGRAMMING WARNING wParam is assumed as passed for the value of bIncludeInvoiced
						                                                                                                                              Set bIncludeInvoiced = wParam
						                                                                                                                              If bCalcLoadTrees
							                                                                                                                              Set bCalcLoadTrees = FALSE
						                                                                                                                              Else 
							                                                                                                                              Set bCalcLoadTrees = TRUE
							                                                                                                                              Call MyTableLoop( hWndForm, hWndForm, PAM_CALCTREES, ROW_Selected, 0, 'Calculating Trees On Loads', nLowToHiWithPositioning )
					On PAM_CALCSELECTEDTREES
						! BIG PROGRAMMING WARNING wParam is assumed as passed for the value of bIncludeInvoiced
						Set bIncludeInvoiced = wParam
						Call MyTableLoop( hWndForm, hWndForm, PAM_CALCTREES, ROW_Selected, 0, 'Calculating Trees On Loads', nLowToHiWithPositioning )
					! On PAM_CALCSELECTEDUNITS
						! BIG PROGRAMMING WARNING wParam is assumed as passed for the value of bIncludeInvoiced
						                                                                                                                              Set bIncludeInvoiced = wParam
						                                                                                                                              Call MyTableLoop( hWndForm, hWndForm, PAM_CALCUNITS, ROW_Selected, 0, 'Calculating Units On Loads', nLowToHiWithPositioning )
					On PAM_CALCTREES
						Set bOk = TRUE
						If NOT GetLoadTreeGroups( colLoadId, cSeasonYear.GetSeasonYear( ), bIncludeInvoiced, colLoadFruitTrees, 
								colLoadMSTrees, colLoadMDTrees, colLoadSmallTrees, colLoadOrnamTrees, colLoadXlgOrnamTrees, 
								colLoadWeeperTrees, colLoadContTrees, colLoadTotalTrees, nExecute )
							Set bOk = FALSE
						If bIncludeInvoiced
							If NOT GetLoadTotalUnits( colLoadId, cSeasonYear.GetSeasonYear( ), colLoadTotalTrees, colLoadTotalUnits, nExecute )
								Set bOk = FALSE
						Else
							If NOT GetLoadTotalUnitsExInvoiced( colLoadId, cSeasonYear.GetSeasonYear( ), colLoadTotalTrees, colLoadTotalUnits, nExecute )
								Set bOk = FALSE
						Return bOk
					On PAM_CALCLOADSELECTEDQUICK
						If bIncludeInvoiced
							Return GetLoadTotalUnits( colLoadId, cSeasonYear.GetSeasonYear( ), colLoadTotalTrees, colLoadTotalUnits, nExecute )
						Else
							Return GetLoadTotalUnitsExInvoiced( colLoadId, cSeasonYear.GetSeasonYear( ), colLoadTotalTrees, colLoadTotalUnits, nExecute )
						Return TRUE
					! On PAM_CALCUNITS
						                                                                                                                              If bIncludeInvoiced
							                                                                                                                              Return GetLoadTotalUnits( colLoadId, cSeasonYear.GetSeasonYear( ), colLoadTotalUnits, nExecute )
						                                                                                                                              Else 
							                                                                                                                              Return GetLoadTotalUnitsExInvoiced( colLoadId, cSeasonYear.GetSeasonYear( ), colLoadTotalUnits, nExecute )

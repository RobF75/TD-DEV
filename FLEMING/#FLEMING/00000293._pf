					Column: colOrdType
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class: OurColumnClass
						Property Template:
						Class DLL Name:
						Title: Ord Type
						Visible? Class Default
						Editable? Class Default
						Maximum Data Length: Class Default
						Data Type: Class Default
						Justify: Class Default
						Width:  0.625"
						Width Editable? Class Default
						Format: Uppercase
						Country: Class Default
						Input Mask: Class Default
						Cell Options
							Cell Type? Drop Down List
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? No
								Vertical Scroll? Class Default
								Auto Drop Down? Yes
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Class Default
						List Values
							Text: A
							Text: F
							Text: O
							Text: ANC
							Text: FNC
							Text: ONC
							Text: C
							Text: S
							Text: E
						Message Actions
							On PAM_SETINSTANCEVARS
								Set OurColumnClass.sSQLCOLNAME = ' LOAD_CUSTOMERS.LOAD_ORDER_TYPE '
								Set OurColumnClass.bOrderBy = TRUE
								Set OurColumnClass.bReportColumn = TRUE
							On PAM_LOOKUPCUST
								Call PopNumber( nOrderType, TRUE )
								!
								If IsFlagSet( nOrderType, nAllOrders )
									If IsFlagSet( nOrderType, nWithOutContainers )
										Set colOrdType = 'ANC'
									Else
										Set colOrdType = 'A'
								Else If IsFlagSet( nOrderType, nFruitOrders )
									If IsFlagSet( nOrderType, nWithOutContainers )
										Set colOrdType = 'FNC'
									Else
										Set colOrdType = 'F'
								Else If IsFlagSet( nOrderType, nOrnamOrders )
									If IsFlagSet( nOrderType, nWithOutContainers )
										Set colOrdType = 'ONC'
									Else
										Set colOrdType = 'O'
								Else If IsFlagSet( nOrderType, nContainerOrders )
									Set colOrdType = 'C'
								!
								Call SalSetFieldEdit( hWndItem, TRUE )
							On PAM_ROWINSERTED
								If colOrdType = 'A' OR colOrdType = 'E'
									Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nAllOrders, colCustNo )
								Else If colOrdType = 'F'
									Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nFruitOrders, colCustNo )
								Else If colOrdType = 'O'
									Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nOrnamOrders, colCustNo )
								Else If colOrdType = 'ANC'
									Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nAllOrders | nWithOutContainers, colCustNo )
								Else If colOrdType = 'FNC'
									Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nFruitOrders | nWithOutContainers, colCustNo )
								Else If colOrdType = 'ONC'
									Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nOrnamOrders | nWithOutContainers, colCustNo )
								Else If colOrdType = 'C'
									Call SalSendMsg( tblAddCustOrdToLoad, PAM_ADDROW, nContainerOrders, colCustNo )
								Set colOrdTypeChanged = FALSE
								! selection orders are trapped on click and tblAddCustOrdToLoad is filled seperately.
								! Dani commented out the class message sends of row updated and row inserted because nothing
										is processed after this column and these sends are killing the column edited flag which means more 
										than 1 changed row is not being processed as the column edited is no longer true  
								! Call SalSendClassMessage( PAM_ROWINSERTED, wParam, lParam )
							On PAM_ROWUPDATED
								If colOrdTypeChanged
									Call RemoveCustOrdersFromLoad( frmNewLoadCust.dfLoadId, 
											  colCustNo, frmNewLoadCust.cSeasonYear.GetSeasonYear( ), nExecute )
									If colOrdType != 'S'
										Call SalSendMsg( hWndItem, PAM_ROWINSERTED, 0, 0 )
								! Dani commented out the class message sends of row updated and row inserted because nothing
										is processed after this column and these sends are killing the column edited flag which means more 
										than 1 changed row is not being processed as the column edited is no longer true  
								! Call SalSendClassMessage( PAM_ROWUPDATED, wParam, lParam )
							On PAM_CHECKROWDELETED
								Call AnyPullnNotInvCustOrdsOnLoad( frmNewLoadCust.dfLoadId, colCustNo, frmNewLoadCust.cSeasonYear.GetSeasonYear( ), bAny, nExecute ) 
								If bAny
									Call ErrorMessage( 'Can NOT delete, as this customer has orders that are pulled and not invoiced!', hWndForm, lParam )
									Return FALSE
								Else
									Return TRUE
							On PAM_ROWDELETED
								If TakeOffCustOrdersFromLoad( frmNewLoadCust.dfLoadId, colCustNo, frmNewLoadCust.cSeasonYear.GetSeasonYear( ), nExecute )
									Call TakeOffCustOrdersFromLoad( '', 0, 0, nCommit )
								Return TRUE
							On PAM_COPYROWINFOFROM
								Call SalTblFetchRow( hWndForm, lParam )
								Set sTemp = colOrdType
							On PAM_COPYROWINFOTO
								Call SalTblFetchRow( hWndForm, lParam )
								Set colOrdType = sTemp
							On PAM_DATAVAL
								If colOrdType = 'A' OR 
										   colOrdType = 'F' OR 
										   colOrdType = 'O' OR 
										   colOrdType = 'C' OR 
										   colOrdType = 'S' OR
										   colOrdType = 'ANC' OR
										   colOrdType = 'ONC' OR
										   colOrdType = 'FNC' OR
										   colOrdType = 'E'
									Return TRUE
								Else
									Call ErrorMessage( 'Please choose the corresponding Order Type first!', hWndForm, lParam )
									Return FALSE
							! On SAM_AnyEdit
								                                                                                                                              If colOrdType = 'S'
									                                                                                                                              Call SalSendMsg( pbAddSelectionOrdersToLoad, SAM_Click, 0, 0 )
							On SAM_Validate
								If colOrdType = 'A' OR colOrdType = 'F' OR colOrdType = 'O' OR 
										   colOrdType = 'C' OR colOrdType = 'S' OR colOrdType = 'ANC' OR
										   colOrdType = 'FNC' OR colOrdType = 'ONC' OR colOrdType = 'E'
									Set colOrdTypeChanged = TRUE
									Call CheckCustomersNotes( colCustNo, 'Load Notes', nExecute )
									Return SalSendClassMessage( SAM_Validate, wParam, lParam )
								Else
									Return VALIDATE_Cancel
							On PAM_EDITCHECK
								If colCustPulled = 'Y'
									Return FALSE
								Else If colCustInvoiced = 'Y'
									Return FALSE
								Else
									Return TRUE
					Column: colCustPulled

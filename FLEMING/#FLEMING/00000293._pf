				Message Actions
					On PAM_CLICK
						If rbForAllRegions
							If NOT SalCreateWindow( frmOutstandOrdersOnOrAllRegions, hWndForm, '', nAllRegions, rbContWanted  )
								Call SalMessageBox( 'Can NOT create screen! Not enough memory!', 'Error', MB_Ok )
						Else
							If SalIsNull( dfRegionId )
								Call SalMessageBox( 'Please pick a region first!', 'Warning', MB_Ok )
							Else
								If RegionIdExists( dfRegionId, nExecute )
									If NOT SalCreateWindow( frmOutstandOrdersOnOrAllRegions, hWndForm, dfRegionId, nOneRegion, rbContWanted )
										Call SalMessageBox( 'Can NOT create screen! Not enough memory!', 'Error', MB_Ok )
								Else
									Call SalMessageBox( 'Region does not exists!  Please Pick a region via the Region button.', 'Warning', MB_Ok )
								! If NewRegionIdExists( dfRegionId, nExecute )
									                                                                                                                              If NOT SalCreateWindow( frmOutstandOrdersOnOrAllRegions, hWndForm, dfRegionId, nOneRegion )
										                                                                                                                              Call SalMessageBox( 'Can NOT create screen! Not enough memory!', 'Error', MB_Ok )
								! Else 
									                                                                                                                              Call SalMessageBox( 'Region does not exists!  Please Pick a region via the Region button.', 'Warning', MB_Ok )

			Pushbutton: pbUnPullCustomer
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: UnPull Cust.
				Window Location and Size
					Left:   4.788"
					Top:    5.073"
					Width:  1.525"
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblCustOnLoad, PAM_VALIDATESELECTION, 0, 0 )
							Set nYr = cSeasonYear.GetSeasonYear( )
							Call MyTableLoop( tblCustOnLoad, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Unpulling Customers', nLowToHiWithPositioning )
							Call SalSendMsg( tblCustOnLoad, PAM_REPOPULATE, 0, 0 )
					On PAM_ROWACTION
						If tblCustOnLoad.colCustInvoiced = 'Y'
							Call SalMessageBox( 'Can NOT UNpull this customer, as they are already invoiced!', 'Warning', MB_Ok )
							Return TRUE
						Else If tblCustOnLoad.colCustPulled = 'N'
							Call SalMessageBox( 'Customer is NOT pulled! No need to UNpull.', 'Warning', MB_Ok )
							Return TRUE
						Else
							If JanUnPullCustOrdOnLoad( dfLoadId, tblCustOnLoad.colCustNo, nYr, nExecute )
								If UpdateLoadCustPullFlag( dfLoadId, tblCustOnLoad.colCustNo, 'N', nExecute )
									Return TRUE
								Else
									Return FALSE
							Else
								Return FALSE

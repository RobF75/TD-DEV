								Set colItemNo.bUpdate = FALSE
							On PAM_COPYROWINFOFROM
								Call SalTblFetchRow( hWndForm, lParam )
								Set nTemp = colItemNo
							On PAM_COPYROWINFOTO
								Call SalTblFetchRow( hWndForm, lParam )
								Set colItemNo = nTemp
							On PAM_LOOKUPITEM
								Call PopNumber( colBatchLocationId, TRUE )
								Call PopNumber( colBatchYearOfSale, TRUE )
								Call PopString( sTmp, TRUE )
								Call PopString( colTreeTypeDesc, TRUE )
								Call SalSetFieldEdit( colTreeTypeDesc, TRUE )
								Call PopString( colCultId, TRUE )
								Call SalSetFieldEdit( colCultId, TRUE )
								Call PopString( colCultDesc, TRUE )
								Call SalSetFieldEdit( colCultDesc, TRUE )
								Call PopString( colRootId, TRUE )
								Call SalSetFieldEdit( colRootId, TRUE )
								Call PopString( colRootDesc, TRUE )
								Call SalSetFieldEdit( colRootDesc, TRUE )
								Call PopNumber( colYear, TRUE )
								Call SalSetFieldEdit( colYear, TRUE )
								Call PopNumber( colItemNo, TRUE )
								Call SalSetFieldEdit( colItemNo, TRUE )
								If colBatchLocationId > 0
									Set colFutureOrder = 'Y'
									Call SalSendMsg( hWndForm, PAM_GETFUTUREAVAILABLE, wParam, lParam )
								Else
									Set colFutureOrder = 'N'
									Set colSeason = ''
									Set colFutureOrderDate = DATETIME_Null
									Call SalSendMsgToChildren( hWndForm, PAM_SETFWDCOLUMNCOLOR, 0, COLOR_Default )
								Return TRUE

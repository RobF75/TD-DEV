				Message Actions
					On PAM_SETINSTANCEVARS
						Set OurTblQBEDataField.sSQLCOLNAME = 'CUSTOMER_MASTER.REGION_ID'
					On PAM_QBE
						If NOT SalIsNull( hWndItem )
							Set dfRegionId = '%'||dfRegionId||'%'
							Call SalSendClassMessage( PAM_QBE, wParam, lParam )
						Else
							If rbRegionsOnLoad
								If SalTblAnyRows( tblRegionsOnLoad, ROW_Selected, 0 )
									Set sRegions = ''
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblRegionsOnLoad, nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( tblRegionsOnLoad, nRow )
										If sRegions = ''
											Set sRegions = ' ( ' || '\'' || tblRegionsOnLoad.colRegionId || '\''
										Else
											Set sRegions = sRegions || ', ' || '\'' || tblRegionsOnLoad.colRegionId || '\''
									Set sRegions = sRegions || ' ) '
									Call PushString( sRegions )
									Call PushString( ' IN ' )
									Call PushString( STRINGHDLFOLLOWING )
									Call PushString( OurTblQBEDataField.sSQLCOLNAME )
									Return TRUE
								Else
									Return FALSE
							Else
								If SalTblAnyRows( tblAllRegions, ROW_Selected, 0 )
									Set sRegions = ''
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblAllRegions, nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( tblAllRegions, nRow )
										If sRegions = ''
											Set sRegions = ' ( ' || '\'' || tblAllRegions.colRegionId || '\''
										Else
											Set sRegions = sRegions || ', ' || '\'' || tblAllRegions.colRegionId || '\''
									Set sRegions = sRegions || ' ) '
									Call PushString( sRegions )
									Call PushString( ' IN ' )
									Call PushString( STRINGHDLFOLLOWING )
									Call PushString( OurTblQBEDataField.sSQLCOLNAME )
									Return TRUE
								Else
									Return FALSE

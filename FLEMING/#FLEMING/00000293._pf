								If tblCustOnLoad.colOrdType = 'S'
									If SalTblAnyRows( tblCustOnLoad, ROW_Edited | ROW_New | ROW_MarkDeleted, 0 ) 
										Call SalMessageBox( 'Please save your changes first!', 'NOTE', MB_Ok )
									Else
										Call SalCreateWindow( frmAddCustSelectionOrdsOnLoad, hWndForm, tblCustOnLoad.colCustNo, frmNewLoadCust.sLoadId, frmNewLoadCust.dtShippingDate )
								Else
									Call SalMessageBox( 'Please ensure the S order type is set for this customer first!', 'NOTE', MB_Ok )
						Else
							Call SalMessageBox( 'Please select a Customer!', 'NOTE', MB_Ok )

		Functions
			Function: GetCustOrdOnLoadInvNo
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nCustNo
					Number: nYear
					Receive Number: nInvoiceNo
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					String: sSql
					String: sFuncName
					Number: nInd
					Number: nGotInvoiceNo
				Actions
					Set sFuncName = 'GetCustOrdOnLoadInvNo'
					Select Case nActionType
						Case nExecute
							Loop Execute
								Loop Connect
									If bHandleConnected
										Break Connect
									Else
										Set bHandleConnected = SqlConnect( hSqlHandle ) 
										If bHandleConnected
											Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
											Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
											Break Connect
										Else
											If IDNO = SalMessageBox( 'Could not connect handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												Break Connect
								Loop Prepare
									If bHandlePrepared
										Break Prepare
									Else
										Set sSql = ' SELECT Customer_Order.Invoice_No 
												FROM Load_Customers, Customer_Order 
												INTO :nGotInvoiceNo 
												WHERE 
												  Load_Customers.Load_Id = :sLoadId AND 
												  Load_Customers.Cust_No = :nCustNo AND 
												  Load_Customers.Cust_No = Customer_Order.Cust_No AND 
												  Customer_Order.Year_Of_Sale = :nYear AND 
												  Customer_Order.Load_Id = :sLoadId '
										If SqlPrepare( hSqlHandle, sSql )
											Set bHandlePrepared = TRUE
											Break Prepare
										Else
											Set bHandlePrepared = FALSE
											If IDNO = SalMessageBox( 'Could not prepare handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												Break Prepare
								!
								Set nInvoiceNo = NUMBER_Null
								Set nGotInvoiceNo = NUMBER_Null
								!
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									Set nInvoiceNo = nGotInvoiceNo
									Return TRUE
								Else
									Set bHandlePrepared = FALSE
									If IDNO = SalMessageBox( 'Could not execute handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
										Return FALSE
						Case nCommit
							Loop Commit
								If bHandleConnected
									If SqlCommit( hSqlHandle )
										Return TRUE
									Else
										If IDNO = SalMessageBox( 'Could not commit handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
											Return FALSE
								Else
									Return TRUE
						Case nRollback
							Loop Rollback
								If bHandleConnected
									Set bHandlePrepared = FALSE
									If SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
										Return TRUE
									Else
										If IDNO = SalMessageBox( 'Could not rollback handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
											Return FALSE
								Else
									Return TRUE
						Case nDisconnect
							Loop Disconnect
								If bHandleConnected
									If SqlDisconnect( hSqlHandle )
										Set bHandleConnected = FALSE
										Set bHandlePrepared = FALSE
										Return TRUE
									Else
										If IDNO = SalMessageBox( 'Could not disconnect handle in function '||sFuncName||'Contact programmers! RETRY?', 'Error', MB_YesNo )
											Return FALSE
								Else
									Return TRUE
						Case nRePrepare
							Set bHandlePrepared = FALSE
							Return TRUE
		Window Parameters
			Window Handle: hWndParentTable
			String: sLoadId
			Number: nRowsSelected
			Date/Time: dtShippingDate
		Window Variables
			Number: nRows
			Number: nType
			Number: nTmp
			Number: nInvoiceNo
			String: sDefaultOrdType
			Boolean: bRowsChanged
			Number: nCount
			Boolean: bContinue
			Number: nYr
			Number: nRow
			Number: nCustNos[*]
			String: saOrdTypes[*]
			Date/Time: dtaOrdDT[*]
			Window Handle: hWndCol
			String: sArguments
			Boolean: bExists
		Message Actions
			On PAM_SETINSTANCEVARS
				Set bMoveUpDownRowsAllowed = TRUE
				Set sDatabase = SqlDatabase
				Set bTablePrintReportAllowed = TRUE
			On SAM_CreateComplete
				Set dfLoadId = sLoadId
				Set dfShippingDate = dtShippingDate
				Call SalDisableWindow( SalParentWindow( hWndForm ) )
				Call SalWaitCursor( FALSE )
			On SAM_Destroy
				Call SalEnableWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				Call JanUnPullCustOrdOnLoad( '', 0, 0, nDisconnect )
				Call UpdateLoadCustPullFlag( '', 0, '', nDisconnect )
				Call NewUpdateLoadCustInvFlag( '', 0, '', nDisconnect )
				Call UnInvInvNo( 0, 0, nDisconnect )
				Call GetCustOrdOnLoadInvNo( '', 0, 0, nInvoiceNo, nDisconnect )
				Call MaintainCustOrders( nCustNos, saOrdTypes, '', DATETIME_Null, 0, '', nDisconnect )
				Call CheckCustomersNotes( 0, '', nDisconnect )
				Call VerifyInvoiceForCust(  0, 0, nDisconnect )
				Call GetLoadTransportCapacity( '', dfTotalUnitsCapacity, nDisconnect )
				Call GetLoadTotalUnits( '', 0, nTmp, dfTotalCurrentUnits, nDisconnect )
				Call GetLoadCustTotalUnits( 0, '', 0,tblCustOnLoad.colUnits, nDisconnect )
				Call CheckLoadDupSeqNo( '', bExists, nDisconnect )
				Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
			On PAM_LOOKUPLOAD
				Call PushString( dfLoadId )
				Return TRUE
			On PAM_REPORTFINISHED
				If wParam = nPullSheet
					Call SalSendMsg( tblCustOnLoad, PAM_REPOPULATE, 0, 0 )
			On PAM_PARENTREPOP
				If lParam = nFrmNewCustOrdOnLoadId
					If wParam
						Call SalSendMsg( tblCustOnLoad, PAM_REPOPULATE, 0, 0 )

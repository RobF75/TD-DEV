					Menu Item Name:
				Menu Separator
				Menu Item: Print Host plants Report for selected Customers
					Resource Id: 34610
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when:
						Checked when:
					Menu Actions
						Call SalWaitCursor( TRUE )
						Set nCount = 0
						Set nCustNos[ nCount ] = NUMBER_Null
						Set nTmp = TBL_MinRow
						While SalTblFindNextRow( tblCustOnLoad, nTmp, ROW_Selected, 0 )
							Call SalTblFetchRow( tblCustOnLoad, nTmp )
							Set nCustNos[ nCount ] = tblCustOnLoad.colCustNo
							Set nCount = nCount + 1
							Set nCustNos[ nCount ] = NUMBER_Null
						If nCustNos[ 0 ] = NUMBER_Null
							Call SalMessageBox( 'Please select at least one Customer first!', 'Error', MB_Ok )
							Call SalWaitCursor( FALSE )
							Return FALSE
						If NOT WriteNumArrayListToFile( OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'C:\\TEMP' )||'\\HostPlnt.tmp', nCustNos )
							Call SalMessageBox( 'Please check your C drive ( Hard Disk ) for available space!', 'Error', MB_Ok )
							Call SalWaitCursor( FALSE )
							Return FALSE
						Set sArguments = SqlDatabase || ' ' || 
								SqlUser || ' ' || 
								SqlPassword || ' ' || 
								sLoadId || ' ' ||
								OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'C:\\TEMP' )||'\\HostPlnt.tmp' || ' ' ||
								'LOAD_CUSTOMERS'
						Call SalLoadApp( OurGetIniFileParameter( 'GENERAL', 'HostPlantsReport', '' ), sArguments )
						Call SalWaitCursor( FALSE )
					Menu Item Name:

				Functions
				Window Variables
					Boolean: bTablePopulated
					Number: nCount
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' MEET_ADDRESS '
						Set sSQLPOPTABLENAME = ' Meet_Address, Region_Meet, Region_Load '
						Set sSQLWHERE = ' WHERE Region_Meet.Meet_Id = Meet_Address.Meet_Id and 
								Region_Load.Region_Id = Region_Meet.Region_Id and 
								region_Load.load_Id = :dlgQueryTblCustomer.sLoadId '
						Set sORDERBY = ' ORDER BY MEET_ADDRESS.MEET_ID '
						Set sROWID = ' MEET_ADDRESS.ROWID '
						Set sTableHeading = 'Meets On Load'
						Set bSelectFirstRow = FALSE
						Set bTablePopulated = FALSE
					On PAM_SHOWMEETSTBL
						If wParam = nMeetsOnLoad
							Call SalShowWindow( hWndForm )
							If NOT bTablePopulated
								If SalSendMsg( SalParentWindow( hWndForm ), PAM_LOOKUPLOAD, 0, 0 )
									Call PopString( sLoadId, TRUE )
									Call SalPostMsg( hWndForm, PAM_POPULATE, 0, 0 )
									Set bTablePopulated = TRUE
						Else
							Call SalHideWindow( hWndForm )
			!

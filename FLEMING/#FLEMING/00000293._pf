				Message Actions
		Functions
			Function: UpdateLoadCustPullFlag
				Description: Updates the Cust_Pulled_Flag on Table Load_Customers to the 
						sCustPulledFlag parameter.  This function commits and 
						rollbacks it self.
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nCustNo
					String: sCustPulledFlag
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					String: sSql
					String: sFuncName
				Actions
					Set sFuncName = 'UpdateLoadCustPullFlag'
					Select Case nActionType
						Case nExecute
							Loop Execute
								Loop Connect
									If bHandleConnected
										Break Connect
									Else
										Set bHandleConnected = SqlConnect( hSqlHandle ) 
										If bHandleConnected
											Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
											Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
											Break Connect
										Else
											If IDNO = SalMessageBox( 'Could not connect handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												Break Connect
								Loop Prepare
									If bHandlePrepared
										Break Prepare
									Else
										Set sSql = ' UPDATE Load_Customers SET Cust_Pulled_Flag = :sCustPulledFlag 
												WHERE Load_Id = :sLoadId AND Cust_No = :nCustNo '
										If SqlPrepare( hSqlHandle, sSql )
											Set bHandlePrepared = TRUE
											Break Prepare
										Else
											Set bHandlePrepared = FALSE
											If IDNO = SalMessageBox( 'Could not prepare handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												Break Prepare
								!
								If SqlExecute( hSqlHandle )
									Call UpdateLoadCustPullFlag( '', 0, '', nCommit )
									Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call UpdateLoadCustPullFlag( '', 0, '', nRollback )
									If IDNO = SalMessageBox( 'Could not execute handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
										Return FALSE
						Case nCommit
							Loop Commit
								If bHandleConnected
									If SqlCommit( hSqlHandle )
										Return TRUE
									Else
										If IDNO = SalMessageBox( 'Could not commit handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
											Return FALSE
								Else
									Return TRUE
						Case nRollback
							Loop Rollback
								If bHandleConnected
									Set bHandlePrepared = FALSE
									If SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
										Return TRUE
									Else
										If IDNO = SalMessageBox( 'Could not rollback handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
											Return FALSE
								Else
									Return TRUE
						Case nDisconnect
							Loop Disconnect
								If bHandleConnected
									If SqlDisconnect( hSqlHandle )
										Set bHandleConnected = FALSE
										Set bHandlePrepared = FALSE
										Return TRUE
									Else
										If IDNO = SalMessageBox( 'Could not disconnect handle in function '||sFuncName||'Contact programmers! RETRY?', 'Error', MB_YesNo )
											Return FALSE
								Else
									Return TRUE
						Case nRePrepare
							Set bHandlePrepared = FALSE
							Return TRUE
		Window Parameters
			Number: nCustNo
			String: sCustName
			String: sLoadId
			! String: sLoadDesc
			Date/Time: dtShipDate
		Window Variables
			Boolean: bRepopParent
			Date/Time: dtaOrdDTs[*]
			Number: nRow
			Number: nPos
		Message Actions
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
				Set OurFrmWndWithChildTbl.bQueryTableAllowed = FALSE
				Set bRepopParent = FALSE
			On SAM_CreateComplete
				Set dfCustNo = nCustNo
				Set dfCustName = sCustName
				Set dfLoadId = sLoadId
				! Set dfLoadDesc = sLoadDesc
				Set dfShipDate = dtShipDate
				Set dfYear = cSeasonYear.GetSeasonYear( )
				Call SalDisableWindow( SalParentWindow( hWndForm ) )
				Call SalWaitCursor( FALSE )
				Call CheckCustomersNotes( dfCustNo, 'Load Notes', nExecute )
			On SAM_Destroy
				Call SalEnableWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				Call SalPostMsg( SalParentWindow( hWndForm ), PAM_PARENTREPOP, bRepopParent, nFrmNewCustOrdOnLoadId )
				Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
	!

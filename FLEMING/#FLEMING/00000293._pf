				Functions
					Function: GetMeetAddress
						Description:
						Returns
							Boolean:
						Parameters
							String: sMeetId
							Receive String: sAddressLine1
							Receive String: sAddressLine2
							Receive String: sSuburb
							Receive String: sPostcode
							Receive String: sState
							Receive String: sCountry
							Receive String: sAreaCode
							Receive String: sPhoneNo
							Receive String: sAreaCodeFax
							Receive String: sFaxNo
							Receive String: sComments
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							String: sGotAddressLine1
							String: sGotAddressLine2
							String: sGotSuburb
							String: sGotPostcode
							String: sGotState
							String: sGotCountry
							String: sGotAreaCode
							String: sGotPhoneNo
							String: sGotAreaCodeFax
							String: sGotFaxNo
							String: sGotComments
							Number: nInd
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Meet_Address_1, Meet_Address_2, Meet_Suburb, 
											  Meet_Postcode, Meet_State, Meet_Country,
											  Meet_Area_Code, Meet_Phone_No, Meet_Area_Code_Fax, 
											  Meet_Fax_No, Meet_Comments
											  FROM Meet_Address 
											  INTO :sGotAddressLine1, :sGotAddressLine2, :sGotSuburb, 
											  :sGotPostcode, :sGotState, :sGotCountry, :sGotAreaCode, :sGotPhoneNo, 
											  :sGotAreaCodeFax, :sGotFaxNo, :sGotComments
											  WHERE Meet_Id = :sMeetId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								Set sAddressLine1 = ''
								Set sAddressLine2 = ''
								Set sSuburb = ''
								Set sPostcode = ''
								Set sState = ''
								Set sCountry = ''
								Set sAreaCode = ''
								Set sPhoneNo = ''
								Set sAreaCodeFax = ''
								Set sFaxNo = ''
								Set sComments = ''
								Set sGotAddressLine1 = ''
								Set sGotAddressLine2 = ''
								Set sGotSuburb = ''
								Set sGotPostcode = ''
								Set sGotState = ''
								Set sGotCountry = ''
								Set sGotAreaCode = ''
								Set sGotPhoneNo = ''
								Set sGotAreaCodeFax = ''
								Set sGotFaxNo = ''
								Set sGotComments = ''
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									Set sAddressLine1 = sGotAddressLine1
									Set sAddressLine2 = sGotAddressLine2
									Set sSuburb = sGotSuburb
									Set sPostcode = sGotPostcode
									Set sState = sGotState
									Set sCountry = sGotCountry
									Set sAreaCode = sGotAreaCode
									Set sPhoneNo = sGotPhoneNo
									Set sAreaCodeFax = sGotAreaCodeFax
									Set sFaxNo = sGotFaxNo
									Set sComments = sGotComments
									Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in GetMeetAddress, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Call SqlDisconnect( hSqlHandle )
								Return TRUE
				Window Variables
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' CUSTOMER_ADDRESS '
						Set sSQLPOPTABLENAME = ' CUSTOMER_ADDRESS '
						Set sSQLWHERE = " WHERE Cust_No = :dlgQCustAddr.dfCustNo AND NOT Address_Type = 'POSTAL' "
						Set sORDERBY = ''
						Set sTableHeading = 'Pick Customer Address Types'
					On SAM_FetchRowDone
						If NOT SalIsNull( colMeetId )
							Call GetMeetAddress( colMeetId, colAddressLine1, colAddressLine2, colSuburb, 
									  colPostcode, colState, colCountry, colAreaCode, colPhoneNo, colAreaCodeFax, 
									  colFaxNo, colComments, nExecute )
					On SAM_Destroy
						Call GetMeetAddress( '', colAddressLine1, colAddressLine2, colSuburb, 
								  colPostcode, colState, colCountry, colAreaCode, colPhoneNo, colAreaCodeFax, 
								  colFaxNo, colComments, nDisconnect )
						Call SalSendClassMessage( SAM_Destroy, wParam, lParam )

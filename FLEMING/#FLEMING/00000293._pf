				Functions
					! New cls version in ITEM.APL Function: UpdateCustOrdLoadId
						                                                                                                                              Description: Set the load_id for a customer order to the parameter sLoadId
								Given the cust_no and Order_Date_Time.
								This function commits/ rollsback it self
						                                                                                                                              Returns 
							                                                                                                                              Boolean: 
						                                                                                                                              Parameters 
							                                                                                                                              Number: nCustNo
							                                                                                                                              Date/Time: dtOrdDT
							                                                                                                                              String: sLoadId
							                                                                                                                              Number: nActionType
						                                                                                                                              Static Variables 
							                                                                                                                              Sql Handle: hSqlHandle
							                                                                                                                              Boolean: bHandleConnected
							                                                                                                                              Boolean: bHandlePrepared
						                                                                                                                              Local variables 
							                                                                                                                              Boolean: bOk
							                                                                                                                              String: sSql
						                                                                                                                              Actions 
							                                                                                                                              Select Case nActionType
								                                                                                                                              Case nExecute
									                                                                                                                              If NOT bHandleConnected
										                                                                                                                              Set bHandleConnected = SqlConnect( hSqlHandle ) 
										                                                                                                                              If bHandleConnected
											                                                                                                                              Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
											                                                                                                                              Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
										                                                                                                                              Else 
											                                                                                                                              Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
											                                                                                                                              Return FALSE
									                                                                                                                              If NOT bHandlePrepared
										                                                                                                                              Set sSql = ' UPDATE Customer_Order 
												  SET Load_Id = :sLoadId 
												  WHERE 
												     Cust_No = :nCustNo AND 
												     Order_Date_Time = :dtOrdDT '
										                                                                                                                              If SqlPrepare( hSqlHandle, sSql )
											                                                                                                                              Set bHandlePrepared = TRUE
										                                                                                                                              Else 
											                                                                                                                              Set bHandlePrepared = FALSE
									!
									                                                                                                                              If SqlExecute( hSqlHandle )
										                                                                                                                              Call UpdateCustOrdLoadId( 0, DATETIME_Null, '', nCommit )
										                                                                                                                              Return TRUE
									                                                                                                                              Else 
										! Call UpdateCustOrdLoadId( 0, DATETIME_Null, '', nRollback )
										                                                                                                                              Set bHandlePrepared = FALSE
										                                                                                                                              Call SalMessageBox( 'SqlExecute had a error in UpdateCustOrdLoadId!, Contact programmers please!', 'ERROR', MB_Ok )
										                                                                                                                              Return FALSE
								                                                                                                                              Case nCommit
									                                                                                                                              Set bOk = TRUE
									                                                                                                                              If bHandleConnected
										                                                                                                                              Set bOk = SqlCommit( hSqlHandle )
									                                                                                                                              Return bOk
								                                                                                                                              Case nRollback
									                                                                                                                              Set bOk = TRUE
									                                                                                                                              If bHandleConnected
										                                                                                                                              Set bOk = SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
										                                                                                                                              Set bHandlePrepared = FALSE
									                                                                                                                              Return bOk
								                                                                                                                              Case nDisconnect
									                                                                                                                              Set bOk = FALSE
									                                                                                                                              Set bHandlePrepared = FALSE
									                                                                                                                              If bHandleConnected
										                                                                                                                              Set bHandleConnected = FALSE
										                                                                                                                              Set bOk = SqlDisconnect( hSqlHandle )
									                                                                                                                              Return bOk
								                                                                                                                              Case nRePrepare
									                                                                                                                              Set bHandlePrepared = FALSE
									                                                                                                                              Return TRUE
				Window Variables
					Number: nTemp
					Date/Time: dtTemp
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' CUSTOMER_ORDER '
						Set sSQLPOPTABLENAME = ' CUSTOMER_ORDER, STOCK_ITEM'
						Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO =
								 :frmAddCustSelectionOrdsOnLoad.dfCustNo AND 
								 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
								 CUSTOMER_ORDER.CONF_AMT > 0 AND 
								 NOT CUSTOMER_ORDER.INVOICED_FLAG = 'Y' AND 
								 ( Customer_Order.Hold_Order_Date <= :frmAddCustSelectionOrdsOnLoad.dfShipDate OR 
								    Customer_Order.Hold_Order_Date IS NULL ) AND 
								 CUSTOMER_ORDER.YEAR_OF_SALE = :frmAddCustSelectionOrdsOnLoad.dfYear AND
								 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO "
						!
						Set sORDERBY = ' ORDER BY 2,3,4,5,9 '
						Set sROWID = ' CUSTOMER_ORDER.ROWID '
						Set sTableHeading = 'Add Customer Selection Order onto This Load'
						Set hWndRowNewColumn = colOrderDate
						Set bSelectFirstRow = FALSE
						Set nTableFillType = TBL_FillAll
					On PAM_WRITEINSERTSUPDATES
						Call MyTableLoop( hWndForm, hWndForm, PAM_ROWACTION, ROW_Selected, 0, 'Save Changes', nLowToHi )
					On PAM_ROWACTION
						If UpdateCustOrdLoadId( colCustNo, colOrderDateTime, frmAddCustSelectionOrdsOnLoad.dfLoadId, nExecute )
							Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
							Return nRowDeleted
						Else
							Return TRUE
					On SAM_Destroy
						Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
						Call UpdateCustOrdLoadId( 0, DATETIME_Null, '', nDisconnect )

			Pushbutton: pbOk
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Ok - Enter
				Window Location and Size
					Left:   0.375"
					Top:    1.802"
					Width:  1.475"
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Enter
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If rbFruitOrders
							If cbNoContainers
								Set nLoadOrderType = nFruitOrders | nWithOutContainers
							Else
								Set nLoadOrderType = nFruitOrders
						Else If rbOrnamOrders
							If cbNoContainers
								Set nLoadOrderType = nOrnamOrders | nWithOutContainers
							Else
								Set nLoadOrderType = nOrnamOrders
						Else If rbContOrders
							Set nLoadOrderType = nContainerLoads
						Else
							Set nLoadOrderType = nSelectionOrders
						!
						If nLoadOrderType = nSelectionOrders
							If MyTableAnyRows( hWndTable, ROW_Selected, 0, nCount )
								If nCount > 1
									Call SalMessageBox( 'Please select one Customer only!', 'NOTE', MB_Ok )
									Call SalSendMsg( pbCancel, SAM_Click, 0, FALSE )
								Else
									If SalTblAnyRows( hWndTable, ROW_Edited | ROW_New | ROW_MarkDeleted, 0 ) 
										Call SalMessageBox( 'Please save your changes first!', 'NOTE', MB_Ok )
										Call SalSendMsg( pbCancel, SAM_Click, 0, FALSE )
									Else
										Call SalCreateWindow( frmAddCustSelectionOrdsOnLoad, hWndForm, hWndTable.colCustNo, sLoadId, dtShippingDate )
							Else
								Call SalMessageBox( 'Please select a Customer!', 'NOTE', MB_Ok )
								Call SalSendMsg( pbCancel, SAM_Click, 0, FALSE )
						Else
							Call MyTableLoop( hWndTable, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Including Orders', nLowToHi )
							Call SalSendMsg( pbCancel, SAM_Click, 0, TRUE )
					On PAM_ROWACTION
						If NewAddCustOrdTypeToLoad( sLoadId, nYear, hWndTable.colCustNo, nLoadOrderType, DATETIME_Null, dtShippingDate, nExecute )
							Call NewAddCustOrdTypeToLoad( '', 0, 0, 0, DATETIME_Null, DATETIME_Null, nCommit )
						Return TRUE
			Background Text: NOTE: that a REDO of these customers on this load will loose included orders from here.  A REFRESH will NOT harm these included orders.

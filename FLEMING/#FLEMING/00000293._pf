			Function: GetLoadTransportCapacity
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Receive Number: nCapacity
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nSqlHandleNo
					!
					Number: nGotCapacity
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetLoadTransportCapacity' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Transport_Method.Unit_Capacity 
									FROM 
									  Load, 
									  Transport_Method 
									WHERE 
									  Load.Load_Id = :1 AND 
									  Load.Transport_Id = Transport_Method.Transport_Id "
							Set sName = 'GLTTOTCAP'
							Set sBind = ':sLoadId'
							Set sInto = ':nGotCapacity'
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set nCapacity = NUMBER_Null
							Set nGotCapacity = NUMBER_Null
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									Set nCapacity = nGotCapacity
								Return TRUE
							Else
								Return FALSE
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			Function: GetLoadTotalUnits
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nYear
					Receive Number: nTotalTrees
					Receive Number: nTotalUnits
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nSqlHandleNo
					Number: nSqlHandleNoHist
					Boolean: bOk
					!
					Number: nGotTotalTrees
					Number: nGotTotalUnits
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetLoadTotalUnits' )
					Set nSqlHandleNoHist = SqlHandlesGetReferenceNo( 'GetLoadTotalUnitsHistory' )
					Select Case nActionType
						Case nExecute
							If nYear < WhichSeasonYear( SalDateCurrent(  ) ) AND nYear != 77
								Set sSql = " SELECT 
										  SUM( Cust_Order_History.Conf_Amt )  AS Total_Trees, 
										  SUM( Cust_Order_History.Conf_Amt * Stock_Item.Unit_Size )  AS Total_Units
										FROM 
										  Cust_Order_History, 
										  Stock_Item 
										WHERE 
										  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
										  Cust_Order_History.Year_Of_Sale = :1 AND 
										  Cust_Order_History.Load_Id = :2 "
								Set sName = 'GLDTOTUNI2H'
								Set sBind = ':nYear, :sLoadId'
								Set sInto = ':nGotTotalTrees, :nGotTotalUnits'
								Call haSqlHandles[ nSqlHandleNoHist ].Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( haSqlHandles[ nSqlHandleNoHist ].hSqlHandle )
								!
								Set nTotalTrees = NUMBER_Null
								Set nGotTotalTrees = NUMBER_Null
								Set nTotalUnits = NUMBER_Null
								Set nGotTotalUnits = NUMBER_Null
								!
								If haSqlHandles[ nSqlHandleNoHist ].Execute( )
									If haSqlHandles[ nSqlHandleNoHist ].FetchNext( nInd )
										Set nTotalTrees = nGotTotalTrees
										Set nTotalUnits = nGotTotalUnits
									Return TRUE
								Else
									Return FALSE
							Else
								Set sSql = " SELECT 
										  SUM( Customer_Order.Conf_Amt )  AS Total_Trees, 
										  SUM( Customer_Order.Conf_Amt * Stock_Item.Unit_Size )  AS Total_Units
										FROM 
										  Customer_Order, 
										  Stock_Item 
										WHERE 
										  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
										  Customer_Order.Year_Of_Sale = :1 AND 
										  Customer_Order.Load_Id = :2 "
								Set sName = 'GLDTOTUNI2'
								Set sBind = ':nYear, :sLoadId'
								Set sInto = ':nGotTotalTrees, :nGotTotalUnits'
								Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
								!
								Set nTotalTrees = NUMBER_Null
								Set nGotTotalTrees = NUMBER_Null
								Set nTotalUnits = NUMBER_Null
								Set nGotTotalUnits = NUMBER_Null
								!
								If haSqlHandles[ nSqlHandleNo ].Execute( )
									If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
										Set nTotalTrees = nGotTotalTrees
										Set nTotalUnits = nGotTotalUnits
									Return TRUE
								Else
									Return FALSE
						Case nDisconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nSqlHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nSqlHandleNoHist ].Disconnect( )
								Set bOk = FALSE
							Return bOk
			Function: GetLoadTotalUnitsExInvoiced
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nYear
					Receive Number: nTotalTrees
					Receive Number: nTotalUnits
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nSqlHandleNo
					Number: nSqlHandleNoHist
					Boolean: bOk
					!
					Number: nGotTotalTrees
					Number: nGotTotalUnits
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetLoadTotalUnitsExInvoiced' )
					Set nSqlHandleNoHist = SqlHandlesGetReferenceNo( 'GetLoadTotalUnitsExInvoicedHistory' )
					Select Case nActionType
						Case nExecute
							If nYear < WhichSeasonYear( SalDateCurrent(  ) ) AND nYear != 77
								Set sSql = " SELECT 
										  SUM( Cust_Order_History.Conf_Amt )  AS Total_Trees, 
										  SUM( Cust_Order_History.Conf_Amt * Stock_Item.Unit_Size )  AS Total_Units
										FROM 
										  Cust_Order_History, 
										  Stock_Item 
										WHERE 
										  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
										  Cust_Order_History.Year_Of_Sale = :1 AND 
										  Cust_Order_History.Load_Id = :2   AND 
										  ( NOT Cust_Order_History.Invoiced_Flag = 'Y' OR 
										    Cust_Order_History.Invoiced_Flag IS NULL ) "
								Set sName = 'GLDTOTUTXIV2H'
								Set sBind = ':nYear, :sLoadId'
								Set sInto = ':nGotTotalTrees, :nGotTotalUnits'
								Call haSqlHandles[ nSqlHandleNoHist ].Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( haSqlHandles[ nSqlHandleNoHist ].hSqlHandle )
								!
								Set nTotalTrees = NUMBER_Null
								Set nGotTotalTrees = NUMBER_Null
								Set nTotalUnits = NUMBER_Null
								Set nGotTotalUnits = NUMBER_Null
								!
								If haSqlHandles[ nSqlHandleNoHist ].Execute( )
									If haSqlHandles[ nSqlHandleNoHist ].FetchNext( nInd )
										Set nTotalTrees = nGotTotalTrees
										Set nTotalUnits = nGotTotalUnits
									Return TRUE
								Else
									Return FALSE
							Else
								Set sSql = " SELECT 
										  SUM( Customer_Order.Conf_Amt )  AS Total_Trees, 
										  SUM( Customer_Order.Conf_Amt * Stock_Item.Unit_Size )  AS Total_Units
										FROM 
										  Customer_Order, 
										  Stock_Item 
										WHERE 
										  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
										  Customer_Order.Year_Of_Sale = :1 AND 
										  Customer_Order.Load_Id = :2   AND 
										  ( NOT Customer_Order.Invoiced_Flag = 'Y' OR 
										    Customer_Order.Invoiced_Flag IS NULL ) "
								Set sName = 'GLDTOTUNTXIV2'
								Set sBind = ':nYear, :sLoadId'
								Set sInto = ':nGotTotalTrees, :nGotTotalUnits'
								Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
								!
								Set nTotalTrees = NUMBER_Null
								Set nGotTotalTrees = NUMBER_Null
								Set nTotalUnits = NUMBER_Null
								Set nGotTotalUnits = NUMBER_Null
								!
								If haSqlHandles[ nSqlHandleNo ].Execute( )
									If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
										Set nTotalTrees = nGotTotalTrees
										Set nTotalUnits = nGotTotalUnits
									Return TRUE
								Else
									Return FALSE
						Case nDisconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nSqlHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nSqlHandleNoHist ].Disconnect( )
								Set bOk = FALSE
							Return bOk
			Function: GetCustTotalUnitsOutstand
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					Number: nYear
					Receive Number: nTotalUnits
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					Number: nSqlHandleNo
					Number: nSqlHandleNoHist
					Boolean: bOk
					Number: nGotTotalUnits
					!
					Number: nInd
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetCustTotalUnitsOutstand' )
					Set nSqlHandleNoHist = SqlHandlesGetReferenceNo( 'GetCustTotalUnitsOutstandHistory' )
					Select Case nActionType
						Case nExecute
							If nYear < WhichSeasonYear( SalDateCurrent(  ) ) AND nYear != 77
								Set sSql = " SELECT 
										  Sum( Cust_Order_History.Conf_Amt * Stock_Item.Unit_Size ) 
										FROM 
										  Cust_Order_History, 
										  Stock_Item 
										WHERE 
										  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
										  Cust_Order_History.Cust_No = :1 AND 
										  Cust_Order_History.Year_Of_Sale = :2 AND 
										  Cust_Order_History.Load_Id IS NULL AND 
										  ( NOT Cust_Order_History.Invoiced_Flag = 'Y' OR 
										    Cust_Order_History.Invoiced_Flag IS NULL ) AND 
										  ( NOT Cust_Order_History.Pull_Sheet_Issued = 'Y' OR 
										    Cust_Order_History.Pull_Sheet_Issued IS NULL ) "
								Set sName = 'GTCSTTUNTOTH'
								Set sBind = ':nCustNo, :nYear'
								Set sInto = ':nGotTotalUnits'
								!
								Call haSqlHandles[ nSqlHandleNoHist ].Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( haSqlHandles[ nSqlHandleNoHist ].hSqlHandle )
								!
								Set nTotalUnits = NUMBER_Null
								Set nGotTotalUnits = NUMBER_Null
								!
								If haSqlHandles[ nSqlHandleNoHist ].Execute( )
									If haSqlHandles[ nSqlHandleNoHist ].FetchNext( nInd )
										Set nTotalUnits = nGotTotalUnits
									Return TRUE
								Else
									Return FALSE
							Else
								Set sSql = " SELECT 
										  Sum( Customer_Order.Conf_Amt * Stock_Item.Unit_Size ) 
										FROM 
										  Customer_Order, 
										  Stock_Item 
										WHERE 
										  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
										  Customer_Order.Cust_No = :1 AND 
										  Customer_Order.Year_Of_Sale = :2 AND 
										  Customer_Order.Load_Id IS NULL AND 
										  ( NOT Customer_Order.Invoiced_Flag = 'Y' OR 
										    Customer_Order.Invoiced_Flag IS NULL ) AND 
										  ( NOT Customer_Order.Pull_Sheet_Issued = 'Y' OR 
										    Customer_Order.Pull_Sheet_Issued IS NULL ) "
								Set sName = 'GTCSTTUNTOUT'
								Set sBind = ':nCustNo, :nYear'
								Set sInto = ':nGotTotalUnits'
								!
								Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
								Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
								!
								Set nTotalUnits = NUMBER_Null
								Set nGotTotalUnits = NUMBER_Null
								!
								If haSqlHandles[ nSqlHandleNo ].Execute( )
									If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
										Set nTotalUnits = nGotTotalUnits
									Return TRUE
								Else
									Return FALSE
						Case nDisconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nSqlHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nSqlHandleNoHist ].Disconnect( )
								Set bOk = FALSE
							Return bOk
			! Function: GetLoadCustTotalUnits
				                                                                                                                              Description: 
				                                                                                                                              Returns 
					                                                                                                                              Boolean: 
				                                                                                                                              Parameters 
					                                                                                                                              Number: nCustNo
					                                                                                                                              String: sLoadId
					                                                                                                                              Number: nYear
					                                                                                                                              Receive Number: nTotalUnits
					                                                                                                                              Number: nActionType
				                                                                                                                              Static Variables 
				                                                                                                                              Local variables 
					                                                                                                                              String: sSql
					                                                                                                                              String: sBind
					                                                                                                                              String: sInto
					                                                                                                                              String: sName
					                                                                                                                              Number: nInd
					                                                                                                                              Number: nSqlHandleNo
					!
					                                                                                                                              Number: nGotTotalUnits
				                                                                                                                              Actions 
					                                                                                                                              Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetLoadCustTotalUnits' )
					                                                                                                                              Select Case nActionType
						                                                                                                                              Case nExecute
							                                                                                                                              Set sSql = " SELECT 
									  SUM( Customer_Order.Conf_Amt * Stock_Item.Unit_Size )  AS Total_Units
									FROM 
									  Customer_Order, 
									  Stock_Item 
									WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									  Customer_Order.Cust_No = :1 AND 
									  Customer_Order.Year_Of_Sale = :2 AND 
									  Customer_Order.Load_Id = :3 "
							                                                                                                                              Set sName = 'GLDCSTTOTUNIT'
							                                                                                                                              Set sBind = ':nCustNo, :nYear, :sLoadId'
							                                                                                                                              Set sInto = ':nGotTotalUnits'
							                                                                                                                              Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							                                                                                                                              Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							                                                                                                                              Set nTotalUnits = NUMBER_Null
							                                                                                                                              Set nGotTotalUnits = NUMBER_Null
							!
							                                                                                                                              If haSqlHandles[ nSqlHandleNo ].Execute( )
								                                                                                                                              If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									                                                                                                                              Set nTotalUnits = nGotTotalUnits
								                                                                                                                              Return TRUE
							                                                                                                                              Else 
								                                                                                                                              Return FALSE
						                                                                                                                              Case nDisconnect
							                                                                                                                              Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			Function: CheckLoadDupSeqNo
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Receive Boolean: bExists
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nSqlHandleNo
					!
					Number: nInd
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CheckLoadDupSeqNo' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Sequence_No 
									FROM 
									  Load_Customers 
									WHERE 
									  Load_Id  = :1 
									GROUP BY 
									  Sequence_No 
									HAVING 
									  COUNT( Sequence_No ) > 1"
							Set sName = 'EXLDCSTDSEQN'
							Set sBind = ':sLoadId'
							Set sInto = ''
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set bExists = FALSE
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									Set bExists = TRUE
								Return TRUE
							Else
								Return FALSE
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			!
			Function: UpdtCustDenormMeetAddrs
				Description:
				Returns
					Boolean:
				Parameters
					Number: nCustNo
					! sSelectCustType = 'ALL' OR 'SELECTED'
					String: sSelectCustType
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					Number: nInd
					!
					Window Handle: hWndMeter
					Number: nTotalRows
					Number: nRowCount
					Number: nSqlHandleNo
					!
					String: sGotMeetId
					Number: nGotCustNo
					String: sGotAddress1
					String: sGotAddress2
					String: sGotSuburb
					String: sGotPostcode
					String: sGotState
					String: sGotCountry
					String: sGotAreaCode
					String: sGotPhoneNo
					String: sGotAreaCodeFax
					String: sGotFaxNo
					String: sGotComments 
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'UpdtCustDenormMeetAddrs' )
					Select Case nActionType
						Case nExecute
							If sSelectCustType = 'ALL'
								Set sSql = " SELECT  
										  Customer_Address.Address_Meet_Id, 
										  Customer_Address.Cust_No, 
										  Meet_Address.Meet_Address_1, 
										  Meet_Address.Meet_Address_2, 
										  Meet_Address.Meet_Suburb, 
										  Meet_Address.Meet_Postcode, 
										  Meet_Address.Meet_State, 
										  Meet_Address.Meet_Country, 
										  Meet_Address.Meet_Area_Code, 
										  Meet_Address.Meet_Phone_No, 
										  Meet_Address.Meet_Area_Code_Fax, 
										  Meet_Address.Meet_Fax_No, 
										  Meet_Address.Meet_Comments 
										FROM 
										  Customer_Address, 
										  Meet_Address 
										INTO 
										  :sGotMeetId, 
										  :nGotCustNo, 
										  :sGotAddress1, 
										  :sGotAddress2, 
										  :sGotSuburb, 
										  :sGotPostcode, 
										  :sGotState, 
										  :sGotCountry, 
										  :sGotAreaCode, 
										  :sGotPhoneNo, 
										  :sGotAreaCodeFax, 
										  :sGotFaxNo, 
										  :sGotComments 
										WHERE 
										  Customer_Address.Address_Meet_Id = Meet_Address.Meet_Id AND 
										  (
										    NOT Customer_Address.Address_1 = Meet_Address.Meet_Address_1 OR 
										    NOT Customer_Address.Address_2 = Meet_Address.Meet_Address_2 OR 
										    NOT Customer_Address.Suburb = Meet_Address.Meet_Suburb OR 
										    NOT Customer_Address.Postcode = Meet_Address.Meet_Postcode OR 
										    NOT Customer_Address.State = Meet_Address.Meet_State OR 
										    NOT Customer_Address.Country = Meet_Address.Meet_Country OR 
										    NOT Customer_Address.Area_Code = Meet_Address.Meet_Area_Code OR 
										    NOT Customer_Address.Phone_No = Meet_Address.Meet_Phone_No OR 
										    NOT Customer_Address.Area_Code_Fax = Meet_Address.Meet_Area_Code_Fax OR 
										    NOT Customer_Address.Fax_No = Meet_Address.Meet_Fax_No OR 
										    NOT Customer_Address.Comments = Meet_Address.Meet_Comments 
										  ) "
							Else
								Set sSql = " SELECT  
										  Customer_Address.Address_Meet_Id, 
										  Customer_Address.Cust_No, 
										  Meet_Address.Meet_Address_1, 
										  Meet_Address.Meet_Address_2, 
										  Meet_Address.Meet_Suburb, 
										  Meet_Address.Meet_Postcode, 
										  Meet_Address.Meet_State, 
										  Meet_Address.Meet_Country, 
										  Meet_Address.Meet_Area_Code, 
										  Meet_Address.Meet_Phone_No, 
										  Meet_Address.Meet_Area_Code_Fax, 
										  Meet_Address.Meet_Fax_No, 
										  Meet_Address.Meet_Comments 
										FROM 
										  Customer_Address, 
										  Meet_Address 
										INTO 
										  :sGotMeetId, 
										  :nGotCustNo, 
										  :sGotAddress1, 
										  :sGotAddress2, 
										  :sGotSuburb, 
										  :sGotPostcode, 
										  :sGotState, 
										  :sGotCountry, 
										  :sGotAreaCode, 
										  :sGotPhoneNo, 
										  :sGotAreaCodeFax, 
										  :sGotFaxNo, 
										  :sGotComments 
										WHERE 
										  Customer_Address.Cust_No = :nCustNo AND 
										  Customer_Address.Address_Meet_Id = Meet_Address.Meet_Id AND 
										  (
										    NOT Customer_Address.Address_1 = Meet_Address.Meet_Address_1 OR 
										    NOT Customer_Address.Address_2 = Meet_Address.Meet_Address_2 OR 
										    NOT Customer_Address.Suburb = Meet_Address.Meet_Suburb OR 
										    NOT Customer_Address.Postcode = Meet_Address.Meet_Postcode OR 
										    NOT Customer_Address.State = Meet_Address.Meet_State OR 
										    NOT Customer_Address.Country = Meet_Address.Meet_Country OR 
										    NOT Customer_Address.Area_Code = Meet_Address.Meet_Area_Code OR 
										    NOT Customer_Address.Phone_No = Meet_Address.Meet_Phone_No OR 
										    NOT Customer_Address.Area_Code_Fax = Meet_Address.Meet_Area_Code_Fax OR 
										    NOT Customer_Address.Fax_No = Meet_Address.Meet_Fax_No OR 
										    NOT Customer_Address.Comments = Meet_Address.Meet_Comments 
										  ) "
							Call haSqlHandles[ nSqlHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set sGotMeetId = ''
							Set nGotCustNo = NUMBER_Null
							Set sGotAddress1 = ''
							Set sGotAddress2 = ''
							Set sGotSuburb = ''
							Set sGotPostcode = ''
							Set sGotState = ''
							Set sGotCountry = ''
							Set sGotAreaCode = ''
							Set sGotPhoneNo = ''
							Set sGotAreaCodeFax = ''
							Set sGotFaxNo = ''
							Set sGotComments  = ''
							!
							!
							If haSqlHandles[ nSqlHandleNo ].PrepareAndExecute( )
								Call haSqlHandles[ nSqlHandleNo ].ResultSetCount( nTotalRows )
								If nTotalRows >= nNumRowsToMeter
									Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Updating customers meet address fields.', nTotalRows )
								Set nRowCount = 0
								!
								While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									If SetCustMeetAddrsFields( sGotMeetId, nGotCustNo, sGotAddress1, sGotAddress2, sGotSuburb, sGotPostcode, sGotState, sGotCountry, sGotAreaCode, sGotPhoneNo, sGotAreaCodeFax, sGotFaxNo, sGotComments, nExecute )
										Call SetCustMeetAddrsFields( '', 0, '', '', '', '', '', '', '', '', '', '', '', nCommit )
									Set nRowCount = nRowCount + 1
									Call SalSendMsg( hWndMeter, PAM_SETPROGRESS, 0, nRowCount )
								!
								Call SalSendMsg( hWndMeter, PAM_END, 0, 0 )
								Return TRUE
							Else
								Return FALSE
						Case nDisconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nSqlHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT SetCustMeetAddrsFields( '', 0, '', '', '', '', '', '', '', '', '', '', '', nCommit )
								Set bOk = FALSE
							Return bOk
			Function: SetCustMeetAddrsFields
				Description:
				Returns
					Boolean:
				Parameters
					String: sMeetId
					Number: nCustNo
					String: sAddress1
					String: sAddress2
					String: sSuburb
					String: sPostcode
					String: sState
					String: sCountry
					String: sAreaCode
					String: sPhoneNo
					String: sAreaCodeFax
					String: sFaxNo
					String: sComments 
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					Number: nSqlHandleNo
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'SetCustMeetAddrsFields' )
					Select Case nActionType
						Case nExecute
							Set sSql = " UPDATE 
									  Customer_Address 
									SET 
									  Address_1 = :sAddress1, 
									  Address_2 = :sAddress2, 
									  Suburb = :sSuburb, 
									  Postcode = :sPostcode, 
									  State = :sState, 
									  Country = :sCountry, 
									  Area_Code = :sAreaCode, 
									  Phone_No = :sPhoneNo, 
									  Area_Code_Fax = :sAreaCodeFax, 
									  Fax_No = :sFaxNo, 
									  Comments = :sComments 
									WHERE 
									  Cust_No = :nCustNo AND 
									  Address_Meet_Id = :sMeetId  "
							Call haSqlHandles[ nSqlHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Return haSqlHandles[ nSqlHandleNo ].PrepareAndExecute( )
						Case nCommit
							Return haSqlHandles[ nSqlHandleNo ].Commit( )
						Case nRollback
							Return haSqlHandles[ nSqlHandleNo ].Rollback( )
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			!
			!
			Function: MoveCustLoadToLoad
				Description: Moves a customer and his orders on a load to another load.
						This functions commits/rollsback by its self.
				Returns
					Boolean:
				Parameters
					String: sLoadIdFrom
					String: sLoadIdTo
					Number: nCustNo
					Number: nCurrentYear
					Number: nActionType
				Static Variables
				Local variables
					Boolean: bOk
					Boolean: bExists
					Boolean: bCustomerMoved
					Number: nNewSeqNo
				Actions
					Select Case nActionType
						Case nExecute
							If ExistsCustOnLoad( sLoadIdTo, nCustNo, bExists, nExecute )
								Set bCustomerMoved = FALSE
								If NOT bExists
									If GetLoadMaxSeq( sLoadIdTo, nNewSeqNo, nExecute )
										Set nNewSeqNo = nNewSeqNo + 5
										If ChangeCustLoadToLoad( sLoadIdFrom, sLoadIdTo, nCustNo, nNewSeqNo, nExecute )
											Set bCustomerMoved = TRUE
										Else
											Return FALSE
									Else
										Return FALSE
								If ChangeCustOrdLoadToLoad( sLoadIdFrom, sLoadIdTo, nCustNo, nCurrentYear, nExecute )
									If bCustomerMoved
										Call MoveCustLoadToLoad( '', '', 0, 0, nCommit )
									Call ChangeCustOrdLoadToLoad( '', '', 0, 0, nCommit )
									Return TRUE
								Else
									Call MoveCustLoadToLoad( '', '', 0, 0, nRollback )
									Return FALSE
							Else
								Return FALSE
						Case nCommit
							Set bOk = TRUE
							If NOT ChangeCustLoadToLoad( '', '', 0, 0, nCommit )
								Set bOk = FALSE
							If NOT ChangeCustOrdLoadToLoad( '', '', 0, 0, nCommit )
								Set bOk = FALSE
							Return bOk
						Case nRollback
							Set bOk = TRUE
							If NOT ChangeCustLoadToLoad( '', '', 0, 0, nRollback )
								Set bOk = FALSE
							If NOT ChangeCustOrdLoadToLoad( '', '', 0, 0, nRollback )
								Set bOk = FALSE
							Return bOk
						Case nDisconnect
							Set bOk = FALSE
							If NOT ChangeCustLoadToLoad( '', '', 0, 0, nDisconnect )
								Set bOk = FALSE
							If NOT ChangeCustOrdLoadToLoad( '', '', 0, 0, nDisconnect )
								Set bOk = FALSE
							If NOT ExistsCustOnLoad( '', 0, bExists, nDisconnect )
								Set bOk = FALSE
							If NOT GetLoadMaxSeq( '', nNewSeqNo, nDisconnect )
								Set bOk = FALSE
							Return bOk
						Case nRePrepare
							Call ChangeCustLoadToLoad( '', '', 0, 0, nRePrepare )
							Call ChangeCustOrdLoadToLoad( '', '', 0, 0, nRePrepare )
							Call ExistsCustOnLoad( '', 0, bExists, nRePrepare )
							Call GetLoadMaxSeq( '', nNewSeqNo, nRePrepare )
							Return TRUE
			! function MoveCustLoadToLoad uses the 4 functions bellow
			Function: ChangeCustLoadToLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadIdFrom
					String: sLoadIdTo
					Number: nCustNo
					Number: nSeqNo
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					Boolean: bOk
					String: sSql
					Number: nInd
				Actions
					Select Case nActionType
						Case nExecute
							If NOT bHandleConnected
								Set bHandleConnected = SqlConnect( hSqlHandle ) 
								If bHandleConnected
									Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
									Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
								Else
									Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									Return FALSE
							If NOT bHandlePrepared
								Set sSql = ' UPDATE Load_Customers
										  SET Load_Id = :sLoadIdTo, 
										          Sequence_No = :nSeqNo 
										  WHERE 
										     Load_Id = :sLoadIdFrom AND 
										     Cust_No = :nCustNo '
								If SqlPrepare( hSqlHandle, sSql )
									Set bHandlePrepared = TRUE
								Else
									Set bHandlePrepared = FALSE
							!
							If SqlExecute( hSqlHandle )
								Return TRUE
							Else
								Set bHandlePrepared = FALSE
								Call SalMessageBox( 'SqlExecute had a error in ChangeCustLoadToLoad!, Contact programmers please!', 'ERROR', MB_Ok )
								Return FALSE
						Case nCommit
							Set bOk = TRUE
							If bHandleConnected
								Set bOk = SqlCommit( hSqlHandle )
							Return bOk
						Case nRollback
							Set bOk = TRUE
							If bHandleConnected
								Set bOk = SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
								Set bHandlePrepared = FALSE
							Return bOk
						Case nDisconnect
							Set bOk = FALSE
							Set bHandlePrepared = FALSE
							If bHandleConnected
								Set bHandleConnected = FALSE
								Set bOk = SqlDisconnect( hSqlHandle )
							Return bOk
						Case nRePrepare
							Set bHandlePrepared = FALSE
							Return TRUE
			Function: ChangeCustOrdLoadToLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadIdFrom
					String: sLoadIdTo
					Number: nCustNo
					Number: nYear
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					Boolean: bOk
					String: sSql
					Number: nInd
				Actions
					Select Case nActionType
						Case nExecute
							If NOT bHandleConnected
								Set bHandleConnected = SqlConnect( hSqlHandle ) 
								If bHandleConnected
									Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
									Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
								Else
									Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									Return FALSE
							If NOT bHandlePrepared
								Set sSql = ' UPDATE Customer_Order 
										  SET Load_Id = :sLoadIdTo 
										  WHERE 
										     Cust_No = :nCustNo AND 
										     Load_Id = :sLoadIdFrom AND 
										     Year_Of_Sale = :nYear '
								If SqlPrepare( hSqlHandle, sSql )
									Set bHandlePrepared = TRUE
								Else
									Set bHandlePrepared = FALSE
							!
							If SqlExecute( hSqlHandle )
								Return TRUE
							Else
								Set bHandlePrepared = FALSE
								Call SalMessageBox( 'SqlExecute had a error in ChangeCustOrdLoadToLoad!, Contact programmers please!', 'ERROR', MB_Ok )
								Return FALSE
						Case nCommit
							Set bOk = TRUE
							If bHandleConnected
								Set bOk = SqlCommit( hSqlHandle )
							Return bOk
						Case nRollback
							Set bOk = TRUE
							If bHandleConnected
								Set bOk = SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
								Set bHandlePrepared = FALSE
							Return bOk
						Case nDisconnect
							Set bOk = FALSE
							Set bHandlePrepared = FALSE
							If bHandleConnected
								Set bHandleConnected = FALSE
								Set bOk = SqlDisconnect( hSqlHandle )
							Return bOk
						Case nRePrepare
							Set bHandlePrepared = FALSE
							Return TRUE
			Function: GetLoadMaxSeq
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Receive Number: nMaxSeqNo
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					Boolean: bOk
					String: sSql
					Number: nInd
					Number: nGotMaxSeqNo
				Actions
					Select Case nActionType
						Case nExecute
							If NOT bHandleConnected
								Set bHandleConnected = SqlConnect( hSqlHandle ) 
								If bHandleConnected
									Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
									Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
								Else
									Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									Return FALSE
							If NOT bHandlePrepared
								Set sSql = ' SELECT Max( Sequence_No ) 
										  FROM Load_Customers 
										  INTO :nGotMaxSeqNo 
										  WHERE Load_Id = :sLoadId '
								If SqlPrepare( hSqlHandle, sSql )
									Set bHandlePrepared = TRUE
								Else
									Set bHandlePrepared = FALSE
							!
							Set nMaxSeqNo = NUMBER_Null
							Set nGotMaxSeqNo = NUMBER_Null
							!
							If SqlExecute( hSqlHandle )
								If SqlFetchNext( hSqlHandle, nInd )
									If nGotMaxSeqNo = NUMBER_Null
										Set nMaxSeqNo = 5
									Else
										Set nMaxSeqNo = nGotMaxSeqNo
									Return TRUE
								Else
									Return FALSE
							Else
								Set bHandlePrepared = FALSE
								Call SalMessageBox( 'SqlExecute had a error in GetLoadMaxSeq!, Contact programmers please!', 'ERROR', MB_Ok )
								Return FALSE
						Case nDisconnect
							Set bOk = FALSE
							Set bHandlePrepared = FALSE
							If bHandleConnected
								Set bHandleConnected = FALSE
								Set bOk = SqlDisconnect( hSqlHandle )
							Return bOk
						Case nRePrepare
							Set bHandlePrepared = FALSE
							Return TRUE
			Function: ExistsCustOnLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nCustNo
					Receive Boolean: bExists
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					Boolean: bOk
					String: sSql
					Number: nInd
				Actions
					Select Case nActionType
						Case nExecute
							If NOT bHandleConnected
								Set bHandleConnected = SqlConnect( hSqlHandle ) 
								If bHandleConnected
									Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
									Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
								Else
									Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									Return FALSE
							If NOT bHandlePrepared
								Set sSql = ' SELECT Cust_No
										  FROM Load_Customers 
										  WHERE Load_Id = :sLoadId AND Cust_No = :nCustNo '
								If SqlPrepare( hSqlHandle, sSql )
									Set bHandlePrepared = TRUE
								Else
									Set bHandlePrepared = FALSE
							!
							Set bExists = FALSE
							!
							If SqlExecute( hSqlHandle )
								If SqlFetchNext( hSqlHandle, nInd )
									Set bExists = TRUE
								Else
									Set bExists = FALSE
								Return TRUE
							Else
								Set bHandlePrepared = FALSE
								Call SalMessageBox( 'SqlExecute had a error in ExistsCustOnLoad!, Contact programmers please!', 'ERROR', MB_Ok )
								Return FALSE
						Case nDisconnect
							Set bOk = FALSE
							Set bHandlePrepared = FALSE
							If bHandleConnected
								Set bHandleConnected = FALSE
								Set bOk = SqlDisconnect( hSqlHandle )
							Return bOk
						Case nRePrepare
							Set bHandlePrepared = FALSE
							Return TRUE
			!
			Function: MoveCustOrdLinesLoadToLoad
				Description: Moves a customers orders on a load to another load.
						This functions commits/rollsback by its self.
				Returns
					Boolean:
				Parameters
					String: sLoadIdFrom
					String: sLoadIdTo
					Number: nCustNo
					! dtaOrdDTs is a NUMBER_Null terminated array
					Date/Time: dtaOrdDTs[*]
					Number: nActionType
				Static Variables
				Local variables
					Boolean: bOk
					Boolean: bExists
					Boolean: bCustomerMoved
					Number: nNewSeqNo
				Actions
					Select Case nActionType
						Case nExecute
							If ExistsCustOnLoad( sLoadIdTo, nCustNo, bExists, nExecute )
								Set bCustomerMoved = FALSE
								If NOT bExists
									If GetLoadMaxSeq( sLoadIdTo, nNewSeqNo, nExecute )
										Set nNewSeqNo = nNewSeqNo + 5
										If CopyCustLoadToLoad( sLoadIdFrom, sLoadIdTo, nCustNo, nNewSeqNo, nExecute )
											Set bCustomerMoved = TRUE
										Else
											Return FALSE
									Else
										Return FALSE
								If ChangeCustOrdLinesLoadToLoad( sLoadIdTo, nCustNo, dtaOrdDTs, nExecute )
									If bCustomerMoved
										Call CopyCustLoadToLoad( '', '', 0, 0, nCommit )
									Call ChangeCustOrdLinesLoadToLoad( '', 0, dtaOrdDTs, nCommit )
									Return TRUE
								Else
									Call CopyCustLoadToLoad( '', '', 0, 0, nRollback )
									Return FALSE
							Else
								Return FALSE
						Case nDisconnect
							Set bOk = FALSE
							If NOT ExistsCustOnLoad( '', 0, bExists, nDisconnect )
								Set bOk = FALSE
							If NOT GetLoadMaxSeq( '', nNewSeqNo, nDisconnect )
								Set bOk = FALSE
							If NOT CopyCustLoadToLoad( '', '', 0, 0, nDisconnect )
								Set bOk = FALSE
							If NOT ChangeCustOrdLinesLoadToLoad( '', 0, dtaOrdDTs, nDisconnect )
								Set bOk = FALSE
							Return bOk
			Function: CopyCustLoadToLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadIdFrom
					String: sLoadIdTo
					Number: nCustNo
					Number: nSeqNoTo
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
					! hcSqlHandle: fcOurInsHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					Number: nInd
					Boolean: bOk
					!
					String: sDelivInst
					Date/Time: dtDelivDate
					Date/Time: dtDelivTime
					Number: nSqlHandleNo
					Number: nSqlHandleNoIns
					String: sDelivComments
					String: sCustContFlag
					String: sFreightCode
					String: sLoadOrdType
					Date/Time: dtDelivAddrDT
					String: sPullFlag
					String: sInvFlag
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CopyCustLoadToLoad' )
					Set nSqlHandleNoIns = SqlHandlesGetReferenceNo( 'CopyCustLoadToLoadIns' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Deliv_Instructions, 
									  Anticip_Del_Date, 
									  Anticip_Del_Time, 
									  Delivery_Comments, 
									  Cust_Cont_Flag, 
									  Freight_Code, 
									  Load_Order_Type, 
									  Deliv_Addr_DT, 
									  Cust_Pulled_Flag, 
									  Cust_Inv_Flag 
									FROM 
									  Load_Customers 
									INTO 
									  :sDelivInst, 
									  :dtDelivDate, 
									  :dtDelivTime, 
									  :sDelivComments, 
									  :sCustContFlag, 
									  :sFreightCode, 
									  :sLoadOrdType, 
									  :dtDelivAddrDT, 
									  :sPullFlag, 
									  :sInvFlag
									WHERE 
									  Load_Id = :sLoadIdFrom AND 
									  Cust_No = :nCustNo "
							Call haSqlHandles[ nSqlHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set sSql = " INSERT INTO Load_Customers 
									(
									  Load_Id, 
									  Sequence_No, 
									  Cust_No,  
									  Deliv_Instructions, 
									  Anticip_Del_Date, 
									  Anticip_Del_Time, 
									  Delivery_Comments, 
									  Cust_Cont_Flag, 
									  Freight_Code, 
									  Load_Order_Type, 
									  Deliv_Addr_DT, 
									  Cust_Pulled_Flag, 
									  Cust_Inv_Flag 
									) 
									VALUES 
									(
									  :sLoadIdTo, 
									  :nSeqNoTo, 
									  :nCustNo, 
									  :sDelivInst, 
									  :dtDelivDate, 
									  :dtDelivTime, 
									  :sDelivComments, 
									  :sCustContFlag, 
									  :sFreightCode, 
									  :sLoadOrdType, 
									  :dtDelivAddrDT, 
									  :sPullFlag, 
									  :sInvFlag 
									) "
							Call haSqlHandles[ nSqlHandleNoIns ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoIns ].hSqlHandle )
							!
							If haSqlHandles[ nSqlHandleNo ].PrepareAndExecute( )
								If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									Return haSqlHandles[ nSqlHandleNoIns ].PrepareAndExecute( )
								Else
									Return FALSE
							Else
								Return FALSE
						Case nCommit
							Return haSqlHandles[ nSqlHandleNoIns ].Commit( )
						Case nRollback
							Return haSqlHandles[ nSqlHandleNoIns ].Rollback( )
						Case nDisconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nSqlHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nSqlHandleNoIns ].Disconnect( )
								Set bOk = FALSE
							Return bOk
			Function: ChangeCustOrdLinesLoadToLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadIdTo
					Number: nCustNo
					! dtaOrdDTs is a NUMBER_Null terminated array
					Date/Time: dtaOrdDTs[*]
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					Number: nSqlHandleNo
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'ChangeCustOrdLinesLoadToLoad' )
					Select Case nActionType
						Case nExecute
							Call MakeDateTimeList( dtaOrdDTs, ', ', '', sSql )
							Set sSql = " UPDATE Customer_Order 
									SET Load_Id = :sLoadIdTo 
									WHERE 
									  Cust_No = :nCustNo AND 
									  Order_Date_Time IN ( " || sSql || " ) "
							!
							Call haSqlHandles[ nSqlHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							If haSqlHandles[ nSqlHandleNo ].PrepareAndExecute( )
								Return TRUE
							Else
								Return FALSE
						Case nCommit
							Return haSqlHandles[ nSqlHandleNo ].Commit( )
						Case nRollback
							Return haSqlHandles[ nSqlHandleNo ].Rollback( )
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			!
			Function: CopyLoadToLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadIdFrom
					String: sLoadIdTo
					String: sLoadDescTo
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					Number: nInd
					Boolean: bOk
					Number: nSqlHandleNo
					Number: nSqlHandleNoIns
					!
					String: sTransportId
					Date/Time: dtShippingDate
					Date/Time: dtExpReturnDate
					String: sLoadPrimaryType
					String: sLoadPullFlag
					String: sLoadComments
					String: sLoadDescription
					String: sLoadInvFlag
					String: sLoadDriver
					Date/Time: dtLoadInvoiceByDate
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CopyLoadToLoad' )
					Set nSqlHandleNoIns = SqlHandlesGetReferenceNo( 'CopyLoadToLoadIns' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Transport_Id, 
									  Shipping_Date, 
									  Exp_Return_Date, 
									  Load_Primary_Type, 
									  Load_Pulled_Flag, 
									  Load_Comments, 
									  Load_Invoiced_Flag, 
									  Load_Driver, 
									  Invoice_By_Date 
									FROM 
									  Load  
									INTO 
									  :sTransportId, 
									  :dtShippingDate, 
									  :dtExpReturnDate, 
									  :sLoadPrimaryType, 
									  :sLoadPullFlag, 
									  :sLoadComments, 
									  :sLoadInvFlag, 
									  :sLoadDriver, 
									  :dtLoadInvoiceByDate 
									WHERE 
									  Load_Id = :sLoadIdFrom "
							Call haSqlHandles[ nSqlHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set sSql = " INSERT INTO Load  
									(  
									  Load_Id, 
									  Transport_Id, 
									  Shipping_Date, 
									  Exp_Return_Date, 
									  Load_Primary_Type, 
									  Load_Pulled_Flag, 
									  Load_Comments, 
									  Load_Description, 
									  Load_Invoiced_Flag, 
									  Load_Driver, 
									  Invoice_By_Date 
									) 
									VALUES 
									(  
									  :sLoadIdTo, 
									  :sTransportId, 
									  :dtShippingDate, 
									  :dtExpReturnDate, 
									  :sLoadPrimaryType, 
									  :sLoadPullFlag, 
									  :sLoadComments, 
									  :sLoadDescTo, 
									  :sLoadInvFlag, 
									  :sLoadDriver, 
									  :dtLoadInvoiceByDate 
									) "
							Call haSqlHandles[ nSqlHandleNoIns ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoIns ].hSqlHandle )
							!
							If haSqlHandles[ nSqlHandleNo ].PrepareAndExecute( )
								If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									Set sLoadPullFlag = 'N'
									Set sLoadInvFlag = 'N'
									Return haSqlHandles[ nSqlHandleNoIns ].PrepareAndExecute( )
								Else
									Return FALSE
							Else
								Return FALSE
						Case nCommit
							Return haSqlHandles[ nSqlHandleNoIns ].Commit( )
						Case nRollback
							Return haSqlHandles[ nSqlHandleNoIns ].Rollback( )
						Case nDisconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nSqlHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nSqlHandleNoIns ].Disconnect( )
								Set bOk = FALSE
							Return bOk
			Function: CopyLoadCustomersToLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadIdFrom
					String: sLoadIdTo
					Number: nActionType
				Static Variables
				Local variables
					String: sSql
					Number: nInd
					Boolean: bOk
					Number: nSqlHandleNo
					Number: nSqlHandleNoIns
					!
					Number: nSeqNo
					Number: nCustNo
					String: sDelivInst
					Date/Time: dtDelivDate
					Date/Time: dtDelivTime
					String: sDelivComments
					String: sCustContFlag
					String: sFreightCode
					String: sLoadOrdType
					String: sPullFlag
					String: sInvFlag
					Date/Time: dtDelivAddrDT
					String: sDeliveryNotiLetter
					String: sCustRegionId
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CopyLoadCustomersToLoad' )
					Set nSqlHandleNoIns = SqlHandlesGetReferenceNo( 'CopyLoadCustomersToLoadIns' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Load_Customers.Sequence_No, 
									  Load_Customers.Cust_No, 
									  Load_Customers.Deliv_Instructions, 
									  Load_Customers.Anticip_Del_Date, 
									  Load_Customers.Anticip_Del_Time, 
									  Load_Customers.Delivery_Comments, 
									  Load_Customers.Cust_Cont_Flag, 
									  Load_Customers.Freight_Code, 
									  Load_Customers.Load_Order_Type, 
									  Load_Customers.Cust_Pulled_Flag,
									  Load_Customers.Cust_Inv_Flag, 
									  Load_Customers.Deliv_Addr_DT, 
									  Load_Customers.Deliv_Noti_Letter, 
									  Customer_Master.Region_Id 
									FROM 
									  Load_Customers, 
									  Customer_Master  
									INTO 
									  :nSeqNo, 
									  :nCustNo, 
									  :sDelivInst, 
									  :dtDelivDate, 
									  :dtDelivTime, 
									  :sDelivComments, 
									  :sCustContFlag, 
									  :sFreightCode, 
									  :sLoadOrdType, 
									  :sPullFlag, 
									  :sInvFlag, 
									  :dtDelivAddrDT, 
									  :sDeliveryNotiLetter, 
									  :sCustRegionId 
									WHERE 
									  Load_Customers.Load_Id = :sLoadIdFrom AND 
									  Load_Customers.Cust_No = Customer_Master.Cust_No "
							Call haSqlHandles[ nSqlHandleNo ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set sSql = " INSERT INTO Load_Customers 
									( 
									  Load_Id, 
									  Sequence_No, 
									  Cust_No, 
									  Deliv_Instructions, 
									  Anticip_Del_Date, 
									  Anticip_Del_Time, 
									  Delivery_Comments, 
									  Cust_Cont_Flag, 
									  Freight_Code, 
									  Load_Order_Type, 
									  Cust_Pulled_Flag,
									  Cust_Inv_Flag, 
									  Deliv_Addr_DT, 
									  Deliv_Noti_Letter 
									) 
									VALUES 
									( 
									  :sLoadIdTo, 
									  :nSeqNo, 
									  :nCustNo, 
									  :sDelivInst, 
									  :dtDelivDate, 
									  :dtDelivTime, 
									  :sDelivComments, 
									  :sCustContFlag, 
									  :sFreightCode, 
									  :sLoadOrdType, 
									  :sPullFlag, 
									  :sInvFlag, 
									  :dtDelivAddrDT, 
									  :sDeliveryNotiLetter 
									) "
							Call haSqlHandles[ nSqlHandleNoIns ].PrepareSetup( sSql )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoIns ].hSqlHandle )
							!
							Set bOk = TRUE
							If haSqlHandles[ nSqlHandleNo ].PrepareAndExecute( )
								While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd ) AND bOk
									Set sPullFlag = 'N'
									Set sInvFlag = 'N'
									If haSqlHandles[ nSqlHandleNoIns ].PrepareAndExecute( )
										If NOT LoadIdRegionIdExists( sLoadIdTo, sCustRegionId, nExecute )
											If NOT AddCustRegionToLoad( sLoadIdTo, sCustRegionId, nExecute )
												Call SalMessageBox( 'Could not add customers region to load!  Please rerun the update customers regions on load facility!', 'Error', MB_Ok )
												Set bOk = FALSE
									Else
										Set bOk = FALSE
							Else
								Set bOk = FALSE
							Return bOk
						Case nCommit
							Set bOk = TRUE
							If NOT AddCustRegionToLoad( '', '', nCommit )
								Set bOk = FALSE
							If NOT haSqlHandles[ nSqlHandleNoIns ].Commit( )
								Set bOk = FALSE
							Return bOk
						Case nRollback
							Set bOk = TRUE
							If NOT AddCustRegionToLoad( '', '', nRollback )
								Set bOk = FALSE
							If NOT haSqlHandles[ nSqlHandleNoIns ].Rollback( )
								Set bOk = FALSE
							Return bOk
						Case nDisconnect
							Set bOk = TRUE
							If NOT LoadIdRegionIdExists( '', '', nDisconnect )
								Set bOk = FALSE
							If NOT AddCustRegionToLoad( '', '', nDisconnect )
								Set bOk = FALSE
							If NOT haSqlHandles[ nSqlHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nSqlHandleNoIns ].Disconnect( )
								Set bOk = FALSE
							Return bOk
			!
			Function: ExistsLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Receive Boolean: bExists
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					Boolean: bOk
					String: sSql
					Number: nInd
				Actions
					Select Case nActionType
						Case nExecute
							If NOT bHandleConnected
								Set bHandleConnected = SqlConnect( hSqlHandle ) 
								If bHandleConnected
									Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
									Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
								Else
									Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									Return FALSE
							If NOT bHandlePrepared
								Set sSql = ' SELECT Load_Id
										  FROM Load 
										  WHERE Load_Id = :sLoadId '
								If SqlPrepare( hSqlHandle, sSql )
									Set bHandlePrepared = TRUE
								Else
									Set bHandlePrepared = FALSE
							!
							Set bExists = FALSE
							!
							If SqlExecute( hSqlHandle )
								If SqlFetchNext( hSqlHandle, nInd )
									Set bExists = TRUE
								Else
									Set bExists = FALSE
								Return bExists
							Else
								Set bHandlePrepared = FALSE
								Call SalMessageBox( 'SqlExecute had a error in ExistsLoad!, Contact programmers please!', 'ERROR', MB_Ok )
								Return FALSE
						Case nDisconnect
							Set bOk = FALSE
							Set bHandlePrepared = FALSE
							If bHandleConnected
								Set bHandleConnected = FALSE
								Set bOk = SqlDisconnect( hSqlHandle )
							Return bOk
						Case nRePrepare
							Set bHandlePrepared = FALSE
							Return TRUE
			!
			!
			!
			Function: AnyPullnNotInvCustOrdsOnLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nCustNo
					Number: nYear
					Receive Boolean: bAny
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nSqlHandleNo
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'ANYCPULLNINV' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Order_Date_Time 
									FROM 
									  Customer_Order 
									WHERE 
									  Cust_No = :1 AND 
									  Year_Of_Sale = :2 AND 
									  Load_Id = :3 AND 
									  Pull_Sheet_Issued = 'Y' AND 
									  ( NOT Invoiced_Flag = 'Y' OR 
									  Invoiced_Flag IS NULL ) "
							Set sName = 'ANYCPULLNINV'
							Set sBind = ':nCustNo, :nYear, :sLoadId'
							Set sInto = ''
							!
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set bAny = FALSE
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									Set bAny = TRUE
								Return TRUE
							Else
								Return FALSE
						Case nCommit
							Return haSqlHandles[ nSqlHandleNo ].Commit( )
						Case nRollback
							Return haSqlHandles[ nSqlHandleNo ].Rollback( )
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			Function: AnyPullnNotInvOrdsOnLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nYear
					Receive Boolean: bAny
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					Number: nSqlHandleNo
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'ANYOPULLNINV' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Cust_No  
									FROM 
									  Customer_Order 
									WHERE 
									  Year_Of_Sale = :1 AND 
									  Load_Id = :2 AND 
									  Pull_Sheet_Issued = 'Y' AND 
									  ( NOT Invoiced_Flag = 'Y' OR 
									  Invoiced_Flag IS NULL ) "
							Set sName = 'ANYOPULLNINV'
							Set sBind = ':nYear, :sLoadId'
							Set sInto = ''
							!
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set bAny = FALSE
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
									Set bAny = TRUE
								Return TRUE
							Else
								Return FALSE
						Case nCommit
							Return haSqlHandles[ nSqlHandleNo ].Commit( )
						Case nRollback
							Return haSqlHandles[ nSqlHandleNo ].Rollback( )
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			!
			! The next three functions should stay here
			Function: LoadIdRegionIdExists
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					String: sRegionId
					Number: nExecuteOrDisconnect
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					String: sSql
					Number: nInd
					Boolean: bOk
				Actions
					If nExecuteOrDisconnect != nDisconnect
						If NOT bHandleConnected
							Set bHandleConnected = SqlConnect( hSqlHandle ) 
							If bHandleConnected
								Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
								Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
							Else
								Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
								Return FALSE
						If NOT bHandlePrepared
							Set sSql = ' SELECT Load_Id, Region_Id FROM Region_Load WHERE Load_Id = :sLoadId AND Region_Id = :sRegionId '
							If SqlPrepare( hSqlHandle, sSql )
								Set bHandlePrepared = TRUE
							Else
								Set bHandlePrepared = FALSE
						If SqlExecute( hSqlHandle )
							If SqlFetchNext( hSqlHandle, nInd )
								Return TRUE
							Else
								Return FALSE
						Else
							Set bHandlePrepared = FALSE
							Call SalMessageBox( 'SqlExecute had a error in LoadIdRegionIdExists, Contact programmers please!', 'ERROR', MB_Ok )
							Return FALSE
					Else
						Set bOk = TRUE
						Set bHandlePrepared = FALSE
						If bHandleConnected
							Set bHandleConnected = FALSE
							Set bOk = SqlDisconnect( hSqlHandle )
						Return bOk
			Function: AddCustRegionToLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					String: sRegionId
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					Boolean: bOk
					String: sSql
				Actions
					Select Case nActionType
						Case nExecute
							If NOT bHandleConnected
								Set bHandleConnected = SqlConnect( hSqlHandle ) 
								If bHandleConnected
									Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
									Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
								Else
									Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									Return FALSE
							If NOT bHandlePrepared
								Set sSql = ' INSERT INTO Region_Load ( Load_Id, Region_Id ) VALUES ( :sLoadId, :sRegionId ) '
								If SqlPrepare( hSqlHandle, sSql )
									Set bHandlePrepared = TRUE
								Else
									Set bHandlePrepared = FALSE
							If SqlExecute( hSqlHandle )
								Return TRUE
							Else
								Set bHandlePrepared = FALSE
								Call SalMessageBox( 'SqlExecute had a error in AddCustRegionToLoad, Contact programmers please!', 'ERROR', MB_Ok )
								Return FALSE
						Case nCommit
							Set bOk = TRUE
							If bHandleConnected
								Set bOk = SqlCommit( hSqlHandle )
							Return bOk
						Case nRollback
							Set bOk = TRUE
							If bHandleConnected
								Set bOk = SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
								Set bHandlePrepared = FALSE
							Return bOk
						Case nDisconnect
							Set bOk = FALSE
							Set bHandlePrepared = FALSE
							If bHandleConnected
								Set bHandleConnected = FALSE
								Set bOk = SqlDisconnect( hSqlHandle )
							Return bOk
						Case nRePrepare
							Set bHandlePrepared = FALSE
							Return TRUE
			Function: UpdateCustRegionsOnLoads
				Description:
				Returns
					Boolean:
				Parameters
					String: saLoadIds[*]
					Number: nActionType
				Static Variables
				Local variables
					Boolean: bOk
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					String: sLoadId
					!
					Number: nDelHandleNo
					Number: nInsHandleNo
				Actions
					Set nDelHandleNo = SqlHandlesGetReferenceNo( 'UpdateCustRegionsOnLoadsDelete' )
					Set nInsHandleNo = SqlHandlesGetReferenceNo( 'UpdateCustRegionsOnLoadsInsert' )
					Select Case nActionType
						Case nExecute
							Set sSql = 'DELETE FROM Region_Load 
									WHERE Load_Id = :1 '
							Set sName = 'DELALLREGOLD'
							Set sBind = ':sLoadId'
							Set sInto = ''
							Call haSqlHandles[ nDelHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nDelHandleNo ].hSqlHandle )
							!
							Set sSql = 'INSERT INTO Region_Load 
									( Load_Id, Region_Id )
									SELECT DISTINCT
									  Load_Customers.Load_Id, 
									  Customer_Master.Region_Id 
									FROM 
									  Load_Customers, 
									  Customer_Master 
									WHERE 
									  Load_Customers.Load_Id = :1 AND 
									  Load_Customers.Cust_No = Customer_Master.Cust_No'
							Set sName = 'INSALLCSTREGOLD'
							Set sBind = ':sLoadId'
							Set sInto = ''
							Call haSqlHandles[ nInsHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nInsHandleNo ].hSqlHandle )
							!
							Set bOk = TRUE
							Set nIndex = 0
							While saLoadIds[nIndex] != '' AND bOk
								Set sLoadId = saLoadIds[nIndex]
								If haSqlHandles[ nDelHandleNo ].Execute( )
									If haSqlHandles[ nInsHandleNo ].Execute( )
										Call haSqlHandles[ nDelHandleNo ].Commit( )
										Call haSqlHandles[ nInsHandleNo ].Commit( )
									Else
										Call haSqlHandles[ nDelHandleNo ].Rollback( )
										Set bOk = FALSE
								Else
									Set bOk = FALSE
								Set nIndex = nIndex + 1
							Return bOk
						Case nDisconnect
							Set bOk = TRUE
							If NOT haSqlHandles[ nDelHandleNo ].Disconnect( )
								Set bOk = FALSE
							If NOT haSqlHandles[ nInsHandleNo ].Disconnect( )
								Set bOk = FALSE
							Return bOk
			! Function: UpdateCustRegionsOnLoads
				                                                                                                                              Description: 
				                                                                                                                              Returns 
					                                                                                                                              Boolean: 
				                                                                                                                              Parameters 
					                                                                                                                              String: saLoadIds[*]
					                                                                                                                              Number: nActionType
				                                                                                                                              Static Variables 
					                                                                                                                              Sql Handle: hSqlHandle
					                                                                                                                              Boolean: bHandleConnected
					                                                                                                                              Boolean: bHandlePrepared
				                                                                                                                              Local variables 
					                                                                                                                              Boolean: bOk
					                                                                                                                              String: sSql
					                                                                                                                              Number: nInd
					                                                                                                                              Number: nIndex
					                                                                                                                              String: sBind
					                                                                                                                              String: sInto
					                                                                                                                              String: sName
					!
					                                                                                                                              String: sLoadId
					                                                                                                                              Number: nCustNo
					                                                                                                                              String: sRegionId
					!
					                                                                                                                              Number: nSqlHandleNo
					                                                                                                                              Number: nTotalRows
					                                                                                                                              Number: nRow
					                                                                                                                              Window Handle: hWndMeter
				                                                                                                                              Actions 
					                                                                                                                              Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'SELCSTREGONLD' )
					                                                                                                                              Select Case nActionType
						                                                                                                                              Case nExecute
							                                                                                                                              Set sSql = ' SELECT 
									    Load_Customers.Load_Id, 
									    Load_Customers.Cust_No, 
									    Customer_Master.Region_Id 
									  FROM 
									    Load_Customers, 
									    Customer_Master 
									    WHERE Load_Customers.Cust_No = Customer_Master.Cust_No AND
									 Load_Customers.Load_Id = :1'
							                                                                                                                              Set sName = 'SELCSTREGONLD'
							                                                                                                                              Set sBind = ':sLoadId'
							                                                                                                                              Set sInto = ':sLoadId, :nCustNo, :sRegionId'
							                                                                                                                              Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							                                                                                                                              Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							                                                                                                                              Set nIndex = 0
							                                                                                                                              While saLoadIds[nIndex] != ''
								                                                                                                                              Set sLoadId = saLoadIds[nIndex]
								                                                                                                                              If haSqlHandles[ nSqlHandleNo ].Execute( )
									                                                                                                                              While haSqlHandles[nSqlHandleNo].FetchNext ( nInd )
										                                                                                                                              Set nRow = nRow + 1
										                                                                                                                              Call SalSendMsg( hWndMeter, PAM_SETPROGRESS, 0, nRow )
										                                                                                                                              If NOT LoadIdRegionIdExists( sLoadId, sRegionId, nExecute )
											                                                                                                                              If AddCustRegionToLoad( sLoadId, sRegionId, nExecute )
												                                                                                                                              Call AddCustRegionToLoad( '', '', nCommit )
											                                                                                                                              Else 
												                                                                                                                              Call AddCustRegionToLoad( '', '', nRollback )
								                                                                                                                              Set nIndex = nIndex + 1
							!
						                                                                                                                              Case nDisconnect
							                                                                                                                              If NOT AddCustRegionToLoad( '', '', nDisconnect )
								                                                                                                                              Set bOk = FALSE
							                                                                                                                              If NOT AddCustRegionToLoad( '', '', nDisconnect )
								                                                                                                                              Set bOk = FALSE
							                                                                                                                              Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			! Function: UpdateCustRegionsOnLoads
				                                                                                                                              Description: 
				                                                                                                                              Returns 
					                                                                                                                              Boolean: 
				                                                                                                                              Parameters 
					                                                                                                                              Number: nActionType
				                                                                                                                              Static Variables 
					                                                                                                                              Sql Handle: hSqlHandle
					                                                                                                                              Boolean: bHandleConnected
					                                                                                                                              Boolean: bHandlePrepared
				                                                                                                                              Local variables 
					                                                                                                                              Boolean: bOk
					                                                                                                                              String: sSql
					                                                                                                                              Number: nInd
					!
					                                                                                                                              String: sLoadId
					                                                                                                                              Number: nCustNo
					                                                                                                                              String: sRegionId
					!
					                                                                                                                              Number: nTotalRows
					                                                                                                                              Number: nRow
					                                                                                                                              Window Handle: hWndMeter
				                                                                                                                              Actions 
					                                                                                                                              Select Case nActionType
						                                                                                                                              Case nExecute
							                                                                                                                              If NOT bHandleConnected
								                                                                                                                              Set bHandleConnected = SqlConnect( hSqlHandle ) 
								                                                                                                                              If bHandleConnected
									                                                                                                                              Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
									                                                                                                                              Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
								                                                                                                                              Else 
									                                                                                                                              Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									                                                                                                                              Return FALSE
							                                                                                                                              If NOT bHandlePrepared
								                                                                                                                              Set sSql = ' SELECT 
										    Load_Customers.Load_Id, 
										    Load_Customers.Cust_No, 
										    Customer_Master.Region_Id 
										  FROM 
										    Load_Customers, 
										    Customer_Master 
										  INTO 
										    :sLoadId, 
										    :nCustNo, 
										    :sRegionId 
										  WHERE Load_Customers.Cust_No = Customer_Master.Cust_No '
								                                                                                                                              If SqlPrepare( hSqlHandle, sSql )
									                                                                                                                              Set bHandlePrepared = TRUE
								                                                                                                                              Else 
									                                                                                                                              Set bHandlePrepared = FALSE
							!
							                                                                                                                              Set sLoadId = ''
							                                                                                                                              Set nCustNo = NUMBER_Null
							                                                                                                                              Set sRegionId = ''
							!
							                                                                                                                              If SqlExecute( hSqlHandle )
								                                                                                                                              Call SqlGetResultSetCount( hSqlHandle, nTotalRows )
								                                                                                                                              Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Updating Customers Regions On Loads', nTotalRows )
								                                                                                                                              Set nRow = 0
								                                                                                                                              While SqlFetchNext( hSqlHandle, nInd )
									                                                                                                                              Set nRow = nRow + 1
									                                                                                                                              Call SalSendMsg( hWndMeter, PAM_SETPROGRESS, 0, nRow )
									                                                                                                                              If NOT LoadIdRegionIdExists( sLoadId, sRegionId, nExecute )
										                                                                                                                              If AddCustRegionToLoad( sLoadId, sRegionId, nExecute )
											                                                                                                                              Call AddCustRegionToLoad( '', '', nCommit )
										                                                                                                                              Else 
											                                                                                                                              Call AddCustRegionToLoad( '', '', nRollback )
								                                                                                                                              Call SalSendMsg( hWndMeter, PAM_END, 0, 0 )
								                                                                                                                              Return TRUE
							                                                                                                                              Else 
								                                                                                                                              Set bHandlePrepared = FALSE
								                                                                                                                              Call SalMessageBox( 'SqlExecute had a error in UpdateCustRegionsOnLoads!, Contact programmers please!', 'ERROR', MB_Ok )
								                                                                                                                              Return FALSE
						                                                                                                                              Case nDisconnect
							                                                                                                                              Set bOk = FALSE
							                                                                                                                              Set bHandlePrepared = FALSE
							                                                                                                                              If bHandleConnected
								                                                                                                                              Set bHandleConnected = FALSE
								                                                                                                                              Set bOk = SqlDisconnect( hSqlHandle )
							                                                                                                                              If NOT AddCustRegionToLoad( '', '', nDisconnect )
								                                                                                                                              Set bOk = FALSE
							                                                                                                                              If NOT AddCustRegionToLoad( '', '', nDisconnect )
								                                                                                                                              Set bOk = FALSE
							                                                                                                                              Return bOk
						                                                                                                                              Case nRePrepare
							                                                                                                                              Set bHandlePrepared = FALSE
							                                                                                                                              Call AddCustRegionToLoad( '', '', nRePrepare )
							                                                                                                                              Call AddCustRegionToLoad( '', '', nRePrepare )
							                                                                                                                              Return TRUE
			!
			Function: UpdateLoadInvoicedFlag
				Description: Update Load table load_invoiced_flag
						This function does its own commit and rollbacks
				Returns
					Boolean:
				Parameters
					String: sLoadId
					String: sLoadInvFlag
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nSqlHandleNo
					!
					Number: nInd
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'UPDTLOADINVFLAG' )
					Select Case nActionType
						Case nExecute
							Set sSql = " UPDATE Load 
									SET Load_Invoiced_Flag = :2 
									WHERE Load_Id = :1 "
							Set sName = 'UPDTLOADINVFLAG'
							Set sBind = ':sLoadId, :sLoadInvFlag'
							Set sInto = ''
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								Call UpdateLoadInvoicedFlag( '', '', nCommit )
								Return TRUE
							Else
								Return FALSE
						Case nCommit
							Return haSqlHandles[ nSqlHandleNo ].Commit( )
						Case nRollback
							Return haSqlHandles[ nSqlHandleNo ].Rollback( )
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			!
			Function: MaintainLoadsOrders
				Description: User sType as either 'REFRESH' OR 'REDO'
						ALL ARRAYS MUST BE NULL TERMINATED
				Returns
				Parameters
					String: saLoadIds[*]
					Date/Time: dtaLoadsShipDates[*]
					Number: nYear
					String: sType
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					Boolean: bRefresh
					Number: nPos
					!
					Number: nRowCountLoads
					Number: nSqlHandleNo
					Window Handle: hWndMeterLoads
					Number: nRowCountCusts
					Window Handle: hWndMeterCusts
					!
					String: sSql
					String: sBind
					String: sInto
					String: sName
					!
					String: sLoadId
					Number: nCustNo
					String: sOrdType
					Number: nOrdType
					!
					Number: nInd
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'MTNLDCUST' )
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  Cust_No, 
									  Load_Order_Type 
									FROM
									  Load_Customers 
									WHERE 
									  Load_Id = :1 "
							Set sName = 'MTNLDCUST'
							Set sBind = ':sLoadId'
							Set sInto = ':nCustNo, :sOrdType'
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							Set nPos = 0
							While saLoadIds[ nPos ] != ''
								Set nPos = nPos + 1
							!
							Set hWndMeterLoads = hWndNULL
							Set hWndMeterCusts = hWndNULL
							!
							If nPos > 0
								If sType = 'REDO'
									Set hWndMeterLoads = SalCreateWindow( dlgMeterProgress, hWndForm, 'Redoing Loads', nPos )
								Else
									Set hWndMeterLoads = SalCreateWindow( dlgMeterProgress, hWndForm, 'Refreshing Loads', nPos )
								Set nRowCountLoads = 0
								!
								Set nPos = 0
								While saLoadIds[ nPos ] != ''
									Set sLoadId = saLoadIds[ nPos ]
									Set nCustNo = NUMBER_Null
									Set sOrdType = ''
									Set nOrdType = NUMBER_Null
									!
									If haSqlHandles[ nSqlHandleNo ].Execute( )
										Call haSqlHandles[ nSqlHandleNo ].ResultSetCount( nRowCountCusts )
										!
										If hWndMeterCusts = hWndNULL
											If sType = 'REDO'
												Set hWndMeterCusts = SalCreateWindow( dlgMeterProgress, hWndForm, 'Redoing Customers On Load', nRowCountCusts )
											Else
												Set hWndMeterCusts = SalCreateWindow( dlgMeterProgress, hWndForm, 'Refreshing Customers On Load', nRowCountCusts )
											Call SalMoveWindow( hWndMeterCusts, 0.239, 0.385 )
										Else
											If sType = 'REDO'
												Call PushString( 'Redoing Customers On Load' )
											Else
												Call PushString( 'Refreshing Customers On Load' )
											Call SalSendMsg( hWndMeterCusts, PAM_RESET, 0, nRowCountCusts )
										!
										Set nRowCountCusts = 0
										While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
											If sOrdType = 'A' OR sOrdType = 'E'
												Set nOrdType = nAllOrders
												Set bRefresh = TRUE
											Else If sOrdType = 'F'
												Set nOrdType = nFruitOrders
												Set bRefresh = TRUE
											Else If sOrdType = 'O'
												Set nOrdType = nOrnamOrders
												Set bRefresh = TRUE
											Else If sOrdType = 'ANC'
												Set nOrdType = nAllOrders | nWithOutContainers
												Set bRefresh = TRUE
											Else If sOrdType = 'FNC'
												Set nOrdType = nFruitOrders | nWithOutContainers
												Set bRefresh = TRUE
											Else If sOrdType = 'ONC'
												Set nOrdType = nOrnamOrders | nWithOutContainers
												Set bRefresh = TRUE
											Else If sOrdType = 'C'
												Set nOrdType = nContainerOrders
												Set bRefresh = TRUE
											Else
												Set bRefresh = FALSE
											!
											If bRefresh
												If sType = 'REDO'
													Call RemoveCustOrdersFromLoad( saLoadIds[ nPos ], nCustNo, nYear, nExecute )
												If NewAddCustOrdTypeToLoad( saLoadIds[ nPos ], nYear, nCustNo, nOrdType, DATETIME_Null, dtaLoadsShipDates[ nPos ], nExecute )
													Call NewAddCustOrdTypeToLoad( '', 0, 0, 0, DATETIME_Null, DATETIME_Null, nCommit )
											!
											Set nRowCountCusts = nRowCountCusts + 1
											Call SalSendMsg( hWndMeterCusts, PAM_SETPROGRESS, 0, nRowCountCusts )
									!
									Set nRowCountLoads = nRowCountLoads + 1
									Call SalSendMsg( hWndMeterLoads, PAM_SETPROGRESS, 0, nRowCountLoads )
									!
									Set nPos = nPos + 1
								!
								Call SalSendMsg( hWndMeterLoads, PAM_END, 0, 0 )
								Call SalSendMsg( hWndMeterCusts, PAM_END, 0, 0 )
								Return TRUE
							Else
								Return TRUE
						Case nDisconnect
							Call RemoveCustOrdersFromLoad( '', 0, 0, nDisconnect )
							Call NewAddCustOrdTypeToLoad( '', 0, 0, 0, DATETIME_Null, DATETIME_Null, nDisconnect )
							Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
							Return TRUE
			Function: MaintainCustOrders
				Description: User sType as either 'REFRESH' OR 'REDO'
						Assumption : naCustNos[*] and saOrdTypes[*] should match array positioning
						ALL ARRAYS MUST BE NULL TERMINATED
				Returns
				Parameters
					Number: naCustNos[*]
					String: saOrdTypes[*]
					String: sLoadId
					Date/Time: dtShipDate
					Number: nYear
					String: sType
					Number: nActionType
				Static Variables
				Local variables
					Boolean: bRefresh
					Number: nPos
					!
					Number: nRowCount
					Window Handle: hWndMeter
					!
					Number: nOrdType
				Actions
					Select Case nActionType
						Case nExecute
							Set nPos = 0
							While naCustNos[ nPos ] != NUMBER_Null
								Set nPos = nPos + 1
							!
							Set hWndMeter = hWndNULL
							!
							If nPos > 0
								If sType = 'REDO'
									Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Redoing Customers Orders', nPos )
								Else
									Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Refreshing Customers Orders', nPos )
								Set nRowCount = 0
								!
								Set nPos = 0
								While naCustNos[ nPos ] != NUMBER_Null
									Set nOrdType = NUMBER_Null
									!
									If saOrdTypes[ nPos ] = 'A' OR saOrdTypes[ nPos ] = 'E'
										Set nOrdType = nAllOrders
										Set bRefresh = TRUE
									Else If saOrdTypes[ nPos ] = 'F'
										Set nOrdType = nFruitOrders
										Set bRefresh = TRUE
									Else If saOrdTypes[ nPos ] = 'O'
										Set nOrdType = nOrnamOrders
										Set bRefresh = TRUE
									Else If saOrdTypes[ nPos ] = 'ANC'
										Set nOrdType = nAllOrders | nWithOutContainers
										Set bRefresh = TRUE
									Else If saOrdTypes[ nPos ] = 'FNC'
										Set nOrdType = nFruitOrders | nWithOutContainers
										Set bRefresh = TRUE
									Else If saOrdTypes[ nPos ] = 'ONC'
										Set nOrdType = nOrnamOrders | nWithOutContainers
										Set bRefresh = TRUE
									Else If saOrdTypes[ nPos ] = 'C'
										Set nOrdType = nContainerOrders
										Set bRefresh = TRUE
									Else
										Set bRefresh = FALSE
									!
									If bRefresh
										If sType = 'REDO'
											Call RemoveCustOrdersFromLoad( sLoadId, naCustNos[ nPos ], nYear, nExecute )
										If NewAddCustOrdTypeToLoad( sLoadId, nYear, naCustNos[ nPos ], nOrdType, DATETIME_Null, dtShipDate, nExecute )
											Call NewAddCustOrdTypeToLoad( '', 0, 0, 0, DATETIME_Null, DATETIME_Null, nCommit )
									!
									Set nRowCount = nRowCount + 1
									Call SalSendMsg( hWndMeter, PAM_SETPROGRESS, 0, nRowCount )
									!
									Set nPos = nPos + 1
								!
								Call SalSendMsg( hWndMeter, PAM_END, 0, 0 )
								Return TRUE
							Else
								Return TRUE
						! Case nCommit
							                                                                                                                              Return fcOurHandle.Commit( )
						! Case nRollback
							                                                                                                                              Return fcOurHandle.Rollback( )
						Case nDisconnect
							Call RemoveCustOrdersFromLoad( '', 0, 0, nDisconnect )
							Call NewAddCustOrdTypeToLoad( '', 0, 0, 0, DATETIME_Null, DATETIME_Null, nDisconnect )
							Return TRUE
			Function: RemoveCustOrdersFromLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nCustNo
					Number: nYear
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nSqlHandleNo
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'REMORDFRMLOAD' )
					Select Case nActionType
						Case nExecute
							Set sSql = " UPDATE Customer_Order Set Load_Id = NULL
									WHERE Cust_No = :1 AND Load_Id = :2 AND 
									Year_Of_Sale = :3 AND NOT Invoiced_Flag = 'Y' and NOT pull_sheet_issued = 'Y' "
							Set sName = 'REMORDFRMLOAD'
							Set sBind = ':nCustNo, :sLoadId, :nYear'
							Set sInto = ''
							!
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								Call haSqlHandles[ nSqlHandleNo ].Commit( )
								Return TRUE
							Else
								Return FALSE
						Case nCommit
							Return haSqlHandles[ nSqlHandleNo ].Commit( )
						Case nRollback
							Return haSqlHandles[ nSqlHandleNo ].Rollback( )
						Case nDisconnect
							Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
			!
			! The bellow block of functions is for putting orders onto a load
			Function: NewAddCustOrdTypeToLoad
				Description: Add Customers Orders To a Load depending on the order Type
						Use nOrderLoadType constants :- 
						    nSelectionOrder, 
						    nContainerOrders,
						    nAllOrders,
						    nFruitOrders,
						    nOrnamOrders,
						    nAllOrders | nWithOutContainers,
						    nFruitOrders | nWithOutContainers,
						    nOrnamOrders | nWithOutContainers
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nYear
					Number: nCustNo
					Number: nLoadOrderType
					Date/Time: dtOrderDateTime
					Date/Time: dtShipDate
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
					!
					Sql Handle: hSqlContHandle
					Boolean: bContHandleConnected
					Boolean: bContHandlePrepared
				Local variables
					Boolean: bOk
					!
					Number: nPos
					Date/Time: dtaOrdSysDTs[*]
				Actions
					Select Case nActionType
						Case nExecute
							If nLoadOrderType = nSelectionOrders
								If UpdateOrderToLoadId( sLoadId, nCustNo, dtShipDate, dtOrderDateTime, nExecute )
									Call UpdateOrderToLoadId( '', 0, DATETIME_Null, DATETIME_Null, nCommit )
									Return TRUE
								Else
									Call UpdateOrderToLoadId( '', 0, DATETIME_Null, DATETIME_Null, nRollback )
									Return FALSE
							Else
								If ExtractCustOrdToGoOnLoad( sLoadId, nYear, nCustNo, nLoadOrderType, dtaOrdSysDTs, dtShipDate, nExecute )
									Set bOk = TRUE
									Set nPos = 0
									While dtaOrdSysDTs[ nPos ] != DATETIME_Null
										!
										If UpdateOrderToLoadId( sLoadId, nCustNo, dtShipDate, dtaOrdSysDTs[ nPos ], nExecute )
											Call UpdateOrderToLoadId( '', 0, DATETIME_Null, DATETIME_Null, nCommit )
										Else
											Call UpdateOrderToLoadId( '', 0, DATETIME_Null, DATETIME_Null, nRollback )
											Set bOk = FALSE
										!
										Set nPos = nPos + 1
									Return bOk
								Else
									Return FALSE
						Case nDisconnect
							Set bOk = TRUE
							If NOT UpdateOrderToLoadId( '', 0, DATETIME_Null, DATETIME_Null, nDisconnect )
								Set bOk = FALSE
							If NOT ExtractCustOrdToGoOnLoad( '', 0, 0, 0, dtaOrdSysDTs, DATETIME_Null, nDisconnect )
								Set bOk = FALSE
							Return bOk
						Case nRePrepare
							Call UpdateOrderToLoadId( '', 0, DATETIME_Null, DATETIME_Null, nRePrepare )
							Call ExtractCustOrdToGoOnLoad( '', 0, 0, 0, dtaOrdSysDTs, DATETIME_Null, nRePrepare )
							Return TRUE
			Function: UpdateOrderToLoadId
				Description: Update Customer Order To a Load
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nCustNo
					Date/Time: dtShipDT
					Date/Time: dtOrderDateTime
					Number: nActionType
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					Boolean: bOk
					String: sSql
				Actions
					Select Case nActionType
						Case nExecute
							If NOT bHandleConnected
								Set bHandleConnected = SqlConnect( hSqlHandle ) 
								If bHandleConnected
									Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
									Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
								Else
									Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									Return FALSE
							If NOT bHandlePrepared
								Set sSql = 
										'UPDATE
											Customer_Order
										 SET
											Load_Id = :sLoadId 
										WHERE 
											Cust_No = :nCustNo AND 
											Order_Date_Time = :dtOrderDateTime and
											(hold_order_date <= :dtShipDT or
											hold_order_date IS NULL)'
								If SqlPrepare( hSqlHandle, sSql )
									Set bHandlePrepared = TRUE
								Else
									Set bHandlePrepared = FALSE
							If SqlExecute( hSqlHandle )
								Return TRUE
							Else
								Set bHandlePrepared = FALSE
								Call SalMessageBox( 'SqlExecute had a error in UpdateOrderToLoad, Contact programmers please!', 'ERROR', MB_Ok )
								Return FALSE
						Case nCommit
							Set bOk = TRUE
							If bHandleConnected
								Set bOk = SqlCommit( hSqlHandle )
							Return bOk
						Case nRollback
							Set bOk = TRUE
							If bHandleConnected
								Set bOk = SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
								Set bHandlePrepared = FALSE
							Return bOk
						Case nDisconnect
							Set bOk = FALSE
							Set bHandlePrepared = FALSE
							If bHandleConnected
								Set bHandleConnected = FALSE
								Set bOk = SqlDisconnect( hSqlHandle )
							Return bOk
						Case nRePrepare
							Set bHandlePrepared = FALSE
							Return TRUE
			!

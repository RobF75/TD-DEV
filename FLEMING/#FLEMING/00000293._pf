				!
				! String: REGLOAD = ' REGION_LOAD, LOAD, TRANSPORT_METHOD'
				! String: LOADCUSTCUSTTYPE = ' LOAD_CUSTOMERS, CUSTOMER_MASTER,
						 CUSTOMER_TYPE'
				! String: CUSTPOSPOS = ' CUST_PROMO, PROMO'
				! String: ORDSI = ' CUSTOMER_ORDER, STOCK_ITEM'
				! String: WHORDPRINTINV = ' WHERE CUSTOMER_ORDER.CUST_NO = 
						:frmRegLoad.tblCust.colCustno  AND CUSTOMER_ORDER.LOAD_ID = :frmRegLoad.tblRegLoad.colLoadId 
						AND CUSTOMER_ORDER.PULL_SHEET_ISSUED = \'Y\' 
						AND CUSTOMER_ORDER.INVOICED_FLAG !=\'Y\' AND
						CUSTOMER_ORDER.SALE_CAT != \'CS\' 
						AND CUSTOMER_ORDER.YEAR_OF_SALE = :frmRegLoad.dfYr AND
						STOCK_ITEM.ITEM_NO = CUSTOMER_ORDER.STOCK_ITEM_NO ORDER BY 1,2'
				! String: WHORDPOSPRINTINV = ' WHERE CUST_PROMO.CUST_NO = 
						:frmRegLoad.tblCust.colCustno AND CUST_PROMO.PROMO_SENT_FLAG != \'Y\' 
						 AND CUST_PROMO.YEAR_OF_ORDER = :frmRegLoad.dfYr AND
						PROMO.PROMO_ID = CUST_PROMO.PROMO_ID'
				! String: WHCUSTREGLOAD = ' WHERE LOAD_CUSTOMERS.LOAD_ID = 
						 :frmRegLoad.tblRegLoad.colLoadId AND CUSTOMER_MASTER.CUST_NO =
						 LOAD_CUSTOMERS.CUST_NO AND CUSTOMER_TYPE.CUST_TYPE = 
						CUSTOMER_MASTER.CUSTOMER_TYPE
						  ORDER BY LOAD_CUSTOMERS.SEQUENCE_NO'
				! String: WHEREREG = ' WHERE REGION_LOAD.REGION_ID = :frmRegLoad.dfReg AND
						 LOAD.LOAD_ID = REGION_LOAD.LOAD_ID AND
						 TRANSPORT_METHOD.TRANSPORT_ID = LOAD.TRANSPORT_ID ORDER BY 
						 LOAD.SHIPPING_DATE'
				!

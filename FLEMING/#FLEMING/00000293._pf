				Functions
					Function: RegionIdExists
						Description:
						Returns
							Boolean:
						Parameters
							String: sRegionId
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Region_Id FROM Region WHERE Region_Id = :sRegionId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								If SqlExecute( hSqlHandle )
									If SqlFetchNext( hSqlHandle, nInd )
										Return TRUE
									Else
										Return FALSE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in LoadIdExists, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
					Function: FreightCodeIdExists
						Description:
						Returns
							Boolean:
						Parameters
							String: sFreightCodeId
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Freight_Code FROM Freight_Codes WHERE Freight_Code = :sFreightCodeId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								If SqlExecute( hSqlHandle )
									If SqlFetchNext( hSqlHandle, nInd )
										Return TRUE
									Else
										Return FALSE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in LoadIdExists, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
				Window Variables
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' REGION '
						Set sSQLPOPTABLENAME = ' REGION, FREIGHT_CODES '
						Set sSQLWHERE = ' WHERE Region.Freight_Code = Freight_Codes.Freight_Code(+)'
						Set sORDERBY = ' ORDER BY Region.Region_Id '
						Set sROWID = ' REGION.ROWID '
						Set sTableHeading = 'Regions'
						Set hWndRowNewColumn = colRegionId
						Set nTableFillType = TBL_FillAll
					On SAM_Destroy
						Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
						Call RegionIdExists( '', nDisconnect )
						Call FreightCodeIdExists( '', nDisconnect )

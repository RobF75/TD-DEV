				                                                                                                                              Message Actions 
					                                                                                                                              On SAM_Click
						                                                                                                                              If NOT SalTblAnyRows( tblRegions, ROW_Selected, 0 )
							                                                                                                                              Call SalMessageBox( 'Please select a region first', 'Region', MB_Ok )
							                                                                                                                              Return FALSE
						                                                                                                                              Call SalWaitCursor( TRUE )
						                                                                                                                              Set ngRow = TBL_MinRow
						                                                                                                                              Call SalTblFindNextRow( tblRegions, ngRow, ROW_Selected, 0 )
						                                                                                                                              Call SalTblFetchRow( tblRegions, ngRow )
						                                                                                                                              Call PushString( tblRegions.colRegionId )
						                                                                                                                              Call PushString( tblRegions.colRegDesc )
						                                                                                                                              Call PushString( 'SHOW' )
						                                                                                                                              Call PushWndHdl (hWndItem)
						                                                                                                                              Call SalDisableWindow ( hWndItem ) 
						                                                                                                                              Set hWndRegLoad = SalCreateWindow( frmRegLoad, hWndForm )
					                                                                                                                              On PAM_ENABLE
						                                                                                                                              Call SalEnableWindow( hWndItem )
						                                                                                                                              Call SalSendMsg( tblRegions, PAM_POPULATE, 0, 0 )
					                                                                                                                              On PAM_QUERYDISABLE
						                                                                                                                              If wParam
							                                                                                                                              Call SalDisableWindow( hWndItem )
						                                                                                                                              Else 
							                                                                                                                              Call SalEnableWindow( hWndItem )

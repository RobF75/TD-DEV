			Pushbutton: pbMove
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: &MOVE - Enter
				Window Location and Size
					Left:   0.088"
					Top:    1.469"
					Width:  Class Default
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Enter
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalIsNull( dfLoadIdTo )
							Call SalMessageBox( 'Please enter a TO Load Id first! ', 'Warning', MB_Ok )
						Else
							If ExistsLoad( dfLoadIdTo, bExists, nExecute )
								If NOT bExists
									Call SalMessageBox( 'The TO Load Id is invalid! Please pick a valid one! ', 'Warning', MB_Ok )
								If MoveCustOrdLinesLoadToLoad( dfLoadIdFrom, dfLoadIdTo, nCustNo, dtaOrdDTs, nExecute )
									Call SalSendMsg( pbCancel, SAM_Click, 0, TRUE )
								Else
									Call SalSendMsg( pbCancel, SAM_Click, 0, FALSE )
							Else
								Call SalMessageBox( 'Nothing has been moved! Please try again!', 'Warning', MB_Ok )
			Pushbutton: pbLoads

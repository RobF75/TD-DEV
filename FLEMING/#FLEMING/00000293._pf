				Functions
					Function: CalcTreesGiven
						Description:
						Returns
							Boolean:
						Parameters
							Number: nCustNo
							Number: nYear
							Receive Number: nTotalTrees
							Number: nActionType
						Static Variables
						Local variables
							String: sSql
							String: sBind
							String: sInto
							String: sName
							!
							Number: nSqlHandleNo
							Number: nGotTotalTrees
							!
							Number: nInd
						Actions
							Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CalcTreesGiven' )
							Select Case nActionType
								Case nExecute
									Set sSql = " SELECT 
											  Sum( Conf_Amt ) 
											FROM 
											  Customer_Order 
											WHERE 
											  Cust_No = :1 AND 
											  Year_Of_Sale = :2 AND 
											  Load_Id IS NULL AND 
											  ( NOT Invoiced_Flag = 'Y' OR 
											    Invoiced_Flag IS NULL ) AND 
											  ( NOT Pull_Sheet_Issued = 'Y' OR 
											    Pull_Sheet_Issued IS NULL ) "
									Set sName = 'CSTTOUTNOLD'
									! Set sSql = " SELECT 
											  Sum( Conf_Amt ) 
											FROM 
											  Customer_Order 
											WHERE 
											  Cust_No = :1 AND 
											  Year_Of_Sale = :2 "
									! Set sName = 'SUMCONFAMT'
									Set sBind = ':nCustNo, :nYear'
									Set sInto = ':nGotTotalTrees'
									!
									Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
									Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
									!
									Set nTotalTrees = NUMBER_Null
									Set nGotTotalTrees = NUMBER_Null
									!
									If haSqlHandles[ nSqlHandleNo ].Execute( )
										Call haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
										!
										Set nTotalTrees = nGotTotalTrees
										Return TRUE
									Else
										Return FALSE
								Case nDisconnect
									Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
				Window Variables
					Number: nOrderType
					Boolean: bOk
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' CUSTOMER_MASTER '
						Set sSQLPOPTABLENAME = ' CUSTOMER_MASTER, CUSTOMER_ORDER, STOCK_ITEM '
						Set sSQLWHERE = " WHERE 
								  Customer_Master.Cust_No = Customer_Order.Cust_No AND
								  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
								  Customer_Order.Year_Of_Sale = :dlgQCustomer.dfYear AND
								  Customer_Order.Conf_Amt > 0 AND  
								  Customer_Order.Load_Id IS NULL AND
								  NOT Customer_Order.Invoiced_Flag = 'Y' "
						! Set sSQLWHERE = " WHERE 
								  Customer_Master.Cust_No = Customer_Order.Cust_No AND
								  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
								  Customer_Order.Year_Of_Sale = :dlgQCustomer.dfYear AND
								  Customer_Order.Conf_Amt > 0 AND  
								  Customer_Order.Load_Id IS NULL AND
								  Stock_Item.Stock_Type = 'C' AND
								  NOT Customer_Order.Invoiced_Flag = 'Y' "
						! Set sORDERBY = ' ORDER BY CUSTOMER_MASTER.CUST_NO '
						Set sORDERBY = ' GROUP BY CUSTOMER_MASTER.REGION_ID, 
								CUSTOMER_MASTER.CUST_NAME, CUSTOMER_MASTER.CUST_NO '
						Set sROWID = ' CUSTOMER_MASTER.ROWID '
						Set sTableHeading = 'Pick Customer'
						Set sQueryDialogName = 'dlgQueryTblCustomer'
						Set nSelectType = nSELDISTINCT
					! On PAM_CALCTREES
						                                                                                                                              Call SalSendMsgToChildren( hWndForm, PAM_CALCTREES, wParam, 0 )
						                                                                                                                              If wParam
							                                                                                                                              Call SalSendMsg( hWndForm, PAM_REPOPULATE, 0, 0 )
					On PAM_POPFIELDS
						Call PopNumber( nOrderType, TRUE )
						Return TRUE
					On SAM_RowHeaderClick
						If SalTblQueryRowFlags( hWndForm, lParam, ROW_Selected )
							Call SalPostMsg( dlgQCustomer.pbOutstandOrders, SAM_Click, 0, 0 )
					!
					On SAM_FetchRowDone
						If dlgQCustomer.cbCalcTrees
							Call SalSendMsg( hWndForm, PAM_CALCTREES, 0, lParam )
						! If dlgQCustomer.cbCalcUnits
							                                                                                                                              Call SalSendMsg( hWndForm, PAM_CALCUNITS, 0, lParam )
					! On PAM_CALCSELECTEDTREES
						                                                                                                                              If dlgQCustomer.cbCalcTrees
							                                                                                                                              Call MyTableLoop( hWndForm, hWndForm, PAM_CALCTREES, ROW_Selected, 0, 'Calculating Trees', nLowToHi )
					On PAM_CALCTREES
						Set bOk = TRUE
						If NOT CalcTreesGiven( colCustNo, frmLoads.cSeasonYear.GetSeasonYear( ), colTrees, nExecute )
							Set bOk = FALSE
						If NOT GetCustTotalUnitsOutstand( colCustNo, frmLoads.cSeasonYear.GetSeasonYear( ), colUnits, nExecute )
							Set bOk = FALSE
						Return bOk
					! On PAM_CALCUNITS
						                                                                                                                              Return GetCustTotalUnitsOutstand( colCustNo, frmLoads.cSeasonYear.GetSeasonYear( ), colUnits, nExecute )
					!
					On SAM_Destroy
						Call CalcTreesGiven( 0, 0, tblCustomer.colTrees, nDisconnect )
						Call GetCustTotalUnitsOutstand( 0, 0, colUnits, nDisconnect )
						Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

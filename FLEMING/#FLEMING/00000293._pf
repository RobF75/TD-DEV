									Call ErrorMessage( 'This Transport Id does not exists in the Transport table! Please rectify!', hWndForm, lParam )
									Return FALSE
							On PAM_LOOKUP
								Call PopString( colTransportId, TRUE )
								Call SalSetFieldEdit( hWndItem, TRUE )

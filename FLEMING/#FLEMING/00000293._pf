							On PAM_DATAVAL
								If SalIsNull( hWndItem )
									Set colInvoicedFlag = 'N'
								If colInvoicedFlag = 'Y' OR colInvoicedFlag = 'N'
									Return TRUE
								Else
									Call ErrorMessage( 'Please use only Y or N for the Inv. column!', hWndForm, lParam )
									Return FALSE
							On PAM_CHECKROWDELETED
								If colInvoicedFlag = 'Y'
									Call ErrorMessage( 'Cannot delete this load, because it is invoiced!', hWndForm, lParam )
									Return FALSE
								Else
									Return TRUE
					Column: colLoadDriver

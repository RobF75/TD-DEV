				Functions
					Function: GetLoadCustInvFlag
						Description:
						Returns
							Boolean:
						Parameters
							String: sLoadId
							Number: nCustNo
							Receive String: sInvFlag
							Number: nActionType
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							String: sFuncName
							String: sGotInvFlag
							Number: nInd
						Actions
							Set sFuncName = 'GetLoadCustInvFlag'
							Select Case nActionType
								Case nExecute
									Loop Execute
										Loop Connect
											If bHandleConnected
												Break Connect
											Else
												Set bHandleConnected = SqlConnect( hSqlHandle ) 
												If bHandleConnected
													Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
													Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
													Break Connect
												Else
													If IDNO = SalMessageBox( 'Could not connect handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
														Break Connect
										Loop Prepare
											If bHandlePrepared
												Break Prepare
											Else
												Set sSql = 'SELECT Cust_Inv_Flag 
														FROM Load_Customers 
														INTO :sGotInvFlag 
														WHERE Load_Id = :sLoadId AND Cust_No = :nCustNo '
												If SqlPrepare( hSqlHandle, sSql )
													Set bHandlePrepared = TRUE
													Break Prepare
												Else
													Set bHandlePrepared = FALSE
													If IDNO = SalMessageBox( 'Could not prepare handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
														Break Prepare
										!
										Set sInvFlag = ''
										Set sGotInvFlag = ''
										!
										If SqlExecute( hSqlHandle )
											Call SqlFetchNext( hSqlHandle, nInd )
											Set sInvFlag = sGotInvFlag
											Return TRUE
										Else
											Set bHandlePrepared = FALSE
											If IDNO = SalMessageBox( 'Could not execute handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												Return FALSE
								Case nCommit
									Loop Commit
										If bHandleConnected
											If SqlCommit( hSqlHandle )
												Return TRUE
											Else
												If IDNO = SalMessageBox( 'Could not commit handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													Return FALSE
										Else
											Return TRUE
								Case nRollback
									Loop Rollback
										If bHandleConnected
											Set bHandlePrepared = FALSE
											If SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
												Return TRUE
											Else
												If IDNO = SalMessageBox( 'Could not rollback handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													Return FALSE
										Else
											Return TRUE
								Case nDisconnect
									Loop Disconnect
										If bHandleConnected
											If SqlDisconnect( hSqlHandle )
												Set bHandleConnected = FALSE
												Set bHandlePrepared = FALSE
												Return TRUE
											Else
												If IDNO = SalMessageBox( 'Could not disconnect handle in function '||sFuncName||'Contact programmers! RETRY?', 'Error', MB_YesNo )
													Return FALSE
										Else
											Return TRUE
								Case nRePrepare
									Set bHandlePrepared = FALSE
									Return TRUE
					!
					! Function: CopyTblRowFromTo
						                                                                                                                              Description: 
						                                                                                                                              Returns 
							                                                                                                                              Boolean: 
						                                                                                                                              Parameters 
							                                                                                                                              Window Handle: hWndTable
							                                                                                                                              Number: nFromRow
							                                                                                                                              Number: nToRow
							                                                                                                                              Boolean: bCopyRowFlags
							                                                                                                                              Number: nFlagsToCopy
							                                                                                                                              Boolean: bCopyRowColumns
						                                                                                                                              Static Variables 
						                                                                                                                              Local variables 
						                                                                                                                              Actions 
							                                                                                                                              If bCopyRowFlags
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_Edited )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_Edited )
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_Hidden )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_Hidden )
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_HideMarks )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_HideMarks )
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_MarkDeleted )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_MarkDeleted )
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_New )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_New )
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_Selected )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_Selected )
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_UnusedFlag1 )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_UnusedFlag1 )
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_UnusedFlag2 )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_UnusedFlag2 )
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_UserFlag1 )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_UserFlag1 )
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_UserFlag2 )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_UserFlag2 )
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_UserFlag3 )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_UserFlag3 )
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_UserFlag4 )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_UserFlag4 )
								                                                                                                                              If IsFlagSet( nFlagsToCopy, ROW_UserFlag5 )
									                                                                                                                              Call CopyRowFlagsFromTo( hWndTable, nFromRow, nToRow, ROW_UserFlag5 )
							                                                                                                                              If bCopyRowColumns
								                                                                                                                              Call CopyRowColumnsFromTo( hWndTable, nFromRow, nToRow )
					! Function: CopyRowColumnsFromTo
						                                                                                                                              Description: 
						                                                                                                                              Returns 
							                                                                                                                              Boolean: 
						                                                                                                                              Parameters 
							                                                                                                                              Window Handle: hWndTable
							                                                                                                                              Number: nFromRow
							                                                                                                                              Number: nToRow
						                                                                                                                              Static Variables 
						                                                                                                                              Local variables 
							                                                                                                                              Window Handle: hWndChild
							                                                                                                                              String: sGotText
							                                                                                                                              Boolean: bRowFlag
						                                                                                                                              Actions 
							                                                                                                                              Set hWndChild = SalGetFirstChild( hWndTable, TYPE_TableColumn )
							                                                                                                                              While hWndChild != hWndNULL
								                                                                                                                              Call SalTblFetchRow( hWndTable, nFromRow )
								                                                                                                                              Call SalFmtFieldToStr( hWndChild, sGotText, TRUE )
								!
								                                                                                                                              Call SalTblFetchRow( hWndTable, nToRow )
								                                                                                                                              Call SalFmtStrToField( hWndChild, sGotText, TRUE )
								!
								                                                                                                                              Set hWndChild = SalGetNextChild( hWndChild, TYPE_TableColumn )
					! Function: CopyRowFlagsFromTo
						                                                                                                                              Description: 
						                                                                                                                              Returns 
						                                                                                                                              Parameters 
							                                                                                                                              Window Handle: hWndTable
							                                                                                                                              Number: nFromRow
							                                                                                                                              Number: nToRow
							                                                                                                                              Number: nROWFlag
						                                                                                                                              Static Variables 
						                                                                                                                              Local variables 
							                                                                                                                              Boolean: bRowFlag
						                                                                                                                              Actions 
							                                                                                                                              Call SalTblFetchRow( hWndTable, nFromRow )
							                                                                                                                              Set bRowFlag = SalTblQueryRowFlags( hWndTable, nFromRow, nROWFlag )
							                                                                                                                              Call SalTblFetchRow( hWndTable, nToRow )
							                                                                                                                              Call SalTblSetRowFlags( hWndTable, nToRow, nROWFlag, bRowFlag )
				Window Variables
					String: sCancelReason
					String: sCancelOrderBookNo
					String: sLoadCustInvFlag
					Number: nRow
					Number: nTemp
					Date/Time: dtTemp
					String: sTmp
					Number: nNewRow
					Number: nStrLength
					Boolean: bOk
					Boolean: bNewAllocated
					Number: naBatchLocationIds[*]
					Number: naBatchLocAllocated[*]
					! Boolean: bUpdateLoadCustPullFlag
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' CUSTOMER_ORDER '
						Set sSQLPOPTABLENAME = ' CUSTOMER_ORDER, STOCK_ITEM'
						Set sSQLWHERE = ' WHERE CUSTOMER_ORDER.CUST_NO =
								 :frmNewCustOrdOnLoad.dfCustNo AND 
								CUSTOMER_ORDER.LOAD_ID = :frmNewCustOrdOnLoad.dfLoadId
								 AND CUSTOMER_ORDER.YEAR_OF_SALE = :frmNewCustOrdOnLoad.dfYear AND
								 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO '
						!
						Set sORDERBY = ' ORDER BY 2,3,4,5,9 '
						Set sROWID = ' CUSTOMER_ORDER.ROWID '
						Set sTableHeading = 'Customer Order On This Load'
						Set hWndRowNewColumn = colOrderDate
						Call SqlSetParameter( hLocalSqlPopTbl, DBP_FETCHTHROUGH, TRUE, '' )
						Set nTableFillType = TBL_FillAll
					On PAM_ADDROW
						Call GetLoadCustInvFlag( frmNewCustOrdOnLoad.dfLoadId, frmNewCustOrdOnLoad.dfCustNo, sLoadCustInvFlag, nExecute )
						If sLoadCustInvFlag = 'Y'
							Call SalMessageBox( 'Cannot ADD order as this customer has been invoiced! ', 'Warning', MB_Ok )
						Else
							Call SalSendClassMessage( PAM_ADDROW, wParam, lParam )
							Set colOrderDate = SalDateCurrent(  )
							Set colSaleCat = 'NM'
							Set colPulled = 'N'
							Set colInvoiced = 'N'
							Set colNPASentFlag= 'N'
							Set colNPARecdFlag = 'N'
							Set colSubsOkFlag = 'Y'
							Set colAllocFlag = 'N'
							Set colOrdAmt = 0
							Set colCustNo = frmNewCustOrdOnLoad.dfCustNo
							Set colLoadId = frmNewCustOrdOnLoad.dfLoadId
							Set colYear = frmNewCustOrdOnLoad.dfYear
					On PAM_WRITEINSERTSUPDATES
						If IDNO = SalMessageBox( 'Are you ready to insert/update/delete the modified rows?',
								sTableHeading, MB_YesNo|MB_IconExclamation )
							Return FALSE
						If MyTableDataVal( hWndForm )
							! Set bUpdateLoadCustPullFlag = FALSE
							Call MyTableLoop( hWndForm, hWndForm, PAM_ROWACTION, ROW_New | ROW_Edited | ROW_MarkDeleted, 0, 'Save Changes', nLowToHi )
							! If bUpdateLoadCustPullFlag
								                                                                                                                              If UpdateLoadCustPullFlag( frmNewCustOrdOnLoad.dfLoadId, frmNewCustOrdOnLoad.dfCustNo, 'N', nExecute )
									                                                                                                                              Set frmNewCustOrdOnLoad.bRepopParent = TRUE
							! Call SalSendMsg( hWndForm, PAM_REPOPULATE, 0, 0 )
					!
					On PAM_POPULATE
						Call SalSendMsgToChildren( hWndForm, PAM_SETFWDCOLUMNCOLOR, 0, COLOR_Default )
						Return SalSendClassMessage( PAM_POPULATE, wParam, lParam )
					On PAM_REPOPULATE
						Call SalSendMsgToChildren( hWndForm, PAM_SETFWDCOLUMNCOLOR, 0, COLOR_Default )
						Return SalSendClassMessage( PAM_REPOPULATE, wParam, lParam )
					On PAM_SEARCH
						Call SalSendMsgToChildren( hWndForm, PAM_SETFWDCOLUMNCOLOR, 0, COLOR_Default )
						Return SalSendClassMessage( PAM_SEARCH, wParam, lParam )
					On SAM_FetchRowDone
						If colFutureOrder = 'Y'
							Call SalSendMsg( hWndForm, PAM_GETFUTUREAVAILABLE, wParam, lParam )
					On PAM_GETFUTUREAVAILABLE
						Call GetEstAvailDate( colBatchLocationId, colBatchYearOfSale, colFutureOrderDate, nExecute )
						Set colSeason = GetSeason( colFutureOrderDate )
						Call SalSendMsgToChildren( hWndForm, PAM_SETFWDCOLUMNCOLOR, 0, GetSeasonColor( colSeason ) )
						If NOT SalIsNull( colFutureOrderDate )
							Set colSeason = colSeason || ' ' || SalNumberToStrX( SalDateYear( colFutureOrderDate ), 0 )
						Return TRUE
					On PAM_REMOVEFROMLOAD
						If colInvoiced = 'Y'
							Call SalMessageBox( 'Cannot remove this order, as it has been invoiced!', 'Warning', MB_Ok )
						Else
							Set colLoadId = ''
							Set colPulled = 'N'
							Set naBatchLocationIds[0] = colBatchLocationId
							Set naBatchLocationIds[1] = NUMBER_Null
							Set naBatchLocAllocated[0] = colConfAmt
							Set naBatchLocAllocated[1] = NUMBER_Null
							If NewSaveOrder( frmNewCustOrdOnLoad.dfCustNo, colOrderDateTime, colItemNo, colYear, colOrdAmt, colConfAmt, colAllocFlag, colSubsOkFlag, naBatchLocationIds, naBatchLocAllocated, colBatchYearOfSale, hWndForm, PAM_UPDATE, nExecute )
								Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
								Return nRowDeleted
						Return TRUE
					On PAM_ROWACTION
						Set bOk = TRUE
						Set bNewAllocated = FALSE
						If SalTblQueryRowFlags( hWndForm, lParam, ROW_New )
							If NOT colBatchLocationId > 0
								Call GetItemStockType( colItemNo, sTmp, nExecute )
								If sTmp = 'C'
									Call AllocatedPotsLocation( colItemNo, colYear, colOrdAmt, colConfAmt, naBatchLocationIds, naBatchLocAllocated, colBatchYearOfSale, nExecute )
									If NOT naBatchLocationIds[0] > 0
										Call SalMessageBox( 'Cannot allocate a batch! Either none exist or over sold.  Please verify the stock batches before posting this order.', 'Warning', MB_Ok )
										Set bOk = FALSE
								Else
									Set naBatchLocationIds[0] = NUMBER_Null
									Set naBatchLocAllocated[0] = NUMBER_Null
							Else
								! Call GetAvailableForBatchSeason( colBatchLocationId, colBatchYearOfSale, nTemp, nExecute )
								Call GetAvailableForBatchLocation( colBatchLocationId, colBatchYearOfSale, nTemp, nExecute )
								If SalIsNull( colConfAmt )
									If NOT ( nTemp - colOrdAmt ) >= 0
										Call SalMessageBox( 'Cannot allocate this batch! These lot of Batches are over sold.  Please verify the stock batches before posting this order.', 'Warning', MB_Ok )
										Return FALSE
									Set naBatchLocAllocated[0] = colOrdAmt
									Set naBatchLocAllocated[1] = NUMBER_Null
								Else
									If NOT ( nTemp - colConfAmt ) >= 0
										! Call SalMessageBox( 'Cannot allocate this batch! These lot of Batches are over sold.  Please verify the stock batches before posting this order.', 'Warning', MB_Ok )
										! Changing the mesage so user knows of change. Make thsi temporary.
										! Call SalMessageBox( 'Cannot allocate this batch! These lot of Batches are over sold.  Please verify the stock batches before posting this order.', 'Warning', MB_Ok )
										Call AllocatedPotsLocation( colItemNo, colYear, colOrdAmt, colConfAmt, naBatchLocationIds, naBatchLocAllocated, colBatchYearOfSale, nExecute )
										If NOT naBatchLocationIds[0] > 0
											Call SalMessageBox( 'Cannot allocate a batch! Either none exist or over sold.  Please verify the stock batches before posting this order.', 'Warning', MB_Ok )
											Set bOk = FALSE
										Else
											Set bNewAllocated = TRUE
										! Return FALSE
										! Set bOk = FALSE
									Set naBatchLocAllocated[0] = colConfAmt
									Set naBatchLocAllocated[1] = NUMBER_Null
								If Not bNewAllocated
									Set naBatchLocationIds[0] = colBatchLocationId
									Set naBatchLocationIds[1] = NUMBER_Null
							If bOk
								If NewAddOrder( frmNewCustOrdOnLoad.dfCustNo, colYear, colOrderDate, colItemNo, colOrdAmt, colConfAmt, colOrderBookNo, colSaleCat, colSubsOkFlag, naBatchLocationIds, naBatchLocAllocated, colBatchYearOfSale, hWndForm, PAM_INSERT, nExecute 
										)
									Call SalTblSetRowFlags( hWndForm, lParam, ROW_New, FALSE )
									Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, FALSE )
									! Set bUpdateLoadCustPullFlag = TRUE
									Set colOrgOrdAmt = colOrdAmt
									Set colOrgConfAmt = colConfAmt
									Set colOrgBatchLocationId = colBatchLocationId
									Set colOrgBatchYearOfSale = colBatchYearOfSale
						Else If SalTblQueryRowFlags( hWndForm, lParam, ROW_Edited )
							Call GetItemStockType( colItemNo, sTmp, nExecute )
							If sTmp = 'C'
								If colOrgBatchLocationId > 0 AND NOT colBatchLocationId > 0
									Call SalMessageBox( 'Cannot allow a batch order to picked over by a unbatched order!  Please pick a batch or delte and reenter the order.', 'Warning', MB_Ok )
									Set bOk = FALSE
								Else
									If NOT colBatchLocationId > 0 AND colBatchLocationId != colOrgBatchLocationId
										Call AllocatedPotsLocation( colItemNo, colYear, colOrdAmt, colConfAmt, naBatchLocationIds, naBatchLocAllocated, colBatchYearOfSale, nExecute )
										If NOT naBatchLocationIds[0] > 0
											Call SalMessageBox( 'Cannot allocate a batch! Either none exist or over sold.  Please verify the stock batches before posting this order.', 'Warning', MB_Ok )
											Set bOk = FALSE
									Else
										If colConfAmt > colOrgConfAmt
											! Call GetAvailableForBatchSeason( colBatchLocationId, colBatchYearOfSale, nTemp, nExecute )
											Call GetAvailableForBatchLocation( colBatchLocationId, colBatchYearOfSale, nTemp, nExecute )
											If SalIsNull( colConfAmt )
												If NOT ( nTemp + colOrgOrdAmt - colOrdAmt ) >= 0
													! Call SalMessageBox( 'Cannot allocate this batch! These lot of Batches are over sold.  Please verify the stock batches before posting this order.', 'Warning', MB_Ok )
													Call SalMessageBox( 'Cannot increase this order! This Batch is over sold.  Please verify the stock batches in farms and if need be reallocate to another batch before increasing this order.', 'Warning', MB_Ok )
													Return FALSE
											Else
												If NOT ( nTemp + colOrgConfAmt - colConfAmt ) >= 0
													! Call SalMessageBox( 'Cannot allocate this batch! These lot of Batches are over sold.  Please verify the stock batches before posting this order.', 'Warning', MB_Ok )
													! Now to allow for if the batch is over sold, it looks for new batch.
													! Call SalMessageBox( 'Cannot increase this order! This Batch is over sold.  Please verify the stock batches in farms and if need be reallocate to another batch before increasing this order.', 'Warning', MB_Ok )
													! Changing the message so that user knows of change. Make this Temporary.
													! Call SalMessageBox( 'Cannot increase this order! This Batch is over sold.  Please verify the stock batches in farms and if need be reallocate to another batch before increasing this order.', 'Warning', MB_Ok )
													Call AllocatedPotsLocation( colItemNo, colYear, colOrdAmt, colConfAmt, naBatchLocationIds, naBatchLocAllocated, colBatchYearOfSale, nExecute )
													If NOT naBatchLocationIds[0] > 0
														Call SalMessageBox( 'Cannot allocate a batch! Either none exist or over sold.  Please verify the stock batches before posting this order.', 'Warning', MB_Ok )
														Set bOk = FALSE
													Else
														Set bNewAllocated = TRUE
													! Return FALSE
													! Set bOk = FALSE
										If SalIsNull( colConfAmt )
											Set naBatchLocAllocated[0] = colOrdAmt
											Set naBatchLocAllocated[1] = NUMBER_Null
										Else
											Set naBatchLocAllocated[0] = colConfAmt
											Set naBatchLocAllocated[1] = NUMBER_Null
										If Not bNewAllocated
											Set naBatchLocationIds[0] = colBatchLocationId
											Set naBatchLocationIds[1] = NUMBER_Null
							Else
								Set naBatchLocationIds[0] = NUMBER_Null
								Set naBatchLocAllocated[0] = NUMBER_Null
							If bOk
								If NewSaveOrder( frmNewCustOrdOnLoad.dfCustNo, colOrderDateTime, colItemNo, colYear, colOrdAmt, colConfAmt, colAllocFlag, colSubsOkFlag, naBatchLocationIds, naBatchLocAllocated, colBatchYearOfSale, hWndForm, PAM_UPDATE, nExecute )
									Call SalTblSetRowFlags( hWndForm, lParam, ROW_Edited, FALSE )
									Set colOrgOrdAmt = colOrdAmt
									Set colOrgConfAmt = colConfAmt
									Set colOrgBatchLocationId = colBatchLocationId
									Set colOrgBatchYearOfSale = colBatchYearOfSale
						Else If SalTblQueryRowFlags( hWndForm, lParam, ROW_MarkDeleted )
							If SalModalDialog( dlgGetCancelOrderReason, hWndForm )
								Call PopString( sCancelOrderBookNo, TRUE)
								Call PopString( sCancelReason, TRUE )
								If colInvoiced = 'Y'
									Call SalMessageBox( 'Cannot delete this order, as it has been invoiced!', 'Warning', MB_Ok )
								Else
									If NewDeleteOrder( frmNewCustOrdOnLoad.dfCustNo, colOrderDateTime, sCancelReason, sCancelOrderBookNo, nExecute )
										Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
										Return nRowDeleted
						Return TRUE
					On PAM_SPLIT
						If MyTableAnyRows( hWndForm, ROW_Selected, 0, nNewRow )
							If nNewRow > 1
								Call SalMessageBox( 'Please only split one Row at a time!', 'Warning', MB_Ok )
								Return FALSE
							Else
								Call SalWaitCursor( TRUE )
								Call GetLoadCustInvFlag( frmNewCustOrdOnLoad.dfLoadId, frmNewCustOrdOnLoad.dfCustNo, sLoadCustInvFlag, nExecute )
								If sLoadCustInvFlag = 'Y'
									Call SalMessageBox( 'Cannot SPLIT order as this customer has been invoiced! ', 'Warning', MB_Ok )
								Else
									Set nRow = TBL_MinRow
									If SalTblFindNextRow( hWndForm, nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( hWndForm, nRow )
										Set nNewRow = SalTblInsertRow( hWndForm, nRow+1 )
										! Call CopyTblRowFromTo( hWndForm, nRow, nNewRow, TRUE, ROW_Selected, TRUE )
										! Changed the 'Change row flags' flag to stop it changing the flag from new to not new.
										Call CopyTblRowFromTo( hWndForm, nRow, nNewRow, FALSE, ROW_Selected, TRUE )
										Call SalTblFetchRow( hWndForm, nNewRow )
										Set colOrderDateTime = DATETIME_Null
										! Set colPulled = 'N'
										Set colInvoiced = 'N'
										Set colOrdAmt = 0
										Set colOrderBookNo = colOrderBookNo || ' - L Split'
										Set nStrLength = SalStrLength( colOrderBookNo )
										If nStrLength > 30
											Set colOrderBookNo = SalStrLeftX( colOrderBookNo, 30 )
								Call SalWaitCursor( FALSE )
						Else
							Call SalMessageBox( 'No Rows Selected!', 'Warning', MB_Ok )
							Return FALSE
					On PAM_VALIDATESELECTION
						If SalTblAnyRows( hWndForm, ROW_Selected, 0 )
							If SalTblAnyRows( hWndForm, ROW_New, 0 )
								Call SalMessageBox( 'Please SAVE your changes first!', 'Warning', MB_Ok )
								Return FALSE
							Else
								Return TRUE
						Else
							Call SalMessageBox( 'No Rows Selected!', 'Warning', MB_Ok )
							Return FALSE
					On SAM_Destroy
						Call NewAddOrder( 0, 0, DATETIME_Null, 0, 0, 0, '', '', '', naBatchLocationIds, naBatchLocAllocated, 0, hWndNULL, 0, nDisconnect )
						Call NewSaveOrder( 0, DATETIME_Null, 0, 0, 0, 0, '', '', naBatchLocationIds, naBatchLocAllocated, 0, hWndNULL, 0, nDisconnect )
						Call NewDeleteOrder( 0, DATETIME_Null, '', '', nDisconnect )
						Call GetLoadCustInvFlag( '', 0, sLoadCustInvFlag, nDisconnect )
						Call UpdateLoadCustPullFlag( '', 0, '', nDisconnect )
						Call GetItemStockType( 0, sTmp, nDisconnect )
						Call AllocatedPotsLocation( 0, 0, 0, 0, naBatchLocationIds, naBatchLocAllocated, colBatchYearOfSale, nDisconnect )
						Call GetAvailableForBatchSeason( 0, 0, nTemp, nDisconnect )
						Call GetAvailableForBatchLocation( 0, 0, nTemp, nDisconnect )
						Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
			Pushbutton: pbSelectFromTable

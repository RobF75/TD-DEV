				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblCustOnLoad, PAM_VALIDATESELECTION, 0, 0 )
							If SalModalDialog( dlgGetNPADetails, hWndForm, nSingleCustomer )
								! Set nYr = OurDateYear( dfCurrentDate )
								Call PopNumber( nYr, TRUE )
								Call PopNumber( nType, TRUE )
								! Temporarily when getNPADetails called it sets things if selected customers then comes out with
										single customer
								If nType = nSingleCustomer
									Set nType = nSelectedCustomers
								Set nCount = 0
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblCustOnLoad, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( tblCustOnLoad, nRow )
									Set nCustNos[ nCount ] = tblCustOnLoad.colCustNo
									Set nCount = nCount + 1
									Set nCustNos[ nCount ] = NUMBER_Null
								Call SalCreateWindow( frmPrintCustomerNPAs, hWndForm, nCustNos, nCount, nYr, nType )
								! Call SalCreateWindow( frmPrintCustomerNPAs, hWndForm, nCustNos, nCount, nYr, nSelectedCustomers )
			Pushbutton: pbMoveCustLoadToLoad
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Move Customers Load To Load
				Window Location and Size
					Left:   3.7"
					Top:    0.354"
					Width:  2.65"
					Width Editable? Class Default
					Height: 0.156"
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Courier New
				Font Size: 8
				Font Enhancement: None
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblCustOnLoad, PAM_VALIDATESELECTION, 0, 0 )
							Set nCount = 0
							Set nRow = TBL_MinRow
							While SalTblFindNextRow( tblCustOnLoad, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblCustOnLoad, nRow )
								Set nCustNos[ nCount ] = tblCustOnLoad.colCustNo
								Set nCount = nCount + 1
								Set nCustNos[ nCount ] = NUMBER_Null
							Set nYr = cSeasonYear.GetSeasonYear( )
							If SalModalDialog( dlgMoveCustLoadToLoad, hWndForm, dfLoadId, nCustNos, nYr )
								! customer was removed from this load and put onto another load.
										  however he is still in the populated table and the result set.
										  The next code removes the customer from the table and the result set
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblCustOnLoad, nRow, ROW_Selected, 0 )
									Call SalTblDeleteRow( tblCustOnLoad, nRow, TBL_Adjust )
									Set nRow = nRow - 1
			Pushbutton: pbPrintPulls
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Print Pulls
				Window Location and Size
					Left:   7.45"
					Top:    5.073"
					Width:  1.013"
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblCustOnLoad, PAM_VALIDATESELECTION, 0, 0 )
							!
							Call CheckLoadDupSeqNo( dfLoadId, bExists, nExecute )
							If bExists
								Call SalMessageBox( 'Please verify sequence numbers!  Some customers have the same seq.No.', 'Warning', MB_Ok )
							Else
								!
								Set nCount = 0
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblCustOnLoad, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( tblCustOnLoad, nRow )
									If tblCustOnLoad.colCustPulled = 'Y'
										Call ErrorMessage( 'This customer is already pulled! Cannot pull again!', tblCustOnLoad, nRow )
									Else
										Set nCustNos[ nCount ] = tblCustOnLoad.colCustNo
										Set nCount = nCount + 1
										Set nCustNos[ nCount ] = NUMBER_Null
								If nCount > 0
									Set nYr = cSeasonYear.GetSeasonYear( )
									Call SalCreateWindow( frmPrintPullSheets, hWndForm, dfLoadId, nCustNos, dtaOrdDT, nYr, nSelectedCustOnLoad )
								Else
									Call SalMessageBox( 'No customers can be pulled!', 'Warning', MB_Ok )

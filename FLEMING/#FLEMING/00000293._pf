						Property Template:
						Class DLL Name:
						Title: NPA Recd.
						Visible? Class Default
						Editable? Class Default
						Maximum Data Length: Class Default
						Data Type: String
						Justify: Center
						Width:  0.913"
						Width Editable? Class Default
						Format: Uppercase
						Country: Class Default
						Input Mask: Class Default
						Cell Options
							Cell Type? Class Default
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? Class Default
								Vertical Scroll? Class Default
								Auto Drop Down? Class Default
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
							On PAM_SETINSTANCEVARS
								Set colNPARecdFlag.sSQLCOLNAME = 'CUSTOMER_ORDER.NPA_RECD_FLAG'
								Set colNPARecdFlag.bInsert = FALSE
								Set colNPARecdFlag.bUpdate = FALSE
								Set colNPARecdFlag.bReportColumn = TRUE
				Functions
				Window Variables
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' CUSTOMER_ORDER '
						Set sSQLPOPTABLENAME = ' CUSTOMER_ORDER, CUSTOMER_MASTER, STOCK_ITEM'
						!
						If frmOutstandOrdersOnOrAllRegions.bContWanted
							If frmOutstandOrdersOnOrAllRegions.nActionType = nAllRegions
								Set sSQLWHERE = ' WHERE CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
										 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
										 CUSTOMER_ORDER.CONF_AMT > 0 AND 
										 CUSTOMER_ORDER.YEAR_OF_SALE = :frmOutstandOrdersOnOrAllRegions.nYear AND
										 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO '
							Else
								Set sSQLWHERE = ' WHERE CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
										 CUSTOMER_MASTER.REGION_ID = :frmOutstandOrdersOnOrAllRegions.sRegionId AND  
										 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
										 CUSTOMER_ORDER.CONF_AMT > 0 AND 
										 CUSTOMER_ORDER.YEAR_OF_SALE = :frmOutstandOrdersOnOrAllRegions.nYear AND
										 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO '
						Else
							If frmOutstandOrdersOnOrAllRegions.nActionType = nAllRegions
								Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
										 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
										 CUSTOMER_ORDER.CONF_AMT > 0 AND 
										 CUSTOMER_ORDER.YEAR_OF_SALE = :frmOutstandOrdersOnOrAllRegions.nYear AND
										 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO AND 
										 NOT STOCK_ITEM.TREE_TYPE LIKE 'C%' "
							Else
								Set sSQLWHERE = " WHERE CUSTOMER_ORDER.CUST_NO = CUSTOMER_MASTER.CUST_NO AND
										 CUSTOMER_MASTER.REGION_ID = :frmOutstandOrdersOnOrAllRegions.sRegionId AND  
										 CUSTOMER_ORDER.LOAD_ID IS NULL AND 
										 CUSTOMER_ORDER.CONF_AMT > 0 AND 
										 CUSTOMER_ORDER.YEAR_OF_SALE = :frmOutstandOrdersOnOrAllRegions.nYear AND
										 CUSTOMER_ORDER.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO  AND 
										 NOT STOCK_ITEM.TREE_TYPE LIKE 'C%' "
						!
						Set sORDERBY = ' ORDER BY CUSTOMER_MASTER.REGION_ID, 
								CUSTOMER_ORDER.CUST_NO, 
								STOCK_ITEM.VARIETY_TYPE, 
								STOCK_ITEM.VARIETY, 
								STOCK_ITEM.CULT_DESC, 
								STOCK_ITEM.TREE_TYPE_DESC '
						Set sROWID = ' CUSTOMER_ORDER.ROWID '
						Set sTableHeading = 'Outstanding Orders On or All Regions'
						Set hWndRowNewColumn = colOrderDate
						Set bSelectFirstRow = FALSE
						Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\outords2.qrp'
					On PAM_POPULATE
						Call SalSendClassMessage( PAM_POPULATE, wParam, lParam )
						Call SalTblSetLockedColumns( hWndForm, 4 )
					On PAM_REPOPULATE
						Call SalSendClassMessage( PAM_REPOPULATE, wParam, lParam )
						Call SalTblSetLockedColumns( hWndForm, 4 )
			!

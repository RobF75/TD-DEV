				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblLoads, PAM_VALIDATESELECTION, 0, 0 )
							Set nLoadIdCount = 0
							Set nRowsSelected = TBL_MinRow
							While SalTblFindNextRow( tblLoads, nRowsSelected, ROW_Selected, 0 )
								Call SalTblFetchRow( tblLoads, nRowsSelected )
								Set saLoadIds[ nLoadIdCount ] = tblLoads.colLoadId
								Set dtaLoadsShipDates[ nLoadIdCount ] = tblLoads.colShipDate
								Set nLoadIdCount = nLoadIdCount + 1
								Set saLoadIds[ nLoadIdCount ] = ''
								Set dtaLoadsShipDates[ nLoadIdCount ] = DATETIME_Null
							Set nYear = cSeasonYear.GetSeasonYear( )
							If NOT SalCreateWindow( frmPrintTruckStockReport, hWndForm, saLoadIds, dtaLoadsShipDates, nYear )
								Call SalMessageBox( 'Not enough system memory to perform this task!', 'Error', MB_Ok )
			Pushbutton: pbPrintCustInRegions
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Cust.On Region
				Window Location and Size
					Left:   7.15"
					Top:    5.073"
					Width:  1.163"
					Width Editable? Class Default
					Height: 0.292"
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Arial
				Font Size: 8
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblLoads, PAM_VALIDATESELECTION, 0, 0 )
							! Set saAllRegions[ 0 ] = ''
							! Set saAllRegions[ 1 ] = ''
							! Call MyTableLoop( tblLoads, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Collecting Regions On Load', nLowToHi )
							Call SalSendMsg( hWndForm, PAM_ALLREGONSELLOADS, 0, 0 )
							!
							Set nYear = cSeasonYear.GetSeasonYear( )
							Set nTmp = SalMessageBox( 'Do you wish to see Container Loads on this report!', 'Containers', MB_YesNoCancel )
							If nTmp = IDYES
								Set bContWanted = TRUE
							Else If nTmp = IDNO
								Set bContWanted = FALSE
							Else
								Return FALSE
							!
							Set nTmp = SalMessageBox( 'Do you wish to include Invoiced Orders on this report!', 'Orders', MB_YesNoCancel )
							If nTmp = IDYES
								Set bIncludeInvoiced = TRUE
							Else If nTmp = IDNO
								Set bIncludeInvoiced = FALSE
							Else
								Return FALSE
							!
							If NOT SalCreateWindow( frmPrintCustInRegNLoads, hWndForm, saAllRegions, nYear, bIncludeInvoiced, nSelectionRegions, bContWanted )
								Call SalMessageBox( 'Not enough system memory to perform this task!', 'Error', MB_Ok )
					! On PAM_ROWACTION
						                                                                                                                              If GetListRegionsOnLoad( tblLoads.colLoadId, saLoadRegions, nExecute )
							                                                                                                                              Set nLoadRegionsPos = 0
							                                                                                                                              While saLoadRegions[ nLoadRegionsPos ] != ''
								                                                                                                                              Call InsertRegion( saAllRegions, saLoadRegions[ nLoadRegionsPos ] )
								                                                                                                                              Set nLoadRegionsPos = nLoadRegionsPos + 1
						                                                                                                                              Return TRUE
			Pushbutton: pbPrintCustInRegsNotOnLoads
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title:
				Window Location and Size
					Left:   Default
					Top:    Default
					Width:  Default
					Width Editable? Class Default
					Height: Default
					Height Editable? Class Default
				Visible? No
				Keyboard Accelerator: Class Default
				Font Name: Arial
				Font Size: 8
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblLoads, PAM_VALIDATESELECTION, 0, 0 )
							Call SalSendMsg( hWndForm, PAM_ALLREGONSELLOADS, 0, 0 )
							Set nTmp = SalMessageBox( 'Do you want the Pots version only?', 'Customers In Regions Not On Loads', MB_YesNoCancel )
							If nTmp = IDYES
								Set sStockType = 'CONT'
							Else If nTmp = IDNO
								Set nTmp = SalMessageBox( 'Include Container Trees in Fruit and Ornamenatal Calculations?', 'Customers In Regions Not On Loads', MB_YesNoCancel )
								If nTmp = IDYES
									Set sStockType = 'BOTH'
								Else If nTmp = IDNO
									Set sStockType = 'BARE'
								Else
									Return FALSE
							Else
								Return FALSE
							!
							Set nYear = cSeasonYear.GetSeasonYear( )
							!
							If NOT WriteStrArrayListToFile( saAllRegions, OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'c:\\temp' )||'\\regions.tmp' )
								Call SalMessageBox( 'Please check your C drive ( Hard Disk ) for available space and or c:\\Temp directory!', 'Error', MB_Ok )
								Call SalWaitCursor( FALSE )
								Return FALSE
							! Set sArguments = SqlDatabase || ' ' || SqlUser || ' ' || SqlPassword || ' ' || 
									'c:\\temp\\regions.tmp' || ' ' || SalNumberToStrX( nYear, 0 ) || ' ' || sIncludeContainers || ' ' || SalNumberToStrX( nSelectionRegions, 0 )
							Set sArguments = SqlDatabase || ' ' || SqlUser || ' ' || SqlPassword || ' ' || 
									OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'c:\\temp' )||'\\regions.tmp' || ' ' || SalNumberToStrX( nYear, 0 ) || ' ' || sStockType || ' ' || SalNumberToStrX( nSelectionRegions, 0 )
							!
							Call SalLoadApp( OurGetIniFileParameter( 'GENERAL', 'CustInRegNotOnLoad', '' ), sArguments )
							! If SqlDatabase = 'STOCKDEV'
								                                                                                                                              Call SalLoadApp( 'CSTNOTLD', sArguments )
							! Else
								                                                                                                                              Call SalLoadApp( 'CSTNOTL', sArguments )
			Pushbutton: pbMaintainOrders
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title:
				Window Location and Size
					Left:   Default
					Top:    Default
					Width:  Default
					Width Editable? Class Default
					Height: Default
					Height Editable? Class Default
				Visible? No
				Keyboard Accelerator: Class Default
				Font Name: Arial
				Font Size: 8
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblLoads, PAM_VALIDATESELECTION, 0, 0 )
							Set nTmp = SalMessageBox( 'Would you Like to REFRESH Orders', 'Maintain Orders', MB_YesNoCancel )
							If nTmp = IDYES
								Call SalSendMsg( hWndItem, PAM_UPDATE, 1, 1 )
							Else If nTmp = IDNO
								Set nTmp = SalMessageBox( 'Would you Like to REDO Orders', 'Maintain Orders', MB_YesNoCancel )
								If nTmp = IDYES
									Call SalSendMsg( hWndItem, PAM_UPDATE, 2, 1 )
					On PAM_UPDATE
						! wParam = 1 = REFRESH
						! wParam = 2 = REDO
						! lParam = 1 = Comming from push button click
						! lParam = 2 = Comming from menu item
						If lParam = 2
							If SalSendMsg( tblLoads, PAM_VALIDATESELECTION, 0, 0 )
								Set bContinue = TRUE
							Else
								Set bContinue = FALSE
						Else
							Set bContinue = TRUE
						!
						If bContinue
							Set nLoadIdCount = 0
							Set saLoadIds[ nLoadIdCount ] = ''
							Set dtaLoadsShipDates[ nLoadIdCount ] = DATETIME_Null
							Call MyTableLoop( tblLoads, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Collecting Loads', nLowToHi )
							!
							If nLoadIdCount > 0
								Call SalWaitCursor( TRUE )
								If wParam = 1
									Call MaintainLoadsOrders( saLoadIds, dtaLoadsShipDates, cSeasonYear.GetSeasonYear( ), 'REFRESH', nExecute )
								Else
									Call MaintainLoadsOrders( saLoadIds, dtaLoadsShipDates, cSeasonYear.GetSeasonYear( ), 'REDO', nExecute )
								Call SalWaitCursor( FALSE )
								!
					On PAM_ROWACTION
						Set saLoadIds[ nLoadIdCount ] = tblLoads.colLoadId
						Set dtaLoadsShipDates[ nLoadIdCount ] = tblLoads.colShipDate
						Set nLoadIdCount = nLoadIdCount + 1
						Set saLoadIds[ nLoadIdCount ] = ''
						Set dtaLoadsShipDates[ nLoadIdCount ] = DATETIME_Null
						Return TRUE

					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when:
						Checked when:
					Menu Actions
						Call SalSendValidateMsg(  )
						Call SalSendMsg( pbPrintCustInRegsNotOnLoads, SAM_Click, 0, 0 )
					Menu Item Name:
				Menu Separator
				Menu Item: Print Delivery Notification
					Resource Id: 51048
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when:
						Checked when:
					Menu Actions
						Call SalWaitCursor( TRUE )
						Set nLoadIdCount = 0
						Set saLoadIds[ nLoadIdCount ] = ''
						Set nRowsSelected = TBL_MinRow
						While SalTblFindNextRow( tblLoads, nRowsSelected, ROW_Selected, 0 )
							Call SalTblFetchRow( tblLoads, nRowsSelected )
							Set saLoadIds[ nLoadIdCount ] = tblLoads.colLoadId
							Set nLoadIdCount = nLoadIdCount + 1
							Set saLoadIds[ nLoadIdCount ] = ''
						If saLoadIds[ 0 ] = ''
							Call SalMessageBox( 'Please select at least one load first!', 'Error', MB_Ok )
							Call SalWaitCursor( FALSE )
							Return FALSE
						If NOT WriteStrArrayListToFile( saLoadIds, OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'C:\\TEMP' )||'\\DelNoti.tmp' )
							Call SalMessageBox( 'Please check your C drive ( Hard Disk ) for available space!', 'Error', MB_Ok )
							Call SalWaitCursor( FALSE )
							Return FALSE
						Set sArguments = SqlDatabase || ' ' || 
								SqlUser || ' ' || 
								SqlPassword || ' ' || 
								OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'C:\\TEMP' )||'\\DelNoti.tmp'
						Call SalLoadApp( OurGetIniFileParameter( 'GENERAL', 'DeliveryNotificationReport', '' ), sArguments )
						Call SalWaitCursor( FALSE )
					Menu Item Name:
				Menu Separator
				Menu Item: Print Host plants Report for selected Load ( 1 at a time )
					Resource Id: 34609
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when:
						Checked when:
					Menu Actions
						Call SalWaitCursor( TRUE )
						Set nLoadIdCount = 0
						Set nRowsSelected = TBL_MinRow
						While SalTblFindNextRow( tblLoads, nRowsSelected, ROW_Selected, 0 )
							Call SalTblFetchRow( tblLoads, nRowsSelected )
							Set nLoadIdCount = nLoadIdCount + 1
						If nLoadIdCount != 1
							Call SalMessageBox( 'Please select ONE load!', 'Error', MB_Ok )
							Call SalWaitCursor( FALSE )
							Return FALSE
						Set sArguments = SqlDatabase || ' ' || 
								SqlUser || ' ' || 
								SqlPassword || ' ' || 
								tblLoads.colLoadId || ' ' ||
								'noFile' || ' ' ||
								'LOAD'
						Call SalLoadApp( OurGetIniFileParameter( 'GENERAL', 'HostPlantsReport', '' ), sArguments )
						Call SalWaitCursor( FALSE )

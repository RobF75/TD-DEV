						Menu Item Name:
				Menu Separator
				Menu Item: Reset (All / Selected) Loads for New Season
					Resource Id: 35604
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when:
						Checked when:
					Menu Actions
						If SalModalDialog( dlgGetYear, hWndForm )
							Call PopNumber( nTmp, TRUE )
							If nTmp < 100
								Set nTmp = nTmp + 1900
							If SalTblAnyRows( tblLoads, ROW_Selected, 0 )
								If IDYES = SalMessageBox( 'Are you sure you wish Reset the SELECTED Loads and Customers on Loads ready for the '|| SalNumberToStrX( nTmp, 0 ) ||' season?', 'Warning', MB_YesNo )
									Set nLoadIdCount = 0
									Set saLoadIds[ nLoadIdCount ] = ''
									Call MyTableLoop( tblLoads, hWndForm, PAM_ROWACTION, ROW_Selected, 0, 'Collecting Loads', nLowToHi )
									!
									Call ResetLoadsForNewSeason( nTmp, saLoadIds, 'SELECTED', nExecute )
							Else
								If IDYES = SalMessageBox( 'Are you sure you wish Reset ALL the relevant Loads and Customers on Loads ready for the '|| SalNumberToStrX( nTmp, 0 ) ||' season?', 'Warning', MB_YesNo )
									Set nLoadIdCount = 0
									Set saLoadIds[ nLoadIdCount ] = ''
									Call ResetLoadsForNewSeason( nTmp, saLoadIds, 'ALL', nExecute )
					Menu Item Name:
				Menu Separator
				Menu Item: Denorm. All Customers Meet Address Fields

			Function: DeleteCustOrdersFromLoad
				Description:
				Returns
					Boolean:
				Parameters
					String: sLoadId
					Number: nYear
					Number: nActionType
				Static Variables
					! hcSqlHandle: fcOurHandle
.winattr class :
						Class: hcSqlHandle
.end
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nSqlHandleNo
				Actions
					Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'DELLDCSTORD' )
					Select Case nActionType
						Case nExecute
							Set sSql = " UPDATE Customer_Order Set Load_Id = @IF(@EXACT(Invoiced_Flag,'Y'), 'GONE','')  
									WHERE Load_Id = :1 AND Year_Of_Sale = :2 "
							Set sName = 'DELLDCSTORD'
							Set sBind = ':sLoadId, :nYear'
							Set sInto = ''
							!
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							!
							If haSqlHandles[ nSqlHandleNo ].Execute( )
								Return TRUE
							Else
								Return FALSE
						Case nCommit
							Return haSqlHandles[ nSqlHandleNo ].Commit( )
						Case nRollback

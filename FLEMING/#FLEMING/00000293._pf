			Pushbutton: pbMaintainOrders
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title:
				Window Location and Size
					Left:   Default
					Top:    Default
					Width:  Default
					Width Editable? Class Default
					Height: Default
					Height Editable? Class Default
				Visible? No
				Keyboard Accelerator: Class Default
				Font Name: Arial
				Font Size: 8
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblCustOnLoad, PAM_VALIDATESELECTION, 0, 0 )
							Set nTmp = SalMessageBox( 'Would you Like to REFRESH Orders', 'Maintain Orders', MB_YesNoCancel )
							If nTmp = IDYES
								Call SalSendMsg( hWndItem, PAM_UPDATE, 1, 1 )
							Else If nTmp = IDNO
								Set nTmp = SalMessageBox( 'Would you Like to REDO Orders', 'Maintain Orders', MB_YesNoCancel )
								If nTmp = IDYES
									Call SalSendMsg( hWndItem, PAM_UPDATE, 2, 1 )
					On PAM_UPDATE
						! wParam = 1 = REFRESH
						! wParam = 2 = REDO
						! lParam = 1 = Comming from push button click
						! lParam = 2 = Comming from menu item
						If lParam = 2
							If SalSendMsg( tblCustOnLoad, PAM_VALIDATESELECTION, 0, 0 )
								Set bContinue = TRUE
							Else
								Set bContinue = FALSE
						Else
							Set bContinue = TRUE
						!
						If bContinue
							Set nCount = 0
							Set nCustNos[ nCount ] = NUMBER_Null
							Set saOrdTypes[ nCount ] = ''
							Call MyTableLoop( tblCustOnLoad, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Collecting Customers', nLowToHi )
							!
							If nCount > 0
								Call SalWaitCursor( TRUE )
								If wParam = 1
									Call MaintainCustOrders( nCustNos, saOrdTypes, dfLoadId, dfShippingDate, cSeasonYear.GetSeasonYear( ), 'REFRESH', nExecute )
								Else
									Call MaintainCustOrders( nCustNos, saOrdTypes, dfLoadId, dfShippingDate, cSeasonYear.GetSeasonYear( ), 'REDO', nExecute )
								Call SalWaitCursor( FALSE )
								!
								Call SalSendMsgToChildren( hWndForm, PAM_POPULATE_CAPACITY, 1, 0 )
					On PAM_ROWACTION
						Set nCustNos[ nCount ] = tblCustOnLoad.colCustNo
						Set saOrdTypes[ nCount ] = tblCustOnLoad.colOrdType
						Set nCount = nCount + 1
						Set nCustNos[ nCount ] = NUMBER_Null
						Set saOrdTypes[ nCount ] = ''
						Return CheckCustomersNotes( tblCustOnLoad.colCustNo, 'Load Notes', nExecute )
			!

				Functions
					Function: RegionIdMeetIdExists
						Description:
						Returns
							Boolean:
						Parameters
							String: sRegionId
							String: sMeetId
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Region_Id, Meet_Id FROM Region_Meet WHERE Region_Id = :sRegionId AND Meet_Id = :sMeetId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									If nInd = FETCH_EOF
										Return FALSE
									Else
										Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in MeetIdExists, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
					Function: MeetIdExists
						Description:
						Returns
							Boolean:
						Parameters
							String: sMeetId
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Meet_Id FROM Region_Meet WHERE Meet_Id = :sMeetId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									If nInd = FETCH_EOF
										Return FALSE
									Else
										Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in MeetIdExists, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
				Window Variables
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' REGION_MEET '
						Set sSQLPOPTABLENAME= ' REGION_MEET, MEET_ADDRESS'
						Set sSQLWHERE =  ' WHERE Region_Meet.Region_Id = :frmRegionMeets.sRegionId AND
								 Region_Meet.Meet_Id = Meet_Address.Meet_Id '
						Set sORDERBY = ' ORDER BY Region_Meet.Meet_Id '
						Set sROWID = ' REGION_MEET.ROWID '
						Set sTableHeading = 'Meeting Address\' for a Region'
						Set hWndRowNewColumn = colMeetId
						Set nTableFillType = TBL_FillAll
					On SAM_Destroy
						Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
						Call RegionIdMeetIdExists( '', '', nDisconnect )
						Call MeetIdExists( '', nDisconnect )

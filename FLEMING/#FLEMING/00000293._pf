			Pushbutton: pbPrintLblPull
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Pull Load
				Window Location and Size
					Left:   3.263"
					Top:    3.625"
					Width:  0.913"
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? No
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					! On PAM_CLICK
						                                                                                                                              If SalSendMsg( tblLoads, PAM_VALIDATESELECTION, 0, 0 )
							                                                                                                                              If MyTableAnyRows( tblLoads, ROW_Selected, 0, nLoadIdCount )
								                                                                                                                              If nLoadIdCount > 1
									                                                                                                                              Call SalWaitCursor( FALSE )
									                                                                                                                              Call SalMessageBox( 'Please select one load to print Label Pull Sheets for!', 'Warning', MB_Ok )
									                                                                                                                              Call SalWaitCursor( TRUE )
								                                                                                                                              Else 
									                                                                                                                              Set nYear = cSeasonYear.GetSeasonYear( )
									! If tblLoads.colInvoicedFlag = 'Y'
										                                                                                                                              Call SalMessageBox( 'Can NOT print label pull sheets for a load thats already invoiced!', 'Warning', MB_Ok )
									! Else
										                                                                                                                              If NOT SalCreateWindow( frmPullLabels, hWndForm, tblLoads.colLoadId, naCustNos, dtaOrdDT, nYear, '',nAllCustOnLoad )
											                                                                                                                              Call SalMessageBox( 'Could not start the label pull sheet screen!  Most likely because to many things are open at the one time!', 'Error', MB_Ok )
									                                                                                                                              If NOT SalCreateWindow( frmPullLabels, hWndForm, tblLoads.colLoadId, naCustNos, dtaOrdDT, nYear, '',nAllCustOnLoad )
										                                                                                                                              Call SalMessageBox( 'Could not start the label pull sheet screen!  Most likely because to many things are open at the one time!', 'Error', MB_Ok )
					On PAM_CLICK
						If SalSendMsg( tblLoads, PAM_VALIDATESELECTION, 0, 0 )
							Set nLoadIdCount = TBL_MinRow
							Call SalSendMsg( hWndItem, PAM_ROWACTION, 0, 0 )
					On PAM_ROWACTION
						Call SalWaitCursor( TRUE )
						If SalTblFindNextRow( tblLoads, nLoadIdCount, ROW_Selected, 0 )
							Call SalTblFetchRow( tblLoads, nLoadIdCount )
							Set nYear = cSeasonYear.GetSeasonYear( )
							If NOT SalCreateWindow( frmPullLabels, hWndForm, tblLoads.colLoadId, naCustNos, dtaOrdDT, nYear, '',nAllCustOnLoad )
								Call SalMessageBox( 'Could not start the label pull sheet screen!  Most likely because to many things are open at the one time!', 'Error', MB_Ok )
						Call SalWaitCursor( FALSE )
					On PAM_REPORTFINISHED
						Return SalSendMsg( hWndItem, PAM_ROWACTION, 0, 0 )
			Pushbutton: pbUnPull
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: UnPull Load
				Window Location and Size
					Left:   3.113"
					Top:    4.76"
					Width:  1.113"
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default

			! Jan, put in a check here in invoice to make sure all customers on this load are pulled = Y - JANFIX
			Pushbutton: pbInvoice
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Invoice Load
				Window Location and Size
					Left:   4.263"
					Top:    4.76"
					Width:  1.575"
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblLoads, PAM_VALIDATESELECTION, 0, 0 )
							Set nRow = TBL_MinRow
							Call SalTblFindNextRow( tblLoads, nRow, ROW_Selected, 0 )
							Call SalTblFetchRow( tblLoads, nRow )
							!
							If tblLoads.colPulledFlag = 'N'
								Call SalWaitCursor( FALSE )
								Call SalMessageBox( 'This load is not pulled!  Cannot invoice!', 'Warning', MB_Ok )
								Call SalWaitCursor( TRUE )
								Return FALSE
							!
							Call CheckLoadDupSeqNo( tblLoads.colLoadId, bExists, nExecute )
							If bExists
								Call SalMessageBox( 'Please verify sequence numbers!  Some customers have the same seq.No.', 'Warning', MB_Ok )
							Else
								If SalModalDialog( dlgObtainInvoiceDate, hWndForm )
									Call PopDateTime( dtInvoiceDate, TRUE )
								If CheckLoadHasPRCs(tblLoads.colLoadId, cSeasonYear.GetSeasonYear( ), bAnyPRCOnLoad, nExecute)
									Set bAnyPRCOnLoad = TRUE
								If CheckLoadHasNormal(tblLoads.colLoadId, cSeasonYear.GetSeasonYear( ), bAnyNormalOnLoad, nExecute)
									Set bAnyNormalOnLoad = TRUE
								If bAnyPRCOnLoad  and bAnyNormalOnLoad
									Set naPRCNeededCustNos[0] = TRUE
									! Flemings invoices
									Call SalCreateWindow( TblPrintInvoices, hWndForm, dtInvoiceDate, 0, dtaOrderDT, cSeasonYear.GetSeasonYear( ), tblLoads.colLoadId, 'LOAD', naPRCNeededCustNos, 'F' )
									! From here a message is returned. PAM_INVOICECOMPLETE to tell it to now do Zee Invoices
								Else If bAnyNormalOnLoad
									Set naPRCNeededCustNos[0] = FALSE
									! Only Flemings invoices
									Call SalCreateWindow( TblPrintInvoices, hWndForm, dtInvoiceDate, 0, dtaOrderDT, cSeasonYear.GetSeasonYear( ), tblLoads.colLoadId, 'LOAD', naPRCNeededCustNos , 'F')
								Else If bAnyPRCOnLoad
									! Only Zee Invoices
									Call SalCreateWindow( TblPrintInvoices, hWndForm, dtInvoiceDate, 0, dtaOrderDT, cSeasonYear.GetSeasonYear( ), tblLoads.colLoadId, 'LOAD', naPRCNeededCustNos , 'Z')
			Pushbutton: pbPull
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Pull Load
				Window Location and Size
					Left:   1.95"
					Top:    4.76"
					Width:  1.113"
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblLoads, PAM_VALIDATESELECTION, 0, 0 )
							If MyTableAnyRows( tblLoads, ROW_Selected, 0, nLoadIdCount )
								If nLoadIdCount > 1
									Call SalWaitCursor( FALSE )
									Call SalMessageBox( 'Please select one load to print Pull Sheets for!', 'Warning', MB_Ok )
									Call SalWaitCursor( TRUE )
								Else
									Set nYear = cSeasonYear.GetSeasonYear( )
									If tblLoads.colPulledFlag = 'Y'
										Call SalMessageBox( 'Can NOT pull a load thats already pulled!', 'Warning', MB_Ok )
									Else If tblLoads.colInvoicedFlag = 'Y'
										Call SalMessageBox( 'Can NOT pull a load thats already invoiced!', 'Warning', MB_Ok )
									Else
										Call CheckLoadDupSeqNo( tblLoads.colLoadId, bExists, nExecute )
										If bExists
											Call SalMessageBox( 'Please verify sequence numbers!  Some customers have the same seq.No.', 'Warning', MB_Ok )
										Else
											If NOT SalCreateWindow( frmPrintPullSheets, hWndForm, tblLoads.colLoadId, naCustNos, dtaOrdDT, nYear, nAllCustOnLoad )
												Call SalMessageBox( 'Could not start the pull sheet screen!  Most likely because to many things are open at the one time!', 'Error', MB_Ok )

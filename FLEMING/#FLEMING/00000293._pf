			Pushbutton: pbCopy
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Copy
				Window Location and Size
					Left:   0.238"
					Top:    2.396"
					Width:  1.375"
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						Set bOk = TRUE
						Call ExistsLoad( dfToLoadId, bExists, nExecute )
						If bExists
							Call SalMessageBox( 'The TO: load Id already exists!  Please choose another!', 'Warning', MB_Ok )
							Set bOk = FALSE
						Else
							If CopyLoadToLoad( dfFromLoadId, dfToLoadId, dfToLoadDesc, nExecute )
								If CopyLoadCustomersToLoad( dfFromLoadId, dfToLoadId, nExecute )
									Call CopyLoadCustomersToLoad( dfFromLoadId, dfToLoadId, nCommit )
									Call CopyLoadToLoad( dfFromLoadId, dfToLoadId, dfToLoadDesc, nCommit )
								Else
									Call CopyLoadCustomersToLoad( dfFromLoadId, dfToLoadId, nRollback )
									Call CopyLoadToLoad( dfFromLoadId, dfToLoadId, dfToLoadDesc, nRollback )
									Set bOk = FALSE
							Else
								Call CopyLoadToLoad( dfFromLoadId, dfToLoadId, dfToLoadDesc, nRollback )
								Set bOk = FALSE
						Return SalSendMsg( pbCancel, SAM_Click, bOk, bOk )

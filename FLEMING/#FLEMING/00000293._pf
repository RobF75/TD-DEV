				Functions
					Function: LoadIdExists
						Description:
						Returns
							Boolean:
						Parameters
							String: sLoadId
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Load_Id FROM Load WHERE Load_Id = :sLoadId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									If nInd = FETCH_EOF
										Return FALSE
									Else
										Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in LoadIdExists, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
					Function: TransportIdExists
						Description:
						Returns
							Boolean:
						Parameters
							String: sTransportId
							Number: nExecuteOrDisconnect
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							Number: nInd
							Boolean: bOk
						Actions
							If nExecuteOrDisconnect != nDisconnect
								If NOT bHandleConnected
									Set bHandleConnected = SqlConnect( hSqlHandle ) 
									If bHandleConnected
										Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bHandlePrepared
									Set sSql = ' SELECT Transport_Id FROM Transport_Method WHERE Transport_Id = :sTransportId '
									If SqlPrepare( hSqlHandle, sSql )
										Set bHandlePrepared = TRUE
									Else
										Set bHandlePrepared = FALSE
								If SqlExecute( hSqlHandle )
									Call SqlFetchNext( hSqlHandle, nInd )
									If nInd = FETCH_EOF
										Return FALSE
									Else
										Return TRUE
								Else
									Set bHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute had a error in LoadIdExists, Contact programmers please!', 'ERROR', MB_Ok )
									Return FALSE
							Else
								Set bOk = TRUE
								Set bHandlePrepared = FALSE
								If bHandleConnected
									Set bHandleConnected = FALSE
									Set bOk = SqlDisconnect( hSqlHandle )
								Return bOk
				Window Variables
				Message Actions
					On PAM_SETINSTANCEVARS
						Set sSQLTABLENAME = ' LOAD '
						Set sSQLPOPTABLENAME = ' LOAD '
						Set sSQLWHERE = ''
						Set sORDERBY = ' ORDER BY LOAD_ID '
						Set sTableHeading = 'Loads'
						Set hWndRowNewColumn = colLoadId
						Set nTableFillType = TBL_FillAll
					On SAM_Destroy
						Call SalSendClassMessage( SAM_Destroy, wParam, lParam )
						Call LoadIdExists( '', nDisconnect )
						Call TransportIdExists( '', nDisconnect )

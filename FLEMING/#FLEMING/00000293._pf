			Number: nYear
		Message Actions
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
				Set bExitOnSelect = FALSE
				Set bSelectPbEnabled = FALSE
				Set bQueryOnSelect = FALSE
				Set bQueryTableAllowed = FALSE
				Set bAddRowsAllowed = FALSE
				Set bSaveRowsAllowed = FALSE
				Set bDeleteRowsAllowed = FALSE
				Set bUnDeleteRowsAllowed = FALSE
				Set nMultipleSelectDirection = nLowToHi
			On SAM_CreateComplete
				Set nYear = cSeasonYear.GetSeasonYear( )
				Call SalWaitCursor( FALSE )
			On PAM_POPFIELDS
				Call PopNumber( dfCustNo, TRUE )
				Return TRUE
			On PAM_SHOW
				Call SalSendClassMessage( PAM_SHOW, wParam, lParam )
				Call SalSendMsg( tblCustOutstandOrders, PAM_REPOPULATE, 0, 0 )
	!

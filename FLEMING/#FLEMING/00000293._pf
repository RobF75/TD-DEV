		Functions
		Window Parameters
			String: sRegionId
			! nActionType either nOneRegion, nAllRegions
			Number: nActionType
			Boolean: bContWanted
		Window Variables
			Number: nYear
		Message Actions
			On PAM_SETINSTANCEVARS
				Set sDatabase = SqlDatabase
				Set OurFrmWndWithChildTbl.bQueryTableAllowed = FALSE
				Set OurFrmWndWithChildTbl.bAddRowsAllowed = FALSE
				Set OurFrmWndWithChildTbl.bSaveRowsAllowed = FALSE
				Set OurFrmWndWithChildTbl.bDeleteRowsAllowed = FALSE
				Set OurFrmWndWithChildTbl.bUnDeleteRowsAllowed = FALSE
				Set OurFrmWndWithChildTbl.bTablePrintReportAllowed = TRUE
			On SAM_CreateComplete
				If nActionType = nOneRegion
					Set dfRegionId = sRegionId
				Else
					Set dfRegionId = ''
					Call SalHideWindow( dfRegionId )
				If bContWanted
					Set dfContWanted = 'Containers Included'
				Else
					Set dfContWanted = 'Containers Excluded'
				Set nYear = cSeasonYear.GetSeasonYear( )
				Call SalDisableWindow( SalParentWindow( hWndForm ) )
				Call SalWaitCursor( FALSE )
			On SAM_Destroy
				!
				Call SalEnableWindow( SalParentWindow( hWndForm ) )
				Call SalBringWindowToTop( SalParentWindow( hWndForm ) )
				!
				Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
	!

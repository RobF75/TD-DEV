						Title: Year
						Visible? No
						Editable? Class Default
						Maximum Data Length: Class Default
						Data Type: Number
						Justify: Class Default
						Width:  0.663"
						Width Editable? Class Default
						Format: Class Default
						Country: Class Default
						Input Mask: Class Default
						Cell Options
							Cell Type? Class Default
							Multiline Cell? Class Default
							Cell DropDownList
								Sorted? Class Default
								Vertical Scroll? Class Default
								Auto Drop Down? Class Default
								Allow Text Editing? Class Default
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Class Default
						List Values
						Message Actions
							On PAM_SETINSTANCEVARS
								Set colYear.sSQLCOLNAME = ' CUSTOMER_ORDER.YEAR_OF_SALE '
								Set colYear.bInsert = FALSE
								Set colYear.bUpdate = FALSE
							On PAM_COPYROWINFOFROM
								Call SalTblFetchRow( hWndForm, lParam )
								Set nTemp = colYear
								!
								!
								! Call SalTblFetchRow( hWndForm, lParam )
								! Set sTemp = VisTblGetCell( hWndForm, lParam, hWndItem )
								! Select Case SalGetDataType( hWndItem )
									                                                                                                                              Case DT_Boolean
										                                                                                                                              If SalStrToNumber( sTemp )
											                                                                                                                              Set bTemp = TRUE
										                                                                                                                              Else 
											                                                                                                                              Set bTemp = FALSE
										                                                                                                                              Break 
									                                                                                                                              Case DT_DateTime
										                                                                                                                              Set dtTemp = SalStrToDate( sTemp )
										                                                                                                                              Break 
									                                                                                                                              Case DT_Number
										                                                                                                                              Set nTemp = SalStrToNumber( sTemp )
										                                                                                                                              Break 
							On PAM_COPYROWINFOTO
								Call SalTblFetchRow( hWndForm, lParam )
								Set colYear = nTemp
							On PAM_DATAVAL
								If colYear = frmNewCustOrdOnLoad.dfYear
									Return TRUE
								Else
									If colBatchLocationId > 0
										Return TRUE
									Else
										Call ErrorMessage( 'This stock item year does not match the current year! Please rectify! ', hWndForm, lParam )
										Return FALSE
					Column: colItemNo

			Data Field: dfCustNo
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurTblQBEDataField
				Property Template:
				Class DLL Name:
				Data
					Maximum Data Length: Class Default
					Data Type: Number
					Editable? Class Default
				Display Settings
					Window Location and Size
						Left:   1.625"
						Top:    1.125"
						Width:  1.138"
						Width Editable? Class Default
						Height: 0.25"
						Height Editable? Class Default
					Visible? Class Default
					Border? Class Default
					Justify: Class Default
					Format: Class Default
					Country: Class Default
					Font Name: Class Default
					Font Size: Class Default
					Font Enhancement: Class Default
					Text Color: Class Default
					Background Color: White
					Input Mask: Class Default
				Message Actions
					On PAM_SETINSTANCEVARS
						Set OurTblQBEDataField.sSQLCOLNAME = 'CUSTOMER_MASTER.CUST_NO'
						Set OurTblQBEDataField.sQBEOperand = EQOPERAND
					On PAM_QBE
						If NOT SalIsNull( hWndItem )
							Call SalSendClassMessage( PAM_QBE, wParam, lParam )
						Else
							If rbMeetAddrForLoad
								If SalTblAnyRows( tblMeetsOnLoad, ROW_Selected, 0 )
									Set sMeets = ''
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblMeetsOnLoad, nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( tblMeetsOnLoad, nRow )
										If sMeets = ''
											Set sMeets = ' ( ' || '\'' || tblMeetsOnLoad.colMeetId || '\''
										Else
											Set sMeets = sMeets || ', ' || '\'' || tblMeetsOnLoad.colMeetId || '\''
									Set sMeets = sMeets || ' ) '
									Set sMeets = ' ( SELECT Cust_No FROM Customer_Address WHERE Address_Meet_Id IN ' || sMeets || ' ) '
									Call PushString( sMeets )
									Call PushString( ' IN ' )
									Call PushString( STRINGHDLFOLLOWING )
									Call PushString( OurTblQBEDataField.sSQLCOLNAME )
									Return TRUE
								Else
									Return FALSE
							Else
								If SalTblAnyRows( tblAllMeets, ROW_Selected, 0 )
									Set sMeets = ''
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblAllMeets, nRow, ROW_Selected, 0 )
										Call SalTblFetchRow( tblAllMeets, nRow )
										If sMeets = ''
											Set sMeets = ' ( ' || '\'' || tblAllMeets.colMeetId || '\''
										Else
											Set sMeets = sMeets || ', ' || '\'' || tblAllMeets.colMeetId || '\''
									Set sMeets = sMeets || ' ) '
									Set sMeets = ' ( SELECT Cust_No FROM Customer_Address WHERE Address_Meet_Id IN ' || sMeets || ' ) '
									Call PushString( sMeets )
									Call PushString( ' IN ' )
									Call PushString( STRINGHDLFOLLOWING )
									Call PushString( OurTblQBEDataField.sSQLCOLNAME )
									Return TRUE
								Else
									Return FALSE

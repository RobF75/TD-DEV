			Pushbutton: pbMoveCustOrdLoadToLoad
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Move Customers Orders Load To Load
				Window Location and Size
					Left:   3.3"
					Top:    0.115"
					Width:  3.05"
					Width Editable? Class Default
					Height: 0.156"
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Courier New
				Font Size: 8
				Font Enhancement: None
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalSendMsg( tblCustOrders, PAM_VALIDATESELECTION, 0, 0 )
							Set nPos = 0
							Set dtaOrdDTs[ nPos ] = DATETIME_Null
							!
							Set nRow = TBL_MinRow
							While SalTblFindNextRow( tblCustOrders, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblCustOrders, nRow )
								Set dtaOrdDTs[ nPos ] = tblCustOrders.colOrderDateTime
								Set nPos = nPos + 1
								Set dtaOrdDTs[ nPos ] = DATETIME_Null
							!
							If nPos = 0 
								Call SalMessageBox( 'Please select orders first!', 'Warning', MB_Ok )
								Return FALSE
							Else
								If SalModalDialog( dlgMoveCustOrdLinesLoadToLoad, hWndForm, dfLoadId, dfCustNo, dtaOrdDTs )
									! customer order was removed from this load and put onto another load.
											  however he is still in the populated table and the result set.
											  The next code removes the customer from the table and the result set
									Set nRow = TBL_MinRow
									While SalTblFindNextRow( tblCustOrders, nRow, ROW_Selected, 0 )
										Call SalTblDeleteRow( tblCustOrders, nRow, TBL_Adjust )
										Set nRow = nRow - 1
			!

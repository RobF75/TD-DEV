.head 7 -  Set hWndChild = SalGetNextChild( hWndChild, TYPE_DataField | TYPE_ComboBox | TYPE_CheckBox )
.head 6 -  !
.head 6 +  If bShowQueryMsg
.head 7 +  If sBuildWhere = ''
.head 8 +  If IDYES = SalMessageBox( 'No query conditions specified.  This could be quite time consuming! Continue?', 'Warning', MB_YesNo | MB_DefButton2 )

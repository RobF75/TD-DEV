		Application Actions
			On SAM_AppStartup
				If strArgArray[0] = ''
					Set SqlDatabase = 'STOCKDEV'
					Set SqlUser = 'GRAHAM'
					Set SqlPassword = 'GRAHAM'
				Else
					Set SqlDatabase = strArgArray[1]
					Set SqlUser = strArgArray[2]
					Set SqlPassword = strArgArray[3]
				!
				! Set strArgArray[4] = '333849'
				! Set strArgArray[5] = '1998-06-01'
				! Set strArgArray[6] = '1998-8-25'
				! Set strArgArray[7] = 'F'
				!
				Call CheckProgramExistance( 'Debtors Transaction Ledger Report', TRUE )
				!
				Call SqlHandlesSetup(  )
			On SAM_AppExit
				Call SqlHandlesDisconnectClose(  )

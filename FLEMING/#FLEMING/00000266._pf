			Number: nCountSectionResultSet
			Number: nCountSectionPos
			!
			Number: nSectionSubTotal
			Number: nReportTotal
			!
			! Report Columns
			Number: nCustNo
			String: sCustName
			Date/Time: dtFromDate
			Date/Time: dtToDate
			Number: nCurrentARBalance
			Number: nChildARSum
			String: sSectionHeading
			!
			Date/Time: dtTransDate
			String: sTransReferenceId
			String: sTransType
			Number: nTransAmount
			Number: nTotalTransAmount
			!
			Number: nReportBalance
			Number: nParentCustNo
			!
			String: sCompany
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set sReportFileNameNoPath = 'trledgr1.qrp'
				Set sReportBind = ':frmTransLedger.nParentCustNo, 
						:frmTransLedger.sCustName, 
						:frmTransLedger.dtFromDate, 
						:frmTransLedger.dtToDate, 
						:frmTransLedger.nCurrentARBalance, 
						:frmTransLedger.sSectionHeading, 
						:frmTransLedger.dtTransDate, 
						:frmTransLedger.sTransReferenceId, 
						:frmTransLedger.sTransType, 
						:frmTransLedger.nTransAmount, 
						:frmTransLedger.nTotalTransAmount, 
						:frmTransLedger.nReportBalance,
						:frmTransLedger.sCompany'
				Set sReportInto = 'nCustNo, 
						sCustName, 
						dtFromDate, 
						dtToDate, 
						nCurrentARBalance, 
						sSectionHeading, 
						dtTransDate, 
						sTransReferenceId, 
						sTransType, 
						nTransAmount, 
						nTotalTransAmount, 
						nReportBalance,
						sCompany'
				Set sReportType = 'VIEW'
			On SAM_ReportStart
				Return TRUE
			On SAM_ReportFetchInit
				Set bProcessCustDetails = TRUE
				Set bFirstProcessOfSection = TRUE
				Set bProcessInvoices = FALSE
				Set bProcessCashReceipts = FALSE
				Set bProcessCreditNotes = FALSE
				Set bProcessCRJournals = FALSE
				Set bProcessDRJournals = FALSE
				Set bProcessDepositsPaid = FALSE
				Set bPrintedDeposit = FALSE
				!
				Set nCustNo = SalStrToNumber( strArgArray[4] )
				Set sCustName = ''
				Set dtFromDate = SalStrToDate( strArgArray[5] )
				Set dtToDate = SalStrToDate( strArgArray[6] )
				Set sCompany = strArgArray[7]
				! TEmp
				! Set nCustNo = 310178
				! Set sCustName = ''
				! Set dtFromDate = 1996-06-01-00.00.00.000000
				! Set dtToDate = 1997-05-31-00.00.00.000000
				! !
				Set nCurrentARBalance = NUMBER_Null
				Set sSectionHeading = ''
				Set dtTransDate = DATETIME_Null
				Set sTransReferenceId = ''
				Set sTransType = ''
				Set nTransAmount = NUMBER_Null
				Set nTotalTransAmount = NUMBER_Null
				!
				Set nSectionSubTotal = NUMBER_Null
				Set nReportTotal = NUMBER_Null
				Set nParentCustNo = nCustNo
				Return TRUE
			On SAM_ReportFetchNext
				Loop
					If bProcessCustDetails
						If bFirstProcessOfSection
							Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'TransactionLedger' )
							Set bFirstProcessOfSection = FALSE
							Set sSql = " SELECT 
									  Customer_Master.Cust_Name, 
									  Customer_Master.Cust_AR_Balance
									FROM 
									  Customer_Master 
									WHERE 
									  Customer_Master.Cust_No = :1 "
							Set sName = 'TrLedger'
							Set sBind = ':frmTransLedger.nCustNo'
							Set sInto = ':frmTransLedger.sCustName, 
									  :frmTransLedger.nCurrentARBalance '
							! !
							Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
							! !
							If NOT haSqlHandles[nSqlHandleNo].Execute( )
								Return FALSE
						If haSqlHandles[nSqlHandleNo].FetchNext( nInd )
							Set bProcessCustDetails = FALSE
							Set bProcessInvoices = TRUE
							Set bFirstProcessOfSection = TRUE
						Else
							Return FALSE
					If bProcessInvoices
						If bFirstProcessOfSection
							Set bFirstProcessOfSection = FALSE
							! !
							Set nSqlHandleNoChild = SqlHandlesGetReferenceNo( 'TransLedgerChildren' )
							Set nSqlHandleNoSumChild = SqlHandlesGetReferenceNo( 'ARSumChildren' )
							Set nSqlHandleNoInv = SqlHandlesGetReferenceNo( 'ChildInv' )
							!
							Set sSql = " SELECT 
									     Customer_Master.Cust_No
									   FROM 
									  Customer_Master 
									WHERE 
									  Customer_Master.Ass_Cust_No = :1 
									 ORDER BY CUST_NO"
							Set sName = 'TrLedgerChild'
							Set sBind = ':frmTransLedger.nParentCustNo'
							Set sInto = ' :frmTransLedger.nCustNo '
							! !
							Call haSqlHandles[ nSqlHandleNoChild ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoChild ].hSqlHandle )
							! !
							Call haSqlHandles[nSqlHandleNoChild].Execute( )
							!
							Set sSql = " SELECT SUM( Customer_Master.Cust_AR_Balance)
									   FROM 
									  Customer_Master 
									WHERE 
									  Customer_Master.Ass_Cust_No = :1 
									 ORDER BY CUST_NO"
							Set sName = 'ARSumChild'
							Set sBind = ':frmTransLedger.nParentCustNo'
							Set sInto = ' :frmTransLedger.nChildARSum '
							! !
							Call haSqlHandles[ nSqlHandleNoSumChild ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoSumChild ].hSqlHandle )
							! !
							Call haSqlHandles[nSqlHandleNoSumChild].Execute( )
							If haSqlHandles[nSqlHandleNoSumChild].FetchNext( nInd)
								Set frmTransLedger.nCurrentARBalance = frmTransLedger.nCurrentARBalance + frmTransLedger.nChildARSum
							!
							Set sSql = "SELECT 
									  Transaction.Transaction_Date, 
									  Transaction.Reference_Id, 
									  Transaction.Transaction_Amount
									FROM 
									  Transaction 
									WHERE 
									  Transaction.Cust_No = :1 AND 
									  Transaction.Transaction_Type = 'INVOICE' AND 
									  Transaction.Transaction_Date BETWEEN :2 AND :3 and
									Transaction.Company = :4
									UNION ALL 
									SELECT 
									  Trans_History.Hist_Trans_Date, 
									  Trans_History.Hist_Reference_Id, 
									  Trans_History.Hist_Trans_Amount
									FROM 
									  Trans_History 
									WHERE 
									  Trans_History.Cust_No = :1 AND 
									  Trans_History.Hist_Trans_Type = 'INVOICE' AND 
									  Trans_History.Hist_Trans_Date BETWEEN :2 AND :3 and
									Trans_History.Hist_Company = :4
									ORDER BY 1 "
							Set sName = 'ChildInv1'
							Set sBind = ':frmTransLedger.nCustNo, :frmTransLedger.dtFromDate, :frmTransLedger.dtToDate, :sCompany  '
							Set sInto = ' :frmTransLedger.dtTransDate, 
									  :frmTransLedger.sTransReferenceId, 
									  :frmTransLedger.nTransAmount '
							! !
							Call haSqlHandles[ nSqlHandleNoInv ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoInv ].hSqlHandle )
							! !
							Call haSqlHandles[nSqlHandleNoInv].Execute( )
							Call haSqlHandles[nSqlHandleNoInv].ResultSetCount( nCountSectionResultSet )
							Set nCountSectionPos = 0
							!
							Set sSectionHeading = 'Invoices'
							Set nSectionSubTotal = NUMBER_Null
						If haSqlHandles[nSqlHandleNoInv].FetchNext( nInd )
							! Set nSectionSubTotal = nSectionSubTotal + nTransAmount
							! Set nCountSectionPos = nCountSectionPos + 1
							! If nCountSectionPos = nCountSectionResultSet
								  Set nTotalTransAmount = nSectionSubTotal
								  Set nReportTotal = nReportTotal + nSectionSubTotal
							Set nReportTotal = nReportTotal + nTransAmount
							Return TRUE
						Else
							If haSqlHandles[nSqlHandleNoChild].FetchNext (nInd)
								Call haSqlHandles[nSqlHandleNoInv].Execute( )
							Else
								Set bProcessInvoices = FALSE
								Set bProcessCashReceipts = TRUE
								Set bFirstProcessOfSection = TRUE
								! DMF 21/5/96
								Set nTotalTransAmount = NUMBER_Null
					If bProcessCashReceipts
						If bFirstProcessOfSection
							Set bFirstProcessOfSection = FALSE
							Set nSqlHandleNoCash = SqlHandlesGetReferenceNo( 'ChildCash' )
							! Set the children back to the beginning of the result set
							Call haSqlHandles[nSqlHandleNoChild].Execute ( )
							Set nCustNo = nParentCustNo
							!
							Set sSql = "SELECT 
									  Cash_Receipt.Receipt_Date, 
									  Cash_Receipt.Receipt_Type, 
									  Cash_Receipt.Receipt_Amount 
									FROM 
									  Cash_Receipt 
									WHERE 
									  Cash_Receipt.Cust_No = :1 AND 
									  Cash_Receipt.Receipt_Date BETWEEN :2 AND :3 AND 
									  NOT EXISTS 
									  ( SELECT 
									      Dep_Sysdatetime 
									    FROM 
									      Outstand_Deposit 
									    WHERE 
									      Outstand_Deposit.Receipt_User_Id = Cash_Receipt.Receipt_User_Id AND 
									      Outstand_Deposit.Rcpt_Sysdatetime = Cash_Receipt.Rcpt_Sysdatetime  and
										Outstand_Deposit.Company = :4
									  ) "
							Set sName = 'ChildCash1'
							Set sBind = ':frmTransLedger.nCustNo, :frmTransLedger.dtFromDate, :frmTransLedger.dtToDate , ;sCompany '
							Set sInto = ' :frmTransLedger.dtTransDate, 
									  :frmTransLedger.sTransReferenceId, 
									  :frmTransLedger.nTransAmount '
							! !
							Call haSqlHandles[ nSqlHandleNoCash ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoCash ].hSqlHandle )
							! !
							Call haSqlHandles[nSqlHandleNoCash].Execute( )
							Call haSqlHandles[nSqlHandleNoCash].ResultSetCount( nCountSectionResultSet )
							Set nCountSectionPos = 0
							!
							Set sSectionHeading = 'Less Cash Receipts'
							Set nSectionSubTotal = NUMBER_Null
						If haSqlHandles[nSqlHandleNoCash].FetchNext( nInd )
							! Set nSectionSubTotal = nSectionSubTotal + nTransAmount
							! Set nCountSectionPos = nCountSectionPos + 1
							! If nCountSectionPos = nCountSectionResultSet
								  Set nTotalTransAmount = nSectionSubTotal
								  Set nReportTotal = nReportTotal - nSectionSubTotal
							Set nReportTotal = nReportTotal - nTransAmount
							Return TRUE
						Else
							If haSqlHandles[nSqlHandleNoChild].FetchNext (nInd)
								Call haSqlHandles[nSqlHandleNoCash].Execute( )
							Else
								Set bProcessCashReceipts = FALSE
								Set bProcessCreditNotes = TRUE
								Set bFirstProcessOfSection = TRUE
								! DMF 21/5/96
								Set nTotalTransAmount = NUMBER_Null
					If bProcessCreditNotes
						If bFirstProcessOfSection
							Set bFirstProcessOfSection = FALSE
							Set nSqlHandleNoCredit = SqlHandlesGetReferenceNo( 'ChildCredit' )
							! Set the children back to the beginning of the result set
							Call haSqlHandles[nSqlHandleNoChild].Execute ( )
							Set nCustNo = nParentCustNo
							!
							Set sSql = "SELECT 
									  Transaction.Transaction_Date, 
									  Transaction.Reference_Id, 
									  Transaction.Transaction_Amount
									FROM 
									  Transaction 
									WHERE 
									  Transaction.Cust_No = :1 AND 
									  Transaction.Transaction_Type = 'CREDNOTE' AND 
									  Transaction.Transaction_Date BETWEEN :2 AND :3 and
									Transaction.Company = :4
									UNION ALL 
									SELECT 
									  Trans_History.Hist_Trans_Date, 
									  Trans_History.Hist_Reference_Id, 
									  Trans_History.Hist_Trans_Amount
									FROM 
									  Trans_History 
									WHERE 
									  Trans_History.Cust_No = :1 AND 
									  Trans_History.Hist_Trans_Type = 'CREDNOTE' AND 
									  Trans_History.Hist_Trans_Date BETWEEN :2 AND :3 and
									Trans_History.Hist_Company = :4
									ORDER BY 1 "
							!
							Set sName = 'ChildCredit1'
							Set sBind = ':frmTransLedger.nCustNo, :frmTransLedger.dtFromDate, :frmTransLedger.dtToDate, :sCompany  '
							Set sInto = ' :frmTransLedger.dtTransDate, 
									  :frmTransLedger.sTransReferenceId, 
									  :frmTransLedger.nTransAmount '
							! !
							Call haSqlHandles[ nSqlHandleNoCredit ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoCredit ].hSqlHandle )
							! !
							Call haSqlHandles[nSqlHandleNoCredit].Execute( )
							Call haSqlHandles[nSqlHandleNoCredit].ResultSetCount( nCountSectionResultSet )
							Set nCountSectionPos = 0
							!
							Set sSectionHeading = 'Less Credit Notes'
							Set nSectionSubTotal = NUMBER_Null
						If haSqlHandles[nSqlHandleNoCredit].FetchNext( nInd )
							! Set nSectionSubTotal = nSectionSubTotal + nTransAmount
							! Set nCountSectionPos = nCountSectionPos + 1
							! If nCountSectionPos = nCountSectionResultSet
								  Set nTotalTransAmount = nSectionSubTotal
								  Set nReportTotal = nReportTotal - nSectionSubTotal
							Set nReportTotal = nReportTotal - nTransAmount
							Return TRUE
						Else
							If haSqlHandles[nSqlHandleNoChild].FetchNext (nInd)
								Call haSqlHandles[nSqlHandleNoCredit].Execute( )
							Else
								Set bProcessCreditNotes = FALSE
								Set bProcessCRJournals = TRUE
								Set bFirstProcessOfSection = TRUE
								! DMF 21/5/96
								Set nTotalTransAmount = NUMBER_Null
					If bProcessCRJournals
						If bFirstProcessOfSection
							Set bFirstProcessOfSection = FALSE
							Set nSqlHandleNoCRJnl = SqlHandlesGetReferenceNo( 'ChildCRJnl' )
							! Set the children back to the beginning of the result set
							Call haSqlHandles[nSqlHandleNoChild].Execute ( )
							Set nCustNo = nParentCustNo
							!
							Set sSql = "SELECT 
									    Transaction.Transaction_Date, 
									    Transaction.Reference_Id, 
									    Transaction.Transaction_Amount
									  FROM 
									    Transaction 
									  WHERE 
									    Transaction.Cust_No = :1 AND 
									    NOT Transaction.Transaction_Type IN ('INVOICE','CREDNOTE') AND
									    Transaction.Transaction_Code = 'CR' AND 
									    Transaction.Transaction_Date BETWEEN :2 AND :3 and
									Transaction.Company = :4
									  UNION ALL 
									  SELECT 
									    Trans_History.Hist_Trans_Date, 
									    Trans_History.Hist_Reference_Id, 
									    Trans_History.Hist_Trans_Amount
									  FROM 
									    Trans_History 
									  WHERE 
									    Trans_History.Cust_No = :1 AND 
									    NOT Trans_History.Hist_Trans_Type IN ('INVOICE','CREDNOTE') AND
									    Trans_History.Hist_Trans_Code = 'CR' AND  
									    Trans_History.Hist_Trans_Date BETWEEN :2 AND :3 and
									Trans_History.Hist_Company = :4
									  ORDER BY 1 "
							!
							Set sName = 'ChildCRJnl1'
							Set sBind = ':frmTransLedger.nCustNo, :frmTransLedger.dtFromDate, :frmTransLedger.dtToDate, :sCompany  '
							Set sInto = ' :frmTransLedger.dtTransDate, 
									  :frmTransLedger.sTransReferenceId, 
									  :frmTransLedger.nTransAmount '
							! !
							Call haSqlHandles[ nSqlHandleNoCRJnl ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoCRJnl ].hSqlHandle )
							! !
							Call haSqlHandles[nSqlHandleNoCRJnl].Execute( )
							Call haSqlHandles[nSqlHandleNoCRJnl].ResultSetCount( nCountSectionResultSet )
							Set nCountSectionPos = 0
							!
							Set sSectionHeading = 'CR Journals'
							Set nSectionSubTotal = NUMBER_Null
						If haSqlHandles[nSqlHandleNoCRJnl].FetchNext( nInd )
							! Set nSectionSubTotal = nSectionSubTotal + nTransAmount
							! Set nCountSectionPos = nCountSectionPos + 1
							! If nCountSectionPos = nCountSectionResultSet
								  Set nTotalTransAmount = nSectionSubTotal
								  Set nReportTotal = nReportTotal - nSectionSubTotal
							Set nReportTotal = nReportTotal - nTransAmount
							Return TRUE
						Else
							If haSqlHandles[nSqlHandleNoChild].FetchNext (nInd)
								Call haSqlHandles[nSqlHandleNoCRJnl].Execute( )
							Else
								Set bProcessCRJournals = FALSE
								Set bProcessDRJournals = TRUE
								Set bFirstProcessOfSection = TRUE
								! DMF 21/5/96
								Set nTotalTransAmount = NUMBER_Null
					If bProcessDRJournals
						If bFirstProcessOfSection
							Set bFirstProcessOfSection = FALSE
							Set nSqlHandleNoDRJnl = SqlHandlesGetReferenceNo( 'ChildDRJnl' )
							! Set the children back to the beginning of the result set
							Call haSqlHandles[nSqlHandleNoChild].Execute ( )
							Set nCustNo = nParentCustNo
							!
							Set sSql = "SELECT 
									    Transaction.Transaction_Date, 
									    Transaction.Reference_Id, 
									    Transaction.Transaction_Amount
									  FROM 
									    Transaction 
									  WHERE 
									    Transaction.Cust_No = :1 AND 
									    NOT Transaction.Transaction_Type = 'INVOICE' AND
									    Transaction.Transaction_Code = 'DR' AND 
									    Transaction.Transaction_Date BETWEEN :2 AND :3 and
									Transaction.Company = :4
									  UNION ALL 
									  SELECT 
									    Trans_History.Hist_Trans_Date, 
									    Trans_History.Hist_Reference_Id, 
									    Trans_History.Hist_Trans_Amount
									  FROM 
									    Trans_History 
									  WHERE 
									    Trans_History.Cust_No = :1 AND 
									    NOT Trans_History.Hist_Trans_Type = 'INVOICE' AND
									    Trans_History.Hist_Trans_Code = 'DR' AND  
									    Trans_History.Hist_Trans_Date BETWEEN :2 AND :3 and
									Trans_History.Hist_Company = :4
									    ORDER BY 1 "
							!
							Set sName = 'ChildDRJnl1'
							Set sBind = ':frmTransLedger.nCustNo, :frmTransLedger.dtFromDate, :frmTransLedger.dtToDate :sCompany '
							Set sInto = ' :frmTransLedger.dtTransDate, 
									  :frmTransLedger.sTransReferenceId, 
									  :frmTransLedger.nTransAmount '
							! !
							Call haSqlHandles[ nSqlHandleNoDRJnl ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoDRJnl ].hSqlHandle )
							! !
							Call haSqlHandles[nSqlHandleNoDRJnl].Execute( )
							Call haSqlHandles[nSqlHandleNoDRJnl].ResultSetCount( nCountSectionResultSet )
							Set nCountSectionPos = 0
							!
							Set sSectionHeading = 'DR Journals'
							Set nSectionSubTotal = NUMBER_Null
						If haSqlHandles[nSqlHandleNoDRJnl].FetchNext( nInd )
							! Set nSectionSubTotal = nSectionSubTotal + nTransAmount
							! Set nCountSectionPos = nCountSectionPos + 1
							! If nCountSectionPos = nCountSectionResultSet
								  Set nTotalTransAmount = nSectionSubTotal
								  Set nReportTotal = nReportTotal + nSectionSubTotal
							Set nReportTotal = nReportTotal + nTransAmount
							Return TRUE
						Else
							If haSqlHandles[nSqlHandleNoChild].FetchNext (nInd)
								Call haSqlHandles[nSqlHandleNoDRJnl].Execute( )
							Else
								Set bProcessDRJournals = FALSE
								Set bProcessBalance = TRUE
								Set bFirstProcessOfSection = TRUE
								! DMF 21/5/96
								Set nTotalTransAmount = NUMBER_Null
					If bProcessBalance
						Set dtTransDate = DATETIME_Null
						Set sTransReferenceId = ''
						Set nTransAmount = NUMBER_Null
						Set nCountSectionPos = 0
						Set sSectionHeading = ''
						Set nSectionSubTotal = NUMBER_Null
						!
						Set nTotalTransAmount = NUMBER_Null
						!
						Set nReportBalance = nReportTotal
						!
						Set bProcessBalance = FALSE
						Set bProcessDepositsPaid = TRUE
						Set bFirstProcessOfSection = TRUE
						!
						! Return TRUE
					If bProcessDepositsPaid
						If bFirstProcessOfSection
							Set bFirstProcessOfSection = FALSE
							Set nSqlHandleNoDep = SqlHandlesGetReferenceNo( 'ChildDep' )
							! Set the children back to the beginning of the result set
							Call haSqlHandles[nSqlHandleNoChild].Execute ( )
							Set nCustNo = nParentCustNo
							!
							Set sSql = "SELECT 
									  Outstand_Deposit.Deposit_Paid_Date, 
									  'DEPOSIT', 
									  Outstand_Deposit.Dep_Amount_Paid
									FROM 
									  Outstand_Deposit 
									WHERE 
									  Outstand_Deposit.Cust_No = :1 AND 
									  Outstand_Deposit.Dep_Amount_Paid > 0 AND 
									  Outstand_Deposit.Deposit_Paid_Date BETWEEN :2 AND :3 and
									Outstand_Deposit.Company = :4 "
							!
							Set sName = 'ChildDep1'
							Set sBind = ':frmTransLedger.nCustNo, :frmTransLedger.dtFromDate, :frmTransLedger.dtToDate, :sCompany  '
							Set sInto = ' :frmTransLedger.dtTransDate, 
									  :frmTransLedger.sTransReferenceId, 
									  :frmTransLedger.nTransAmount '
							! !
							Call haSqlHandles[ nSqlHandleNoDep ].Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( haSqlHandles[ nSqlHandleNoDep ].hSqlHandle )
							! !
							Call haSqlHandles[nSqlHandleNoDep].Execute( )
							Call haSqlHandles[nSqlHandleNoDep].ResultSetCount( nCountSectionResultSet )
							Set nCountSectionPos = 0
							!
							Set sSectionHeading = 'Deposits Paid'
							Set nSectionSubTotal = NUMBER_Null
						If haSqlHandles[nSqlHandleNoDep].FetchNext( nInd )
							! Set nSectionSubTotal = nSectionSubTotal + nTransAmount
							! Set nCountSectionPos = nCountSectionPos + 1
							! If nCountSectionPos = nCountSectionResultSet
								  Set nTotalTransAmount = nSectionSubTotal
							Set bPrintedDeposit = TRUE
							Set nTotalTransAmount = nTotalTransAmount + nTransAmount
							Return TRUE
						Else
							If haSqlHandles[nSqlHandleNoChild].FetchNext (nInd)
								Call haSqlHandles[nSqlHandleNoDep].Execute( )
							Else
								Set bProcessDepositsPaid = FALSE
								Set bFirstProcessOfSection = FALSE
								! If we havent printed a deposit we want it to return TRUE to print totals and then return FALSE from
										customer - otherwise just return FALSE here 
								If bPrintedDeposit = TRUE
									Return FALSE
								Set bProcessCustDetails = TRUE
								Return TRUE
				! Return TRUE
			! On SAM_ReportFetchNext
				  If bProcessCustDetails
					  If bFirstProcessOfSection
						  Set bFirstProcessOfSection = FALSE
						  Set sSql = " SELECT 
								  Customer_Master.Cust_Name, 
								  Customer_Master.Cust_AR_Balance 
								FROM 
								  Customer_Master 
								INTO 
								  :frmTransLedger.sCustName, 
								  :frmTransLedger.nCurrentARBalance 
								WHERE 
								  Customer_Master.Cust_No = :frmTransLedger.nCustNo "
						  Call fcCustDetsHdl.PrepareSetup( sSql )
						  Call SqlVarSetup( fcCustDetsHdl.hSqlHandle )
						!
						  Call fcCustDetsHdl.PrepareAndExecute( )
					  If fcCustDetsHdl.FetchNext( nInd )
						  Set bProcessCustDetails = FALSE
						  Set bProcessInvoices = TRUE
						  Set bFirstProcessOfSection = TRUE
					  Else 
						  Return FALSE
				  If bProcessInvoices
					  If bFirstProcessOfSection
						  Set bFirstProcessOfSection = FALSE
						  Set sSql = "SELECT 
								  Transaction.Transaction_Date, 
								  Transaction.Reference_Id, 
								  Transaction.Transaction_Amount
								FROM 
								  Transaction 
								WHERE 
								  Transaction.Cust_No = :frmTransLedger.nCustNo AND 
								  Transaction.Transaction_Type = 'INVOICE' AND 
								  Transaction.Transaction_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate 
								UNION ALL 
								SELECT 
								  Trans_History.Hist_Trans_Date, 
								  Trans_History.Hist_Reference_Id, 
								  Trans_History.Hist_Trans_Amount
								FROM 
								  Trans_History 
								WHERE 
								  Trans_History.Cust_No = :frmTransLedger.nCustNo AND 
								  Trans_History.Hist_Trans_Type = 'INVOICE' AND 
								  Trans_History.Hist_Trans_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate 
								INTO 
								  :frmTransLedger.dtTransDate, 
								  :frmTransLedger.sTransReferenceId, 
								  :frmTransLedger.nTransAmount
								ORDER BY 1 "
						  Call fcInvoicesHdl.PrepareSetup( sSql )
						  Call SqlVarSetup( fcInvoicesHdl.hSqlHandle )
						!
						  Call fcInvoicesHdl.PrepareAndExecute( )
						  Call fcInvoicesHdl.ResultSetCount( nCountSectionResultSet )
						  Set nCountSectionPos = 0
						!
						  Set sSectionHeading = 'Invoices'
						  Set nSectionSubTotal = NUMBER_Null
					  If fcInvoicesHdl.FetchNext( nInd )
						  Set nSectionSubTotal = nSectionSubTotal + nTransAmount
						  Set nCountSectionPos = nCountSectionPos + 1
						  If nCountSectionPos = nCountSectionResultSet
							  Set nTotalTransAmount = nSectionSubTotal
							  Set nReportTotal = nReportTotal + nSectionSubTotal
						  Return TRUE
					  Else 
						  Set bProcessInvoices = FALSE
						  Set bProcessCashReceipts = TRUE
						  Set bFirstProcessOfSection = TRUE
						! DMF 21/5/96
						  Set nTotalTransAmount = NUMBER_Null
				  If bProcessCashReceipts
					  If bFirstProcessOfSection
						  Set bFirstProcessOfSection = FALSE
						  Set sSql = "SELECT 
								  Cash_Receipt.Receipt_Date, 
								  Cash_Receipt.Receipt_Type, 
								  Cash_Receipt.Receipt_Amount 
								FROM 
								  Cash_Receipt 
								INTO 
								  :frmTransLedger.dtTransDate, 
								  :frmTransLedger.sTransReferenceId, 
								  :frmTransLedger.nTransAmount
								WHERE 
								  Cash_Receipt.Cust_No = :frmTransLedger.nCustNo AND 
								  Cash_Receipt.Receipt_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate AND 
								  NOT EXISTS 
								  ( SELECT 
								      Dep_Sysdatetime 
								    FROM 
								      Outstand_Deposit 
								    WHERE 
								      Outstand_Deposit.Receipt_User_Id = Cash_Receipt.Receipt_User_Id AND 
								      Outstand_Deposit.Rcpt_Sysdatetime = Cash_Receipt.Rcpt_Sysdatetime  
								  ) "
						  Call fcCashReceiptsHdl.PrepareSetup( sSql )
						  Call SqlVarSetup( fcCashReceiptsHdl.hSqlHandle )
						!
						  Call fcCashReceiptsHdl.PrepareAndExecute( )
						  Call fcCashReceiptsHdl.ResultSetCount( nCountSectionResultSet )
						  Set nCountSectionPos = 0
						!
						  Set sSectionHeading = 'Less Cash Receipts'
						  Set nSectionSubTotal = NUMBER_Null
					  If fcCashReceiptsHdl.FetchNext( nInd )
						  Set nSectionSubTotal = nSectionSubTotal + nTransAmount
						  Set nCountSectionPos = nCountSectionPos + 1
						  If nCountSectionPos = nCountSectionResultSet
							  Set nTotalTransAmount = nSectionSubTotal
							  Set nReportTotal = nReportTotal - nSectionSubTotal
						  Return TRUE
					  Else 
						  Set bProcessCashReceipts = FALSE
						  Set bProcessCreditNotes = TRUE
						  Set bFirstProcessOfSection = TRUE
						! DMF 21/5/96
						  Set nTotalTransAmount = NUMBER_Null
				  If bProcessCreditNotes
					  If bFirstProcessOfSection
						  Set bFirstProcessOfSection = FALSE
						  Set sSql = "SELECT 
								  Transaction.Transaction_Date, 
								  Transaction.Reference_Id, 
								  Transaction.Transaction_Amount
								FROM 
								  Transaction 
								WHERE 
								  Transaction.Cust_No = :frmTransLedger.nCustNo AND 
								  Transaction.Transaction_Type = 'CREDNOTE' AND 
								  Transaction.Transaction_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate 
								UNION ALL 
								SELECT 
								  Trans_History.Hist_Trans_Date, 
								  Trans_History.Hist_Reference_Id, 
								  Trans_History.Hist_Trans_Amount
								FROM 
								  Trans_History 
								WHERE 
								  Trans_History.Cust_No = :frmTransLedger.nCustNo AND 
								  Trans_History.Hist_Trans_Type = 'CREDNOTE' AND 
								  Trans_History.Hist_Trans_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate 
								INTO 
								  :frmTransLedger.dtTransDate, 
								  :frmTransLedger.sTransReferenceId, 
								  :frmTransLedger.nTransAmount
								ORDER BY 1 "
						  Call fcCreditNotesHdl.PrepareSetup( sSql )
						  Call SqlVarSetup( fcCreditNotesHdl.hSqlHandle )
						!
						  Call fcCreditNotesHdl.PrepareAndExecute( )
						  Call fcCreditNotesHdl.ResultSetCount( nCountSectionResultSet )
						  Set nCountSectionPos = 0
						!
						  Set sSectionHeading = 'Less Credit Notes'
						  Set nSectionSubTotal = NUMBER_Null
					  If fcCreditNotesHdl.FetchNext( nInd )
						  Set nSectionSubTotal = nSectionSubTotal + nTransAmount
						  Set nCountSectionPos = nCountSectionPos + 1
						  If nCountSectionPos = nCountSectionResultSet
							  Set nTotalTransAmount = nSectionSubTotal
							  Set nReportTotal = nReportTotal - nSectionSubTotal
						  Return TRUE
					  Else 
						  Set bProcessCreditNotes = FALSE
						  Set bProcessCRJournals = TRUE
						  Set bFirstProcessOfSection = TRUE
						! DMF 21/5/96
						  Set nTotalTransAmount = NUMBER_Null
				  If bProcessCRJournals
					  If bFirstProcessOfSection
						  Set bFirstProcessOfSection = FALSE
						  Set sSql = "SELECT 
								    Transaction.Transaction_Date, 
								    Transaction.Reference_Id, 
								    Transaction.Transaction_Amount
								  FROM 
								    Transaction 
								  WHERE 
								    Transaction.Cust_No = :frmTransLedger.nCustNo AND 
								    NOT Transaction.Transaction_Type IN ('INVOICE','CREDNOTE') AND
								    Transaction.Transaction_Code = 'CR' AND 
								    Transaction.Transaction_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate 
								  UNION ALL 
								  SELECT 
								    Trans_History.Hist_Trans_Date, 
								    Trans_History.Hist_Reference_Id, 
								    Trans_History.Hist_Trans_Amount
								  FROM 
								    Trans_History 
								  WHERE 
								    Trans_History.Cust_No = :frmTransLedger.nCustNo AND 
								    NOT Trans_History.Hist_Trans_Type IN ('INVOICE','CREDNOTE') AND
								    Trans_History.Hist_Trans_Code = 'CR' AND  
								    Trans_History.Hist_Trans_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate 
								  INTO 
								    :frmTransLedger.dtTransDate, 
								    :frmTransLedger.sTransReferenceId, 
								    :frmTransLedger.nTransAmount
								  ORDER BY 1 "
						  Call fcCRJournalsHdl.PrepareSetup( sSql )
						  Call SqlVarSetup( fcCRJournalsHdl.hSqlHandle )
						!
						  Call fcCRJournalsHdl.PrepareAndExecute( )
						  Call fcCRJournalsHdl.ResultSetCount( nCountSectionResultSet )
						  Set nCountSectionPos = 0
						!
						  Set sSectionHeading = 'CR Journals'
						  Set nSectionSubTotal = NUMBER_Null
					  If fcCRJournalsHdl.FetchNext( nInd )
						  Set nSectionSubTotal = nSectionSubTotal + nTransAmount
						  Set nCountSectionPos = nCountSectionPos + 1
						  If nCountSectionPos = nCountSectionResultSet
							  Set nTotalTransAmount = nSectionSubTotal
							  Set nReportTotal = nReportTotal - nSectionSubTotal
						  Return TRUE
					  Else 
						  Set bProcessCRJournals = FALSE
						  Set bProcessDRJournals = TRUE
						  Set bFirstProcessOfSection = TRUE
						! DMF 21/5/96
						  Set nTotalTransAmount = NUMBER_Null
				  If bProcessDRJournals
					  If bFirstProcessOfSection
						  Set bFirstProcessOfSection = FALSE
						  Set sSql = "SELECT 
								    Transaction.Transaction_Date, 
								    Transaction.Reference_Id, 
								    Transaction.Transaction_Amount
								  FROM 
								    Transaction 
								  WHERE 
								    Transaction.Cust_No = :frmTransLedger.nCustNo AND 
								    NOT Transaction.Transaction_Type = 'INVOICE' AND
								    Transaction.Transaction_Code = 'DR' AND 
								    Transaction.Transaction_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate 
								  UNION ALL 
								  SELECT 
								    Trans_History.Hist_Trans_Date, 
								    Trans_History.Hist_Reference_Id, 
								    Trans_History.Hist_Trans_Amount
								  FROM 
								    Trans_History 
								  WHERE 
								    Trans_History.Cust_No = :frmTransLedger.nCustNo AND 
								    NOT Trans_History.Hist_Trans_Type = 'INVOICE' AND
								    Trans_History.Hist_Trans_Code = 'DR' AND  
								    Trans_History.Hist_Trans_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate 
								  INTO 
								    :frmTransLedger.dtTransDate, 
								    :frmTransLedger.sTransReferenceId, 
								    :frmTransLedger.nTransAmount
								  ORDER BY 1 "
						  Call fcDRJournalsHdl.PrepareSetup( sSql )
						  Call SqlVarSetup( fcDRJournalsHdl.hSqlHandle )
						!
						  Call fcDRJournalsHdl.PrepareAndExecute( )
						  Call fcDRJournalsHdl.ResultSetCount( nCountSectionResultSet )
						  Set nCountSectionPos = 0
						!
						  Set sSectionHeading = 'DR Journals'
						  Set nSectionSubTotal = NUMBER_Null
					  If fcDRJournalsHdl.FetchNext( nInd )
						  Set nSectionSubTotal = nSectionSubTotal + nTransAmount
						  Set nCountSectionPos = nCountSectionPos + 1
						  If nCountSectionPos = nCountSectionResultSet
							  Set nTotalTransAmount = nSectionSubTotal
							  Set nReportTotal = nReportTotal + nSectionSubTotal
						  Return TRUE
					  Else 
						  Set bProcessDRJournals = FALSE
						  Set bProcessBalance = TRUE
						  Set bFirstProcessOfSection = TRUE
						! DMF 21/5/96
						  Set nTotalTransAmount = NUMBER_Null
				  If bProcessBalance
					  Set dtTransDate = DATETIME_Null
					  Set sTransReferenceId = ''
					  Set nTransAmount = NUMBER_Null
					  Set nCountSectionPos = 0
					  Set sSectionHeading = ''
					  Set nSectionSubTotal = NUMBER_Null
					!
					  Set nTotalTransAmount = NUMBER_Null
					!
					  Set nReportBalance = nReportTotal
					!
					  Set bProcessBalance = FALSE
					  Set bProcessDepositsPaid = TRUE
					  Set bFirstProcessOfSection = TRUE
					!
					  Return TRUE
				  If bProcessDepositsPaid
					  If bFirstProcessOfSection
						  Set bFirstProcessOfSection = FALSE
						  Set sSql = "SELECT 
								  Outstand_Deposit.Deposit_Paid_Date, 
								  'DEPOSIT', 
								  Outstand_Deposit.Dep_Amount_Paid
								FROM 
								  Outstand_Deposit 
								INTO 
								  :frmTransLedger.dtTransDate, 
								  :frmTransLedger.sTransReferenceId, 
								   :frmTransLedger.nTransAmount
								WHERE 
								  Outstand_Deposit.Cust_No = :frmTransLedger.nCustNo AND 
								  Outstand_Deposit.Dep_Amount_Paid > 0 AND 
								  Outstand_Deposit.Deposit_Paid_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate "
						  Call fcDepositsPaidHdl.PrepareSetup( sSql )
						  Call SqlVarSetup( fcDepositsPaidHdl.hSqlHandle )
						!
						  Call fcDepositsPaidHdl.PrepareAndExecute( )
						  Call fcDepositsPaidHdl.ResultSetCount( nCountSectionResultSet )
						  Set nCountSectionPos = 0
						!
						  Set sSectionHeading = 'Deposits Paid'
						  Set nSectionSubTotal = NUMBER_Null
					  If fcDepositsPaidHdl.FetchNext( nInd )
						  Set nSectionSubTotal = nSectionSubTotal + nTransAmount
						  Set nCountSectionPos = nCountSectionPos + 1
						  If nCountSectionPos = nCountSectionResultSet
							  Set nTotalTransAmount = nSectionSubTotal
						  Return TRUE
					  Else 
						  Set bProcessDepositsPaid = FALSE
						  Set bFirstProcessOfSection = TRUE
						  Return FALSE
				  Return TRUE
			On SAM_ReportFinish
				Call haSqlHandles[nSqlHandleNo].Disconnect( )
				Call haSqlHandles[nSqlHandleNoInv].Disconnect( )
				Call haSqlHandles[nSqlHandleNoChild].Disconnect( )
				Call haSqlHandles[nSqlHandleNoSumChild].Disconnect( )
				Call haSqlHandles[nSqlHandleNoCash].Disconnect( )
				Call haSqlHandles[nSqlHandleNoCredit].Disconnect( )
				Call haSqlHandles[nSqlHandleNoCRJnl].Disconnect( )
				Call haSqlHandles[nSqlHandleNoDRJnl].Disconnect( )
				Call haSqlHandles[nSqlHandleNoDep].Disconnect( )
				Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )

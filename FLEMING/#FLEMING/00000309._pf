						   Call PushNumber( frmStock.tblStock.colItemNo )
						   Call PushString( frmStock.tblStock.colTreeType )
						   Call PushString( frmStock.tblStock.colCultdesc )
						   Call PushString( frmStock.tblStock.colRootId )
						   Return TRUE
					   On PAM_ENABLE

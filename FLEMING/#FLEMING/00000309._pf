					Menu Item Name:
				Menu Separator
				Menu Item: &Bundles
					Resource Id: 24650
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when:
						Checked when:
					Menu Actions
						Call SalWaitCursor( TRUE )
						If SalModalDialog( dlgGetBundlesDetails, hWndForm )
							Call SalWaitCursor( TRUE )
							Call PopNumber( nYear, TRUE )
							Call PopNumber( nType, TRUE )
							Set nNumItems = 0
							If nType = nSelectedItems
								Set nNumItems = 0
								Set saItemNos[ nNumItems ] = ''
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblStock, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( tblStock, nRow )
									Set saItemNos[ nNumItems ] = SalNumberToStrX( tblStock.colItemNo, 0 )
									Set nNumItems = nNumItems + 1
									Set saItemNos[ nNumItems ] = ''
								If NOT WriteStrArrayListToFile( saItemNos, 'c:\\temp\\items.tmp' )
									Call SalMessageBox( 'Please check your C drive ( Hard Disk ) for available space!', 'Error', MB_Ok )
									Call SalWaitCursor( FALSE )
									Return FALSE
								Set sArguments = SqlDatabase || ' ' || SqlUser || ' ' || SqlPassword || ' ' || 
										'c:\\temp\\items.tmp' || ' ' || SalNumberToStrX( nYear, 0 ) || ' ' || 'SELECTED'
							Else
								Set sArguments = SqlDatabase || ' ' || SqlUser || ' ' || SqlPassword || ' ' || 
										'c:\\temp\\items.tmp' || ' ' || SalNumberToStrX( nYear, 0 ) || ' ' || 'ALL'
							!
							If SqlDatabase = 'STOCKDEV'
								Call SalLoadApp( 'PRBUNDLD', sArguments )
							Else
								Call SalLoadApp( 'PRBUNDL', sArguments )
						Call SalWaitCursor( FALSE )

		Application Actions
			On SAM_AppStartup
				! 15/2/95 Bug in allocating a confirmed amount when none was there previously fixed
				! 15/2/95 Bug in ordering stock item table and assigned inventory fixed
				! Bug in inventory book and assigned inventory not printing associated MR1 and RD1
						if the MR1 record  doesnt exist
				! 20/2/95 Printing full assigned inventory was still printing containers
				! 20/2/95 Order by of query and assigned inventory was wrong - ordering by shipped first!! 
				! 22/2/95 bug in not setting acknowledge and conf flag back to N in allocations fixed
				! 22/2/95 Denormalise code put in 
				! 27/2/95 myfunc.apl has had the report printing and other window screens removed
						  into seperate APLs.
				! 27/4/95 myfunc.apl printlabels has changed to include hWndNULL parameter to speed up the 
						  gettting of data for field counts.
				! !!
				! NOTE DO NOT PUT INTO LIVE UNTIL DEMORMALIZATION
				! 4/4/95 Inventory book root_desc not printing fixed.
				! 18/4/95 In CalcItemTotalAvailable changed so that if a count was entered as 0 it included it
				! 2/5/95 includes to SalLoadApp of bundles report just uncomment the menu item under frmStock
						  when code is converted to 5.01
				! 2/5/95 inventory book FC or RP orders against items loosing the last one is fixed.
				! 2/5/95 bug in denormalising fixed with root_desc not being denormalised
				! 4/5/95 hiding of parent window is done in here
				! 27/5/95 Allocations stage 2.1 Table populate changed to Tbl_FillAll
				!
				!
				!
				If strArgArray[0] = ''
					Set SqlDatabase = 'STOCKDEV'
					Set SqlUser = 'GRAHAM'
					Set SqlPassword = 'GRAHAM'
				Else
					Set SqlDatabase = strArgArray[1]
					Set SqlUser = strArgArray[2]
					Set SqlPassword = strArgArray[3]
				!
				Set bShowSql = FALSE
				Set bghSqlDetail = SqlConnect( hSqlDetail )
				If bghSqlDetail
					Call SqlSetIsolationLevel( hSqlDetail,'RL')
					Call SqlSetLockTimeout( hSqlDetail,SQLTIMEOUT )
			On SAM_AppExit
				If bghSqlDetail
					Call SqlDisconnect( hSqlDetail )
			On SAM_SqlError
				Call SqlExtractArgs( wParam, lParam, hSqlError, nSqlError, nErrorPos )
				! Going to comments the return false line and put in others to do error processing
				! Return FALSE
				Call SqlGetErrorText( nSqlError, sErrmsg )
				Call SalNumberToStr( nSqlError, 0, sNum )
				Call SalMessageBox( sNum || '-' || sErrmsg || '.
						Choose OK to quit.', 'Stock Control', MB_Ok | MB_IconStop )
				! temp putting this here to see what problem is
				Return FALSE

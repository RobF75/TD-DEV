					Column: colWhere
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title:
						Visible? No
						Editable? Yes
						Maximum Data Length: Default
						Data Type: String
						Justify: Left
						Width:  1.2"
						Width Editable? Yes
						Format: Unformatted
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_WHEREPOPULATE
								If nQueryType = nQCultivars
									If frmStock.sPreEntryWhere != ''
										Set sBuildWhere = frmStock.sPreEntryWhere
									Else
										Set sBuildWhere = ' '
								Else If nQueryType = nQueryAllocFlag
									If frmStock.sPreEntryWhere != ''
										Set sBuildWhere = frmStock.sPreEntryWhere || ' AND STOCK_ITEM.ITEM_NO = STOCK_ITEM_SALE.STOCK_ITEM_NO AND STOCK_ITEM_SALE.YEAR_OF_SALE = :frmStock.dfYr '
									Else
										Set sBuildWhere = ' '
								Else
									If frmStock.sPreEntryWhere != ''
										Set sBuildWhere = frmStock.sPreEntryWhere
									Else
										Set sBuildWhere = ''
							! On PAM_WHEREPOPULATE
								   If nQueryType = nQCultivars
									   If frmStock.sPreEntryWhere != ''
										   Set sBuildWhere = frmStock.sPreEntryWhere || ' AND STOCK_ITEM.CULTIVAR_ID = CULTIVAR.CULT_ID '
									   Else 
										   Set sBuildWhere = ' WHERE STOCK_ITEM.CULTIVAR_ID = CULTIVAR.CULT_ID '
								   Else 
									   If frmStock.sPreEntryWhere != ''
										   Set sBuildWhere = frmStock.sPreEntryWhere || ' AND STOCK_ITEM.CULTIVAR_ID = CULTIVAR.CULT_ID(+) '
									   Else 
										   Set sBuildWhere = ' WHERE STOCK_ITEM.CULTIVAR_ID = CULTIVAR.CULT_ID(+) '
							! On PAM_QBE
								   Call PushString( NOTHINGFOLLOWING )
								   Call PushString( ' STOCK_ITEM.CULTIVAR_ID = CULTIVAR.CULT_ID(+) ' )
							On PAM_DATAVAL
								Return TRUE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE
					Column: colWhere2
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title:
						Visible? No
						Editable? Yes
						Maximum Data Length: Default
						Data Type: String
						Justify: Left
						Width:  1.2"
						Width Editable? Yes
						Format: Unformatted
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							! On PAM_WHEREPOPULATE
								   Set sBuildWhere = ' WHERE STOCK_ITEM.CULTIVAR_ID = CULTIVAR.CULT_ID AND STOCK_ITEM.ITEM_NO =
										STOCK_ITEM_SALE.STOCK_ITEM_NO AND STOCK_ITEM_SALE.YEAR_OF_SALE = :frmStock.nAssInvYr '
							On PAM_WHEREPOPULATE
								! Set sBuildWhere = ' WHERE STOCK_ITEM.CULTIVAR_ID = CULTIVAR.CULT_ID AND STOCK_ITEM.ITEM_NO =
										STOCK_ITEM_SALE.STOCK_ITEM_NO AND STOCK_ITEM_SALE.YEAR_OF_SALE = :frmStock.nAssInvYr 
										AND NOT (STOCK_ITEM_SALE.AMT_GROWING = 0 AND STOCK_ITEM_SALE.AMT_GRADED = 0
										AND STOCK_ITEM_SALE.AMT_SHIPPED = 0 AND STOCK_ITEM_SALE.AMT_SUBS_SHIPPED = 0 AND STOCK_ITEM_SALE.AMT_ON_ORDER = 0
										AND STOCK_ITEM_SALE.ON_ORD_AS_SUBS = 0)'
								! denorm
								Set sBuildWhere = " WHERE  STOCK_ITEM.ITEM_NO =
										STOCK_ITEM_SALE.STOCK_ITEM_NO AND STOCK_ITEM.TREE_TYPE
										NOT LIKE 'C%'  AND 
										STOCK_ITEM.TREE_TYPE = TREE_TYPE.TREE_TYPE AND 
										( Tree_Type.ExcFrmStockReports = 'N' OR Tree_Type.ExcFrmStockReports IS NULL )
										AND STOCK_ITEM_SALE.YEAR_OF_SALE = :frmStock.nAssInvYr "
								! Set sBuildWhere = " WHERE STOCK_ITEM.CULTIVAR_ID =
										 CULTIVAR.CULT_ID(+) AND STOCK_ITEM.ITEM_NO =
										STOCK_ITEM_SALE.STOCK_ITEM_NO AND STOCK_ITEM.TREE_TYPE
										NOT LIKE 'C%'  
										AND STOCK_ITEM_SALE.YEAR_OF_SALE = :frmStock.nAssInvYr "
							On PAM_DATAVAL
								Return TRUE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE
					! col1 in assinvsql, query table
					Column: colItemNo
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Item No
						Visible? No
						Editable? Yes
						Maximum Data Length: Default
						Data Type: Number
						Justify: Left
						Width:  0.713"
						Width Editable? Yes
						Format: Unformatted
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM.ITEM_NO' )
							On PAM_ASSINVSQL
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM.ITEM_NO' )
							On PAM_INSERT
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'STOCK_ITEM.ITEM_NO' )
							On PAM_RENEWROWID
								Call PushString( ':frmStock.tblStock.colItemNo' )
								Call PushString( EQOPERAND )
								Call PushString( STRINGHDLFOLLOWING )
								Call PushString( 'STOCK_ITEM.ITEM_NO' )
								Return TRUE
							! On PAM_ROWINSERTED
								   If NOT StockItemSaleExists( hSqlSISExistsHdl, bSISExistsHdlConnected, bSISExistsHdlPrepared, colItemNo, frmStock.dfYr )
									   If MyInsertRecord( hSqlInsSISHdl, bInsSISHdlConnected, bInsSISHdlPrepared, ' STOCK_ITEM_SALE ', hWndForm, PAM_ADDSTCKITMSALE, PAM_SETSISVALUES )
										   Call SqlCommit( hSqlInsSISHdl )
									   Else 
										   Call SqlPrepareAndExecute( hSqlInsSISHdl, 'ROLLBACK' )
							On PAM_ADDSTCKITMSALE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM_NO' )
							On PAM_QBE
								If NOT SalIsNull( hWndItem )
									Call PushNumber( colItemNo )
									Call PushString( EQOPERAND )
									Call PushString( NUMERICFOLLOWING )
									Call PushString( 'STOCK_ITEM.ITEM_NO' )
									Return TRUE
							On PAM_DATAVAL
								Return TRUE
							On PAM_REPORTCOLUMNS
								Call BuildSQL(  wParam, hWndItem, 'ITEM_NO' )
							On PAM_CANORDERBY
								Call PushNumber( 1 )
								Call SalTblGetColumnTitle( hWndItem, sQueryTmpStr, 30 )
								Call PushString( sQueryTmpStr )
								Return TRUE
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, 0 )
							On SAM_Create
								If IsUserAdmin( SqlUser, FALSE )
									Call SalShowWindow( hWndItem )
							On PAM_EDITCHECK
								If NOT SalTblQueryRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_New )
									Call SalTblKillEdit( hWndForm )
							On PAM_CHECKROWNEW
								Set sSql =  'SELECT MAX( ITEM_NO ) + 1 FROM STOCK_ITEM INTO :frmStock.tblStock.colItemNo '
								If MySqlPrepExecFetch( hLocalSqlExtra, sSql, nInd )
									If SalIsNull( hWndItem )
										Set colItemNo = 1
								Call SalSetFieldEdit( hWndItem, TRUE )
								If SalIsNull( colRootId )
									Set sSql = 'SELECT item_no FROM stock_item WHERE tree_type = :frmStock.tblStock.colTreeType AND cultivar_id = :frmStock.tblStock.colCultId AND ROOTSTOCK_ID IS NULL'
								Else If SalIsNull( colCultId )
									Set sSql = 'SELECT item_no FROM stock_item WHERE tree_type = :frmStock.tblStock.colTreeType AND rootstock_id = :frmStock.tblStock.colRootId AND CULTIVAR_ID IS NULL'
								Else
									Set sSql = 'SELECT item_no FROM stock_item WHERE tree_type = :frmStock.tblStock.colTreeType AND cultivar_id = :frmStock.tblStock.colCultId AND rootstock_id = :frmStock.tblStock.colRootId '
								If MySqlExists( sSql, bExists )
									If bExists
										Call ErrorMessage( 'This stock item already exists in this table!', hWndForm, wParam )
										Return FALSE
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Set sSql = 'SELECT Stock_Item_No FROM CUSTOMER_ORDER WHERE STOCK_ITEM_NO = :frmStock.tblStock.colItemNo'
								If MySqlExists( sSql, bExists )
									If bExists
										Call ErrorMessage( 'Someone still has this stock Item on Order. Please delete the order first!.', hWndForm, wParam )
										Return FALSE
								Set sSql = 'SELECT STOCK_ITEM_NO FROM STOCK_ITEM_SALE WHERE STOCK_ITEM_NO = :frmStock.tblStock.colItemNo'
								If MySqlExists( sSql, bExists )
									If bExists
										Call ErrorMessage( 'This stock Item still has field counts. Please delete these first!.', hWndForm, lParam )
										Return FALSE
								Return TRUE
					! col2 in assinvsql, query table
					Column: colTreeType
						Class Child Ref Key: 0
						Class ChildKey: 0
						Class:
						Property Template:
						Class DLL Name:
						Title: Type
						Visible? Yes
						Editable? Yes
						Maximum Data Length: 8
						Data Type: String
						Justify: Center
						Width:  0.85"
						Width Editable? Yes
						Format: Uppercase
						Country: Default
						Input Mask: Unformatted
						Cell Options
							Cell Type? Standard
							Multiline Cell? No
							Cell DropDownList
								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_SQL
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM.TREE_TYPE' )
							On PAM_ASSINVSQL
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM.TREE_TYPE' )
							On PAM_INSERT
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'STOCK_ITEM.TREE_TYPE' )
							On PAM_UPDATE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'STOCK_ITEM.TREE_TYPE' )
							On PAM_QBE
								If NOT SalIsNull( hWndItem )
									Set sQueryTmpStr = colTreeType||'%'
									Call PushString( sQueryTmpStr )
									Call PushString( LIKEOPERAND )
									Call PushString( STRINGFOLLOWING )
									Call PushString( 'STOCK_ITEM.TREE_TYPE' )
									Return TRUE
							On PAM_QBETREETYPE
								If NOT SalIsNull( hWndItem )
									Set sQueryTmpStr = colTreeType||'%'
									Call PushString( sQueryTmpStr )
									Call PushString( LIKEOPERAND )
									Call PushString( STRINGFOLLOWING )
									Call PushString( 'TREE_TYPE.TREE_TYPE' )
									Return TRUE
							On PAM_LOOKUPTYPE
								Call PopString( colTreeType, TRUE )
								Call SalSetFieldEdit( hWndItem, TRUE )
							On PAM_ENABLECHILDSELECTPB
								Set frmStock.bEnableTreeTypeDlgSelectPb = TRUE
							On PAM_REPORTCOLUMNS
								Call BuildSQL(  wParam, hWndItem, 'TREE_TYPE' )
							On PAM_CANORDERBY
								Call PushNumber( 2 )
								Call SalTblGetColumnTitle( hWndItem, sQueryTmpStr, 30 )
								Call PushString( sQueryTmpStr )
								Return TRUE
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, 0 )
							On PAM_EDITCHECK
								If NOT SalTblQueryRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_New )
									Call SalTblKillEdit( hWndForm )
							On PAM_DATAVAL
								If SalIsNull( hWndItem )
									Call ErrorMessage( 'Enter a Tree Type first.', hWndForm, ngRow )
									Return FALSE
								Else
									Set sgSql = 'SELECT Tree_Type FROM Tree_Type WHERE 
											Tree_Type = :frmStock.tblStock.colTreeType'
									If NOT RowIdExists( sgSql )
										Call ErrorMessage( 'Invalid Tree Type! Please select your Tree Type via the push button TREE TYPE.', hWndForm, ngRow )
										Return FALSE
								Return TRUE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE
							On PAM_PRINTASSINVSEL
								Call BuildSQL(  wParam,hWndItem,'TreeType' )

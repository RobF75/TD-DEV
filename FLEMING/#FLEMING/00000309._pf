			Pushbutton: pbOrderTable
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title: &Order Table
				Window Location and Size
					Left:   2.588"
					Top:    3.573"
					Width:  1.2"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? No
				Keyboard Accelerator: (none)
				Font Name: Default
				Font Size: Default
				Font Enhancement: Italic
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						If NOT TableForgetChanges( tblStock, frmStock.tblStock.bEdit )
							Return FALSE
						Call SalWaitCursor( TRUE )
						Call PushWndHdl( hWndItem )
						Call PushWndHdl( tblStock )
						Call PushString( frmStock.tblStock.sCurrentBuildWhere )
						Call SalDisableWindow( hWndItem )
						Call SalModalDialog( dlgTblOrderBy, hWndForm )
					On PAM_ENABLE
						If wParam
							Call PopString( frmStock.tblStock.sCurrentBuildWhere, TRUE )
							Call SalSendMsg( tblStock, PAM_REPOPULATE, 0, 0 )
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
			Pushbutton: pbItemAllocAsIs
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class: OurPushbuttonClass
				Property Template:
				Class DLL Name:
				Title: Item Alloc As Ord.
				Window Location and Size
					Left:   Default
					Top:    Default
					Width:  Class Default
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? No
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name:
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Message Actions
					On PAM_CLICK
						If SalTblAnyRows( tblStock, ROW_Selected, 0 )
							If SalModalDialog( dlgGetYear, hWndForm )
								Call PopNumber( nYear, TRUE )
								!
								Set bFirst = TRUE
								Set sCommaListOfItemNos = ''
								If MyTableLoop( tblStock, hWndItem, PAM_ROWACTION, ROW_Selected, 0, 'Checking & Collecting Selected Items', nLowToHiWithPositioning )
									Call AllocateAsOrdItems( sCommaListOfItemNos, nYear, hWndItem, nExecute )
						Else
							Call SalMessageBox( 'Please select a item first!', 'Warning', MB_Ok )
					On PAM_ROWACTION
						If tblStock.colGenItem = 'Y'
							Call SalMessageBox( 'Cannot do Items Allocation As Ordered on a Generic stock item!', 'Warning', MB_Ok )
							Return FALSE
						Else
							If bFirst
								Set sCommaListOfItemNos = SalNumberToStrX( tblStock.colItemNo, 0 )
								Set bFirst = FALSE
								Return TRUE
							Else
								Set sCommaListOfItemNos = sCommaListOfItemNos || ',' || SalNumberToStrX( tblStock.colItemNo, 0 )
								Return TRUE
					!
					On PAM_ROWUPDATED
						If wParam
							Set nAllocatedItemNo = lParam
							Set sAllocatedFlag = 'Y'
							Call MyTableLoop( tblStock, hWndItem, PAM_SETVALUES, ROW_Selected, 0, 'Updating allocated flag', nLowToHi )
						Return TRUE
					On PAM_SETVALUES
						If tblStock.colItemNo = nAllocatedItemNo
							Set tblStock.colAllocFlag = sAllocatedFlag
							! Returns false here to stop the Updating allocated flag loop
							Return FALSE
						Else
							Return TRUE
			!

							On PAM_ASSINVSELECTED
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM_SALE.YEAR_OF_SALE' )
							On PAM_PRINTASSINVSEL
								Call BuildSQL(  wParam,hWndItem,'AssInvYr' )

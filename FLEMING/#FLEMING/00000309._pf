					   Menu Item Name: 
					   Menu Item: &One Item, choose type of label
						   Keyboard Accelerator: (none)
						   Status Text: 
						   Menu Settings 
							   Enabled when: 
							   Checked when: 
						   Menu Actions 
							   If NOT SalTblAnyRows( tblStock,ROW_Selected, 0 )
								   Call SalMessageBox( 'No rows selected', 'Stock Items', MB_Ok )
								   Return FALSE
							   Call PushNumber( frmStock.tblStock.colItemNo )
							   Call SalModalDialog( dlgLbl, hWndForm )
						   Menu Item Name: 
					   Menu Item: &Many Items same type of label
						   Keyboard Accelerator: (none)
						   Status Text: 
						   Menu Settings 
							   Enabled when: 
							   Checked when: 
						   Menu Actions 
							   Set nTmp = 0
							   Set naQuantities[ nTmp ] = NUMBER_Null
							   Set nRow = TBL_MinRow
							   While SalTblFindNextRow( tblStock, nRow, ROW_Selected, 0 )
								   Call SalTblFetchRow( tblStock, nRow )
								   Set nItemNo[ nTmp ] = tblStock.colItemNo
								   Set nTmp = nTmp + 1
								   Set nItemNo[ nTmp ] = NUMBER_Null
							!
							   If nTmp = 0
								   Call SalMessageBox( 'No rows selected', 'Stock Items', MB_Ok )
								   Return FALSE
							   Else 
								   Call SalModalDialog( dlgPrintLabelsDetails, hWndForm, NUMBER_Null, '', nItemNo, naQuantities, TRUE )

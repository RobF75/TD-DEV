							On PAM_INSERT
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'STOCK_ITEM.ROOTSTOCK_ID' )
							On PAM_UPDATE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'STOCK_ITEM.ROOTSTOCK_ID' )
							On PAM_QBE
								If NOT SalIsNull( hWndItem )
									Set sQueryTmpStr = colRootId||'%'
									Call PushString( sQueryTmpStr )
									Call PushString( LIKEOPERAND )
									Call PushString( STRINGFOLLOWING )
									Call PushString( 'STOCK_ITEM.ROOTSTOCK_ID' )
									Return TRUE
							On PAM_QBEROOT
								If NOT SalIsNull( hWndItem )
									Set sQueryTmpStr = colRootId||'%'
									Call PushString( sQueryTmpStr )
									Call PushString( LIKEOPERAND )
									Call PushString( STRINGFOLLOWING )
									Call PushString( 'ROOTSTOCK.ROOT_ID' )
									Return TRUE
							! denorm
							! On PAM_LOOKUPCULT
								   Call SalTblSetFocusCell( hWndForm, SalTblQueryContext( hWndForm ), colRootId, -1, -1 )
							On PAM_LOOKUPROOT
								Call PopString( colRootId,TRUE )
								Set bEdit = TRUE
								Call SalSetFieldEdit( hWndItem, TRUE )
							On SAM_SetFocus
								Set frmStock.bEnableRootStockFrmSelectPb = TRUE
							On SAM_KillFocus
								Set frmStock.bEnableRootStockFrmSelectPb = FALSE
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, 0 )
							On PAM_EDITCHECK
								If NOT SalTblQueryRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_New )
									Call SalTblKillEdit( hWndForm )
							On PAM_REPORTCOLUMNS
								Call BuildSQL(  wParam, hWndItem, 'ROOT_ID' )
							On PAM_CANORDERBY
								Call PushNumber( 6 )
								Call SalTblGetColumnTitle( hWndItem, sQueryTmpStr, 30 )
								Call PushString( sQueryTmpStr )
								Return TRUE
							On PAM_DATAVAL
								If SalIsNull( hWndItem ) AND SalIsNull( colCultId )
									Call ErrorMessage( 'Please enter a Rootstock Id first.', hWndForm, ngRow )
									Return FALSE
								Else If NOT SalIsNull( hWndItem )
									If NOT GetDenormRootDetails( colRootId, colRootDesc, colRootNPAflag, colRTNotSale, nExecute )
										Call ErrorMessage( 'Invalid Rootstock Id! Please select your Rootstock via the push button ROOTSTOCK.', hWndForm, ngRow )
										Return FALSE
								Return TRUE
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE

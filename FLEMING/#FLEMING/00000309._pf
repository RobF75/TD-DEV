					Resource Id: 61997
					Keyboard Accelerator: (none)
					Status Text:
					Menu Settings
						Enabled when:
						Checked when:
					Menu Actions
						Call SalWaitCursor( TRUE )
						If SalModalDialog( dlgGetInvBookDetails, hWndForm )
							Call SalWaitCursor( TRUE )
							Call PopNumber( nYear, TRUE )
							Call PopNumber( nType, TRUE )
							Set nNumItems = 0
							If nType = nSelectedItems
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( tblStock, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( tblStock, nRow )
									Set nNumItems = nNumItems + 1
									Set nItemNo[nNumItems-1] = tblStock.colItemNo
								Call SalCreateWindow( frmPrintInvBook, hWndForm, nItemNo, nNumItems, nYear, nSelectedItems )
							Else
								Call SalCreateWindow( frmPrintInvBook, hWndForm, nItemNo, 0, nYear, nAllItems )
						Call SalWaitCursor( FALSE )

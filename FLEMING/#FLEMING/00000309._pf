								Sorted? Yes
								Vertical Scroll? Yes
								Auto Drop Down? No
								Allow Text Editing? Yes
							Cell CheckBox
								Check Value:
								Uncheck Value:
								Ignore Case? Yes
						List Values
						Message Actions
							! denorm
							On PAM_SQL
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM.CULT_DESC' )
							On PAM_ASSINVSQL
								Call BuildSQL(  wParam, hWndItem, 'STOCK_ITEM.CULT_DESC' )
							On PAM_QBE
								If NOT SalIsNull( hWndItem )
									Set sQueryTmpStr = colCultdesc
									Call SalStrUpper( sQueryTmpStr, sQueryTmpStr )
									Call MyStrReplace( sQueryTmpStr, '\'', '_' )
									Set sQueryTmpStr = '%'||sQueryTmpStr||'%'
									Call PushString( sQueryTmpStr )
									Call PushString( LIKEOPERAND )
									Call PushString( STRINGFOLLOWING )
									Call PushString( '@UPPER(STOCK_ITEM.CULT_DESC)' )
									Return TRUE
							On PAM_QBECULT
								If NOT SalIsNull( hWndItem )
									Set sQueryTmpStr = colCultdesc
									Call SalStrUpper( sQueryTmpStr, sQueryTmpStr )
									Call MyStrReplace( sQueryTmpStr, '\'', '_' )
									Set sQueryTmpStr = '%'||sQueryTmpStr||'%'
									Call PushString( sQueryTmpStr )
									Call PushString( LIKEOPERAND )
									Call PushString( STRINGFOLLOWING )
									Call PushString( '@UPPER(CULT_DESC)' )
									Return TRUE
							On PAM_LOOKUPTYPE
								Call SalTblSetFocusCell( hWndForm, SalTblQueryContext( hWndForm ), hWndItem, -1, -1 )
							On PAM_LOOKUPCULT
								Call PopString( colCultdesc,TRUE )
								Call SalSetFieldEdit( hWndItem, TRUE )
							On SAM_Click
								Call SalPostMsg( hWndItem, PAM_EDITCHECK, 0, 0 )
							On PAM_EDITCHECK
								If NOT SalTblQueryRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_New )
									Call SalTblKillEdit( hWndForm )
							On PAM_REPORTCOLUMNS
								Call BuildSQL(  wParam, hWndItem, 'CULT_DESC' )
							On PAM_CANORDERBY
								Call PushNumber( 4 )
								Call SalTblGetColumnTitle( hWndItem, sQueryTmpStr, 30 )
								Call PushString( sQueryTmpStr )
								Return TRUE
							On PAM_DATAVAL
								If NOT SalIsNull( hWndItem ) AND SalIsNull( colCultId )
									Call ErrorMessage( 'Please select the cultivar from the CULTIVAR push button.', hWndForm, ngRow )
									Return FALSE
								Else If SalIsNull( hWndItem ) AND NOT SalIsNull( colCultId )
									Call SalClearField( colCultId )
								Return TRUE
							On PAM_INSERT
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'STOCK_ITEM.CULT_DESC' )
							On PAM_UPDATE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam,hWndItem,'STOCK_ITEM.CULT_DESC' )
							On PAM_CHECKROWNEW
								Return TRUE
							On PAM_CHECKROWEDITED
								Return TRUE
							On PAM_CHECKROWDELETED
								Return TRUE
							On PAM_PRINTASSINVSEL
								Call BuildSQL(  wParam,hWndItem,'Cultivar' )

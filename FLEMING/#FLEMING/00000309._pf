			User
				!
				! Constants used by frmOrderDets only
				!
				String: CNORD = ' WHERE CUSTOMER_ORDER.CUST_NO =
						 :hWndForm.dfCustno AND
						CUSTOMER_ORDER.ORDER_DATE_TIME = :hWndForm.dfDateTime'
				String: LOADCUSTLOAD = ' LOAD_CUSTOMERS, LOAD' 
				String: WHCUSTDATE  = ' WHERE LOAD_CUSTOMERS.CUST_NO = :dlgLoad.dfCustno
						 AND LOAD.LOAD_ID = LOAD_CUSTOMERS.LOAD_ID AND 
						LOAD.SHIPPING_DATE >= :dlgLoad.dfCurrDate' 
				!
				String: WHERESISFRGRW = ' WHERE
						STOCK_ITEM_SALE.STOCK_ITEM_NO = :frmGrowing.dfItemNo AND
						STOCK_ITEM_SALE.YEAR_OF_SALE = :frmGrowing.dfYr'
				String: SIS = ' STOCK_ITEM_SALE '

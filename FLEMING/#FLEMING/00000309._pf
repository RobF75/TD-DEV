				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title:
				Window Location and Size
					Left:   5.088"
					Top:    3.906"
					Width:  1.4"
					Width Editable? Yes
					Height: 0.292"
					Height Editable? Yes
				Visible? No
				Keyboard Accelerator: (none)
				Font Name: Default
				Font Size: Default
				Font Enhancement: Italic
				Picture File Name:
				Picture Transparent Color: None
				Image Style: Single
				Text Color: Default
				Background Color: Default
				Message Actions
					On SAM_Click
						Call SalWaitCursor( TRUE )
						Set frmStock.tblStock.bCalcTotPrice = TRUE
						Set nRow = TBL_MinRow
						If SalTblAnyRows( tblStock, ROW_Selected, 0 )
							While SalTblFindNextRow( tblStock, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblStock, nRow )
								Set frmStock.tblStock.colTotPrice = frmStock.tblStock.colBasePr
								! True or false booleans are sent to indicate whether rootstock or cult processing
								If NOT SalIsNull( frmStock.tblStock.colRootId )
									! Set frmStock.tblStock.colTotPrice =  frmStock.tblStock.colTotPrice + RoyaltySelects( FALSE )  
									Call CalcRootstockRoyalty( 0, frmStock.tblStock.colRootId, frmStock.tblStock.colItemNo, nTmp, nExecute )
									Set frmStock.tblStock.colTotPrice =  frmStock.tblStock.colTotPrice + nTmp
								If NOT SalIsNull( frmStock.tblStock.colCultId )
									! Set frmStock.tblStock.colTotPrice = frmStock.tblStock.colTotPrice + RoyaltySelects( TRUE )
									Call CalcCultivarRoyalty( 0, frmStock.tblStock.colCultId, frmStock.tblStock.colItemNo, nTmp, nExecute )
									Set frmStock.tblStock.colTotPrice = frmStock.tblStock.colTotPrice + nTmp
						Call SalWaitCursor( FALSE )
					On PAM_ENABLE
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )
			Pushbutton: pbAvail
				Class Child Ref Key: 0
				Class ChildKey: 0
				Class:
				Property Template:
				Class DLL Name:
				Title:
				Window Location and Size
					Left:   5.088"
					Top:    3.906"

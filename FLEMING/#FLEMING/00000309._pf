			! Function: Prohibitions
				   Description: To bring up a list of prohibitions for a particular cultivar/rootstock
						depending which parameter is not null
				   Returns 
				   Parameters 
					   Window Handle: hWndParent
					   Window Handle: hWndPushButton
					   String: sCultId
					   String: sCultDesc
					   String: sRootId
				   Static Variables 
				   Local variables 
				   Actions 
					   Call PushString( sCultId )
					   Call PushString( sCultDesc )
					   Call PushString( sRootId )
					   Call PushWndHdl( hWndPushButton )
					   Call SalModalDialog( dlgProhib, hWndParent )
			! Function: AddGrowing
				   Description: For a given year and item no to add all of the growing locations together
						to get an interactive total
				   Returns 
				   Parameters 
				   Static Variables 
				   Local variables 
					   Number: nGrowing
				   Actions 
					   Set nGrowing = 0
					   Set ngRow = TBL_MinRow
					   While SalTblFindNextRow( frmGrowing.tblGrowing, ngRow, 0, 0 )
						   Call SalTblFetchRow( frmGrowing.tblGrowing, ngRow )
						   If SalIsNull( frmGrowing.tblGrowing.colSecCount ) 
							   If SalIsNull( frmGrowing.tblGrowing.colFirstCount ) 
								   Set nGrowing = nGrowing + frmGrowing.tblGrowing.colBegCount 
							   Else 
								   Set nGrowing = nGrowing + frmGrowing.tblGrowing.colFirstCount
						   Else 
							   Set nGrowing = nGrowing + frmGrowing.tblGrowing.colSecCount
					!
					! This old code didnt work for lots of rows in the table.
					!
					! Call SalTblQueryScroll( frmGrowing.tblGrowing, ngPos, ngMinRange, ngMaxRange ) 
					! Set ngRow = ngMinRange
					! While ngRow <= ngMaxRange
						   Call SalTblSetContext( frmGrowing.tblGrowing, ngRow ) 
						   If SalIsNull( tblGrowing.colSecCount ) 
							   If SalIsNull( tblGrowing.colFirstCount ) 
								   Set nGrowing = nGrowing + tblGrowing.colBegCount 
							   Else
								   Set nGrowing = nGrowing + tblGrowing.colFirstCount
						   Else
							   Set nGrowing = nGrowing + tblGrowing.colSecCount
						   Set ngRow = ngRow + 1
					!
					! Then the amount growing total has changed so need to update the parent record
					   If nGrowing != frmGrowing.dfGrowing
						! If the amount growing is different to what it was then we need to adjust the total
								available too so we will need to recalc this figure 
						! Have a problem here where total available is getting set wrongly, because the
								select statement isnt retrieving the amt on order even though there is some
								 so the following set the tot = tot - onorder isnt deducting anything cos it cant
								find anything 
						   Call CallBuildSql( frmGrowing, nSELECT, PAM_SQL2, SIS, WHERESISFRGRW )
						   If NOT SqlImmediate( sgSql )
							   Call SqlClearImmediate(  )
							   Call CallBuildSql( frmGrowing, nINSERT, PAM_SQL2, SIS, WHERESISFRGRW )
							   If NOT SqlOK( frmGrowing.tblGrowing.hLocalSqlB, sgSql )
								   Call SalMessageBox( 'Update of Stock Items for Sale incomplete, please notify
										Dani', 'Growing', MB_Ok )
								   Return FALSE
						! If NOT SqlOK( frmGrowing.hLocalSqlB, sgSql )
							   Call CallBuildSql( frmGrowing, nINSERT, PAM_SQL2, SIS, WHERESISFRGRW )
							   If NOT SqlOK( frmGrowing.hLocalSqlB, sgSql )
								   Call SalMessageBox( 'Update of Stock Items for Sale incomplete, please notify
										Dani', 'Growing', MB_Ok )
								   Return FALSE
						   Set frmGrowing.dfGrowing = nGrowing
						   Set frmGrowing.dfTot = nGrowing + frmGrowing.dfSupplied 
						! Set frmGrowing.dfTot = frmGrowing.dfTot - frmGrowing.dfGraded
						   Set frmGrowing.dfTot = frmGrowing.dfTot - frmGrowing.dfPendDig
						   Set frmGrowing.dfTot = frmGrowing.dfTot - frmGrowing.dfShipped
						   Set frmGrowing.dfTot = frmGrowing.dfTot - frmGrowing.dfShipAsSub
						   Set frmGrowing.dfTot = frmGrowing.dfTot - frmGrowing.dfOnOrder
						   Set frmGrowing.dfTot = frmGrowing.dfTot - frmGrowing.dfOnOrdAsSubs
						   Call SalSendMsgToChildren( frmGrowing, PAM_SETEDIT, 0, 0 )
						   Call CallBuildSql( frmGrowing, nUPDATE, PAM_SQL2, SIS, WHERESISFRGRW )
						   If NOT SqlOK( frmGrowing.tblGrowing.hLocalSqlB, sgSql )
							   Call SalMessageBox( 'Update of Stock Items for Sale incomplete, please notify
									Dani', 'Growing', MB_Ok )
							   Return FALSE
						   Call SqlImmediate( 'commit' )
						   Call SqlClearImmediate(  )
						! Set sgSql = 'UPDATE STOCK_ITEM_SALE SET 
								AMT_GROWING = :frmGrowing.dfGrowing WHERE
								STOCK_ITEM_SALE.STOCK_ITEM_NO = :frmGrowing.dfItemNo AND
								STOCK_ITEM_SALE.YEAR_OF_SALE = :frmGrowing.dfYr'
					   Set frmGrowing.dfGrowingTotal = nGrowing
			! Function: AddGrowing
				   Description: For a given year and item no to add all of the growing locations together
						to get an interactive total
				   Returns 
				   Parameters 
				   Static Variables 
				   Local variables 
					   Number: nGrowing
				   Actions 
					   Set nGrowing = 0
					   Set ngRow = TBL_MinRow
					   While SalTblFindNextRow( frmGrowing.tblGrowing, ngRow, 0, 0 )
						   Call SalTblFetchRow( frmGrowing.tblGrowing, ngRow )
						   If SalIsNull( frmGrowing.tblGrowing.colSecCount ) 
							   If SalIsNull( frmGrowing.tblGrowing.colFirstCount ) 
								   Set nGrowing = nGrowing + frmGrowing.tblGrowing.colBegCount 
							   Else 
								   Set nGrowing = nGrowing + frmGrowing.tblGrowing.colFirstCount
						   Else 
							   Set nGrowing = nGrowing + frmGrowing.tblGrowing.colSecCount
					   If nGrowing != frmGrowing.dfGrowing
						   Call CalcItemTotalAvail( frmGrowing.dfItemNo, frmGrowing.dfYr, nCalcItemAvail, nExecute )
					   Set frmGrowing.dfGrowingTotal = nGrowing
			! Function: AddLocations
				   Description: To fill the location table with the rows supplied by nRowsFrom and 
						nRowsTo with a default seq = 10 and supplied farm Id (sFarmId) the
						locations between the from and to numbers.  If a location is found that
						already exists it is skipped over.
				   Returns 
					   Boolean: 
				   Parameters 
					   String: sFarmId
					   Number: nRowsFrom
					   Number: nRowsTo
				   Static Variables 
				   Local variables 
					   Number: nRowCount
					   Number: nSeqDefault
					   Number: nLocationId
					   Boolean: bExists
					   Boolean: bLocalSqlA
					   Sql Handle: hLocalSqlA
					   Boolean: bLocalSqlB
					   Sql Handle: hLocalSqlB
					   String: sSql
					   Number: nInd
				   Actions 
					   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					   If bLocalSqlA
						   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					   Else 
						   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						   Return FALSE
					   Set bLocalSqlB = SqlConnect( hLocalSqlB ) 
					   If bLocalSqlB
						   Call SqlSetLockTimeout( hLocalSqlB, SQLTIMEOUT )
					   Else 
						   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						   Return FALSE
					   Set sSql = 'SELECT MAX( Location_Id ) + 1 FROM Location 
							 INTO :nLocationId '
					   If SqlPrepare( hLocalSqlA, sSql )
						   If SqlExecute( hLocalSqlA )
							   If NOT SqlFetchNext( hLocalSqlA, nInd )
								   Call SalMessageBox( 'SqlFetchNext had a error, in AddLocations.', 'Error', MB_Ok | MB_IconStop )
								   If bLocalSqlA
									   Call SqlDisconnect( hLocalSqlA )
								   If bLocalSqlB
									   Call SqlDisconnect( hLocalSqlB )
								   Return FALSE
						   Else 
							   Call SalMessageBox( 'SqlExecute had a error, in AddLocations.', 'Error', MB_Ok | MB_IconStop )
							   If bLocalSqlA
								   Call SqlDisconnect( hLocalSqlA )
							   If bLocalSqlB
								   Call SqlDisconnect( hLocalSqlB )
							   Return FALSE
					   Else 
						   Call SalMessageBox( 'SqlPrepare found a error, in AddLocations.', 'Error', MB_Ok | MB_IconStop )
						   If bLocalSqlA
							   Call SqlDisconnect( hLocalSqlA )
						   If bLocalSqlB
							   Call SqlDisconnect( hLocalSqlB )
						   Return FALSE
					   Set nSeqDefault = 10
					   Set nRowCount = nRowsFrom
					   While nRowCount <= nRowsTo
						   Set sSql = 'SELECT Location_Id FROM Location WHERE 
								  Farm_Name = :sFarmId AND 
								  Row# = :nRowCount AND
								  Seq# = :nSeqDefault'
						   If SqlExists( sSql, bExists )
							   If NOT bExists
								   Set sSql = 'INSERT  INTO Location ( Location_Id, Farm_Name, Row#, Seq#, Loc_Added_By, Loc_Added_Date )
										 VALUES ( :nLocationId, :sFarmId, :nRowCount, :nSeqDefault, USER, SYSDATE ) ' 
								   If SqlPrepare( hLocalSqlB, sSql )
									   If NOT SqlExecute( hLocalSqlB )
										   Set sSql = 'SELECT MAX( Location_Id ) + 1 FROM Location  INTO :nLocationId '
										   If SqlPrepare( hLocalSqlA, sSql )
											   If SqlExecute( hLocalSqlA )
												   If NOT SqlFetchNext( hLocalSqlA, nInd )
													   Call SalMessageBox( 'SqlFetchNext had a error, in AddLocations.', 'Error', MB_Ok | MB_IconStop )
													   Call SqlCommit( hLocalSqlB )
													   If bLocalSqlA
														   Call SqlDisconnect( hLocalSqlA )
													   If bLocalSqlB
														   Call SqlDisconnect( hLocalSqlB )
													   Return FALSE
											   Else 
												   Call SalMessageBox( 'SqlExecute had a error, in AddLocations.', 'Error', MB_Ok | MB_IconStop )
												   Call SqlCommit( hLocalSqlB )
												   If bLocalSqlA
													   Call SqlDisconnect( hLocalSqlA )
												   If bLocalSqlB
													   Call SqlDisconnect( hLocalSqlB )
												   Return FALSE
										   Else 
											   Call SalMessageBox( 'SqlPrepare found a error, in AddLocations.', 'Error', MB_Ok | MB_IconStop )
											   Call SqlCommit( hLocalSqlB )
											   If bLocalSqlA
												   Call SqlDisconnect( hLocalSqlA )
											   If bLocalSqlB
												   Call SqlDisconnect( hLocalSqlB )
											   Return FALSE
										   If NOT SqlExecute( hLocalSqlB )
											   Call SalMessageBox( 'Error: multiuser conflict, Caution not all your data was saved!', 'Error', MB_Ok )
											   Call SqlCommit( hLocalSqlB )
											   If bLocalSqlA
												   Call SqlDisconnect( hLocalSqlA )
											   If bLocalSqlB
												   Call SqlDisconnect( hLocalSqlB )
											   Return FALSE
									   Else 
										   Set nLocationId = nLocationId + 1
								   Else 
									   Call SalMessageBox( 'SqlPrepare found a error, in AddLocations.', 'Error', MB_Ok | MB_IconStop )
									   Call SqlCommit( hLocalSqlB )
									   If bLocalSqlA
										   Call SqlDisconnect( hLocalSqlA )
									   If bLocalSqlB
										   Call SqlDisconnect( hLocalSqlB )
									   Return FALSE
						   Set nRowCount = nRowCount + 1
					   Call SqlCommit( hLocalSqlB )
					   If bLocalSqlA
						   Call SqlDisconnect( hLocalSqlA )
					   If bLocalSqlB
						   Call SqlDisconnect( hLocalSqlB )
					   Return TRUE
			! Function: AddSubs
				   Description: For a given year and item no to add all of the substitutes together
						to get an interactive total
				   Returns 
				   Parameters 
				   Static Variables 
				   Local variables 
					   Number: nSubs
					   Number: nInd
					   Number: nMin
					   Number: nMax
				   Actions 
					   Set ngArray = 0
					   Call SalQueryArrayBounds( ngSubItemNo, nMin, nMax )
					   While ngArray <= nMax
						   Set ngSubItemNo[ngArray] = 0
						   Set ngUpTo[ngArray] = 0
						   Set ngArray = ngArray + 1
					   Set ngArray = 0
					   Set sgSql = 'SELECT SUBSTITUTE_ITEM_NO,SUB_UP_TO_MAX FROM SUBSTITUTES INTO
							:ngSubItemNo[ngArray],:ngUpTo[ngArray] WHERE SUBSTITUTES.STOCK_ITEM_NO = 
							:frmInventory.dfItemNo' 
					! There may not be any substitutes for this item 
					   If NOT SqlOK( frmInventory.tblInv.hLocalSqlDoTbl, sgSql )
						   Return FALSE
					   While SqlFetchNext( frmInventory.tblInv.hLocalSqlDoTbl, nInd )
						   Set ngArray = ngArray + 1
					! Means that there are no stockitemsale entries for this item, but there are
							substitutes possible, eg Garden centre Granny Smith 
					   Call SalTblQueryScroll( frmInventory.tblInv, ngPos, ngMinRange, ngMaxRange ) 
					   Set ngRow = ngMinRange
					   While ngRow <= ngMaxRange
						   Set nSubs = 0
						   Set ngArray = 0
						   Call SalQueryArrayBounds( ngSubItemNo, nMin, nMax )
						   Call SalTblFetchRow( frmInventory.tblInv, ngRow )
						   While ngArray <= nMax
							   Set sgSql = 'SELECT TOT_AVAIL,AMT_GRADED FROM
									 STOCK_ITEM_SALE INTO :frmInventory.nTotal,:frmInventory.nGraded
									WHERE STOCK_ITEM_SALE.STOCK_ITEM_NO = :ngSubItemNo[ngArray]
									AND STOCK_ITEM_SALE.YEAR_OF_SALE = :frmInventory.tblInv.colYr'
							   If NOT SqlOK( frmInventory.tblInv.hLocalSqlDoTbl, sgSql )
								   Call SalMessageBox( 'Error calculating substitutes, please notify
										Dani', 'Growing', MB_Ok )
								   Return FALSE
							   Call SqlFetchNext( frmInventory.tblInv.hLocalSqlDoTbl, nInd )
							   If nInd != FETCH_EOF 
								! Wrong !! - Need to check firstly if we are using the graded amount or the total from
										field counts amount - then need to check if it has an up to amount - if not
										then assume all as subs, if so then need to check if the amt available is
										less than the up to amount cos we can only use what is available 
								   If ngUpTo[ngArray] = NUMBER_Null
									   Set nSubs = nSubs + frmInventory.nTotal
								   Else 
									   If frmInventory.nTotal > ngUpTo[ngArray]
										   Set nSubs = nSubs + ngUpTo[ngArray]
									   Else 
										   Set nSubs = nSubs + frmInventory.nTotal
								! If ngUpTo[ngArray] = NUMBER_Null
									   If frmInventory.nGraded = 0
										   Set nSubs = nSubs + frmInventory.nTotal
									   Else 
										   Set nSubs = nSubs + frmInventory.nGraded
								! Else 
									! JAN CHANGED NUMBER_Null to 0 of the next line.
									   If frmInventory.nGraded = 0
										   If frmInventory.nTotal > ngUpTo[ngArray]
											   Set nSubs = nSubs + ngUpTo[ngArray]
										   Else 
											   Set nSubs = nSubs + frmInventory.nTotal
									   Else 
										   If frmInventory.nGraded > ngUpTo[ngArray]
											   Set nSubs = nSubs + ngUpTo[ngArray]
										   Else 
											   Set nSubs = nSubs + frmInventory.nGraded
							   Set ngArray = ngArray + 1
						   Call PushNumber( nSubs )
						   Call SalSendMsgToChildren( frmInventory.tblInv, PAM_LOOKUP, 0, 0 )
						   Set ngRow = ngRow + 1
			Function: RoyaltySelects
				Description:
				Returns
					Number: nTotRoy
				Parameters
					Boolean: bCultivar
				Static Variables
				Local variables
					String: sSql
					Boolean: bLocalSqlA
					Sql Handle: hLocalSqlA
					Number: nInd
					Number: nRoy
					Number: nTotRoy
				Actions
					Call SalWaitCursor( TRUE )
					Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					If bLocalSqlA
						Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					Else
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						Return FALSE
					Set nRoy = 0
					Set nTotRoy = 0
					If NOT bCultivar
						Set sSql = 'SELECT AMOUNT_PAYABLE FROM ROYALTY_PAYABLE
								INTO :nRoy WHERE ROOTSTOCK_ID = :frmStock.tblStock.colRootId'  
					Else
						Set sSql = 'SELECT AMOUNT_PAYABLE FROM ROYALTY_PAYABLE
								INTO :nRoy WHERE CULTIVAR_ID = :frmStock.tblStock.colCultId'  
					If SqlPrepare( hLocalSqlA, sSql )
						If NOT SqlExecute( hLocalSqlA )
							Call SalWaitCursor( FALSE )
							Call SalMessageBox( 'SqlExecute had a error, in RoyaltySelects.', 'Error', MB_Ok | MB_IconStop )
							If bLocalSqlA
								Call SqlDisconnect( hLocalSqlA )
							Return FALSE
					Else
						Call SalWaitCursor( FALSE )
						Call SalMessageBox( 'SqlPrepare found a error, in RoyaltySelects.', 'Error', MB_Ok | MB_IconStop )
						If bLocalSqlA
							Call SqlDisconnect( hLocalSqlA )
						Return FALSE
					While SqlFetchNext( hLocalSqlA, nInd )
						Set nTotRoy = nTotRoy + nRoy
					If bLocalSqlA
						Call SqlDisconnect( hLocalSqlA )
					Call SalWaitCursor( FALSE )
					Return nTotRoy
			! Function: CalcTotals
				   Description: Calculates the total trees on order per customer from the the frmOnOrder.
						Calculates total trees, total fruit, total ornam, total current
				   Returns 
				   Parameters 
					   Sql Handle: hSqlHandle
					   String: sColumn
					   Number: nType
					   Number: nCustNo
					   Number: nCurrentItemNo
				   Static Variables 
				   Local variables 
					   String: sSql
					   Number: nInd
					   String: sCustNo
					   String: sItemNo
				   Actions 
					   Call SalWaitCursor( TRUE )
					   Call SalNumberToStr( nCustNo, 0, sCustNo )
					   Call SalNumberToStr( nCurrentItemNo, 0, sItemNo )
					   Select Case nType
						   Case nTotalTreesOrdAmts
							   Set sSql = 'SELECT SUM( Ordered_Amount ) FROM Customer_Order 
									  INTO :' || sColumn || '  WHERE Cust_No = '||sCustNo
							   Call MySqlPrepExecFetch( hSqlHandle, sSql, nInd )
							   Break 
						   Case nTotalTreesConfAmts
							   Set sSql = 'SELECT SUM( Conf_Amt ) FROM Customer_Order 
									  INTO :' || sColumn || '  WHERE Cust_No = '||sCustNo
							   Call MySqlPrepExecFetch( hSqlHandle, sSql, nInd )
							   Break 
						   Case nTotalFruitOrdAmts
							! denorm
							   Set sSql = 'SELECT SUM( Ordered_Amount ) 
									FROM Customer_Order, Stock_Item
									INTO :' || sColumn || ' WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									   Customer_Order.Cust_No = ' || sCustNo || ' AND 
									  Stock_Item.Variety_Type = \'F\' '
							! Set sSql = 'SELECT SUM( Ordered_Amount ) 
									FROM Customer_Order, Stock_Item, Cultivar 
									INTO :' || sColumn || ' WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									  Stock_Item.Cultivar_Id = Cultivar.Cult_Id AND 
									  Customer_Order.Cust_No = ' || sCustNo || ' AND 
									  Cultivar.Variety_Type = \'F\' '
							   Call MySqlPrepExecFetch( hSqlHandle, sSql, nInd )
							   Break 
						   Case nTotalFruitConfAmts
							! denorm
							   Set sSql = 'SELECT SUM( Conf_Amt ) 
									FROM Customer_Order, Stock_Item 
									INTO :' || sColumn || ' WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									    Customer_Order.Cust_No = ' || sCustNo || ' AND 
									  Stock_Item.Variety_Type = \'F\' '
							! Set sSql = 'SELECT SUM( Conf_Amt ) 
									FROM Customer_Order, Stock_Item, Cultivar 
									INTO :' || sColumn || ' WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									  Stock_Item.Cultivar_Id = Cultivar.Cult_Id AND 
									  Customer_Order.Cust_No = ' || sCustNo || ' AND 
									  Cultivar.Variety_Type = \'F\' '
							   Call MySqlPrepExecFetch( hSqlHandle, sSql, nInd )
							   Break 
						   Case nTotalOrnamOrdAmts
							! denorm
							   Set sSql = 'SELECT SUM( Ordered_Amount ) 
									FROM Customer_Order, Stock_Item 
									INTO :' || sColumn || ' WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									    Customer_Order.Cust_No = ' || sCustNo || ' AND 
									  Stock_Item.Variety_Type = \'O\' '
							! Set sSql = 'SELECT SUM( Ordered_Amount ) 
									FROM Customer_Order, Stock_Item, Cultivar 
									INTO :' || sColumn || ' WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									  Stock_Item.Cultivar_Id = Cultivar.Cult_Id AND 
									  Customer_Order.Cust_No = ' || sCustNo || ' AND 
									  Cultivar.Variety_Type = \'O\' '
							   Call MySqlPrepExecFetch( hSqlHandle, sSql, nInd )
							   Break 
						   Case nTotalOrnamConfAmts
							! denorm
							   Set sSql = 'SELECT SUM( Conf_Amt ) 
									FROM Customer_Order, Stock_Item 
									INTO :' || sColumn || ' WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									    Customer_Order.Cust_No = ' || sCustNo || ' AND 
									  Stock_Item.Variety_Type = \'O\' '
							! Set sSql = 'SELECT SUM( Conf_Amt ) 
									FROM Customer_Order, Stock_Item, Cultivar 
									INTO :' || sColumn || ' WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									  Stock_Item.Cultivar_Id = Cultivar.Cult_Id AND 
									  Customer_Order.Cust_No = ' || sCustNo || ' AND 
									  Cultivar.Variety_Type = \'O\' '
							   Call MySqlPrepExecFetch( hSqlHandle, sSql, nInd )
							   Break 
						   Case nTotalBalleOrdAmts
							! Item No's 3586, 1350, 3585, 1349 are Ballerinas Balero, 
									  Maypole, Polka & Waltz Generics respectively.
							! denorm
							   Set sSql = 'SELECT SUM( Ordered_Amount ) 
									FROM Customer_Order, Stock_Item 
									INTO :' || sColumn || ' WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									    Customer_Order.Cust_No = ' || sCustNo || ' AND 
									  Customer_Order.Stock_Item_NO IN (3586, 1350, 3585, 1349) '
							! Set sSql = 'SELECT SUM( Ordered_Amount ) 
									FROM Customer_Order, Stock_Item, Cultivar 
									INTO :' || sColumn || ' WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									  Stock_Item.Cultivar_Id = Cultivar.Cult_Id AND 
									  Customer_Order.Cust_No = ' || sCustNo || ' AND 
									  Customer_Order.Stock_Item_NO IN (3586, 1350, 3585, 1349) '
							   Call MySqlPrepExecFetch( hSqlHandle, sSql, nInd )
							   Break 
						   Case nTotalBalleConfAmts
							! Item No's 3586, 1350, 3585, 1349 are Ballerinas Balero, 
									  Maypole, Polka & Waltz Generics respectively.
							   Set sSql = 'SELECT SUM( Conf_Amt ) 
									FROM Customer_Order, Stock_Item
									INTO :' || sColumn || ' WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									    Customer_Order.Cust_No = ' || sCustNo || ' AND 
									  Customer_Order.Stock_Item_NO in (3586, 1350, 3585, 1349) '
							! Set sSql = 'SELECT SUM( Conf_Amt ) 
									FROM Customer_Order, Stock_Item, Cultivar 
									INTO :' || sColumn || ' WHERE 
									  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
									  Stock_Item.Cultivar_Id = Cultivar.Cult_Id AND 
									  Customer_Order.Cust_No = ' || sCustNo || ' AND 
									  Customer_Order.Stock_Item_NO in (3586, 1350, 3585, 1349) '
							   Call MySqlPrepExecFetch( hSqlHandle, sSql, nInd )
							   Break 
						   Case nTotalCurrentOrdAmts
							   Set sSql = 'SELECT SUM( Ordered_Amount ) FROM Customer_Order 
									  INTO :' || sColumn || ' WHERE Cust_No = ' || sCustNo || ' AND Stock_Item_No = ' || sItemNo
							   Call MySqlPrepExecFetch( hSqlHandle, sSql, nInd )
							   Break 
						   Case nTotalCurrentConfAmts
							   Set sSql = 'SELECT SUM( Conf_Amt ) FROM Customer_Order 
									  INTO :' || sColumn || ' WHERE Cust_No = ' || sCustNo || ' AND Stock_Item_No = ' || sItemNo
							   Call MySqlPrepExecFetch( hSqlHandle, sSql, nInd )
					   Call SalWaitCursor( FALSE )
			! Function: CalculateSubs
				   Description: For a given year and item no to add all of the substitutes together
						to get an interactive total
				   Returns 
					   Boolean: 
				   Parameters 
					   Window Handle: hWndCalledFrom
					   Number: nItemNo
					   Number: nYr
					   Receive Number: nSubs
				   Static Variables 
				   Local variables 
					   Number: nInd
					   Number: nMin
					   Number: nMax
					! Number: nTotalAvail
					! Number: nGraded
					   Boolean: bExists
					   Boolean: bLocalSqlB
					   Sql Handle: hLocalSqlB
					   String: sSql
				   Actions 
					   Set bLocalSqlB = SqlConnect( hLocalSqlB ) 
					   If bLocalSqlB
						   Call SqlSetLockTimeout( hLocalSqlB, SQLTIMEOUT )
					   Else 
						   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						   Return FALSE
					   Set nSubs = 0
					   Set ngYr = nYr
					   Set ngItemNo =  nItemNo
					   If NOT ObtainAllSubs(  )
						   Return FALSE
					   Set sSql = 'SELECT TOT_AVAIL, AMT_GRADED FROM
							 STOCK_ITEM_SALE INTO :ngTotal, :ngGraded
							WHERE STOCK_ITEM_SALE.STOCK_ITEM_NO = :ngSubItemNo[ngArray]
							AND STOCK_ITEM_SALE.YEAR_OF_SALE = :ngYr'
					   If NOT SqlPrepare( hLocalSqlB, sSql )
						   Return FALSE
					   Call SalQueryArrayBounds( ngSubItemNo, nMin, nMax )
					   Set ngArray = 0
					   While ngArray <= nMax
						   If SqlExecute( hLocalSqlB )
							   If NOT SqlFetchNext( hLocalSqlB, nInd )
								! Call SalMessageBox( 'SqlFetchNext had a error, in CalculateSubs.', 'Error', MB_Ok | MB_IconStop )
								   If bLocalSqlB
									   Call SqlDisconnect( hLocalSqlB )
								   Return FALSE
						   Else 
							   Call SalMessageBox( 'SqlExecute had a error, in CalculateSubs.', 'Error', MB_Ok | MB_IconStop )
							   If bLocalSqlB
								   Call SqlDisconnect( hLocalSqlB )
							   Return FALSE
						   If nInd != FETCH_EOF 
							! Wrong -  when the graded amount is changed in tblInv then we adjust the
									total available column then so we dont need to worry if we're using a graded
									figure or not cos it is still the total available that we use!!!  Need to check firstly if we are using the graded amount or the total from
									field counts amount - then need to check if it has an up to amount - if not
									then assume all as subs,  if so then need to check if the amt available is
									less than the up to amount cos we can only use what is available
							! If ngUpTo[ngArray] = NUMBER_Null
								   If ngGraded = 0
									   Set nSubs = nSubs + ngTotal
								   Else 
									   Set nSubs = nSubs + ngGraded
							! Else 
								   If ngGraded = 0
									   If ngTotal > ngUpTo[ngArray]
										   Set nSubs = nSubs + ngUpTo[ngArray] 
									   Else 
										   Set nSubs = nSubs + ngTotal
								   Else 
									   If ngGraded > ngUpTo[ngArray]
										   Set nSubs = nSubs + ngUpTo[ngArray]
									   Else 
										   Set nSubs = nSubs + ngGraded
							   If ngUpTo[ngArray] = NUMBER_Null
								   Set nSubs = nSubs + ngTotal
							   Else 
								   If ngTotal > ngUpTo[ngArray]
									   Set nSubs = nSubs + ngUpTo[ngArray] 
								   Else 
									   Set nSubs = nSubs + ngTotal
						   Set ngArray = ngArray + 1
					   If bLocalSqlB
						   Call SqlDisconnect( hLocalSqlB )
			Function: CalculateSubs
				Description: For a given year and item no to add all of the substitutes together
						to get an interactive total
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					Window Handle: hWndCalledFrom
					Number: nItemNo
					Number: nYr
					Receive Number: nSubs
				Static Variables
				Local variables
					Number: nInd
					Number: nMin
					Number: nMax
					! Number: nTotalAvail
					! Number: nGraded
					Boolean: bExists
					Boolean: bLocalSqlB
					Sql Handle: hLocalSqlB
					String: sSql
				Actions
					Set nSubs = 0
					Set ngYr = nYr
					Set ngItemNo =  nItemNo
					If NOT ObtainAllSubs(  )
						Return FALSE
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Set sSql = 'SELECT TOT_AVAIL, AMT_GRADED FROM
								 STOCK_ITEM_SALE INTO :ngTotal, :ngGraded
								WHERE STOCK_ITEM_SALE.STOCK_ITEM_NO = :ngSubItemNo[ngArray]
								AND STOCK_ITEM_SALE.YEAR_OF_SALE = :ngYr'
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					Call SalQueryArrayBounds( ngSubItemNo, nMin, nMax )
					Set ngArray = 0
					While ngArray <= nMax
						If SqlExecute( hSqlHandle )
							If NOT SqlFetchNext( hSqlHandle, nInd )
								Return FALSE
						Else
							Set bHandlePrepared = FALSE
							Return FALSE
						If nInd != FETCH_EOF 
							! Wrong -  when the graded amount is changed in tblInv then we adjust the
									total available column then so we dont need to worry if we're using a graded
									figure or not cos it is still the total available that we use!!!  Need to check firstly if we are using the graded amount or the total from
									field counts amount - then need to check if it has an up to amount - if not
									then assume all as subs,  if so then need to check if the amt available is
									less than the up to amount cos we can only use what is available
							If ngUpTo[ngArray] = NUMBER_Null
								Set nSubs = nSubs + ngTotal
							Else
								If ngTotal > ngUpTo[ngArray]
									Set nSubs = nSubs + ngUpTo[ngArray] 
								Else
									Set nSubs = nSubs + ngTotal
						Set ngArray = ngArray + 1
			Function: FetchInvRecord
				Description: For a given year and item no to fetch the on hand value
				Returns
					Number: nOnHand
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					Number: nItemNo
					Number: nYr
				Static Variables
				Local variables
					Number: nInd
					String: sSql
					Number: nOnHand
				Actions
					Set nOnHand = 0
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return 0
					If NOT bHandlePrepared
						Set sSql = ' SELECT TOT_AVAIL FROM
								STOCK_ITEM_SALE 
								INTO :nOnHand WHERE STOCK_ITEM_NO = :nItemNo AND 
								YEAR_OF_SALE = :nYr '
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						Call SqlFetchNext( hSqlHandle, nInd )
					Else
						Call SalMessageBox( 'SqlExecute had a error in function FetchInvRecord.  Please contact programmers.', 'Error', MB_Ok )
						Return 0
					Return nOnHand
			! Function: FetchAddressRecord
				   Description: For a given year and item no to fetch the on hand value
				   Returns 
					   Number: nOnHand
				   Parameters 
					   Receive Sql Handle: hSqlHandle
					   Receive Boolean: bHandleConnected
					   Receive Boolean: bHandlePrepared
					   Number: nItemNo
					   Number: nYr
				   Static Variables 
				   Local variables 
					   Number: nInd
					   String: sSql
					   Number: nOnHand
				   Actions 
					   Set nOnHand = 0
					   If NOT bHandleConnected
						   Set bHandleConnected = SqlConnect( hSqlHandle ) 
						   If bHandleConnected
							   Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							   Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						   Else 
							   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							   Return 0
					   If NOT bHandlePrepared
						   Set sSql = ' SELECT TOT_AVAIL FROM
								STOCK_ITEM_SALE 
								INTO :nOnHand WHERE STOCK_ITEM_NO = :nItemNo AND 
								YEAR_OF_SALE = :nYr '
						   If SqlPrepare( hSqlHandle, sSql )
							   Set bHandlePrepared = TRUE
						   Else 
							   Set bHandlePrepared = FALSE
					   If SqlExecute( hSqlHandle )
						   Call SqlFetchNext( hSqlHandle, nInd )
					   Else 
						   Call SalMessageBox( 'SqlExecute had a error in function FetchInvRecord.  Please contact programmers.', 'Error', MB_Ok )
						   Return 0
					   Return nOnHand
			! Function: GetAnyShippingAddressForCust 
				   Description: To search for the shipping address of the given customer No.
						and if one type doesnt exists retrieve the next of address which
						could be used for shipping. - used in dlgQItem in checking for 
						a prohibition address
				   Returns 
					   String: 
				   Parameters 
					   Number: nCustNo
				   Static Variables 
				   Local variables 
					   Boolean: bExists
					   String: sAddType
					   String: sSql
				   Actions 
					   Set sAddType = 'SHIP'
					   Set sSql = 'SELECT 
							  Customer_Address.Address_Type
							FROM
							  Customer_Address
							WHERE
							  Customer_Address.Cust_No = :nCustNo AND
							  Customer_Address.Address_Type = :sAddType'
					   Loop 
						   If SqlExists( sSql, bExists )
							   If bExists
								   Return sAddType
							   Else If sAddType = 'SHIP'
								   Set sAddType = 'RAIL'
							   Else If sAddType = 'RAIL'
								   Set sAddType = 'BUS'
							   Else If sAddType = 'BUS'
								   Set sAddType = 'HOME'
							   Else If sAddType = 'HOME'
								   Set sAddType = 'POSTAL'
							   Else If sAddType = 'POSTAL'
								   Break 
					   Set sSql = 'SELECT 
							  Customer_Address.Address_Type
							FROM
							  Customer_Address 
							INTO 
							  :sAddType
							WHERE
							  Customer_Address.Cust_No = :nCustNo'
					   Call SqlImmediate( sSql )
					   Call SqlClearImmediate(  )
					   Return sAddType
			!
			! Functions used only by frmOrderDets which is Allocations
			!
			! Function: LoadForOrder
				   Description: To check if this customer has any other orders on any other loads, if one
						add this order to that load, if more than one display a dialog box
						requesting which load to add it to - does not have to be given a load
				   Returns 
				   Parameters 
				   Static Variables 
				   Local variables 
					   Boolean: bLocalSqlA
					   Sql Handle: hLocalSqlA
				   Actions 
					! LOCAL SQL HANDLE CONNECTION, disconnect are on exit pointS
					   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					   If bLocalSqlA
						   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					   Else 
						! Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						   Return FALSE
					!
					   Set ngArray = 0
					   Call SalQueryArrayBounds( sgLoadId, ngMin, ngMax )
					   While ngArray <= ngMax
						   Set sgLoadId[ngArray] = ' '
						   Set sgPulled[ngArray] = ' '
						   Set ngArray = ngArray + 1
					   Call SalSetArrayBounds( sgLoadId, AC_Dynamic, AC_Dynamic )
					   Set ngArray = 0
					! Set sgSql = 'SELECT DISTINCT LOAD_ID FROM CUSTOMER_ORDER INTO :sgLoadId[ngArray] WHERE
							 CUSTOMER_ORDER.CUST_NO = :frmOrderDets.dfCustno AND YEAR_OF_SALE
							= :frmOrderDets.dfYr'
					   Set sgSql = 'SELECT DISTINCT LOAD_CUSTOMERS.LOAD_ID, 
							LOAD.LOAD_PULLED_FLAG  FROM LOAD_CUSTOMERS, LOAD
							 INTO :sgLoadId[ngArray], :sgPulled[ngArray] WHERE 
							 LOAD_CUSTOMERS.CUST_NO = :frmOrderDets.dfCustno AND 
							LOAD.SHIPPING_DATE >= :frmOrderDets.dfCurrDate AND 
							LOAD.LOAD_ID = LOAD_CUSTOMERS.LOAD_ID'
					   If NOT SqlOK( hLocalSqlA, sgSql )
						   If bLocalSqlA
							   Call SqlDisconnect( hLocalSqlA )
						   Return FALSE
					   While SqlFetchNext( hLocalSqlA, ngFetch )
						   Set ngArray = ngArray + 1
					   Set ngArray = 0
					   Call SalQueryArrayBounds( sgLoadId, ngMin, ngMax )
					! USED TO BE If sgLoadId[0]
					   If sgLoadId[ngMin] = ' '
						! Jan, check the logic in the following routine
						   Call NumLoadToRegionLeft(  )
						   If bLocalSqlA
							   Call SqlDisconnect( hLocalSqlA )
						   Return FALSE
					! Jan commented the else if ngMax = ngMin cause the load dialog should come up
							  even if the customer has one order on a load, and not automaticaly 
					! Else If ngMax = ngMin
						   If sgPulled[ngMin] = 'Y'
							! Call SalMessageBox( 'The last load this customer has trees on has been
									pulled.   Please notify despatch to see if it can be included on this load still',
									 'Loads for this Order', MB_Ok )
							   If bLocalSqlA
								   Call SqlDisconnect( hLocalSqlA )
							   Return FALSE
						   Else
							   Call PushString( sgLoadId[ngMin] )
							   Call SalSendMsg( frmOrderDets.dfLoadId, PAM_LOOKUPLOAD, 0, 0 )
							   If bLocalSqlA
								   Call SqlDisconnect( hLocalSqlA )
							   Return TRUE
					   Else If ngMax >= ngMin 
						   Call PushNumber( frmOrderDets.dfCustno )
						   If SalModalDialog( dlgLoad, frmOrderDets )
							   Call SalSendMsgToChildren( frmOrderDets, PAM_LOOKUPLOAD, 0, 0 )
							   If bLocalSqlA
								   Call SqlDisconnect( hLocalSqlA )
							   Return TRUE
					   If bLocalSqlA
						   Call SqlDisconnect( hLocalSqlA )
			! Function: AddOrd
				   Description: To add a record into table Customer order
				   Returns 
					   Boolean: 
				   Parameters 
				   Static Variables 
				   Local variables 
					   Boolean: bLocalSqlA
					   Sql Handle: hLocalSqlA
					   String: sSql
					   Boolean: bExists
				   Actions 
					! LOCAL SQL HANDLE CONNECTION
					   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					   If bLocalSqlA
						   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					   Else 
						! Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						   Return FALSE
					!
					   Set bgEdit = FALSE
					   If NOT AdditionLogic(  )
						   Call MySqlPrepExec( hLocalSqlA, 'rollback' )
						   If bLocalSqlA
							   Call SqlDisconnect( hLocalSqlA )
						   Return FALSE
					! Call LoadForOrder(  )
					   Call CallBuildSql( hWndForm,nINSERT, PAM_INSERTUPDATE, ' CUSTOMER_ORDER ', '' )
					   If SqlOK( hLocalSqlA, sgSql )
						   Call SqlCommit( hLocalSqlA )
						! On addition of an order we wish to clear the screen and reset it 
						! Call PushNumber( frmOrderDets.dfCustno )
						! Call PushString(  frmOrderDets.dfCustname )
						! Call ClearOrd (  )
					   Else 
						! Call SalMessageBox ('Record Addition Unsuccessful','Add Error', MB_RetryCancel )
						   Call MySqlPrepExec( hLocalSqlA, 'rollback' )
						   If bLocalSqlA
							   Call SqlDisconnect( hLocalSqlA )
						! Need to reset fields and allow
						   Return FALSE
					! LOCAL SQL HANDLE CLOSURE
					   If bLocalSqlA
						   Call SqlDisconnect( hLocalSqlA )
					   Return TRUE
			! Function: SaveOrd
				   Description: Save the changes done to an order
				   Returns 
					   Boolean: 
				   Parameters 
				   Static Variables 
				   Local variables 
					   Boolean: bLocalSqlA
					   Sql Handle: hLocalSqlA
					   String: sSql
					   Boolean: bExists
				   Actions 
					! LOCAL SQL HANDLE CONNECTION
					   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					   If bLocalSqlA
						   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					   Else 
						! Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						   Return FALSE
					!
					   Set bgEdit = FALSE
					   If NOT ChangeLogic(  )
						   Call MySqlPrepExec( hLocalSqlA, 'rollback' )
						   If bLocalSqlA
							   Call SqlDisconnect( hLocalSqlA )
						   Return FALSE
					   Call CallBuildSql( hWndForm, nUPDATE, PAM_INSERTUPDATE, ' CUSTOMER_ORDER ', CNORD )
					   If SqlOK(  hLocalSqlA,sgSql )
						   Call SqlCommit( hLocalSqlA )
						   Set bgEdit = FALSE
					   Else 
						   Call MySqlPrepExec( hLocalSqlA, 'rollback' )
						   If bLocalSqlA
							   Call SqlDisconnect( hLocalSqlA )
						   Return FALSE
					! LOCAL SQL HANDLE CLOSURE
					   If bLocalSqlA
						   Call SqlDisconnect( hLocalSqlA )
					   Return TRUE
			! Function: AdditionLogic
				   Description: To handle the logic required when adding a customer order 
				   Returns 
					   Boolean: 
				   Parameters 
				   Static Variables 
				   Local variables 
				   Actions 
					   Set ngItemNo = hWndForm.dfItemNo
					   Set bgGeneric = CheckIfGeneric( ngItemNo  )
					   If AddToStockItemSale(  )
						   Return TRUE
					   Else 
						   Return FALSE
			! Function: ChangeLogic
				   Description: To handle the logic required when changing a customer order 
				   Returns 
					   Boolean: 
				   Parameters 
				   Static Variables 
				   Local variables 
				   Actions 
					   Set ngItemNo = hWndForm.dfItemNo
					   Set bgGeneric = CheckIfGeneric( ngItemNo )
					   If ngOldYr = hWndForm.dfYr
						   If ngOldItemNo = hWndForm.dfItemNo
							   If ngOldOrdAmt = hWndForm.dfOrdAmt
								   If sgOldAlloc = hWndForm.dfAlloc
									   If ngOldConfAmt = hWndForm.dfConfAmt
										! Then nothing has changed to the 5 fields that impact the total amount on order
												so we dont need to update anything 
										   Return TRUE
					   Set bgOldItemGeneric = CheckIfGeneric( ngOldItemNo )
					   Call DeductFromStockItemSale(  )
					   If hWndForm.dfSubsItemNo > 0 
						   Call DeleteFromSub(  )
					   If AddToStockItemSale(  )
						   Return TRUE
					   Else 
						   Return FALSE
			! Function: AddToStockItemSale
				   Description: To update the stock item sale values with the ordered amt whether
						it be the conf amount or the ordered amount
				   Returns 
					   Boolean: 
				   Parameters 
				   Static Variables 
				   Local variables 
					   Boolean: bLocalSqlA
					   Sql Handle: hLocalSqlA
				   Actions 
					! LOCAL SQL HANDLE CONNECTION, CLOSURE ON EXIT pointS.
					   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					   If bLocalSqlA
						   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					   Else 
						! Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						   Return FALSE
					!
					   Set sgSql = 'SELECT AMT_ON_ORDER,TOT_AVAIL FROM STOCK_ITEM_SALE 
							INTO :hWndForm.nAmtOnOrder,:hWndForm.nTotAvail  WHERE STOCK_ITEM_NO =
							 :hWndForm.dfItemNo AND YEAR_OF_SALE = :hWndForm.dfYr'
					   If SqlOK( hLocalSqlA,sgSql )
						   If SqlFetchNext( hLocalSqlA,ngFetch )
							   If ngFetch !=FETCH_EOF
								   If hWndForm.dfAlloc = 'N'
									   Set hWndForm.nAmtOnOrder = hWndForm.nAmtOnOrder + hWndForm.dfOrdAmt
									   Set hWndForm.nTotAvail = hWndForm.nTotAvail - hWndForm.dfOrdAmt
								   Else 
									   Set hWndForm.nAmtOnOrder = hWndForm.nAmtOnOrder + hWndForm.dfConfAmt
									   Set hWndForm.nTotAvail = hWndForm.nTotAvail - hWndForm.dfConfAmt
								   If hWndForm.nTotAvail < 20
									! If NOT bgGeneric
										   If hWndForm.dfSubs = 'N'
											! If IDNO = SalMessageBox( 'Available stock levels are less than 20.   Do you
													still want to add the order?', 'Customer Order', MB_YesNo )
												   Return FALSE
										   Else
											   If NOT StockAvailable(  )
												   Return FALSE
											   Else
												   Return TRUE
									! Else If NOT StockAvailable(  )
										   Return FALSE
									   If NOT bgGeneric
										   If hWndForm.dfSubs = 'N'
											! If IDNO = SalMessageBox( 'Available stock levels are less than 20.   Do you
													still want to add the order?', 'Customer Order', MB_YesNo )
												   If bLocalSqlA
													   Call SqlDisconnect( hLocalSqlA )
												   Return FALSE
										   Else 
											   If StockAvailable(  )
												   If bLocalSqlA
													   Call SqlDisconnect( hLocalSqlA )
												   Return TRUE
											   Else 
												! If IDNO = SalMessageBox( 'Available stock levels are less than 20.   Do you
														still want to add the order?', 'Customer Order', MB_YesNo )
													   If bLocalSqlA
														   Call SqlDisconnect( hLocalSqlA )
													   Return FALSE
									   Else If NOT StockAvailableForGen(  )
										! Call SalMessageBox( 'There is no stock available for this generic stock item!,  Either substitutes have no stock counts, or there are no substitutes!  Please refer to the STOCK ITEMS program.  YOUR order has NOT been ADDED!', 'Warning', 
												MB_Ok|MB_IconExclamation )
										   If bLocalSqlA
											   Call SqlDisconnect( hLocalSqlA )
										   Return FALSE
								   If bgGeneric
									   Set hWndForm.nTotAvail = 0
								   Set sgSql = 'UPDATE STOCK_ITEM_SALE SET AMT_ON_ORDER
										=:frmOrderDets.nAmtOnOrder, TOT_AVAIL = :frmOrderDets.nTotAvail WHERE
										 STOCK_ITEM_NO = :frmOrderDets.dfItemNo AND YEAR_OF_SALE=
										 :frmOrderDets.dfYr'
								   If MySqlImmediate( sgSql )
									   If bLocalSqlA
										   Call SqlDisconnect( hLocalSqlA )
									   Return TRUE
								   Else 
									! Call SalMessageBox( 'Problem updating Stock-item-sale with the total ordered.
											 Please contact programmer','Customer Order', MB_Ok )
									   If bLocalSqlA
										   Call SqlDisconnect( hLocalSqlA )
									   Return FALSE
							   Else 
								! Call SalMessageBox( 'Record Not Found','No Record', MB_Ok )
								   If bLocalSqlA
									   Call SqlDisconnect( hLocalSqlA )
								   Return FALSE
						   Else 
							! Call SalMessageBox( 'Record Not Found','No Record', MB_Ok )
							   If bLocalSqlA
								   Call SqlDisconnect( hLocalSqlA )
							   Return FALSE
					   Else 
						! Call SalMessageBox( 'Error fetching record','No Record', MB_Ok )
						   If bLocalSqlA
							   Call SqlDisconnect( hLocalSqlA )
						   Return FALSE
					   If bLocalSqlA
						   Call SqlDisconnect( hLocalSqlA )
					   Return FALSE
			! Function: DeductFromStockItemSale
				   Description: To deduct the ord or conf amt from the old stock item sale values
				   Returns 
					   Boolean: 
				   Parameters 
				   Static Variables 
				   Local variables 
					   Boolean: bLocalSqlA
					   Sql Handle: hLocalSqlA
				   Actions 
					! LOCAL SQL HANDLE CONNECTION
					   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					   If bLocalSqlA
						   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					   Else 
						! Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						   Return FALSE
					!
					   Set sgSql = 'SELECT AMT_ON_ORDER,TOT_AVAIL FROM STOCK_ITEM_SALE 
							INTO :hWndForm.nAmtOnOrder,:hWndForm.nTotAvail  WHERE STOCK_ITEM_NO =
							 :ngOldItemNo AND YEAR_OF_SALE = :ngOldYr'
					   If SqlOK( hLocalSqlA,sgSql )
						   If SqlFetchNext( hLocalSqlA,ngFetch )
							   If ngFetch !=FETCH_EOF
								   If sgOldAlloc = 'N'
									   Set hWndForm.nAmtOnOrder = hWndForm.nAmtOnOrder - ngOldOrdAmt
									   Set hWndForm.nTotAvail = hWndForm.nTotAvail + ngOldOrdAmt
								   Else 
									   Set hWndForm.nAmtOnOrder = hWndForm.nAmtOnOrder - ngOldConfAmt
									   Set hWndForm.nTotAvail = hWndForm.nTotAvail + ngOldConfAmt
								   If bgOldItemGeneric
									   Set hWndForm.nTotAvail = 0
								   Set sgSql = 'UPDATE STOCK_ITEM_SALE SET AMT_ON_ORDER
										=:frmOrderDets.nAmtOnOrder, TOT_AVAIL = :frmOrderDets.nTotAvail  WHERE
										 STOCK_ITEM_NO = :ngOldItemNo AND YEAR_OF_SALE = :ngOldYr'
								   If NOT MySqlImmediate( sgSql )
									! Call SalMessageBox( 'Problem updating old Stock-item-sale with the total ordered.
											 Please contact programmer','Customer Order', MB_Ok )
							   Else 
								! Call SalMessageBox( 'Record Not Found','No Record', MB_Ok )
						   Else 
							! Call SalMessageBox( 'Record Not Found','No Record', MB_Ok )
					   Else 
						! Call SalMessageBox( 'Error fetching record','No Record', MB_Ok )
					! LOCAL SQL HANDLE CLOSURE
					   If bLocalSqlA
						   Call SqlDisconnect( hLocalSqlA )
			Function: ObtainAllSubs
				Description: To obtain in a dynamic array all of the available substitutes for this item
				Returns
					Boolean:
				Parameters
				Static Variables
				Local variables
					Boolean: bLocalSqlA
					Sql Handle: hLocalSqlA
				Actions
					! LOCAL SQL HANDLE CONNECTION, DISCONNECT ON exit pointS
					Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					If bLocalSqlA
						Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					Else
						! Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						Return FALSE
					!
					! To be here sgGeneric = Y, or subs ok = Y and we need to find out for this item no
							 which in order of priority as substitutes have available stock for this order
					Set ngArray = 0
					Call SalQueryArrayBounds( ngSubItemNo, ngMin, ngMax )
					While ngArray <= ngMax
						Set ngSubItemNo[ngArray] = 0
						Set ngArray = ngArray + 1
					Set ngArray = 0
					Set sgSql = 'SELECT SUBSTITUTE_ITEM_NO,SUB_UP_TO_MAX FROM SUBSTITUTES INTO
							:ngSubItemNo[ngArray],:ngUpTo[ngArray] WHERE STOCK_ITEM_NO = :ngItemNo' 
					If NOT SqlOK( hLocalSqlA, sgSql )
						! Call SalMessageBox( 'Error, this stock item  has no items as substitutes',
								 'Customer Order', MB_Ok )
						If bLocalSqlA
							Call SqlDisconnect( hLocalSqlA )
						Return FALSE
					While SqlFetchNext( hLocalSqlA, ngFetch )
						! Jan, added the if ngFetch = fetch_eof then break to prevent the array from
								looking like it has 1 substitute when in fact the sgSql statement didn't
								come back with any.
						If ngFetch  = FETCH_EOF
							Break
						Set ngArray = ngArray + 1
					If bLocalSqlA
						Call SqlDisconnect( hLocalSqlA )
					Return TRUE
			! Function: AddToAvailSub
				   Description: We need to add to the on-ord-as-subs field of the item that will 
						be substituted for it
				   Returns 
					   Boolean: 
				   Parameters 
				   Static Variables 
				   Local variables 
				   Actions 
					   Set ngArray = 0
					   Call SalQueryArrayBounds( ngSubItemNo, ngMin, ngMax )
					   While ngArray <= ngMax
						   Set sgSql = 'SELECT ON_ORD_AS_SUBS,TOT_AVAIL FROM STOCK_ITEM_SALE 
								INTO :hWndForm.nOnOrdSub,:hWndForm.nSubTotAvail  WHERE STOCK_ITEM_NO =
								 :ngSubItemNo[ngArray] AND YEAR_OF_SALE = :hWndForm.dfYr'
						   If NOT SqlOK( frmOrderDets.hLocalSqlC,sgSql )
							! Call SalMessageBox( 'Record Not Found','No Record', MB_Ok )
							   Return FALSE
						   If SqlFetchNext( frmOrderDets.hLocalSqlC, ngFetch )
							   If ngFetch !=FETCH_EOF
								   If hWndForm.dfAlloc = 'N'
									   Set hWndForm.nOnOrdSub = hWndForm.nOnOrdSub + hWndForm.dfOrdAmt
									   Set hWndForm.nSubTotAvail = hWndForm.nSubTotAvail - hWndForm.dfOrdAmt
								   Else 
									   Set hWndForm.nOnOrdSub = hWndForm.nOnOrdSub + hWndForm.dfConfAmt
									   Set hWndForm.nSubTotAvail = hWndForm.nSubTotAvail - hWndForm.dfConfAmt
								! Check if nOnOrdSub > max available then dont allow the addition to this sub.
								! the following up to array statement succeeded for the first sub but didnt
										allow the addition for the second sub which was ok 
								   If ngUpTo[ngArray] != NUMBER_Null
									   If hWndForm.nOnOrdSub > ngUpTo[ngArray]
										   Set ngArray = ngArray + 1
								   If hWndForm.nSubTotAvail > 20
									   Set sgSql = 'UPDATE STOCK_ITEM_SALE SET ON_ORD_AS_SUBS
											=:frmOrderDets.nOnOrdSub, TOT_AVAIL = :frmOrderDets.nSubTotAvail WHERE
											 STOCK_ITEM_NO = :ngSubItemNo[ngArray] AND YEAR_OF_SALE=
											 :frmOrderDets.dfYr'
									   If MySqlImmediate( sgSql )
										   Call PushNumber( ngSubItemNo[ngArray] )
										   Call SalSendMsgToChildren( hWndForm, PAM_LOOKUPSUB, 0, 0 )
										   Return TRUE
									   Else 
										   Set ngArray = ngArray + 1
								   Else 
									   Set ngArray = ngArray + 1
								! If ngUpTo[ngArray] > hWndForm.nOnOrdSub 
									   If hWndForm.nSubTotAvail > 20
										   Set sgSql = 'UPDATE STOCK_ITEM_SALE SET ON_ORD_AS_SUBS
												=:hWndForm.nOnOrdSub, TOT_AVAIL = :hWndForm.nSubTotAvail WHERE
												 STOCK_ITEM_NO = :ngSubItemNo[ngArray] AND YEAR_OF_SALE=
												 :hWndForm.dfYr'
										   If SqlImmediate( sgSql )
											   Call SqlClearImmediate(  )
											   Call PushNumber( ngSubItemNo[ngArray] )
											   Call SalSendMsgToChildren( hWndForm, PAM_LOOKUPSUB, 0, 0 )
											   Return TRUE
										   Else
											   Call SqlClearImmediate(  )
											   Set ngArray = ngArray + 1
									   Else
										   Set ngArray = ngArray + 1
								! Else 
									   Set ngArray = ngArray + 1
							   Else 
								   Set ngArray = ngArray + 1
						   Else 
							   Set ngArray = ngArray + 1
					! If the user has been asked if they still want the record added and they do, then
							we need to add and return true - otherwise they dont want to add it so return
							false.  In the main part we can check if it is a generic stock item if the return has
							been true cos this is the only instance where we want to continue to include this
							order in the ordered field
					   If NOT QueryOrderAddition(  )
						   Return FALSE
					   Else 
						   Return TRUE
			! Function: DeleteFromSub
				   Description: 
				   Returns 
					   Boolean: 
				   Parameters 
				   Static Variables 
				   Local variables 
					   Boolean: bLocalSqlA
					   Sql Handle: hLocalSqlA
				   Actions 
					! LOCAL SQL HANDLE CONNECTION
					   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					   If bLocalSqlA
						   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					   Else 
						! Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						   Return FALSE
					!
					   Set sgSql = 'SELECT ON_ORD_AS_SUBS,TOT_AVAIL FROM STOCK_ITEM_SALE 
							INTO :hWndForm.nOnOrdSub,:hWndForm.nSubTotAvail  WHERE STOCK_ITEM_NO =
							 :hWndForm.dfSubsItemNo AND YEAR_OF_SALE = :ngOldYr'
					   If NOT SqlOK( hLocalSqlA,sgSql )
						! Call SalMessageBox( 'Record Not Found', 'No Record', MB_Ok )
						   If bLocalSqlA
							   Call SqlDisconnect( hLocalSqlA )
						   Return FALSE
					   If SqlFetchNext( hLocalSqlA, ngFetch )
						   If ngFetch != FETCH_EOF
							   If sgOldAlloc = 'N'
								   Set hWndForm.nOnOrdSub = hWndForm.nOnOrdSub - ngOldOrdAmt
								   Set hWndForm.nSubTotAvail = hWndForm.nSubTotAvail + ngOldOrdAmt
							   Else 
								   Set hWndForm.nOnOrdSub = hWndForm.nOnOrdSub - ngOldConfAmt
								   Set hWndForm.nSubTotAvail = hWndForm.nSubTotAvail + ngOldConfAmt
							   Set sgSql = 'UPDATE STOCK_ITEM_SALE SET ON_ORD_AS_SUBS
									=:frmOrderDets.nOnOrdSub, TOT_AVAIL = :frmOrderDets.nSubTotAvail  WHERE
									 STOCK_ITEM_NO = :frmOrderDets.dfSubsItemNo AND YEAR_OF_SALE
									 = :ngOldYr'
							   If MySqlImmediate( sgSql )
								   Call PushNumber( 0 )
								   Call SalSendMsgToChildren( hWndForm, PAM_LOOKUPSUB, 0, 0 )
								   If bLocalSqlA
									   Call SqlDisconnect( hLocalSqlA )
								   Return TRUE
						   Else 
							! Call SalMessageBox( 'Unable to delete the order.    Please notify programmers ',
									 'Customer Order', MB_Ok )
							   If bLocalSqlA
								   Call SqlDisconnect( hLocalSqlA )
							   Return FALSE
					! Call SalMessageBox( 'Unable to delete the order.    Please notify programmers',
							 'Customer Order', MB_Ok )
					! LOCAL SQL HANDLE CLOSURE
					   If bLocalSqlA
						   Call SqlDisconnect( hLocalSqlA )
					   Return FALSE
			! Function: QueryOrderAddition
				   Description: This is called if we've tried to find a suitable substitute to use, cant
						find any, so we want to ask the user if they still want it added - if so
						add the order to the first substitute for the stock item
				   Returns 
					   Boolean: 
				   Parameters 
				   Static Variables 
				   Local variables 
				   Actions 
					! Latest change added if not bgGeneric then return false
					   If NOT bgGeneric
						   Return FALSE
					! If IDNO = SalMessageBox( 'Available stock levels are less than 20.   Do you
							still want to add the order?', 'Customer Order',
							 MB_YesNo )
						   Return FALSE
					   Set ngArray = 0
					   Set sgSql = 'SELECT ON_ORD_AS_SUBS,TOT_AVAIL FROM STOCK_ITEM_SALE 
							INTO :hWndForm.nOnOrdSub,:hWndForm.nSubTotAvail  WHERE STOCK_ITEM_NO =
							 :ngSubItemNo[ngArray] AND YEAR_OF_SALE = :hWndForm.dfYr'
					   If NOT SqlOK( frmOrderDets.hLocalSqlC,sgSql )
						! Call SalMessageBox( 'Record Not Found','No Record', MB_Ok )
						   Return FALSE
					   If SqlFetchNext( frmOrderDets.hLocalSqlC, ngFetch )
						   If ngFetch !=FETCH_EOF
							   If hWndForm.dfAlloc = 'N'
								   Set hWndForm.nOnOrdSub = hWndForm.nOnOrdSub + hWndForm.dfOrdAmt
								   Set hWndForm.nSubTotAvail = hWndForm.nSubTotAvail - hWndForm.dfOrdAmt
							   Else 
								   Set hWndForm.nOnOrdSub = hWndForm.nOnOrdSub + hWndForm.dfConfAmt
								   Set hWndForm.nSubTotAvail = hWndForm.nSubTotAvail - hWndForm.dfConfAmt
							   Set sgSql = 'UPDATE STOCK_ITEM_SALE SET ON_ORD_AS_SUBS
									=:frmOrderDets.nOnOrdSub, TOT_AVAIL = :frmOrderDets.nSubTotAvail WHERE
									 STOCK_ITEM_NO = :ngSubItemNo[ngArray] AND YEAR_OF_SALE=
									 :frmOrderDets.dfYr'
							   If MySqlImmediate( sgSql )
								   Call PushNumber( ngSubItemNo[ngArray] )
								   Call SalSendMsgToChildren( hWndForm, PAM_LOOKUPSUB, 0, 0 )
								   Return TRUE
							   Else 
								   Return FALSE
						   Else 
							   Return FALSE
			! Function: StockAvailable
				   Description: To process the handling of availability of stock
				   Returns 
					   Boolean: 
				   Parameters 
				   Static Variables 
				   Local variables 
				   Actions 
					! To be here subs are allowable for this order either because it is a generic or 
							substitutes are allowable for it 
					   If NOT ObtainAllSubs(  )
						! If NOT SalMessageBox( 'Available stock levels are less than 20.   Do you
								still want to add the order?', 'Customer Order',
								 MB_YesNo )
							   Return FALSE
						! Else 
						   Return TRUE
					   If NOT AddToAvailSub(  )
						! If IDNO = SalMessageBox( 'Available stock levels are less than 20.   Do you
								still want to add the order?', 'Customer Order',
								 MB_YesNo )
							   Return FALSE
						! Else 
							   Return TRUE
						   Return FALSE
					   Else 
						! Return FALSE
						   Return TRUE
			! Function: StockAvailableForGen
				   Description: To process the handling of availability of stock for generic
				   Returns 
					   Boolean: 
				   Parameters 
				   Static Variables 
				   Local variables 
				   Actions 
					! To be here subs are allowable for this order either because it is a generic or 
							substitutes are allowable for it 
					   If NOT ObtainAllSubs(  )
						! If NOT SalMessageBox( 'Available stock levels are less than 20.   Do you
								still want to add the order?', 'Customer Order',
								 MB_YesNo )
							   Return FALSE
						! Else 
						   Return TRUE
					   If NOT AddToAvailSub(  )
						! If IDNO = SalMessageBox( 'Available stock levels are less than 20.   Do you
								still want to add the order?', 'Customer Order',
								 MB_YesNo )
							   Return FALSE
						! Else 
							   Return TRUE
						   Return FALSE
					   Else 
						! Return FALSE
						   Return TRUE
			! Function: NumLoadToRegionLeft
				   Description: To check if a customer order has been added and has not been 
						assigned a load yet, if there is only one more load to their region
						left to display a warning if it has already been pulled 
				   Returns 
				   Parameters 
				   Static Variables 
				   Local variables 
					   Boolean: bLocalSqlA
					   Sql Handle: hLocalSqlA
				   Actions 
					! LOCAL SQL HANDLE CONNECTION, DISCONNECT ARE on exit pointS
					   Set bLocalSqlA = SqlConnect( hLocalSqlA ) 
					   If bLocalSqlA
						   Call SqlSetLockTimeout( hLocalSqlA, SQLTIMEOUT )
					   Else 
						! Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
						   Return FALSE
					!
					   Set ngArray = 0
					   Call SalQueryArrayBounds( sgLoadId, ngMin, ngMax )
					   While ngArray <= ngMax
						   Set sgLoadId[ngArray] = ' '
						   Set sgPulled[ngArray] = ' '
						   Set ngArray = ngArray + 1
					   Call SalSetArrayBounds( sgLoadId, AC_Dynamic, AC_Dynamic )
					   Set ngArray = 0
					! I think this should have the shipping date as part of the where clause also
					   Set sgSql = 'SELECT LOAD.LOAD_ID,LOAD_PULLED_FLAG FROM 
							CUSTOMER_MASTER,REGION_LOAD,LOAD INTO
							 :sgLoadId[ngArray], :sgPulled[ngArray] WHERE
							 CUSTOMER_MASTER.CUST_NO = :frmOrderDets.dfCustno AND
							REGION_LOAD.REGION_ID = CUSTOMER_MASTER.REGION_ID AND 
							LOAD.LOAD_ID = REGION_LOAD.LOAD_ID'
					   If NOT SqlOK( hLocalSqlA, sgSql )
						   If bLocalSqlA
							   Call SqlDisconnect( hLocalSqlA )
						   Return FALSE
					   While SqlFetchNext( hLocalSqlA, ngFetch )
						   Set ngArray = ngArray + 1
					   Set ngArray = 0
					   Call SalQueryArrayBounds( sgLoadId, ngMin, ngMax )
					   If ngMax = ngMin
						   If sgPulled[ngMin] = 'Y'
							! Call SalMessageBox( 'The last load for this region has been
									pulled.   Please notify despatch to see if it can be included on this load still',
									 'Loads for this Order', MB_Ok )
					   If bLocalSqlA
						   Call SqlDisconnect( hLocalSqlA )
			! Function: ClearOrd 
				   Description: Clear the screen and reset field defaults
				   Returns 
				   Parameters 
				   Static Variables 
				   Local variables 
				   Actions 
					   Call InitTopLevelWindow( hWndForm )
					   Call SalSetFocus( frmOrderDets.dfYr )
					   Set bgNew = TRUE
					   Call PopString(  frmOrderDets.dfCustname, TRUE )
					   Call PopNumber(  frmOrderDets.dfCustno, TRUE )
					   Call SalSendMsgToChildren( hWndForm,PAM_NEWREC,0,0 )
					   Set bgEdit = FALSE
			! Function: VerifyStockItemSale
				   Description: To verify that the year,itemno combination is a valid one prior to addition
						and modification and if not if the stock item is a generic then to add it
						otherwise request from the user whether they want it added or not 
				   Returns 
					   Boolean: 
				   Parameters 
				   Static Variables 
				   Local variables 
					   Number: nStockItem
				   Actions 
					   Set nStockItem = 0
					   Set sgSql = 'SELECT  STOCK_ITEM_NO FROM
							 STOCK_ITEM_SALE INTO :nStockItem WHERE STOCK_ITEM_NO =
							:hWndForm.dfItemNo AND YEAR_OF_SALE = :hWndForm.dfYr'
					   If NOT SqlImmediate( sgSql )
						   Call SqlClearImmediate(  )
						! Call SalMessageBox( 'Error in reading Stock Item Sale file', 'Customer Order', MB_Ok )
						   Return FALSE
					   Call SqlClearImmediate(  )
					   If nStockItem = 0
						! means that there is no record for this item,year combination 
						   Set sgGeneric = ''
						   Set sgSql = 'SELECT  STOCK_ITEM.GENERIC_STOCK_ITEM FROM
								 STOCK_ITEM_SALE,STOCK_ITEM INTO :sgGeneric WHERE STOCK_ITEM_NO =
								:hWndForm.dfItemNo AND YEAR_OF_SALE = :hWndForm.dfYr AND
								 STOCK_ITEM_SALE.STOCK_ITEM_NO = STOCK_ITEM.ITEM_NO'
						   Call SqlImmediate( sgSql )
						   Call SqlClearImmediate(  )
						   If sgGeneric = 'N'
							! If NOT SalMessageBox( 'The year, item no combination doesnt exist.   Would 
									you like it entered?', 'Customer Order', MB_YesNo )
								   Return FALSE
						! To be here sgGeneric = Y or sgGeneric = N and they want the combination entered
						   Set sgSql = 'INSERT INTO STOCK_ITEM_SALE (STOCK_ITEM_NO,YEAR_OF_SALE)
								VALUES (:hWndForm.dfItemNo, :hWndForm.dfYr)' 
						   If SqlImmediate( sgSql )
							   Call SqlClearImmediate(  )
							   Return TRUE
						   Else 
							   Call SqlClearImmediate(  )
					   Else 
						   Return TRUE
			Function: RecalcInvFigures
				Description: To recalculate for a given stock item, and for any year from the current
						year on, to retally the on hand, on order, shipped etc
				Returns
				Parameters
				Static Variables
				Local variables
					Number: nInd
				Actions
					! Set bgGeneric = CheckIfGeneric( frmStock.tblStock.colItemNo )
					! Set bgGeneric = frmStock.tblStock.colGenItem
					! If MySelectRecord( frmStock.hSqlHdlSelSIS, frmStock.bHdlSelSISConnected,
							 frmStock.bHdlSelSISPrepared, 'Select YEAR_OF_SALE, AMT_GRADED,
							AMT_GROWING from STOCK_ITEM_SALE into :frmStock.tblStock.colRecalcYr, 
							:frmStock.tblStock.colGraded,:frmStock.tblStock.colGrowing Where
							 YEAR_OF_SALE >= :frmStock.dfYr AND STOCK_ITEM_NO = :frmStock.tblStock.colItemNo',
							 nFetchNone, nInd )
						   While SqlFetchNext( frmStock.hSqlHdlSelSIS, nInd )
							   Call SalSendMsgToChildren( frmStock.tblStock, PAM_INITIALIZE, 0, 0 )
							   Call MySelectRecord( frmStock.hSqlHdlOrdOnOrd, frmStock.bHdlOrdOnOrdConnected,
									 frmStock.bHdlOrdOnOrdPrepared, 'Select SUM(Ordered_amount) from
									Customer_order into :frmStock.tblStock.colOnOrdOrd where Stock_item_no = :frmStock.tblStock.colItemNo
									and year_of_sale = :frmStock.tblStock.colRecalcYr and conf_amt is NULL
									 and invoiced_flag = :frmStock.tblStock.colNotInvoiced', nFetchFirst, nInd )
							   Call MySelectRecord( frmStock.hSqlHdlConfOnOrd, frmStock.bHdlConfOnOrdConnected,
									 frmStock.bHdlConfOnOrdPrepared, 'Select SUM(Conf_amt) from
									Customer_order into :frmStock.tblStock.colOnOrdConf where Stock_item_no = :frmStock.tblStock.colItemNo
									and year_of_sale = :frmStock.tblStock.colRecalcYr and invoiced_flag = :frmStock.tblStock.colNotInvoiced',
									 nFetchFirst, nInd )
							   Call MySelectRecord( frmStock.hSqlHdlShItem, frmStock.bHdlShItemConnected,
									 frmStock.bHdlShItemPrepared, 'Select SUM(Conf_amt) from
									Customer_order into :frmStock.tblStock.colShItem where Stock_item_no = :frmStock.tblStock.colItemNo
									and year_of_sale = :frmStock.tblStock.colRecalcYr and invoiced_flag = :frmStock.tblStock.colInvoiced',
									 nFetchFirst, nInd )
							   Call MySelectRecord( frmStock.hSqlHdlShAsSub, frmStock.bHdlShAsSubConnected,
									 frmStock.bHdlShAsSubPrepared, 'Select SUM(Conf_amt) from
									Customer_order into :frmStock.tblStock.colShAsSub where Subs_item_no = :frmStock.tblStock.colItemNo
									and year_of_sale = :frmStock.tblStock.colRecalcYr and invoiced_flag = :frmStock.tblStock.colInvoiced',
									 nFetchFirst, nInd )
							   Call MySelectRecord( frmStock.hSqlHdlSubsOrd, frmStock.bHdlSubsOrdConnected,
									 frmStock.bHdlSubsOrdPrepared, 'Select SUM(Ordered_amount) from
									Customer_order into :frmStock.tblStock.colSubsOrd where Subs_item_no = :frmStock.tblStock.colItemNo
									and year_of_sale = :frmStock.tblStock.colRecalcYr and conf_amt is NULL  
									and invoiced_flag = :frmStock.tblStock.colNotInvoiced', nFetchFirst, nInd )
							   Call MySelectRecord( frmStock.hSqlHdlSubsConf, frmStock.bHdlSubsConfConnected,
									 frmStock.bHdlSubsConfPrepared, 'Select SUM(Conf_amt) from
									Customer_order into :frmStock.tblStock.colSubsConf where Subs_item_no = :frmStock.tblStock.colItemNo
									and year_of_sale = :frmStock.tblStock.colRecalcYr and invoiced_flag = :frmStock.tblStock.colNotInvoiced',
									nFetchFirst, nInd )
							   Set frmStock.tblStock.colRecalcOnOrd = frmStock.tblStock.colOnOrdOrd + frmStock.tblStock.colOnOrdConf
							! Set tblStock.colRecalcShipped = tblStock.colShItem + tblStock.colShAsSub
							   Set frmStock.tblStock.colRecalcSubsOnOrd = frmStock.tblStock.colSubsOrd + frmStock.tblStock.colSubsConf
							   If frmStock.tblStock.colGenItem = 'Y'
								   Set frmStock.tblStock.colRecalcTotAvail = 0
							   Else 
								   If frmStock.tblStock.colGraded > 0
									   Set frmStock.tblStock.colRecalcTotAvail = frmStock.tblStock.colGraded - frmStock.tblStock.colRecalcOnOrd
									   Set frmStock.tblStock.colRecalcTotAvail = frmStock.tblStock.colRecalcTotAvail - frmStock.tblStock.colRecalcSubsOnOrd
									! At this point in most routines we added a supplied value and deduct
											a pending digging value - these arent implemented at this stage so I wont 
											do in this section
								   Else 
									   Set frmStock.tblStock.colRecalcTotAvail = frmStock.tblStock.colGrowing - frmStock.tblStock.colRecalcOnOrd
									   Set frmStock.tblStock.colRecalcTotAvail = frmStock.tblStock.colRecalcTotAvail - frmStock.tblStock.colShItem
									   Set frmStock.tblStock.colRecalcTotAvail = frmStock.tblStock.colRecalcTotAvail - frmStock.tblStock.colShAsSub
									   Set frmStock.tblStock.colRecalcTotAvail = frmStock.tblStock.colRecalcTotAvail - frmStock.tblStock.colRecalcSubsOnOrd
									! At this point in most routines we added a supplied value and deduct
											a pending digging value - these arent implemented at this stage so I wont 
											do in this section
							   Call SalSendMsgToChildren( frmStock.tblStock, PAM_SIDATANOTNULL, 0, 0 )
							! Using the MySelectRecord to update the file by passing the update statement
									instead of a select
							   If MySelectRecord( frmStock.hSqlHdlUpdSIS, frmStock.bHdlUpdSISConnected,
									 frmStock.bHdlUpdSISPrepared, 'UPDATE STOCK_ITEM_SALE SET AMT_SHIPPED
									= :frmStock.tblStock.colShItem, AMT_SUBS_SHIPPED = :frmStock.tblStock.colShAsSub, AMT_ON_ORDER = :frmStock.tblStock.colRecalcOnOrd, 
									ON_ORD_AS_SUBS = :frmStock.tblStock.colRecalcSubsOnOrd, TOT_AVAIL = :frmStock.tblStock.colRecalcTotAvail 
									 WHERE Stock_item_no = :frmStock.tblStock.colItemNo and 
									year_of_sale = :frmStock.tblStock.colRecalcYr', nFetchNone, nInd )
								   Call SqlCommit( frmStock.hSqlHdlUpdSIS )
							   Else 
								   Call MySqlPrepExec( frmStock.hSqlHdlUpdSIS, 'ROLLBACK' )
					If MySelectRecord( frmStock.hSqlHdlSelSIS, frmStock.bHdlSelSISConnected,
							 frmStock.bHdlSelSISPrepared, 'Select YEAR_OF_SALE, AMT_GRADED,
							EST_AVAIL_COUNT from STOCK_ITEM_SALE into :frmStock.tblStock.colRecalcYr, 
							:frmStock.tblStock.colGraded,:frmStock.tblStock.colEstGrowing Where
							 YEAR_OF_SALE >= :frmStock.dfYr AND STOCK_ITEM_NO = :frmStock.tblStock.colItemNo',
							 nFetchNone, nInd )
						While SqlFetchNext( frmStock.hSqlHdlSelSIS, nInd )
							Call SalSendMsgToChildren( frmStock.tblStock, PAM_INITIALIZE, 0, 0 )
							Call MySelectRecord( frmStock.hSqlHdlOrdOnOrd, frmStock.bHdlOrdOnOrdConnected,
									 frmStock.bHdlOrdOnOrdPrepared, 'Select SUM(Ordered_amount) from
									Customer_order into :frmStock.tblStock.colOnOrdOrd where Stock_item_no = :frmStock.tblStock.colItemNo
									and year_of_sale = :frmStock.tblStock.colRecalcYr and conf_amt is NULL
									 and invoiced_flag = :frmStock.tblStock.colNotInvoiced', nFetchFirst, nInd )
							Call MySelectRecord( frmStock.hSqlHdlConfOnOrd, frmStock.bHdlConfOnOrdConnected,
									 frmStock.bHdlConfOnOrdPrepared, 'Select SUM(Conf_amt) from
									Customer_order into :frmStock.tblStock.colOnOrdConf where Stock_item_no = :frmStock.tblStock.colItemNo
									and year_of_sale = :frmStock.tblStock.colRecalcYr and invoiced_flag = :frmStock.tblStock.colNotInvoiced',
									 nFetchFirst, nInd )
							Call MySelectRecord( frmStock.hSqlHdlShItem, frmStock.bHdlShItemConnected,
									 frmStock.bHdlShItemPrepared, 'Select SUM(Conf_amt) from
									Customer_order into :frmStock.tblStock.colShItem where Stock_item_no = :frmStock.tblStock.colItemNo
									and year_of_sale = :frmStock.tblStock.colRecalcYr and invoiced_flag = :frmStock.tblStock.colInvoiced',
									 nFetchFirst, nInd )
							Call MySelectRecord( frmStock.hSqlHdlShAsSub, frmStock.bHdlShAsSubConnected,
									 frmStock.bHdlShAsSubPrepared, 'Select SUM(Conf_amt) from
									Customer_order into :frmStock.tblStock.colShAsSub where Subs_item_no = :frmStock.tblStock.colItemNo
									and year_of_sale = :frmStock.tblStock.colRecalcYr and invoiced_flag = :frmStock.tblStock.colInvoiced',
									 nFetchFirst, nInd )
							Call MySelectRecord( frmStock.hSqlHdlSubsOrd, frmStock.bHdlSubsOrdConnected,
									 frmStock.bHdlSubsOrdPrepared, 'Select SUM(Ordered_amount) from
									Customer_order into :frmStock.tblStock.colSubsOrd where Subs_item_no = :frmStock.tblStock.colItemNo
									and year_of_sale = :frmStock.tblStock.colRecalcYr and conf_amt is NULL  
									and invoiced_flag = :frmStock.tblStock.colNotInvoiced', nFetchFirst, nInd )
							Call MySelectRecord( frmStock.hSqlHdlSubsConf, frmStock.bHdlSubsConfConnected,
									 frmStock.bHdlSubsConfPrepared, 'Select SUM(Conf_amt) from
									Customer_order into :frmStock.tblStock.colSubsConf where Subs_item_no = :frmStock.tblStock.colItemNo
									and year_of_sale = :frmStock.tblStock.colRecalcYr and invoiced_flag = :frmStock.tblStock.colNotInvoiced',
									nFetchFirst, nInd )
							Set frmStock.tblStock.colRecalcOnOrd = frmStock.tblStock.colOnOrdOrd + frmStock.tblStock.colOnOrdConf
							! Set tblStock.colRecalcShipped = tblStock.colShItem + tblStock.colShAsSub
							Set frmStock.tblStock.colRecalcSubsOnOrd = frmStock.tblStock.colSubsOrd + frmStock.tblStock.colSubsConf
							If frmStock.tblStock.colGenItem = 'Y'
								Set frmStock.tblStock.colRecalcTotAvail = 0
							Else
								If frmStock.tblStock.colGraded > 0
									Set frmStock.tblStock.colRecalcTotAvail = frmStock.tblStock.colGraded - frmStock.tblStock.colRecalcOnOrd
									Set frmStock.tblStock.colRecalcTotAvail = frmStock.tblStock.colRecalcTotAvail - frmStock.tblStock.colRecalcSubsOnOrd
									! At this point in most routines we added a supplied value and deduct
											a pending digging value - these arent implemented at this stage so I wont 
											do in this section
								Else
									Set frmStock.tblStock.colRecalcTotAvail = frmStock.tblStock.colEstGrowing - frmStock.tblStock.colRecalcOnOrd
									Set frmStock.tblStock.colRecalcTotAvail = frmStock.tblStock.colRecalcTotAvail - frmStock.tblStock.colShItem
									Set frmStock.tblStock.colRecalcTotAvail = frmStock.tblStock.colRecalcTotAvail - frmStock.tblStock.colShAsSub
									Set frmStock.tblStock.colRecalcTotAvail = frmStock.tblStock.colRecalcTotAvail - frmStock.tblStock.colRecalcSubsOnOrd
									! At this point in most routines we added a supplied value and deduct
											a pending digging value - these arent implemented at this stage so I wont 
											do in this section
							Call SalSendMsgToChildren( frmStock.tblStock, PAM_SIDATANOTNULL, 0, 0 )
							! Using the MySelectRecord to update the file by passing the update statement
									instead of a select
							If MySelectRecord( frmStock.hSqlHdlUpdSIS, frmStock.bHdlUpdSISConnected,
									 frmStock.bHdlUpdSISPrepared, 'UPDATE STOCK_ITEM_SALE SET AMT_SHIPPED
									= :frmStock.tblStock.colShItem, AMT_SUBS_SHIPPED = :frmStock.tblStock.colShAsSub, AMT_ON_ORDER = :frmStock.tblStock.colRecalcOnOrd, 
									ON_ORD_AS_SUBS = :frmStock.tblStock.colRecalcSubsOnOrd, TOT_AVAIL = :frmStock.tblStock.colRecalcTotAvail 
									 WHERE Stock_item_no = :frmStock.tblStock.colItemNo and 
									year_of_sale = :frmStock.tblStock.colRecalcYr', nFetchNone, nInd )
								Call SqlCommit( frmStock.hSqlHdlUpdSIS )
							Else
								Call MySqlPrepExec( frmStock.hSqlHdlUpdSIS, 'ROLLBACK' )
			!
			! Function: GetRootDetails
				   Description: Where a root id is not null in a populate of a table, to get the root
						details which have been passed in a string
				   Returns 
					   Boolean: 
				   Parameters 
					   Receive Sql Handle: hSqlHandle
					   Receive Boolean: bHandleConnected
					   Receive Boolean: bHandlePrepared
					   String: sDataFields
					   String: sTblFields
					   String: sColRootId
				   Static Variables 
				   Local variables 
					   String: sSql
					   Number: nInd
				   Actions 
					   If NOT bHandleConnected
						   Set bHandleConnected = SqlConnect( hSqlHandle ) 
						   If bHandleConnected
							   Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							   Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						   Else 
							   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							   Return FALSE
					   If NOT bHandlePrepared
						   Set sSql = 'SELECT '||sDataFields||' FROM Rootstock
								 INTO '||sTblFields||'  WHERE Root_Id = :'||sColRootId
						   If SqlPrepare( hSqlHandle, sSql )
							   Set bHandlePrepared = TRUE
						   Else 
							   Set bHandlePrepared = FALSE
					   If SqlExecute( hSqlHandle )
						   Call SqlFetchNext( hSqlHandle, nInd )
						   If nInd = FETCH_Ok
							   Return TRUE
					   Else 
						   Set bHandlePrepared = FALSE
					   Return FALSE
			Function: DoesItemHaveSubstitute
				Description: Checks if an item has a substitute available for use when calculating
						assigned inventory - wont bother with subs if not needed
				Returns
					Boolean:
				Parameters
					Receive Sql Handle: hSqlHandle
					Receive Boolean: bHandleConnected
					Receive Boolean: bHandlePrepared
					String: scolItemNo
				Static Variables
				Local variables
					String: sSql
					Number: nInd
					Number: nSubsItemNo
				Actions
					Set nSubsItemNo = 0
					If NOT bHandleConnected
						Set bHandleConnected = SqlConnect( hSqlHandle ) 
						If bHandleConnected
							Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
							Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
					If NOT bHandlePrepared
						Set sSql = 'SELECT SUBSTITUTE_ITEM_NO FROM SUBSTITUTES
								 INTO :nSubsItemNo  WHERE STOCK_ITEM_NO = :'||scolItemNo
						If SqlPrepare( hSqlHandle, sSql )
							Set bHandlePrepared = TRUE
						Else
							Set bHandlePrepared = FALSE
					If SqlExecute( hSqlHandle )
						Call SqlFetchNext( hSqlHandle, nInd )
						If nInd = FETCH_Ok
							If nSubsItemNo = 0
								Return FALSE
							Else
								Return TRUE
					Else
						Set bHandlePrepared = FALSE
					Return FALSE
			!
			! Function: NewAddToSub
				   Description: 
				   Returns 
					   Boolean: 
				   Parameters 
					   Number: nSubItemNo
					   Number: nYear
					   Number: nOrdAmt
					   Number: nConfAmt
					   String: sAllocFlag
					   Number: nActionType
				   Static Variables 
					   Sql Handle: hSqlHandle
					   Boolean: bHandleConnected
					   Boolean: bHandlePrepared
					!
					   Sql Handle: hSqlUpdateHandle
					   Boolean: bUpdateHandleConnected
					   Boolean: bUpdateHandlePrepared
				   Local variables 
					   String: sSql
					   Boolean: bOk
					   Number: nInd
					   Number: nCount
					!
					   Number: nOnOrdSub
					   Number: nSubTotAvail
				   Actions 
					   Select Case nActionType
						   Case nExecute
							   If NOT bHandleConnected
								   Set bHandleConnected = SqlConnect( hSqlHandle ) 
								   If bHandleConnected
									   Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
									   Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
								   Else 
									   Call SalMessageBeep( 0 )
									   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									   Return FALSE
							   If NOT bHandlePrepared
								   Set sSql = " SELECT On_Ord_As_Subs, Tot_Avail FROM Stock_Item_Sale 
										  INTO :nOnOrdSub, :nSubTotAvail 
										  WHERE Stock_Item_No = :nSubItemNo AND 
										    Year_Of_Sale = :nYear "
								   If SqlPrepare( hSqlHandle, sSql )
									   Set bHandlePrepared = TRUE
								   Else 
									   Set bHandlePrepared = FALSE
							!
							   If NOT bUpdateHandleConnected
								   Set bUpdateHandleConnected = SqlConnect( hSqlUpdateHandle ) 
								   If bUpdateHandleConnected
									   Call SqlSetLockTimeout( hSqlUpdateHandle, SQLTIMEOUT )
									   Call SqlSetParameter( hSqlUpdateHandle, DBP_PRESERVE, TRUE, ''  )
								   Else 
									   Call SalMessageBeep( 0 )
									   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									   Return FALSE
							   If NOT bUpdateHandlePrepared
								   Set sSql = " UPDATE Stock_Item_Sale SET On_Ord_As_Subs = :nOnOrdSub, 
										  Tot_Avail = :nSubTotAvail 
										  WHERE Stock_Item_No = :nSubItemNos[nCount] AND Year_Of_Sale = :nYear "
								   If SqlPrepare( hSqlUpdateHandle, sSql )
									   Set bUpdateHandlePrepared = TRUE
								   Else 
									   Set bUpdateHandlePrepared = FALSE
							!
							   If SqlExecute( hSqlHandle )
								   If SqlFetchNext( hSqlHandle, nInd )
									   If sAllocFlag = 'N'
										   Set nOnOrdSub = nOnOrdSub + nOrdAmt
										   Set nSubTotAvail = nSubTotAvail - nOrdAmt
									   Else 
										   Set nOnOrdSub = nOnOrdSub + nConfAmt
										   Set nSubTotAvail = nSubTotAvail - nConfAmt
									!
									   If nSubTotAvail >= 0
										   If SqlExecute( hSqlUpdateHandle )
											   Return TRUE
										   Else 
											   Set bUpdateHandlePrepared = FALSE
											   Call SalMessageBeep( 0 )
											   Call SalMessageBox( 'SqlExecute hSqlUpdateHandle had a error in function NewAddToSub! Please contact programmers!', 'Error', MB_Ok )
											   Return FALSE
									   Else 
										   Call SalMessageBeep( 0 )
										   Call SalMessageBox( 'New Substitute available level falls bellow ZERO.  Substitute not Changed!', 'Error', MB_Ok )
										   Return FALSE
								   Else 
									   Return FALSE
							   Else 
								   Set bHandlePrepared = FALSE
								   Call SalMessageBeep( 0 )
								   Call SalMessageBox( 'SqlExecute hSqlHandle had a error in function NewAddToSub! Please contact programmers!', 'Error', MB_Ok )
								   Return FALSE
						   Case nCommit
							   Set bOk = TRUE
							   If bUpdateHandleConnected
								   If NOT SqlCommit( hSqlUpdateHandle )
									   Set bOk = FALSE
							   Return bOk
						   Case nRollback
							   Set bOk = TRUE
							   If bUpdateHandleConnected
								   If NOT SqlPrepareAndExecute( hSqlUpdateHandle, 'ROLLBACK' )
									   Set bOk = FALSE
								   Set bUpdateHandlePrepared = FALSE
							   Return bOk
						   Case nDisconnect
							   Set bOk = TRUE
							   Set bHandlePrepared = FALSE
							   If bHandleConnected
								   Set bHandleConnected = FALSE
								   If NOT SqlDisconnect( hSqlHandle )
									   Set bOk = FALSE
							   Set bUpdateHandlePrepared = FALSE
							   If bUpdateHandleConnected
								   Set bUpdateHandleConnected = FALSE
								   If NOT SqlDisconnect( hSqlUpdateHandle )
									   Set bOk = FALSE
							   Return bOk
						   Case nRePrepare
							   Set bHandlePrepared = FALSE
							   Set bUpdateHandlePrepared = FALSE
							   Return TRUE
			! Function: NewChangeOrderSubstitute
				   Description: Change order line substitute item no
				   Returns 
					   Boolean: 
				   Parameters 
					   Number: nCustNo
					   Date/Time: dtOrderSysDT
					   Number: nNewSubsItemNo
					   Number: nActionType
				   Static Variables 
					   Sql Handle: hSqlUpdateHandle
					   Boolean: bUpdateHandleConnected
					   Boolean: bUpdateHandlePrepared
				   Local variables 
					   String: sSql
					   Boolean: bOk
					!
					   Number: nItemNo
					   Number: nYear
					   Number: nOrdAmt
					   Number: nConfAmt
					   String: sAllocFlag
					!
					   Number: nOldSubsItemNo
				   Actions 
					   Select Case nActionType
						   Case nExecute
							   If NOT bUpdateHandleConnected
								   Set bUpdateHandleConnected = SqlConnect( hSqlUpdateHandle ) 
								   If bUpdateHandleConnected
									   Call SqlSetLockTimeout( hSqlUpdateHandle, SQLTIMEOUT )
									   Call SqlSetParameter( hSqlUpdateHandle, DBP_PRESERVE, TRUE, ''  )
								   Else 
									   Call SalMessageBeep( 0 )
									   Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									   Return FALSE
							   If NOT bUpdateHandlePrepared
								   Set sSql = " UPDATE Customer_Order SET Subs_Item_No = :nNewSubsItemNo 
										  WHERE Cust_No = :nCustNo AND Order_Date_Time = :dtOrderSysDT "
								   If SqlPrepare( hSqlUpdateHandle, sSql )
									   Set bUpdateHandlePrepared = TRUE
								   Else 
									   Set bUpdateHandlePrepared = FALSE
							!
							   If GetOrderBasicDetails( nCustNo, dtOrderSysDT, nItemNo, nOldSubsItemNo, nYear, nOrdAmt, nConfAmt, sAllocFlag, nExecute )
								   If NewDeleteFromSub( nOldSubsItemNo, nYear, nOrdAmt, nConfAmt, sAllocFlag, nExecute )
									   If NewAddToSub( nNewSubsItemNo, nYear, nOrdAmt, nConfAmt, sAllocFlag, nExecute )
										   If SqlExecute( hSqlUpdateHandle )
											   Call NewChangeOrderSubstitute( 0, DATETIME_Null, 0, nCommit )
											   Return TRUE
										   Else 
											   Set bUpdateHandlePrepared = FALSE
											   Call NewChangeOrderSubstitute( 0, DATETIME_Null, 0, nRollback )
											   Call SalMessageBeep( 0 )
											   Call SalMessageBox( 'SqlExecute hSqlUpdateHandle had a error in function NewChangeOrderSubstitute! Please contact programmers!', 'Error', MB_Ok )
											   Return FALSE
									   Else 
										   Call NewChangeOrderSubstitute( 0, DATETIME_Null, 0, nRollback )
										   Return FALSE
								   Else 
									   Call NewChangeOrderSubstitute( 0, DATETIME_Null, 0, nRollback )
									   Return FALSE
							   Else 
								   Call NewChangeOrderSubstitute( 0, DATETIME_Null, 0, nRollback )
								   Return FALSE
						   Case nCommit
							   Set bOk = TRUE
							   If bUpdateHandleConnected
								   If NOT SqlCommit( hSqlUpdateHandle )
									   Set bOk = FALSE
							!
							   If NOT NewDeleteFromSub( 0, 0, 0, 0, '', nCommit )
								   Set bOk = FALSE
							   If NOT NewAddToSub( 0, 0, 0, 0, '', nCommit )
								   Set bOk = FALSE
							   Return bOk
						   Case nRollback
							   Set bOk = TRUE
							   If bUpdateHandleConnected
								   If NOT SqlPrepareAndExecute( hSqlUpdateHandle, 'ROLLBACK' )
									   Set bOk = FALSE
								   Set bUpdateHandlePrepared = FALSE
							   If NOT NewDeleteFromSub( 0, 0, 0, 0, '', nRollback )
								   Set bOk = FALSE
							   If NOT NewAddToSub( 0, 0, 0, 0, '', nRollback )
								   Set bOk = FALSE
							   Return bOk
						   Case nDisconnect
							   Set bOk = TRUE
							   Set bUpdateHandlePrepared = FALSE
							   If bUpdateHandleConnected
								   Set bUpdateHandleConnected = FALSE
								   If NOT SqlDisconnect( hSqlUpdateHandle )
									   Set bOk = FALSE
							   If NOT NewDeleteFromSub( 0, 0, 0, 0, '', nDisconnect )
								   Set bOk = FALSE
							   If NOT NewAddToSub( 0, 0, 0, 0, '', nDisconnect )
								   Set bOk = FALSE
							   Return bOk
						   Case nRePrepare
							   Set bUpdateHandlePrepared = FALSE
							   Call NewDeleteFromSub( 0, 0, 0, 0, '', nRePrepare )
							   Call NewAddToSub( 0, 0, 0, 0, '', nRePrepare )
							   Return TRUE
			!

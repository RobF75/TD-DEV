					On SAM_Click
						Call SalWaitCursor( TRUE )
						Set frmStock.tblStock.bCalcAvail = TRUE
						Set nRow = TBL_MinRow
						If SalTblAnyRows( tblStock, ROW_Selected, 0 )
							While SalTblFindNextRow( tblStock, nRow, ROW_Selected, 0 )
								Call SalTblFetchRow( tblStock, nRow )
								Set frmStock.tblStock.colOnHand = FetchInvRecord( frmStock.hSqlHdlInv, frmStock.bHdlInvConnected, frmStock.bHdlInvPrepared, frmStock.tblStock.colItemNo, frmStock.dfYr )
								! Call CalculateSubs( hWndForm, frmStock.tblStock.colItemNo, frmStock.dfYr, frmStock.tblStock.colSubs )
								Call CalculateSubs( frmStock.tblStock.hSqlCalcSubHdl,
										 frmStock.tblStock.bCalcSubHdlConnected,frmStock.tblStock.bCalcSubHdlPrepared,
										hWndForm, frmStock.tblStock.colItemNo, frmStock.dfYr, frmStock.tblStock.colSubs )
								Call SalSendMsgToChildren( frmStock.tblStock, PAM_LOOKUPSUB, 0, 0 )
						Call SalWaitCursor( FALSE )
					On PAM_ENABLE
						Call SalEnableWindow( hWndItem )
						Call SalWaitCursor( FALSE )

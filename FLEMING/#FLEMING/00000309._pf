								Ignore Case? Yes
						List Values
						Message Actions
							On PAM_ADDSTCKITMSALE
								Call SalSetFieldEdit( hWndItem, TRUE )
								Call BuildSQL(  wParam, hWndItem, 'YEAR_OF_SALE' )
							On PAM_SETSISVALUES
								Set colSISYearOfSale = frmStock.dfYr
							On PAM_DATAVAL
								Return TRUE

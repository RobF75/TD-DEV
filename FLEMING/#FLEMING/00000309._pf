.end
				   Message Actions 
					   On PAM_QBE
						   If NOT SalIsNull( hWndItem )
							   Set sQueryTmpStr = dfCultNPA||'%'
							   Call PushString( sQueryTmpStr )
							   Call PushString( LIKEOPERAND )
							   Call PushString( STRINGFOLLOWING )
							   Call PushString( 'CULTIVAR.CV_NON_PROP_FLAG' )
							   Return TRUE
					   On SAM_Validate
						   If dfCultNPA = 'Y' OR dfCultNPA = 'N'
							   Return VALIDATE_Ok
						   Else 
							   Return VALIDATE_Cancel

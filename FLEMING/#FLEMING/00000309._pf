		Functions
			Function: GetSISFigures
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Number: nYear
					Receive Number: nTotAvail
					Receive Number: nGraded
					Receive Number: nGrowing
					Receive Number: nEstAvailCount
					Receive Number: nShipped
					Receive Number: nSubsShipped
					Receive Number: nOnOrder
					Receive Number: nOnOrdAsSubs
					Number: nExecuteOrDisconnect
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					String: sSql
					Number: nInd
					!
					Number: nGotTotAvail
					Number: nGotGraded
					Number: nGotGrowing
					Number: nGotEstAvailCount
					Number: nGotShipped
					Number: nGotSubsShipped
					Number: nGotOnOrder
					Number: nGotOnOrdAsSubs
				Actions
					If nExecuteOrDisconnect != nDisconnect
						If NOT bHandleConnected
							Set bHandleConnected = SqlConnect( hSqlHandle ) 
							If bHandleConnected
								Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
								Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
							Else
								Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
								Return FALSE
						If NOT bHandlePrepared
							Set sSql = ' SELECT Tot_Avail, Amt_Graded, Amt_Growing, Est_Avail_Count, 
									  Amt_Shipped, Amt_Subs_Shipped, Amt_On_Order, On_Ord_As_Subs 
									  FROM Stock_Item_Sale
									  INTO :nGotTotAvail, :nGotGraded, :nGotGrowing, :nGotEstAvailCount, 
									           :nGotShipped, :nGotSubsShipped, :nGotOnOrder, :nGotOnOrdAsSubs 
									  WHERE Stock_Item_No = :nItemNo AND 
									    Year_Of_Sale = :nYear '
							If SqlPrepare( hSqlHandle, sSql )
								Set bHandlePrepared = TRUE
							Else
								Set bHandlePrepared = FALSE
						!
						Set nGotTotAvail = NUMBER_Null
						Set nGotGraded = NUMBER_Null
						Set nGotGrowing = NUMBER_Null
						Set nGotEstAvailCount = NUMBER_Null
						Set nGotShipped = NUMBER_Null
						Set nGotSubsShipped = NUMBER_Null
						Set nGotOnOrder = NUMBER_Null
						Set nGotOnOrdAsSubs = NUMBER_Null
						!
						Set nTotAvail = NUMBER_Null
						Set nGraded = NUMBER_Null
						Set nGrowing = NUMBER_Null
						Set nEstAvailCount = NUMBER_Null
						Set nShipped = NUMBER_Null
						Set nSubsShipped = NUMBER_Null
						Set nOnOrder = NUMBER_Null
						Set nOnOrdAsSubs = NUMBER_Null
						!
						If SqlExecute( hSqlHandle )
							If SqlFetchNext( hSqlHandle, nInd )
								Set nTotAvail = nGotTotAvail
								Set nGraded = nGotGraded
								Set nGrowing = nGotGrowing
								Set nEstAvailCount = nGotEstAvailCount
								Set nShipped = nGotShipped
								Set nSubsShipped = nGotSubsShipped
								Set nOnOrder = nGotOnOrder
								Set nOnOrdAsSubs = nGotOnOrdAsSubs
								Return TRUE
							Else
								Return FALSE
						Else
							Set bHandlePrepared = FALSE
							Call SalMessageBox( 'SqlExecute had a error in function GetSISFigures! Please contact programmers!', 'Error', MB_Ok )
							Return FALSE
					Else
						Set bHandlePrepared = FALSE
						If bHandleConnected
							Set bHandleConnected = FALSE
							Call SqlDisconnect( hSqlHandle )
						Return TRUE
			!
			Function: ItemUsed
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Number: nYear
					String: sTreeType
					String: sCultId
					String: sRootId
					Number: nExecuteOrDisconnect
				Static Variables
				Local variables
					Number: nRD1ItemNo
					Number: nMR1ItemNo
				Actions
					If nExecuteOrDisconnect != nDisconnect
						If ItemActive( nItemNo, nYear, nExecute )
							Return TRUE
						Else
							If sTreeType = 'MR1'
								If GetItemNoFromBasicDetails( 'RD1', sCultId, sRootId, nRD1ItemNo, nExecute )
									If ItemActive( nRD1ItemNo, nYear, nExecute )
										Return TRUE
									Else
										Return FALSE
								Else
									Return FALSE
							Else If sTreeType = 'RD1'
								If GetItemNoFromBasicDetails( 'MR1', sCultId, sRootId, nMR1ItemNo, nExecute )
									If ItemActive( nMR1ItemNo, nYear, nExecute )
										Return TRUE
									Else
										Return FALSE
								Else
									Return FALSE
							Else
								Return FALSE
					Else
						Call ItemActive( 0, 0, nDisconnect )
						Call GetItemNoFromBasicDetails( '', '', '', nMR1ItemNo, nDisconnect )
						Return TRUE
			Function: ItemActive
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Number: nYear
					Number: nExecuteOrDisconnect
				Static Variables
					Sql Handle: hSqlHandle
					Boolean: bHandleConnected
					Boolean: bHandlePrepared
				Local variables
					String: sSql
					Number: nInd
				Actions
					If nExecuteOrDisconnect != nDisconnect
						If NOT bHandleConnected
							Set bHandleConnected = SqlConnect( hSqlHandle ) 
							If bHandleConnected
								Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
								Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
							Else
								Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
								Return FALSE
						If NOT bHandlePrepared
							Set sSql = ' SELECT Stock_Item_No
									  FROM Stock_Item_Sale
									  WHERE Stock_Item_No = :nItemNo AND 
									     Year_Of_Sale = :nYear AND NOT (Amt_Growing = 0 AND 
									     Amt_Graded = 0 AND Amt_Shipped = 0 AND Amt_Subs_Shipped = 0 AND 
									     Amt_On_Order = 0 AND On_Ord_As_Subs = 0 ) '
							If SqlPrepare( hSqlHandle, sSql )
								Set bHandlePrepared = TRUE
							Else
								Set bHandlePrepared = FALSE
						!
						If SqlExecute( hSqlHandle )
							If SqlFetchNext( hSqlHandle, nInd )
								Return TRUE
							Else
								Return FALSE
						Else
							Set bHandlePrepared = FALSE
							Call SalMessageBox( 'SqlExecute had a error in function ItemActive! Please contact programmers!', 'Error', MB_Ok )
							Return FALSE
					Else
						Set bHandlePrepared = FALSE
						If bHandleConnected
							Set bHandleConnected = FALSE
							Call SqlDisconnect( hSqlHandle )
						Return TRUE
			Function: DenormaliseData
				Description: Run through the stock items table to update the stock item table with
						the associated values from cultivar to denormalise to speed up query
						times
				Returns
					Boolean:
				Parameters
					Window Handle: hWndTable
					Number: nActionType
				Static Variables
					Sql Handle: hSqlSIHandle
					Boolean: bSIHandleConnected
					Boolean: bSIHandlePrepared
					Sql Handle: hSqlCultHandle
					Boolean: bCultHandleConnected
					Boolean: bCultHandlePrepared
					Sql Handle: hSqlRootHandle
					Boolean: bRootHandleConnected
					Boolean: bRootHandlePrepared
					Sql Handle: hSqlUpdSIHandle
					Boolean: bUpdSIHandleConnected
					Boolean: bUpdSIHandlePrepared
				Local variables
					Boolean: bOk
					String: sSql
					Number: nInd
					Number: nCount
					String: sCultId
					String: sRootId
					!
					Window Handle: hWndMeter
					Number: nItemNo
					Number: nNumItemNos
					String: sVar
					Number: nCultInd
					Number: nRootInd
					String: sVarType
					String: sCultDesc
					String: sRootDesc
					String: sRtNPA
					String: sRtNotSale
					String: sCvNPA
					String: sCvNotSale
					String: sLastCultId
					String: sLastRootId
				Actions
					Select Case nActionType
						Case nExecute
							If NOT bCultHandleConnected
								Set bCultHandleConnected = SqlConnect( hSqlCultHandle ) 
								If bCultHandleConnected
									Call SqlSetLockTimeout( hSqlCultHandle, SQLTIMEOUT )
									Call SqlSetParameter( hSqlCultHandle, DBP_PRESERVE, TRUE, ''  )
								Else
									Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									Return FALSE
							If NOT bCultHandlePrepared
								Set sSql = ' SELECT VARIETY, CULT_DESC, VARIETY_TYPE, CV_NON_PROP_FLAG,
										 CV_NOT_SALE_FLAG  
										  INTO :sVar, :sCultDesc, :sVarType, :sCvNPA, :sCvNotSale  
										  FROM CULTIVAR
										  WHERE CULT_ID = :sCultId '
								If SqlPrepare( hSqlCultHandle, sSql )
									Set bCultHandlePrepared = TRUE
								Else
									Set bCultHandlePrepared = FALSE
							!
							If NOT bRootHandleConnected
								Set bRootHandleConnected = SqlConnect( hSqlRootHandle ) 
								If bRootHandleConnected
									Call SqlSetLockTimeout( hSqlRootHandle, SQLTIMEOUT )
									Call SqlSetParameter( hSqlRootHandle, DBP_PRESERVE, TRUE, ''  )
								Else
									Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									Return FALSE
							If NOT bRootHandlePrepared
								Set sSql = ' SELECT ROOT_DESC, RT_NON_PROP_FLAG, RT_NOT_SALE_FLAG  
										  INTO :sRootDesc, :sRtNPA, :sRtNotSale  
										  FROM ROOTSTOCK
										  WHERE ROOT_ID = :sRootId '
								If SqlPrepare( hSqlRootHandle, sSql )
									Set bRootHandlePrepared = TRUE
								Else
									Set bRootHandlePrepared = FALSE
							!
							If NOT bUpdSIHandleConnected
								Set bUpdSIHandleConnected = SqlConnect( hSqlUpdSIHandle ) 
								If bUpdSIHandleConnected
									Call SqlSetLockTimeout( hSqlUpdSIHandle, SQLTIMEOUT )
									Call SqlSetParameter( hSqlUpdSIHandle, DBP_PRESERVE, TRUE, ''  )
								Else
									Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
									Return FALSE
							If NOT bUpdSIHandlePrepared
								Set sSql = ' UPDATE STOCK_ITEM SET CULT_DESC = :sCultDesc,
										 VARIETY_TYPE = :sVarType, VARIETY = :sVar, ROOT_DESC = :sRootDesc,
										 CV_NON_PROP_FLAG = :sCvNPA, CV_NOT_SALE_FLAG = :sCvNotSale,
										 RT_NON_PROP_FLAG = :sRtNPA, RT_NOT_SALE_FLAG = :sRtNotSale     
										  WHERE ITEM_NO = :nItemNo '
								If SqlPrepare( hSqlUpdSIHandle, sSql )
									Set bUpdSIHandlePrepared = TRUE
								Else
									Set bUpdSIHandlePrepared = FALSE
							!
							If MyTableAnyRows( hWndTable, ROW_Selected, 0, nNumItemNos )
								Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Denormalising Data', nNumItemNos )
								Set nCount = 0
								Set nRow = TBL_MinRow
								While SalTblFindNextRow( hWndTable, nRow, ROW_Selected, 0 )
									Call SalTblFetchRow( hWndTable, nRow )
									!
									Set nItemNo = hWndTable.colItemNo
									Set sCultId = hWndTable.colCultId
									Set sRootId = hWndTable.colRootId
									!
									If sCultId != sLastCultId 
										If SqlExecute( hSqlCultHandle )
											If SqlFetchNext( hSqlCultHandle, nCultInd )
												If nCultInd != FETCH_Ok
													Set bCultHandlePrepared = FALSE
													Call SalMessageBox( 'SqlFetchNext failed (hSqlCultHandle) in function Denormalising Data! Please contact programmers!', 'Error', MB_Ok )
													Return FALSE
												Else
													Set sLastCultId = sCultId
											Else
												Set bCultHandlePrepared = FALSE
												Call SalMessageBox( 'SqlFetchNext failed to fetch anything (hSqlCultHandle) in function Denormalising Data! Please contact programmers!', 'Error', MB_Ok )
												Return FALSE
										Else
											Set bCultHandlePrepared = FALSE
											Call SalMessageBox( 'SqlExecute failed (hSqlCultHandle) in function Denormalising Data! Please contact programmers!', 'Error', MB_Ok )
											Return FALSE
									If sRootId > ''
										If sRootId != sLastRootId 
											If SqlExecute( hSqlRootHandle )
												If SqlFetchNext( hSqlRootHandle, nRootInd )
													If nRootInd != FETCH_Ok
														Set bRootHandlePrepared = FALSE
														Call SalMessageBox( 'SqlFetchNext failed (hSqlRootHandle) in function Denormalising Data! Please contact programmers!', 'Error', MB_Ok )
														Return FALSE
													Else
														Set sLastRootId = sRootId
												Else
													Set bRootHandlePrepared = FALSE
													Call SalMessageBox( 'SqlFetchNext failed to fetch anything (hSqlRootHandle) in function Denormalising Data! Please contact programmers!', 'Error', MB_Ok )
													Return FALSE
											Else
												Set bRootHandlePrepared = FALSE
												Call SalMessageBox( 'SqlExecute failed (hSqlRootHandle) in function Denormalising Data! Please contact programmers!', 'Error', MB_Ok )
												Return FALSE
									Else
										Set sLastRootId = ''
										Set sRootDesc = ''
										Set sRtNPA = ''
										Set sRtNotSale = ''
									If NOT SqlExecute( hSqlUpdSIHandle )
										Set bUpdSIHandlePrepared = FALSE
										Call SalMessageBox( 'SqlExecute failed (hSqlUpdSIHandle) in function RecalEstAvail! Please contact programmers!', 'Error', MB_Ok )
										Call SqlPrepareAndExecute( hSqlUpdSIHandle, 'rollback' )
										Return FALSE
									Else
										If NOT SqlCommit( hSqlUpdSIHandle )
											Call SalMessageBox( 'SqlCommit failed (hSqlUpdSIHandle) in function RecalEstAvail! Please contact programmers!', 'Error', MB_Ok )
									Set nCount = nCount + 1
									Call SalSendMsg( hWndMeter, PAM_SETPROGRESS, 0, nCount )
								Call SalSendMsg( hWndMeter, PAM_END, 0, 0 )
								Return bOk
							Else
								If NOT bSIHandleConnected
									Set bSIHandleConnected = SqlConnect( hSqlSIHandle ) 
									If bSIHandleConnected
										Call SqlSetLockTimeout( hSqlSIHandle, SQLTIMEOUT )
										Call SqlSetParameter( hSqlSIHandle, DBP_PRESERVE, TRUE, ''  )
									Else
										Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
										Return FALSE
								If NOT bSIHandlePrepared
									Set sSql = ' SELECT Item_No, Cultivar_Id, Rootstock_Id  
											  INTO :nItemNo, :sCultId, :sRootId
											  FROM Stock_Item
											  ORDER BY CULTIVAR_ID '
									If SqlPrepare( hSqlSIHandle, sSql )
										Set bSIHandlePrepared = TRUE
									Else
										Set bSIHandlePrepared = FALSE
								!
								Set bOk = TRUE
								If SqlExecute( hSqlSIHandle )
									Call SqlGetResultSetCount( hSqlSIHandle, nNumItemNos )
									Set hWndMeter = SalCreateWindow( dlgMeterProgress, hWndForm, 'Denormalising Data', nNumItemNos )
									Set nCount = 0
									While SqlFetchNext( hSqlSIHandle, nInd )
										If sCultId != sLastCultId 
											If SqlExecute( hSqlCultHandle )
												If SqlFetchNext( hSqlCultHandle, nCultInd )
													If nCultInd != FETCH_Ok
														Set bCultHandlePrepared = FALSE
														Call SalMessageBox( 'SqlFetchNext failed (hSqlCultHandle) in function Denormalising Data! Please contact programmers!', 'Error', MB_Ok )
														Return FALSE
													Else
														Set sLastCultId = sCultId
												Else
													Set bCultHandlePrepared = FALSE
													Call SalMessageBox( 'SqlFetchNext failed to fetch anything (hSqlCultHandle) in function Denormalising Data! Please contact programmers!', 'Error', MB_Ok )
													Return FALSE
											Else
												Set bCultHandlePrepared = FALSE
												Call SalMessageBox( 'SqlExecute failed (hSqlCultHandle) in function Denormalising Data! Please contact programmers!', 'Error', MB_Ok )
												Return FALSE
										If sRootId > ''
											If sRootId != sLastRootId 
												If SqlExecute( hSqlRootHandle )
													If SqlFetchNext( hSqlRootHandle, nRootInd )
														If nRootInd != FETCH_Ok
															Set bRootHandlePrepared = FALSE
															Call SalMessageBox( 'SqlFetchNext failed (hSqlRootHandle) in function Denormalising Data! Please contact programmers!', 'Error', MB_Ok )
															Return FALSE
														Else
															Set sLastRootId = sRootId
													Else
														Set bRootHandlePrepared = FALSE
														Call SalMessageBox( 'SqlFetchNext failed to fetch anything (hSqlRootHandle) in function Denormalising Data! Please contact programmers!', 'Error', MB_Ok )
														Return FALSE
												Else
													Set bRootHandlePrepared = FALSE
													Call SalMessageBox( 'SqlExecute failed (hSqlRootHandle) in function Denormalising Data! Please contact programmers!', 'Error', MB_Ok )
													Return FALSE
										Else
											Set sLastRootId = ''
											Set sRootDesc = ''
											Set sRtNPA = ''
											Set sRtNotSale = ''
										If NOT SqlExecute( hSqlUpdSIHandle )
											Set bUpdSIHandlePrepared = FALSE
											Call SalMessageBox( 'SqlExecute failed (hSqlUpdSIHandle) in function RecalEstAvail! Please contact programmers!', 'Error', MB_Ok )
											Call SqlPrepareAndExecute( hSqlUpdSIHandle, 'rollback' )
											Return FALSE
										Else
											If NOT SqlCommit( hSqlUpdSIHandle )
												Call SalMessageBox( 'SqlCommit failed (hSqlUpdSIHandle) in function RecalEstAvail! Please contact programmers!', 'Error', MB_Ok )
										Set nCount = nCount + 1
										Call SalSendMsg( hWndMeter, PAM_SETPROGRESS, 0, nCount )
									Call SalSendMsg( hWndMeter, PAM_END, 0, 0 )
									Return bOk
								Else
									Set bSIHandlePrepared = FALSE
									Call SalMessageBox( 'SqlExecute failed (hSqlSIHandle) in function RecalEstAvail! Please contact programmers!', 'Error', MB_Ok )
									Return FALSE
						Case nRePrepare
							Set bSIHandlePrepared = FALSE
							Set bCultHandlePrepared = FALSE
							Set bRootHandlePrepared = FALSE
							Set bUpdSIHandlePrepared = FALSE
							Return TRUE
						Case nDisconnect
							Set bOk = TRUE
							Set bSIHandlePrepared = FALSE
							If bSIHandleConnected
								Set bSIHandleConnected = FALSE
								If NOT SqlDisconnect( hSqlSIHandle )
									Set bOk = FALSE
							Set bCultHandlePrepared = FALSE
							If bCultHandleConnected
								Set bCultHandleConnected = FALSE
								If NOT SqlDisconnect( hSqlCultHandle )
									Set bOk = FALSE
							Set bRootHandlePrepared = FALSE
							If bRootHandleConnected
								Set bRootHandleConnected = FALSE
								If NOT SqlDisconnect( hSqlRootHandle )
									Set bOk = FALSE
							Set bUpdSIHandlePrepared = FALSE
							If bUpdSIHandleConnected
								Set bUpdSIHandleConnected = FALSE
								If NOT SqlDisconnect( hSqlUpdSIHandle )
									Set bOk = FALSE
							Return bOk
			!
			! Function: GetItemTotalBudCount
				   Description: 
				   Returns 
					   Boolean: 
				   Parameters 
					   Number: nItemNo
					   Number: nYear
					   Receive Number: nBudCount
					   Number: nActionType
				   Static Variables 
					   : fcOurHandle
				   Local variables 
					   String: sSql
					   String: sBind
					   String: sInto
					   String: sName
					   Number: nInd
					!
					   Number: nGotBudCount
				   Actions 
					   Select Case nActionType
						   Case nExecute
							   Set sSql = " SELECT 
									  SUM( Beg_Count )
									FROM 
									  Growing_Sale
									WHERE 
									   Stock_Item_No = :1 AND  
									   Year_Of_Sale = :2 "
							   Set sName = 'GETITMBUDCNT'
							   Set sBind = ':nItemNo, :nYear'
							   Set sInto = ':nGotBudCount'
							   Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							   Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							   Set nBudCount = NUMBER_Null
							   Set nGotBudCount = NUMBER_Null
							!
							   If fcOurHandle.Execute( )
								   If fcOurHandle.FetchNext( nInd )
									   Set nBudCount = nGotBudCount
								   Return TRUE
							   Else 
								   Return FALSE
						   Case nDisconnect
							   Return fcOurHandle.Disconnect( )
			Function: GetItemTotalBFSCounts
				Description:
				Returns
					Boolean:
				Parameters
					Number: nItemNo
					Number: nYear
					Receive Number: nBudTotal
					Receive Number: nFirstTotal
					Receive Number: nSecondTotal
					Number: nActionType
				Static Variables
					: fcOurHandle
						Class: hcSqlHandle
				Local variables
					String: sSql
					String: sBind
					String: sInto
					String: sName
					Number: nInd
					!
					Number: nGotBudTotal
					Number: nGotFirstTotal
					Number: nGotSecondTotal
				Actions
					Select Case nActionType
						Case nExecute
							Set sSql = " SELECT 
									  SUM( Beg_Count ), 
									  SUM( First_Count ), 
									  SUM( Second_Count ) 
									FROM 
									  Growing_Sale
									WHERE 
									  Stock_Item_No = :1 AND  
									  Year_Of_Sale = :2 "
							Set sName = 'GTITMBFSCNTT'
							Set sBind = ':nItemNo, :nYear'
							Set sInto = ':nGotBudTotal, :nGotFirstTotal, :nGotSecondTotal'
							Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
							Call SqlVarSetup( fcOurHandle.hSqlHandle )
							!
							Set nBudTotal = NUMBER_Null
							Set nGotBudTotal = NUMBER_Null
							Set nFirstTotal = NUMBER_Null
							Set nGotFirstTotal = NUMBER_Null
							Set nSecondTotal = NUMBER_Null
							Set nGotSecondTotal = NUMBER_Null
							!
							If fcOurHandle.Execute( )
								If fcOurHandle.FetchNext( nInd )
									Set nBudTotal = nGotBudTotal
									Set nFirstTotal = nGotFirstTotal
									Set nSecondTotal = nGotSecondTotal
								Return TRUE
							Else
								Return FALSE
						Case nDisconnect
							Return fcOurHandle.Disconnect( )
		Window Parameters
		Window Variables
			Window Handle: hWndPushbutton
			Window Handle: hWndCalled
			Window Handle: hWndCol
			Number: nTmp
			String: sTmp
			Boolean: bTblStockIsActive
			Boolean: bRolloverGraded
			Boolean: bSelectedRows
			Boolean: bFirst
			String: sCommaListOfItemNos
			String: saItemNos[*]
			String: sArguments
			Boolean: bSimpleAssInv
			Boolean: bBasicAssInv
			String: sCurrentCultVariety
			Number: nAllocatedItemNo
			String: sAllocatedFlag
			Number: nRow
			Number: nType
			Number: nYear
			Number: nItemNo[*]
			Number: naQuantities[*]
			Number: nNumItems
			Number: nReturnCode
			Boolean: bShowQueryOk
			Boolean: bEnableTreeTypeDlgSelectPb
			Boolean: bEnableCultivarFrmSelectPb
			Boolean: bEnableRootStockFrmSelectPb
			Sql Handle: hSqlCalcSubHdl
			Boolean: bCalcSubHdlConnected
			Boolean: bCalcSubHdlPrepared
			String: sASSINVTABNAME
			String: sAssInvSelected
			Boolean: bAssInv
			Number: nAssInvYr
			!
			Number: nRD1TotAvail
			Number: nRD1Subs
			Number: nRD1Graded
			Number: nRD1Growing
			Number: nRD1EstAvailCount
			Number: nRD1Shipped
			Number: nRD1SubsShipped
			Number: nRD1OnOrder
			Number: nRD1OnOrdAsSubs
			Number: nRD1ItemNo
			Number: nMR1ItemNo
			Boolean: bSecondCount
			!
			Sql Handle: hSqlHdlInv
			Boolean: bHdlInvConnected
			Boolean: bHdlInvPrepared
			!
			Sql Handle: hSqlHdlSelSIS
			Boolean: bHdlSelSISConnected
			Boolean: bHdlSelSISPrepared
			Sql Handle: hSqlHdlRootDesc
			Boolean: bHdlRootDescConnected
			Boolean: bHdlRootDescPrepared
			Sql Handle: hSqlHdlSub
			Boolean: bHdlSubConnected
			Boolean: bHdlSubPrepared
			!
			Sql Handle: hSqlHdlOrdOnOrd
			Boolean: bHdlOrdOnOrdConnected
			Boolean: bHdlOrdOnOrdPrepared
			!
			Sql Handle: hSqlHdlConfOnOrd
			Boolean: bHdlConfOnOrdConnected
			Boolean: bHdlConfOnOrdPrepared
			!
			Sql Handle: hSqlHdlShItem
			Boolean: bHdlShItemConnected
			Boolean: bHdlShItemPrepared
			!
			Sql Handle: hSqlHdlShAsSub
			Boolean: bHdlShAsSubConnected
			Boolean: bHdlShAsSubPrepared
			!
			Sql Handle: hSqlHdlSubsOrd
			Boolean: bHdlSubsOrdConnected
			Boolean: bHdlSubsOrdPrepared
			!
			Sql Handle: hSqlHdlSubsConf
			Boolean: bHdlSubsConfConnected
			Boolean: bHdlSubsConfPrepared
			!
			Sql Handle: hSqlHdlUpdSIS
			Boolean: bHdlUpdSISConnected
			Boolean: bHdlUpdSISPrepared
			!
			Sql Handle: hSqlSelAssInvHdl
			Boolean: bSelAssInvHdlConnected
			Boolean: bSelAssInvHdlPrepared
			!
			String: sHelpFileName
			String: sPreEntryWhere
			String: sSql
		Message Actions
			On SAM_Create
				Set sHelpFileName = 'g:\\apps\\gupta\\help\\stkItems.hlp'
				Set bEnableTreeTypeDlgSelectPb = FALSE
				Set bEnableCultivarFrmSelectPb = FALSE
				Set bEnableRootStockFrmSelectPb = FALSE
				Set bShowQueryOk = FALSE
				Set bTblStockIsActive = FALSE
				Call SalPostMsg( hWndForm, PAM_CREATECOMPLETE, 0, 0 )
			On PAM_CREATECOMPLETE
				Set bHdlSelSISConnected = FALSE
				Set bHdlSelSISPrepared = FALSE
				Set bHdlUpdSISConnected = FALSE
				Set bHdlUpdSISPrepared = FALSE
				Set bHdlSubsConfConnected = FALSE
				Set bHdlSubsConfPrepared = FALSE
				Set bHdlSubsOrdConnected = FALSE
				Set bHdlSubsOrdPrepared = FALSE
				Set bCalcSubHdlConnected = FALSE
				Set bCalcSubHdlPrepared = FALSE
				Set bHdlShAsSubConnected = FALSE
				Set bHdlShAsSubPrepared = FALSE
				Set bHdlShItemConnected = FALSE
				Set bHdlShItemPrepared = FALSE
				Set bHdlOrdOnOrdConnected = FALSE
				Set bHdlOrdOnOrdPrepared = FALSE
				Set bHdlConfOnOrdConnected = FALSE
				Set bHdlConfOnOrdPrepared = FALSE
				Set bHdlSubConnected = FALSE
				Set bHdlSubPrepared = FALSE
				Set bSelAssInvHdlConnected = FALSE
				Set bSelAssInvHdlPrepared = FALSE
				Set dfCurrDate = SalDateCurrent(  )
				Set dfYr = cSeasonYear.GetSeasonYear( )
				Set sBuildWhere = ''
				Set nReturnCode = SalModalDialog( dlgEntryToStock, hWndForm )
				If nReturnCode = nQCultivars OR nReturnCode = nQRootstocks OR nReturnCode = nQueryAllocFlag
					If sBuildWhere = ' WHERE '
						Set sBuildWhere = ''
					Set sPreEntryWhere = sBuildWhere
					Set bTblStockIsActive = TRUE
					Call SalSendMsg( tblStock, PAM_POPULATE, nReturnCode, 0 )
				Else If nReturnCode = nAddNew
					! Call SalSendMsg( pbAdd, SAM_Click, 0, 0 )
					Call SalWaitCursor( FALSE )
				! Else 
					   If NOT bTblStockIsActive
						   Call SalDestroyWindow( hWndForm )
			On SAM_Destroy
				If bHdlInvConnected
					Call SqlDisconnect( hSqlHdlInv )
				If bHdlUpdSISConnected
					Call SqlDisconnect( hSqlHdlUpdSIS )
				If bHdlSubsConfConnected
					Call SqlDisconnect( hSqlHdlSubsConf )
				If bHdlSubsOrdConnected
					Call SqlDisconnect( hSqlHdlSubsOrd )
				If bHdlSubConnected
					Call SqlDisconnect( hSqlHdlSub )
				If bHdlShAsSubConnected
					Call SqlDisconnect( hSqlHdlShAsSub )
				If bHdlShItemConnected
					Call SqlDisconnect( hSqlHdlShItem )
				If bHdlConfOnOrdConnected
					Call SqlDisconnect( hSqlHdlConfOnOrd )
				If bHdlOrdOnOrdConnected
					Call SqlDisconnect( hSqlHdlOrdOnOrd )
				If bHdlSelSISConnected
					Call SqlDisconnect( hSqlHdlSelSIS )
				If bCalcSubHdlConnected
					Call SqlDisconnect( hSqlCalcSubHdl )
				If bSelAssInvHdlConnected
					Call SqlDisconnect( hSqlSelAssInvHdl )
				Call RecalcEstAvail( nItemNo, 0, 0, 0, nDisconnect )
				Call DenormaliseData( hWndNULL, nDisconnect )
				Call CalcItemTotalAvail( 0, 0, nCalcItemAvail, nDisconnect )
				Call GetItemNoFromBasicDetails( '', '', '', nRD1ItemNo, nDisconnect )
				Call HaveMR1RD1ItemsSecondCount( 0, 0, 0, bSecondCount, nDisconnect )
				Call GetSISFigures( 0, 0, nRD1TotAvail, nRD1Graded,
						  nRD1Growing, nRD1EstAvailCount, nRD1Shipped, nRD1SubsShipped,
						  nRD1OnOrder, nRD1OnOrdAsSubs, nDisconnect )
				Call NewCalculateSubs( 0, 0, nRD1Subs, nDisconnect )
				Call RecalculateInventoryFigures( nItemNo, 0, '', nDisconnect )
				Call CalcCultivarRoyalty( 0, '', 0, nTmp, nDisconnect )
				Call CalcRootstockRoyalty( 0, '', 0, nTmp, nDisconnect )
				Call SalSendMsg( hWndPushbutton, PAM_ENABLE, 0, 0 )
			On SAM_Activate
				Return SalSendMsgToChildren( hWndForm, PAM_ACTIVATE, wParam, lParam )
			On SAM_Close
				If NOT TableForgetChanges( tblStock, frmStock.tblStock.bEdit )
					Return FALSE
				If IDCANCEL = SalMessageBox( 'You are about to EXIT the STOCK ITEMS program, Do you want to do this?', 'Warning', MB_OkCancel )
					Return FALSE
			On PAM_PRINTASSINV
				Set bAssInv = TRUE
				Call CallBuildSql( frmStock.tblStock, nSELECT, PAM_PRINTASSINVSEL, '', '' )
				Set sgRepInto = sColumns
				Set sgRepBind = sIntoVars
				If bSimpleAssInv 
					Set sgReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\assinvs3.qrp'
				Else If bBasicAssInv
					Set sgReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\assinvb3.qrp'
				Else
					Set sgReportFile = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\assinvc3.qrp'
				Set ngError = 1
				Call SalReportPrint( hWndForm, sgReportFile, sgRepBind, sgRepInto, 1, RPT_PrintAll,0,0, ngError )
			On SAM_ReportStart
				If bAssInv
					If SalTblAnyRows( frmStock.tblStock, ROW_Selected, 0 )
						Set bSelectedRows = TRUE
					Else
						Set bSelectedRows = FALSE
					Return TRUE
			On SAM_ReportFetchInit
				If bAssInv
					If bSelectedRows
						! denorm
						Call CallBuildSql( frmStock.tblStock, nSELECT, PAM_ASSINVSELECTED, ' STOCK_ITEM_SALE ',
								 '  WHERE  STOCK_ITEM_SALE.STOCK_ITEM_NO = :frmStock.tblStock.colItemNo AND 
								STOCK_ITEM_SALE.YEAR_OF_SALE = :frmStock.nAssInvYr ' )
						! Call CallBuildSql( frmStock.tblStock, nSELECT, PAM_ASSINVSELECTED, 'CULTIVAR, STOCK_ITEM_SALE ',
								 '  WHERE  CULTIVAR.CULT_ID(+) = :frmStock.tblStock.colCultId AND 
								STOCK_ITEM_SALE.STOCK_ITEM_NO = :frmStock.tblStock.colItemNo AND 
								STOCK_ITEM_SALE.YEAR_OF_SALE = :frmStock.nAssInvYr ' )
						Set sAssInvSelected = sgSql
					Else
						Call SalSendMsg( frmStock.tblStock, PAM_POPULATE2, 0, 0 )
					Set sCurrentCultVariety = ''
					Set ngTRow = TBL_MinRow
					Set dfBreakTotGrowing = 0
					Set dfBreakTotEstGrow = 0
					Set dfBreakTotOnOrder = 0
					Set dfBreakTotShip = 0
					Set dfTotalGrowing = 0
					Set dfTotalEstGrow = 0
					Set dfTotalOnOrder = 0
					Set dfTotalShip = 0
					Return TRUE
			On SAM_ReportFetchNext
				If bAssInv
					!
					Loop
						If bSelectedRows 
							If NOT SalTblFindNextRow( frmStock.tblStock, ngTRow, ROW_Selected, 0 )
								Return FALSE
						Else
							If NOT SalTblFindNextRow( frmStock.tblStock, ngTRow, 0, 0 )
								Return FALSE
						! If SalTblFindNextRow( frmStock.tblStock, ngTRow, 0, 0 )
						Call SalTblFetchRow( frmStock.tblStock, ngTRow )
						If ItemActive( tblStock.colItemNo, nAssInvYr, nExecute )
							If ItemUsed( tblStock.colItemNo, nAssInvYr, tblStock.colTreeType, tblStock.colCultId, tblStock.colRootId, nExecute )
								If tblStock.colTreeType = 'RD1'
									If GetItemNoFromBasicDetails( 'MR1', tblStock.colCultId, tblStock.colRootId, nMR1ItemNo, nExecute )
										! Need to check if the associated MR1 actually has a year record for it
										If DoesMR1Exist( nMR1ItemNo, nAssInvYr, nExecute )
											If ItemActive( nMR1ItemNo, nAssInvYr, nExecute )
												Call HaveMR1RD1ItemsSecondCount( tblStock.colItemNo, nMR1ItemNo, nAssInvYr, bSecondCount, nExecute )
												If bSecondCount
													Break
											Else
												Break
										Else
											Break
									Else
										Break
								Else
									Break
					!
					Set tblStock.colMR1RD1Combined = 'N'
					If bSelectedRows
						Call MySelectRecord( hSqlSelAssInvHdl, bSelAssInvHdlConnected, bSelAssInvHdlPrepared, sAssInvSelected, nFetchFirst, nReturnCode )
					If DoesItemHaveSubstitute( hSqlHdlSub, bHdlSubConnected,
							 bHdlSubPrepared, 'frmStock.tblStock.colItemNo' )
						Call CalculateSubs( frmStock.hSqlCalcSubHdl,
								 frmStock.bCalcSubHdlConnected,frmStock.bCalcSubHdlPrepared,
								hWndForm, frmStock.tblStock.colItemNo, frmStock.nAssInvYr, frmStock.tblStock.colSubs )
						Call SalSendMsgToChildren( frmStock.tblStock, PAM_LOOKUPSUB, 0, 0 )
					Else
						Set frmStock.tblStock.colAvail = frmStock.tblStock.colOnHand
					! denorm
					! If NOT SalIsNull( frmStock.tblStock.colRootId )
						   Call GetRootDetails( hSqlHdlRootDesc, bHdlRootDescConnected,
								 bHdlRootDescPrepared, 'ROOT_DESC, RT_NON_PROP_FLAG, RT_NOT_SALE_FLAG',
								 ':frmStock.tblStock.colRootDesc, :frmStock.tblStock.colRootNPAflag,
								:frmStock.tblStock.colRTNotSale', 'frmStock.tblStock.colRootId' )
					Call SalSendMsgToChildren( frmStock.tblStock, PAM_SETVALUES, 0, 0 )
					!
					If tblStock.colTreeType = 'MR1'
						If GetItemNoFromBasicDetails( 'RD1', tblStock.colCultId, tblStock.colRootId, nRD1ItemNo, nExecute )
							If ItemActive( nRD1ItemNo, nAssInvYr, nExecute )
								Call HaveMR1RD1ItemsSecondCount( tblStock.colItemNo, nRD1ItemNo, nAssInvYr, bSecondCount, nExecute )
								If NOT bSecondCount 
									Call GetSISFigures( nRD1ItemNo, nAssInvYr, nRD1TotAvail, nRD1Graded,
											  nRD1Growing, nRD1EstAvailCount, nRD1Shipped, nRD1SubsShipped,
											  nRD1OnOrder, nRD1OnOrdAsSubs, nExecute )
									!
									Call NewCalculateSubs( nRD1ItemNo, nAssInvYr, nRD1Subs, nExecute )
									Set tblStock.colAvail = tblStock.colAvail + nRD1TotAvail + nRD1Subs
									Set tblStock.colOnHand = tblStock.colOnHand + nRD1TotAvail
									Set tblStock.colGraded = tblStock.colGraded + nRD1Graded
									Set tblStock.colGrowing = tblStock.colGrowing + nRD1Growing
									Set tblStock.colEstGrowing = tblStock.colEstGrowing + nRD1EstAvailCount
									Set tblStock.colShipped = tblStock.colShipped + nRD1Shipped
									Set tblStock.colShippedAsSubs = tblStock.colShippedAsSubs + nRD1SubsShipped
									Set tblStock.colOnOrder = tblStock.colOnOrder + nRD1OnOrder
									Set tblStock.colOnOrderAsSubs = tblStock.colOnOrderAsSubs + nRD1OnOrdAsSubs
									Set tblStock.colMR1RD1Combined = 'Y'
					! Calculate totals as a problem with report with sum() was found.
					If tblStock.colCultVariety = sCurrentCultVariety
						Set dfBreakTotGrowing = dfBreakTotGrowing + tblStock.colGrowing
						Set dfBreakTotEstGrow = dfBreakTotEstGrow + tblStock.colEstGrowing
						Set dfBreakTotOnOrder = dfBreakTotOnOrder + tblStock.colOnOrder
						Set dfBreakTotShip = dfBreakTotShip + tblStock.colShipped
					Else
						Set sCurrentCultVariety = tblStock.colCultVariety
						Set dfBreakTotGrowing = tblStock.colGrowing
						Set dfBreakTotEstGrow = tblStock.colEstGrowing
						Set dfBreakTotOnOrder = tblStock.colOnOrder
						Set dfBreakTotShip = tblStock.colShipped
					Set dfTotalGrowing = dfTotalGrowing + tblStock.colGrowing
					Set dfTotalEstGrow = dfTotalEstGrow + tblStock.colEstGrowing
					Set dfTotalOnOrder = dfTotalOnOrder + tblStock.colOnOrder
					Set dfTotalShip = dfTotalShip + tblStock.colShipped
					!
					! Call GetItemTotalBudCount( tblStock.colItemNo, nAssInvYr, dfItemTotalBudCount, nExecute )
					Call GetItemTotalBFSCounts( tblStock.colItemNo, nAssInvYr, dfItemTotalBudCount, dfItemTotalFirstCount, dfItemTotalSecondCount, nExecute )
					If NOT tblStock.colGenItem = 'Y'
						Call CalcItemsGCAvailORAvail(  tblStock.colItemNo, nAssInvYr, dfGCAvail, dfORAvail, nExecute )
					!
					Return TRUE
					! Else 
						   Return FALSE
			On SAM_ReportFinish
				! Call GetItemTotalBudCount( 0, 0, dfItemTotalBudCount, nDisconnect )
				Call GetItemTotalBFSCounts( 0, 0, dfItemTotalBudCount, dfItemTotalFirstCount, dfItemTotalSecondCount, nDisconnect )
				Call CalcItemsGCAvailORAvail(  0, 0, dfGCAvail, dfORAvail, nDisconnect )
				Set bgReportFinish = TRUE
				Call SalWaitCursor( FALSE )
				Return TRUE

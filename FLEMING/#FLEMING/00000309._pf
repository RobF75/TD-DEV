				Functions
					Function: GetItemAllocFlag
						Description:
						Returns
							Boolean:
						Parameters
							Number: nItemNo
							Number: nYear
							Receive String: sItemAllocFlag
							Number: nActionType
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							String: sFuncName
							Boolean: bOk
							Number: nInd
							!
							String: sGotItemAllocFlag
						Actions
							Set sFuncName = 'GetItemAllocFlag'
							Select Case nActionType
								Case nExecute
									Loop Execute
										Loop Connect
											If bHandleConnected
												Break Connect
											Else
												Set bHandleConnected = SqlConnect( hSqlHandle ) 
												If bHandleConnected
													Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
													Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
													Break Connect
												Else
													If IDNO = SalMessageBox( 'Could not connect handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
														Break Connect
										Loop Prepare
											If bHandlePrepared
												Break Prepare
											Else
												Set sSql = 'SELECT 
														  Allocated_Flag 
														FROM 
														  Stock_Item_Sale 
														INTO 
														  :sGotItemAllocFlag 
														WHERE
														  Stock_Item_No = :nItemNo AND 
														  Year_Of_Sale = :nYear '
												If SqlPrepare( hSqlHandle, sSql )
													Set bHandlePrepared = TRUE
													Break Prepare
												Else
													Set bHandlePrepared = FALSE
													If IDNO = SalMessageBox( 'Could not prepare handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
														Break Prepare
										!
										If SqlExecute( hSqlHandle )
											Call SqlFetchNext( hSqlHandle, nInd )
											Set sItemAllocFlag = sGotItemAllocFlag
											Return TRUE
										Else
											Set bHandlePrepared = FALSE
											If IDNO = SalMessageBox( 'Could not execute handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												Return FALSE
								Case nCommit
									Set bOk = TRUE
									Loop Commit
										If bHandleConnected
											If SqlCommit( hSqlHandle )
												Break Commit
											Else
												If IDNO = SalMessageBox( 'Could not commit handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													Set bOk = FALSE
													Break Commit
										Else
											Break Commit
									Return bOk
								Case nRollback
									Set bOk = TRUE
									Loop Rollback
										If bHandleConnected
											Set bHandlePrepared = FALSE
											If SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
												Break Rollback
											Else
												If IDNO = SalMessageBox( 'Could not rollback handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													Set bOk = FALSE
													Break Rollback
										Else
											Break Rollback
									Return bOk
								Case nDisconnect
									Set bOk = TRUE
									Loop Disconnect
										If bHandleConnected
											If SqlDisconnect( hSqlHandle )
												Set bHandleConnected = FALSE
												Set bHandlePrepared = FALSE
												Break Disconnect
											Else
												If IDNO = SalMessageBox( 'Could not disconnect handle in function '||sFuncName||'Contact programmers! RETRY?', 'Error', MB_YesNo )
													Set bOk = FALSE
													Break Disconnect
										Else
											Break Disconnect
									Return bOk
								Case nRePrepare
									Set bHandlePrepared = FALSE
									Return TRUE
					Function: GetItemGradedFlag
						Description:
						Returns
							Boolean:
						Parameters
							Number: nItemNo
							Number: nYear
							Receive String: sItemGradedFlag
							Number: nActionType
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							String: sFuncName
							Boolean: bOk
							Number: nInd
							!
							Number: nGotItemGraded
						Actions
							Set sFuncName = 'GetItemGradedFlag'
							Select Case nActionType
								Case nExecute
									Loop Execute
										Loop Connect
											If bHandleConnected
												Break Connect
											Else
												Set bHandleConnected = SqlConnect( hSqlHandle ) 
												If bHandleConnected
													Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
													Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
													Break Connect
												Else
													If IDNO = SalMessageBox( 'Could not connect handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
														Break Connect
										Loop Prepare
											If bHandlePrepared
												Break Prepare
											Else
												Set sSql = 'SELECT 
														  Amt_Graded 
														FROM 
														  Stock_Item_Sale 
														INTO 
														  :nGotItemGraded 
														WHERE
														  Stock_Item_No = :nItemNo AND 
														  Year_Of_Sale = :nYear '
												If SqlPrepare( hSqlHandle, sSql )
													Set bHandlePrepared = TRUE
													Break Prepare
												Else
													Set bHandlePrepared = FALSE
													If IDNO = SalMessageBox( 'Could not prepare handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
														Break Prepare
										!
										If SqlExecute( hSqlHandle )
											Call SqlFetchNext( hSqlHandle, nInd )
											If nGotItemGraded > 0
												Set sItemGradedFlag = 'Y'
											Else
												Set sItemGradedFlag = 'N'
											Return TRUE
										Else
											Set bHandlePrepared = FALSE
											If IDNO = SalMessageBox( 'Could not execute handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												Return FALSE
								Case nCommit
									Set bOk = TRUE
									Loop Commit
										If bHandleConnected
											If SqlCommit( hSqlHandle )
												Break Commit
											Else
												If IDNO = SalMessageBox( 'Could not commit handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													Set bOk = FALSE
													Break Commit
										Else
											Break Commit
									Return bOk
								Case nRollback
									Set bOk = TRUE
									Loop Rollback
										If bHandleConnected
											Set bHandlePrepared = FALSE
											If SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
												Break Rollback
											Else
												If IDNO = SalMessageBox( 'Could not rollback handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													Set bOk = FALSE
													Break Rollback
										Else
											Break Rollback
									Return bOk
								Case nDisconnect
									Set bOk = TRUE
									Loop Disconnect
										If bHandleConnected
											If SqlDisconnect( hSqlHandle )
												Set bHandleConnected = FALSE
												Set bHandlePrepared = FALSE
												Break Disconnect
											Else
												If IDNO = SalMessageBox( 'Could not disconnect handle in function '||sFuncName||'Contact programmers! RETRY?', 'Error', MB_YesNo )
													Set bOk = FALSE
													Break Disconnect
										Else
											Break Disconnect
									Return bOk
								Case nRePrepare
									Set bHandlePrepared = FALSE
									Return TRUE
					Function: GetDenormRootDetails
						Description:
						Returns
							Boolean:
						Parameters
							String: sRootId
							Receive String: sRootDesc
							Receive String: sRootNPAFlag
							Receive String: sRootNotSaleFlag
							Number: nActionType
						Static Variables
							Sql Handle: hSqlHandle
							Boolean: bHandleConnected
							Boolean: bHandlePrepared
						Local variables
							String: sSql
							String: sFuncName
							Boolean: bOk
							Number: nInd
							!
							String: sGotRootDesc
							String: sGotRootNPAFlag
							String: sGotRootNotSaleFlag
						Actions
							Set sFuncName = 'GetDenormRootDetails'
							Select Case nActionType
								Case nExecute
									Loop Execute
										Loop Connect
											If bHandleConnected
												Break Connect
											Else
												Set bHandleConnected = SqlConnect( hSqlHandle ) 
												If bHandleConnected
													Call SqlSetLockTimeout( hSqlHandle, SQLTIMEOUT )
													Call SqlSetParameter( hSqlHandle, DBP_PRESERVE, TRUE, ''  )
													Break Connect
												Else
													If IDNO = SalMessageBox( 'Could not connect handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
														Break Connect
										Loop Prepare
											If bHandlePrepared
												Break Prepare
											Else
												Set sSql = 'SELECT 
														  Root_Desc, 
														  Rt_Non_Prop_Flag, 
														  Rt_Not_Sale_Flag 
														FROM 
														  Rootstock  
														INTO 
														  :sGotRootDesc, 
														  :sGotRootNPAFlag, 
														  :sGotRootNotSaleFlag 
														WHERE
														  Root_Id = :sRootId '
												If SqlPrepare( hSqlHandle, sSql )
													Set bHandlePrepared = TRUE
													Break Prepare
												Else
													Set bHandlePrepared = FALSE
													If IDNO = SalMessageBox( 'Could not prepare handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
														Break Prepare
										!
										Set sRootDesc = ''
										Set sRootNPAFlag = ''
										Set sRootNotSaleFlag = ''
										!
										Set sGotRootDesc = ''
										Set sGotRootNPAFlag = ''
										Set sGotRootNotSaleFlag = ''
										!
										If SqlExecute( hSqlHandle )
											If SqlFetchNext( hSqlHandle, nInd )
												Set sRootDesc = sGotRootDesc
												Set sRootNPAFlag = sGotRootNPAFlag
												Set sRootNotSaleFlag = sGotRootNotSaleFlag
												Return TRUE
											Else
												Return FALSE
										Else
											Set bHandlePrepared = FALSE
											If IDNO = SalMessageBox( 'Could not execute handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
												Return FALSE
								Case nCommit
									Set bOk = TRUE
									Loop Commit
										If bHandleConnected
											If SqlCommit( hSqlHandle )
												Break Commit
											Else
												If IDNO = SalMessageBox( 'Could not commit handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													Set bOk = FALSE
													Break Commit
										Else
											Break Commit
									Return bOk
								Case nRollback
									Set bOk = TRUE
									Loop Rollback
										If bHandleConnected
											Set bHandlePrepared = FALSE
											If SqlPrepareAndExecute( hSqlHandle, 'ROLLBACK' )
												Break Rollback
											Else
												If IDNO = SalMessageBox( 'Could not rollback handle in function '||sFuncName||'! Contact programmers! RETRY?', 'Error', MB_YesNo )
													Set bOk = FALSE
													Break Rollback
										Else
											Break Rollback
									Return bOk
								Case nDisconnect
									Set bOk = TRUE
									Loop Disconnect
										If bHandleConnected
											If SqlDisconnect( hSqlHandle )
												Set bHandleConnected = FALSE
												Set bHandlePrepared = FALSE
												Break Disconnect
											Else
												If IDNO = SalMessageBox( 'Could not disconnect handle in function '||sFuncName||'Contact programmers! RETRY?', 'Error', MB_YesNo )
													Set bOk = FALSE
													Break Disconnect
										Else
											Break Disconnect
									Return bOk
								Case nRePrepare
									Set bHandlePrepared = FALSE
									Return TRUE
				Window Variables
					Sql Handle: hLocalSqlPopTbl
					Boolean: bLocalSqlPopTbl
					Sql Handle: hLocalSqlDoTbl
					Boolean: bLocalSqlDoTbl
					Sql Handle: hLocalSqlExtra
					Boolean: bLocalSqlExtra
					String: sSQLPOPTABLENAME
					String: sSQLTABLENAME
					String: sSQLWHEREROWID
					String: sORDERBY
					String: sAssInvORDERBY
					String: sSql
					Boolean: bEdit
					Boolean: bExists
					Boolean: bCalcTotPrice
					Boolean: bCalcAvail
					Boolean: bShowAlloc
					Boolean: bShowGraded
					Number: nInd
					Number: nQueryType
					String: sQueryTmpStr
					String: sCurrentBuildWhere
					!
					Sql Handle: hSqlSISExistsHdl
					Boolean: bSISExistsHdlConnected
					Boolean: bSISExistsHdlPrepared
					Sql Handle: hSqlInsSISHdl
					Boolean: bInsSISHdlConnected
					Boolean: bInsSISHdlPrepared
					Sql Handle: hSqlCalcSubHdl
					Boolean: bCalcSubHdlConnected
					Boolean: bCalcSubHdlPrepared
					String: sCurrentDate
					Number: nCurrYear
					!
					String: sReportFileName
					Boolean: bReportTableSelectedRowsOnly
					Number: nReportTableRow
					String: sRepInto
					String: sRepBind
				Message Actions
					On PAM_POPULATE
						Set nQueryType = wParam
						If nQueryType = nQueryAllocFlag OR nQueryType = nQueryGradedFlag
							Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME || ', STOCK_ITEM_SALE ', sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
						Else
							Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_POPULATE2
						Call TablePopulate( hWndForm, hLocalSqlPopTbl, colWhere2, nSELECT, sASSINVTABNAME, sAssInvORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_ASSINVSQL )
					On PAM_REPOPULATE
						Call TableRePopulate( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_SEARCH
						Call TableSearch( hWndForm, hLocalSqlPopTbl, nSELECT, sSQLPOPTABLENAME, sORDERBY, sCurrentBuildWhere, TRUE, TBL_FillNormal, PAM_SQL )
					On PAM_DELETEROWS
						Call TableDeleteRows( hWndForm )
					On PAM_UNDELETEROWS
						Call TableUnDeleteRows( hWndForm )
					On PAM_ADDROW
						Call TableAddRowNew( hWndForm, colTreeType )
					On PAM_WRITEINSERTSUPDATES
						Call TableSaveChanges( hWndForm, hLocalSqlDoTbl, 'Stock Items', sSQLTABLENAME, sSQLWHEREROWID, bEdit, TRUE )
					On PAM_NOROWS
						Call SalMessageBox( 'No rows were found.', 'Stock Items', MB_Ok|MB_IconAsterisk )
					On PAM_RESET
						Call TableReset( hWndForm, colTreeType )
					On SAM_Create
						Set bLocalSqlPopTbl = SqlConnect( hLocalSqlPopTbl ) 
						If bLocalSqlPopTbl
							Call SqlSetLockTimeout( hLocalSqlPopTbl, SQLTIMEOUT )
							Call SqlSetParameter( hLocalSqlPopTbl, DBP_PRESERVE, TRUE, ''  )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bLocalSqlDoTbl = SqlConnect( hLocalSqlDoTbl ) 
						If bLocalSqlDoTbl
							Call SqlSetLockTimeout( hLocalSqlDoTbl, SQLTIMEOUT )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bLocalSqlExtra = SqlConnect( hLocalSqlExtra ) 
						If bLocalSqlExtra
							Call SqlSetLockTimeout( hLocalSqlExtra, SQLTIMEOUT )
						Else
							Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
							Return FALSE
						Set bCalcTotPrice = FALSE
						Set bCalcAvail = FALSE
						Set bEdit = FALSE
						Set sASSINVTABNAME = 'STOCK_ITEM, STOCK_ITEM_SALE, TREE_TYPE'
						! Set sASSINVTABNAME = 'STOCK_ITEM, CULTIVAR, STOCK_ITEM_SALE'
						Set sSQLPOPTABLENAME = ' STOCK_ITEM '
						! Set sSQLPOPTABLENAME = ' STOCK_ITEM, CULTIVAR '
						Set sSQLTABLENAME = ' STOCK_ITEM '
						Set sSQLWHEREROWID = ' WHERE ROWID = :frmStock.tblStock.colRowId '
						! Changing the order by to use the UPPERcult desc so that an index is used
						Set sORDERBY = ' ORDER BY 16,5,21,6,2 '
						! Set sORDERBY = ' ORDER BY 16,5,4,6,2 '
						Set sAssInvORDERBY = ' ORDER BY 11, 5,8,4,6,2 '
						Set bHdlRootDescConnected = FALSE
						Set bHdlRootDescPrepared = FALSE
						Set bCalcSubHdlConnected = FALSE
						Set bCalcSubHdlPrepared = FALSE
						Call SalDateToStr( SalDateCurrent(  ), sCurrentDate )
						Set bShowAlloc = FALSE
						Set nCurrYear = frmStock.cSeasonYear.GetSeasonYear( )
					On SAM_Destroy
						If bLocalSqlPopTbl
							Call SqlDisconnect( hLocalSqlPopTbl )
						If bLocalSqlDoTbl
							Call SqlDisconnect( hLocalSqlDoTbl )
						If bLocalSqlExtra
							Call SqlDisconnect( hLocalSqlExtra )
						If bSISExistsHdlConnected
							Call SqlDisconnect( hSqlSISExistsHdl )
						If bCalcSubHdlConnected
							Call SqlDisconnect( hSqlCalcSubHdl )
						If bInsSISHdlConnected
							Call SqlDisconnect( hSqlInsSISHdl )
						If bHdlRootDescConnected
							Call SqlDisconnect( hSqlHdlRootDesc )
						Call GetItemAllocFlag( 0, 0, colAllocFlag, nDisconnect )
						Call GetItemGradedFlag( 0, 0, colGradedFlag, nDisconnect )
					On SAM_FetchRowDone
						If bCalcTotPrice
							Set colTotPrice = colBasePr
							! True or false booleans are sent to indicate whether rootstock or cult processing
							If NOT SalIsNull( colRootId )
								Set colTotPrice =  colTotPrice + RoyaltySelects( FALSE )  
							If NOT SalIsNull( colCultId )
								Set colTotPrice = colTotPrice + RoyaltySelects( TRUE )
						If bCalcAvail
							Set colOnHand = FetchInvRecord( frmStock.hSqlHdlInv, frmStock.bHdlInvConnected, frmStock.bHdlInvPrepared, colItemNo, frmStock.dfYr )
							Call CalculateSubs( frmStock.tblStock.hSqlCalcSubHdl,
									 frmStock.tblStock.bCalcSubHdlConnected,frmStock.tblStock.bCalcSubHdlPrepared,
									hWndForm, frmStock.tblStock.colItemNo, frmStock.dfYr, frmStock.tblStock.colSubs )
							Call SalSendMsgToChildren( frmStock.tblStock, PAM_LOOKUPSUB, 0, 0 )
						If bShowAlloc
							Call SalSendMsg( hWndForm, PAM_SHOWALLOC, 0, 0 )
						If bShowGraded
							Call SalSendMsg( hWndForm, PAM_SHOWGRADED, 0, 0 )
						Set colUserId = SqlUser
					On PAM_SHOWALLOC
						Call GetItemAllocFlag( colItemNo, nCurrYear, colAllocFlag, nExecute )
						Return TRUE
					On PAM_SHOWGRADED
						Call GetItemGradedFlag( colItemNo, nCurrYear, colGradedFlag, nExecute )
						Return TRUE
					!
					On PAM_PRINTFULLTABLEREPORT
						Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\tblstock.qrp'
						Call TableReportPrint( hWndForm, sReportFileName, PAM_REPORTCOLUMNS, nReportPrint )
					On SAM_ReportStart
						Return TRUE
					On SAM_ReportFetchInit
						Return TableReportFetchInit( hWndForm, nReportTableRow, bReportTableSelectedRowsOnly )
					On SAM_ReportFetchNext
						Return TableReportFetchNext( hWndForm, nReportTableRow, bReportTableSelectedRowsOnly )
					On SAM_ReportFinish
						Return TRUE
			! Pushbutton: pbYearInv

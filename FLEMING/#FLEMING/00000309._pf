			Combo Box Class: clsComboBox
				Window Location and Size
					Left:  
					Top:   
					Width:  1.2"
					Width Editable? Class Default
					Height: 1.26"
					Height Editable? Class Default
				Visible? Class Default
				Editable? Class Default
				String Type: Class Default
				Maximum Data Length: Class Default
				Sorted? Class Default
				Always Show List? Class Default
				Vertical Scroll? Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Text Color: Class Default
				Background Color: Class Default
				Input Mask: Class Default
				List in Tool Palette? Yes
				Property Template:
				Class DLL Name:
				Description:
				Derived From
				Class Variables
				Instance Variables
					Boolean: bInitialised
					Boolean: bPopulateAllowed
					String: sPopulateStatement
					: hSqlHandle
						Class: hcSqlHandle
					String: sOldValue
				Functions
				List Initialization
				Message Actions
					On SAM_Create
						Set bInitialised =  FALSE
						Set bPopulateAllowed = FALSE
						Set sPopulateStatement = ''
						Call SalSendMsg( hWndItem, PAM_SETINSTANCEVARS, wParam, lParam )
						If bPopulateAllowed
							Call hSqlHandle.Connect( )
					On SAM_SetFocus
						Set sOldValue = MyValue
					On SAM_KillFocus
						If MyValue != sOldValue
							Call SalSendMsg( hWndItem, SAM_Validate, wParam, lParam )
					On SAM_DropDown
						If NOT bInitialised AND bPopulateAllowed
							Call SalWaitCursor( TRUE )
							If SalListPopulate( hWndItem, hSqlHandle.hSqlHandle, sPopulateStatement )
								Set bInitialised = TRUE
							Call SalWaitCursor( FALSE )
					On SAM_Destroy
						If bPopulateAllowed
							Call hSqlHandle.Disconnect( )

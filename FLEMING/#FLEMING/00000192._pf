							Menu Item Name:
						! Menu Separator
						! Menu Item: &Bundles
							                                                             Keyboard Accelerator: (none)
							                                                             Status Text: 
							                                                             Menu Settings 
								                                                             Enabled when: 
								                                                             Checked when: 
							                                                             Menu Actions 
								                                                             Call SalWaitCursor( TRUE )
								                                                             If SalModalDialog( dlgGetBundlesDetails, hWndForm )
									                                                             Call SalWaitCursor( TRUE )
									                                                             Call PopNumber( nYear, TRUE )
									                                                             Call PopNumber( nType, TRUE )
									                                                             Set nNumItems = 0
									                                                             If nType = nSelectedItems
										                                                             Set nNumItems = 0
										                                                             Set saItemNos[ nNumItems ] = ''
										                                                             Set nRow = TBL_MinRow
										                                                             While SalTblFindNextRow( tblStock, nRow, ROW_Selected, 0 )
											                                                             Call SalTblFetchRow( tblStock, nRow )
											                                                             Set saItemNos[ nNumItems ] = SalNumberToStrX( tblStock.colItemNo, 0 )
											                                                             Set nNumItems = nNumItems + 1
											                                                             Set saItemNos[ nNumItems ] = ''
										                                                             If NOT WriteStrArrayListToFile( saItemNos, 'c:\\temp\\items.tmp' )
											                                                             Call SalMessageBox( 'Please check your C drive ( Hard Disk ) for available space!', 'Error', MB_Ok )
											                                                             Call SalWaitCursor( FALSE )
											                                                             Return FALSE
										                                                             Set sArguments = SqlDatabase || ' ' || SqlUser || ' ' || SqlPassword || ' ' || 
												'c:\\temp\\items.tmp' || ' ' || SalNumberToStrX( nYear, 0 ) || ' ' || 'SELECTED'
									                                                             Else 
										                                                             Set sArguments = SqlDatabase || ' ' || SqlUser || ' ' || SqlPassword || ' ' || 
												'c:\\temp\\items.tmp' || ' ' || SalNumberToStrX( nYear, 0 ) || ' ' || 'ALL'
									!
									                                                             If SqlDatabase = 'STOCKDEV'
										                                                             Call SalLoadApp( 'PRBUNDLD', sArguments )
									                                                             Else 
										                                                             Call SalLoadApp( 'PRBUNDL', sArguments )
								                                                             Call SalWaitCursor( FALSE )
							                                                             Menu Item Name: 
					Popup Menu: F&urther
						Resource Id: 56163
						Enabled when:
						Status Text:
						Menu Item Name:
						Menu Item: Generate Curent Season Inventory Year
							Resource Id: 56181
							Keyboard Accelerator: (none)
							Status Text:
							Menu Settings
								Enabled when:
								Checked when:
							Menu Actions
								If IDYES = SalMessageBox( 'A inventory year will be created for the current season for the selected items. To create a different year, change the current season year first.  Continue ?', 'Note', MB_YesNo )
									Call SalSendMsg( tblStockItems, PAM_clsNSTKINVD_CREATEITMSINVYRS, 2, 0 )
							Menu Item Name:
						Menu Separator
						Menu Item: Recalculate Stock Figures ( full all recalc )
							Resource Id: 56162
							Keyboard Accelerator: (none)
							Status Text:
							Menu Settings
								Enabled when:
								Checked when:
							Menu Actions
								If SalModalDialog( dlgGetRecalcEstAvailDetails, hWndForm )
									Call PopNumber( nYear, TRUE )
									Call PopString( sType, TRUE )
									Set nPos = 0
									Set naItemNos[ nPos ] = NUMBER_Null
									If sType = 'SELECTED'
										Call TableLoop( tblStockItems, hWndForm, PAM_clsTBL_ROWACTION, 2, ROW_Selected, 0, 'Extracting Selected Items', TBL_cls_LowToHi )
										Call RecalculateInventoryFigures( naItemNos, nYear, 'SELECTED', SH_cls_Execute )
									Else
										Call RecalculateInventoryFigures( naItemNos, nYear, 'ALL', SH_cls_Execute )
							Menu Item Name:
						Menu Separator
						Menu Item: Update Denorm. Stock Item Fields
							Resource Id: 56161
							Keyboard Accelerator: (none)
							Status Text:
							Menu Settings
								Enabled when:
								Checked when:
							Menu Actions
								If SalModalDialog( dlgGetDenormDataDetails, hWndForm )
									Call PopNumber( nYear, TRUE )
									Call PopString( sType, TRUE )
									Set nPos = 0
									Set naItemNos[ nPos ] = NUMBER_Null
									If sType = 'SELECTED'
										Call TableLoop( tblStockItems, hWndForm, PAM_clsTBL_ROWACTION, 2, ROW_Selected, 0, 'Extracting Selected Items', TBL_cls_LowToHi )
										Call UpdtDenormStckItmFields( naItemNos, 'SELECTED', SH_cls_Execute )
									Else
										Call UpdtDenormStckItmFields( naItemNos, 'ALL', SH_cls_Execute )

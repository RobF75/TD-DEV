									Cell Type? Class Default
									Multiline Cell? Class Default
									Cell DropDownList
										Sorted? Class Default
										Vertical Scroll? Class Default
										Auto Drop Down? Class Default
										Allow Text Editing? Class Default
									Cell CheckBox
										Check Value:
										Uncheck Value:
										Ignore Case? Class Default
								List Values
								Message Actions
									On PAM_clsTBL_ROWNEWINIT
										Set MyValue = 'N'
									On PAM_clsTBL_DATAVAL
										If SalIsNull( hWndItem )
											Set MyValue = 'N'
										Else If MyValue = 'Y'
											Call ExistsItemOnGrowSaleLocation( colItemNo, bExists, SH_cls_Execute )
											If bExists
												Call ErrorMessage( 'This stock item is growing at a location. It Cannot become a Generic.  Please rectify!', hWndForm, lParam )
												Return FALSE
										Return TRUE

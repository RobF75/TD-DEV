								Maximum Data Length: 1
								Data Type: Class Default
								Justify: Class Default
								Width:  Class Default
								Width Editable? Class Default
								Format: Uppercase
								Country: Class Default
								Input Mask: Class Default
								Cell Options
									Cell Type? Drop Down List
									Multiline Cell? Class Default
									Cell DropDownList
										Sorted? Class Default
										Vertical Scroll? Class Default
										Auto Drop Down? Class Default
										Allow Text Editing? No
									Cell CheckBox
										Check Value:
										Uncheck Value:
										Ignore Case? Class Default
								List Values
									Text: C
									Text: B
								Message Actions
									! On PAM_clsTBL_ROWNEWINIT
										                                                             Set MyValue = 'B'
									On PAM_clsTBL_DATAVAL
										If SalIsNull( hWndItem )
											Call ErrorMessage( "Please enter the Stock Type first.  'B' Bare Rooted, 'C' Container.", hWndForm, lParam )
											Return FALSE
										Else If MyValue = 'B' OR MyValue = 'C'
											Return TRUE
										Else
											Call ErrorMessage( "Stock Type can only be 'B' Bare Rooted, 'C' Container.  Please rectify first.", hWndForm, lParam )
											Return FALSE

							                                                             Message Actions 
								                                                             On PAM_cls_SETINSTANCEVARS
									                                                             Set pbInventory.hWndPickIntoTable = tblStockItems
								                                                             On PAM_cls_SETFIELDS
									                                                             Call pbInventory.SetInventoryFields( tblStockItems.colItemNo, tblStockItems.colTreeTypeDesc, tblStockItems.colCultDesc, tblStockItems.colRootDesc )
									                                                             Return TRUE
						                                                             Pushbutton: pbPickTreeTypes
							                                                             Message Actions 
								                                                             On PAM_cls_SETINSTANCEVARS
									                                                             Set pbPickTreeTypes.hWndPickIntoTable = tblStockItems
								                                                             On PAM_cls_GETFIELDS
									                                                             If SalSendMsg( tblStockItems, PAM_clsNSTKINVD_PCKITMFIELDSOK, 0, SalHStringToNumber( 'TREETYPE' ) )
										                                                             Call pbPickTreeTypes.GetTreeTypeFields( tblStockItems.colTreeType, tblStockItems.colTreeTypeDesc, tblStockItems.colTypeDescription )
									                                                             Return TRUE
						                                                             Pushbutton: pbPickCultivars
							                                                             Message Actions 
								                                                             On PAM_cls_SETINSTANCEVARS
									                                                             Set pbPickCultivars.hWndPickIntoTable = tblStockItems
								                                                             On PAM_cls_SETFIELDS
									                                                             Call pbPickCultivars.SetCultivarFields( tblStockItems.colCultId, tblStockItems.colCultDesc )
									                                                             Return TRUE
								                                                             On PAM_cls_GETFIELDS
									                                                             If SalSendMsg( tblStockItems, PAM_clsNSTKINVD_PCKITMFIELDSOK, 0, SalHStringToNumber( 'CULTIVAR' ) )
										                                                             Call pbPickCultivars.GetCultivarFields( tblStockItems.colCultId, tblStockItems.colCultDesc )
									                                                             Return TRUE
								!
								                                                             On SAM_Click
									                                                             If SalTblQueryRowFlags( tblStockItems, SalTblQueryContext( tblStockItems ), ROW_Selected ) AND NOT SalIsNull( tblStockItems.colCultId )
										                                                             Return SalSendMsg( pbDetsCult, SAM_Click, 0, 0 )
									                                                             Else 
										                                                             Return SalSendClassMessage( SAM_Click, wParam, lParam )
						                                                             Pushbutton: pbDetsCult
							                                                             Message Actions 
								                                                             On PAM_cls_SETINSTANCEVARS
									                                                             Set pbDetsCult.hWndParentTable = tblStockItems
								                                                             On PAM_cls_SETFIELDS
									                                                             Call pbDetsCult.SetCultivarDetailsFields( tblStockItems.colCultId )
									                                                             Return TRUE
						                                                             Pushbutton: pbPickRootstocks
							                                                             Message Actions 
								                                                             On PAM_cls_SETINSTANCEVARS
									                                                             Set pbPickRootstocks.hWndPickIntoTable = tblStockItems
								                                                             On PAM_cls_SETFIELDS
									                                                             Call pbPickRootstocks.SetRootstockFields( tblStockItems.colRootId, tblStockItems.colRootDesc )
									                                                             Return TRUE
								                                                             On PAM_cls_GETFIELDS
									                                                             If SalSendMsg( tblStockItems, PAM_clsNSTKINVD_PCKITMFIELDSOK, 0, SalHStringToNumber( 'ROOTSTOCK' ) )
										                                                             Call pbPickRootstocks.GetRootstockFields( tblStockItems.colRootId, tblStockItems.colRootDesc )
									                                                             Return TRUE
								!
								                                                             On SAM_Click
									                                                             If SalTblQueryRowFlags( tblStockItems, SalTblQueryContext( tblStockItems ), ROW_Selected ) AND NOT SalIsNull( tblStockItems.colRootId )
										                                                             Return SalSendMsg( pbDetsRoot, SAM_Click, 0, 0 )
									                                                             Else 
										                                                             Return SalSendClassMessage( SAM_Click, wParam, lParam )

									                                                             Set pbDetsRoot.hWndParentTable = tblStockItems
								                                                             On PAM_cls_SETFIELDS
									                                                             Call pbDetsRoot.SetRootDetailsFields( tblStockItems.colRootId )
									                                                             Return TRUE

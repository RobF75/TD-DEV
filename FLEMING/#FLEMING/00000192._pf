						Contents
							Column: colYear
								Class Child Ref Key: 25
								Class ChildKey: 9
								Class: clsfrmQueryStockItems
								Property Template:
								Class DLL Name:
								Title:
								Visible? Class Default
								Editable? Class Default
								Maximum Data Length: Class Default
								Data Type: Class Default
								Justify: Class Default
								Width:  Class Default
								Width Editable? Class Default
								Format: Class Default
								Country: Class Default
								Input Mask: Class Default
								Cell Options
									Cell Type? Class Default
									Multiline Cell? Class Default
									Cell DropDownList
										Sorted? Class Default
										Vertical Scroll? Class Default
										Auto Drop Down? Class Default
										Allow Text Editing? Class Default
									Cell CheckBox
										Check Value:
										Uncheck Value:
										Ignore Case? Class Default
								List Values
								Message Actions
							Column: colItemNo
								Class Child Ref Key: 26
								Class ChildKey: 10
								Class: clsfrmQueryStockItems
								Property Template:
								Class DLL Name:
								Title:
								Visible? Class Default
								Editable? Class Default
								Maximum Data Length: Class Default
								Data Type: Class Default
								Justify: Class Default
								Width:  Class Default
								Width Editable? Class Default
								Format: Class Default
								Country: Class Default
								Input Mask: Class Default
								Cell Options
									Cell Type? Class Default
									Multiline Cell? Class Default
									Cell DropDownList
										Sorted? Class Default
										Vertical Scroll? Class Default
										Auto Drop Down? Class Default
										Allow Text Editing? Class Default
									Cell CheckBox
										Check Value:
										Uncheck Value:
										Ignore Case? Class Default
								List Values
								Message Actions
									On PAM_clsTBL_CHECKROWNEW
										Call ExistsItemByItemFields( colTreeType, colCultId, colRootId, bExists, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'This stock item already exists!', hWndForm, lParam )
											Return FALSE
										Else
											Call GetNextNewItemNo( colItemNo, SH_cls_Execute )
											If SalIsNull( hWndItem )
												Set colItemNo = 1
											Call GetTreeTypeDenormDets( colTreeType, colTreeTypeDesc, colTypeDescription, SH_cls_Execute )
											Call GetCultivarDenormDets( colCultId, colVarietyType, colUpperVariety, colCultDesc, colCVNotSale, colCVNPA, SH_cls_Execute )
											Call GetRootstockDenormDets( colRootId, colRootDesc, colRTNotSale, colRTNPA, SH_cls_Execute )
											Return TRUE
									On PAM_clsTBL_CHECKROWEDITED
										Call GetTreeTypeDenormDets( colTreeType, colTreeTypeDesc, colTypeDescription, SH_cls_Execute )
										Call GetCultivarDenormDets( colCultId, colVarietyType, colUpperVariety, colCultDesc, colCVNotSale, colCVNPA, SH_cls_Execute )
										Call GetRootstockDenormDets( colRootId, colRootDesc, colRTNotSale, colRTNPA, SH_cls_Execute )
										Return TRUE
									On PAM_clsTBL_CHECKROWDELETED
										Call CheckItemOnOrder( colItemNo, bExists, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'This stock item still has orders against it.. Please delete these first!', hWndForm, lParam )
											Return FALSE
										Call ExistsItemOnItemSale( colItemNo, bExists, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'This stock item still has inventory years against it.. Please delete these first!', hWndForm, lParam )
											Return FALSE
										Call ExistsItemOnScionEvalLocation( colItemNo, bExists, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'This stock item is still growing on Scion Eval. Please delete these first!', hWndForm, lParam )
											Return FALSE
										Call ExistsItemOnGrowSaleLocation( colItemNo, bExists, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'This stock item is still growing at a location. Please delete these first!', hWndForm, lParam )
											Return FALSE
										Return TRUE
									On PAM_clsTBL_ROWINSERTED
										Return SalSendMsg( hWndForm, PAM_clsNSTKINVD_CREATEINVYEAR, 1, lParam )
									On PAM_clsTBL_DATAVAL
										If SalIsNull( colTreeType )
											Call ErrorMessage( 'Invalid tree type! Please SELECT a valid one.', hWndForm, lParam )
											Return FALSE
										If SalIsNull( colCultId ) AND SalIsNull( colRootId )
											Call ErrorMessage( 'Invalid cultivar and rootstock! Please SELECT valid ones.', hWndForm, lParam )
											Return FALSE
										Return TRUE
							Column: colVarietyType
								Class Child Ref Key: 27
								Class ChildKey: 11

				                                                             Instance Variables 
				                                                             Functions 
				                                                             Message Actions 
					                                                             On PAM_cls_SETINSTANCEVARS
						                                                             Call SalSendClassMessage( PAM_cls_SETINSTANCEVARS, wParam, lParam )
						                                                             Set clsfrmStockItems.nQueryType = STCKITMQ_QueryStockItem
						                                                             Set clsfrmStockItems.bAddAllowed = TRUE
						                                                             Set clsfrmStockItems.bSaveAllowed = TRUE
						                                                             Set clsfrmStockItems.bDeleteAllowed = TRUE
						                                                             Set clsfrmStockItems.bUnDeleteAllowed = TRUE
					                                                             On SAM_Destroy
						                                                             Call RecalculateInventoryFigures( naItemNos, 0, '', SH_cls_Disconnect )
						                                                             Call UpdtDenormStckItmFields( naItemNos, '', SH_cls_Disconnect )
						                                                             Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
					                                                             On PAM_clsTBL_ROWACTION
						! wParam = 1 spare
						! wParam = 2 for extract selected items for recalculating inventory and Denorm. Data fields
						                                                             If wParam = 2
							                                                             Set naItemNos[ nPos ] = tblStockItems.colItemNo
							                                                             Set nPos = nPos + 1
							                                                             Set naItemNos[ nPos ] = NUMBER_Null
						                                                             Return TRUE
					                                                             On PAM_cls_REFRESHAFTRCHILDCHANGE
						                                                             Set sChildButtonChanged = SalNumberToHString( lParam )
						                                                             If sChildButtonChanged = 'pbInventory'
							                                                             Return FALSE
						                                                             Else 
							                                                             Return TRUE

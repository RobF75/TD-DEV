								List Values
								Message Actions
									On PAM_clsTBL_DATAVAL
										If SalIsNull( hWndItem )
											Call ErrorMessage( "Please enter the Price Group.  Do not guess, see price group listing.", hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE
									On PAM_cls_CREATECOMPLETE
										Call SalListPopulate( hWndItem, hSqlPriceGroup, 'Select distinct Price_Group_Id ' || ' from Price_Group' )
						Functions
							Function: ExistsItemOnGrowSaleLocation
								Description:
								Returns
									Boolean:
								Parameters
									Number: nItemNo
									Receive Boolean: bExists
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'EXSTITMRLOC' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Location_Id
													FROM
													  Growing_Sale
													WHERE
													  Stock_Item_No = :1 "
											Set sName = 'EXSTITMRLOC'
											Set sBind = ':nItemNo'
											Set sInto = ''
											!
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set bExists = FALSE
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set bExists = TRUE
												Else
													Set bExists = FALSE
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: ExistsItemOnScionEvalLocation
								Description:
								Returns
									Boolean:
								Parameters
									Number: nItemNo
									Receive Boolean: bExists
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto

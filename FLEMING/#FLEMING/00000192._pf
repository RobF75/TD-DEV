								Message Actions
									On PAM_clsTBL_ROWNEWINIT
										Set MyValue = 1
									On PAM_clsTBL_DATAVAL
										If SalIsNull( hWndItem )
											Call ErrorMessage( "Please enter the Unit Size first.", hWndForm, lParam )
											Return FALSE
										Else If MyValue <= 0
											Call ErrorMessage( "Unit size can NOT be less than or equal to ZERO.  Please rectify.", hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE

						                                                             Pushbutton: pbOldStockItemsExtras
							                                                             Message Actions 
								                                                             On PAM_clsPB_CLICK
									                                                             Call SalMessageBox( 'This option has not been converted as yet. 
											A cut down version of the old stock items program will be started that only has the last unconverted parts available.', 'Note', MB_Ok )
									                                                             Return SalSendClassMessage( PAM_clsPB_CLICK, wParam, lParam )
				                                                             Contents 
					                                                             Data Field: dfDatabase
						                                                             Message Actions 
					                                                             Data Field: dfUser
						                                                             Message Actions 
					                                                             Background Text: Season
					                                                             Custom Control: ccSeasonYear
						                                                             Message Actions 
					                                                             Check Box: cbCalcAvail
						                                                             Message Actions 
					                                                             Check Box: cbCalcPrice
						                                                             Message Actions 
					                                                             Check Box: cbShowComments
						                                                             Message Actions 
					                                                             Child Table: tblStockItems
						                                                             Contents 
							                                                             Column: colYear
								                                                             List Values 
								                                                             Message Actions 
							                                                             Column: colItemNo
								                                                             List Values 
								                                                             Message Actions 
									                                                             On PAM_clsTBL_CHECKROWNEW
										                                                             Call ExistsItemByItemFields( colTreeType, colCultId, colRootId, bExists, SH_cls_Execute )
										                                                             If bExists
											                                                             Call ErrorMessage( 'This stock item already exists!', hWndForm, lParam )
											                                                             Return FALSE
										                                                             Else 
											                                                             Call GetNextNewItemNo( colItemNo, SH_cls_Execute )
											                                                             If SalIsNull( hWndItem )
												                                                             Set colItemNo = 1
											                                                             Call GetTreeTypeDenormDets( colTreeType, colTreeTypeDesc, colTypeDescription, SH_cls_Execute )
											                                                             Call GetCultivarDenormDets( colCultId, colVarietyType, colUpperVariety, colCultDesc, colCVNotSale, colCVNPA, SH_cls_Execute )
											                                                             Call GetRootstockDenormDets( colRootId, colRootDesc, colRTNotSale, colRTNPA, SH_cls_Execute )
											                                                             Return TRUE
									                                                             On PAM_clsTBL_CHECKROWEDITED
										                                                             Call GetTreeTypeDenormDets( colTreeType, colTreeTypeDesc, colTypeDescription, SH_cls_Execute )
										                                                             Call GetCultivarDenormDets( colCultId, colVarietyType, colUpperVariety, colCultDesc, colCVNotSale, colCVNPA, SH_cls_Execute )
										                                                             Call GetRootstockDenormDets( colRootId, colRootDesc, colRTNotSale, colRTNPA, SH_cls_Execute )
										                                                             Return TRUE
									                                                             On PAM_clsTBL_CHECKROWDELETED
										                                                             Call CheckItemOnOrder( colItemNo, bExists, SH_cls_Execute )
										                                                             If bExists
											                                                             Call ErrorMessage( 'This stock item still has field counts. Please delete these first!', hWndForm, lParam )
											                                                             Return FALSE
										                                                             Else 
											                                                             Return TRUE
									                                                             On PAM_clsTBL_ROWINSERTED
										                                                             Return SalSendMsg( hWndForm, PAM_clsNSTKINVD_CREATEINVYEAR, 1, lParam )
									                                                             On PAM_clsTBL_DATAVAL
										                                                             If SalIsNull( colTreeType )
											                                                             Call ErrorMessage( 'Invalid tree type! Please SELECT a valid one.', hWndForm, lParam )
											                                                             Return FALSE
										                                                             If SalIsNull( colCultId ) AND SalIsNull( colRootId )
											                                                             Call ErrorMessage( 'Invalid cultivar and rootstock! Please SELECT valid ones.', hWndForm, lParam )
											                                                             Return FALSE
										                                                             Return TRUE
							                                                             Column: colVarietyType
								                                                             List Values 
								                                                             Message Actions 
							                                                             Column: colUpperVariety
								                                                             List Values 
								                                                             Message Actions 
							                                                             Column: colUpperCultDesc
								                                                             List Values 

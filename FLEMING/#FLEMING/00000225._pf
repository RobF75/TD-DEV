.head 4 +  Message Actions
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sSQLPopHandle = "SELECT 
  @UPPER( Cultivar.Variety_Type ), 
  @UPPER( Cultivar.Variety ), 
  @UPPER( Cultivar.Cult_Desc ),
  Cultivar.Cult_Id, 
  Cultivar.Cult_Desc
FROM 
  Cultivar
WHERE 
  NOT @SCAN( Cultivar.Cult_Desc, '0' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '1' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '2' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '3' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '4' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '5' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '6' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '7' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '8' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '9' ) = -1
ORDER BY 1,2,3"
.head 6 -  Set sNAMEPopHandle = 'POPNUMCLT'
.head 6 -  Set sBINDPopHandle = ''
.head 6 -  Set sINTOPopHandle = ':frmNumCultivars.tblSelectedCultivars.colUpperVarietyType,
  :frmNumCultivars.tblSelectedCultivars.colUpperVariety,
  :frmNumCultivars.tblSelectedCultivars.colUpperCultDesc,
  :frmNumCultivars.tblSelectedCultivars.colCultId,
  :frmNumCultivars.tblSelectedCultivars.colCultDesc'
.head 6 -  !
.head 6 -  Set bAddAllowed = TRUE
.head 6 -  Set bPopulated = FALSE
.head 5 +  On PAM_clsTBL_POPULATE
.head 6 -  Set bPopulated = TRUE
.head 6 -  Return SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
.head 5 +  On PAM_clsPRTNCLT_GETSELCULTIDS
.head 6 -  Set sCultIdList = ''
.head 6 +  If TableLoop( hWndForm, hWndForm, PAM_clsPRTNCLT_GETSELECTED, 0, ROW_UnusedFlag1, 0, 'Extracting Selected Items', TBL_cls_LowToHi )
.head 7 +  If sCultIdList = ''
.head 8 -  Return FALSE
.head 7 +  Else
.head 8 -  Call PushString( sCultIdList )
.head 8 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  On PAM_clsPRTNCLT_GETSELECTED
.head 6 +  If sCultIdList = ''
.head 7 -  Set sCultIdList = "'" || colCultId || "'"
.head 6 +  Else
.head 7 -  Set sCultIdList = sCultIdList || ', ' || "'" || colCultId || "'"
.head 6 -  Return TRUE

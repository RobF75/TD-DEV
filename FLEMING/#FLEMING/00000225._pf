.head 4 +  Message Actions 
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sSQLPopHandle = "SELECT 
  @UPPER( Cultivar.Variety_Type ), 
  @UPPER( Cultivar.Variety ), 
  @UPPER( Cultivar.Cult_Desc ),
  Cultivar.Cult_Id, 
  Cultivar.Cult_Desc
FROM 
  Cultivar
WHERE 
  NOT @SCAN( Cultivar.Cult_Desc, '0' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '1' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '2' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '3' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '4' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '5' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '6' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '7' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '8' ) = -1 OR 
  NOT @SCAN( Cultivar.Cult_Desc, '9' ) = -1
ORDER BY 1,2,3"
.head 6 -  Set sNAMEPopHandle = 'POPNUMCLT'
.head 6 -  Set sBINDPopHandle = ''

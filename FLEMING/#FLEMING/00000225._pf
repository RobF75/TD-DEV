.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set bAddAllowed = TRUE
.head 5 +  On PAM_clsPRITMINV_GETSELECTEDITEMS
.head 6 -  Set sItemNoList = ''
.head 6 -  Set nSelectedItemYear = NUMBER_Null
.head 6 +  If TableLoop( hWndForm, hWndForm, PAM_clsPRITMINV_GETSELECTED, 0, 0, 0, 'Extracting Selected Items', TBL_cls_LowToHi )
.head 7 +  If hWndParent.ccSeasonYear.GetSeasonYear( ) != nSelectedItemYear
.head 8 -  Call SalMessageBox( 'Selected Items Year does not match report Year. Please match up first!', 'Warning', MB_Ok )
.head 8 -  Set sItemNoList = 'YEARMISMATCH'
.head 7 -  Call PushString( sItemNoList )
.head 7 -  Return TRUE
.head 6 +  Else 
.head 7 -  Return FALSE
.head 5 +  On PAM_clsPRITMINV_GETSELECTED
.head 6 +  If sItemNoList = ''
.head 7 -  Set sItemNoList = SalNumberToStrX( colItemNo, 0 ) 
.head 6 +  Else 
.head 7 -  Set sItemNoList = sItemNoList || ', ' || SalNumberToStrX( colItemNo, 0 ) 
.head 6 +  If nSelectedItemYear = NUMBER_Null
.head 7 -  Set nSelectedItemYear = colYear
.head 6 -  Return TRUE

.head 2 +  Message Actions
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set sReportFileNameNoPath = 'pnocult.qrp'
.head 4 -  !
.head 4 -  Set sReportBind = ':frmPrintNumCultivars.nYear, 
  :frmPrintNumCultivars.nItemNo, 
  :frmPrintNumCultivars.sUpperVarietyType,
  :frmPrintNumCultivars.sUpperVariety,
  :frmPrintNumCultivars.sUpperCultDesc,
  :frmPrintNumCultivars.sUpperRootDesc, 
  :frmPrintNumCultivars.sTreeType, 
  :frmPrintNumCultivars.sVariety, 
  :frmPrintNumCultivars.sCultDesc,
  :frmPrintNumCultivars.sRootDesc,
  :frmPrintNumCultivars.nCustNo, 
  :frmPrintNumCultivars.sCustName, 
  :frmPrintNumCultivars.dtOrdDate, 
  :frmPrintNumCultivars.nOrdAmt, 
  :frmPrintNumCultivars.nConfAmt, 
  :frmPrintNumCultivars.sSaleCat'
.head 4 -  Set sReportInto = 'nYearOfSale, 
  nItemNo, 
  sUpperVarietyType,
  sUpperVariety,
  sUpperCultDesc,
  sUpperRootDesc, 
  sTreeType, 
  sVariety, 
  sCultDesc,
  sRootDesc,
  nCustNo, 
  sCustName, 
  dtOrdDate, 
  nOrdAmt, 
  nConfAmt, 
  sSaleCat'
.head 4 -  Set sReportType = sReportPrintOrView
.head 3 +  On PAM_clsFRM_REPORTSTART
.head 4 +  If sCultivarType = 'ALL'
.head 5 -  Set sReportSql = "SELECT 
  Stock_Item.Item_No, 
  @UPPER( Stock_Item.Variety_Type ), 
  @UPPER( Stock_Item.Variety ), 
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Variety, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Customer_Order.Cust_No, 
  Customer_Master.Cust_Name, 
  Customer_Order.Ord_Date, 
  Customer_Order.Ordered_Amount, 
  Customer_Order.Conf_Amt, 
  Customer_Order.Sale_Cat 
FROM 
  Customer_Order, 
  Customer_Master, 
  Stock_Item 
INTO 
  :frmPrintNumCultivars.nItemNo, 
  :frmPrintNumCultivars.sUpperVarietyType,
  :frmPrintNumCultivars.sUpperVariety,
  :frmPrintNumCultivars.sUpperCultDesc,
  :frmPrintNumCultivars.sUpperRootDesc, 
  :frmPrintNumCultivars.sTreeType, 
  :frmPrintNumCultivars.sVariety, 
  :frmPrintNumCultivars.sCultDesc,
  :frmPrintNumCultivars.sRootDesc,
  :frmPrintNumCultivars.nCustNo, 
  :frmPrintNumCultivars.sCustName, 
  :frmPrintNumCultivars.dtOrdDate, 
  :frmPrintNumCultivars.nOrdAmt, 
  :frmPrintNumCultivars.nConfAmt, 
  :frmPrintNumCultivars.sSaleCat 
WHERE 
  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
  Customer_Order.Year_Of_Sale = :frmPrintNumCultivars.nYear AND 
  ( Customer_Order.Invoiced_Flag = 'N' OR 
  Customer_Order.Invoiced_Flag IS NULL ) AND 
  (
  NOT @SCAN( Stock_Item.Cult_Desc, '0' ) = -1 OR 
  NOT @SCAN( Stock_Item.Cult_Desc, '1' ) = -1 OR 
  NOT @SCAN( Stock_Item.Cult_Desc, '2' ) = -1 OR 
  NOT @SCAN( Stock_Item.Cult_Desc, '3' ) = -1 OR 
  NOT @SCAN( Stock_Item.Cult_Desc, '4' ) = -1 OR 
  NOT @SCAN( Stock_Item.Cult_Desc, '5' ) = -1 OR 
  NOT @SCAN( Stock_Item.Cult_Desc, '6' ) = -1 OR 
  NOT @SCAN( Stock_Item.Cult_Desc, '7' ) = -1 OR 
  NOT @SCAN( Stock_Item.Cult_Desc, '8' ) = -1 OR 
  NOT @SCAN( Stock_Item.Cult_Desc, '9' ) = -1
  )
ORDER BY 2,3,4,5,6,10,9,1"
.head 4 +  Else
.head 5 -  Set sReportSql = "SELECT 
  Stock_Item.Item_No, 
  @UPPER( Stock_Item.Variety_Type ), 
  @UPPER( Stock_Item.Variety ), 
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Variety, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Customer_Order.Cust_No, 
  Customer_Master.Cust_Name, 
  Customer_Order.Ord_Date, 
  Customer_Order.Ordered_Amount, 
  Customer_Order.Conf_Amt, 
  Customer_Order.Sale_Cat 
FROM 
  Customer_Order, 
  Customer_Master, 
  Stock_Item 
INTO 
  :frmPrintNumCultivars.nItemNo, 
  :frmPrintNumCultivars.sUpperVarietyType,
  :frmPrintNumCultivars.sUpperVariety,
  :frmPrintNumCultivars.sUpperCultDesc,
  :frmPrintNumCultivars.sUpperRootDesc, 
  :frmPrintNumCultivars.sTreeType, 
  :frmPrintNumCultivars.sVariety, 
  :frmPrintNumCultivars.sCultDesc,
  :frmPrintNumCultivars.sRootDesc,
  :frmPrintNumCultivars.nCustNo, 
  :frmPrintNumCultivars.sCustName, 
  :frmPrintNumCultivars.dtOrdDate, 
  :frmPrintNumCultivars.nOrdAmt, 
  :frmPrintNumCultivars.nConfAmt, 
  :frmPrintNumCultivars.sSaleCat 
WHERE 
  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
  Stock_Item.Cultivar_Id IN ( " || sSelectedCultIdList || " ) AND 
  Customer_Order.Year_Of_Sale = :frmPrintNumCultivars.nYear AND 
  ( Customer_Order.Invoiced_Flag = 'N' OR 
  Customer_Order.Invoiced_Flag IS NULL ) 
ORDER BY 2,3,4,5,6,10,9,1"

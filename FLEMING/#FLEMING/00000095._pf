					Check Box: cbShowTotalsByFarm
						Class Child Ref Key: 0
						Class ChildKey: 78
						Class: clscbGeneral
						Property Template:
						Class DLL Name:
						Title: Show Totals by Farm
						Window Location and Size
							Left:   5.5"
							Top:    0.385"
							Width:  1.963"
							Width Editable? Class Default
							Height: Class Default
							Height Editable? Class Default
						Visible? Class Default
						Font Name: Class Default
						Font Size: Class Default
						Font Enhancement: Class Default
						Text Color: Blue
						Background Color: Class Default
						Message Actions
							On PAM_clsCB_CLICK
								If wParam
									Call OurWaitCursor( TRUE )
									Call SalShowWindow( tblTotalsByFarm )
									!
									Set nRow = 0
									Set saFarmIds[ nRow ] = ''
									Set naTotals[ nRow ] = NUMBER_Null
									Call SalTblReset( tblTotalsByFarm )
									!
									Call TableLoop( tblGrowingLocations, hWndItem, PAM_clsTBL_ROWACTION, 0, 0, 0, 'Counting Up Farms', TBL_cls_LowToHi )
									!
									Set nPos = 0
									While saFarmIds[ nPos ] != ''
										Set nRow = SalTblInsertRow( tblTotalsByFarm, TBL_MaxRow )
										Call SalTblSetContext( tblTotalsByFarm, nRow )
										Call SalTblSetRowFlags( tblTotalsByFarm, nRow, ROW_HideMarks, TRUE )
										Set tblTotalsByFarm.colFarmId = saFarmIds[ nPos ]
										Set tblTotalsByFarm.colTotal = naTotals[ nPos ]
										Set nPos = nPos + 1
									Call OurWaitCursor( FALSE )
								Else
									Call SalHideWindow( tblTotalsByFarm )
							On PAM_clsTBL_ROWACTION
								Set bFound = FALSE
								Set nPos = 0
								While saFarmIds[ nPos ] != '' AND NOT bFound
									If saFarmIds[ nPos ] = tblGrowingLocations.colFarmId
										Set bFound = TRUE
										!
										If tblGrowingLocations.colSecondCount != NUMBER_Null
											Set naTotals[ nPos ] = naTotals[ nPos ] + tblGrowingLocations.colSecondCount
										Else If tblGrowingLocations.colFirstCount != NUMBER_Null
											Set naTotals[ nPos ] = naTotals[ nPos ] + tblGrowingLocations.colFirstCount
										Else
											Set naTotals[ nPos ] = naTotals[ nPos ] + tblGrowingLocations.colBudCount
									Set nPos = nPos + 1
								If NOT bFound
									Set saFarmIds[ nPos ] = tblGrowingLocations.colFarmId
									If tblGrowingLocations.colSecondCount != NUMBER_Null
										Set naTotals[ nPos ] = tblGrowingLocations.colSecondCount
									Else If tblGrowingLocations.colFirstCount != NUMBER_Null
										Set naTotals[ nPos ] = tblGrowingLocations.colFirstCount
									Else
										Set naTotals[ nPos ] = tblGrowingLocations.colBudCount
									Set nPos = nPos + 1
									Set saFarmIds[ nPos ] = ''
									Set naTotals[ nPos ] = NUMBER_Null
								Return TRUE
					Child Table: tblTotalsByFarm

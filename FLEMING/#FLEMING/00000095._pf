				List in Tool Palette? Yes
				Property Template:
				Class DLL Name:
				Description:
				Derived From
					Class: clspbPickInto
				Class Variables
					String: sTmp
					Number: nTmp
					Window Handle: hWndTmp
				Instance Variables
					! PUBLIC
					Window Handle: hWndPickIntoTable
					! PRIVATE
					Number: nYear
					Number: nItemNo
					String: sTreeTypeDesc
					String: sCultDesc
					String: sRootDesc
					String: sStockType
				Functions
					Function: SetGrowLocationsFields
						Description:
						Returns
							Boolean:
						Parameters
							Number: nNewYear
							Number: nNewItemNo
							String: sNewTreeTypeDesc
							String: sNewCultDesc
							String: sNewRootDesc
							String: sNewStockType
						Static Variables
						Local variables
						Actions
							Set nYear = nNewYear
							Set nItemNo = nNewItemNo
							Set sTreeTypeDesc = sNewTreeTypeDesc
							Set sCultDesc = sNewCultDesc
							Set sRootDesc = sNewRootDesc
							Set sStockType = sNewStockType
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbSIGrowLocations.nActivateWindowType = ACTIVATE_FormWindow
						Set clspbSIGrowLocations.sActivateDialogName = 'frmItemGrowingLocations'
						Set clspbSIGrowLocations.hWndTable = hWndPickIntoTable
						Set clspbSIGrowLocations.hWndParentTable = hWndPickIntoTable
						Set clspbSIGrowLocations.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						Call PushWndHdl( hWndItem )
						Call PushNumber( nYear )
						Call PushNumber( nItemNo )
						Call PushString( sTreeTypeDesc )
						Call PushString( sCultDesc )
						Call PushString( sRootDesc )
						Call PushString( sStockType )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopWndHdl( hWndTmp, TRUE )
						Return TRUE

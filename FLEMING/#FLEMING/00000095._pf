										  Growing_Sale.Est_Sale_Date, 
										  Growing_Sale.Not_For_Sale, 
										  Growing_Sale.Forward_Orders, 
										  Growing_Sale.Date_Planted, 
										  Growing_Sale.Date_Budded, 
										  Growing_Sale.Growing_Comm
										FROM 
										  Growing_Sale, 
										  Location  
										WHERE 
										  Growing_Sale.Stock_Item_No = :1 AND 
										  Growing_Sale.Year_Of_Sale = :2 AND 
										  Growing_Sale.Location_Id = Location.Location_Id 
										ORDER BY 
										  Location.Farm_Name, 
										  Location.Row#, 
										  Location.Seq#  "
								Set sNAMEPopHandle = 'POPITMGRLOC'
								Set sBINDPopHandle = ':hWndParent.clsfrmItemGrowingLocations.nItemNo, :hWndParent.dfYearOfSale'
								Set sINTOPopHandle = ':clsfrmItemGrowingLocations.tblGrowingLocations.colLocationId,  
										:clsfrmItemGrowingLocations.tblGrowingLocations.colFarmId, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colRowNo, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colSeqNo, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colBudCount, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colFirstCount,
										:clsfrmItemGrowingLocations.tblGrowingLocations.colSecondCount, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colEstSaleDate,
										:clsfrmItemGrowingLocations.tblGrowingLocations.colNotForSale, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colForwardOrder, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colPlanted, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colBudded, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colComments'
								!
								Set sSQLRefreshHandle = " SELECT 
										  Growing_Sale.Location_Id, 
										  Location.Farm_Name, 
										  Location.Row#, 
										  Location.Seq#, 
										  Growing_Sale.Beg_Count, 
										  Growing_Sale.First_Count, 
										  Growing_Sale.Second_Count, 
										  Growing_Sale.Est_Sale_Date, 
										  Growing_Sale.Not_For_Sale, 
										  Growing_Sale.Forward_Orders, 
										  Growing_Sale.Date_Planted, 
										  Growing_Sale.Date_Budded, 
										  Growing_Sale.Growing_Comm
										FROM 
										  Growing_Sale, 
										  Location  
										WHERE 
										  Growing_Sale.Stock_Item_No = :1 AND 
										  Growing_Sale.Year_Of_Sale = :2 AND 
										  Growing_Sale.Location_Id = :3 AND 
										  Growing_Sale.Location_Id = Location.Location_Id 
										ORDER BY 
										  Location.Farm_Name, 
										  Location.Row#, 
										  Location.Seq#  "
								Set sNAMERefreshHandle = 'REFITMGRLOC'
								Set sBINDRefreshHandle = ':hWndParent.clsfrmItemGrowingLocations.nItemNo, :hWndParent.dfYearOfSale, :clsfrmItemGrowingLocations.tblGrowingLocations.colLocationId'
								Set sINTORefreshHandle = ':clsfrmItemGrowingLocations.tblGrowingLocations.colLocationId,  
										:clsfrmItemGrowingLocations.tblGrowingLocations.colFarmId, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colRowNo, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colSeqNo, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colBudCount, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colFirstCount,
										:clsfrmItemGrowingLocations.tblGrowingLocations.colSecondCount, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colEstSaleDate,
										:clsfrmItemGrowingLocations.tblGrowingLocations.colNotForSale, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colForwardOrder, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colPlanted, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colBudded, 
										:clsfrmItemGrowingLocations.tblGrowingLocations.colComments'
								!
								Set sSQLInsertHandle = ''
								Set sNAMEInsertHandle = ''
								Set sBINDInsertHandle = ''
								Set sINTOInsertHandle = ''
								!
								Set sSQLUpdateHandle = ''
								Set sNAMEUpdateHandle = ''
								Set sBINDUpdateHandle = ''
								Set sINTOUpdateHandle = ''
								!
								Set sSQLDeleteHandle = ''
								Set sNAMEDeleteHandle = ''
								Set sBINDDeleteHandle = ''
								!
								Set bAddAllowed = FALSE
								Set bSaveAllowed = FALSE
								Set bDeleteAllowed = FALSE
								Set bUnDeleteAllowed = FALSE
								Set bRepopulateAllowed = TRUE
								Set bClearSelectAllowed = TRUE
								Set bQueryAllowed = FALSE
								Set bReportAllowed = FALSE
								Set bOrderAllowed = TRUE
							On PAM_clsTBL_POPULATE
								Call SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
								Call SalSendMsg( hWndForm, PAM_clsITMGRLOC_CALCTOTALGROWING, wParam, lParam )
								If cbShowTotalsByFarm
									Call SalSendMsg( cbShowTotalsByFarm, PAM_clsCB_CLICK, TRUE, 0 )
								Return TRUE
							On PAM_clsTBL_SEARCH
								Call SalSendClassMessage( PAM_clsTBL_SEARCH, wParam, lParam )
								Return SalSendMsg( hWndForm, PAM_clsITMGRLOC_CALCTOTALGROWING, wParam, lParam )
							On PAM_clsITMGRLOC_CALCTOTALGROWING
								Set hWndParent.dfTotalGrowing = 0
								Return TableLoop( hWndForm, hWndForm, PAM_clsITMGRLOC_CALCGROWING, 0, 0, 0, 'Calculating Total Growing', TBL_cls_LowToHi )
							On PAM_clsITMGRLOC_CALCGROWING
								If colSecondCount != NUMBER_Null
									Set hWndParent.dfTotalGrowing = hWndParent.dfTotalGrowing + colSecondCount
								Else If colFirstCount != NUMBER_Null
									Set hWndParent.dfTotalGrowing = hWndParent.dfTotalGrowing + colFirstCount
								Else
									Set hWndParent.dfTotalGrowing = hWndParent.dfTotalGrowing + colBudCount
								Return TRUE
							On PAM_clsITMGRLOC_STOCKTYPE
								Return SalSendMsgToChildren( hWndForm, PAM_clsITMGRLOC_STOCKTYPE, wParam, lParam )
					!

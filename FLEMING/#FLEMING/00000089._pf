					Text Color: Class Default
					Background Color: Class Default
					Message Actions
						On PAM_clsPB_CLICK
							If SqlDatabase = 'STOCK'
								Set sDatabase = 'LIVE'
							Else
								Set sDatabase = 'PLAY'
							!
							When SqlError
								Call SalMessageBox( 'Error!  Please try again.','Login', MB_Ok )
							Set bOk = SqlConnect( hSqlA )
							If bOk
								Call SqlDisconnect( hSqlA )
								Call SalEndDialog( hWndForm,TRUE )
							Else
								Call SalEndDialog( hWndForm, FALSE )

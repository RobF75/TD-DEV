		Functions
		Window Parameters
			String: sStartDatabase
			String: sStartUser
		Window Variables
			Number: nConnection 
			String: sUserName 
			Number: nType
			Number: nID
			Number: nLoginTime
			Number: nRetCode
			Sql Handle: hSqlA
			Boolean: bOk
		Message Actions
			On SAM_Create
				! Set nConnection=NWGetConnectionNumber()
				! Call SalStrSetBufferLength( sUserName,20 )
				! Set nRetCode=NWGetConnectionInformation(nConnection,sUserName,nType,nID,nLoginTime)
				Call GetUser( sUserName )
				If sUserName = ''
					Call SalModalDialog( dlgDatabaseInfo, hWndForm )
					Set dfUser = SqlUser
					Set sUserName = SqlUser
				If sUserName = 'SUPERVISOR'
					Set SqlUser = 'SYSADM'
					Set SqlPassword = 'DANI'
				Else
					Set sUserName = SalStrLeftX( sUserName, 8 )
					Set SqlDatabase = ''
					Set SqlUser = sUserName
					Set SqlPassword = sUserName
				If sStartDatabase = 'STOCKDEV'
					Set rbPlay = TRUE
				Else If sStartDatabase = 'STKLOCAL'
					Set rbLocal = TRUE
				Else
					Set rbLive = TRUE
				Return SalSendClassMessage( SAM_Create, wParam, lParam )
			On SAM_CreateComplete
				If rbPlay
					Call SalSendMsg( rbPlay, SAM_Click, 0, 0 )
				Else If rbLocal
					Call SalSendMsg( rbLocal, SAM_Click, 0, 0 )
				Else
					Call SalSendMsg( rbLive, SAM_Click, 0, 0 )
				Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )

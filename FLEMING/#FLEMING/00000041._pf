			Check Box Class: clscbGeneral
				Title:
				Window Location and Size
					Left:  
					Top:   
					Width:  1.4"
					Width Editable? Class Default
					Height: 0.25"
					Height Editable? Class Default
				Visible? Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Text Color: Dark Blue
				Background Color: Gray
				List in Tool Palette? Yes
				Property Template:
				Class DLL Name:
				Description:
				Derived From
				Class Variables
					Number: nReturn
					String: sTmp
				Instance Variables
					Number: nActionOnInitialize
					! Default actions are for sFlagValue = Y or N
					String: sFlagValue
					String: sFlagValueTRUE
					String: sFlagValueFALSE
				Functions
				Message Actions
					On SAM_Create
						Set nActionOnInitialize = CB_ClearOnInit
						Set sFlagValueTRUE = 'Y'
						Set sFlagValueFALSE = 'N'
						Set sFlagValue = sFlagValueFALSE
						Call SalSendMsg( hWndItem, PAM_cls_SETINSTANCEVARS, 0, 0 ) 
						Set sTmp = OurGetIniFileParameter( 'GENERAL', GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndItem ), '' )
						If sTmp = 'TRUE'
							Set sFlagValue = sFlagValueTRUE
						Else If sTmp = 'FALSE'
							Set sFlagValue = sFlagValueFALSE
						!
						If sFlagValue = sFlagValueTRUE
							Set MyValue = TRUE
						Else
							Set MyValue = FALSE
					On SAM_Click
						If SalIsButtonChecked( hWndItem )
							Set nReturn = SalSendMsg( hWndItem, PAM_clsCB_VALIDATE, TRUE, 0 )
							If nReturn = VALIDATE_Ok OR nReturn = VALIDATE_OkClearFlag
								If nReturn = VALIDATE_OkClearFlag
									Call SalSetFieldEdit( hWndItem, FALSE )
								Set sFlagValue = sFlagValueTRUE
								Call SalSendMsg( hWndItem, PAM_clsCB_CLICK, TRUE, 0 ) 
							Else
								Set MyValue = FALSE
						Else
							Set nReturn = SalSendMsg( hWndItem, PAM_clsCB_VALIDATE, FALSE, 0 )
							If nReturn = VALIDATE_Ok OR nReturn = VALIDATE_OkClearFlag
								If nReturn = VALIDATE_OkClearFlag
									Call SalSetFieldEdit( hWndItem, FALSE )
								Set sFlagValue = sFlagValueFALSE
								Call SalSendMsg( hWndItem, PAM_clsCB_CLICK, FALSE, 0 ) 
							Else
								Set MyValue = TRUE
					On PAM_clsCB_VALIDATE
						Return VALIDATE_Ok
					On PAM_clsCB_SET
						! Use wParam to set the check box TRUE OR FALSE
						Set MyValue = wParam
						Return SalSendMsg( hWndItem, SAM_Click, 0, 0 )
					!
					On PAM_cls_INITIALISE
						Select Case nActionOnInitialize
							Case CB_ClearOnInit
								Call SalSendMsg( hWndItem, PAM_clsCB_CLEAR, 0, 0 )
								Break
							Case CB_DisableOnInit
								Call SalSendMsg( hWndItem, PAM_clsCB_DISABLE, 0, 0 )
								Break
							Case CB_EnableOnInit
								Call SalSendMsg( hWndItem, PAM_clsCB_ENABLE, 0, 0 )
								Break
							Case CB_HideOnInit
								Call SalSendMsg( hWndItem, PAM_clsCB_HIDE, 0, 0 )
								Break
							Case CB_ShowOnInit
								Call SalSendMsg( hWndItem, PAM_clsCB_SHOW, 0, 0 )
								Break
					!
					On PAM_clsCB_DISABLE
						Return SalDisableWindow( hWndItem )
					On PAM_clsCB_ENABLE
						Return SalEnableWindow( hWndItem )
					On PAM_clsCB_HIDE
						Return SalHideWindow( hWndItem )
					On PAM_clsCB_SHOW
						Return SalShowWindow( hWndItem )
					On PAM_clsCB_CLEAR
						Set sFlagValue = sFlagValueFALSE
						Return SalClearField( hWndItem )
					!
					On WM_RBUTTONDBLCLK
						Call SalGetWindowText( hWndItem, sTmp, 60 )
						If SalIsButtonChecked( hWndItem )
							Call OurSetIniFileParameter( 'GENERAL', GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndItem ), 'TRUE' )
							Call SalMessageBox( 'Default for this screen is set to ON', sTmp, MB_Ok )
						Else
							Call OurSetIniFileParameter( 'GENERAL', GetFullItemName( SalParentWindow( hWndForm ), hWndForm, hWndItem ), 'FALSE' )
							Call SalMessageBox( 'Default for this screen is set to OFF', sTmp, MB_Ok )

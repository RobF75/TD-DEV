		Named Menus
		Internal Functions
			Function: DisplayHelp
				Description:
				Returns
					Boolean:
				Parameters
					Window Handle: hWnd
				Static Variables
				Local variables
					String: sHelpFileName
				Actions
					If ExtractHelpFileName( hWnd, sHelpFileName )
						Set sHelpFileName = OurGetIniFileParameter( 'GENERAL', 'HelpStoragePath', '' ) || '\\' || sHelpFileName
						Call SalMessageBox( 'Loading.. '||sHelpFileName, 'Help', MB_Ok )
						Return TRUE
					Else
						Return FALSE
			Function: ExtractHelpFileName
				Description:
				Returns
					Boolean:
				Parameters
					Window Handle: hWnd
					Receive String: sHelpFileName
				Static Variables
				Local variables
					String: sTemplet
					Number: nPos
					Number: nTempletLength
					Number: nNum
				Actions
					If SalGetItemName( hWnd, sTemplet )
						Set sHelpFileName = ''
						Set nTempletLength = SalStrLength( sTemplet )
						Set nNum = 0
						Set nPos = 1
						While nPos <= nTempletLength
							Set nNum = nNum + SalStrLop( sTemplet ) * nPos
							Set nPos = nPos + 1
						Set sHelpFileName = SalNumberToStrX( nNum, 0 ) || '.hlp'
						Return TRUE
					Else
						Return FALSE
			Function: OurGetIniFileParameter
				Description: sGeneralOrAccounts = 'GENERAL' OR 'ACCOUNTS' exact strings only.
						sEntry = 'Customer' is the name of the program eg  Customer='g:\apps\....'
						sDefalt is what to return if entry cannot be found.
				Returns
					String:
				Parameters
					String: sGeneralOrAccounts
					String: sEntry
					String: sDefault
				Static Variables
				Local variables
					String: sValue
					String: sSection
				Actions
					Set sValue = ''
					If SqlDatabase = 'STOCK'
						If sGeneralOrAccounts = 'GENERAL'
							Set sSection = IniGeneralLiveSectionName
						Else
							Set sSection = IniAccountsLiveSectionName
					Else
						If sGeneralOrAccounts = 'GENERAL'
							Set sSection = IniGeneralPlaySectionName
						Else
							Set sSection = IniAccountsPlaySectionName
					Call SalGetProfileString( sSection, sEntry, sDefault, sValue, FlemSysIniFileName )
					Return sValue
			Function: OurSetIniFileParameter
				Description: sGeneralOrAccounts = 'GENERAL' OR 'ACCOUNTS' exact strings only.
						sEntry = 'Customer' is the name of the program eg  Customer='g:\apps\....'
						sValue is the entry value.
				Returns
					Boolean:
				Parameters
					String: sGeneralOrAccounts
					String: sEntry
					String: sValue
				Static Variables
				Local variables
					String: sSection
				Actions
					If SqlDatabase = 'STOCK'
						If sGeneralOrAccounts = 'GENERAL'
							Set sSection = IniGeneralLiveSectionName
						Else
							Set sSection = IniAccountsLiveSectionName
					Else
						If sGeneralOrAccounts = 'GENERAL'
							Set sSection = IniGeneralPlaySectionName
						Else
							Set sSection = IniAccountsPlaySectionName
					Return SalSetProfileString( sSection, sEntry, sValue, FlemSysIniFileName )
			Function: ValidateUserRightsList
				Description:
				Returns
					Boolean:
				Parameters
					String: sValidUsers
					String: sUser
					Boolean: bNotify
				Static Variables
				Local variables
				Actions
					If SalStrScan( sValidUsers, sUser ) = -1
						If bNotify
							Call SalMessageBox( 'Your access rights are not sufficient.', 'Warning', MB_Ok )
						Return FALSE
					Else
						Return TRUE
			Function: IsUserAccounts
				Description:
				Returns
					Boolean:
				Parameters
					String: sUserId
					Boolean: bNotify
				Static Variables
				Local variables
					String: sAccountsUsers
				Actions
					Set sAccountsUsers = OurGetIniFileParameter( 'ACCOUNTS', 'AccountsUsers', '' )
					Return ValidateUserRightsList( sAccountsUsers, sUserId, bNotify )
			Function: IsUserAdmin
				Description:
				Returns
					Boolean:
				Parameters
					String: sUserId
					Boolean: bNotify
				Static Variables
				Local variables
					String: sAdminUsers
				Actions
					Set sAdminUsers = OurGetIniFileParameter( 'ACCOUNTS', 'SystemAdministrators', '' )
					Return ValidateUserRightsList( sAdminUsers, sUserId, bNotify )
			Function: IsUserStockController
				Description:
				Returns
					Boolean:
				Parameters
					String: sUserId
					Boolean: bNotify
				Static Variables
				Local variables
					String: sStockControllers
				Actions
					Set sStockControllers = OurGetIniFileParameter( 'GENERAL', 'StockControllers', '' )
					Return ValidateUserRightsList( sStockControllers, sUserId, bNotify )
			Function: CheckProgramExistance
				Description:
				Returns
				Parameters
					String: sStartupWindowHeading
					Boolean: bCheckDatabaseInfo
				Static Variables
				Local variables
					Window Handle: hWndTmp
				Actions
					Set hWndTmp = FindWindowA( 0, sStartupWindowHeading )
					If hWndTmp
						Call SalBringWindowToTop( hWndTmp )
						! Maximize the window
						Call ShowWindow( hWndTmp, 3 )
						Call SalMessageBeep( 1 )
						Call SalQuit(  )
					Else
						If bCheckDatabaseInfo AND SqlDatabase = ''
							If NOT SalModalDialog( dlgDatabaseInfo, hWndNULL )
								Call SalQuit(  )
			Function: OurWaitCursor  
				Description:
				Returns
				Parameters
					Boolean: bOn  
				Static Variables
				Local variables
				Actions
					Call OurWaitCursorOverride( bOn, FALSE )
			Function: OurWaitCursorOverride  
				Description:
				Returns
				Parameters
					Boolean: bOn  
					Boolean: bOverride  
				Static Variables
					Number: nWaitCount  
					Boolean: bOverriden  
				Local variables
				Actions
					If bOverride
						If bOn
							Call SalWaitCursor( TRUE )
						Else
							Call SalWaitCursor( FALSE )
						Set bOverriden = TRUE
					Else
						If bOn
							If NOT nWaitCount > 0 OR bOverriden
								Call SalWaitCursor( TRUE )
								Set bOverriden = FALSE
							Set nWaitCount = nWaitCount + 1
						Else
							Set nWaitCount = nWaitCount - 1
							If NOT nWaitCount > 0 OR bOverriden
								Call SalWaitCursor( FALSE )
								Set bOverriden = FALSE
			Function: OurMapEnterToTab  
				Description:
				Returns
				Parameters
					Boolean: bOn  
				Static Variables
					Number: nCount  
				Local variables
				Actions
					If bOn
						If NOT nCount > 0
							Call SalMapEnterToTab( TRUE )
						Set nCount = nCount + 1
					Else
						Set nCount = nCount - 1
						If NOT nCount > 0
							Call SalMapEnterToTab( FALSE )
			Function: RoundTo2Decimals  
				Description:
				Returns
					Number:
				Parameters
					Number: nNumber  
				Static Variables
				Local variables
				Actions
					Return SalNumberTruncate( ( nNumber + 0.005 ), 10, 2 )
			Function: GetFullItemName
				Description: Gets full item name eg frmCust.tblCust.colCustNo.
						If parameter is null then it is ignored
				Returns
					String:
				Parameters
					Window Handle: hWndParnt
					Window Handle: hWndFrm
					Window Handle: hWndItm
				Static Variables
				Local variables
					String: sFullItmName
					String: sItmName
				Actions
					If hWndItm = hWndNULL
						Set sItmName = ''
						Set sFullItmName = sItmName
					Else
						Call SalGetItemName( hWndItm, sItmName )
						Set sFullItmName = sItmName
					If hWndFrm = hWndNULL
						Set sItmName = ''
					Else
						Call SalGetItemName( hWndFrm, sItmName )
						Set sFullItmName = sItmName || '.' || sFullItmName
					If hWndParnt = hWndNULL
						Set sItmName = ''
					Else
						Call SalGetItemName( hWndParnt, sItmName )
						Set sFullItmName = sItmName || '.' || sFullItmName
					Return sFullItmName

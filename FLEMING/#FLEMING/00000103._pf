.head 7 +  Function: GetPurchOrdUser
.head 8 -  Description: 
.head 8 +  Returns 
.head 9 -  Boolean: 
.head 8 +  Parameters 
.head 9 -  String: sPONo
.head 9 -  Receive String: sIssuedTo
.head 9 -  Number: nActionType

				Derived From
				Class Variables
					Number: nTmp
					String: sTmp
					Date/Time: dtTmp
					Window Handle: hWndTmp
					Number: nReturn
				Instance Variables
					Number: nDialogType
					Number: nActionOnExit
					String: sHelpFileName
					Boolean: bMapEnterToTab
					Boolean: bPrintFormAllowed
					Boolean: bTreeSystem
				Functions
				Message Actions
					On SAM_Create
						Call OurWaitCursor( TRUE )
						Set nDialogType = DLG_Modal
						Set nActionOnExit = DLG_EndOnExit
						Set sHelpFileName = ''
						Set bMapEnterToTab = FALSE
						Set bPrintFormAllowed = FALSE
						Set bTreeSystem = TRUE
						Call SalSendMsg( hWndForm, PAM_clsDLG_POPFIELDS, 0, 0 )
						Call SalSendMsg( hWndForm, PAM_cls_SETINSTANCEVARS, 0, 0 )
						If NOT bPrintFormAllowed
							Call SalSendMsg( pbPrintForm, PAM_clsPB_HIDE, 0, 0 )
						If NOT bTreeSystem
							Call SalSendMsgToChildren( hWndForm, PAM_clsDLG_NOTTREESYS, 0, 0 )
					On SAM_CreateComplete
						If bMapEnterToTab
							Call OurMapEnterToTab( TRUE )
						Call OurWaitCursor( FALSE )
					On SAM_Destroy
						If nActionOnExit = FRM_EndOnExit
							Return SalSendMsg( hWndForm, PAM_cls_DESTROY, 0, 0 )
					On PAM_cls_DESTROY
						If bMapEnterToTab
							Call OurMapEnterToTab( FALSE )
						If SalParentWindow( hWndForm )
							Call SalSendMsg( SalParentWindow( hWndForm ), PAM_cls_PARENTACTIVATE, 0, 0 )
						Return TRUE
					On SAM_Close
						Set nReturn = SalSendMsg( hWndForm, PAM_cls_EXIT, 0, 0 )
						If nReturn = PB_ExitHideWindow
							Call SalHideWindow( hWndForm )
							Return FALSE
					On PAM_cls_CLOSE
						Set nReturn =  SalSendMsg( hWndForm, PAM_cls_EXIT, wParam, lParam )
						If nReturn = PB_ExitDestroyWindow
							Return SalDestroyWindow( hWndForm )
						Else If nReturn = PB_ExitEndDialog
							Return SalEndDialog( hWndForm, wParam )
						Else If nReturn = PB_ExitHideWindow
							Return SalHideWindow( hWndForm )
					On PAM_cls_PARENTACTIVATE
						Call SalShowWindow( hWndForm )
						Call SalBringWindowToTop( hWndForm )
					On SAM_Activate
						Call SalSendMsgToChildren( hWndForm, PAM_clsDLG_ACTIVATE, wParam, lParam )
					On PAM_cls_EXIT
						Call SalSendMsg( hWndForm, PAM_clsDLG_PUSHFIELDS, 0, 0 )
						Call SalSendMsg( SalParentWindow( hWndForm ), PAM_clsDLG_RETURN, 0, SalWindowHandleToNumber( hWndForm ) )
						If nDialogType = DLG_Modal
							Return PB_ExitEndDialog
						Else If nActionOnExit = DLG_EndOnExit
							Return PB_ExitDestroyWindow
						Else
							Return PB_ExitHideWindow
					On PAM_cls_HELP
						Return DisplayHelp( hWndForm )
					On PAM_clsDLG_SHOW
						Call SalSendMsg( hWndForm, PAM_clsDLG_POPFIELDS, 0, 0 )
						Return SalShowWindow( hWndForm )

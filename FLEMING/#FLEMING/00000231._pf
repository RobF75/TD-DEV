					Message Actions
						On PAM_clsPB_CLICK
							If SalSendMsg( tblFutureIncEstAvailDates, PAM_GETSELECTEDDATES, 0, 0 )
								Call PopString( sSelectedDateList, TRUE )
							Else
								Call SalMessageBox( 'Please enter some dates first.', 'Warning', MB_Ok )
								Return FALSE
							!
							If rbView
								Set sReportType = 'VIEW'
							Else
								Set sReportType = 'PRINT'
							!
							If hWndReport = hWndNULL
								Set hWndReport = SalCreateWindow( frmPrintStockAtDate, hWndForm, sSelectedDateList, sReportType )
								Return TRUE
							Else
								Call SalMessageBox( 'Please close down your first report!', 'Warning', MB_Ok )
								Return FALSE

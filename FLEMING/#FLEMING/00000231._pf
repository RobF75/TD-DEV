			Contents
		Contents
		Functions
		Window Parameters
			! sSelectedDateList is a comma separated list of dates
			String: sSelectedDateList
			! sReportPrintOrView = 'VIEW' OR 'PRINT'
			String: sReportPrintOrView
		Window Variables
			! REPORT FIELDS
			Number: nItemNo
			String: sUpperVarietyType
			String: sUpperVariety
			String: sUpperCultDesc
			String: sUpperRootDesc
			String: sUpperTreeTypeDesc
			String: sTreeTypeDesc
			String: sCultDesc
			String: sRootDesc
			String: sFarmName
			Number: nRowNo
			Number: nSeqNo
			Number: nSecondCount
			Date/Time: dtEstSaleDate
		Message Actions
			On PAM_cls_SETINSTANCEVARS
				Set sReportFileNameNoPath = 'prtstkatdate.qrp'
				!
				Set sReportBind = ':frmPrintStockAtDate.nItemNo,
						:frmPrintStockAtDate.sUpperVarietyType,
						:frmPrintStockAtDate.sUpperVariety,
						:frmPrintStockAtDate.sUpperCultDesc,
						:frmPrintStockAtDate.sUpperRootDesc,
						:frmPrintStockAtDate.sUpperTreeTypeDesc,
						:frmPrintStockAtDate.sTreeTypeDesc,
						:frmPrintStockAtDate.sCultDesc,
						:frmPrintStockAtDate.sRootDesc,
						:frmPrintStockAtDate.sFarmName, 
						:frmPrintStockAtDate.nRowNo, 
						:frmPrintStockAtDate.nSeqNo, 
						:frmPrintStockAtDate.nSecondCount,
						:frmPrintStockAtDate.dtEstSaleDate'
				Set sReportInto = 'nItemNo,
						sUpperVarietyType,
						sUpperVariety,
						sUpperCultDesc,
						sUpperRootDesc,
						sUpperTreeTypeDesc,
						sTreeTypeDesc,
						sCultDesc,
						sRootDesc,
						sFarmName, 
						nRowNo, 
						nSeqNo, 
						nSecondCount,
						dtEstSaleDate'
				Set sReportSql = " select 
						  stock_item.item_no, 
						  @UPPER( stock_item.variety_type ), 
						  @UPPER( stock_item.variety ), 
						  @UPPER( stock_item.cult_desc ), 
						  @UPPER( stock_item.root_desc ), 
						  @UPPER( stock_item.tree_type_desc ), 
						  stock_item.tree_type_desc, 
						  stock_item.cult_desc, 
						  stock_item.root_desc, 
						  location.farm_name, 
						  location.row#, 
						  location.seq#, 
						  growing_sale.second_count, 
						  growing_sale.est_sale_date
						from 
						  stock_item, 
						  growing_sale, 
						  location 
						into 
						  :frmPrintStockAtDate.nItemNo,
						  :frmPrintStockAtDate.sUpperVarietyType,
						  :frmPrintStockAtDate.sUpperVariety,
						  :frmPrintStockAtDate.sUpperCultDesc,
						  :frmPrintStockAtDate.sUpperRootDesc,
						  :frmPrintStockAtDate.sUpperTreeTypeDesc, 
						  :frmPrintStockAtDate.sTreeTypeDesc,
						  :frmPrintStockAtDate.sCultDesc,
						  :frmPrintStockAtDate.sRootDesc,
						  :frmPrintStockAtDate.sFarmName, 
						  :frmPrintStockAtDate.nRowNo, 
						  :frmPrintStockAtDate.nSeqNo, 
						  :frmPrintStockAtDate.nSecondCount,
						  :frmPrintStockAtDate.dtEstSaleDate
						where 
						  stock_item.item_no = growing_sale.stock_item_no and 
						  growing_sale.location_id = location.location_id and 
						  growing_sale.est_sale_date in ( " || sSelectedDateList || " ) 
						order by 
						  10,11,12,2,3,4,5,6 "
				Set sReportType = sReportPrintOrView

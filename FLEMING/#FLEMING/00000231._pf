					On PAM_GETSELECTEDDATES
						Set sDateList = ''
						If TableLoop( hWndForm, hWndForm, PAM_GETSELECTED, 0, 0, 0, 'Extracting Selected Items', TBL_cls_LowToHi )
							Call PushString( sDateList )
							Return TRUE
						Else
							Return FALSE
					On PAM_GETSELECTED
						If sDateList = ''
							Set sDateList = DateToStrX( colEstAvailDate )
						Else
							Set sDateList = sDateList || ', ' || DateToStrX( colEstAvailDate )
						Return TRUE
			!

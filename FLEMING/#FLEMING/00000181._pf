		Application Actions
			On SAM_AppStartup
				If SalStrUpperX( SalStrRightX( strArgArray[0],3 ) ) = 'EXE'
					Set SqlDatabase = strArgArray[1]
					Set SqlUser = strArgArray[2]
					Set SqlPassword = strArgArray[3]
				Else
					Set SqlDatabase = 'STOCK'
					Set SqlUser = 'GRAHAM'
					Set SqlPassword = 'GRAHAM'
				!
				Call SqlHandlesSetup(  )
				!
				Call CheckProgramExistance( "Fleming's Nurseries System Version Control Module", TRUE )
				!
				Call SalModalDialog( dlgVersionControl, hWndNULL )
			On SAM_AppExit
				Call SqlHandlesDisconnectClose(  )

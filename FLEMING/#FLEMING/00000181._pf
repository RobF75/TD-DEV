		Functions
			Function: ProgramVersionControl
				Description:
				Returns
				Parameters
					Window Handle: hWndUpdate
				Static Variables
				Local variables
					!
					Number: nTotalFiles
					Number: nDoneFiles
					String: sCopyFileFrom
					String: sCopyFileTo
					!
					String: sLocalDeployPath
					String: sServerDeployOriginPath
					String: sAdditionalLocalEXEsAllowed
					!
					Number: nNumLocalFiles
					String: saLocalFiles[*]
					Number: naLocalSizes[*]
					Date/Time: dtaLocalTimeStamps[*]
					Number: naLocalAttributes[*]
					!
					Number: nNumServerFiles
					String: saServerFiles[*]
					Number: naServerSizes[*]
					Date/Time: dtaServerTimeStamps[*]
					Number: naServerAttributes[*]
					!
					Number: nCount
					Number: nFoundPos
					!
					Number: nFileCopyCount
					String: saCopyFileFrom[*]
					Date/Time: dtaCopyFileFromDT[*]
					String: saCopyFileTo[*]
				Actions
					!
					Set sLocalDeployPath = OurGetIniFileParameter( 'GENERAL', 'ClientDeployEXEPath', 'c:\\Centura\\localexe' )
					Set sServerDeployOriginPath = OurGetIniFileParameter( 'GENERAL', 'ServerDeployEXEPath', 'k:\\Centura\\remotupd' )
					Set sAdditionalLocalEXEsAllowed = OurGetIniFileParameter( 'GENERAL', 'AdditionalLocalEXEsAllowed', '1' )
					!
					Set sLocalDeployPath = SalStrTrimX( sLocalDeployPath )
					Set sServerDeployOriginPath = SalStrTrimX( sServerDeployOriginPath )
					!
					Set nNumServerFiles = VisDosEnumFileInfo( sServerDeployOriginPath || '\\*.*' , FA_Standard, saServerFiles, naServerSizes, dtaServerTimeStamps, naServerAttributes )
					Call ConvertStrArrayToUpper( saServerFiles, nNumServerFiles )
					!
					Set nNumLocalFiles = VisDosEnumFileInfo( sLocalDeployPath || '\\*.*', FA_Standard, saLocalFiles, naLocalSizes, dtaLocalTimeStamps, naLocalAttributes )
					Call ConvertStrArrayToUpper( saLocalFiles, nNumLocalFiles )
					!
					!
					Set nFileCopyCount = 0
					Set saCopyFileFrom[ nFileCopyCount ] = ''
					Set dtaCopyFileFromDT[ nFileCopyCount ] = DATETIME_Null
					Set saCopyFileTo[ nFileCopyCount ] = ''
					!
					Set nCount = 0
					While nCount < nNumLocalFiles
						!
						If StrArrayFind( saServerFiles, nNumServerFiles, saLocalFiles[ nCount ], nFoundPos )
							If dtaServerTimeStamps[ nFoundPos ] != dtaLocalTimeStamps[ nCount ] OR naServerSizes[ nFoundPos ] != naLocalSizes[ nCount ]
								Set saCopyFileFrom[ nFileCopyCount ] = sServerDeployOriginPath || '\\' || saServerFiles[ nFoundPos ]
								Set saCopyFileTo[ nFileCopyCount ] = sLocalDeployPath || '\\' || saLocalFiles[ nCount ]
								Set dtaCopyFileFromDT[ nFileCopyCount ] = dtaServerTimeStamps[ nFoundPos ]
								Set nFileCopyCount = nFileCopyCount + 1
								Set saCopyFileFrom[ nFileCopyCount ] = ''
								Set saCopyFileTo[ nFileCopyCount ] = ''
								Set dtaCopyFileFromDT[ nFileCopyCount ] = DATETIME_Null
						!
						Set nCount = nCount + 1
					!
					If sAdditionalLocalEXEsAllowed = '1'
						Set nCount = 0
						While nCount < nNumServerFiles
							!
							If NOT StrArrayFind( saLocalFiles, nNumLocalFiles, saServerFiles[ nCount ], nFoundPos )
								Set saCopyFileFrom[ nFileCopyCount ] = sServerDeployOriginPath || '\\' || saServerFiles[ nCount ]
								Set saCopyFileTo[ nFileCopyCount ] = sLocalDeployPath || '\\' || saServerFiles[ nCount ]
								Set dtaCopyFileFromDT[ nFileCopyCount ] = dtaServerTimeStamps[ nCount ]
								Set nFileCopyCount = nFileCopyCount + 1
								Set saCopyFileFrom[ nFileCopyCount ] = ''
								Set saCopyFileTo[ nFileCopyCount ] = ''
								Set dtaCopyFileFromDT[ nFileCopyCount ] = DATETIME_Null
							!
							Set nCount = nCount + 1
					!
					Set nTotalFiles = nFileCopyCount
					Set nDoneFiles = 0
					!
					Set nCount = 0
					While saCopyFileFrom[ nCount ] != ''
						!
						Set sCopyFileFrom = saCopyFileFrom[ nCount ]
						Set sCopyFileTo = saCopyFileTo[ nCount ]
						!
						Call PushNumber( nTotalFiles )
						Call PushNumber( nDoneFiles )
						Call PushString( sCopyFileFrom )
						Call PushString( sCopyFileTo )
						If NOT SalSendMsg( hWndUpdate, PAM_cls_SETFIELDS, 0, 0 )
							Call PopString( sCopyFileTo, TRUE )
							Call PopString( sCopyFileFrom, TRUE )
							Call PopNumber( nDoneFiles, TRUE )
							Call PopNumber( nTotalFiles, TRUE )
						Call VisFileCopy( sCopyFileFrom, sCopyFileTo )
						! If VisFileCopy( sCopyFileFrom, sCopyFileTo )
							          Call VisFileSetDateTime( sCopyFileTo, dtaCopyFileFromDT[ nCount ] )
						!
						Set nCount = nCount + 1
						Set nDoneFiles = nDoneFiles + 1
					!
			!
			Function: CSVFilingControl
				Description:
				Returns
				Parameters
					Window Handle: hWndUpdate
				Static Variables
				Local variables
					: fcMeter
						Class: clsMeterBar
					!
					Number: nTotalFiles
					Number: nDoneFiles
					String: sCopyFileFrom
					String: sCopyFileTo
					!
					Number: nProcessingNo
					!
					String: sFromPath
					Number: nNumLocalFiles
					String: saLocalFiles[*]
					Number: naLocalSizes[*]
					Date/Time: dtaLocalTimeStamps[*]
					Number: naLocalAttributes[*]
					!
					Number: nCount
					Number: nTmp
					!
					Number: nFileCopyCount
					String: saCopyFileFrom[*]
					String: saCopyFileTo[*]
				Actions
					Set nFileCopyCount = 0
					Set saCopyFileFrom[ nFileCopyCount ] = ''
					Set saCopyFileTo[ nFileCopyCount ] = ''
					!
					Set nProcessingNo = 0
					While nProcessingNo < 8
						!
						Select Case nProcessingNo
							Case 0
								Set sFromPath = SalStrTrimX( OurGetIniFileParameter( 'ACCOUNTS', 'InvoicesCSVPath', 'c:\\temp' ) )
								Break
							Case 1
								Set sFromPath = SalStrTrimX( OurGetIniFileParameter( 'ACCOUNTS', 'CRNotesCSVPath', 'c:\\temp' ) )
								Break
							Case 2
								Set sFromPath = SalStrTrimX( OurGetIniFileParameter( 'ACCOUNTS', 'StatementsCSVPath', 'c:\\temp' ) )
								Break
							Case 3
								Set sFromPath = SalStrTrimX( OurGetIniFileParameter( 'ACCOUNTS', 'ConfsCSVPath', 'c:\\temp' ) )
								Break
							Case 4
								Set sFromPath = SalStrTrimX( OurGetIniFileParameter( 'ACCOUNTS', 'NPAsCSVPath', 'c:\\temp' ) )
								Break
							Case 5
								Set sFromPath = SalStrTrimX( OurGetIniFileParameter( 'ACCOUNTS', 'AcksCSVPath', 'c:\\temp' ) )
								Break
							Case 6
								Set sFromPath = SalStrTrimX( OurGetIniFileParameter( 'ACCOUNTS', 'RcptsCSVPath', 'c:\\temp' ) )
								Break
							Case 7
								Set sFromPath = SalStrTrimX( OurGetIniFileParameter( 'ACCOUNTS', 'PRCsCSVPath', 'c:\\temp' ) )
								Break
						!
						Set nNumLocalFiles = VisDosEnumFileInfo( sFromPath || '\\c*.*', FA_Standard, saLocalFiles, naLocalSizes, dtaLocalTimeStamps, naLocalAttributes )
						Select Case nProcessingNo
							Case 0
								Call fcMeter.Setup( 'Extracting Invoice CSV files.', nNumLocalFiles )
								Break
							Case 1
								Call fcMeter.Reset( 'Extracting Credit Note CSV files.', nNumLocalFiles )
								Break
							Case 2
								Call fcMeter.Reset( 'Extracting Statement CSV files.', nNumLocalFiles )
								Break
							Case 3
								Call fcMeter.Reset( 'Extracting Confirmation CSV files.', nNumLocalFiles )
								Break
							Case 4
								Call fcMeter.Reset( 'Extracting NPA CSV files.', nNumLocalFiles )
								Break
							Case 5
								Call fcMeter.Reset( 'Extracting Acknowledgment CSV files.', nNumLocalFiles )
								Break
							Case 6
								Call fcMeter.Reset( 'Extracting Receipts CSV files.', nNumLocalFiles )
								Break
							Case 7
								Call fcMeter.Reset( 'Extracting PRC CSV files.', nNumLocalFiles )
								Break
						Call ConvertStrArrayToUpper( saLocalFiles, nNumLocalFiles )
						!
						Set nCount = 0
						While nCount < nNumLocalFiles
							!
							Set saCopyFileFrom[ nFileCopyCount ] = sFromPath || '\\' || saLocalFiles[ nCount ]
							Set saCopyFileTo[ nFileCopyCount ] = ExtractToPath( nProcessingNo, saLocalFiles[ nCount ] ) || '\\' || saLocalFiles[ nCount ]
							Set nFileCopyCount = nFileCopyCount + 1
							Set saCopyFileFrom[ nFileCopyCount ] = ''
							Set saCopyFileTo[ nFileCopyCount ] = ''
							Call fcMeter.Increment( 1 )
							!
							Set nCount = nCount + 1
						!
						Set nProcessingNo = nProcessingNo + 1
					Call fcMeter.End( )
					!
					Set nTotalFiles = nFileCopyCount
					Set nDoneFiles = 0
					!
					Set nCount = 0
					While saCopyFileFrom[ nCount ] != ''
						!
						Set sCopyFileFrom = saCopyFileFrom[ nCount ]
						Set sCopyFileTo = saCopyFileTo[ nCount ]
						!
						Call PushNumber( nTotalFiles )
						Call PushNumber( nDoneFiles )
						Call PushString( sCopyFileFrom )
						Call PushString( sCopyFileTo )
						If NOT SalSendMsg( hWndUpdate, PAM_cls_SETFIELDS, 0, 0 )
							Call PopString( sCopyFileTo, TRUE )
							Call PopString( sCopyFileFrom, TRUE )
							Call PopNumber( nDoneFiles, TRUE )
							Call PopNumber( nTotalFiles, TRUE )
						If VisFileCopy( sCopyFileFrom, sCopyFileTo )
							Call VisFileDelete( sCopyFileFrom )
							! Call VisFileSetAttribute( sCopyFileFrom, FA_Archive, FALSE )
						!
						Set nCount = nCount + 1
						Set nDoneFiles = nDoneFiles + 1
			Function: ExtractToPath
				Description:
				Returns
					String:
				Parameters
					Number: nProcessingNo
					String: sFileName
				Static Variables
				Local variables
					String: sToPath
					Number: nCustNo
					Number: nYear
					String: sInvCredNo
					String: sQrpFileName
					String: sFileType
				Actions
					Set sToPath = ''
					!
					Select Case nProcessingNo
						Case 0
							Call TokenCustInvoiceCSVFileName( sFileName, nCustNo, nYear, sInvCredNo, sQrpFileName, sFileType )
							Break
						Case 1
							Call TokenCustCreditNoteCSVFileName( sFileName, nCustNo, nYear, sInvCredNo, sQrpFileName, sFileType )
							Break
						Case 2
							Call TokenCustStatementCSVFileName( sFileName, nCustNo, nYear, sQrpFileName, sFileType )
							Break
						Case 3
							Call TokenCustConfCSVFileName( sFileName, nCustNo, nYear, sQrpFileName, sFileType )
							Break
						Case 4
							Call TokenCustNPACSVFileName( sFileName, nCustNo, nYear, sQrpFileName, sFileType )
							Break
						Case 5
							Call TokenCustAckCSVFileName( sFileName, nCustNo, nYear, sQrpFileName, sFileType )
							Break
						Case 6
							Call TokenCustRcpCSVFileName( sFileName, nCustNo, nYear, sQrpFileName, sFileType )
							Break
						Case 7
							Call TokenCustPRCCSVFileName( sFileName, nCustNo, nYear, sQrpFileName, sFileType )
							Break
					!
					Call CreateCustStructure( nCustNo )
					Set sToPath =  GetCustCSVFileStructurePath( nCustNo, sFileType )
					Return sToPath
			!
			Function: ConvertStrArrayToUpper
				Description:
				Returns
				Parameters
					Receive String: saLocalFiles[*]
					Number: nTotalCount
				Static Variables
				Local variables
					Number: nCount
				Actions
					Set nCount = 0
					While nCount < nTotalCount
						Set saLocalFiles[ nCount ] = SalStrUpperX( saLocalFiles[ nCount ] )
						Set nCount = nCount + 1
		Window Parameters
		Window Variables
		Message Actions
			On SAM_Create
				Call SalSendMsg( pbExit, PAM_clsPB_DISABLE, 0, 0 )
				Return SalSendClassMessage( SAM_Create, wParam, lParam )
			On SAM_Close
				Return FALSE
			On SAM_CreateComplete
				Call OurWaitCursor( TRUE )
				Call SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
				!
				Call ProgramVersionControl( hWndForm )
				Call CSVFilingControl( hWndForm )
				!
				Call OurWaitCursor( FALSE )
				Call SalSendMsg( pbExit, SAM_Click, 0, 0 )
			On PAM_cls_SETFIELDS
				Call PopString( dfCopyFileTo, TRUE )
				Call PopString( dfCopyFileFrom, TRUE )
				Call PopNumber( dfDoneFiles, TRUE )
				Call PopNumber( dfTotalFiles, TRUE )
				Call SalUpdateWindow( hWndForm )
				Return TRUE

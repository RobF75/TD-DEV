		Named Menus
		Internal Functions
			! Function: GetStrJulianDate
				   Description: 
				   Returns 
					   String: 
				   Parameters 
					   Date/Time: dtDate
				   Static Variables 
				   Local variables 
				   Actions 
					   Return SalNumberToStrX( dtDate - SalDateYearBegin( dtDate ) + 1, 0 ) || SalStrMidX( SalNumberToStrX( SalDateYear( dtDate ), 0 ), 3, 1 )
			! Function: DateMonthEnd
				   Description: Returns the last day of the month given in date/time field
				   Returns 
					   Date/Time: 
				   Parameters 
					   Date/Time: dtGivenDate
				   Static Variables 
				   Local variables 
					   Date/Time: dtTmpDate
					   Number: nDay
					   Number: nMonth
					   Number: nYear
				   Actions 
					   Set nDay = SalDateDay( dtGivenDate )
					   Set nMonth = SalDateMonth( dtGivenDate )
					   If nMonth < 12
						   Set nMonth = nMonth + 1
					   Else 
						   Set nMonth = 1
					   Set nYear = SalDateYear( dtGivenDate )
					   Set dtTmpDate = SalDateConstruct( nYear, nMonth, nDay, 0, 0, 0 )
					   Set dtTmpDate = SalDateMonthBegin( dtTmpDate ) - 1
					   Return dtTmpDate
			! Function: SubtractMonthsFromMonth
				   Description: Assumes the first parameter is a month and the second is the number
						of months to subtract.  month parameter is assumed to be in the
						month range 1..12 and NO range checking is performed
				   Returns 
					   Number: 
				   Parameters 
					   Number: nMonth
					   Number: nSubMonths
				   Static Variables 
				   Local variables 
					   Number: nCount
				   Actions 
					   Set nCount = nSubMonths
					   While nCount > 0
						   Set nMonth = nMonth - 1
						   Set nCount = nCount - 1
						   If nMonth < 1
							   Set nMonth = 12
					   Return nMonth
			! Function: DaysDiffBetweenMonths
				   Description: 
				   Returns 
					   Number: 
				   Parameters 
					   Number: nFirstMonth
					   Number: nSecondMonth
				   Static Variables 
				   Local variables 
					   Number: nMonths
				   Actions 
					   If nFirstMonth < nSecondMonth
						   Set nMonths = nSecondMonth - nFirstMonth
					   Else If nFirstMonth = nSecondMonth
						   Set nMonths = 0
					   Else 
						   Set nMonths = nFirstMonth - nSecondMonth
					   Return nMonths
			! Function: OurDateYear
				   Description: Because SqlWindows 3.0 SalDateYear returned a 2 digit year. eg 94
						and SqlWindows 5.0 SalDateYear returns 1994 our database has
						year fields as keys and we cannot change them, this function
						takes the 1900 of the year if its not year 1997 or more.  Assumption
						is that after year 1997 we will want to have 1997, 1998, 1999, 2000 etc 
						year fields in the database.
				   Returns 
					   Number: 
				   Parameters 
					   Date/Time: dtCurrentDate
				   Static Variables 
				   Local variables 
					   Number: nCurrentYear
				   Actions 
					   Set nCurrentYear = SalDateYear( dtCurrentDate )
					   If nCurrentYear < 1997
						   Set nCurrentYear = nCurrentYear - 1900
					   Return nCurrentYear
			! Function: AdjustYearToYearOfSale
				   Description: 
				   Returns 
				   Parameters 
					   Receive Number: nYear
				   Static Variables 
				   Local variables 
				   Actions 
					   If nYear < 1997 AND nYear > 1900
						   Set nYear = nYear - 1900
					   Else If nYear > 96 AND nYear < 100
						   Set nYear = nYear + 1900
					   Else If nYear >= 0 AND nYear < 50
						   Set nYear = nYear + 2000
			! Function: AdjustYearOfSaleToYear
				   Description: 
				   Returns 
				   Parameters 
					   Receive Number: nYear
				   Static Variables 
				   Local variables 
				   Actions 
					   If nYear < 100 AND nYear >= 50
						   Set nYear = nYear + 1900
					   Else If nYear >= 0 AND nYear < 50
						   Set nYear = nYear + 2000
			! Function: GetUniqueCurrentSysDT
				   Description: 
				   Returns 
					   Date/Time: 
				   Parameters 
				   Static Variables 
					   Date/Time: dtLastSysDT
				   Local variables 
					   Date/Time: dtSysDT
				   Actions 
					   Set dtSysDT = SalDateCurrent(  )
					   While dtSysDT = dtLastSysDT
						   Set dtSysDT = SalDateCurrent(  )
					   Set dtLastSysDT = dtSysDT
					   Return dtSysDT
			! Function: DateToStrX
				   Description: 
				   Returns 
					   String: 
				   Parameters 
					   Date/Time: dtDate
				   Static Variables 
				   Local variables 
					   String: sStrDate
				   Actions 
					   Call SalDateToStr( dtDate, sStrDate ) 
					   Return sStrDate
			! Function: StrToDateTimeFromDateToStrX
				   Description: assumption to this function is that the format came from DateToStrX( ) being YYYY-MM-DD-HH.MM.SS.TTTTTT
				   Returns 
					   Date/Time: 
				   Parameters 
					   String: sDateTime
				   Static Variables 
				   Local variables 
				   Actions 
					   Return SalDateConstruct( SalStrToNumber( SalStrLeftX( sDateTime, 4 ) ), 
							SalStrToNumber( SalStrMidX( sDateTime, 5, 2 ) ), 
							SalStrToNumber( SalStrMidX( sDateTime, 8, 2 ) ), 
							SalStrToNumber( SalStrMidX( sDateTime, 11, 2 ) ), 
							SalStrToNumber( SalStrMidX( sDateTime, 14, 2 ) ), 
							SalStrToNumber( SalStrMidX( sDateTime, 17, 9 ) ) )
			! Function: FmtGetPictureX
				   Description: 
				   Returns 
					   String: 
				   Parameters 
					   Window Handle: hWnd
				   Static Variables 
				   Local variables 
					   String: sPicture
				   Actions 
					   Call SalFmtGetPicture( hWnd, sPicture )
					   Return sPicture
			! The following have been taken back out of cdates.apl to get migration going
			Function: GetStrJulianDate 
				Description:
				Returns
					String:
				Parameters
					Date/Time: dtDate
				Static Variables
				Local variables
				Actions
					Return SalNumberToStrX( dtDate - SalDateYearBegin( dtDate ) + 1, 0 ) || SalStrMidX( SalNumberToStrX( SalDateYear( dtDate ), 0 ), 3, 1 )
			Function: GetMonthBegEndDays
				Description:
				Returns
				Parameters
					Number: nMonth
					Number: nYear
					Receive Number: nBegDay
					Receive Number: nEndDay
				Static Variables
				Local variables
				Actions
					Set nBegDay = 1
					Set nEndDay = SalDateDay( DateMonthEnd( SalDateConstruct( nYear, nMonth, 1, 0, 0, 0 ) ) )
			Function: DateMonthEnd  
				Description: Returns the last day of the month given in date/time field
				Returns
					Date/Time:
				Parameters
					Date/Time: dtGivenDate  
				Static Variables
				Local variables
					Date/Time: dtTmpDate  
					Number: nDay  
					Number: nMonth  
					Number: nYear  
				Actions
					Set nDay = SalDateDay( dtGivenDate )
					Set nMonth = SalDateMonth( dtGivenDate )
					Set nYear = SalDateYear( dtGivenDate )
					If nMonth < 12
						Set nMonth = nMonth + 1
					Else
						Set nMonth = 1
						Set nYear = nYear + 1
					Set dtTmpDate = SalDateConstruct( nYear, nMonth, nDay, 0, 0, 0 )
					Set dtTmpDate = SalDateMonthBegin( dtTmpDate ) - 1
					Return dtTmpDate
			Function: DateYearEnd  
				Description: Returns the last day of the Year given in date/time field
				Returns
					Date/Time:
				Parameters
					Date/Time: dtGivenDate  
				Static Variables
				Local variables
					Date/Time: dtTmpDate  
					Number: nDay  
					Number: nMonth  
					Number: nYear  
				Actions
					Set nDay = SalDateDay( dtGivenDate )
					Set nMonth = SalDateMonth( dtGivenDate )
					Set nYear = SalDateYear( dtGivenDate ) + 1
					Set dtTmpDate = SalDateConstruct( nYear, nMonth, nDay, 0, 0, 0 )
					Set dtTmpDate = SalDateYearBegin( dtTmpDate ) - 1
					Return dtTmpDate
			Function: SubtractMonthsFromMonth  
				Description: Assumes the first parameter is a month and the second is the number
						of months to subtract.  month parameter is assumed to be in the
						month range 1..12 and NO range checking is performed
				Returns
					Number:
				Parameters
					Number: nMonth  
					Number: nSubMonths  
				Static Variables
				Local variables
					Number: nCount  
				Actions
					Set nCount = nSubMonths
					While nCount > 0
						Set nMonth = nMonth - 1
						Set nCount = nCount - 1
						If nMonth < 1
							Set nMonth = 12
					Return nMonth
			Function: DaysDiffBetweenMonths  
				Description:
				Returns
					Number:
				Parameters
					Number: nFirstMonth  
					Number: nSecondMonth  
				Static Variables
				Local variables
					Number: nMonths  
				Actions
					If nFirstMonth < nSecondMonth
						Set nMonths = nSecondMonth - nFirstMonth
					Else If nFirstMonth = nSecondMonth
						Set nMonths = 0
					Else
						Set nMonths = nFirstMonth - nSecondMonth
					Return nMonths
			Function: OurDateYear  
				Description: Because SqlWindows 3.0 SalDateYear returned a 2 digit year. eg 94
						and SqlWindows 5.0 SalDateYear returns 1994 our database has
						year fields as keys and we cannot change them, this function
						takes the 1900 of the year if its not year 1997 or more.  Assumption
						is that after year 1997 we will want to have 1997, 1998, 1999, 2000 etc
						year fields in the database.
				Returns
					Number:
				Parameters
					Date/Time: dtCurrentDate  
				Static Variables
				Local variables
					Number: nCurrentYear  
				Actions
					Set nCurrentYear = SalDateYear( dtCurrentDate )
					If nCurrentYear < 1997
						Set nCurrentYear = nCurrentYear - 1900
					Return nCurrentYear
			Function: AdjustYearToYearOfSale  
				Description:
				Returns
				Parameters
					Receive Number: nYear  
				Static Variables
				Local variables
				Actions
					If nYear < 1997 AND nYear > 1900
						Set nYear = nYear - 1900
					Else If nYear > 96 AND nYear < 100
						Set nYear = nYear + 1900
					Else If nYear >= 0 AND nYear < 50
						Set nYear = nYear + 2000
			Function: AdjustYearOfSaleToYear  
				Description:
				Returns
				Parameters
					Receive Number: nYear  
				Static Variables
				Local variables
				Actions
					If nYear < 100 AND nYear >= 50
						Set nYear = nYear + 1900
					Else If nYear >= 0 AND nYear < 50
						Set nYear = nYear + 2000
			Function: GetUniqueCurrentSysDT  
				Description:
				Returns
					Date/Time:
				Parameters
				Static Variables
					Date/Time: dtLastSysDT  
				Local variables
					Date/Time: dtSysDT  
				Actions
					Set dtSysDT = SalDateCurrent(  )
					While dtSysDT = dtLastSysDT
						Set dtSysDT = SalDateCurrent(  )
					Set dtLastSysDT = dtSysDT
					Return dtSysDT
			Function: DateToStrX  
				Description:
				Returns
					String:
				Parameters
					Date/Time: dtDate  
				Static Variables
				Local variables
					String: sStrDate  
				Actions
					Call SalDateToStr( dtDate, sStrDate )
					Return sStrDate
			Function: StrToDateTimeFromDateToStrX  
				Description: assumption to this function is that the format came from DateToStrX( ) being YYYY-MM-DD-HH.MM.SS.TTTTTT
				Returns
					Date/Time:
				Parameters
					String: sDateTime  
				Static Variables
				Local variables
				Actions
					Return SalDateConstruct( SalStrToNumber( SalStrLeftX( sDateTime, 4 ) ),
							SalStrToNumber( SalStrMidX( sDateTime, 5, 2 ) ),
							SalStrToNumber( SalStrMidX( sDateTime, 8, 2 ) ),
							SalStrToNumber( SalStrMidX( sDateTime, 11, 2 ) ),
							SalStrToNumber( SalStrMidX( sDateTime, 14, 2 ) ),
							SalStrToNumber( SalStrMidX( sDateTime, 17, 9 ) ) )
			Function: FmtGetPictureX  
				Description:
				Returns
					String:
				Parameters
					Window Handle: hWnd  
				Static Variables
				Local variables
					String: sPicture  
				Actions
					Call SalFmtGetPicture( hWnd, sPicture )
					Return sPicture
			Function: DateTimeToStrHHMMSS
				Description:
				Returns
					String:
				Parameters
					Date/Time: dtDateTime
				Static Variables
				Local variables
					String: sHour
					String: sMin
					String: sSec
				Actions
					Set sHour = SalNumberToStrX( SalDateHour( dtDateTime ), 0 )
					Call StringStartPad( sHour, '0', 2 )
					Set sMin = SalNumberToStrX( SalDateMinute( dtDateTime ), 0 )
					Call StringStartPad( sMin, '0', 2 )
					Set sSec = SalNumberToStrX( SalDateSecond( dtDateTime ), 0 )
					Call StringStartPad( sSec, '0', 2 )
					Return sHour || sMin || sSec
			Function: DateTimeToStrYYMMDD
				Description:
				Returns
					String:
				Parameters
					Date/Time: dtDateTime
				Static Variables
				Local variables
					String: sYear
					String: sMonth
					String: sDay
				Actions
					Set sYear = SalStrRightX( SalNumberToStrX( SalDateYear( dtDateTime ), 2 ), 0 )
					Call StringStartPad( sYear, '0', 2 )
					Set sMonth = SalNumberToStrX( SalDateMonth( dtDateTime ), 0 )
					Call StringStartPad( sMonth, '0', 2 )
					Set sDay = SalNumberToStrX( SalDateDay( dtDateTime ), 0 )
					Call StringStartPad( sDay, '0', 2 )
					Return sYear || sMonth || sDay

						Functions
							Function: ExistsGrowSaleLocation
								Description:
								Returns
									Boolean:
								Parameters
									Number: nItemNo
									Number: nYear
									Receive Boolean: bExists
									Number: nActionType
								Static Variables
									! hcSqlHandle: fcOurHandle
.winattr class :
										Class: hcSqlHandle
.end
								Local variables
									String: sSql
									String: sBind
									String: sInto
									String: sName
									Number: nOurHandleNo
									!
									Number: nInd
								Actions
									Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GSALELOCEXISTS' )
									Select Case nActionType
										Case SH_cls_Execute
											Set sSql = " SELECT Location_Id 
													FROM 
													  Growing_Sale 
													WHERE 
													  Stock_Item_No = :1 AND 
													  Year_Of_Sale = :2 "
											Set sName = 'GSALELOCEXISTS'
											Set sBind = ':nItemNo, :nYear'
											Set sInto = ''
											!
											Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
											Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
											!
											Set bExists = FALSE
											!
											If haSqlHandles[ nOurHandleNo ].Execute( )
												If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
													Set bExists = TRUE
												Else
													Set bExists = FALSE
												Return TRUE
											Else
												Return FALSE
										Case SH_cls_Disconnect
											Return haSqlHandles[ nOurHandleNo ].Disconnect( )
							Function: ExistsItemCustOrder
								Description:
								Returns
									Boolean:
								Parameters
									Number: nItemNo
									Number: nYear
									Receive Boolean: bExists

			Pushbutton Class: clspbSISInventory
				Title: Inv.
				Window Location and Size
					Left:  
					Top:   
					Width:  Class Default
					Width Editable? Class Default
					Height: Class Default
					Height Editable? Class Default
				Visible? Class Default
				Keyboard Accelerator: Class Default
				Font Name: Class Default
				Font Size: Class Default
				Font Enhancement: Class Default
				Picture File Name: C:\CENTURA\ICONS\INV.BMP
				Picture Transparent Color: Class Default
				Image Style: Class Default
				Text Color: Class Default
				Background Color: Class Default
				List in Tool Palette? Yes
				Property Template:
				Class DLL Name:
				Description:
				Derived From
					Class: clspbPickInto
				Class Variables
					String: sTmp
					Number: nTmp
					Window Handle: hWndTmp
				Instance Variables
					! PUBLIC
					Window Handle: hWndPickIntoTable
					! PRIVATE
					Number: nItemNo
					String: sTreeTypeDesc
					String: sCultDesc
					String: sRootDesc
					String: sStockType
				Functions
					Function: SetInventoryFields
						Description:
						Returns
							Boolean:
						Parameters
							Number: nNewItemNo
							String: sNewTreeTypeDesc
							String: sNewCultDesc
							String: sNewRootDesc
							String: sNewStockType
						Static Variables
						Local variables
						Actions
							Set nItemNo = nNewItemNo
							Set sTreeTypeDesc = sNewTreeTypeDesc
							Set sCultDesc = sNewCultDesc
							Set sRootDesc = sNewRootDesc
							Set sStockType = sNewStockType
							Return TRUE
				Message Actions
					On SAM_Create
						Set hWndPickIntoTable = hWndItem
						Call SalSendClassMessage( SAM_Create, wParam, lParam )
						Set clspbSISInventory.nActivateWindowType = ACTIVATE_FormWindow
						Set clspbSISInventory.sActivateDialogName = 'frmInventory'
						Set clspbSISInventory.hWndTable = hWndPickIntoTable
						Set clspbSISInventory.hWndParentTable = hWndPickIntoTable
						Set clspbSISInventory.hWndFieldLookUp = hWndItem
					On PAM_clsACTIVATE_PUSHFIELDS
						Call SalSendMsg( hWndItem, PAM_cls_SETFIELDS, 0, 0 )
						If sStockType = 'C'
							Set clspbSISInventory.sActivateDialogName = 'frmPotsInventory'
						Else
							Set clspbSISInventory.sActivateDialogName = 'frmInventory'
						Call PushWndHdl( hWndItem )
						Call PushNumber( nItemNo )
						Call PushString( sTreeTypeDesc )
						Call PushString( sCultDesc )
						Call PushString( sRootDesc )
						Call PushString( sStockType )
						Return TRUE
					On PAM_clsACTIVATE_POPFIELDS
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopString( sTmp, TRUE )
						Call PopNumber( nTmp, TRUE )
						Call PopWndHdl( hWndTmp, TRUE )
						Return TRUE

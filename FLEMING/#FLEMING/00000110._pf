									On PAM_clsTBL_DATAVAL
										If SalIsNull( hWndItem )
											Set colTotalGraded = 0
										Return TRUE
									On PAM_cls_INITIALISE
										Set colTotalGraded = 0
									On SAM_Validate
										If colTotalGraded != colOrgTotalGraded
											If IDYES = SalMessageBox( 'Are you sure you want to change the Total Graded figure?', 'Warning', MB_YesNo )
												Set colGraded = colTotalGraded - colShip - colShipAsSub
												If colGraded = 0
													Set colGraded = 0.1
												Call SalSetFieldEdit( colGraded, TRUE )
											Else
												Set colTotalGraded = colOrgTotalGraded
										Return VALIDATE_Ok
									On PAM_clsTBL_EDITCHECK
										If hWndForm.hWndParent.clsfrmInventory.sStockType = 'C'
											Return FALSE
										Else
											Return TRUE

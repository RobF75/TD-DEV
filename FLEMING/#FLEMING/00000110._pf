						Contents
							Column: colYearOfSale
								Class Child Ref Key: 0
								Class ChildKey: 29
								Class: clsColumnGeneral
								Property Template:
								Class DLL Name:
								Title: Year
								Visible? Class Default
								Editable? Class Default
								Maximum Data Length: Class Default
								Data Type: Number
								Justify: Center
								Width:  0.55"
								Width Editable? Class Default
								Format: #0
								Country: Class Default
								Input Mask: Class Default
								Cell Options
									Cell Type? Class Default
									Multiline Cell? Class Default
									Cell DropDownList
										Sorted? Class Default
										Vertical Scroll? Class Default
										Auto Drop Down? Class Default
										Allow Text Editing? Class Default
									Cell CheckBox
										Check Value:
										Uncheck Value:
										Ignore Case? Class Default
								List Values
								Message Actions
									On SAM_Validate
										Call AdjustYearToYearOfSale( colYearOfSale )
										Return VALIDATE_Ok
									On PAM_clsTBL_DATAVAL
										If SalIsNull( colYearOfSale )
											Call ErrorMessage( 'Please enter a year of sale first!', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE
									On PAM_clsTBL_CHECKROWNEW
										Call CheckYearItemExists( hWndForm.hWndParent.clsfrmPotsInventory.nItemNo, colYearOfSale, bExists, sTmp, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'This year of sale is already created! Please enter another!', hWndForm, lParam )
											Return FALSE
										Else
											Return TRUE
									On PAM_clsTBL_CHECKROWDELETED
										Call ExistsGrowSaleLocation( hWndForm.hWndParent.clsfrmPotsInventory.nItemNo, colYearOfSale, bExists, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'This stock Item still has field counts.', hWndForm, wParam )
											Return FALSE
										Call ExistsItemCustOrder( hWndForm.hWndParent.clsfrmPotsInventory.nItemNo, colYearOfSale, bExists, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'Someone still has this stock Item on Order for this year. Please delete the order first!.', hWndForm, wParam )
											Return FALSE
										Call ExistsItemCustOrderHist( hWndForm.hWndParent.clsfrmPotsInventory.nItemNo, colYearOfSale, bExists, SH_cls_Execute )
										If bExists
											Call ErrorMessage( 'Someone still has this stock Item on Order in History for this year. Please delete the order first!.', hWndForm, wParam )
											Return FALSE
										Return TRUE
							Column: colCurrAvail

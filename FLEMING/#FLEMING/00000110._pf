								List Values
								Message Actions
									On PAM_clsTBL_DATAVAL
										If SalIsNull( hWndItem )
											Set colGraded = 0
										Return TRUE
									On PAM_cls_INITIALISE
										Set colGraded = 0
									On SAM_Validate
										If colGraded != colOrgGraded
											Call ExistsFutureAvailStock( hWndForm.hWndParent.clsfrmInventory.nItemNo, colYearOfSale, bExists, SH_cls_Execute )
											If bExists
												If IDNO = SalMessageBox( 'Future available stock exists! Do you still wish to change the graded figure? ', 'Warning', MB_YesNo | MB_DefButton2 )
													Set colGraded = colOrgGraded
													Return VALIDATE_OkClearFlag
										If colGraded = 0
											Set colGraded = 0.1
										Return VALIDATE_Ok
									On PAM_clsTBL_EDITCHECK
										If hWndForm.hWndParent.clsfrmInventory.sStockType = 'C'
											Return FALSE
										Else
											Return TRUE

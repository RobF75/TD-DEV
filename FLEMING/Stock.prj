INSERT INTO TMADM.PROMOTION (PROMOTION_ID,PROJECT_CODE,PROMOTION_LEVEL,PROMOTION_NAME,ENABLE_EXTRACT,DESCRIPTION,PROM_DIRECTORY,ROW_VER,MODIFIED_BY)  VALUES(:1,:2,:3,:4,:5,:6,:7,:8,:9)
¥
$datatypes NUMERIC,CHARACTER,NUMERIC,CHARACTER,NUMERIC,CHARACTER,CHARACTER,NUMERIC,CHARACTER
$datacount=4
1,"#STARTER",1,"Development",0,"A module revision is automatically at the  Development level as soon as it is created, or Checked In. When a module revision is at development, it is at it's lowest promotion level.","",1,"TMADM"
2,"#STARTER",2,"Test",0,"When a module revision is at the test level means that  the module revision is ready to be tested. Once a module has completed being tested, it can either get promoted to Test Sign Off (passed) or get demoted back to Development (failed).","",1,"TMADM"
3,"#STARTER",3,"Test Sign Off",0,"When a module revision is at the Test Sign Off level means that  the module revision has passed all testing at the Test level, but is not yet ready for production. If it is deemed that the module is not fit for Production, it can be demoted back.","",1,"TMADM"
4,"#STARTER",4,"Production",0,"When a module revision is at the Production level means that  the module revision is deemed to be fit for production quality.A module revision cannot exist at a higher level than production.","",1,"TMADM"
/


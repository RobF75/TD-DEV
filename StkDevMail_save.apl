.head 3 +  Function: fGetCorrespondenceFileName
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  String:
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Return ''
.head 2 +  Window Parameters
.head 3 -  ! Number: nEmailType
.head 2 +  Window Variables
.head 3 -  String: sEmailAddress
.head 3 -  String: sExpandedEmailAddress
.head 3 -  String: sCustTypes
.head 3 -  Boolean: bBeenHere
.head 3 -  Number: nExpandedEmailAddressCharLimit
.head 2 +  Message Actions
.head 3 +  On PAM_SETINSTANCEVARS
.head 4 -  Call fSetSaveCorrespondence( FALSE )
.head 4 -  Set bBeenHere = FALSE
.head 4 -  Set sEmailAddress = STRING_Null
.head 3 +  On PAM_CLICK
.head 4 -  Set sCustTypes = ''
.head 4 -  Call MyTableLoop( tblCustTypes, hWndForm, PAM_ROWACTION, 0, 0, 'Gather selected customer types.', nLowToHi )
.head 4 +  If sCustTypes = ''
.head 5 -  Call SalMessageBox( 'Please select at least one customer type!', 'Warning', MB_Ok )
.head 4 +  Else
.head 5 -  ! remove the very first comma.
.head 5 -  Call SalStrLop( sCustTypes )
.head 5 -  Return SalSendClassMessage( PAM_CLICK, wParam, lParam )
.head 3 -  !
.head 3 +  ! On SAM_ReportFetchNext	! graham's changes.
.head 4 +  ! If SalSendClassMessage( SAM_ReportFetchNext, wParam, lParam )
.head 5 -  Call fSetToAddress( sEmailAddress )
.head 5 -  Return TRUE
.head 4 +  ! Else
.head 5 -  Return FALSE
.head 4 +  If NOT bBeenHere
.head 5 +  While fcEmailSqlHandle.FetchNext( nInd )
.head 6 -  Set nRowCount = nRowCount + 1
.head 6 -  Call SalSendMsg( hWndMeter, PAM_SETPROGRESS, 0, nRowCount )
.head 6 -  Set sExpandedEmailAddress = sExpandedEmailAddress || sEmailAddress || ';'
.head 6 -  Call fSetBCCAddress( sExpandedEmailAddress )
.head 6 -  Set bBeenHere = TRUE
.head 5 -  Call fSetToAddress( STRING_Null )
.head 5 -  Return TRUE
.head 4 +  Else
.head 5 -  Return FALSE
.head 3 +  On SAM_ReportFetchNext	! jan improved OO style a bit.
.head 4 +  ! If SalSendClassMessage( SAM_ReportFetchNext, wParam, lParam )
.head 5 -  Call fSetToAddress( sEmailAddress )
.head 5 -  Return TRUE
.head 4 +  ! Else
.head 5 -  Return FALSE
.head 4 -  Set nExpandedEmailAddressCharLimit = 23000
.head 4 +  If NOT bBeenHere
.head 5 +  While SalSendClassMessage( SAM_ReportFetchNext, wParam, lParam ) AND SalStrLength( sExpandedEmailAddress ) < nExpandedEmailAddressCharLimit
.head 6 -  Set sExpandedEmailAddress = sExpandedEmailAddress || sEmailAddress || ';'
.head 6 -  Set bBeenHere = TRUE
.head 5 -  Call fSetBCCAddress( sExpandedEmailAddress )
.head 5 -  Call fSetToAddress( STRING_Null )
.head 5 -  !
.head 5 +  If SalStrLength( sExpandedEmailAddress ) < nExpandedEmailAddressCharLimit
.head 6 -  Return bBeenHere
.head 5 +  Else
.head 6 -  Set bBeenHere = FALSE
.head 6 -  Return TRUE
.head 4 +  Else
.head 5 -  Return FALSE
.head 3 -  !
.head 3 +  On PAM_ROWACTION
.head 4 +  If SalStrUpperX( tblCustTypes.colsSelected ) ='Y'
.head 5 -  Set sCustTypes = sCustTypes || ", '" || tblCustTypes.colsCustType || "'"
.head 4 -  Return TRUE
.head 3 +  On SAM_CreateComplete
.head 4 -  Set rbCustomSelected = TRUE

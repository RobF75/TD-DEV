.head 4 +  Functions
.head 5 +  Function: fSetCustNo
.head 6 -  Description:
.head 6 -  Returns
.head 6 +  Parameters
.head 7 -  Number: npCustNo
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  Number: nInd
.head 7 -  String: sEmailAddress
.head 6 +  Actions
.head 7 -  Set dfCustNo = npCustNo
.head 7 -  Set sSql = "SELECT
	CM.CUST_NAME,
	CA.EMAIL
FROM
	CUSTOMER_MASTER CM,
	CUSTOMER_ADDRESS CA
WHERE
	CM.CUST_NO = :npCustNo AND
	CM.CUST_NO = CA.CUST_NO(+)
ORDER BY
	CA.MAIN_ADDRESS_FLAG DESC
INTO
	:hWndForm.dfCustName,
	:hWndForm.cmbEmailToAddress"
.head 7 -  Call fcEmailSqlHandle.PrepareSetup( sSql )
.head 7 -  Call SqlVarSetup( fcEmailSqlHandle.hSqlHandle )
.head 7 +  If fcEmailSqlHandle.PrepareAndExecute( )
.head 8 -  Call fcEmailSqlHandle.FetchNext( nInd )
.head 7 -  Set sSql = "SELECT DISTINCT
	email
FROM
	customer_address
WHERE
	cust_no = :npCustNo AND
	email IS NOT NULL
UNION ALL
SELECT DISTINCT
	email
FROM
	customer_contacts
WHERE
	cust_no = :npCustNo AND
	email IS NOT NULL
INTO
	:sEmailAddress "
.head 7 -  Call fcEmailSqlHandle.PrepareSetup( sSql )
.head 7 +  If fcEmailSqlHandle.PrepareAndExecute( )
.head 8 +  While fcEmailSqlHandle.FetchNext( nInd )
.head 9 -  Call SalListAdd( cmbEmailToAddress, sEmailAddress )
.head 9 -  Call SalListAdd( cmbEmailCCAddress, sEmailAddress )
.head 9 -  Call SalListAdd( cmbEmailBCCAddress, sEmailAddress )
.head 5 +  Function: fGetCorrespondenceFileName
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  String:
.head 6 -  Parameters
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  String: sTmp
.head 6 +  Actions
.head 7 -  Set sTmp = dfSubject
.head 7 -  Call StringReplace( sTmp, ' ', '_' )
.head 7 -  Call StringReplace( sTmp, '/', '_' )
.head 7 -  Call StringReplace( sTmp, '\\', '_' )
.head 7 -  Call StringReplace( sTmp, ':', '_' )
.head 7 -  Call StringReplace( sTmp, '*', '_' )
.head 7 -  Call StringReplace( sTmp, '?', '_' )
.head 7 -  Call StringReplace( sTmp, '<', '_' )
.head 7 -  Call StringReplace( sTmp, '>', '_' )
.head 7 -  Call StringReplace( sTmp, '|', '_' )
.head 7 -  Return 'C' || SalNumberToStrX( dfCustNo, 0 ) || 's_' || sTmp || 'dt_' || SalFmtFormatDateTime( SalDateCurrent(  ), 'dd-MM-yyyy-hh.mm.ssAMPM' ) || '_email.txt'
.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Call SalSendClassMessage( SAM_Create, wParam, lParam )
.head 6 -  Call fSetSaveCorrespondence( TRUE )
.head 5 +  On SAM_CreateComplete
.head 6 -  Set dfSubject = fGetSubject( )
.head 6 -  Set dfAttachment = fGetAttachments( )
.head 6 -  Set mlBody = fGetText( )
.head 6 -  Set cmbEmailToAddress = fGetToAddress()
.head 6 -  Call SalWaitCursor( FALSE )
.head 5 +  On SAM_ReportStart
.head 6 -  Call ..fSetToAddress( cmbEmailToAddress )
.head 6 -  Call ..fSetCCAddress( cmbEmailCCAddress )
.head 6 -  Call ..fSetBCCAddress( cmbEmailBCCAddress )
.head 6 -  !
.head 6 -  Call ..fSetSubject( dfSubject )
.head 6 -  Call ..fSetText( mlBody )
.head 6 -  Call ..fSetAttachments( sAttachment )
.head 6 -  !
.head 6 -  Call ..fSetSenderName( dfSenderName )
.head 6 -  Call ..fSetSenderDetails( mlCompanyDetails )
.head 6 -  Call ..fSetSenderAddress( dfSenderAddress )
.head 6 -  !
.head 6 -  Set bFirst = TRUE
.head 6 -  !
.head 6 -  Return TRUE
.head 5 +  On SAM_ReportFetchInit
.head 6 -  Return TRUE
.head 5 +  On SAM_ReportFetchNext
.head 6 +  If bFirst
.head 7 -  Set bFirst = FALSE
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  On SAM_ReportFinish
.head 6 -  Return fcEmailSqlHandle.Disconnect( )
.head 5 +  On PAM_CLICK
.head 6 -  Call SalSendMsgToChildren( hWndForm, PAM_DATAVAL, 0, 0 )
.head 6 +  If ..fStartSending( )

.head 4 +  Actions
.head 5 +  If nEmailType = nEmailGardenCentres
.head 6 -  Return "SELECT DISTINCT
	email
FROM
	customer_address ca,
	Customer_master cm
WHERE
	ca.cust_no = cm.cust_no and
	@UPPER( promo_email_flag ) = 'Y'
	AND email IS NOT NULL and
	customer_type not like '%OR%' and
	customer_type not in ('GCB', 'GCK', 'GCH', 'GCW')
UNION ALL
SELECT DISTINCT
	email
FROM
	customer_contacts cc,
	Customer_master cm
WHERE
	cc.cust_no = cm.cust_no and
	@UPPER( contact_mail_flag ) = 'Y'
	AND email IS NOT NULL and
	customer_type not like '%OR%' and
	customer_type not in ('GCB', 'GCK', 'GCH', 'GCW')
INTO :hWndForm.sEmailAddress "
.head 5 +  Else If nEmailType = nEmailOrchardists
.head 6 -  Return "SELECT DISTINCT
	email
FROM
	customer_address ca,
	Customer_master cm
WHERE
	ca.cust_no = cm.cust_no and
	@UPPER( promo_email_flag ) = 'Y'
	AND email IS NOT NULL and
	customer_type  like '%OR%'
UNION ALL
SELECT DISTINCT
	email
FROM
	customer_contacts cc,
	Customer_master cm
WHERE
	cc.cust_no = cm.cust_no and
	@UPPER( contact_mail_flag ) = 'Y'
	AND email IS NOT NULL and
	customer_type  like '%OR%'
INTO :hWndForm.sEmailAddress "

.head 4 +  Functions
.head 5 +  Function: fSetCustomerTypesSelection
.head 6 -  Description:
.head 6 -  Returns
.head 6 +  Parameters
.head 7 -  ! sCustType = 'GARDENCENTRES', 'ORCHARDISTS', 'CHAINSTORES', 'CUSTOM'
.head 7 -  String: sCustType
.head 6 -  Static Variables
.head 6 -  Local variables
.head 6 +  Actions
.head 7 +  If NOT sCustType = 'CUSTOM'
.head 8 -  Set sSelectionType = sCustType
.head 8 -  Call MyTableLoop( hWndForm, hWndForm, PAM_ROWACTION, 0, 0, 'Preset selection types', nLowToHi )
.head 4 +  Window Variables
.head 5 -  String: sSelectionType
.head 4 +  Message Actions
.head 5 +  On PAM_SETINSTANCEVARS
.head 6 -  Set sSQLPOPTABLENAME = ' CUSTOMER_TYPE '
.head 6 -  Set sSQLTABLENAME = ' CUSTOMER_TYPE '
.head 6 -  Set sSQLWHERE = ''
.head 6 -  Set sORDERBY = ' ORDER BY CUST_TYPE '
.head 5 +  On SAM_CreateComplete
.head 6 -  Call SalSendMsg( hWndForm, PAM_POPULATE, 0, 0 )
.head 5 +  On SAM_FetchRowDone
.head 6 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_HideMarks, TRUE )
.head 5 +  On PAM_ROWACTION
.head 6 +  If sSelectionType = 'CHAINSTORES'
.head 7 +  If colsCustType = 'GCB' OR colsCustType = 'GCK' OR colsCustType = 'GCH' OR colsCustType = 'GCW'
.head 8 -  Set colsSelected = 'Y'
.head 7 +  Else
.head 8 -  Set colsSelected = 'N'
.head 6 +  Else If sSelectionType = 'ORCHARDISTS'
.head 7 +  If SalStrScan( colsCustType, '%OR%' ) = -1
.head 8 -  Set colsSelected = 'N'
.head 7 +  Else
.head 8 +  If colsCustType = 'BOR'
.head 9 -  Set colsSelected = 'N'
.head 8 +  Else
.head 9 -  Set colsSelected = 'Y'
.head 6 +  Else If sSelectionType = 'ZEECUSTOMERS'
.head 7 +  If SalStrScan( colsCustType, '%OR%' ) = -1
.head 8 +  If colsCustType = 'ZS'
.head 9 -  Set colsSelected = 'Y'
.head 8 +  Else
.head 9 -  Set colsSelected = 'N'
.head 7 +  Else
.head 8 +  If colsCustType = 'BOR'
.head 9 -  Set colsSelected = 'N'
.head 8 +  Else
.head 9 -  Set colsSelected = 'Y'
.head 6 +  Else If sSelectionType = 'GARDENCENTRES'
.head 7 +  If NOT ( colsCustType = 'GCB' OR colsCustType = 'GCK' OR colsCustType = 'GCH' OR colsCustType = 'GCW' ) AND SalStrScan( colsCustType, '%OR%' ) = -1 AND SalStrScan( colsCustType, '%GC%' ) >= 0
.head 8 -  Set colsSelected = 'Y'
.head 7 +  Else
.head 8 -  Set colsSelected = 'N'
.head 6 -  Return TRUE

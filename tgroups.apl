.head 3 +  Function: GetLoadCustTotalUnits
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Number: nLoadCustInstNo
.head 5 -  String: sLoadId
.head 5 -  Number: nYear
.head 5 -  Receive Number: nTotalUnits
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nInd
.head 5 -  Number: nSqlHandleNo
.head 5 -  !
.head 5 -  Number: nGotTotalUnits
.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetLoadCustTotalUnits' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT
  SUM( Customer_Order.Conf_Amt * Stock_Item.Unit_Size )  AS Total_Units
FROM
  Customer_Order,
  Stock_Item
WHERE
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND
  Customer_Order.Cust_No = :1 AND
  Customer_Order.Year_Of_Sale = :2 AND
  Customer_Order.Load_Id = :3 AND
  Customer_Order.Load_Cust_Inst_No = :4"
.head 7 -  Set sName = 'GLDCSTTOTUNIT2'
.head 7 -  Set sBind = ':nCustNo, :nYear, :sLoadId, :nLoadCustInstNo'
.head 7 -  Set sInto = ':nGotTotalUnits'
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set nTotalUnits = NUMBER_Null
.head 7 -  Set nGotTotalUnits = NUMBER_Null
.head 7 -  !
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 -  Set nTotalUnits = nGotTotalUnits
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 3 +  Function: GetLoadCustTotalUnitsExInv
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Number: nLoadCustInstNo
.head 5 -  String: sLoadId
.head 5 -  Number: nYear
.head 5 -  Receive Number: nTotalUnits
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nInd
.head 5 -  Number: nSqlHandleNo
.head 5 -  !
.head 5 -  Number: nGotTotalUnits
.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetLoadCustTotalUnitsExInv' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT
  SUM( Customer_Order.Conf_Amt * Stock_Item.Unit_Size )  AS Total_Units
FROM
  Customer_Order,
  Stock_Item
WHERE
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND
  Customer_Order.Cust_No = :1 AND
  Customer_Order.Year_Of_Sale = :2 AND
  Customer_Order.Load_Id = :3 AND
  Customer_Order.Load_Cust_Inst_No = :4 AND
  ( NOT Customer_Order.Invoiced_Flag = 'Y' OR
    Customer_Order.Invoiced_Flag IS NULL ) "
.head 7 -  Set sName = 'GLDCSTTUNTXIN2'
.head 7 -  Set sBind = ':nCustNo, :nYear, :sLoadId, :nLoadCustInstNo'
.head 7 -  Set sInto = ':nGotTotalUnits'
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set nTotalUnits = NUMBER_Null
.head 7 -  Set nGotTotalUnits = NUMBER_Null
.head 7 -  !
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 -  Set nTotalUnits = nGotTotalUnits
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )

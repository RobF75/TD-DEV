.head 2 +  Named Menus
.head 2 +  Internal Functions
.head 3 +  Function: GetCustTreeGroupsOnLoad
.head 4 -  Description: Calculates trees groups that are NOT invoiced!
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Number: nLoadCustInstNo
.head 5 -  String: sLoadId
.head 5 -  Number: nYear
.head 5 -  Boolean: bIncludeInvoiced
.head 5 -  Receive Number: nFruitTrees
.head 5 -  Receive Number: nMSTrees
.head 5 -  Receive Number: nMDTrees
.head 5 -  Receive Number: nSmallFruitTrees
.head 5 -  Receive Number: nOrnamTrees
.head 5 -  Receive Number: nXlgOrnamTrees
.head 5 -  Receive Number: nWeeperTrees
.head 5 -  Receive Number: nContTrees
.head 5 -  Receive Number: nTotalTrees
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Boolean: bOk
.head 4 +  Actions
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set nFruitTrees = 0
.head 7 -  Set nMSTrees = 0
.head 7 -  Set nMDTrees = 0
.head 7 -  Set nSmallFruitTrees = 0
.head 7 -  Set nOrnamTrees = 0
.head 7 -  Set nXlgOrnamTrees = 0
.head 7 -  Set nWeeperTrees = 0
.head 7 -  Set nContTrees = 0
.head 7 -  Set nTotalTrees = 0
.head 7 -  !
.head 7 +  If GetCustTotalTreesOnLoad( nCustNo, nLoadCustInstNo, sLoadId, nYear, bIncludeInvoiced, nTotalTrees, SH_cls_Execute )
.head 8 +  If GetCustFruitTreesOnLoad( nCustNo, nLoadCustInstNo, sLoadId, nYear, bIncludeInvoiced, nFruitTrees, SH_cls_Execute )
.head 9 +  If GetCustSmallFruitTreesOnLoad( nCustNo, nLoadCustInstNo, sLoadId, nYear, bIncludeInvoiced, nSmallFruitTrees, SH_cls_Execute )
.head 10 +  If GetCustWeeperTreesOnLoad( nCustNo, nLoadCustInstNo, sLoadId, nYear, bIncludeInvoiced, nWeeperTrees, SH_cls_Execute )
.head 11 +  If GetCustTreeTypeTreesOnLoad( nCustNo, nLoadCustInstNo, sLoadId, nYear, bIncludeInvoiced, 'MS%', nMSTrees, SH_cls_Execute )
.head 12 +  If GetCustTreeTypeTreesOnLoad( nCustNo, nLoadCustInstNo, sLoadId, nYear, bIncludeInvoiced, 'MD%', nMDTrees, SH_cls_Execute )
.head 13 +  If GetCustTreeTypeTreesOnLoad( nCustNo, nLoadCustInstNo, sLoadId, nYear, bIncludeInvoiced, 'X%', nXlgOrnamTrees, SH_cls_Execute )
.head 14 +  If GetCustTreeTypeTreesOnLoad( nCustNo, nLoadCustInstNo, sLoadId, nYear, bIncludeInvoiced, 'C%', nContTrees, SH_cls_Execute )
.head 15 -  Set nOrnamTrees = nTotalTrees - nFruitTrees- nXlgOrnamTrees - nWeeperTrees
.head 15 -  Set nFruitTrees = nFruitTrees - nMSTrees - nMDTrees - nSmallFruitTrees
.head 15 -  Return TRUE
.head 14 +  Else
.head 15 -  Return FALSE
.head 13 +  Else
.head 14 -  Return FALSE
.head 12 +  Else
.head 13 -  Return FALSE
.head 11 +  Else
.head 12 -  Return FALSE
.head 10 +  Else
.head 11 -  Return FALSE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Else
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT GetCustTotalTreesOnLoad( 0, 0, '', 0, FALSE, nTotalTrees, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT GetCustFruitTreesOnLoad( 0, 0, '', 0, FALSE, nFruitTrees, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT GetCustSmallFruitTreesOnLoad( 0, 0, '', 0, FALSE, nSmallFruitTrees, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT GetCustTreeTypeTreesOnLoad( 0, 0, '', 0, FALSE, '', nMSTrees, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 +  If NOT GetCustWeeperTreesOnLoad( 0, 0, '', 0, FALSE, nWeeperTrees, SH_cls_Disconnect )
.head 8 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case SH_cls_RePrepare
.head 7 -  Call GetCustTotalTreesOnLoad( 0, 0, '', 0, FALSE, nTotalTrees, SH_cls_RePrepare )
.head 7 -  Call GetCustFruitTreesOnLoad( 0, 0, '', 0, FALSE, nFruitTrees, SH_cls_RePrepare )
.head 7 -  Call GetCustSmallFruitTreesOnLoad( 0, 0, '', 0, FALSE, nSmallFruitTrees, SH_cls_RePrepare )
.head 7 -  Call GetCustTreeTypeTreesOnLoad( 0, 0, '', 0, FALSE, '', nMSTrees, SH_cls_RePrepare )
.head 7 -  Call GetCustWeeperTreesOnLoad( 0, 0, '', 0, FALSE, nWeeperTrees, SH_cls_RePrepare )
.head 7 -  Return TRUE
.head 3 -  !
.head 3 +  Function: GetCustTotalTreesOnLoad
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Number: nLoadCustInstNo
.head 5 -  String: sLoadId
.head 5 -  Number: nYear
.head 5 -  Boolean: bIncludeInvoiced
.head 5 -  Receive Number: nTotalTrees
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  Sql Handle: hSqlTotalHandle
.head 5 -  Boolean: bTotalHandleConnected
.head 5 -  Boolean: bTotalHandlePrepared
.head 5 -  Number: nMatchLoadIdType
.head 5 -  ! nMatchLoadIdType = 0 ( initial state )
  nMatchLoadIdType = 1 ( where load_id = :sLoadId )
  nMatchLoadIdType = 2 ( where load_id is null ) 
.head 5 -  Number: nIncludeInvoiceType
.head 5 -  ! nIncludeInvoiceType = 0 ( initial state )
  nIncludeInvoiceType = 1 ( WITHOUT   NOT invoiced_flag = 'Y' )
  nIncludeInvoiceType = 2 ( WITH   NOT invoiced_flag = 'Y' ) 
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sFuncName
.head 5 -  Boolean: bOk
.head 5 -  Number: nInd
.head 5 -  Number: nGotTotalTrees
.head 4 +  Actions
.head 5 -  Set sFuncName = 'GetCustTotalTreesOnLoad'
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 +  If sLoadId = ''
.head 8 +  If nMatchLoadIdType != 2

.head 4 +  Actions
.head 5 -  Set sFuncName = 'GetCustWeeperTreesOnLoad'
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 +  If sLoadId = ''
.head 8 +  If nMatchLoadIdType != 2
.head 9 -  Set bWeeperHandlePrepared = FALSE
.head 9 -  Set nMatchLoadIdType = 2
.head 7 +  Else
.head 8 +  If nMatchLoadIdType != 1
.head 9 -  Set bWeeperHandlePrepared = FALSE
.head 9 -  Set nMatchLoadIdType = 1
.head 7 -  !
.head 7 +  If bIncludeInvoiced
.head 8 +  If nIncludeInvoiceType != 1
.head 9 -  Set bWeeperHandlePrepared = FALSE
.head 9 -  Set nIncludeInvoiceType = 1
.head 7 +  Else
.head 8 +  If nIncludeInvoiceType != 2
.head 9 -  Set bWeeperHandlePrepared = FALSE
.head 9 -  Set nIncludeInvoiceType = 2
.head 7 -  !
.head 7 +  Loop Execute

  Customer_Order.Cust_No = :nCustNo AND 
  Customer_Order.Load_Id IS NULL AND 
  Customer_Order.Year_Of_Sale = :nYear AND 
  NOT Customer_Order.Invoiced_Flag = 'Y' AND 
  Stock_Item.Tree_Type IN ( 'SHT', 'SHT2', 'STSM', 'TAL2', 'TALL' ) "
.head 10 +  Else
.head 11 +  If bIncludeInvoiced
.head 12 -  Set sSql = " SELECT 
  sum( Customer_Order.Conf_Amt ) 

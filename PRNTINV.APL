  Load_Customers.Load_Id = :1 AND 
  Load_Customers.Cust_No = Customer_Order.Cust_No AND 
  Customer_Order.Year_Of_Sale = :2 AND 
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 

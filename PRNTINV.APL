      Customer_Order.Conf_Amt, 
      Customer_Order.Purchase_Order_No, 
      Customer_Order.Contract_Price, 
      Customer_Order.NPA_Sent_Flag, 
      Customer_Order.NPA_Recd_Flag, 
      Customer_Order.Sale_Cat, 
      Customer_Order.Order_Date_Time, 
      Customer_Order.Batch_Year_Of_Sale, 
      Customer_Order.Batch_Location_Id, 
      @UPPER(Stock_Item.Variety), 
      @UPPER(Stock_Item.Cult_Desc), 
      @UPPER(Stock_Item.Root_Desc), 
      Stock_Item.Cultivar_Id, 
      Stock_Item.Cult_Desc, 
      Stock_Item.Rootstock_Id, 
      Stock_Item.Root_Desc, 
      Stock_Item.Base_Price, 
      Stock_Item.CV_Non_Prop_Flag, 
      Stock_Item.RT_Non_Prop_Flag, 
      Stock_Item.Tree_Type, 
      Stock_Item.Type_Description, 
      Stock_Item.Top_Worked, 
      NULL  
  FROM  
      Customer_Master, 
      Customer_Order, 
      Stock_Item 
  INTO 
      :colCustNo, 
      :colAssCustNo, 
      :colCustName, 
      :colBusName, 
      :colBarCodeLblReqd, 
      :colCODFlag, 
      :colCustType, 
      :colCustFNAFlag, 
      :colCustOverFRCode, 
      :colCustRegionId, 
      :colStockItemNo, 
      :colSubItemNo, 
      :colConfAmt, 
      :colPurchOrdNo, 
      :colOrdContractPrice, 
      :colNPASentFlag, 
      :colNPARecdFlag, 
      :colSaleCat, 
      :colOrderDT, 
      :colBatchYearOfSale, 
      :colBatchLocationId, 
      :colUpperVariety, 
      :colUpperCultDesc, 
      :colUpperRootDesc, 
      :colCultId, 
      :colCultDesc, 
      :colRootId, 
      :colRootDesc, 
      :colPricePerUnit,
      :colCVNPAFlag, 
      :colRTNPAFlag, 
      :colTreeType, 
      :colTreeDesc, 
      :colTopWorked, 
      :colLoadId 
  WHERE 
      Customer_Master.Cust_No = :nCustNo AND 
      Customer_Order.Cust_No = :nCustNo AND 
      Customer_Order.Order_Date_Time IN ( " || sOrdDTList || " ) AND 
      Customer_Order.Year_Of_Sale = :nYear AND 
      Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
      NOT Customer_Order.Sale_Cat = 'CS'
  ORDER BY 
      Stock_Item.Variety_Type, 22, 23, 24, 
      Stock_Item.Tree_Type_Desc"

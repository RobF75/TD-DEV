.head 3 -  FunctionalVar: fcInvNoOutstandOrdsCst
.head 4 -  Class: numStack
.head 2 +  Named Menus
.head 2 +  Internal Functions
.head 3 +  Function: UnInvInvNo
.head 4 -  Description: Uninvoice Customer orders matching given invoice No.
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Number: nInvoiceNo
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  ! hcSqlHandle: fcOrdersHandle
.winattr class FunctionalVar:
.head 6 -  Class: hcSqlHandle
.end
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sName
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  Number: nInd
.head 5 -  Boolean: bOk
.head 5 -  !
.head 5 -  Date/Time: dtDateTime
.head 5 -  Number: nItemNo
.head 5 -  Number: nSubsItemNo
.head 5 -  Number: nConfAmt
.head 5 -  Number: nYear
.head 5 -  String: sGenericFlag
.head 5 -  Number: nSqlHandleNo
.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GETUNINVORD' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Call SalWaitCursor( TRUE )
.head 7 -  Set sSql = " SELECT Order_Date_Time,
  Stock_Item_No, 
  Subs_Item_No, 
  Conf_Amt , Year_Of_Sale     
FROM  Customer_Order 
WHERE Cust_No = :1  AND
  Invoice_No = :2 "
.head 7 -  Set sName = 'GETUNINVORD'
.head 7 -  Set sBind = ':nCustNo, :nInvoiceNo'
.head 7 -  Set sInto = ':dtDateTime, :nItemNo, :nSubsItemNo, :nConfAmt, :nYear'
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set dtDateTime = DATETIME_Null
.head 7 -  Set nItemNo = NUMBER_Null
.head 7 -  Set nSubsItemNo = NUMBER_Null
.head 7 -  Set nConfAmt = NUMBER_Null
.head 7 -  !
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 +  While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 +  If UnInvInvNoCustOrder( nCustNo, dtDateTime, SH_cls_Execute )
.head 10 -  Call UnInvInvNoCustOrder( 0, DATETIME_Null, SH_cls_Commit )
.head 9 +  If nSubsItemNo > 0
.head 10 +  If UnInvInvNoShippedForSub( nSubsItemNo, nYear, nConfAmt, SH_cls_Execute )
.head 11 -  Call UnInvInvNoShippedForSub( 0, 0, 0, SH_cls_Commit )
.head 10 -  Call GetGenericStockItemFlag( nItemNo, sGenericFlag, SH_cls_Execute )
.head 10 +  If sGenericFlag = 'Y'
.head 11 +  If UnInvInvNoShippedForItem( nItemNo, nYear, nConfAmt, SH_cls_Execute )
.head 12 -  Call UnInvInvNoShippedForItem( 0, 0, 0, SH_cls_Commit )
.head 11 -  Call UnInvInvNoRoyaltyForItem( nItemNo, nCustNo, nConfAmt, dtDateTime, SH_cls_Execute )
.head 9 +  Else
.head 10 +  If UnInvInvNoShippedForItem( nItemNo, nYear, nConfAmt, SH_cls_Execute )
.head 11 -  Call UnInvInvNoShippedForItem( 0, 0, 0, SH_cls_Commit )
.head 10 -  Call UnInvInvNoRoyaltyForItem( nItemNo, nCustNo, nConfAmt, dtDateTime, SH_cls_Execute )
.head 8 -  Call UnInvInvNoTotalsToFile( nCustNo, nInvoiceNo, SH_cls_Execute )
.head 8 +  If UnInvInvNoPOS( nCustNo, nInvoiceNo, SH_cls_Execute )
.head 9 -  Call UnInvInvNoPOS( 0, 0, SH_cls_Commit )
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Set bOk = TRUE

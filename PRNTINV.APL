.head 5 -  Set nTotalInvoice = nSubTotal - nDepositPaid
.head 3 -  !
.head 3 +  Function: DoesCustTreeReqLabels
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Number:
.head 4 +  Parameters
.head 5 -  Number: nConfAmt
.head 5 -  String: sSaleCat
.head 5 -  String: sTreeType
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If sSaleCat = 'NM'
.head 6 +  If SalStrScan( sTreeType, 'C%' ) < 0
.head 7 -  Return nConfAmt
.head 6 +  Else
.head 7 -  Return 0
.head 5 +  Else
.head 6 -  Return 0

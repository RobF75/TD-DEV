.head 4 -  Call PushNumber( nTotalRows )
.head 4 -  Return TRUE
.head 3 -  !
.head 3 +  On PAM_RESTOREROWS
.head 4 -  Call MyTableLoop( hWndForm, hWndForm, PAM_ROWACTION, 0, 0, 'Reseting Original Charges Calculations', nLowToHi )
.head 4 -  Return TRUE
.head 3 +  On PAM_ROWACTION
.head 4 -  Set colDelCharge = colOrgDelCharge
.head 4 -  Set colPackCharge = colOrgPackCharge
.head 4 -  Set colLabelCharge = colOrgLabelCharge
.head 4 -  Return TRUE
.head 3 -  !
.head 3 +  On PAM_ADDROW
.head 4 -  Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
.head 4 -  Set nTotalRows = nTotalRows + 1
.head 4 -  !
.head 4 -  Call PopNumber( colInvNo, TRUE )
.head 4 -  Call PopNumber( colCustNo, TRUE )
.head 4 -  Call PopNumber( colGrossAmt, TRUE )
.head 4 -  Call PopNumber( colDelCharge, TRUE )
.head 4 -  Call PopNumber( colPackCharge, TRUE )
.head 4 -  Call PopNumber( colLabelCharge, TRUE )
.head 4 -  Call PopNumber( colSubTotal, TRUE )
.head 4 -  Call PopNumber( colDepositPaid, TRUE )
.head 4 -  Call PopNumber( colTotalInvoice, TRUE )
.head 4 -  Call PopNumber( colTotalRoyalties, TRUE )
.head 4 -  Call PopNumber( colTotalTreePrices, TRUE )
.head 4 -  !
.head 4 -  Set colOrgDelCharge = colDelCharge
.head 4 -  Set colOrgPackCharge = colPackCharge
.head 4 -  Set colOrgLabelCharge = colLabelCharge
.head 4 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_New, FALSE )
.head 4 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_Edited, FALSE )
.head 4 -  Return TRUE
.head 3 -  !
.head 3 +  On PAM_LOOKUPCHARGECHANGES
.head 4 -  ! lParam is the Customer No we are searching for
.head 4 -  Set nRow = TBL_MinRow
.head 4 +  While SalTblFindNextRow( hWndForm, nRow, ROW_Edited, 0 )
.head 5 -  Call SalTblFetchRow( hWndForm, nRow )
.head 5 +  If colCustNo = lParam
.head 6 -  Call PushNumber( colDelCharge )
.head 6 -  Call PushNumber( colPackCharge )
.head 6 -  Call PushNumber( colLabelCharge )
.head 6 -  Return TRUE
.head 4 -  Return FALSE
.head 3 +  On PAM_SHOW
.head 4 -  Call SalShowWindow( hWndForm )
.head 4 -  Call SalBringWindowToTop( hWndForm )
.head 3 +  On PAM_HIDE
.head 4 -  Call SalHideWindow( hWndForm )
.head 3 +  On PAM_END
.head 4 -  Call SalDestroyWindow( hWndForm )
.head 3 -  !
.head 3 +  On PAM_CALCTOTALSTOTAL
.head 4 -  Set nTotalGrossAmt = nTotalGrossAmt + colGrossAmt
.head 4 -  Set nTotalDelCharge = nTotalDelCharge + colDelCharge
.head 4 -  Set nTotalPackCharge = nTotalPackCharge + colPackCharge
.head 4 -  Set nTotalLabelCharge = nTotalLabelCharge + colLabelCharge
.head 4 -  Set nTotalSubTotal = nTotalSubTotal + colSubTotal
.head 4 -  Set nTotalDepositPaid = nTotalDepositPaid + colDepositPaid
.head 4 -  Set nTotalTotalInvoice = nTotalTotalInvoice + colTotalInvoice
.head 4 -  Set nTotalTotalRoyalties = nTotalTotalRoyalties + colTotalRoyalties
.head 4 -  Set nTotalTotalTreePrice = nTotalTotalTreePrice + colTotalTreePrices
.head 4 -  Return TRUE

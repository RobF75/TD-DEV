.head 5 -  Receive Number: nRootRoy
.head 5 -  Receive Number: nExtRoyalty
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Set nExtRoyalty = NUMBER_Null
.head 5 +  If NOT ( sSaleCat = 'FC' OR sSaleCat = 'RP' )
.head 6 +  If sCultId != ''
.head 7 -  Call CalcCultivarRoyalty( nCustNo, sCultId, nItemNo, nCultRoy, SH_cls_Execute )
.head 7 -  Set nExtRoyalty =  nExtRoyalty + ( nCultRoy * nConfAmt )
.head 6 +  If sRootId != ''
.head 7 -  Call CalcRootstockRoyalty( nCustNo, sRootId, nItemNo, nRootRoy, SH_cls_Execute )
.head 7 -  Set nExtRoyalty =  nExtRoyalty + ( nRootRoy * nConfAmt )

.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'MAXDAYSINVNO' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT 
  MAX( Invoice_No ) 
FROM 
  Inv_No_Register 
WHERE 
  Invoice_No BETWEEN :1 AND :2 "
.head 7 -  Set sName = 'MAXDAYSINVNO'
.head 7 -  Set sBind = ':nMinInvNo, :nMaxInvNo'
.head 7 -  Set sInto = ':nGotMaxDaysInvNo'
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set sJulianDate = GetStrJulianDate( dtDate )
.head 7 -  Set nMinInvNo = SalStrToNumber( sJulianDate || '0000' )
.head 7 -  Set nMaxInvNo = SalStrToNumber( sJulianDate || '9999' )
.head 7 -  !
.head 7 -  Set nGotMaxDaysInvNo = NUMBER_Null
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 -  Call haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 8 +  If nGotMaxDaysInvNo > 0
.head 9 -  Set nFirstInvoiceNo = nGotMaxDaysInvNo + 1
.head 9 -  Set nLastInvoiceNo = nGotMaxDaysInvNo + nTotalNoInvNos
.head 8 +  Else
.head 9 -  Set nFirstInvoiceNo = nMinInvNo
.head 9 -  Set nLastInvoiceNo = nMinInvNo + nTotalNoInvNos - 1
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )

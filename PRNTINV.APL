.head 9 -  Call SalSendMsg( hWndForm, PAM_POPULATELOAD, 0, 0 )
.head 9 -  Call SalSendMsg( hWndForm, PAM_PRINTINVOICE, nINV_View, 0 )
.head 8 +  Else
.head 9 -  Call SalPostMsg( hWndForm, PAM_END, 0, 0 )
.head 7 +  Else
.head 8 -  Call SalPostMsg( hWndForm, PAM_END, 0, 0 )
.head 6 +  Else
.head 7 -  Call SalModalDialog( dlgInvDisplaySuspectItems, hWndForm, hWndTblInvSuspectItems, 'NO_BASE_PRICE' )
.head 7 -  Call SalPostMsg( hWndForm, PAM_END, 0, 0 )
.head 5 +  Else
.head 6 -  Call SalModalDialog( dlgInvDisplaySuspectItems, hWndForm, hWndTblInvSuspectItems, 'NOT_PULLED' )
.head 6 -  Call SalPostMsg( hWndForm, PAM_END, 0, 0 )
.head 4 +  Else If sInvoiceType = 'CUSTOMER'
.head 5 -  Call CheckCustNeedNPA( nCustNo, nYear, bNPAsNeeded, SH_cls_Execute )
.head 5 +  If bNPAsNeeded
.head 6 -  Set naNPANeededCustNos[ 0 ] = nCustNo
.head 6 -  Set naNPANeededCustNos[ 1 ] = NUMBER_Null
.head 6 -  Set nNPANeededCustNosCount = 1
.head 5 -  !
.head 5 -  Set bViewOnly = FALSE
.head 5 -  Call MakeDateTimeList( dtaOrderDT, ' , ', '', sOrdDTList )

  Customer_Order.Conf_Amt > 0 AND
  ( Stock_Item.RT_Non_Prop_Flag = 'Y' OR 
    Stock_Item.CV_Non_Prop_Flag = 'Y') AND 
  ( NOT Customer_Order.NPA_Recd_Flag = 'Y' OR 
    Customer_Order.NPA_Recd_Flag IS NULL ) AND
  NOT Customer_Order.Sale_Cat = 'RP' 

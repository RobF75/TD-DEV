.head 8 -  Set sSql = 'SELECT DepHist_Amt_Paid
      FROM Deposit_History
      INTO :nDepHistAmtPaid
      WHERE Deposit_History.Receipt_User_Id = :sReceiptUserId AND
            Deposit_History.Rcpt_sysdatetime = :dtReceiptDT AND
            Deposit_History.Trans_User_Id = :sTransUser AND
            Deposit_History.Trans_Sysdatetime = :dtDateTime AND
            Deposit_History.Cust_No = :nCustNo '
.head 8 +  If SqlPrepare( hSqlDepositHandle, sSql )
.head 9 -  Set bDepositHandlePrepared = TRUE
.head 8 +  Else
.head 9 -  Set bDepositHandlePrepared = FALSE
.head 7 -  !
.head 7 -  Set sInvoiceNo = SalNumberToStrX( nInvoiceNo, 0 )
.head 7 -  Set dtDateTime = DATETIME_Null
.head 7 -  Set sReceiptUserId = ''
.head 7 -  Set dtReceiptDT = DATETIME_Null
.head 7 -  !
.head 7 +  If SqlExecute( hSqlTransHandle )
.head 8 +  If SqlFetchNext( hSqlTransHandle, nInd )
.head 9 +  If nInd = FETCH_EOF
.head 10 -  Call SalMessageBox( 'Have been unable to retrieve the required invoice
details.   Please check that this is a current invoice with accounts', 'Uninvoicing', MB_Ok )
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Set nAppAmount = 0
.head 10 +  If SqlExecute( hSqlCashAppHandle )
.head 11 -  Set bFound = FALSE
.head 11 +  While SqlFetchNext( hSqlCashAppHandle, nInd ) AND NOT bFound
.head 12 +  If nAppAmount > 0
.head 13 +  If dtReceiptDT != DATETIME_Null
.head 14 +  If SqlExecute( hSqlDepositHandle )
.head 15 +  If SqlFetchNext( hSqlDepositHandle, nInd )
.head 16 -  Set bFound = FALSE
.head 15 +  Else
.head 16 -  Set bFound = TRUE
.head 14 +  Else
.head 15 -  Set bFound = TRUE
.head 13 +  Else
.head 14 -  Set bFound = TRUE
.head 11 +  If bFound
.head 12 -  Call SalMessageBox( 'You are unable to uninvoice this invoice as there has been cash or credits already applied to it', 'Uninvoicing', MB_Ok )
.head 12 -  Return TRUE
.head 11 +  Else
.head 12 -  Return FALSE
.head 10 +  Else
.head 11 -  Return FALSE
.head 8 +  Else
.head 9 -  Set bTransHandlePrepared = FALSE
.head 9 -  Call SalWaitCursor( FALSE )
.head 9 -  Call SalMessageBox( 'Have been unable to retrieve the required invoice
details, please check the invoice no you wish to uninvoice', 'Uninvoicing', MB_Ok )
.head 9 -  Return TRUE
.head 7 +  Else
.head 8 -  Set bTransHandlePrepared = FALSE
.head 8 -  Call SalWaitCursor( FALSE )
.head 8 -  Call SalMessageBox( 'Have been unable to retrieve the required invoice
details, please check the invoice no you wish to uninvoice', 'Uninvoicing', MB_Ok )
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Set bOk = TRUE
.head 7 -  Set bTransHandlePrepared = FALSE
.head 7 +  If bTransHandleConnected
.head 8 -  Set bTransHandleConnected = FALSE
.head 8 +  If NOT SqlDisconnect( hSqlTransHandle )
.head 9 -  Set bOk = FALSE
.head 7 -  Set bCashAppHandlePrepared = FALSE
.head 7 +  If bCashAppHandleConnected
.head 8 -  Set bCashAppHandleConnected = FALSE
.head 8 +  If NOT SqlDisconnect( hSqlCashAppHandle )
.head 9 -  Set bOk = FALSE
.head 7 -  Set bDepositHandlePrepared = FALSE
.head 7 +  If bDepositHandleConnected
.head 8 -  Set bDepositHandleConnected = FALSE
.head 8 +  If NOT SqlDisconnect( hSqlDepositHandle )
.head 9 -  Set bOk = FALSE
.head 7 -  Return bOk
.head 6 +  Case SH_cls_RePrepare
.head 7 -  Set bTransHandlePrepared = FALSE
.head 7 -  Set bCashAppHandlePrepared = FALSE
.head 7 -  Set bDepositHandlePrepared = FALSE
.head 7 -  Return TRUE
.head 3 -  !

.head 4 -  Set bNPAsNeeded = FALSE
.head 4 +  If sInvoiceType = 'LOAD'
.head 5 -  Call CheckLoadNeedNPAs( sLoadId, nYear, bNPAsNeeded, naNPANeededCustNos, nNPANeededCustNosCount, SH_cls_Execute )
.head 5 -  !
.head 5 -  Set bViewOnly = FALSE
.head 5 -  Call CheckLoadOrdersNotPulled( sLoadId, nYear, hWndTblInvSuspectItems, bOk, SH_cls_Execute )
.head 5 +  If bOk
.head 6 -  Call CheckLoadItemBasePrice( sLoadId, nYear, hWndTblInvSuspectItems, bOk, SH_cls_Execute )
.head 6 +  If bOk
.head 7 -  Call CheckLoadForwardOrders( sLoadId, nYear, hWndTblInvSuspectItems, bOk, SH_cls_Execute )
.head 7 +  If NOT bOk
.head 8 -  Set bOk = SalModalDialog( dlgInvDisplaySuspectItems, hWndForm, hWndTblInvSuspectItems, 'FORWARD_ORDERS' )
.head 7 +  If bOk
.head 8 -  Call CheckLoadCustInvNotes( sLoadId, bOk, SH_cls_Execute )

.head 6 +  Case SH_cls_Execute
.head 7 -  Call SalWaitCursor( TRUE )
.head 7 +  If NOT bOrdersHandleConnected
.head 8 -  Set bOrdersHandleConnected = SqlConnect( hSqlOrdersHandle )
.head 8 +  If bOrdersHandleConnected
.head 9 -  Call SqlSetLockTimeout( hSqlOrdersHandle, SQLTIMEOUT )
.head 9 -  Call SqlSetParameter( hSqlOrdersHandle, DBP_PRESERVE, TRUE, ''  )
.head 8 +  Else
.head 9 -  Call SalWaitCursor( FALSE )
.head 9 -  Call SalMessageBox( 'Connection in Database Error, could not obtain handle!', 'Error', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  If NOT bOrdersHandlePrepared
.head 8 -  Set sSql = 'SELECT Order_Date_Time, Credit_Note_No

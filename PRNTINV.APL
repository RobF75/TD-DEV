.head 4 -  Set nTableTotalRows = 0 
.head 4 -  Set nLastCustNo = NUMBER_Null
.head 4 -  !
.head 4 -  Set sSqlInvCust = " SELECT 
      Customer_Master.Cust_No, 
      Customer_Master.Ass_Cust_No, 
      Customer_Master.Cust_Name, 
      Customer_Master.Bus_Name, 
      Customer_Master.Bar_Code_Lbls_Reqd, 
      Customer_Master.COD_Flag, 

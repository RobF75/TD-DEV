.head 3 +  On PAM_POPULATELOAD
.head 4 -  Set nTableTotalRows = 0 
.head 4 -  Set nLastCustNo = NUMBER_Null
.head 4 -  !
.head 4 -  Set sSqlInvLoad = "  SELECT 
      Load_Customers.Freight_Code, 
      Load_Customers.Load_Order_Type, 
      Load_Customers.Deliv_Addr_DT, 
      Customer_Master.Cust_No, 
      Customer_Master.Ass_Cust_No, 
      Customer_Master.Cust_Name, 
      Customer_Master.Bus_Name, 
      Customer_Master.Bar_Code_Lbls_Reqd, 
      Customer_Master.COD_Flag, 
      Customer_Master.Customer_Type, 
      Customer_Master.FNA_Flag, 
      Customer_Master.Override_Frcode, 
      Customer_Master.Region_Id, 
      Customer_Order.Stock_Item_No, 
      Customer_Order.Subs_Item_No, 
      Customer_Order.Conf_Amt, 
      Customer_Order.Purchase_Order_No, 
      Customer_Order.Contract_Price, 
      Customer_Order.NPA_Sent_Flag, 
      Customer_Order.NPA_Recd_Flag, 
      Customer_Order.Sale_Cat, 
      Customer_Order.Order_Date_Time, 
      Customer_Order.Batch_Year_Of_Sale, 
      Customer_Order.Batch_Location_Id, 
      @UPPER(Stock_Item.Variety), 
      @UPPER(Stock_Item.Cult_Desc), 
      @UPPER(Stock_Item.Root_Desc), 
      Stock_Item.Cultivar_Id, 
      Stock_Item.Cult_Desc, 
      Stock_Item.Rootstock_Id, 
      Stock_Item.Root_Desc, 
      Stock_Item.Base_Price, 
      Stock_Item.CV_Non_Prop_Flag, 
      Stock_Item.RT_Non_Prop_Flag, 
      Stock_Item.Tree_Type, 
      Stock_Item.Type_Description, 
      Stock_Item.Top_Worked, 
      Load_Customers.Load_Id      
  FROM  
      Load_Customers, 
      Customer_Master, 
      Customer_Order, 
      Stock_Item 
  WHERE 
      Load_Customers.Load_Id = :1 AND 
      Load_Customers.Cust_No = Customer_Master.Cust_No AND 
      Load_Customers.Cust_No = Customer_Order.Cust_No AND 
      Customer_Order.Year_Of_Sale = :2 AND 
      Customer_Order.Load_Id = :1 AND 
      Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
      NOT Load_Customers.Cust_Inv_Flag = 'Y' AND
      Customer_Order.Pull_Sheet_Issued = 'Y' AND 
      NOT Customer_Order.Invoiced_Flag = 'Y' AND
      NOT Customer_Order.Sale_Cat = 'CS'
  ORDER BY 
      Load_Customers.Sequence_No, 
      Stock_Item.Variety_Type, 25, 26, 27, 
      Stock_Item.Tree_Type_Desc"
.head 4 -  Set sNameInvLoad = 'POPINVLOAD'
.head 4 -  Set sBindInvLoad = ':sLoadId, :nYear'
.head 4 -  Set sIntoInvLoad = ':colLoadCustFRCode, 
:colLoadOrdType, 
:colDelivAddrDT, 
:colCustNo, 
:colAssCustNo, 
:colCustName, 
:colBusName, 
:colBarCodeLblReqd, 
:colCODFlag, 
:colCustType, 
:colCustFNAFlag, 
:colCustOverFRCode, 
:colCustRegionId, 
:colStockItemNo, 
:colSubItemNo, 
:colConfAmt, 
:colPurchOrdNo, 
:colOrdContractPrice, 
:colNPASentFlag, 
:colNPARecdFlag, 
:colSaleCat, 
:colOrderDT, 
:colBatchYearOfSale,
:colBatchLocationId, 
:colUpperVariety, 
:colUpperCultDesc, 
:colUpperRootDesc, 
:colCultId, 
:colCultDesc, 
:colRootId, 
:colRootDesc, 
:colPricePerUnit,
:colCVNPAFlag, 
:colRTNPAFlag, 
:colTreeType, 
:colTreeDesc, 
:colTopWorked, 
:colLoadId'
.head 4 -  !
.head 4 -  Call fcOurInvLoadHandle.Setup( sSqlInvLoad, sNameInvLoad, sBindInvLoad, sIntoInvLoad )
.head 4 -  Call SqlVarSetup( fcOurInvLoadHandle.hSqlHandle )
.head 4 -  !
.head 4 -  Call fcOurInvLoadHandle.Execute( )
.head 4 -  Call fcOurInvLoadHandle.TablePopulate( hWndForm, TBL_FillAll )
.head 4 -  Call SalTblFetchRow( hWndForm, nTableTotalRows - 1 )
.head 4 -  Set colLastCustOrder = 'Y'
.head 4 -  Call SalTblFetchRow( hWndForm, 0 )
.head 3 +  On PAM_POPULATECUSTOMER
.head 4 -  Set nTableTotalRows = 0 
.head 4 -  Set nLastCustNo = NUMBER_Null
.head 4 -  !
.head 4 -  Set sSqlInvCust = " SELECT 
      Load_Customers.Freight_Code, 
      Load_Customers.Load_Order_Type, 
      Load_Customers.Deliv_Addr_DT, 
      Customer_Master.Cust_No, 
      Customer_Master.Ass_Cust_No, 
      Customer_Master.Cust_Name, 
      Customer_Master.Bus_Name, 
      Customer_Master.Bar_Code_Lbls_Reqd, 
      Customer_Master.COD_Flag, 
      Customer_Master.Customer_Type, 
      Customer_Master.FNA_Flag, 
      Customer_Master.Override_Frcode, 
      Customer_Master.Region_Id, 
      Customer_Order.Stock_Item_No, 
      Customer_Order.Subs_Item_No, 
      Customer_Order.Conf_Amt, 
      Customer_Order.Purchase_Order_No, 
      Customer_Order.Contract_Price, 
      Customer_Order.NPA_Sent_Flag, 
      Customer_Order.NPA_Recd_Flag, 
      Customer_Order.Sale_Cat, 
      Customer_Order.Order_Date_Time, 
      Customer_Order.Batch_Year_Of_Sale, 
      Customer_Order.Batch_Location_Id, 
      @UPPER(Stock_Item.Variety), 
      @UPPER(Stock_Item.Cult_Desc), 
      @UPPER(Stock_Item.Root_Desc), 
      Stock_Item.Cultivar_Id, 
      Stock_Item.Cult_Desc, 
      Stock_Item.Rootstock_Id, 
      Stock_Item.Root_Desc, 
      Stock_Item.Base_Price, 
      Stock_Item.CV_Non_Prop_Flag, 
      Stock_Item.RT_Non_Prop_Flag, 
      Stock_Item.Tree_Type, 
      Stock_Item.Type_Description, 
      Stock_Item.Top_Worked, 
      Load_Customers.Load_Id  
  FROM  
      Load_Customers, 
      Customer_Master, 
      Customer_Order, 
      Stock_Item 
  INTO 
      :colLoadCustFRCode, 
      :colLoadOrdType, 
      :colDelivAddrDT, 
      :colCustNo, 
      :colAssCustNo, 
      :colCustName, 
      :colBusName, 
      :colBarCodeLblReqd, 
      :colCODFlag, 
      :colCustType, 
      :colCustFNAFlag, 
      :colCustOverFRCode, 
      :colCustRegionId, 
      :colStockItemNo, 
      :colSubItemNo, 
      :colConfAmt, 
      :colPurchOrdNo, 
      :colOrdContractPrice, 
      :colNPASentFlag, 
      :colNPARecdFlag, 
      :colSaleCat, 
      :colOrderDT, 
      :colBatchYearOfSale, 
      :colBatchLocationId, 
      :colUpperVariety, 
      :colUpperCultDesc, 
      :colUpperRootDesc, 
      :colCultId, 
      :colCultDesc, 
      :colRootId, 
      :colRootDesc, 
      :colPricePerUnit,
      :colCVNPAFlag, 
      :colRTNPAFlag, 
      :colTreeType, 
      :colTreeDesc, 
      :colTopWorked, 
      :colLoadId 
  WHERE 
      Load_Customers.Cust_No = :nCustNo AND 
      Load_Customers.Load_Id = :sLoadId AND 
      Load_Customers.Cust_No = Customer_Master.Cust_No AND 
      Load_Customers.Cust_No = Customer_Order.Cust_No AND 
      Customer_Order.Order_Date_Time IN ( " || sOrdDTList || " ) AND 
      Customer_Order.Year_Of_Sale = :nYear AND 
      Customer_Order.Load_Id = :sLoadId AND 
      Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
      Customer_Order.Pull_Sheet_Issued = 'Y' AND 
      NOT Customer_Order.Invoiced_Flag = 'Y' AND
      NOT Customer_Order.Sale_Cat = 'CS'
  ORDER BY 
      Load_Customers.Sequence_No, 
      Stock_Item.Variety_Type, 25, 26, 27, 
      Stock_Item.Tree_Type_Desc"
.head 4 -  !
.head 4 -  Call fcOurInvCustHandle.PrepareSetup( sSqlInvCust )
.head 4 -  Call SqlVarSetup( fcOurInvCustHandle.hSqlHandle )
.head 4 -  !
.head 4 -  Call fcOurInvCustHandle.PrepareAndExecute( )
.head 4 -  Call fcOurInvCustHandle.TablePopulate( hWndForm, TBL_FillAll )
.head 4 -  Call SalTblFetchRow( hWndForm, nTableTotalRows - 1 )
.head 4 -  Set colLastCustOrder = 'Y'
.head 4 -  Call SalTblFetchRow( hWndForm, 0 )

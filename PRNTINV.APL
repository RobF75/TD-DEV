.head 3 +  Function: CalcInvGrossNSubTotals
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Number: nCustTotalExtPrice
.head 5 -  Number: nCustTotalExtRoyalty
.head 5 -  Number: nDelCharge
.head 5 -  Number: nPackCharge
.head 5 -  Number: nLabelCharge
.head 5 -  Receive Number: nGrossAmt
.head 5 -  Receive Number: nSubTotal
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 -  Set nGrossAmt = nCustTotalExtPrice + nCustTotalExtRoyalty
.head 5 -  Set nSubTotal = nGrossAmt + nDelCharge + nPackCharge + nLabelCharge
.head 3 +  Function: CalcInvTotalInvoice
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Number: nSubTotal
.head 5 -  Number: nDepositPaid
.head 5 -  Receive Number: nTotalInvoice
.head 4 -  Static Variables
.head 4 -  Local variables

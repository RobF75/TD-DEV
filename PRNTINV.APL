.head 3 +  Function: CalcItemExtPrice
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Number: nCustNo
.head 5 -  Number: nItemNo
.head 5 -  Number: nYear
.head 5 -  String: sSaleCat
.head 5 -  Number: nContractPrice
.head 5 -  Number: nConfAmt
.head 5 -  Receive Number: nPricePerUnit
.head 5 -  Receive Number: nExtPrice
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Boolean: bFound
.head 5 -  Number: nQuotPrice
.head 5 -  Number: nBillCustNo
.head 5 -  String: sSupplier
.head 4 +  Actions
.head 5 +  If nContractPrice != NUMBER_Null
.head 6 -  Set nPricePerUnit = nContractPrice
.head 5 +  Else
.head 6 -  Set bFound = FALSE
.head 6 -  Call GetCustItemQuotPrice( nCustNo, nYear, sSupplier, nItemNo, bFound, nQuotPrice, SH_cls_Execute )
.head 6 +  If bFound
.head 7 -  Set nPricePerUnit = nQuotPrice
.head 6 +  Else
.head 7 -  Call GetBillingParent( nCustNo, nBillCustNo, SH_cls_Execute )
.head 7 +  If nBillCustNo > 0
.head 8 -  Call GetCustItemQuotPrice( nBillCustNo, nYear, sSupplier, nItemNo, bFound, nQuotPrice, SH_cls_Execute )
.head 8 +  If bFound
.head 9 -  Set nPricePerUnit = nQuotPrice
.head 6 -  !
.head 6 +  If sSaleCat = 'FC' OR colSaleCat = 'RP'
.head 7 -  Set nPricePerUnit = 0
.head 6 +  Else If sSaleCat = 'HP'
.head 7 -  Set nPricePerUnit = nPricePerUnit / 2
.head 5 -  Set nExtPrice = nPricePerUnit * nConfAmt
.head 3 +  Function: CalcPOSItemExtPrice
.head 4 -  Description:
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Number: nContractPrice
.head 5 -  Number: nOverridePercent
.head 5 -  Number: nConfAmt
.head 5 -  Number: nTotalCustTreeExtPriceNoPOS
.head 5 -  Receive Number: nPricePerUnit
.head 5 -  Receive Number: nExtPrice
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If nContractPrice != NUMBER_Null
.head 6 -  Set nPricePerUnit = nContractPrice
.head 6 -  Set nExtPrice = nPricePerUnit * nConfAmt
.head 5 +  Else If nOverridePercent != NUMBER_Null
.head 6 -  Set nExtPrice = nTotalCustTreeExtPriceNoPOS * nOverridePercent
.head 5 +  Else
.head 6 -  Set nExtPrice = nPricePerUnit * nConfAmt

.head 8 +  If bOk
.head 9 +  If CheckCustomersNotes( nCustNo, 'Invoice Notes', SH_cls_Execute )
.head 10 -  Call SalSendMsg( hWndForm, PAM_POPULATECUSTOMER, 0, 0 )
.head 10 -  Call SalSendMsg( hWndForm, PAM_PRINTINVOICE, nINV_View, 0 )
.head 9 +  Else

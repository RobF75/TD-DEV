.head 6 -  Call SalSendMsg( hWndForm, PAM_POPULATECUSTOMERPOSONLY, 0, 0 )
.head 6 -  Call SalSendMsg( hWndForm, PAM_PRINTINVOICE, nINV_View, 0 )
.head 5 +  Else

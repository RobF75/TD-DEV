.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nInd
.head 5 -  Number: nSqlHandleNo
.head 5 -  !
.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( '0406GetUser' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = "
SELECT
	Name
FROM
  	HH_Users
WHERE
  	Id = :1
	"
.head 7 -  Set sName = '0406GetUser'
.head 7 -  Set sBind = ':nUserRef'
.head 7 -  Set sInto = ':sUser'
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Return FALSE
.head 7 -  !
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 7 -  Return TRUE

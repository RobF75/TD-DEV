.head 4 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 3 +  On SAM_Close
.head 4 -  Call SalFileClose( fhPullLogFile )
.head 4 -  Call GetUserDetails( 0, sTmp, SH_cls_Disconnect)
.head 4 -  Call GetItemFullBasicDetails( 0, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Disconnect )
.head 4 -  Call GetCustDetails( 0, sTmp, sTmp, SH_cls_Disconnect )
.head 4 -  Return TRUE

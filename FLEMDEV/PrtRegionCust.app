.head 2 +  Message Actions
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set sPrinter = 'SmallFanFold'
.head 4 -  Set sReportFileNameNoPath = 'PrtRegCust.qrp'
.head 4 -  !
.head 4 -  Set sReportBind = ':frmPrintRegionsCust.nCustNo, 
  :frmPrintRegionsCust.sCustName, 
  :frmPrintRegionsCust.sRegionId, 
  :frmPrintRegionsCust.sRegionDesc'
.head 4 -  Set sReportInto = 'nCustNo, 
  sCustName, 
  sRegionId, 
  sRegionDesc'
.head 4 -  Set sReportType = sReportPrintOrView
.head 3 +  On PAM_clsFRM_REPORTSTART
.head 4 +  If sRegionType = 'ALL'
.head 5 +  If sCustType = 'ANY'
.head 6 -  Set sReportSql = "SELECT 
  Customer_Master.Cust_No, 
  Customer_Master.Cust_Name, 
  Customer_Master.Region_Id, 
  Region.Region_Desc 
FROM 
  Customer_Master, 
  Region 
INTO 
  :frmPrintRegionsCust.nCustNo, 
  :frmPrintRegionsCust.sCustName, 
  :frmPrintRegionsCust.sRegionId, 
  :frmPrintRegionsCust.sRegionDesc 
WHERE 
  Customer_Master.Region_Id = Region.Region_Id 
ORDER BY 
  Region.Region_Desc, Customer_Master.Cust_Name "
.head 5 +  Else If sCustType = 'GARDENCENTRES'
.head 6 -  Set sReportSql = "SELECT 
  Customer_Master.Cust_No, 
  Customer_Master.Cust_Name, 
  Customer_Master.Region_Id, 
  Region.Region_Desc 
FROM 
  Customer_Master, 
  Region 
INTO 
  :frmPrintRegionsCust.nCustNo, 
  :frmPrintRegionsCust.sCustName, 
  :frmPrintRegionsCust.sRegionId, 
  :frmPrintRegionsCust.sRegionDesc 
WHERE 
  Customer_Master.Region_Id = Region.Region_Id AND 
  Customer_Master.Customer_Type LIKE '%GC%' 
ORDER BY 
  Region.Region_Desc, Customer_Master.Cust_Name "
.head 5 +  Else
.head 6 -  Set sReportSql = "SELECT 
  Customer_Master.Cust_No, 
  Customer_Master.Cust_Name, 
  Customer_Master.Region_Id, 
  Region.Region_Desc 
FROM 
  Customer_Master, 
  Region 
INTO 
  :frmPrintRegionsCust.nCustNo, 
  :frmPrintRegionsCust.sCustName, 
  :frmPrintRegionsCust.sRegionId, 
  :frmPrintRegionsCust.sRegionDesc 
WHERE 
  Customer_Master.Region_Id = Region.Region_Id AND 
  Customer_Master.Customer_Type LIKE '%OR%' 
ORDER BY 
  Region.Region_Desc, Customer_Master.Cust_Name "
.head 4 +  Else
.head 5 +  If sCustType = 'ANY'
.head 6 -  Set sReportSql = "SELECT 
  Customer_Master.Cust_No, 
  Customer_Master.Cust_Name, 
  Customer_Master.Region_Id, 
  Region.Region_Desc 
FROM 
  Customer_Master, 
  Region 
INTO 
  :frmPrintRegionsCust.nCustNo, 
  :frmPrintRegionsCust.sCustName, 
  :frmPrintRegionsCust.sRegionId, 
  :frmPrintRegionsCust.sRegionDesc 
WHERE 
  Customer_Master.Region_Id = Region.Region_Id AND 
  Customer_Master.Region_Id IN ( " || sSelectedRegionIdList || " ) 
ORDER BY 
  Region.Region_Desc, Customer_Master.Cust_Name "
.head 5 +  Else If sCustType = 'GARDENCENTRES'
.head 6 -  Set sReportSql = "SELECT 
  Customer_Master.Cust_No, 
  Customer_Master.Cust_Name, 
  Customer_Master.Region_Id, 
  Region.Region_Desc 
FROM 
  Customer_Master, 
  Region 
INTO 
  :frmPrintRegionsCust.nCustNo, 
  :frmPrintRegionsCust.sCustName, 
  :frmPrintRegionsCust.sRegionId, 
  :frmPrintRegionsCust.sRegionDesc 
WHERE 
  Customer_Master.Region_Id = Region.Region_Id AND 
  Customer_Master.Customer_Type LIKE '%GC%' AND 
  Customer_Master.Region_Id IN ( " || sSelectedRegionIdList || " ) 
ORDER BY 
  Region.Region_Desc, Customer_Master.Cust_Name "
.head 5 +  Else
.head 6 -  Set sReportSql = "SELECT 
  Customer_Master.Cust_No, 
  Customer_Master.Cust_Name, 
  Customer_Master.Region_Id, 
  Region.Region_Desc 
FROM 
  Customer_Master, 
  Region 
INTO 
  :frmPrintRegionsCust.nCustNo, 
  :frmPrintRegionsCust.sCustName, 
  :frmPrintRegionsCust.sRegionId, 
  :frmPrintRegionsCust.sRegionDesc 
WHERE 
  Customer_Master.Region_Id = Region.Region_Id AND 
  Customer_Master.Customer_Type LIKE '%OR%' AND 
  Customer_Master.Region_Id IN ( " || sSelectedRegionIdList || " ) 
ORDER BY 
  Region.Region_Desc, Customer_Master.Cust_Name "

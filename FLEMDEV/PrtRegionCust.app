.head 4 +  Message Actions
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sSQLPopHandle = " SELECT 
  Region.Region_Id, 
  Region.Region_Desc 
FROM 
  Region 
ORDER BY 
  Region.Region_Desc "
.head 6 -  Set sNAMEPopHandle = 'POPSELREGS'
.head 6 -  Set sBINDPopHandle = ''
.head 6 -  Set sINTOPopHandle = ':frmRegionsCustomers.tblSelectedRegions.colRegionId,
  :frmRegionsCustomers.tblSelectedRegions.colRegionDesc'
.head 6 -  !
.head 6 -  Set bAddAllowed = TRUE
.head 6 -  Set bPopulated = FALSE
.head 5 +  On PAM_clsTBL_POPULATE
.head 6 -  Set bPopulated = TRUE
.head 6 -  Return SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
.head 5 +  On PAM_clsREGCUST_GETSELREGIDS
.head 6 -  Set sRegionIdList = ''
.head 6 +  If TableLoop( hWndForm, hWndForm, PAM_clsPRTREGIONCUST_GETSELECTED, 0, ROW_UnusedFlag1, 0, 'Extracting Selected Regions', TBL_cls_LowToHi )
.head 7 +  If sRegionIdList = ''
.head 8 -  Return FALSE
.head 7 +  Else
.head 8 -  Call PushString( sRegionIdList )
.head 8 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  On PAM_clsPRTREGIONCUST_GETSELECTED
.head 6 +  If sRegionIdList = ''
.head 7 -  Set sRegionIdList = "'" || sRegionIdList || "'"
.head 6 +  Else
.head 7 -  Set sRegionIdList = sRegionIdList || ', ' || "'" || colRegionId || "'"
.head 6 -  Return TRUE

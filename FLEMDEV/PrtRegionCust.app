.head 5 +  Message Actions
.head 6 +  On PAM_clsPB_CLICK
.head 7 +  If rbGardenCentres
.head 8 -  Set sCustType = 'GARDENCENTRES'
.head 7 +  Else If rbOrchardists
.head 8 -  Set sCustType = 'ORCHARDISTS'
.head 7 +  Else
.head 8 -  Set sCustType = 'ANY'
.head 7 -  !
.head 7 +  If rbSelectedRegions
.head 8 -  Set sRegionType = 'SELECTED'
.head 8 +  If SalSendMsg( tblSelectedRegions, PAM_clsREGCUST_GETSELREGIDS, 0, 0 )
.head 9 -  Call PopString( sSelectedRegionIdList, TRUE )
.head 8 +  Else
.head 9 -  Call SalMessageBox( 'Please select some Regions by placing a tick in the Selected column first, or choose All.', 'Warning', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Set sRegionType = 'ALL'
.head 7 -  !
.head 7 +  If rbView
.head 8 -  Set sReportType = 'VIEW'
.head 7 +  Else
.head 8 -  Set sReportType = 'PRINT'
.head 7 -  !
.head 7 +  If hWndReport = hWndNULL
.head 8 -  Set hWndReport = SalCreateWindow( frmPrintRegionsCust, hWndForm, sSelectedRegionIdList, 
ccSeasonYear.GetSeasonYear( ), sRegionType, sCustType, sReportType )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Call SalMessageBox( 'Please close down your first report!', 'Warning', MB_Ok )
.head 8 -  Return FALSE

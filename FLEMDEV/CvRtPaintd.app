.head 3 -  String: sPaintCode2
.head 2 +  Message Actions 
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set sReportFileNameNoPath = 'Itmpcode2.qrp'
.head 4 -  Set sReportBind = ':frmCvRtPaints.nYear, 
  :frmCvRtPaints.sCultOrRoot, 
  :frmCvRtPaints.sDescription, 
  :frmCvRtPaints.sPaintCode1, 
  :frmCvRtPaints.sPaintCode2'
.head 4 -  Set sReportInto = 'YearOfSale, 
  CultOrRoot, 
  Description, 
  PaintCode1, 
  PaintCode2'
.head 4 -  Set sReportType = 'VIEW'
.head 4 -  !
.head 4 -  Set sReportSql = " SELECT 
  'C', 
  Cultivar.Cult_Desc, 
  CPU1.Paint_Id, 
  CPU2.Paint_Id
FROM 
  Cult_Paint_Used CPU1, 
  Cult_Paint_Used CPU2, 
  Cultivar 
INTO 
  :frmCvRtPaints.sCultOrRoot, 
  :frmCvRtPaints.sDescription, 
  :frmCvRtPaints.sPaintCode1, 
  :frmCvRtPaints.sPaintCode2 
WHERE 
  CPU1.Cult_Year_Used = :frmCvRtPaints.nYear AND 
  CPU1.Cultivar_Id = CPU2.Cultivar_Id AND 
  CPU1.Cult_Year_Used = CPU2.Cult_Year_Used AND 
  CPU1.CV_Paint_Number = 1 AND 
  CPU1.Paint_Id = CPU1.Paint_Id AND 
  CPU1.Cultivar_Id = Cultivar.Cult_Id AND 
  CPU2.Cultivar_Id = Cultivar.Cult_Id 
ORDER BY 
  CPU1.Paint_Id, 
  CPU2.Paint_Id "
.head 3 +  On PAM_clsFRM_REPORTSTART
.head 4 -  Set nYear = WhichSeasonYear( SalDateCurrent(  ) )
.head 4 -  Return TRUE

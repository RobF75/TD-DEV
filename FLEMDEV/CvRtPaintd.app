.head 3 +  On SAM_ReportStart
.head 4 -  Set nYear = WhichSeasonYear( SalDateCurrent(  ) )
.head 4 -  !
.head 4 -  Set sSql = " SELECT 
  'R', 
  @UPPER( Rootstock.Root_Desc ), 
  Rootstock.Root_Desc, 
  RPU1.Rt_Paint_Number, 
  RPU1.Paint_Id, 
  RPU2.Rt_Paint_Number, 
  RPU2.Paint_Id
FROM 
  Rtstck_Paint_Used RPU1, 
  Rtstck_Paint_Used RPU2, 
  Rootstock 
INTO 
  :frmCvRtPaints.sCultOrRoot, 
  :frmCvRtPaints.sUpperDesc, 
  :frmCvRtPaints.sDescription, 
  :frmCvRtPaints.sPaintNumber1, 
  :frmCvRtPaints.sPaintCode1, 
  :frmCvRtPaints.sPaintNumber2, 
  :frmCvRtPaints.sPaintCode2 
WHERE 
  RPU1.Rt_Year_Used = :frmCvRtPaints.nYear AND 
  RPU1.Rootstock_Id = RPU2.Rootstock_Id AND 
  RPU1.Rt_Year_Used = RPU2.Rt_Year_Used AND 
  RPU1.Rt_Paint_Number = 1 AND 
  RPU1.Paint_Id = RPU1.Paint_Id AND 
  RPU1.Rootstock_Id = Rootstock.Root_Id AND 
  RPU2.Rootstock_Id = Rootstock.Root_Id 
ORDER BY 5,7,2 "
.head 4 -  Call fcReportRootsHdl.PrepareSetup( sSql )
.head 4 -  !
.head 4 -  Set sSql = " SELECT 
  'C', 
  @UPPER( Cultivar.Cult_Desc ), 
  Cultivar.Cult_Desc, 
  CPU1.CV_Paint_Number, 
  CPU1.Paint_Id, 
  CPU2.CV_Paint_Number, 
  CPU2.Paint_Id
FROM 
  Cult_Paint_Used CPU1, 
  Cult_Paint_Used CPU2, 
  Cultivar 
INTO 
  :frmCvRtPaints.sCultOrRoot, 
  :frmCvRtPaints.sUpperDesc, 
  :frmCvRtPaints.sDescription, 
  :frmCvRtPaints.sPaintNumber1, 
  :frmCvRtPaints.sPaintCode1, 
  :frmCvRtPaints.sPaintNumber2, 
  :frmCvRtPaints.sPaintCode2 
WHERE 
  CPU1.Cult_Year_Used = :frmCvRtPaints.nYear AND 
  CPU1.Cultivar_Id = CPU2.Cultivar_Id AND 
  CPU1.Cult_Year_Used = CPU2.Cult_Year_Used AND 
  CPU1.CV_Paint_Number = 1 AND 
  CPU1.Paint_Id = CPU1.Paint_Id AND 
  CPU1.Cultivar_Id = Cultivar.Cult_Id AND 
  CPU2.Cultivar_Id = Cultivar.Cult_Id 
ORDER BY 5,7,2 "
.head 4 -  Call fcReportCultsHdl.PrepareSetup( sSql )
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchInit
.head 4 -  Set bOk = TRUE
.head 4 -  Set bRootstocks = TRUE
.head 4 -  Set bCultivars = FALSE
.head 4 +  If NOT fcReportRootsHdl.PrepareAndExecute( )
.head 5 -  Set bOk = FALSE
.head 4 +  If NOT fcReportCultsHdl.PrepareAndExecute(  )
.head 5 -  Set bOk = FALSE
.head 4 -  Return bOk
.head 3 +  On SAM_ReportFetchNext
.head 4 +  If bRootstocks
.head 5 +  If fcReportRootsHdl.FetchNext( nInd )
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Set bRootstocks = FALSE
.head 6 -  Set bCultivars = TRUE
.head 4 +  If bCultivars
.head 5 +  If fcReportCultsHdl.FetchNext( nInd )
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Set bCultivars = FALSE
.head 6 -  Return FALSE
.head 3 +  On SAM_ReportFinish
.head 4 -  Call fcReportRootsHdl.Disconnect( )
.head 4 -  Call fcReportCultsHdl.Disconnect(  )

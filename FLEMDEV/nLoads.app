.head 7 -  Number: nInd
.head 7 -  !
.head 7 -  Date/Time: dtCurrent
.head 6 +  Actions
.head 7 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( '1105InsertPromoItem' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = "
INSERT INTO
	Cust_Promo
	 	(
		Cust_no, 
		Promo_Id,
		Promo_DT_Stamp,
		Override_Price,
		No_Units,
		Year_Of_Order,
		Promo_Sent_Flag,

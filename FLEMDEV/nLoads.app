.head 3 +  On PAM_clsFRM_REPORTSTART
.head 4 -  Set sReportSql = "
SELECT
	cm.Cust_no,
	Cust_Name,
	sum(Conf_Amt)
FROM	
	Customer_Master cm,
	Customer_Order co,
	stock_item
INTO
	:frmBrochures.nCustNo,
	:frmBrochures.sCustName,
	:frmBrochures.nConfAmt
WHERE
	stock_item_no = item_no and
	cm.cust_no = co.cust_no and
	co.year_of_sale = :frmBrochures.nYear and
	customer_type like 'GC_' and
	not customer_type = 'GCZ' and
	Stock_type = 'B'
GROUP BY
	cm.Cust_no,
	Cust_Name
ORDER BY
	Cust_Name"
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_POPFIELDS
.head 4 -  Call PopNumber( nYear, TRUE )
.head 4 -  Call PopWndHdl( hParent, TRUE )
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFETCHNEXT
.head 4 +  If nConfAmt > 100
.head 5 -  ! Set nBrochureCount = SalNumberRound( nConfAmt - 30 )
.head 5 -  Set nPackCount = SalNumberRound((nConfAmt - 30) / 100)
.head 5 -  Set nBrochureCount = nPackCount * 25
.head 4 +  Else
.head 5 +  If nConfAmt > 90
.head 6 -  Set nBrochureCount = 25
.head 6 -  Set nPackCount = 1
.head 5 +  Else
.head 6 -  Set nBrochureCount = 0
.head 6 -  Set nPackCount = 0
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFINISH
.head 4 -  Return TRUE
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Call SalSendMsg( hWndForm, PAM_clsFRM_POPFIELDS, 0, 0 )
.head 4 -  Set sReportBind = '
	:frmBrochures.nCustNo,
	:frmBrochures.sCustName,
	:frmBrochures.nConfAmt,
	:frmBrochures.nBrochureCount,
	:frmBrochures.nPackCount'
.head 4 -  Set sReportInto = '
	:nCustNo,
	:sCustName,
	:nConfAmt,
	:nBrochureCount,
	:nPackCount'
.head 4 -  Set sReportFileNameNoPath = 'Brochure.qrp'
.head 4 -  Set sPrinter = 'Laser'
.head 4 -  Set sReportType = 'PRINT'
.head 4 -  Return TRUE

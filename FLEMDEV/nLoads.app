.head 7 -  Set sSQLRefreshHandle =
"
Select
	Sequence_No,
	Load_Cust_Inst_No,
	Cust_No,
	Cust_Name,
	sum(ordered_amount),
	Sum(Conf_amt)
From
	Load_customers lc,
	Customer_Master cm,
	Customer_Order
WHere
	lc.cust_no = cm.cust_no and
	cm.cust_no = co.cust_no and
	load_id = :1
Group by
	Sequence_No,
	Load_Cust_Inst_No,
	Cust_No,
	Cust_Name,
Order By
	Sequence_No
"

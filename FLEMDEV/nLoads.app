.head 7 -  Set sSQLPopHandle =
"
Select
	Sequence_No,
	lc.Load_Cust_Inst_No,
	cm.Cust_No,
	Cust_Name,
	sum(ordered_amount),
	Sum(Conf_amt)
From
	Load_customers lc,
	Customer_Master cm,
	Customer_Order co
WHere
	lc.cust_no = cm.cust_no and
	cm.cust_no = co.cust_no and
	lc.load_id = :1
Group by
	Sequence_No,
	lc.Load_Cust_Inst_No,
	cm.Cust_No,
	Cust_Name
Order By
	Sequence_No
"

.head 5 +  Function: CalcCorfluteStockOnOrder
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  Number: nCustNo
.head 7 -  String: sCorflute
.head 7 -  Number: nYear
.head 7 -  Receive Number: nAmt
.head 7 -  Number: nActionType
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  String: sBind
.head 7 -  String: sInto
.head 7 -  String: sName
.head 7 -  Number: nSqlHandleNo
.head 7 -  Number: nInd
.head 7 -  !
.head 6 +  Actions
.head 7 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( '1105GetCustOrderCor' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = " SELECT
  	sum(conf_amt)
FROM
	Customer_Order co,
	Stock_Item si,
	Cultivar c
WHERE
	c.cult_id = si.Cultivar_id and
	item_no = stock_item_no and
  	Cust_No = :1 and
	year_of_sale = :2 and
	Corflute_Id = :3 and	
	stock_type = 'B'"
.head 9 -  Set sName = '2305GetCustOrderCor'
.head 9 -  Set sBind = ':nCustNo, :nYear, :sCorflute '
.head 9 -  Set sInto = ':nAmt'
.head 9 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 9 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 -  !
.head 9 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 10 +  If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 -  Return FALSE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 5 +  Function: InsertFreePromoItem
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  Number: nCustNo

.head 8 -  Set nTemperature = nTemperature - 0.5
.head 8 -  Call SalNumberRound( nTemperature )
.head 8 -  Set nCount = 0
.head 8 +  While naTemps[nCount].nTemperature < nTemperature
.head 9 -  Set nCount = nCount + 1
.head 8 -  Set naTemps[nCount].nTotalHours = naTemps[nCount].nTotalHours + 1

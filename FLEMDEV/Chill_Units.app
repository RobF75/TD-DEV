.head 5 +  On PAM_cls_ANALISETABLEDATA
.head 6 +  If rbUtah
.head 7 -  Set nRow = TBL_MinRow
.head 7 -  Set nTotalTemperature = 0
.head 7 -  Set nNoOfReadings = 0
.head 7 -  Set nTemperature = 0
.head 7 -  Set nTotalChill = 0
.head 7 -  Set dtPreviousReadingDate = DATETIME_Null
.head 7 +  If SalTblAnyRows( hWndItem, ROW_Selected, 0 )
.head 8 +  While SalTblFindNextRow( hWndItem, nRow, ROW_Selected, 0 )
.head 9 -  Call SalTblFetchRow( hWndItem, nRow )
.head 9 -  Set nNoOfReadings = nNoOfReadings + 1
.head 9 -  Set dtReadingDate = SalStrToDate( colsData2 )
.head 9 -  Set nDay = SalDateDay( dtReadingDate )
.head 9 -  Set nTemperature = SalStrToNumber( colsData3 )
.head 9 +  If dtPreviousReadingDate != DATETIME_Null
.head 10 -  Call CompareDatesReturnDifference( dtPreviousReadingDate, dtReadingDate, nYear, nMonth, nDay, nHour, nMinute, nSecond )
.head 10 -  Set nTotalMinutes = (nHour / 60) + nMinute
.head 10 +  If nYear != 0 and nMonth != 0 and nDay != 0 and nTotalMinutes > 60
.head 11 -  Call SalMessageBox('The temperature readings selected have been taken > 1 hour apart, this is not valid sample data', 'Error', MB_Ok)  
.head 11 -  Return FALSE
.head 10 +  If nTemperature > 1.4 and nTemperature <= 2
.head 11 -  Set nTotalChill = nTotalChill + (( nTotalMinutes / 60 ) / 2)
.head 10 +  Else If nTemperature > 2 and nTemperature <= 9
.head 11 -  Set nTotalChill = nTotalChill + (nTotalMinutes / 60) 
.head 10 +  Else If nTemperature > 9 and nTemperature <= 12
.head 11 -  Set nTotalChill = nTotalChill + ((nTotalMinutes / 60)  / 2)
.head 10 +  Else If nTemperature > 15 and nTemperature <= 18
.head 11 -  Set nTotalChill = nTotalChill - ((nTotalMinutes / 60)  / 2)
.head 10 +  Else If nTemperature > 18
.head 11 -  Set nTotalChill = nTotalChill - (nTotalMinutes / 60) 
.head 9 -  Set dtPreviousReadingDate = dtReadingDate
.head 9 -  Set nTotalTemperature = nTotalTemperature + nTemperature
.head 8 -  Set dfAverage =  nTotalTemperature / nNoOfReadings 
.head 8 -  Set dfChill =  nTotalChill
.head 6 -  Set nTemp = -10
.head 6 -  Set nCount = 0
.head 6 +  While nCount < 100
.head 7 -  Set naTemps[nCount].nTemperature = nTemp
.head 7 -  Set naTemps[nCount].nTotalHours = 0
.head 7 -  Set nTemp = nTemp + 1
.head 7 -  Set nCount = nCount + 1
.head 6 -  Set nRow = TBL_MinRow

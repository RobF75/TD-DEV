.head 4 -  !
.head 4 -  Set sReportSql = "
SELECT
	cm.cust_no,
	cust_name,
	cult_desc,
	root_desc,
	variety_type,
	variety,
	year_of_sale,
	Item_No,
	Order_Date_Time
FROM
	cust_order_history co,
	customer_master cm,
	stock_item si
INTO
	:frmPrintCustTestTrees.nCustNo,
	:frmPrintCustTestTrees.sCustName,
	:frmPrintCustTestTrees.sCultDesc,
	:frmPrintCustTestTrees.sRootDesc,
	:frmPrintCustTestTrees.sVarietyType,
	:frmPrintCustTestTrees.sVariety,
	:frmPrintCustTestTrees.nYearOfSale,
	:frmPrintCustTestTrees.nItemNo,
	:frmPrintCustTestTrees.dtOrderDT
WHERE
	co.cust_no = cm.cust_no and
	co.stock_item_no = si.item_no and
	sale_cat in ('TT') and
	CV_On_Trial_Flag = 'Y' and
	customer_type like '%OR%' and
	co.cust_no not in ( 31070, 334767) and
	(eval_report_year != :nYearOfEval or
	eval_report_year is NULL) and
	Conf_Amt > 0 and
	co.year_of_sale <= :nYearOfEval - 2
GROUP BY
	cm.cust_no,
	cust_name,
	cult_desc,
	root_desc,
	variety_type,
	variety,
	year_of_sale,
	Item_No,
	Order_Date_Time,
	Conf_Amt,
	Trees_Removed
HAVING	
	conf_amt > Trees_Removed or Trees_Removed is Null
ORDER BY
	1,5,6,3,4
"
.head 3 +  On PAM_clsFRM_REPORTFETCHNEXT
.head 4 +  If NOT SetEvalReportYear(nCustNo, nItemNo, nYearOfSale, nYearOfEval, dtOrderDT, SH_cls_Execute)
.head 5 -  Return FALSE
.head 4 -  Return TRUE
.head 3 +  On SAM_Destroy
.head 4 -  Call SetEvalReportYear(nTmp, nTmp, nTmp, nTmp, DATETIME_Null, SH_cls_Disconnect)
.head 4 -  Call SalSendClassMessage( SAM_Destroy, wParam, lParam )

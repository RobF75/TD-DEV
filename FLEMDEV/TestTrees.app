.head 6 -  Call SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
.head 5 +  On SAM_FetchRowDone
.head 6 -  ! Set colTotalTrees = colTotalTrees - nTreesRemoved
.head 6 -  Call GetNumberOfTestTrees(colCustNo, colTotalCults, colTotalTrees, nYear - 2, SH_cls_Execute)
.head 6 -  Call SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
.head 6 -  Call GetPostalAddress( colCustNo, dtTmp, sTmp, colAddress1, colAddress2, colSuburb, colPostCode, colState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
.head 6 -  Call GetMainContact( colCustNo, sTmp, colFirstName, colSurname, colBHCode, colBHPhone, colAHCode, colAHPhone, colContactEmail, FALSE, SH_cls_Execute )
.head 5 +  On SAM_Destroy
.head 6 -  Call GetNumberOfTestTrees(colCustNo, colTotalCults, colTotalTrees, nTmp, SH_cls_Disconnect)
.head 6 -  Call GetPostalAddress( colCustNo, dtTmp, sTmp, colAddress1, colAddress2, colSuburb, colPostCode, colState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Disconnect )
.head 6 -  Call GetMainContact( colCustNo, sTmp, colFirstName, colSurname, colBHCode, colBHPhone, colAHCode, colAHPhone, colContactEmail, FALSE, SH_cls_Disconnect )
.head 5 +  ! On PAM_clsTBL_PRINTTABLEREPORT
.head 6 -  Set sReportFileName = 'TestTrees.qrp'
.head 6 -  Set sRepBind = '

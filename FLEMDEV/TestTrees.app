.head 4 -  Functions 
.head 4 +  Message Actions 
.head 5 +  On PAM_clsFRM_REPORTFETCHINIT
.head 6 -  Set sReportSql = "
SELECT
	cm.cust_no,
	cust_name,
	cult_desc,
	root_desc,
	variety_type,
	variety,
	year_of_sale
FROM
	cust_order_history co,
	customer_master cm,
	stock_item si
INTO
	:nCustNo,
	:sCustName,
	:sCultDesc,
	:sRootDesc,
	:sVarietyType,
	:sVariety,
	:nYearOfSale
WHERE
	co.cust_no = cm.cust_no and
	co.stock_item_no = si.item_no and
	sale_cat in ('TT') and
	customer_type like '%OR%' and
	co.cust_no not in ( 31070, 334767)
ORDER BY
	1,5,6,3,4
"
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sReportType = 'PRINT'
.head 6 -  Set sReportFileNameNoPath = 'CustTestTrees.qrp'
.head 6 -  Set sPrinter = 'LaserPrinter'
.head 6 -  Set sReportBind = '
	clsfrmPrintCustTestTrees.nCustNo,
	clsfrmPrintCustTestTrees.sCustName,
	clsfrmPrintCustTestTrees.sCultDesc,
	clsfrmPrintCustTestTrees.sRootDesc,
	clsfrmPrintCustTestTrees.sVarietyType,
	clsfrmPrintCustTestTrees.sVariety,
	clsfrmPrintCustTestTrees.nYearOfSale'
.head 6 -  Set sReportInto = '
	nCustNo,
	sCustName,
	sCultDesc,
	sRootDesc,
	sVarietyType,
	sVariety,
	nYearOfSale'

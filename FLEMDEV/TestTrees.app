.head 2 +  Message Actions
.head 3 -  ! On PAM_clsFRM_REPORTFETCHINIT
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set sReportType = 'PRINT'
.head 4 -  Set sReportFileNameNoPath = 'CustTestTrees.qrp'
.head 4 -  Set nYearOfEval = nYear
.head 4 -  Set sPrinter = 'LaserPrinter'
.head 4 -  Set sReportBind = '
	frmPrintCustTestTrees.nCustNo,
	frmPrintCustTestTrees.sCustName,
	frmPrintCustTestTrees.sCultDesc,
	frmPrintCustTestTrees.sRootDesc,
	frmPrintCustTestTrees.sVarietyType,
	frmPrintCustTestTrees.sVariety,
	frmPrintCustTestTrees.nYearOfSale'
.head 4 -  Set sReportInto = '

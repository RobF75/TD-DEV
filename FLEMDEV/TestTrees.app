.head 5 -  String: sIntoHandle
.head 5 -  String: sNameHandle
.head 5 -  Number: nOurHandleNo
.head 5 -  Number: nInd
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'SETEVALREPORTYEAR' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSqlHandle = " 
UPDATE
	Cust_Order_History
SET
	eval_report_year = :1
WHERE
	Cust_No = :2 and
	Order_Date_Time = :3"
.head 7 -  Set sNameHandle = 'SETEVALREPYR2'
.head 7 -  Set sBindHandle = ':nYearOfEval, :nCustNo, :dtOrderDT'
.head 7 -  ! :nItemNo, nYearOfSale, 
	Stock_Item_No = :3 and
	Year_Of_Sale = :4 and
.head 7 -  Set sIntoHandle = ''
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSqlHandle, sNameHandle, sBindHandle, sIntoHandle )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 -  Call haSqlHandles[ nOurHandleNo ].Commit(  )
.head 7 +  Else
.head 8 -  Call SalMessageBox('Error updating eval_report_year flag','Error', MB_Ok)
.head 8 -  Return FALSE
.head 7 -  Return TRUE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 7 -  Return TRUE

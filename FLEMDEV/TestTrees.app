.head 5 +  Function: GetNumberOfTestTrees
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 +  Parameters
.head 7 -  Number: nCustNo
.head 7 -  Receive Number: nCults
.head 7 -  Receive Number: nTrees
.head 7 -  Number: nYear
.head 7 -  Number: nActionType
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  Number: nRemoved
.head 7 -  String: sSqlHandle
.head 7 -  String: sBindHandle
.head 7 -  String: sIntoHandle
.head 7 -  String: sNameHandle
.head 7 -  Number: nOurHandleNo
.head 7 -  Number: nInd
.head 6 +  Actions
.head 7 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETTOTALTESTTREES' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSqlHandle = " SELECT
	Count(Stock_Item_No),
  	Sum(conf_amt) ,
  	Sum(Trees_Removed)
FROM
  	Cust_Order_History,
	Stock_Item
WHERE
	Stock_Item.Item_No = Cust_Order_History.stock_Item_No and
  	Cust_No = :1 and
	Variety_Type = 'F' and
	Sale_Cat in ('TT') and
	(eval_report_year != :2 or
	eval_report_year is null) and
	CV_On_Trial_Flag = 'Y' and
	Conf_Amt > 0 and
	year_of_sale <= :2"
.head 9 -  Set sNameHandle = 'GETTOTALTESTTREE7'
.head 9 -  Set sBindHandle = ':nCustNo, :nYear'
.head 9 -  Set sIntoHandle = ':nCults, :nTrees, :nRemoved'
.head 9 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSqlHandle, sNameHandle, sBindHandle, sIntoHandle )
.head 9 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 -  !
.head 9 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 10 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 11 -  Set nTrees = nTrees - nRemoved
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 4 +  Window Variables
.head 5 -  Number: nTreesRemoved
.head 5 -  String: sCultDesc
.head 5 -  Number: nConfAmt
.head 5 -  Number: nEvalReportYear
.head 5 -  Date/Time: dtTmp
.head 5 -  String: sTmp
.head 5 -  Number: nTmp
.head 4 +  Message Actions
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 +  If TRUE
.head 7 -  Set sSQLPopHandle = "
SELECT
	Distinct Customer_Master.Cust_No,
	Cust_Name
FROM
	Customer_Master,
	Cust_Order_History,
	Stock_Item
WHERE
	Customer_Master.Cust_No = Cust_Order_History.Cust_No and
	Stock_Item.Item_No = Cust_Order_History.Stock_Item_No and
	Customer_Type like '%OR%' and
	Sale_Cat in ('TT') and
	CV_On_Trial_Flag = 'Y' and
	Variety_Type = 'F' and
	Customer_Master.Cust_No not in ( 31070, 334767 ) and
	(eval_report_year != :1 or
	eval_report_year is null) and
	Conf_Amt > 0 and
	Cust_Order_History.year_of_sale <= :1
GROUP BY
	Customer_Master.Cust_No,
	Cust_Name,
	conf_amt,
	trees_removed
HAVING
	(Conf_amt > Trees_Removed or Trees_Removed is null)"
.head 7 -  !
.head 7 -  Set sNAMEPopHandle = 'CUSTTESTTREES11'
.head 7 -  Set sBINDPopHandle = ':frmTestTrees.nYear - 2'
.head 7 -  Set sINTOPopHandle = '
:tblTestCustomers.colCustNo,
:tblTestCustomers.colCustName'
.head 6 +  ! If TRUE
.head 7 -  Set sSQLPopHandle = "
SELECT
	Customer_Master.Cust_No,
	Cust_Name,
	Count(stock_item_no),
	Sum(conf_amt),
	Sum(trees_removed)
FROM
	Customer_Master,
	Cust_Order_History,
	Stock_Item
WHERE
	Customer_Master.Cust_No = Cust_Order_History.Cust_No and
	Stock_Item.Item_No = Cust_Order_History.Stock_Item_No and
	Customer_Type like '%OR%' and
	Sale_Cat in ('TT') and
	Variety_Type = 'F'
GROUP BY
	Customer_Master.Cust_No,
	Cust_Name"
.head 7 -  Set sNAMEPopHandle = 'CUSTTRIALTREES1'
.head 7 -  Set sBINDPopHandle = ''
.head 7 -  Set sINTOPopHandle = '
:tblTestCustomers.colCustNo,
:tblTestCustomers.colCustName,
:tblTestCustomers.colTotalCults,
:tblTestCustomers.colTotalTrees,
:tblTestCustomers.nTreesRemoved'

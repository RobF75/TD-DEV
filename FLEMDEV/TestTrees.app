.head 6 +  Functions
.head 7 +  Function: GetNumberOfTestTrees
.head 8 -  Description:
.head 8 +  Returns
.head 9 -  Boolean:
.head 8 +  Parameters
.head 9 -  Number: nCustNo
.head 9 -  Receive Number: nCults
.head 9 -  Receive Number: nTrees
.head 9 -  Number: nActionType
.head 8 -  Static Variables
.head 8 +  Local variables
.head 9 -  Number: nRemoved
.head 9 -  String: sSqlHandle
.head 9 -  String: sBindHandle
.head 9 -  String: sIntoHandle
.head 9 -  String: sNameHandle
.head 9 -  Number: nOurHandleNo
.head 9 -  Number: nInd
.head 8 +  Actions
.head 9 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GETTOTALTESTTREES' )
.head 9 +  Select Case nActionType
.head 10 +  Case SH_cls_Execute
.head 11 -  Set sSqlHandle = " SELECT
	Count(Stock_Item_No),
  	Sum(conf_amt) ,
  	Sum(Trees_Removed)
FROM
  	Cust_Order_History,
	Stock_Item
WHERE
	Stock_Item.Item_No = Cust_Order_History.stock_Item_No and
  	Cust_No = :1 and
	Variety_Type = 'F' and
	Sale_Cat in ('TT', 'FC')"
.head 11 -  Set sNameHandle = 'GETTOTALTESTTREES1'
.head 11 -  Set sBindHandle = ':nCustNo'
.head 11 -  Set sIntoHandle = ':nCults, :nTrees, :nRemoved'
.head 11 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSqlHandle, sNameHandle, sBindHandle, sIntoHandle )
.head 11 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 11 -  !
.head 11 -  !
.head 11 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 12 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 13 -  Set nTrees = nTrees - nRemoved
.head 12 -  Return TRUE
.head 11 +  Else
.head 12 -  Return FALSE
.head 10 +  Case SH_cls_Disconnect
.head 11 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 6 +  Window Variables
.head 7 -  Number: nTreesRemoved
.head 7 -  String: sCultDesc
.head 7 -  Number: nConfAmt
.head 7 -  Number: nEvalReportYear
.head 6 +  Message Actions
.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 +  If TRUE
.head 9 -  Set sSQLPopHandle = "
SELECT
	Customer_Master.Cust_No,
	Cust_Name
FROM
	Customer_Master,
	Cust_Order_History,
	Stock_Item
WHERE
	Customer_Master.Cust_No = Cust_Order_History.Cust_No and
	Stock_Item.Item_No = Cust_Order_History.Stock_Item_No and
	Customer_Type like '%OR%' and
	Sale_Cat in ('TT') and
	CV_On_Trial_Flag = 'Y' and
	Variety_Type = 'F' and
	Customer_Master.Cust_No not in ( 31070, 334767) and
	eval_report_year != :1
GROUP BY
	Customer_Master.Cust_No,
	Cust_Name"
.head 9 -  Set sNAMEPopHandle = 'CUSTTESTTREES1'
.head 9 -  Set sBINDPopHandle = ':clsfrmTestTrees.tblTestCustomers.nEvalReportYear'
.head 9 -  Set sINTOPopHandle = '
:tblTestCustomers.colCustNo,
:tblTestCustomers.colCustName'
.head 8 +  ! If TRUE
.head 9 -  Set sSQLPopHandle = "
SELECT
	Customer_Master.Cust_No,
	Cust_Name,
	Count(stock_item_no),
	Sum(conf_amt),
	Sum(trees_removed)
FROM
	Customer_Master,
	Cust_Order_History,
	Stock_Item
WHERE
	Customer_Master.Cust_No = Cust_Order_History.Cust_No and
	Stock_Item.Item_No = Cust_Order_History.Stock_Item_No and
	Customer_Type like '%OR%' and
	Sale_Cat in ('TT') and
	Variety_Type = 'F'
GROUP BY
	Customer_Master.Cust_No,
	Cust_Name"
.head 9 -  Set sNAMEPopHandle = 'CUSTTRIALTREES1'
.head 9 -  Set sBINDPopHandle = ''
.head 9 -  Set sINTOPopHandle = '
:tblTestCustomers.colCustNo,
:tblTestCustomers.colCustName,
:tblTestCustomers.colTotalCults,
:tblTestCustomers.colTotalTrees,
:tblTestCustomers.nTreesRemoved'
.head 8 -  !
.head 8 -  Set bAddAllowed = FALSE
.head 8 -  Set bSaveAllowed = FALSE
.head 8 -  Set bDeleteAllowed = FALSE
.head 8 -  Set bUnDeleteAllowed = FALSE
.head 8 -  Set bRepopulateAllowed = TRUE
.head 8 -  Set bClearSelectAllowed = TRUE
.head 8 -  Set bQueryAllowed = FALSE
.head 8 -  Set bReportAllowed = FALSE
.head 8 -  Set bOrderAllowed = TRUE
.head 8 -  Set bSelectingColumnsAllowed = FALSE
.head 8 -  Set bSelectColsSUMTotalsAllowed = TRUE
.head 8 -  Set bMakeCSVFileAllowed = TRUE
.head 8 -  Set bMoveRowUpOneAllowed = FALSE
.head 8 -  Set bMoveRowDownOneAllowed = FALSE
.head 8 -  Set bZoomTableAllowed = FALSE
.head 8 -  Set nPopOrQueryOnStartUp = TBL_cls_PopulateOnStartUp
.head 8 -  !
.head 7 +  On SAM_FetchRowDone
.head 8 -  ! Set colTotalTrees = colTotalTrees - nTreesRemoved
.head 8 -  Call GetNumberOfTestTrees(colCustNo, colTotalCults, colTotalTrees, SH_cls_Execute)
.head 8 -  Call SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
.head 8 -  Call GetPostalAddress( colCustNo, dtTmp, sTmp, colAddress1, colAddress2, colSuburb, colPostCode, colState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
.head 8 -  Call GetMainContact( colCustNo, sTmp, colFirstName, colSurname, colBHCode, colBHPhone, colAHCode, colAHPhone, colContactEmail, FALSE, SH_cls_Execute )
.head 7 +  On SAM_Destroy
.head 8 -  Call GetNumberOfTestTrees(colCustNo, colTotalCults, colTotalTrees, SH_cls_Disconnect)
.head 8 -  Call GetPostalAddress( colCustNo, dtTmp, sTmp, colAddress1, colAddress2, colSuburb, colPostCode, colState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Disconnect )
.head 8 -  Call GetMainContact( colCustNo, sTmp, colFirstName, colSurname, colBHCode, colBHPhone, colAHCode, colAHPhone, colContactEmail, FALSE, SH_cls_Disconnect )
.head 7 +  On PAM_clsTBL_POPULATE
.head 8 -  Set tblTestCustomers.nEvalReportYear = ccSeasonYear.GetSeasonYear()
.head 7 +  ! On PAM_clsTBL_PRINTTABLEREPORT
.head 8 -  Set sReportFileName = 'TestTrees.qrp'
.head 8 -  Set sRepBind = '
:tblTestCustomers.colCustNo,
:tblTestCustomers.colCustName,
:tblTestCustomers.colTotalCults,
:tblTestCustomers.colTotalTrees,
:tblTestCustomers.colAddress1,
:tblTestCustomers.colAddress2,
:tblTestCustomers.colSuburb,
:tblTestCustomers.colState,
:tblTestCustomers.colPostCode,
:tblTestCustomers.colFirstName,
:tblTestCustomers.colSurname,
:tblTestCustomers.colBHCode,
:tblTestCustomers.colBHPhone,
:tblTestCustomers.colAHCode,
:tblTestCustomers.colAHPhone,
:tblTestCustomers.colContactEmail,
:sCultDesc,
:nConfAmt
'
.head 8 -  Set sRepInto = '
nCustNo,
sCustName,
nTotalCults,
nTotalTrees,
sAddress1,
sAddress2,
sSuburb,
sState,
sPostCode,
sFirstName,
sSurname,
sBHCode,
sBHPhone,
sAHCode,
sAHPhone,
sContactEmail,
sCultDesc,
nConfAmt
'
.head 8 -  Return TRUE

.head 6 -  Set sSql = '
	SELECT
		Cust_Type
	FROM
		Customer_Type
	WHERE
		@UPPER(Cust_Type) LIKE @UPPER(:sCustType)
	ORDER BY
		Cust_Type '					! Query to get population data
.head 6 -  Call SqlConnect( hSql )					! Connect to Database
.head 6 -  Call SalListPopulate ( hWndItem, hSql, sSql )			! Return the results to the combo box
.head 6 -  Call SqlDisconnect ( hSql)					! Disconnect from Database
.head 6 -  Set sSql = ''
.head 6 -  Call SalWaitCursor( FALSE )

.head 8 -  ! Set sSql = " SELECT
  Customer_Master.Cust_No, 
  Customer_Master.Cust_Name, 
  @UPPER( Customer_Master.Cust_Name ), 
  	contact_title,
	contact_given_name,
	contact_surname,
	wrk_phone_code,
	contact_work_phone,
	ah_phone_code,
	contact_ah_phone,
	contact_position,
	mob_phone_code,
	contact_mob_phone,
	email
FROM 
  Customer_Master, 
  Customer_Contacts
INTO 
  :frmAuditReport.nCustNo,
  :frmAuditReport.sCustName,
  :frmAuditReport.sUpperCustName,
  :frmAuditReport.sContactTitle,
  :frmAuditReport.sGivenName,
  :frmAuditReport.sSurname,
  :frmAuditReport.sWorkCode,
  :frmAuditReport.sWorkPhone,
  :frmAuditReport.sAHCode,
  :frmAuditReport.sAHPhone, 
  :frmAuditReport.sContactPosition,
  :frmAuditReport.sMobileCode,
  :frmAuditReport.sMobilePhone, 
  :frmAuditReport.sContactEmail
WHERE
  Customer_Master.Cust_No = :frmAuditReport.nCustNo  AND 
  Customer_Master.Cust_No = Customer_Contacts.Cust_No 
ORDER BY
  1, Customer_Contacts.Main_Contact_Flag desc"
.head 8 -  Set sSql = " SELECT

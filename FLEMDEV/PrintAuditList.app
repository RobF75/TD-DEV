.head 7 -  Set sSql = " 
SELECT
	Distinct(CM.Cust_No),
	CM.Cust_Name, 
	Region_Id
FROM
	Customer_Master CM,
	Cust_Order_History co,
	Stock_item si
INTO
	:frmAuditReport.nCustNo,
	:frmAuditReport.sCustName,
	:frmAuditReport.sRegionId
WHERE
	si.item_no = co.stock_item_no and
	co.cust_no = CM.cust_no and
	@UPPER(CM.Region_id) LIKE @UPPER(:sRegion) and
	(NPA_RECD_FLAG = 'Y'  or TA_RECD_FLAG = 'Y')
ORDER BY
	"||sOrderBy

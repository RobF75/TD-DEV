.head 8 -  Set sSql = " SELECT
  	sum(conf_amt),
  	year_of_sale,
  	cult_desc,
	root_desc
FROM 
  	cust_order_history co,
	stock_item si
INTO 
  	:frmAuditReport.nConfAmt,
	:frmAuditReport.nYearOfSale,
	:frmAuditReport.sCultDesc,
	:frmAuditReport.sRootDesc
WHERE
	item_no = stock_item_no and
  	Cust_No = :frmAuditReport.nCustNo and
	variety_type = 'F' and
	(NPA_RECD_FLAG = 'Y' or TA_RECD_FLAG = 'Y')
Group By
	year_of_sale,
	cult_desc,
	root_desc,
	variety_type,
	variety
ORDER BY
  	variety,
	cult_desc,
	root_desc,
	year_of_sale"

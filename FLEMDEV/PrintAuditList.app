.head 8 -  Set sSql = " SELECT
  Customer_Master.Cust_No, 
  Customer_Master.Cust_Name, 
  @UPPER( Customer_Master.Cust_Name ), 
	Address_Type,
  	address_1,
	address_2,
	suburb,
	postcode,
	state,
	country,
	area_code,
	phone_no,
	fax_no,
	email
FROM 
  Customer_Master, 
  Customer_Address 
INTO 
  :frmAuditReport.nCustNo,
  :frmAuditReport.sCustName,
  :frmAuditReport.sUpperCustName,
  :frmAuditReport.sAddressType,
  :frmAuditReport.sAddress1,
  :frmAuditReport.sAddress2,
  :frmAuditReport.sSuburb,
  :frmAuditReport.sPostCode,
  :frmAuditReport.sState,
  :frmAuditReport.sCountry,
  :frmAuditReport.sAreaCode,
  :frmAuditReport.sPhoneNo, 
  :frmAuditReport.sFaxNo,
  :frmAuditReport.sAddressEmail
WHERE
  Customer_Master.Cust_No = :frmAuditReport.nCustNo  AND 
  Customer_Master.Cust_No = Customer_Address.Cust_No 
ORDER BY
  1 , Customer_Address.Main_Address_Flag desc"

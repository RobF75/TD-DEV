.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  String: sSql
.head 7 -  String: sBind
.head 7 -  String: sInto
.head 7 -  String: sName
.head 7 -  Number: nInd
.head 7 -  Number: nSqlHandleNo
.head 7 -  !
.head 7 -  Number: nInvoiced
.head 7 -  Number: nAvePrice
.head 7 -  Number: nItemNo
.head 7 -  Number: nConfAmt
.head 6 +  Actions
.head 7 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'CalcBunInvVal' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = " SELECT
	Stock_Item_no,
	conf_amt,
	conf_amt * invoice_tree_price
from
	cust_order_history co,
	stock_item si
into
	:nItemNo,
	:nConfAmt,
	:nInvoiced
where
	co.stock_item_no = si.item_no and
	cust_no = :nCustNo and
	conf_amt > 0 and
	invoice_tree_price > 0 and
	stock_type like :sStockType and
	invoiced_date between :dtFrom and :dtTo
	"
.head 9 -  Call haSqlHandles[ nSqlHandleNo ].RePrepare(  )
.head 9 -  Call haSqlHandles[ nSqlHandleNo ].PrepareSetup( sSql )
.head 9 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 -  Set nBunTotalValue = 0
.head 9 -  !
.head 9 +  If haSqlHandles[ nSqlHandleNo ].PrepareAndExecute( )
.head 10 +  While haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 11 +  If nInvoiced > 0
.head 12 -  Set nBunTotalValue = nBunTotalValue + nInvoiced
.head 12 -  Set nAvePrice = GetItemAvePrice(nItemNo, dfFrom, dfTo, SH_cls_Execute )
.head 12 -  Set nCompare = nCompare + (nAvePrice * nConfAmt )
.head 10 -  Return TRUE
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 9 -  Return TRUE

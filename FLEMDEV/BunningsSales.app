:frmCompareBunningsSales.sCustType '
.head 7 -  Set sINTOPopHandle = '
:frmCompareBunningsSales.tblBunningsSales.colnCustNo,
:frmCompareBunningsSales.tblBunningsSales.colsCustName,
:frmCompareBunningsSales.tblBunningsSales.colnSold'
.head 7 -  !
.head 7 -  Set sSQLRefreshHandle = 
"
Select
	CM.Cust_No,
	Cust_name,
	Sum(conf_amt)
From 
	Customer_Master cm,
	Cust_Order_history co,
	Stock_Item si
Where 
	si.item_no = co.stock_item_no and
	cm.cust_no = co.cust_no and
	customer_type like :4 and
	stock_type like :1 and
	invoiced_date between :2 and :3
group by
	cm.cust_no,
	cust_name
Order By
	cm.cust_no
"
.head 7 -  Set sNAMERefreshHandle = 'RePOPBunnSale3'

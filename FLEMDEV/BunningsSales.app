.head 2 +  Functions
.head 3 +  Function: fnResetYear
.head 4 -  Description: This function sets up the Colour Coding for the current season.
Due to the fact it is not known when this function will be performed the user has to be asked
if they wish to replace any records for the current season  or if they just wish to replace everything
in there with the data from last year.
The function also finds any cultivar's that do not have a single record in the cult_paint_used
table and adds the First Paint record into the table.
.head 4 -  Returns
.head 4 -  Parameters
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Number: nMsgResponse
.head 5 -  Sql Handle: hSqlReset
.head 5 -  Number: nCurrentSeason
.head 5 -  Number: nPreviousSeason
.head 5 -  Boolean: bOk
.head 5 -  Number: nNoCultRolledOver
.head 5 -  Number: nNoRootStockRolledOver
.head 5 -  Number: nNewCultivar
.head 5 -  Number: nNewRootStock
.head 5 -  !
.head 5 -  String: sSqlCultivarCopy
.head 5 -  String: sSqlCultivarNew
.head 5 -  String: sSqlRootStockCopy
.head 5 -  String: sSqlRootStockNew
.head 4 +  Actions
.head 5 -  Set nCurrentSeason = WhichSeasonYear ( SalDateCurrent ( ) ) 
.head 5 -  Set nPreviousSeason = nCurrentSeason - 1
.head 5 -  Set nMsgResponse = SalMessageBox ( 'You are about to reset the cultivar colors for the current season.
There is a possibility that some cultivar records may have been created already for this season. 

If you wish to replace all existing data press YES.  
If you wish to append new data to the existing data press NO.  
To cancel the entire operation click CANCEL.', 'Reset Cultivar Colours', MB_IconExclamation | MB_YesNoCancel )
.head 5 -  ! Set Sql Variables 
.head 5 +  If TRUE
.head 6 -  Set sSqlCultivarCopy = 
"
Insert Into
	Cult_Paint_Used
	( Cultivar_Id,
	Cult_Year_Used,
	Cv_Paint_Number,
	Paint_Id )
Select
	Cultivar_Id,
	:nCurrentSeason,
	Cv_Paint_Number,
	Paint_Id
From
	Cult_Paint_Used
Where
	Cult_Year_Used = :nPreviousSeason
AND	RowId Not In ( 
	Select 
		RowId 
	From 
		Cult_Paint_Used
	Where
		Cult_Year_Used = :nCurrentSeason )
"
.head 6 -  !
.head 6 -  Set sSqlCultivarNew = 
"
Insert Into
	Cult_Paint_Used
	( Cultivar_Id,
	Cult_Year_Used,
	Cv_Paint_Number,
	Paint_id )
Select
	Cult_Id,
	:nCurrentSeason,
	1,
	'0'
From
	Cultivar
Where
	Variety_Type = 'F'
AND	Cult_Id Not In ( 
		Select 
			Cultivar_Id
		From
			Cult_Paint_Used
		Where
			Cult_Year_Used = :nCurrentSeason )
"
.head 6 -  !
.head 6 -  Set sSqlRootStockCopy = 
"
Insert Into
	RtStck_Paint_Used
	( RootStock_Id,
	RT_Year_Used,
	RT_Paint_Number,
	Paint_Id )
Select
	RootStock_Id,
	:nCurrentSeason,
	RT_Paint_Number,
	Paint_Id
From
	RtStck_Paint_Used
Where
	RT_Year_Used = :nPreviousSeason
AND	RowId Not In ( 
	Select 
		RowId 
	From 
		RtStck_Paint_Used
	Where
		RT_Year_Used = :nCurrentSeason )
"
.head 6 -  !
.head 6 -  Set sSqlRootStockNew = 
"
Insert Into
	RtStck_Paint_Used
	( RootStock_Id,
	RT_Year_Used,
	RT_Paint_Number,
	Paint_id )
Select
	Root_Id,
	:nCurrentSeason,
	1,
	'0'
From
	Rootstock
Where
	RootStock.Root_Id  Not In ( 
		Select 
			RootStock_Id
		From
			RtStck_Paint_Used
		Where
			RT_Year_Used = :nCurrentSeason )
"
.head 6 -  !
.head 5 +  Select Case nMsgResponse
.head 6 +  Case IDYES
.head 7 -  Call fnDeleteExistingRecords ( nCurrentSeason )
.head 7 -  Break
.head 6 +  Case IDCANCEL
.head 7 -  Return FALSE
.head 5 -  Call SalWaitCursor( TRUE )
.head 5 -  ! The following performs the entire season rollover for colour codes.
! All four SQL statements must succeed in order for this transaction to succeed
.head 5 +  If SqlConnect( hSqlReset )
.head 6 -  ! First step copy all of last season to this season
.head 6 -  Set bOk = TRUE
.head 6 -  ! First step copy all of last seasons colour codes to this season
.head 6 +  If bOk
.head 7 +  If SqlPrepareAndExecute ( hSqlReset, sSqlCultivarCopy )
.head 8 -  Call SqlGetModifiedRows( hSqlReset, nNoCultRolledOver )
.head 7 +  Else
.head 8 -  Set bOk = FALSE
.head 6 -  ! Second step find any cultivar that do not have colour codes and add them
.head 6 +  If bOk
.head 7 +  If SqlPrepareAndExecute ( hSqlReset, sSqlCultivarNew )
.head 8 -  Call SqlGetModifiedRows( hSqlReset, nNewCultivar )
.head 7 +  Else
.head 8 -  Set bOk = FALSE
.head 6 -  ! Third step is to copy all of the root stock colour codes from last season to this season.
.head 6 +  If bOk
.head 7 +  If SqlPrepareAndExecute ( hSqlReset, sSqlRootStockCopy )
.head 8 -  Call SqlGetModifiedRows( hSqlReset, nNoRootStockRolledOver )
.head 7 +  Else
.head 8 -  Set bOk = FALSE
.head 6 -  ! Final step, find any rootstock without colour code records and add them
.head 6 +  If bOk
.head 7 +  If SqlPrepareAndExecute ( hSqlReset, sSqlRootStockNew)
.head 8 -  Call SqlGetModifiedRows ( hSqlReset, nNewRootStock )
.head 7 +  Else
.head 8 -  Set bOk = FALSE
.head 6 -  ! If all have succeeded then commit changes and refresh table window
.head 6 +  If bOk
.head 7 -  Call SqlCommit ( hSqlReset ) 
.head 7 -  Call SalMessageBox ( SalNumberToStrX ( nNoCultRolledOver, 0 ) || ' Cultivar Colour Codes were rolled over from the previous season.
' || SalNumberToStrX ( nNewCultivar, 0 ) || ' Cultivar records have had default colour records added.

' || SalNumberToStrX ( nNoRootStockRolledOver, 0 ) || ' RootStock Colour Codes were rolled over from the previous season.
' || SalNumberToStrX ( nNewRootStock, 0 ) || ' RootStock records have had default colour records added' , 'Season Colour Reset', MB_Ok ) 
.head 7 -  Call SalSendMsg ( hWndForm, PAM_clsTBL_REPOPULATE,0, 0 ) 
.head 6 +  Else
.head 7 -  Call SqlPrepareAndExecute ( hSqlReset, 'ROLLBACK' )
.head 6 -  Call SqlDisconnect ( hSqlReset )
.head 5 -  Call SalWaitCursor ( FALSE ) 
.head 5 -  Return bOk
.head 3 +  Function: fnIsStockControllerUser
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: spUser
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: saStockControllers[*]
.head 5 -  Number: nCount
.head 5 -  String: sStockControllerList
.head 5 -  Number: nNoControllers
.head 5 -  Boolean: bOk
.head 4 +  Actions
.head 5 +  If GetRegistryValue ( 'GENERAL', 'StockControllers', sStockControllerList, STRING_Null )
.head 6 -  Set nNoControllers = SalStrTokenize ( sStockControllerList, '', ',' , saStockControllers )
.head 6 +  While nCount < nNoControllers
.head 7 +  If saStockControllers[nCount] = spUser
.head 8 -  Set bOk = TRUE
.head 8 -  Break
.head 7 -  Set nCount = nCount + 1
.head 5 -  Return bOk
.head 3 +  Function: fnDeleteExistingRecords
.head 4 -  Description: Deletes all records in the cult_paint_used table that have the same cult_year_used as the current season.  
.head 4 -  Returns
.head 4 +  Parameters
.head 5 -  Number: npCurrentSeason
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  Sql Handle: hSqlDelete
.head 4 +  Actions
.head 5 +  If SqlConnect ( hSqlDelete ) 
.head 6 -  Call SqlPrepareAndExecute ( hSqlDelete, 
"
Delete From
	Cult_Paint_Used 
Where
	Cult_Year_Used = :npCurrentSeason
" )
.head 6 -  Call SqlDisconnect ( hSqlDelete )

	Avg(invoice_tree_price )
from
	cust_order_history co,
	stock_item si,
	customer_master cm
into
	:nAverage
where
	cm.cust_no = co.cust_no and
	co.stock_item_no = si.item_no and
	Stock_Item_no = :nItemNo and
	conf_amt > 0 and
	invoice_tree_price > 0 and
	sale_cat = 'NM' and
	invoiced_date between :dtFrom and :dtTo and
	Customer_type like 'GC_' and
	customer_type != 'GCB'"

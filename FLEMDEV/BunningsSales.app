.head 4 -  Set nMatureProduction = SalStrToNumber( sMatureProduction )
.head 4 -  !
.head 4 -  Set sReportBind = ':SqlUser,
:frmPrintProductionRoyalties.nCustNo,
:frmPrintProductionRoyalties.sCustName,
:frmPrintProductionRoyalties.sBusinessName,

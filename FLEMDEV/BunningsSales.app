.head 9 -  Call SalMessageBox( 'Please select some customers first, or choose All Customers.', 'Warning', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  Else 
.head 8 -  Set sCustType = 'ALL'
.head 7 -  !
.head 7 +  If rbView
.head 8 -  Set sReportType = 'VIEW'
.head 7 +  Else 
.head 8 -  Set sReportType = 'PRINT'
.head 7 -  !
.head 7 +  If hWndReport = hWndNULL
.head 8 -  Set hWndReport = SalCreateWindow( frmPrintProductionRoyalties, hWndForm, sSelectedCustNoList,
sCustType, sReportType )
.head 8 -  Return TRUE
.head 7 +  Else 
.head 8 -  Call SalMessageBox( 'Please close down your first report!', 'Warning', MB_Ok )
.head 8 -  Return FALSE

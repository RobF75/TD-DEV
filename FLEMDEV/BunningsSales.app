.head 3 +  On SAM_ReportStart
.head 4 +  If sCustType = 'SELECTED'
.head 5 -  Set sSql = "
SELECT
	customer_master.cust_no,
	cust_name,
	variety,
	cult_desc,
	item_no,
	conf_amt,
	year_of_sale,
	sale_cat,
	stock_item.prod_royalty,
	Royalty_Percent,
	Tree_type,
	Trees_Removed
FROM
	customer_order,
	stock_item,
	customer_master,
	Prod_Royalty_Class
 WHERE
	Customer_Master.Cust_No IN (:1 ) AND 
	customer_order.stock_item_no = stock_item.item_no and
	customer_master.cust_no = customer_order.cust_no and
	Stock_Item.Prod_Royalty = Prod_Royalty_Class.Prod_Royalty and
	stock_item.prod_royalty != 'A' and 
	year_of_sale >= 1998 and
	Invoiced_Flag = 'Y' and
	Conf_Amt > 0
UNION
SELECT
	customer_master.cust_no,
	cust_name,
	variety,
	cult_desc,
	item_no,
	conf_amt,
	year_of_sale,
	sale_cat,
	stock_item.prod_royalty,
	Royalty_Percent,
	Tree_type,
	Trees_Removed
FROM
	cust_order_history,
	stock_item,
	customer_master,
	Prod_Royalty_Class
 WHERE
	Customer_Master.Cust_No IN :1 AND 
	cust_order_history.stock_item_no = stock_item.item_no and
	customer_master.cust_no = cust_order_history.cust_no and
	Stock_Item.Prod_Royalty = Prod_Royalty_Class.Prod_Royalty and
	stock_item.prod_royalty != 'A' and  
	year_of_sale >= 1998 and
	Invoiced_Flag = 'Y' and
	Conf_Amt > 0
"
.head 5 -  Set sName = 'SELTSELPRROY'
.head 5 -  Set sBind = ':sCustNoList'
.head 5 -  Set sInto = ':frmPrintProductionRoyalties.nCustNo,
  	:frmPrintProductionRoyalties.sCustName,
	:frmPrintProductionRoyalties.sVariety,
 	:frmPrintProductionRoyalties.sCultDesc,
	:frmPrintProductionRoyalties.nItemNo,
  	:frmPrintProductionRoyalties.nConfAmt,
  	:frmPrintProductionRoyalties.nYearOfSale,
  	:frmPrintProductionRoyalties.sSaleCat,
  	:frmPrintProductionRoyalties.sProdRoyalty,
	:frmPrintProductionRoyalties.nRoyaltyPercent,
	:frmPrintProductionRoyalties.sTreeType,
	:frmPrintProductionRoyalties.nTreesRemoved
	'
.head 5 -  ! Call fcSqlHandle.PrepareSetup( sSql )
.head 5 -  Call fcSqlHandle.Setup(sSql, sName, sBind, sInto)
.head 5 -  Call SqlVarSetup( fcSqlHandle.hSqlHandle )
.head 4 +  Else 
.head 5 -  Set sSql = "
SELECT
	customer_master.cust_no,
	cust_name,
	variety,
	cult_desc,
	item_no,
	conf_amt,
	year_of_sale,
	sale_cat,
	stock_item.prod_royalty,
	Royalty_Percent,
	Tree_Type,
	Trees_Removed
FROM
	customer_order,
	stock_item,
	customer_master,
	Prod_Royalty_Class
 WHERE
	customer_order.stock_item_no = stock_item.item_no and
	customer_master.cust_no = customer_order.cust_no and
	Stock_Item.Prod_Royalty = Prod_Royalty_Class.Prod_Royalty and
	stock_item.prod_royalty != 'A' and 
	year_of_sale >= 1998 and
	Invoiced_Flag = 'Y' and
	Conf_Amt > 0
UNION
SELECT
	customer_master.cust_no,
	cust_name,
	variety,
	cult_desc,
	item_no,
	conf_amt,
	year_of_sale,
	sale_cat,
	stock_item.prod_royalty,
	Royalty_Percent,
	Tree_Type,
	Trees_Removed
FROM
	cust_order_History,
	stock_item,
	customer_master,
	Prod_Royalty_Class
 WHERE
	cust_order_history.stock_item_no = stock_item.item_no and
	customer_master.cust_no = cust_order_history.cust_no and
	Stock_Item.Prod_Royalty = Prod_Royalty_Class.Prod_Royalty and
	stock_item.prod_royalty != 'A'  and 
	year_of_sale >= 1998 and
	Invoiced_Flag = 'Y' and
	Conf_Amt > 0
"
.head 5 -  Set sName = 'SELTALLPRROY1'
.head 5 -  Set sBind = ''
.head 5 -  Set sInto = ':frmPrintProductionRoyalties.nCustNo,
  	:frmPrintProductionRoyalties.sCustName,
	:frmPrintProductionRoyalties.sVariety,
 	:frmPrintProductionRoyalties.sCultDesc,
	:frmPrintProductionRoyalties.nItemNo,
  	:frmPrintProductionRoyalties.nConfAmt,
  	:frmPrintProductionRoyalties.nYearOfSale,
  	:frmPrintProductionRoyalties.sSaleCat,
  	:frmPrintProductionRoyalties.sProdRoyalty,
	:frmPrintProductionRoyalties.nRoyaltyPercent,
	:frmPrintProductionRoyalties.sTreeType,
	:frmPrintProductionRoyalties.nTreesRemoved
	'
.head 5 -  ! Call fcSqlHandle.PrepareSetup( sSql )
.head 5 -  Call fcSqlHandle.Setup(sSql, sName, sBind, sInto)
.head 5 -  Call SqlVarSetup( fcSqlHandle.hSqlHandle )
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchInit
.head 4 -  ! Call fcSqlHandle.PrepareAndExecute( )
.head 4 -  Call fcSqlHandle.Execute( )
.head 4 -  ! Set sCurrentCultVariety = ''
.head 4 -  ! Set nBreakTotGrowing = 0
.head 4 -  ! Set nBreakTotEstGrow = 0
.head 4 -  ! Set nBreakTotOnOrder = 0
.head 4 -  ! Set nBreakTotShip = 0
.head 4 -  ! Set nTotalGrowing = 0
.head 4 -  ! Set nTotalEstGrow = 0
.head 4 -  Set nPrevCustNo = NUMBER_Null
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchNext
.head 4 +  If fcSqlHandle.FetchNext( nInd )
.head 5 -  !
.head 5 +  If nPrevCustNo != nCustNo
.head 6 -  Set nTotalCustomerProduction = 0
.head 5 -  Set nTreesGrowing = nConfAmt - nTreesRemoved
.head 5 +  If sSaleCat != 'FC' and sSaleCat != 'TT' and sSaleCat != 'RP' and sSaleCat != 'FR'
.head 6 +  Select Case (nCurrentYear - nYearOfSale)
.head 7 +  Case 0
.head 8 -  Set nTotalTrays = 0
.head 8 -  Break 
.head 7 +  Case 1
.head 8 -  Set nTotalTrays = nTreesGrowing * nFirstLeafProduction
.head 8 -  Break 
.head 7 +  Case 2
.head 8 -  Set nTotalTrays = nTreesGrowing * nSecondLeafProduction
.head 8 -  Break 
.head 7 +  Case 3
.head 8 -  Set nTotalTrays = nTreesGrowing * nThirdLeafProduction
.head 8 -  Break 
.head 7 +  Default 
.head 8 -  Set nTotalTrays = nTreesGrowing * nMatureProduction
.head 8 -  Break 
.head 5 +  Else 
.head 6 -  Set nTotalTrays = 0
.head 5 -  Set nTotalCustomerProduction = nTotalCustomerProduction + nTotalTrays
.head 5 -  !
.head 5 -  Set nPrevCustNo = nCustNo
.head 5 -  Return TRUE
.head 4 +  Else 
.head 5 -  Return FALSE
.head 3 +  On SAM_ReportFinish
.head 4 -  Call fcSqlHandle.Disconnect( )
.head 4 -  ! Call GetItemTotalBudCount( 0, 0, nItemTotalBudCount, SH_cls_Disconnect )
.head 4 -  Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )

.head 5 +  On PAM_clsTBL_POPULATE
.head 6 -  Set nYear = hWndParent.ccSeasonYear.GetSeasonYear( )
.head 6 -  Set nNumColumns = 4
.head 6 -  Call GetPotSizeFutureDates( nYear, hWndForm, PAM_clsTBL_ROWACTION, 3, SH_cls_Execute )
.head 6 -  Call SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
.head 6 -  Return TableLoop( hWndForm, hWndForm, PAM_clsTBL_ROWACTION, 1, 0, 0, 'Fetching Future Figures', TBL_cls_LowToHi )
.head 5 +  On PAM_clsTBL_ROWACTION
.head 6 +  If wParam = 1
.head 7 -  Return GetPotSizeFutureCountNOrd( colTreeType, nYear, hWndForm, PAM_clsTBL_ROWACTION, 2, SH_cls_Execute )
.head 6 +  Else If wParam = 2
.head 7 -  Call PopNumber( nOrd, TRUE )
.head 7 -  Call PopNumber( nCount, TRUE )
.head 7 -  Call PopDateTime( dtEstSaleDate, TRUE )
.head 7 -  Call SetEstSaleDateColumn( hWndForm, dtEstSaleDate, nCount, nOrd )
.head 7 -  Return TRUE
.head 6 +  Else 
.head 7 -  Call PopDateTime( dtEstSaleDate, TRUE )
.head 7 -  Set nNumColumns = nNumColumns + 1
.head 7 -  ! Set sEstSaleDate = SalNumberToStrX( SalDateDay( dtEstSaleDate ), 0 ) || '-' || 
WordMonth( SalDateMonth( dtEstSaleDate ) ) || '-' || 
SalNumberToStrX( SalDateYear( dtEstSaleDate ), 0 )
.head 7 -  Set nColId = SalTblCreateColumn( hWndForm, nNumColumns, 1.433, 12, FormatFutureDatesColTitles( dtEstSaleDate ) )
.head 7 -  Set hWndCol = SalTblGetColumnWindow( hWndForm, nColId, COL_GetID ) 
.head 7 -  Call SalTblSetColumnFlags( hWndCol, COL_CenterJustify, TRUE )
.head 7 -  Call SalTblSetColumnFlags( hWndCol, COL_Editable, FALSE )
.head 7 -  Return TRUE
.head 5 +  On PAM_clsTBL_REPOPULATE
.head 6 -  Call SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
.head 6 -  Return TableLoop( hWndForm, hWndForm, PAM_clsTBL_ROWACTION, 1, 0, 0, 'Fetching Future Figures', TBL_cls_LowToHi )
.head 5 +  On SAM_FetchRowDone
.head 6 -  Call GetPotSizeCurrentCountNOrd( colTreeType, nYear, nCount, nOrd, SH_cls_Execute )
.head 6 -  Set colCurrentFigures = FormatFigures( nCount, nOrd )
.head 6 -  Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
.head 5 +  On PAM_clsTBL_NOROWS
.head 6 -  Return TRUE
.head 5 +  On SAM_Destroy
.head 6 -  Call GetPotSizeCurrentCountNOrd( '', 0, nCount, nOrd, SH_cls_Disconnect )
.head 6 -  Call GetPotSizeFutureCountNOrd( '', 0, hWndNULL, 0, 2, SH_cls_Disconnect )
.head 6 -  Call GetPotSizeFutureDates( 0, hWndNULL, 0, 0, SH_cls_Disconnect )
.head 6 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
.head 5 +  On PAM_clsTBL_PRINTTABLEREPORT
.head 6 -  Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'c:\\temp' )||'\\'||'ptszinv.qrp'

.head 3 +  On SAM_ReportStart
.head 4 +  If rbSelectedItems
.head 5 -  Set sSql = "SELECT
  Stock_Item.Item_No, 
  Stock_Item.Variety_Type,
  Stock_Item.Variety,
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc,
  @UPPER(Stock_Item.Variety),
  @UPPER(Stock_Item.Cult_Desc),
  @UPPER(Stock_Item.Root_Desc),
  Stock_Item.Generic_Stock_Item 
FROM 
  Stock_Item
INTO 
  :frmPrintGradedShortages.nItemNo, 
  :frmPrintGradedShortages.sVarietyType, 
  :frmPrintGradedShortages.sVariety, 
  :frmPrintGradedShortages.sTreeTypeDesc, 
  :frmPrintGradedShortages.sCultDesc,
  :frmPrintGradedShortages.sRootDesc,
  :frmPrintGradedShortages.sUpperVariety, 
  :frmPrintGradedShortages.sUpperCultDesc,
  :frmPrintGradedShortages.sUpperRootDesc,
  :frmPrintGradedShortages.sGenFlag
WHERE 
  Stock_Item.Item_No IN ( " || sSelectedItemNoList || " ) and
  Stock_Type != 'C'
ORDER BY 2,7,8,9,4"
.head 5 -  ! Call hSqlItems.PrepareSetup( sSql )
.head 4 +  Else
.head 5 -  Set sSql = "SELECT
  	Stock_Item.Item_No, 
  	Stock_Item.Variety_Type,
  	Stock_Item.Variety,
  	Stock_Item.Tree_Type_Desc, 
  	Stock_Item.Cult_Desc, 
  	Stock_Item.Root_Desc,
  	@UPPER(Stock_Item.Variety),
  	@UPPER(Stock_Item.Cult_Desc),
  	@UPPER(Stock_Item.Root_Desc),
  	Stock_Item.Generic_Stock_Item,
 	Stock_Item_Sale.Amt_On_Order,
	Stock_Item_Sale.On_Ord_As_Subs,
	Sum(pallet_count),
	Total_Graded,
	Est_Avail_Count,
	Amt_Shipped + AMT_SUBS_SHIPPED
FROM 
  	Stock_Item,
  	Stock_Item_Sale,
  	Pallet_Contents,
	Graded_Pallets
INTO 
  	:frmPrintGradedShortages.nItemNo, 
  	:frmPrintGradedShortages.sVarietyType, 
  	:frmPrintGradedShortages.sVariety, 
  	:frmPrintGradedShortages.sTreeTypeDesc, 
  	:frmPrintGradedShortages.sCultDesc,
  	:frmPrintGradedShortages.sRootDesc,
  	:frmPrintGradedShortages.sUpperVariety, 
  	:frmPrintGradedShortages.sUpperCultDesc,
  	:frmPrintGradedShortages.sUpperRootDesc,
  	:frmPrintGradedShortages.sGenFlag,
  	:frmPrintGradedShortages.nCurrentOrdered,
  	:frmPrintGradedShortages.nCurrentSubsOrdered,
  	:frmPrintGradedShortages.nGradedCount,
  	:frmPrintGradedShortages.nTotalGraded,
  	:frmPrintGradedShortages.nEstAvail,
  	:frmPrintGradedShortages.nShipped
WHERE
	Pallet_Contents.item_no = stock_item.item_no and
	Pallet_Contents.content_datetime = graded_pallets.pallet_datetime and
  	Stock_Item.Item_no = Stock_Item_Sale.Stock_Item_No and
 	Year_of_Sale = :frmPrintGradedShortages.nYear and
  	Stock_Type != 'C' AND 
  	Graded_Pallets.Processed_Date >= :frmPrintGradedShortages.dtSeasonDate 
Group By
	Stock_Item.Item_No, 
 	 Stock_Item.Variety_Type,
  	Stock_Item.Variety,
 	 Stock_Item.Tree_Type_Desc, 
 	 Stock_Item.Cult_Desc, 
  	Stock_Item.Root_Desc,
  	Stock_Item.Generic_Stock_Item,
 	Stock_Item_Sale.Amt_On_Order,
	Stock_Item_Sale.On_Ord_As_Subs,
	Total_Graded,
	Est_Avail_Count,
	Amt_Shipped,
	Amt_subs_shipped
ORDER BY 
	2,7,8,9,4"
.head 4 -  Set dtSeasonDate = SalDateConstruct( nYear, 04, 01, 00, 00, 00 )
.head 4 -  Call hSqlItems.PrepareSetup( sSql )
.head 4 -  ! Set sSql = "
SELECT 
	sum (pallet_count)
FROM 
  	Pallet_Contents,
	Graded_Pallets
INTO 
  	:frmPrintGradedShortages.nGradedCount
WHERE 
	Pallet_Contents.content_datetime = graded_pallets.pallet_datetime and
  	Pallet_Contents.Item_No = :frmPrintGradedShortages.nItemNo AND 
  	Graded_Pallets.Processed_Date >= :frmPrintGradedShortages.dtSeasonDate 
 "

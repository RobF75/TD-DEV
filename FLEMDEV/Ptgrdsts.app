.head 6 -  Set bAddAllowed = TRUE
.head 5 +  On PAM_PTASSINV_GETSELECTEDITEMS
.head 6 -  Set sItemNoList = ''
.head 6 -  Set nSelectedItemYear = NUMBER_Null
.head 6 +  If TableLoop( hWndForm, hWndForm, PAM_PTASSINV_GETSELECTED, 0, 0, 0, 'Extracting Selected Items', TBL_cls_LowToHi )
.head 7 +  If hWndParent.ccSeasonYear.GetSeasonYear( ) != nSelectedItemYear
.head 8 -  Call SalMessageBox( 'Selected Items Year does not match report Year. Please match up first!', 'Warning', MB_Ok )
.head 8 -  Set sItemNoList = 'YEARMISMATCH'
.head 7 -  Call PushString( sItemNoList )
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  On PAM_PTASSINV_GETSELECTED
.head 6 +  If NOT SalStrLeftX( colTreeType, 1 ) = 'C'
.head 7 +  If sItemNoList = ''
.head 8 -  Set sItemNoList = SalNumberToStrX( colItemNo, 0 ) 
.head 7 +  Else
.head 8 -  Set sItemNoList = sItemNoList || ', ' || SalNumberToStrX( colItemNo, 0 ) 
.head 6 +  If nSelectedItemYear = NUMBER_Null
.head 7 -  Set nSelectedItemYear = colYear
.head 6 -  Return TRUE

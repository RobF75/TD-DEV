.head 6 -  Set sSQLPopHandle = " SELECT DISTINCT 
  Stock_Item.Tree_Type, 
  @UPPER( Stock_Item.Tree_Type_Desc ), 
  Stock_Item.Tree_Type_Desc 
FROM 
  Stock_Item 
WHERE 
  Stock_Item.Stock_Type = 'C' AND 
  EXISTS 
  ( 
    SELECT 
      Growing_Sale.Stock_Item_No 
    FROM 
      Growing_Sale 
    WHERE 
      Growing_Sale.Stock_Item_No = Stock_Item.Item_No AND 
      Growing_Sale.Year_Of_Sale >= :1 AND 
      ( Growing_Sale.Not_For_Sale = 'N' OR 
        Growing_Sale.Not_For_Sale IS NULL )
  ) 
ORDER BY 2 "
.head 6 -  Set sNAMEPopHandle = 'POPPTSSIZEINV'
.head 6 -  Set sBINDPopHandle = ':dlgPotsSizeInv.tblPotsSizeInv.nYear'
.head 6 -  Set sINTOPopHandle = ':dlgPotsSizeInv.tblPotsSizeInv.colTreeType,
:dlgPotsSizeInv.tblPotsSizeInv.colUpperTreeTypeDesc,
:dlgPotsSizeInv.tblPotsSizeInv.colTreeTypeDesc'

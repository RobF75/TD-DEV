.head 5 -  Set nMinCustNo = 200000
.head 5 -  Set nMaxCustNo = 299999
.head 4 +  Else If rbNT
.head 5 -  Set nMinCustNo = 800000
.head 5 -  Set nMaxCustNo = 899999

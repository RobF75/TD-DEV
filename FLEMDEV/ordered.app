.head 4 -  !
.head 4 -  Set nError = 1
.head 4 +  If rbView
.head 5 -  Set hWndReport = SalReportView( hWndForm, hWndNULL, sReportFileName, sReportBind, sReportInto, nError )
.head 4 +  Else
.head 5 -  Set hWndReport = SalReportPrint( hWndForm, sReportFileName, sReportBind, sReportInto, 1, RPT_PrintAll | RPT_PrintDraft, 0, 0, nError )
.head 4 -  Call OurWaitCursor( FALSE )
.head 3 +  On SAM_ReportStart
.head 4 +  If nYear < nCurrentYear 
.head 5 -  ! Want to work from the history file
.head 5 +  If rbGC
.head 6 +  If rbBareRootOnly
.head 7 -  Set sSql = "SELECT
  	CO.Cust_No,
  	SUM(CO.Ordered_Amount),
  	SUM(CO.Conf_Amt),
  	SUM(CO.Conf_Amt * CO.Invoice_Tree_Price),
  	SUM(CO.Credited_Amount)	
FROM
  	Cust_Order_History CO, 
	Customer_Master CM, 
	Stock_Item SI
INTO 
	:frmOrdered.nCustNo,
  	:frmOrdered.nSumOrd,
  	:frmOrdered.nSumConf,
	:frmOrdered.nTotAmount,
  	:frmOrdered.nCurrCredit
WHERE 
	CO.Cust_No = CM.Cust_No
AND	CO.Cust_No BETWEEN :frmOrdered.nMinCustNo AND :frmOrdered.nMaxCustNo  
AND	CO.Stock_Item_No = SI.Item_No 
AND	CO.Year_Of_Sale =  :frmOrdered.nYear
AND	SI.Stock_Type = 'B' 
AND	CM.Customer_Type LIKE '%GC%'
GROUP BY
	CO.Cust_No
ORDER BY 
	2 DESC,1"
.head 6 +  Else If rbContainersOnly
.head 7 -  Set sSql = "SELECT
  	CO.Cust_No,

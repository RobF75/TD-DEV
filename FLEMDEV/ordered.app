.head 4 -  Call hSqlOrders.PrepareSetup( sSql )
.head 4 -  !
.head 4 -  Set sSql = "SELECT
  Cust_name,
  Customer_type	
FROM
 customer_master
INTO 
  :frmOrdered.sCustName,
  :frmOrdered.sCustType
where Cust_No =  :frmOrdered.nCustNo"

.head 4 -  Call hSqlCust.PrepareSetup( sSql )
.head 4 -  !
.head 4 -  Set nConstructYear = nYear
.head 4 -  Call AdjustYearOfSaleToYear( nConstructYear)
.head 4 -  Set nConstructYear = nConstructYear - 1
.head 4 -  Set dtBeginDate = SalDateConstruct( nConstructYear, 09, 01, 00, 00, 00 )
.head 4 -  Set nConstructYear = nConstructYear + 1
.head 4 -  Set dtEndDate = SalDateConstruct( nConstructYear, 08, 31, 00, 00, 00 )
.head 4 -  ! 10/11/2003 (PXD) ****************************************************************************************************
.head 4 -  ! 10/11/2003 (PXD) In order to break down the monetary values for each stock_type, we are now 
using Invoice_Tree_Price and Credited_Amounts from the Customer_Order table to calculate the details.
.head 4 -  ! 10/11/2003 (PXD) Set sSql = "SELECT
  SUM(TRANSACTION_AMOUNT)
FROM
 TRANSACTION
 INTO 
  :frmOrdered.nCurrAmount
where Cust_No =  :frmOrdered.nCustNo and 
TRANSACTION_TYPE = 'INVOICE'  AND
Transaction_Date >= :frmOrdered.dtBeginDate and Transaction_Date <= :frmOrdered.dtEndDate"
.head 4 -  ! 10/11/2003 (PXD) Call hSqlCurrAmount.PrepareSetup( sSql )
.head 4 -  !
.head 4 -  ! 10/11/2003 (PXD) Set sSql = "SELECT
  SUM(HIST_TRANS_AMOUNT)
FROM
 TRANS_HISTORY
 INTO 
  :frmOrdered.nHistAmount
where Cust_No =  :frmOrdered.nCustNo and 
HIST_TRANS_TYPE = 'INVOICE'  AND
Hist_Trans_Date >= :frmOrdered.dtBeginDate and Hist_Trans_Date <= :frmOrdered.dtEndDate"
.head 4 -  ! 10/11/2003 (PXD) Call hSqlHistAmount.PrepareSetup( sSql )
.head 4 -  !
.head 4 -  ! !! new credits
.head 4 -  ! 10/11/2003 (PXD) Set sSql = "SELECT
  SUM(TRANSACTION_AMOUNT)
FROM
 TRANSACTION
 INTO 
  :frmOrdered.nCurrCredit
where Cust_No =  :frmOrdered.nCustNo and 
TRANSACTION_TYPE = 'CREDIT'  AND
Transaction_Date >= :frmOrdered.dtBeginDate and Transaction_Date <= :frmOrdered.dtEndDate"
.head 4 -  ! 10/11/2003 (PXD) Call hSqlCurrCredit.PrepareSetup( sSql )
.head 4 -  !
.head 4 -  ! 10/11/2003 (PXD) Set sSql = "SELECT
  SUM(HIST_TRANS_AMOUNT)
FROM
 TRANS_HISTORY
 INTO 
  :frmOrdered.nHistCredit
where Cust_No =  :frmOrdered.nCustNo and 
HIST_TRANS_TYPE = 'CREDIT'  AND
Hist_Trans_Date >= :frmOrdered.dtBeginDate and Hist_Trans_Date <= :frmOrdered.dtEndDate"
.head 4 -  ! 10/11/2003 (PXD) Call hSqlHistCredit.PrepareSetup( sSql )
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchInit
.head 4 -  Call ResetReportFields(  )
.head 4 -  !
.head 4 -  Return hSqlOrders.PrepareAndExecute( )
.head 3 +  On SAM_ReportFetchNext
.head 4 +  Loop
.head 5 -  Call ResetReportFields(  )
.head 5 +  If hSqlOrders.FetchNext( nInd )
.head 6 +  If hSqlCust.PrepareAndExecute( )
.head 7 +  If hSqlCust.FetchNext( nInd)
.head 8 +  If rbIncludeDollars
.head 9 -  ! 10/11/2003 (PXD) In order to break down the monetary values for each stock_type, we are now 
using Invoice_Tree_Price and Credited_Amounts from the Customer_Order table to calculate the details.
.head 9 +  ! 10/11/2003 (PXD) If hSqlCurrAmount.PrepareAndExecute( )
.head 10 -  Call hSqlCurrAmount.FetchNext( nInd )
.head 9 +  ! 10/11/2003 (PXD) If hSqlHistAmount.PrepareAndExecute( )
.head 10 -  Call hSqlHistAmount.FetchNext( nInd )
.head 9 +  ! 10/11/2003 (PXD) If hSqlCurrCredit.PrepareAndExecute( )
.head 10 -  Call hSqlCurrCredit.FetchNext( nInd )
.head 9 +  ! 10/11/2003 (PXD) If hSqlHistCredit.PrepareAndExecute( )
.head 10 -  Call hSqlHistCredit.FetchNext( nInd )
.head 9 -  ! 10/11/2003 (PXD) Set nTotAmount = nCurrAmount + nHistAmount
.head 9 -  ! This gets any cancelled invoices and removes them from
the total
.head 9 -  ! 10/11/2003 (PXD) Set nTotAmount = nTotAmount - nHistCredit
.head 9 -  Set nTotAmount = nTotAmount - nCurrCredit
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Else
.head 7 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 3 +  On SAM_ReportFinish
.head 4 -  Call hSqlOrders.Disconnect( )	! 11/11/03 added these in to allow report regeneration with new SQL details
.head 4 -  Call hSqlCust.Disconnect( ) 	! 11/11/03 added these in to allow report regeneration with new SQL details
.head 4 -  Call SetDefaultPrinter(  )
.head 4 -  Call SalShowWindow( hWndForm )
.head 4 -  Call SalBringWindowToTop( hWndForm )
.head 4 -  Return TRUE
.head 3 +  On SAM_Destroy
.head 4 -  Call hSqlOrders.Disconnect( )
.head 4 -  Call hSqlCust.Disconnect( )
.head 4 -  ! 10/11/2003 (PXD) In order to break down the monetary values for each stock_type, we are now 
using Invoice_Tree_Price and Credited_Amounts from the Customer_Order table to calculate the details.
.head 4 -  ! 10/11/2003 (PXD) Call hSqlCurrAmount.Disconnect( )
.head 4 -  ! 10/11/2003 (PXD) Call hSqlHistAmount.Disconnect( )
.head 4 -  ! 10/11/2003 (PXD) Call hSqlCurrCredit.Disconnect( )
.head 4 -  ! 10/11/2003 (PXD) Call hSqlHistCredit.Disconnect( )
.head 4 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

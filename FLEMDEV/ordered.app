.head 4 -  !
.head 4 -  Call SetPrinter( 'LaserPrinter' )
.head 4 -  Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\orddesc.qrp'
.head 4 -  Set sReportBind = ':frmOrdered.nYear
:frmOrdered.nCustNo, 
:frmOrdered.sCustName, 
:frmOrdered.sCustType, 
:frmOrdered.nSumOrd,
:frmOrdered.nSumConf,

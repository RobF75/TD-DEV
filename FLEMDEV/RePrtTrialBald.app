.head 4 +  Actions
.head 5 -  Call GetMonthBegEndDays( nTBMonth, nTBYear, nTBMonthBegDay, nTBMonthEndDay )
.head 5 -  Set dtTBDate = SalDateConstruct( nTBYear, nTBMonth, nTBMonthEndDay, 0, 0, 0 )
.head 5 -  Set sPath = 'tb'|| SalStrRightX( SalNumberToStrX( nTBYear, 0 ), 1 ) || SalNumberToStrX(
SalDateConstruct( SalDateYear( dtTBDate ),
SalDateMonth( dtTBDate ), SalDateDay( dtTBDate ), 0, 0, 0 ) -
SalDateConstruct( SalDateYear( dtTBDate ), 1, 1, 0, 0, 0 ), 0 )||'.csv'
.head 5 -  Return sPath

.head 6 +  On PAM_clsPB_CLICK
.head 7 +  If rbTrialBalNormal
.head 8 -  Set sTBReportType = 'NORMAL'
.head 7 +  Else If rbTrialBalSummary
.head 8 -  Set sTBReportType = 'SUMMARY'
.head 7 +  Else
.head 8 -  Set sTBReportType = 'PHONELIST'
.head 7 -  !
.head 7 +  If rbView
.head 8 -  Set sReportType = 'VIEW'
.head 7 +  Else
.head 8 -  Set sReportType = 'PRINT'
.head 7 -  !
.head 7 +  If hWndReport = hWndNULL
.head 8 -  Set hWndReport = SalCreateWindow( frmRePrintTrialBalance, hWndForm, dfTrialBalCSVFullFileName, sTBReportType, sReportType )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Call SalMessageBox( 'Please close down your first report!', 'Warning', MB_Ok )
.head 8 -  Return FALSE

.head 4 +  Returns
.head 5 -  Number:
.head 4 +  Parameters
.head 5 -  String: sBCFileName
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sNum
.head 5 -  String: sChar
.head 5 -  Number: nPos
.head 4 +  Actions
.head 5 -  Set sNum = ''
.head 5 -  Set nPos = SalStrLength( sBCFileName ) - 1
.head 5 +  While nPos >= 0
.head 6 -  Set sChar = SalStrMidX( sBCFileName, nPos, 1 )
.head 6 +  If sChar = '0' OR 
sChar = '1' OR 
sChar = '2' OR 
sChar = '3' OR 
sChar = '4' OR 
sChar = '5' OR 
sChar = '6' OR 
sChar = '7' OR 
sChar = '8' OR 
sChar = '9'
.head 7 -  Set sNum = sChar || sNum
.head 6 -  Set nPos = nPos - 1
.head 5 +  If sNum = ''
.head 6 -  Return 0
.head 5 +  Else
.head 6 -  Return SalStrToNumber( sNum )

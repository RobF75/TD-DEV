.head 3 +  On SAM_CreateComplete
.head 4 -  Set sPrinter = 'Barcode'
.head 4 -  Call SalTblSetTableFlags( hWndForm, TBL_Flag_SuppressRowLines, TRUE )
.head 4 -  Call SalTblSetTableFlags( hWndForm, TBL_Flag_SuppressLastColLine, TRUE )
.head 4 -  Call SalSendMsg( hWndForm, PAM_clsTBL_POPULATE, 0, 0 )
.head 3 +  On PAM_clsTBL_POPULATE
.head 4 -  Call SalTblReset( hWndForm )
.head 4 -  Set sQueuePath = OurGetIniFileParameter( 'GENERAL', 'BCLabelsPath', 'C:\TEMP' )
.head 4 -  Set nNumQueueFiles = VisDosEnumFileInfo( sQueuePath || '\\*.bcl', FA_Standard, saQueuelFiles, naQueueSizes, dtaQueueTimeStamps, naQueueAttributes )
.head 4 -  Set nPos = 0
.head 4 +  While nPos < nNumQueueFiles
.head 5 -  Set nRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
.head 5 -  Call SalTblSetContext( hWndForm, nRow )
.head 5 -  Call SalTblSetRowFlags( hWndForm, nRow, ROW_HideMarks, TRUE )
.head 5 -  !
.head 5 -  Set colFullPathFileName = SalStrLowerX( sQueuePath || '\\' || saQueuelFiles[ nPos ] )
.head 5 -  Set colNoPathFileName = saQueuelFiles[ nPos ]
.head 5 -  Set colStatus = 'Paused'
.head 5 -  Set colSize = naQueueSizes[ nPos ]
.head 5 -  Set colGeneratedAt = dtaQueueTimeStamps[ nPos ]
.head 5 -  !
.head 5 -  Set colExtractedNumber = ExtractFileNumber( colNoPathFileName )
.head 5 -  !
.head 5 -  Set nPos = nPos + 1
.head 4 -  !
.head 4 -  Call SalTblSortRows( hWndForm, 1, TBL_SortIncreasing )
.head 4 -  !
.head 4 +  If nNumQueueFiles < 0
.head 5 -  Set nNumQueueFiles = 0
.head 4 -  Call SalStatusSetText( hWndForm, SalNumberToStrX( nNumQueueFiles, 0 )||' jobs in queue' )
.head 4 -  Set bStarted = TRUE
.head 3 +  On PAM_clsTBL_ROWACTION
.head 4 +  If wParam = 1
.head 5 -  ! Set sTmp = OurGetIniFileParameter( 'GENERAL', 'NPrint', 'C:\\TEMP' )||' '||colFullPathFileName||' q=barcode nb nt nff'
.head 5 -  ! Call WinExec( sTmp, 0 )
.head 5 -  !
.head 5 -  Call DIG_Open(sPrinter)
.head 5 -  Call DIG_Out_Line(colFullPathFileName, sPrinter)
.head 5 -  Call DIG_Close()
.head 5 -  Call SalPause( 3500 )
.head 4 -  Set sTmp = OurGetIniFileParameter( 'GENERAL', 'TempStoragePath', 'C:\\TEMP' )||'\\'||colNoPathFileName
.head 4 +  If VisFileCopy( colFullPathFileName, sTmp )
.head 5 -  Call VisFileDelete( colFullPathFileName )
.head 4 -  Return TRUE
.head 3 -  On SAM_Destroy

.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sSQLPopHandle = "   SELECT 
		CUSTOMER_MASTER.CUST_NO, 
		CUST_NAME, 
		Sum(Trans_amount_outst)
	FROM 
		Transaction, 
		CUSTOMER_MASTER 
	WHERE
  		CUSTOMER_MASTER.CUST_NO = Transaction.CUST_NO and
		Trans_amount_outst > 0 and
		transaction_type = 'INVOICE' and
		company = :1
	GROUP BY
		customer_master.cust_no,
		cust_name
	ORDER BY 
		CUST_NAME "
.head 6 -  Set sNAMEPopHandle = 'CUSTOUTSTAND1'
.head 6 -  Set sBINDPopHandle = ':sCompany '
.head 6 -  Set sINTOPopHandle = ':frmAgedDebt.tblAgedDebtList.colCustNo, 
		:frmAgedDebt.tblAgedDebtList.colCustName,
 		:frmAgedDebt.tblAgedDebtList.colTotalOwing'
.head 6 -  ! !
.head 6 -  Set bAddAllowed = FALSE
.head 6 -  Set bSaveAllowed = TRUE
.head 6 -  Set bDeleteAllowed = FALSE
.head 6 -  Set bUnDeleteAllowed = FALSE
.head 6 -  Set bRepopulateAllowed = TRUE
.head 6 -  Set bClearSelectAllowed = TRUE
.head 6 -  Set bQueryAllowed = FALSE
.head 6 -  Set bReportAllowed = TRUE
.head 6 -  Set bOrderAllowed = TRUE
.head 6 -  Set bMakeCSVFileAllowed = TRUE
.head 6 -  ! !
.head 6 -  Set bSelectFirstRow = FALSE
.head 6 -  ! !
.head 6 -  Set sPrinter = 'LaserPrinter'
.head 6 -  Set sReportFileName = 'AgedDebtList.qrp'
.head 6 -  Set sRepBind = ':frmAgedDebt.tblAgedDebtList.colCustNo, 
		:frmAgedDebt.tblAgedDebtList.colCustName,
 		:frmAgedDebt.tblAgedDebtList.colTotalOwing, 
		:frmAgedDebt.tblAgedDebtList.col90Plus, 
		:frmAgedDebt.tblAgedDebtList.col60To90, 
		:frmAgedDebt.tblAgedDebtList.col30To60,
		:frmAgedDebt.tblAgedDebtList.colCurrent,
		:frmAgedDebt.sCompany'
.head 6 -  Set sRepInto = '
	nCustNo, 
	sCustName,
	nTotalOwing, 
	n90Plus,
	n60To90, 
	n30To60, 
	nCurrent, 
	sCompany'
.head 5 +  On SAM_FetchRowDone
.head 6 +  If colCustNo = 511476
.head 7 -  Call SalMessageBox('Here','Here',MB_Ok)
.head 6 -  Call ExtractTransactions(colCustNo, colCurrent, col30To60, col60To90,col90Plus, sCompany, SH_cls_Execute )
.head 5 +  On PAM_clsTBL_SAVECHANGES
.head 6 -  Call SalTblQueryScroll( tblAgedDebtList, nCurrent, nMin, nMax )
.head 6 -  Set nRow = nMin
.head 6 +  While SalTblFetchRow( tblAgedDebtList, nRow )
.head 7 +  If colPrint != 'Y'
.head 8 -  ! Call SalTblSetRowFlags( tblAgedDebtList, nRow, ROW_MarkDeleted, TRUE )
.head 8 -  Call SalTblDeleteRow( tblAgedDebtList, nRow, TBL_Adjust )
.head 7 +  Else
.head 8 -  Call SalTblSetRowFlags( tblAgedDebtList, nRow, ROW_Edited, FALSE )
.head 7 -  Set nRow = nRow + 1

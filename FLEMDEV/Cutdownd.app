.head 2 +  Window Variables
.head 3 -  ! sItemType = 'ALL' , 'BAREROOT', 'CONTAINERS'
.head 3 -  String: sItemType
.head 3 -  ! sCustTypes = 'GARDEN_CENTRES', 'NOT_GARDEN_CENTRES', 'ORCHARDISTS', 'NOT_ORCHARDISTS'
.head 3 -  String: sCustTypes
.head 3 -  ! sCustOrdToComeType = 'ORDERS_STILL_TO_GO', 'NO_MORE_ORDERS_TO_GO'
.head 3 -  String: sCustOrdToComeType
.head 2 +  Message Actions
.head 3 +  On SAM_CreateComplete
.head 4 +  If WhichTypeOfSeason( SalDateCurrent(  ) ) = 'WINTER'
.head 5 -  Set rbBareRoot = TRUE
.head 4 +  Else
.head 5 -  Set rbContainers = TRUE
.head 4 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 3 +  On PAM_clsPB_OKACTION
.head 4 +  If rbAll
.head 5 -  Set sItemType = 'ALL'
.head 4 +  Else If rbBareRoot
.head 5 -  Set sItemType = 'BAREROOT'
.head 4 +  Else
.head 5 -  Set sItemType = 'CONTAINERS'
.head 4 -  !
.head 4 +  If cbNotCustTypes
.head 5 +  If rbGardenCentres
.head 6 -  Set sCustTypes = 'NOT_GARDEN_CENTRES'
.head 5 +  Else
.head 6 -  Set sCustTypes = 'NOT_ORCHARDISTS'
.head 4 +  Else
.head 5 +  If rbGardenCentres
.head 6 -  Set sCustTypes = 'GARDEN_CENTRES'
.head 5 +  Else
.head 6 -  Set sCustTypes = 'ORCHARDISTS'
.head 4 -  !
.head 4 +  If rbNoMoreOrd
.head 5 -  Set sCustOrdToComeType = 'NO_MORE_ORDERS_TO_GO'
.head 4 +  Else
.head 5 -  Set sCustOrdToComeType = 'ORDERS_STILL_TO_GO'
.head 4 -  !
.head 4 -  Call SalCreateWindow( frmCutDown, hWndForm, sItemType, sCustTypes, sCustOrdToComeType, ccSeasonYear.GetSeasonYear( ) )

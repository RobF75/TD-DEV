  CO1.Stock_Item_No = SI1.Item_No AND 
  NOT CO1.Ordered_Amount = CO1.Conf_Amt AND 
  SI1.Tree_Type LIKE 'C%' AND 
  NOT EXISTS 
  (
    SELECT 
      CO2.Order_Date_Time 
    FROM 
      Customer_Order CO2, 
      Stock_Item SI2 
    WHERE 
      CO2.Cust_No = CO1.Cust_No AND 
      CO2.Stock_Item_No = SI2.Item_No AND 
      SI2.Tree_Type LIKE 'C%' AND 
      CO2.Year_Of_Sale = CO1.Year_Of_Sale AND 
      CO2.Ordered_Amount = CO2.Conf_Amt AND 
      (
        CO2.Pull_Sheet_Issued = 'N' OR 
        CO2.Pull_Sheet_Issued IS NULL 
      ) 
  ) "
.head 5 +  Else If sItemType = 'BAREROOT'
.head 6 -  Set sSqlWHEREPart = " WHERE " || sSqlCUSTTYPEPart || " 

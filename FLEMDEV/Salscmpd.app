.head 3 +  On SAM_ReportStart
.head 4 -  Set nThisYear = ccSeasonYear.GetSeasonYear( )
.head 4 -  Set nLastYear = nThisYear-1
.head 4 +  If nLastYear <1997 AND nLastYear >1950
.head 5 -  Set nLastYear = nLastYear - 1900
.head 4 -  !
.head 4 +  If rbSelectedStates
.head 5 +  If cbACT
.head 6 +  If sStates = STRING_Null
.head 7 -  Set sStates = "'ACT'"
.head 6 +  Else
.head 7 -  Set sStates = sStates || ',' || "'ACT'"
.head 5 +  If cbNSW
.head 6 +  If sStates = STRING_Null
.head 7 -  Set sStates = "'NSW'"
.head 6 +  Else
.head 7 -  Set sStates = sStates || ',' || "'NSW'"
.head 5 +  If cbNT
.head 6 +  If sStates = STRING_Null
.head 7 -  Set sStates = "'NT'"
.head 6 +  Else
.head 7 -  Set sStates = sStates || ',' || "'NT'"
.head 5 +  If cbQLD
.head 6 +  If sStates = STRING_Null
.head 7 -  Set sStates = "'QLD'"
.head 6 +  Else
.head 7 -  Set sStates = sStates || ',' || "'QLD'"
.head 5 +  If cbSA
.head 6 +  If sStates = STRING_Null
.head 7 -  Set sStates = "'SA'"
.head 6 +  Else
.head 7 -  Set sStates = sStates || ',' || "'SA'"
.head 5 +  If cbTAS
.head 6 +  If sStates = STRING_Null
.head 7 -  Set sStates = "'TAS'"
.head 6 +  Else
.head 7 -  Set sStates = sStates || ',' || "'TAS'"
.head 5 +  If cbVIC
.head 6 +  If sStates = STRING_Null
.head 7 -  Set sStates = "'VIC'"
.head 6 +  Else
.head 7 -  Set sStates = sStates || ',' || "'VIC'"
.head 5 +  If cbWA
.head 6 +  If sStates = STRING_Null
.head 7 -  Set sStates = "'WA'"
.head 6 +  Else
.head 7 -  Set sStates = sStates || ',' || "'WA'"
.head 4 +  Else
.head 5 -  Set sStates = "'ACT','NSW','NT','QLD','SA','TAS','VIC','WA'"
.head 4 -  !
.head 4 +  If rbOrderByCustNo
.head 5 -  Set sOrderBy = '1,2,3'
.head 4 +  Else If rbOrderByName
.head 5 -  Set sOrderBy = '2,1,3'
.head 4 +  Else If rbOrderByAmt
.head 5 -  Set sOrderBy = '4'
.head 4 +  Else
.head 5 -  Set sOrderBy = '3,1,2'
.head 4 -  !
.head 4 -  ! 23/06/05 (PXD) Added stock type selection options at Wes's request - problem number 837
.head 4 +  If rbBareRoot = TRUE
.head 5 -  Set sStockType = 'B'
.head 5 -  Set sStockTypeDesc = 'Bare Root Stock'
.head 4 +  Else If rbContainers = TRUE
.head 5 -  Set sStockType = 'C'
.head 5 -  Set sStockTypeDesc = 'Containerised Stock'
.head 4 +  Else
.head 5 -  Set sStockType = '%'
.head 5 -  Set sStockTypeDesc = 'All Types'
.head 4 -  !
.head 4 -  ! 27/05/2002 (PXD) Have altered statement to reflect new selection criteria for state or customer type - problem number 170
.head 4 -  ! Set sSql = " SELECT 
  Customer_Master.Cust_No, 
  Customer_Master.Cust_Name, 
  MIN(Customer_Order.Ord_Date), 
  SUM(Customer_Order.Ordered_Amount)
FROM 
  Customer_Order, 
  Customer_Master, 
  Stock_Item
WHERE 
  Customer_Master.Customer_Type LIKE '%GC%' AND 
  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
  Customer_Order.Year_Of_Sale = :frmCustSalesComp.nThisYear AND 
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
  NOT Stock_Item.Tree_Type LIKE 'C%'
GROUP BY 
  1,2
ORDER BY 
  3,1,2
INTO 
  :frmCustSalesComp.nCustNo,
  :frmCustSalesComp.sCustName,
  :frmCustSalesComp.dtMinOrdDate,
  :frmCustSalesComp.nThisYearOrdAmt"
.head 4 +  If rbAllCustomers
.head 5 -  Set sSql = " 
SELECT 
	CM.Cust_No, 
	CM.Cust_Name, 
	MIN(CO.Ord_Date), 
	SUM(CO.Ordered_Amount)
FROM 
  	Customer_Address CA,
  	Customer_Order CO, 
  	Customer_Master CM, 
  	Stock_Item SI
WHERE
  	CO.Cust_No = CA.Cust_No
AND  	CA.Main_Address_Flag = 'Y' 
AND 	CA.State IN (" || sStates || ")
AND  	CO.Cust_No = CM.Cust_No 
AND  	CO.Year_Of_Sale = :frmCustSalesComp.nThisYear
AND	CO.Stock_Item_No = SI.Item_No
AND	SI.Stock_Type LIKE :frmCustSalesComp.sStockType
GROUP BY 
 	1,2
ORDER BY 
  	" || sOrderBy || "
INTO 
  	:frmCustSalesComp.nCustNo,
  	:frmCustSalesComp.sCustName,
  	:frmCustSalesComp.dtMinOrdDate,
  	:frmCustSalesComp.nThisYearOrdAmt"
.head 4 +  If rbAllGCentres
.head 5 -  Set sSql = " 
SELECT 
	CM.Cust_No, 
	CM.Cust_Name, 
	MIN(CO.Ord_Date), 
	SUM(CO.Ordered_Amount)
FROM 
  	Customer_Address CA,
  	Customer_Order CO, 
  	Customer_Master CM, 
  	Stock_Item SI
WHERE
  	CO.Cust_No = CA.Cust_No
AND  	CA.Main_Address_Flag = 'Y' 
AND 	CA.State IN (" || sStates || ")
AND  	CM.Customer_Type LIKE '%GC%'
AND  	CO.Cust_No = CM.Cust_No 
AND  	CO.Year_Of_Sale = :frmCustSalesComp.nThisYear
AND	CO.Stock_Item_No = SI.Item_No
AND	SI.Stock_Type LIKE :frmCustSalesComp.sStockType
GROUP BY 
 	1,2
ORDER BY 
  	" || sOrderBy || "
INTO 
  	:frmCustSalesComp.nCustNo,
  	:frmCustSalesComp.sCustName,
  	:frmCustSalesComp.dtMinOrdDate,
  	:frmCustSalesComp.nThisYearOrdAmt"
.head 4 +  If rbAllOrchardists
.head 5 -  Set sSql = " 
SELECT 
	CM.Cust_No, 
	CM.Cust_Name, 
	MIN(CO.Ord_Date), 
	SUM(CO.Ordered_Amount)
FROM 
  	Customer_Address CA,
  	Customer_Order CO, 
  	Customer_Master CM, 
  	Stock_Item SI
WHERE
  	CO.Cust_No = CA.Cust_No
AND  	CA.Main_Address_Flag = 'Y' 
AND 	CA.State IN (" || sStates || ")
AND  	CM.Customer_Type LIKE '%OR%'
AND  	CO.Cust_No = CM.Cust_No 
AND  	CO.Year_Of_Sale = :frmCustSalesComp.nThisYear
AND	CO.Stock_Item_No = SI.Item_No
AND	SI.Stock_Type LIKE :frmCustSalesComp.sStockType
GROUP BY 
 	1,2
ORDER BY 
  	" || sOrderBy || "
INTO 
  	:frmCustSalesComp.nCustNo,
  	:frmCustSalesComp.sCustName,
  	:frmCustSalesComp.dtMinOrdDate,
  	:frmCustSalesComp.nThisYearOrdAmt"
.head 4 +  If rbSelectedCustomers
.head 5 -  Set sSql = " 
SELECT 
	CM.Cust_No, 
	CM.Cust_Name, 
	MIN(CO.Ord_Date), 
	SUM(CO.Ordered_Amount)
FROM 
  	Customer_Address CA,
  	Customer_Order CO, 
  	Customer_Master CM, 
  	Stock_Item SI
WHERE
  	CO.Cust_No = CA.Cust_No
AND  	CA.Main_Address_Flag = 'Y' 
AND 	CA.State IN (" || sStates || ")
AND  	CM.Customer_Type IN (" || sCustTypeList || " ) 
AND  	CO.Cust_No = CM.Cust_No 
AND  	CO.Year_Of_Sale = :frmCustSalesComp.nThisYear
AND	CO.Stock_Item_No = SI.Item_No
AND	SI.Stock_Type LIKE :frmCustSalesComp.sStockType
GROUP BY 
 	1,2
ORDER BY 
  	" || sOrderBy || "
INTO 
  	:frmCustSalesComp.nCustNo,
  	:frmCustSalesComp.sCustName,
  	:frmCustSalesComp.dtMinOrdDate,
  	:frmCustSalesComp.nThisYearOrdAmt"
.head 4 -  Call hSqlOrders.PrepareSetup( sSql )
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchInit
.head 4 -  Set nGCLastYearOrdAmtTotal = 0
.head 4 -  Set nGCThisYearOrdAmtTotal = 0
.head 4 -  Set nGCSalesCompTotal = 0
.head 4 -  Set nGCPercSalesCompTotal = 0
.head 4 -  Set nORLastYearOrdAmtTotal = 0
.head 4 -  Set nORThisYearOrdAmtTotal = 0
.head 4 -  Set nORSalesCompTotal = 0
.head 4 -  Set nORPercSalesCompTotal = 0
.head 4 -  Call hSqlOrders.PrepareAndExecute( )
.head 4 -  Call hSqlOrders.ResultSetCount( nTotalOrders )
.head 4 -  Set nCountOrders = 0
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchNext
.head 4 +  If hSqlOrders.FetchNext( nInd )
.head 5 -  Set nCountOrders = nCountOrders + 1
.head 5 -  !
.head 5 -  Call CalcHistOrdAmt( nCustNo, nLastYear, sStockType, nLastYearOrdAmt, SH_cls_Execute )
.head 5 -  Set nSalesComp = nThisYearOrdAmt - nLastYearOrdAmt
.head 5 -  Set nPercSalesComp =  CalcPercentageIncrease( nLastYearOrdAmt, nThisYearOrdAmt )
.head 5 -  !
.head 5 -  Set nGCLastYearOrdAmtTotal = nGCLastYearOrdAmtTotal + nLastYearOrdAmt
.head 5 -  Set nGCThisYearOrdAmtTotal = nGCThisYearOrdAmtTotal + nThisYearOrdAmt
.head 5 -  !
.head 5 +  If nCountOrders = nTotalOrders
.head 6 -  ! If SqlUser = 'WES'
.head 6 +  If IsUserFlemingsFamily( SqlUser, FALSE )
.head 7 -  Set nGCSalesCompTotal = nGCThisYearOrdAmtTotal - nGCLastYearOrdAmtTotal
.head 7 -  Set nGCPercSalesCompTotal =  CalcPercentageIncrease( nGCLastYearOrdAmtTotal, nGCThisYearOrdAmtTotal )
.head 7 -  !
.head 7 -  ! Call CalcOrchTotalHistOrdAmt( nLastYear, nORLastYearOrdAmtTotal, SH_cls_Execute )
.head 7 -  ! Call CalcOrchTotalOrdAmt( nThisYear, nORThisYearOrdAmtTotal, SH_cls_Execute )
.head 7 -  Call CalcTotalHistOrdAmt( nLastYear, sStockType, nORLastYearOrdAmtTotal, SH_cls_Execute )
.head 7 -  Call CalcTotalOrdAmt( nThisYear, sStockType, nORThisYearOrdAmtTotal, SH_cls_Execute )
.head 7 -  Set nORSalesCompTotal = nORThisYearOrdAmtTotal - nORLastYearOrdAmtTotal
.head 7 -  Set nORPercSalesCompTotal =  CalcPercentageIncrease( nORLastYearOrdAmtTotal, nORThisYearOrdAmtTotal )
.head 6 +  Else
.head 7 -  Set nGCLastYearOrdAmtTotal = NUMBER_Null
.head 7 -  Set nGCThisYearOrdAmtTotal = NUMBER_Null
.head 7 -  Set nGCSalesCompTotal = NUMBER_Null
.head 7 -  Set nGCPercSalesCompTotal =  NUMBER_Null
.head 7 -  !
.head 7 -  Set nORLastYearOrdAmtTotal = NUMBER_Null
.head 7 -  Set nORThisYearOrdAmtTotal = NUMBER_Null
.head 7 -  Set nORSalesCompTotal = NUMBER_Null
.head 7 -  Set nORPercSalesCompTotal =  NUMBER_Null
.head 5 -  Return TRUE
.head 4 +  Else
.head 5 -  Return FALSE
.head 3 +  On SAM_ReportFinish
.head 4 -  Call hSqlOrders.Disconnect( )
.head 4 -  Call CalcHistOrdAmt( 0, 0, '', nLastYearOrdAmt, SH_cls_Disconnect )
.head 4 -  ! Call CalcOrchTotalHistOrdAmt( 0, nORLastYearOrdAmtTotal, SH_cls_Disconnect )
.head 4 -  ! Call CalcOrchTotalOrdAmt( 0, nORThisYearOrdAmtTotal, SH_cls_Disconnect )
.head 4 -  Call CalcTotalHistOrdAmt( 0, '',  nORLastYearOrdAmtTotal, SH_cls_Disconnect )
.head 4 -  Call CalcTotalOrdAmt( 0, '', nORThisYearOrdAmtTotal, SH_cls_Disconnect )
.head 4 -  Call SalShowWindow( hWndForm )
.head 4 -  Call SalBringWindowToTop( hWndForm )
.head 4 -  Return TRUE
.head 3 +  On SAM_Destroy
.head 4 -  ! 27/05/2002 (PXD) Moved the following disconnects to the SAM_ReportFinish to allow differing reports 
to alter SQL statements without having to close the main window first.
.head 4 -  ! Call hSqlOrders.Disconnect( )
.head 4 -  ! Call CalcHistOrdAmt( 0, 0, nLastYearOrdAmt, SH_cls_Disconnect )
.head 4 -  ! Call CalcOrchTotalHistOrdAmt( 0, nORLastYearOrdAmtTotal, SH_cls_Disconnect )
.head 4 -  ! Call CalcOrchTotalOrdAmt( 0, nORThisYearOrdAmtTotal, SH_cls_Disconnect )
.head 4 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
.head 3 -  ! 27/05/2002 (PXD) Added following to enable/disable all Window form check boxes
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Call SalSendMsgToChildren( hWndForm, PAM_clsCB_CLEAR, 0, 0 )
.head 4 -  Call SalSendMsgToChildren( hWndForm, PAM_clsCB_DISABLE, 0, 0 )
.head 3 +  On PAM_clsCB_DISABLE
.head 4 -  Call SalSendMsgToChildren( hWndForm, PAM_clsCB_DISABLE, 0, 0 )
.head 3 +  On PAM_clsCB_ENABLE

.head 3 +  Function: CalcPercentageIncrease
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Number:
.head 4 +  Parameters
.head 5 -  Number: nLastYear
.head 5 -  Number: nThisYear
.head 4 -  Static Variables
.head 4 -  Local variables
.head 4 +  Actions
.head 5 +  If nLastYear = 0 OR nLastYear = NUMBER_Null
.head 6 -  Return 1
.head 5 +  Else
.head 6 -  Return ( nThisYear / nLastYear ) - 1

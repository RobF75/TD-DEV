.head 3 +  On PAM_clsSALSCMPD_REPORT
.head 4 -  Call OurWaitCursor( TRUE )
.head 4 -  !
.head 4 -  Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\salscmp1.qrp'
.head 4 -  Set sReportBind = ':frmCustSalesComp.nLastYear, 
:frmCustSalesComp.nThisYear, 
:frmCustSalesComp.dtMinOrdDate,
:frmCustSalesComp.nCustNo,
:frmCustSalesComp.sCustName,
:frmCustSalesComp.nLastYearOrdAmt,

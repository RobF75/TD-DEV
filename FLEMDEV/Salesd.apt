.head 8 -  Set colSoldType14 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType15
.head 8 -  Set colSoldType15 = nNewTotalTrees
.head 5 +  Function: DoesTreeTypeMatch
.head 6 -  Description:
.head 6 +  Returns
.head 7 -  Boolean:
.head 6 -  Parameters
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  Boolean: bFound
.head 6 +  Actions
.head 7 +  If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[1]
.head 8 -  Set bFound = TRUE
.head 7 +  Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[2]
.head 8 -  Set bFound = TRUE
.head 7 +  Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[3]
.head 8 -  Set bFound = TRUE
.head 7 +  Else If sNewTreeTypeDesc = frmItemsSizeSalesReport.sTreeTypes[4]
.head 8 -  Set bFound = TRUE

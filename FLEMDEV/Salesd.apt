:frmItemsSalesSeqReport.tblItems.colGCTotalSales, 
:frmItemsSalesSeqReport.tblItems.colORTotalSales,
:frmItemsSalesSeqReport.tblItems.colOtherTotalSales,  
:frmItemsSalesSeqReport.tblItems.colTotalSales, 
:frmItemsSalesSeqReport.tblItems.colOwnerRoyalties, 
:frmItemsSalesSeqReport.tblItems.colFNARoyalties, 
:frmItemsSalesSeqReport.tblItems.colFMNRoyalties'
.head 4 -  Set sReportInputs = 'ReportHeading, 
YearOfSale, 
OrderDateType, 
OrderDate, 
ItemNo, 
VarietyType, 
Variety, 
TreeTypeDesc, 
CultDesc, 
RootDesc, 
GCTrees, 
ORTrees, 
FCRPTrees, 
OtherTrees, 
TotalTrees, 
GCSales, 
ORSales, 
OtherSales, 
TotalSales, 
OwnerRoyalties, 
FNARoyalties, 
FMNRoyalties'
.head 4 -  Set nError = 1
.head 4 +  If sViewPrint = 'PRINT'
.head 5 -  Set hWndReport = SalReportPrint( hWndForm, sReportName, sReportBinds, sReportInputs, 1, RPT_PrintAll | RPT_PrintNoWarn, 0, 0, nError )
.head 4 +  Else
.head 5 -  Set hWndReport = SalReportView( hWndForm, hWndForm, sReportName, sReportBinds, sReportInputs, nError )
.head 5 +  If hWndReport = hWndNULL
.head 6 -  Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
.head 3 +  On PAM_SALES_INSERTINDEX
.head 4 -  Return SalSendMsg( tblItems, PAM_SALES_INSERTINDEX, wParam, lParam )

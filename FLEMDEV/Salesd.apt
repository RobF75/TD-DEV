.head 7 -  Set colCultDesc = sNewCultDesc
.head 7 -  Set colRootDesc = sNewRootDesc
.head 5 +  Function: MatchTreeTypes
.head 6 -  Description:
.head 6 -  Returns
.head 6 -  Parameters
.head 6 -  Static Variables
.head 6 -  Local variables
.head 6 +  Actions
.head 7 +  If sNewTreeTypeDesc = colType1
.head 8 -  Set colSoldType1 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType2
.head 8 -  Set colSoldType2 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType3
.head 8 -  Set colSoldType3 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType4
.head 8 -  Set colSoldType4 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType5
.head 8 -  Set colSoldType5 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType6
.head 8 -  Set colSoldType6 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType7
.head 8 -  Set colSoldType7 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType8
.head 8 -  Set colSoldType8 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType9
.head 8 -  Set colSoldType9 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType10
.head 8 -  Set colSoldType10 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType11
.head 8 -  Set colSoldType11 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType12
.head 8 -  Set colSoldType12 = nNewTotalTrees
.head 7 +  Else If sNewTreeTypeDesc = colType13
.head 8 -  Set colSoldType13 = nNewTotalTrees

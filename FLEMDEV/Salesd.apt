.head 4 +  Message Actions
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sSQLPopHandle = "SELECT Tree_Type, Tree_Type_Desc 
FROM Tree_Type 
WHERE Tree_Type IN ( 'MR1', 'MR2', 'RD1', 'RD2', 'MS1', 'MS2', 'MG1', 'MG2', 'REG', 
'ADV', 'SHT', 'TALL', 'XLBR', 'STSM', 'SML' ) 
ORDER BY Tree_Type_Desc "
.head 6 -  Set sNAMEPopHandle = 'SPOPDEFTTYPE'
.head 6 -  Set sBINDPopHandle = ''
.head 6 -  Set sINTOPopHandle = ':frmSalesReports.tblSelectedTreeTypes.colTreeType, :frmSalesReports.tblSelectedTreeTypes.colTreeTypeDesc '
.head 6 -  !
.head 6 -  Set bAddAllowed = TRUE
.head 6 -  Set bSelectFirstRow = FALSE
.head 6 -  !
.head 6 -  Set nMaxTreeTypesInSizeReport = 15
.head 5 +  On PAM_SALES_MATCHTREETYPES
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_RESET, 0, 0 )
.head 6 +  If TableLoop( tblSelectedItems, hWndForm, PAM_SALES_MATCHITEM, 0, 0, 0, 'Matching Selected Items Tree Types', TBL_cls_LowToHi )
.head 7 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  On PAM_SALES_MATCHITEM
.head 6 -  Set bFound = FALSE
.head 6 -  Set nSearchRow = TBL_MinRow
.head 6 +  While SalTblFindNextRow( hWndForm, nSearchRow, 0, 0 ) AND NOT bFound
.head 7 -  Call SalTblSetContext( hWndForm, nSearchRow )
.head 7 +  If colTreeType = tblSelectedItems.colTreeType
.head 8 -  Set bFound = TRUE
.head 6 +  If NOT bFound
.head 7 -  Set bInsert = TRUE
.head 7 +  If rbOnlyContainers
.head 8 +  If SalStrScan( tblSelectedItems.colTreeType, 'C%' ) < 0
.head 9 -  Set bInsert = FALSE
.head 7 +  Else If rbExcludeContainers
.head 8 +  If SalStrScan( tblSelectedItems.colTreeType, 'C%' ) >= 0
.head 9 -  Set bInsert = FALSE
.head 7 -  !
.head 7 +  If bInsert
.head 8 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 8 -  Set nTmp = SalTblQueryContext( hWndForm )
.head 8 -  Set colTreeType = tblSelectedItems.colTreeType
.head 8 -  Set colTreeTypeDesc = tblSelectedItems.colTreeTypeDesc
.head 8 -  Call SalTblSetRowFlags( hWndForm, nTmp, ROW_HideMarks, TRUE )
.head 6 -  Return TRUE
.head 5 +  On SAM_FetchRowDone
.head 6 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_New, TRUE )
.head 6 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_HideMarks, TRUE )
.head 6 -  Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
.head 5 +  On PAM_SALES_GETSELECTEDITEMS
.head 6 -  Set nTmp = 0
.head 6 -  Set sTreeTypes[ nTmp ] = ''
.head 6 -  Set nTmp = nTmp + 1
.head 6 -  Set sTreeTypes[ nTmp ] = ''
.head 6 +  If TableLoop( hWndForm, hWndForm, PAM_SALES_GETSELECTED, 0, 0, 0, 'Extracting Tree Types', TBL_cls_LowToHi )
.head 7 +  If nTmp-1 > nMaxTreeTypesInSizeReport
.head 8 +  If IDYES = SalMessageBox( 'Only the first ' || SalNumberToStrX( nMaxTreeTypesInSizeReport, 0 ) || 
' Tree Types can appear on the size report any others will be ignored! Continue with this report?', 'Warning', MB_YesNo )
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  On PAM_SALES_GETSELECTED
.head 6 -  Set sTreeTypes[ nTmp ] = tblSelectedTreeTypes.colTreeType
.head 6 -  Set nTmp = nTmp + 1
.head 6 -  Set sTreeTypes[ nTmp ] = ''
.head 6 -  Return TRUE
.head 3 -  !

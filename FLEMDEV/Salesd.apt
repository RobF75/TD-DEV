.head 7 -  Number: nNewRow
.head 6 +  Actions
.head 7 -  Set nNewRow = SalTblInsertRow( hWndForm, TBL_MaxRow )
.head 7 -  Call SalTblSetContext( hWndForm, nNewRow )
.head 7 -  Set colType1 = frmItemsSizeSalesReport.sTreeTypes[1]
.head 7 -  Set colType2 = frmItemsSizeSalesReport.sTreeTypes[2]
.head 7 -  Set colType3 = frmItemsSizeSalesReport.sTreeTypes[3]

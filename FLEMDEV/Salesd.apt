.head 11 +  If sGotRoyOwner = 'FMN'
.head 12 -  Set nFMNAmtPayable = nFMNAmtPayable + nGotAmtPayable
.head 11 +  Else If sGotRoyOwner = 'FNA'
.head 12 -  Set nFNAAmtPayable = nFNAAmtPayable + nGotAmtPayable
.head 11 +  Else
.head 12 -  Set nOtherAmtPayable = nOtherAmtPayable + nGotAmtPayable
.head 10 -  Return TRUE

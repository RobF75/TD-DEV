.head 6 -    Set sSql = "SELECT 
    Transaction.Transaction_Date, 
    Transaction.Reference_Id, 
    Transaction.Transaction_Amount
  FROM 
    Transaction 
  WHERE 
    Transaction.Cust_No = :frmTransLedger.nCustNo AND 
    NOT Transaction.Transaction_Type = 'INVOICE' AND
    Transaction.Transaction_Code = 'DR' AND 
    Transaction.Transaction_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate 
  UNION ALL 
  SELECT 
    Trans_History.Hist_Trans_Date, 
    Trans_History.Hist_Reference_Id, 
    Trans_History.Hist_Trans_Amount
  FROM 
    Trans_History 
  WHERE 
    Trans_History.Cust_No = :frmTransLedger.nCustNo AND 
    NOT Trans_History.Hist_Trans_Type = 'INVOICE' AND
    Trans_History.Hist_Trans_Code = 'DR' AND  
    Trans_History.Hist_Trans_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate 
  INTO 
    :frmTransLedger.dtTransDate, 
    :frmTransLedger.sTransReferenceId, 
    :frmTransLedger.nTransAmount
  ORDER BY 1 "
.head 6 -    Call fcDRJournalsHdl.PrepareSetup( sSql )
.head 6 -    Call SqlVarSetup( fcDRJournalsHdl.hSqlHandle )
.head 6 -  !
.head 6 -    Call fcDRJournalsHdl.PrepareAndExecute( )
.head 6 -    Call fcDRJournalsHdl.ResultSetCount( nCountSectionResultSet )
.head 6 -    Set nCountSectionPos = 0
.head 6 -  !
.head 6 -    Set sSectionHeading = 'DR Journals'
.head 6 -    Set nSectionSubTotal = NUMBER_Null
.head 5 +    If fcDRJournalsHdl.FetchNext( nInd )

.head 6 +    If nCountSectionPos = nCountSectionResultSet
.head 7 -    Set nTotalTransAmount = nSectionSubTotal
.head 7 -    Set nReportTotal = nReportTotal - nSectionSubTotal
.head 6 -    Return TRUE
.head 5 +    Else 
.head 6 -    Set bProcessCRJournals = FALSE
.head 6 -    Set bProcessDRJournals = TRUE

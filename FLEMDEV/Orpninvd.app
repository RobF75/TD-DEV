.head 3 +  On SAM_CreateComplete
.head 4 -  Set rbPrint = FALSE
.head 4 -  Set hWndReport = hWndNULL
.head 4 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 3 +  On PAM_clsORPNINVD_REPORT
.head 4 -  Call OurWaitCursor( TRUE )
.head 4 -  !
.head 4 -  Set sReportFileName = OurGetIniFileParameter( 'GENERAL', 'ReportsPath', '' )||'\\ordpnin2.qrp'
.head 4 -  Set sReportBind = '  :frmOrdersPulledNotInv.nCustNo, 
  :frmOrdersPulledNotInv.sCustName, 
  :frmOrdersPulledNotInv.nYearOfSale, 
  :frmOrdersPulledNotInv.sVarietyType, 
  :frmOrdersPulledNotInv.sUpperVariety, 
  :frmOrdersPulledNotInv.sUpperCultDesc,
  :frmOrdersPulledNotInv.sUpperRootDesc,
  :frmOrdersPulledNotInv.sTreeTypeDesc, 
  :frmOrdersPulledNotInv.sCultDesc,
  :frmOrdersPulledNotInv.sRootDesc,
  :frmOrdersPulledNotInv.nConfAmt, 
  :frmOrdersPulledNotInv.sSaleCat,
  :frmOrdersPulledNotInv.nContPrice'
.head 4 -  Set sReportInto = 'nCustNo, 
  sCustName, 
  nYearOfSale, 
  sVarietyType, 
  sUpperVariety, 
  sUpperCultDesc,
  sUpperRootDesc,
  sTreeTypeDesc, 
  sCultDesc,
  sRootDesc,
  nConfAmt, 
  sSaleCat,
  nContPrice'
.head 4 -  Set nError = 1
.head 4 +  If rbView
.head 5 -  Set hWndReport = SalReportView( hWndForm, hWndNULL, sReportFileName, sReportBind, sReportInto, nError )
.head 4 +  Else
.head 5 -  Set hWndReport = SalReportPrint( hWndForm, sReportFileName, sReportBind, sReportInto, 1, RPT_PrintAll | RPT_PrintDraft, 0, 0, nError )
.head 4 -  Call OurWaitCursor( FALSE )
.head 3 +  On SAM_ReportStart
.head 4 -  Set frmOrdersPulledNotInv.dtEndDate = SalDateMonthBegin( SalDateCurrent(  ) )
.head 4 -  Set sSql = "SELECT 
  Customer_Order.Cust_No, 
  Customer_Master.Cust_Name,
  Customer_Order.Year_Of_Sale, 
  Stock_Item.Variety_Type,
  @UPPER(Stock_Item.Variety),
  @UPPER(Stock_Item.Cult_Desc),
  @UPPER(Stock_Item.Root_Desc),
  Stock_Item.Tree_Type_Desc,
  Stock_Item.Cult_Desc,
  Stock_Item.Root_Desc, 
  Customer_Order.Conf_Amt,
  Customer_Order.Sale_Cat, 
  Customer_Order.Contract_Price
FROM 
  Customer_Order,
  Customer_Master,
  Stock_Item
INTO 
  :frmOrdersPulledNotInv.nCustNo, 
  :frmOrdersPulledNotInv.sCustName, 
  :frmOrdersPulledNotInv.nYearOfSale, 
  :frmOrdersPulledNotInv.sVarietyType, 
  :frmOrdersPulledNotInv.sUpperVariety, 
  :frmOrdersPulledNotInv.sUpperCultDesc,
  :frmOrdersPulledNotInv.sUpperRootDesc,
  :frmOrdersPulledNotInv.sTreeTypeDesc, 
  :frmOrdersPulledNotInv.sCultDesc,
  :frmOrdersPulledNotInv.sRootDesc,
  :frmOrdersPulledNotInv.nConfAmt, 
  :frmOrdersPulledNotInv.sSaleCat,
  :frmOrdersPulledNotInv.nContPrice 
WHERE
  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
  Customer_Order.Pull_Sheet_Issued = 'Y' AND Customer_Order.Pull_Sheet_Date < :frmOrdersPulledNotInv.dtEndDate AND
  ( Customer_Order.Invoiced_Flag = 'N' OR Invoiced_Flag IS NULL )
ORDER BY 1,3,4,5,6,7,8,12,11 "
.head 4 -  Call hSqlOrders.PrepareSetup( sSql )
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchInit
.head 4 -  Return hSqlOrders.PrepareAndExecute( )
.head 3 +  On SAM_ReportFetchNext
.head 4 -  Return hSqlOrders.FetchNext( nInd )
.head 3 +  On SAM_ReportFinish
.head 4 -  Call SalShowWindow( hWndForm )
.head 4 -  Call SalBringWindowToTop( hWndForm )
.head 4 -  Return TRUE
.head 3 +  On SAM_Destroy
.head 4 -  Call hSqlOrders.Disconnect( )
.head 4 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

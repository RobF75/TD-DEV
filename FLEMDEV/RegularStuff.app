.head 9 -  Call GetRegistryValue( 'GENERAL', 'AdminManagerEmail', sAdminEmail, 'tony@factree.com.au' )
.head 9 -  Call SendMail( sSubject, sText, sAdminEmail, '', '', '' )
.head 7 +  Else
.head 8 -  Return FALSE

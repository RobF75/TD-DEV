.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sQueryDialogName = ''
.head 6 -  !
.head 6 -  ! 02/07/2003 (PXD) Changed SQL statement to allow season boundary crossing for selection dates 
.head 6 -  !
.head 6 -  ! Set sSQLPopHandle = "
SELECT
	Stock_Item_No,
	Invoice_No,
	Invoiced_Date,
	Conf_Amt
FROM
	Customer_Order
WHERE
	Cust_No = :1
AND	Invoiced_Date >= :2
AND	Invoiced_Date <= :3
ORDER BY
	Invoiced_Date"
.head 6 -  ! Set sNAMEPopHandle = '2606FREIGHTCOSTS'
.head 6 -  Set sSQLPopHandle = "
SELECT
	Stock_Item_No,
	Invoice_No,
	Invoiced_Date,
	Conf_Amt
FROM
	Customer_Order
WHERE
	Cust_No = :1
AND	Invoiced_Date >= :2
AND	Invoiced_Date <= :3

UNION ALL

SELECT
	Stock_Item_No,
	Invoice_No,
	Invoiced_Date,
	Conf_Amt
FROM
	Cust_Order_History
WHERE
	Cust_No = :1
AND	Invoiced_Date >= :2
AND	Invoiced_Date <= :3

ORDER BY
	3,2"
.head 6 -  Set sNAMEPopHandle = '0207FREIGHTCOSTS'
.head 6 -  Set sBINDPopHandle = '
	:frmShippedQty.dfCustNo,
	:frmShippedQty.dtFromDate,
	:frmShippedQty.dtToDate'
.head 6 -  Set sINTOPopHandle = '
	:frmShippedQty.tblShippedQty.colItemNo,
	:frmShippedQty.tblShippedQty.colInvoiceNo,
	:frmShippedQty.tblShippedQty.colInvoiceDate,
	:frmShippedQty.tblShippedQty.colConfAmt'
.head 6 -  !
.head 6 -  Set sTableHeading = 'Shipped Item Quantities'
.head 6 -  Set nTableFillType = TBL_FillAll
.head 6 -  !
.head 6 -  Set bAddAllowed = FALSE
.head 6 -  Set bSaveAllowed = FALSE
.head 6 -  Set bDeleteAllowed = FALSE

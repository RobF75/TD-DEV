.head 6 -  Set bSelectFirstRow = FALSE
.head 6 -  !
.head 6 -  Set sPrinter = 'Laser'
.head 6 -  Set sReportFileName = 'ShippedItemQty.qrp'
.head 6 -  Set sRepBind = '
	:frmShippedQty.tblShippedQty.sTableHeading,
	:frmShippedQty.dfCustNo,
	:frmShippedQty.sCustType,
	:frmShippedQty.sCustName,	
	:frmShippedQty.dtFromDate,
	:frmShippedQty.dtToDate,
	:frmShippedQty.tblShippedQty.colItemNo,
	:frmShippedQty.tblShippedQty.colCultDesc,
	:frmShippedQty.tblShippedQty.colTypeDesc,
	:frmShippedQty.tblShippedQty.colInvoiceNo,
	:frmShippedQty.tblShippedQty.colInvoiceDate,
	:frmShippedQty.tblShippedQty.colConfAmt,
	:frmShippedQty.dfTotalCount'
.head 6 -  Set sRepInto = '
	Title,
	CustNo,
	CustType,
	CustName,
	FromDate,
	ToDate,
	ItemNo,
	CultDesc,
	TypeDesc,
	InvoiceNo,
	InvoiceDate,
	ConfAmt,
	TotalQty'
.head 6 -  !

.head 6 +  On SAM_Click
.head 7 -  Set bContinue = FALSE
.head 7 +  If dfCustNo = NUMBER_Null
.head 8 +  If sCustName = STRING_Null
.head 9 -  Call SalMessageBox( 'Please check selection criteria first!', 'Invalid Selection', MB_Ok )
.head 8 +  Else
.head 9 +  If fnGetCustNo( sCustName, dfCustNo, SH_cls_Execute )
.head 10 -  Set cmbCustName = sCustName
.head 10 -  Set bContinue = TRUE
.head 9 +  Else
.head 10 -  Call SalMessageBox( 'Unable to resolve customer details from name supplied', 'fnGetCustNo', MB_Ok )
.head 7 +  Else If sCustName = STRING_Null
.head 8 +  If dfCustNo = NUMBER_Null
.head 9 -  Call SalMessageBox( 'Please check selection criteria first!', 'Invalid Selection', MB_Ok )
.head 8 +  Else
.head 9 +  If fnGetCustName( dfCustNo, sCustName, sCustType, SH_cls_Execute )
.head 10 -  Set cmbCustType = sCustType
.head 10 -  Set cmbCustName = sCustName
.head 10 -  Set bContinue = TRUE
.head 9 +  Else
.head 10 -  Call SalMessageBox( 'Unable to resolve customer details from number supplied', 'fnGetCustName', MB_Ok )
.head 7 +  Else
.head 8 -  Set bContinue = TRUE
.head 7 -  !
.head 7 +  If bContinue = TRUE
.head 8 -  Call SalSendMsgToChildren( hWndForm, PAM_GETDATES, 0, 0 )
.head 8 +  If dtFromDate > dtToDate
.head 9 -  Call SalMessageBox( 'Please check Date selection!', 'Invalid Dates', MB_Ok )
.head 8 +  ! 02/07/2003 (PXD) Else If dtFromDate < SalDateConstruct( SalDateYear( SalDateCurrent(  ) ) - 1, 09, 01, 00, 00, 00 )
        OR dtToDate > SalDateConstruct( SalDateYear( SalDateCurrent(  ) ), 08, 31, 23, 59, 59 )
.head 9 -  Call SalMessageBox( 'Date selection exceeds limit - This program is restricted to the current season only', 'Incorrect date given', MB_Ok )
.head 9 -  Return FALSE
.head 8 +  Else
.head 9 -  Set dfTotalCount = 0
.head 9 -  Call SalSendMsg( tblShippedQty, PAM_clsTBL_POPULATE, 0, 0 )

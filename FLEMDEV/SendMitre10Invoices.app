.head 2 +  Message Actions
.head 3 +  On SAM_CreateComplete
.head 4 -  Call SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 4 -  Call GetRegistryValue( 'ACCOUNTS', 'MITRE10HostOut', sInvoiceDirectory, 'c:\\Temp' )
.head 4 -  ! Southern Region
.head 4 -  Set sInvoiceFile = sInvoiceDirectory ||  '\\SthRegionMitre10eInvoice.txt'
.head 4 +  If VisDosExist( sInvoiceFile )
.head 5 -  Set sNewInvoiceFile = sInvoiceDirectory ||  '\\SthRegionMitre10eInvoice_m' || SalNumberToStrX( SalDateMonth( SalDateCurrent(  )), 0 ) || 'd' || SalNumberToStrX( SalDateDay( SalDateCurrent(  ) ), 0 ) || '.txt' 
.head 5 -  Call VisFileRename( sInvoiceFile, sNewInvoiceFile )
.head 5 -  Set sInvoiceFile = sNewInvoiceFile
.head 5 -  Call GetRegistryValue( 'ACCOUNTS', 'MITRE10SthHeadOffice', sMitre10HeadOffice, '333488' )
.head 5 -  Set nMitre10HeadOffice = SalStrToNumber( sMitre10HeadOffice )
.head 5 -  Call GetMainEmailAddress( nMitre10HeadOffice, sMitre10Email, SH_cls_Execute )
.head 5 -  Call GetRegistryValue( 'GENERAL', 'SysAdm', sAdminEmail, 'graham@flemings.com.au' )
.head 5 +  If NOT SendMail('Electronic Invoices from Flemings Nurseries', 'Please find attached electronic invoice files', sMitre10Email,'','', sInvoiceFile )
.head 6 -  Call SendMail('Failed to send Mitre 10 Invoices', 'Programming error, Please fix program ',sAdminEmail,'','', '')
.head 5 +  Else
.head 6 -  Set sSourceFile = sInvoiceFile
.head 6 -  Set sFilingFile = OurGetIniFileParameter( 'ACCOUNTS', 'Correspondence', 'c:\\temp' ) || '\\'
.head 6 -  Call SalDateToStr( SalDateCurrent(  ), sDateAsString )
.head 6 -  Set sFilingFile = sFilingFile || '333488_eInvoice_' || sDateAsString || '.txt'
.head 6 -  !
.head 6 +  If NOT sSourceFile = sFilingFile
.head 7 +  If VisFileCopy( sSourceFile, sFilingFile ) > 0
.head 8 +  If VisFileDelete( sSourceFile ) <= 0
.head 9 -  Call SendMail('Failed DELETE Mitre 10 Invoice file', 'Programming error, Please fix program ',sAdminEmail,'','', '')
.head 7 +  Else
.head 8 -  Call CreateFileStructure( 'CSVFiles' )
.head 8 +  If VisFileCopy( sSourceFile, sFilingFile ) > 0
.head 9 +  If VisFileDelete( sSourceFile ) <= 0
.head 10 -  Call SendMail('Failed DELETE Mitre 10 Invoice file', 'Programming error, Please fix program ',sAdminEmail,'','', '')
.head 8 +  Else
.head 9 -  Call SendMail('Failed COPY to FILE Mitre 10 Invoice file', 'Programming error, Please fix program ',sAdminEmail,'','', '')
.head 4 -  ! Northern Region
.head 4 -  Set sInvoiceFile = sInvoiceDirectory ||  '\\NthRegionMitre10eInvoice.txt'
.head 4 +  If VisDosExist( sInvoiceFile )
.head 5 -  Call GetRegistryValue( 'ACCOUNTS', 'MITRE10NthHeadOffice', sMitre10HeadOffice, '410826' )
.head 5 -  Set nMitre10HeadOffice = SalStrToNumber( sMitre10HeadOffice )
.head 5 -  Call GetMainEmailAddress( nMitre10HeadOffice, sMitre10Email, SH_cls_Execute )
.head 5 -  Call GetRegistryValue( 'GENERAL', 'SysAdm', sAdminEmail, 'graham@flemings.com.au' )
.head 5 +  If NOT SendMail('Electronic Invoices from Flemings Nurseries', 'Please find attached electronic invoice files', sMitre10Email,'','', sInvoiceFile )
.head 6 -  Call SendMail('Failed to send Mitre 10 Invoices', 'Programming error, Please fix program ',sAdminEmail,'','', '')
.head 5 +  Else
.head 6 -  Set sSourceFile = sInvoiceFile
.head 6 -  Set sFilingFile = OurGetIniFileParameter( 'ACCOUNTS', 'Correspondence', 'c:\\temp' ) || '\\'
.head 6 -  Call SalDateToStr( SalDateCurrent(  ), sDateAsString )
.head 6 -  Set sFilingFile = sFilingFile || 'c333488_eInvoice_' || sDateAsString || '.txt'
.head 6 -  !
.head 6 +  If NOT sSourceFile = sFilingFile
.head 7 +  If VisFileCopy( sSourceFile, sFilingFile ) > 0
.head 8 +  If VisFileDelete( sSourceFile ) <= 0
.head 9 -  Call SendMail('Failed DELETE Mitre 10 Invoice file', 'Programming error, Please fix program ',sAdminEmail,'','', '')
.head 7 +  Else
.head 8 -  Call SendMail('Failed COPY to FILE Mitre 10 Invoice file', 'Programming error, Please fix program ',sAdminEmail,'','', '')
.head 4 -  Call CSVFilingControl( hWndForm )
.head 4 -  Call SalDestroyWindow( hWndForm )
.head 3 +  On SAM_Destroy
.head 4 -  Call GetMainEmailAddress( 0, sTmp, SH_cls_Disconnect )

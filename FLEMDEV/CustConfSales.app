PRC_Received,
NPA_Received,
TA_Received'
.head 4 -  !
.head 4 -  Set sReportType = sReportPrintOrView
.head 4 -  !
.head 4 +  If sCompany = 'Z'
.head 5 -  Set sReportSql = "Stock_Item.Prod_Royalty != 'A'"
.head 4 +  Else
.head 5 -  Set sReportSql = "Stock_Item.Prod_Royalty = 'A'"
.head 4 -  !
.head 4 +  If sAllSeasons = 'Y'
.head 5 -  Set sReportSql = "SELECT 
  Customer_Order.Cust_No, 
  Customer_Master.Cust_Name, 
  Stock_Item.Tree_Type_Desc,
  Stock_Item.Cult_Desc,
  Stock_Item.Root_Desc,
  Customer_Order.Conf_Amt, 
  Customer_Order.No_Trees_Credited,
  Customer_Order.Invoice_No,
  Customer_Order.Invoiced_Date,
  Customer_Order.Sale_Cat,
  Customer_Order.PRC_Recd_Flag,
  Customer_Order.NPA_Recd_Flag,
  Customer_Order.TA_Recd_Flag
FROM 
  Customer_Order, 
  Customer_Master, 
  Stock_Item 
WHERE 
  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
  Customer_Order.Invoiced_Flag = 'Y' AND 
  Customer_Order.Conf_Amt > 0 AND
  " || sReportSql || "
UNION
SELECT 
  Cust_Order_History.Cust_No, 
  Customer_Master.Cust_Name, 
  Stock_Item.Tree_Type_Desc,
  Stock_Item.Cult_Desc,
  Stock_Item.Root_Desc,
  Cust_Order_History.Conf_Amt, 
  Cust_Order_History.No_Trees_Credited,
  Cust_Order_History.Invoice_No,
  Cust_Order_History.Invoiced_Date,
  Cust_Order_History.Sale_Cat,
  Cust_Order_History.PRC_Recd_Flag,
  Cust_Order_History.NPA_Recd_Flag,
  Cust_Order_History.TA_Recd_Flag
FROM 
  Cust_Order_History, 
  Customer_Master, 
  Stock_Item 
WHERE 
  Cust_Order_History.Cust_No = Customer_Master.Cust_No AND 
  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
  Cust_Order_History.Invoiced_Flag = 'Y' AND 
  Cust_Order_History.Conf_Amt > 0 AND
  " || sReportSql || " 
ORDER BY 2, 3, 4, 5
INTO
  :hWndForm.nCustNo, 
  :hWndForm.sCustName, 
  :hWndForm.sTreeTypeDesc,
  :hWndForm.sCultDesc,
  :hWndForm.sRootDesc,
  :hWndForm.nConfAmt, 
  :hWndForm.nTreesCredited,
  :hWndForm.nInvoiceNo, 
  :hWndForm.dtInvoiceDate,
  :hWndForm.sSaleCat,
  :hWndForm.sPRCReceived,
  :hWndForm.sNPAReceived,
  :hWndForm.sTAReceived"
.head 4 +  Else If nYear < WhichSeasonYear( SalDateCurrent(  ) ) AND NOT nYear = 77 AND NOT bForceCurrentOrderFile
.head 5 -  Set sReportSql = "SELECT 
  Customer_Order.Cust_No, 
  Customer_Master.Cust_Name, 
  Stock_Item.Tree_Type_Desc,
  Stock_Item.Cult_Desc,
  Stock_Item.Root_Desc,
  Customer_Order.Conf_Amt, 
  Customer_Order.No_Trees_Credited,
  Customer_Order.Invoice_No,
  Customer_Order.Invoiced_Date,
  Customer_Order.Sale_Cat,
  Customer_Order.PRC_Recd_Flag,
  Customer_Order.NPA_Recd_Flag,
  Customer_Order.TA_Recd_Flag
FROM 
  Customer_Order, 
  Customer_Master, 
  Stock_Item 
INTO
  :hWndForm.nCustNo, 
  :hWndForm.sCustName, 
  :hWndForm.sTreeTypeDesc,
  :hWndForm.sCultDesc,
  :hWndForm.sRootDesc,
  :hWndForm.nConfAmt, 
  :hWndForm.nTreesCredited,
  :hWndForm.nInvoiceNo, 
  :hWndForm.dtInvoiceDate,
  :hWndForm.sSaleCat,
  :hWndForm.sPRCReceived,
  :hWndForm.sNPAReceived,
  :hWndForm.sTAReceived
WHERE 
  Customer_Order.Cust_No = Customer_Master.Cust_No AND 
  Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
  Customer_Order.Year_Of_Sale = :hWndForm.nYear AND 
  Customer_Order.Invoiced_Flag = 'Y' AND 
  Customer_Order.Conf_Amt > 0 AND
  " || sReportSql || "
ORDER BY 
  Customer_Master.Cust_Name,
  Stock_Item.Tree_Type_Desc,
  Stock_Item.Cult_Desc,
  Stock_Item.Root_Desc"
.head 4 +  Else
.head 5 -  Set sReportSql = "SELECT 
  Cust_Order_History.Cust_No, 
  Customer_Master.Cust_Name, 
  Stock_Item.Tree_Type_Desc,
  Stock_Item.Cult_Desc,
  Stock_Item.Root_Desc,
  Cust_Order_History.Conf_Amt, 
  Cust_Order_History.No_Trees_Credited,
  Cust_Order_History.Invoice_No,
  Cust_Order_History.Invoiced_Date,
  Cust_Order_History.Sale_Cat,
  Cust_Order_History.PRC_Recd_Flag,
  Cust_Order_History.NPA_Recd_Flag,
  Cust_Order_History.TA_Recd_Flag
FROM 
  Cust_Order_History, 
  Customer_Master, 
  Stock_Item 
INTO
  :hWndForm.nCustNo, 
  :hWndForm.sCustName, 
  :hWndForm.sTreeTypeDesc,
  :hWndForm.sCultDesc,
  :hWndForm.sRootDesc,
  :hWndForm.nConfAmt, 
  :hWndForm.nTreesCredited,
  :hWndForm.nInvoiceNo, 
  :hWndForm.dtInvoiceDate,
  :hWndForm.sSaleCat,
  :hWndForm.sPRCReceived,
  :hWndForm.sNPAReceived,
  :hWndForm.sTAReceived
WHERE 
  Cust_Order_History.Cust_No = Customer_Master.Cust_No AND 
  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
  Cust_Order_History.Year_Of_Sale = :hWndForm.nYear AND 
  Cust_Order_History.Invoiced_Flag = 'Y' AND 
  Cust_Order_History.Conf_Amt > 0 AND
  " || sReportSql || "
ORDER BY 
  Customer_Master.Cust_Name,
  Stock_Item.Tree_Type_Desc,
  Stock_Item.Cult_Desc,
  Stock_Item.Root_Desc"
.head 3 +  On PAM_clsFRM_REPORTSTART
.head 4 +  If NOT sMailMergeFileName = ''
.head 5 -  Call fcOutputFile.Setup( sMailMergeFileName, NUMBER_Null, NUMBER_Null )
.head 5 -  Call fcOutputFile.Open( )
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFETCHINIT
.head 4 -  Call fBuildCSVLine( 'HEADER', SH_cls_Execute )

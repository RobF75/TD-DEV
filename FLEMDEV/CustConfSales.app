.head 4 +  Actions
.head 5 +  If nActionType = SH_cls_Execute
.head 6 +  If sType = 'HEADER'
.head 7 -  Set sTmp = 'Customer_No, "Customer_Name", "Company", "Address_Line1", "Address_Line2", "Suburb", "State", "Postcode"'
.head 7 -  Call fcOutputFile.Write( sTmp )
.head 6 +  Else
.head 7 +  If NOT nCustNo = nLastCustNo
.head 8 -  Call GetMainAddress( nCustNo, dtTmp, sTmp, sAddressLine1, sAddressLine2, sSuburb, sPostcode, sState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, 'Y', SH_cls_Execute )
.head 8 -  Set nLastCustNo = nCustNo
.head 8 -  Set sTmp = SalNumberToStrX( nCustNo, 0 ) || ', "' || 
sCustName || '", "' || 
sCompany || '", "' || 
sAddressLine1 || '", "' || 
sAddressLine2 || '", "' || 
sSuburb || '", "' || 
sState || '", "' || 
sPostcode || '"'
.head 8 -  Call fcOutputFile.Write( sTmp )
.head 5 +  Else
.head 6 -  Call GetMainAddress( 0, dtTmp, sTmp, sAddressLine1, sAddressLine2, sSuburb, sPostcode, sState, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, sTmp, 'Y', nActionType )

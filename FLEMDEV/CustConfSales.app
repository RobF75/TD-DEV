.head 3 +  On PAM_clsFRM_REPORTSTART
.head 4 +  If NOT sMailMergeFileName = ''
.head 5 -  Call fcOutputFile.Setup( sMailMergeFileName, NUMBER_Null, NUMBER_Null )
.head 5 -  Call fcOutputFile.Open( )
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFETCHINIT
.head 4 -  Call fBuildCSVLine( 'HEADER', SH_cls_Execute )
.head 4 -  Call fBuildCSVLine( 'DETAIL', SH_cls_Execute )
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFETCHNEXT
.head 4 -  Call fBuildCSVLine( 'DETAIL', SH_cls_Execute )
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFETCHNEXTEND
.head 4 +  If NOT sMailMergeFileName = ''
.head 5 -  Call fcOutputFile.Close( )
.head 5 -  Call fBuildCSVLine( 'DETAIL', SH_cls_Disconnect )
.head 5 -  Set sMailMergeFileName = ''
.head 4 -  Return FALSE

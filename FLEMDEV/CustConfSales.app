.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set sPrinter = 'LaserPrinter'
.head 4 -  Set sReportFileNameNoPath = 'CustConfCultSales2.qrp'
.head 4 -  Set sReportBind = ':hWndForm.sCompany,
:hWndForm.nYear, 
:hWndForm.nCustNo, 
:hWndForm.sCustName, 
:hWndForm.nInvoiceNo, 
:hWndForm.dtInvoiceDate,
:hWndForm.sTreeTypeDesc,
:hWndForm.sCultDesc,
:hWndForm.sRootDesc,
:hWndForm.nConfAmt, 

.head 4 -    Set sReportType = 'VIEW'
.head 4 -  !
.head 4 -    Set sReportSql = "SELECT 
  Stock_Item.Variety_Type, 
  @UPPER( Stock_Item.Variety ), 
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  Stock_Item.Variety, 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Item_No 
FROM 
  Stock_Item, 
  Stock_Item_Sale 
INTO 
  :frmPrBundles.sVarietyType, 
  :frmPrBundles.sUpperVariety, 
  :frmPrBundles.sUpperCultDesc, 
  :frmPrBundles.sUpperRootDesc, 
  :frmPrBundles.sVariety, 
  :frmPrBundles.sTreeTypeDesc, 
  :frmPrBundles.sCultDesc, 
  :frmPrBundles.sRootDesc, 
  :frmPrBundles.nItemNo 
WHERE 
  Stock_Item.Stock_Type = 'B' AND 
  ( Stock_Item.Generic_Stock_Item = 'N' OR 
    Stock_Item.Generic_Stock_Item IS NULL ) AND 
  Stock_Item.Item_No = Stock_Item_Sale.Stock_Item_No AND 
  Stock_Item_Sale.Year_Of_Sale = :frmPrBundles.nYear AND 
  Stock_Item_Sale.Amt_Growing > 0 
ORDER BY 
  1,2,3,4,6 "
.head 3 +    On PAM_clsFRM_REPORTSTART
.head 4 -    Set nYear = WhichSeasonYear( SalDateCurrent(  ) )

.head 5 -  Set sSql = " SELECT 
  CO.Cust_No, 
  SUM( CO.Conf_Amt ) 
FROM 
  Cust_Order_History CO 
INTO 
  :frmPrBundles.nCustNoItem, 
  :frmPrBundles.nCustConfAmtItem 
WHERE 
   CO.Stock_Item_No = :frmPrBundles.nItemNo AND 

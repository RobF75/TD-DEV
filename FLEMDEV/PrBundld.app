.head 3 +  On PAM_clsFRM_REPORTFETCHNEXT
.head 4 -  Set nFives = NUMBER_Null
.head 4 -  Set nFours = NUMBER_Null
.head 4 -  Set nThrees = NUMBER_Null
.head 4 -  Set nTwos = NUMBER_Null
.head 4 -  Set nOnes = NUMBER_Null
.head 4 -  !
.head 4 -  Set nCustConfAmt = NUMBER_Null
.head 4 +  If fcCustConfAmtItem.PrepareAndExecute( )
.head 5 +  If fcCustConfAmtSub.PrepareAndExecute( )
.head 6 -  !
.head 6 -  Set nCustNoItem = NUMBER_Null
.head 6 -  Set nCustNoSub = NUMBER_Null
.head 6 -  Set nCustConfAmtItem = NUMBER_Null
.head 6 -  Set nCustConfAmtSub = NUMBER_Null
.head 6 -  !
.head 6 +  If fcCustConfAmtItem.FetchNext( nInd )
.head 7 -  Set bMoreItem = TRUE
.head 7 -  Set bProcessItem = TRUE
.head 6 +  Else
.head 7 -  Set bMoreItem = FALSE
.head 7 -  Set bProcessItem = FALSE
.head 6 -  !
.head 6 +  If fcCustConfAmtSub.FetchNext( nInd )
.head 7 -  Set bMoreSub = TRUE
.head 7 -  Set bProcessSub = TRUE
.head 6 +  Else
.head 7 -  Set bMoreSub = FALSE
.head 7 -  Set bProcessSub = FALSE
.head 6 -  !
.head 6 +  While bMoreItem OR bMoreSub
.head 7 -  !
.head 7 +  If bMoreItem AND bMoreSub
.head 8 +  If nCustNoItem = nCustNoSub
.head 9 -  Set nCustConfAmt = nCustConfAmtItem + nCustConfAmtSub
.head 9 -  Set bProcessItem = TRUE
.head 9 -  Set bProcessSub = TRUE
.head 8 +  If nCustNoItem < nCustNoSub
.head 9 -  Set nCustConfAmt = nCustConfAmtItem
.head 9 -  Set bProcessItem = TRUE
.head 9 -  Set bProcessSub = FALSE
.head 8 +  Else
.head 9 -  Set nCustConfAmt = nCustConfAmtSub
.head 9 -  Set bProcessItem = FALSE
.head 9 -  Set bProcessSub = TRUE
.head 7 +  Else If bMoreItem AND NOT bMoreSub
.head 8 -  Set nCustConfAmt = nCustConfAmtItem
.head 8 -  Set bProcessItem = TRUE
.head 7 +  Else
.head 8 -  Set nCustConfAmt = nCustConfAmtSub
.head 8 -  Set bProcessSub = TRUE
.head 7 -  !
.head 7 -  Set nResult = nCustConfAmt
.head 7 -  Set nGroup = 10
.head 7 +  While nGroup > 0
.head 8 +  If nResult >= nGroup
.head 9 -  Set nResult = SalNumberMod( nResult, nGroup )
.head 9 +  If nResult >= 0
.head 10 +  Select Case nGroup
.head 11 +  Case 10
.head 12 -  Break
.head 11 +  Case 5
.head 12 -  Set nFives = nFives + 1
.head 12 -  Break
.head 11 +  Case 4
.head 12 -  Set nFours = nFours + 1
.head 12 -  Break
.head 11 +  Case 3
.head 12 -  Set nThrees = nThrees + 1
.head 12 -  Break
.head 11 +  Case 2
.head 12 -  Set nTwos = nTwos + 1
.head 12 -  Break
.head 11 +  Case 1
.head 12 -  Set nOnes = nOnes + 1
.head 12 -  Break
.head 8 -  !
.head 8 +  If nGroup = 10
.head 9 -  Set nGroup = 5
.head 8 +  Else
.head 9 -  Set nGroup = nGroup - 1
.head 7 -  !
.head 7 +  If bProcessItem AND bMoreItem
.head 8 +  If NOT fcCustConfAmtItem.FetchNext( nInd )
.head 9 -  Set bMoreItem = FALSE
.head 7 +  If bProcessSub AND bMoreSub
.head 8 +  If NOT fcCustConfAmtSub.FetchNext( nInd )
.head 9 -  Set bMoreSub = FALSE
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 4 +  Else
.head 5 -  Return FALSE
.head 3 +  On PAM_clsFRM_REPORTFINISH
.head 4 -  Call fcCustConfAmtItem.Disconnect( )
.head 4 -  Call fcCustConfAmtSub.Disconnect( )
.head 4 -  Return TRUE

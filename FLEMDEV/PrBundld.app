INTO 
  :frmPrBundles.nCustNo, 
  :frmPrBundles.nCustConfAmt 
WHERE 
  ( 
    Customer_Order.Stock_Item_No = :frmPrBundles.nItemNo OR 
    Customer_Order.Subs_Item_No = :frmPrBundles.nItemNo 
  ) AND 
    Customer_Order.Year_Of_Sale = :frmPrBundles.nYear AND 
  ( Customer_Order.Invoiced_Flag = 'N' OR 
  Customer_Order.Invoiced_Flag IS NULL ) 
GROUP BY 
  Customer_Order.Cust_No "
.head 4 -    Call fcCustConfAmt.PrepareSetup( sSql )
.head 4 -    Call SqlVarSetup( fcCustConfAmt.hSqlHandle )
.head 4 -    Return TRUE
.head 3 +    On PAM_clsFRM_REPORTFETCHNEXT
.head 4 -    Set nFives = NUMBER_Null
.head 4 -    Set nFours = NUMBER_Null
.head 4 -    Set nThrees = NUMBER_Null
.head 4 -    Set nTwos = NUMBER_Null
.head 4 -    Set nOnes = NUMBER_Null
.head 4 +    If fcCustConfAmt.PrepareAndExecute( )
.head 5 +    While fcCustConfAmt.FetchNext( nInd )
.head 6 -  !
.head 6 -    Set nResult = nCustConfAmt
.head 6 -    Set nGroup = 10
.head 6 +    While nGroup > 0
.head 7 +    If nResult >= nGroup
.head 8 -    Set nResult = SalNumberMod( nResult, nGroup )
.head 8 +    If nResult >= 0
.head 9 +    Select Case nGroup
.head 10 +    Case 10
.head 11 -    Break 
.head 10 +    Case 5
.head 11 -    Set nFives = nFives + 1
.head 11 -    Break 
.head 10 +    Case 4
.head 11 -    Set nFours = nFours + 1
.head 11 -    Break 
.head 10 +    Case 3
.head 11 -    Set nThrees = nThrees + 1
.head 11 -    Break 
.head 10 +    Case 2
.head 11 -    Set nTwos = nTwos + 1
.head 11 -    Break 
.head 10 +    Case 1
.head 11 -    Set nOnes = nOnes + 1
.head 11 -    Break 
.head 7 -  !
.head 7 +    If nGroup = 10
.head 8 -    Set nGroup = 5
.head 7 +    Else 
.head 8 -    Set nGroup = nGroup - 1
.head 6 -  !
.head 5 -    Return TRUE
.head 4 +    Else 
.head 5 -    Return FALSE
.head 3 +    On PAM_clsFRM_REPORTFINISH
.head 4 -    Return fcCustConfAmt.Disconnect( )

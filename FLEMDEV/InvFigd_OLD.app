.head 6 +  Message Actions
.head 7 +  On SAM_AnyEdit
.head 8 +  If colMonth = 'Jan'
.head 9 -  Call MonthFromAndToDates( 1, colFromDate, colToDate )
.head 8 +  Else If colMonth = 'Feb'
.head 9 -  Call MonthFromAndToDates( 2, colFromDate, colToDate )
.head 8 +  Else If colMonth = 'Mar'
.head 9 -  Call MonthFromAndToDates( 3, colFromDate, colToDate )
.head 8 +  Else If colMonth = 'Apr'
.head 9 -  Call MonthFromAndToDates( 4, colFromDate, colToDate )
.head 8 +  Else If colMonth = 'May'
.head 9 -  Call MonthFromAndToDates( 5, colFromDate, colToDate )
.head 8 +  Else If colMonth = 'Jun'
.head 9 -  Call MonthFromAndToDates( 6, colFromDate, colToDate )
.head 8 +  Else If colMonth = 'Jul'
.head 9 -  Call MonthFromAndToDates( 7, colFromDate, colToDate )
.head 8 +  Else If colMonth = 'Aug'
.head 9 -  Call MonthFromAndToDates( 8, colFromDate, colToDate )
.head 8 +  Else If colMonth = 'Sep'

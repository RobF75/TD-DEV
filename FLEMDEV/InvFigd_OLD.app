	customer_type
FROM 
  	Customer_Order, 
  	Stock_Item,
	Tree_Type,
	customer_master
WHERE 
	customer_master.cust_no = customer_order.cust_no and 
	Tree_Type.Tree_Type = Stock_Item.Tree_Type and
  	Customer_Order.Invoiced_Flag = 'Y' AND 
  	Customer_Order.Stock_Item_No = Stock_Item.Item_No AND 
  	Customer_Order.Invoiced_Date BETWEEN :1 AND :2 AND 
  	Tree_Type.Item_Type = :3 
UNION ALL 
SELECT 
  	Cust_Order_History.Conf_Amt,
	Cust_Order_History.Invoice_Tree_Price, 
	Cust_Order_History.credited_amount, 
	Cust_Order_History.NO_TREES_CREDITED,
	INV_TREE_ROY_OWNR,
	INV_TREE_FMN,
	INV_TREE_FNA,
	Invoice_no,
	contract_Price,
	customer_type
FROM 
  	Cust_Order_History, 
  	Stock_Item,
	Tree_Type,
	customer_master
WHERE 
	customer_master.cust_no = cust_order_history.cust_no and 
	Tree_Type.Tree_Type = Stock_Item.Tree_Type and
  	Cust_Order_History.Invoiced_Flag = 'Y' AND 
  	Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
  	Cust_Order_History.Invoiced_Date BETWEEN :1 AND :2 AND 
  	Tree_Type.Item_Type = :3
ORDER BY
	8
"
.head 10 -  Set sName = 'INVFIGCATSTISTP11'
.head 10 -  Set sBind = ':dtFromDate, :dtToDate, :sStockType'
.head 10 -  Set sInto = ':nConfAmt, :nInvTreePrice, :nCreditedAmt, :nNoTreesCredited, :nRoyOwnAmt, :nFMNAmt, :nFNAAmt, :nInvNo, :nContractPrice, :sCustType'
.head 10 -  Call haSqlHandles[ nStockTypeHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 10 -  Call SqlVarSetup( haSqlHandles[ nStockTypeHandleNo ].hSqlHandle )
.head 10 -  !
.head 10 +  If sStockTypeDesc = 'Bare'
.head 11 -  Set sStockType = 'B'
.head 10 +  Else If sStockTypeDesc = 'Adv'
.head 11 -  Set sStockType = 'A'
.head 10 +  Else
.head 11 -  Set sStockType = 'C'
.head 10 -  !
.head 10 +  If haSqlHandles[ nStockTypeHandleNo ].Execute( )
.head 11 +  While haSqlHandles[ nStockTypeHandleNo ].FetchNext( nInd )
.head 12 +  If nInvTreePrice = NUMBER_Null
.head 13 -  Set nInvTreePrice = 0
.head 12 +  If nRoyOwnAmt = NUMBER_Null
.head 13 -  Set nRoyOwnAmt = 0
.head 12 +  If nFMNAmt = NUMBER_Null
.head 13 -  Set nFMNAmt = 0
.head 12 +  If nFNAAmt = NUMBER_Null
.head 13 -  Set nFNAAmt = 0
.head 12 +  If nCreditedAmt = NUMBER_Null
.head 13 -  Set nCreditedAmt = 0
.head 12 +  If nNoTreesCredited = NUMBER_Null
.head 13 -  Set nNoTreesCredited = 0
.head 12 -  Set nCreditAmt = nNoTreesCredited * (nCreditedAmt * nGST)
.head 12 +  If sCustType = 'HAB'
.head 13 +  If nContractPrice > nInvTreePrice
.head 14 -  Set nTreePrice = ((nContractPrice - nInvTreePrice) + nRoyOwnAmt + nFMNAmt + nFNAAmt ) * nGST
.head 13 +  Else
.head 14 -  Set nTreePrice = ((nContractPrice) + nRoyOwnAmt + nFMNAmt + nFNAAmt ) * nGST
.head 12 +  Else
.head 13 +  If nContractPrice != NUMBER_Null
.head 14 -  Set nTreePrice = (nContractPrice + nRoyOwnAmt + nFMNAmt + nFNAAmt ) * nGST
.head 13 +  Else
.head 14 -  Set nTreePrice = (nInvTreePrice + nRoyOwnAmt + nFMNAmt + nFNAAmt ) * nGST
.head 12 +  If nInvNo != nPrevInvNo and nPrevInvNo != 0
.head 13 -  Call GetInvCreditAmt(SalNumberToStrX( nInvNo, 0), nInvCredAmt, SH_cls_Execute )
.head 13 -  Set nInvCredAmt = nInvCredAmt - nCreditAmt
.head 13 -  Set nPrevInvNo = nInvNo
.head 12 +  Else
.head 13 -  Set nInvCredAmt = 0
.head 13 -  Set nPrevInvNo = nInvNo
.head 12 -  Set nInvoiced = nInvoiced + ((nConfAmt * nTreePrice) - nCreditAmt) - nInvCredAmt
.head 11 -  Return TRUE
.head 10 +  Else
.head 11 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Set bOk = TRUE
.head 9 -  Call GetInvCreditAmt('', nTmp, SH_cls_Disconnect )
.head 9 +  If NOT haSqlHandles[ nAllHandleNo ].Disconnect( )
.head 10 -  Set bOk = FALSE
.head 9 +  If NOT haSqlHandles[ nStockTypeHandleNo ].Disconnect( )
.head 10 -  Set bOk = FALSE
.head 9 -  Return bOk
.head 4 +  Window Variables
.head 5 -  ! Number: nYear
.head 5 -  Number: nTmp
.head 5 -  String: sTmp
.head 4 +  Message Actions
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set bAddAllowed = TRUE
.head 6 -  Set bAddRowBellow = TRUE
.head 6 -  !
.head 6 -  Set bReportAllowed = TRUE
.head 6 -  Set sPrinter = 'LaserPrinter'
.head 6 -  Set sReportFileName = 'InvFig.qrp'
.head 6 -  Set sRepBind = ':frmInvFigures.tblInvFigures.colMonth,
:frmInvFigures.tblInvFigures.colFromDate,
:frmInvFigures.tblInvFigures.colToDate,
:frmInvFigures.tblInvFigures.colInvTotalActual,
:frmInvFigures.tblInvFigures.colStockType,
:frmInvFigures.tblInvFigures.colInvTotalCatagory,
:frmInvFigures.tblInvFigures.colInvTotalEstimated'
.head 6 -  Set sRepInto = 'sMonth,
dtFromDate,
dtToDate,
nInvTotalActual,
sStockType,
nInvTotalCatagory, 
nInvTotalEstimated'
.head 5 +  On SAM_CreateComplete
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 6 -  Set colMonth = 'Jan'
.head 6 -  Call MonthFromAndToDates( 1, colFromDate, colToDate )
.head 6 -  !
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 6 -  Set colMonth = 'Feb'
.head 6 -  Call MonthFromAndToDates( 2, colFromDate, colToDate )
.head 6 -  !
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 6 -  Set colMonth = 'Mar'
.head 6 -  Call MonthFromAndToDates( 3, colFromDate, colToDate )
.head 6 -  !
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 6 -  Set colMonth = 'Apr'
.head 6 -  Call MonthFromAndToDates( 4, colFromDate, colToDate )
.head 6 -  !
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 6 -  Set colMonth = 'May'
.head 6 -  Call MonthFromAndToDates( 5, colFromDate, colToDate )
.head 6 -  !
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 6 -  Set colMonth = 'Jun'
.head 6 -  Call MonthFromAndToDates( 6, colFromDate, colToDate )
.head 6 -  !
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 6 -  Set colMonth = 'Jul'
.head 6 -  Call MonthFromAndToDates( 7, colFromDate, colToDate )
.head 6 -  !
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 6 -  Set colMonth = 'Aug'
.head 6 -  Call MonthFromAndToDates( 8, colFromDate, colToDate )
.head 6 -  !
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 6 -  Set colMonth = 'Sep'
.head 6 -  Call MonthFromAndToDates( 9, colFromDate, colToDate )
.head 6 -  !
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 6 -  Set colMonth = 'Oct'
.head 6 -  Call MonthFromAndToDates( 10, colFromDate, colToDate )
.head 6 -  !
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 6 -  Set colMonth = 'Nov'
.head 6 -  Call MonthFromAndToDates( 11, colFromDate, colToDate )
.head 6 -  !
.head 6 -  Call SalSendMsg( hWndForm, PAM_clsTBL_ADDROW, 0, 0 )
.head 6 -  Set colMonth = 'Dec'
.head 6 -  Call MonthFromAndToDates( 12, colFromDate, colToDate )
.head 6 -  !
.head 6 -  Return TRUE
.head 5 +  On PAM_clsTBL_ADDROW
.head 6 -  Call SalSendClassMessage( PAM_clsTBL_ADDROW, wParam, lParam )
.head 6 -  Call SalTblSetRowFlags( hWndForm, SalTblQueryContext( hWndForm ), ROW_HideMarks, TRUE )
.head 6 -  Return TRUE
.head 5 +  On PAM_clsTBL_ROWNEWINIT
.head 6 -  Set colStockType = 'Total'
.head 6 -  Set colFetchedActual = 'N'
.head 6 -  Set colFetchedEstimate = 'N'
.head 6 -  Set colFetchedCatagory = 'N'
.head 6 -  Return TRUE
.head 5 +  On PAM_clsTBL_ROWACTION
.head 6 +  If wParam = 1
.head 7 +  If colCalcActual = 'Y'
.head 8 +  If colFetchedActual = 'N'
.head 9 +  If CalcActualInvoiced( colFromDate, colToDate, colInvTotalActual, SH_cls_Execute )
.head 10 -  Set colFetchedActual = 'Y'
.head 9 +  Else
.head 10 -  Call SalClearField( colInvTotalActual )
.head 8 -  Set dfActualTotal = dfActualTotal + colInvTotalActual
.head 7 +  ! Else
.head 8 -  Set dfActualTotal = dfActualTotal - colInvTotalActual
.head 8 -  Call SalClearField( colInvTotalActual )
.head 6 +  Else If wParam = 2
.head 7 +  If colCalcEstimate = 'Y'
.head 8 +  If colFetchedEstimate = 'N'
.head 9 +  If CalcEstimateInvoiced( colFromDate, colToDate, colStockType, colInvTotalEstimated, nYear, SH_cls_Execute )
.head 10 -  Set colFetchedEstimate = 'Y'
.head 9 +  Else
.head 10 -  Call SalClearField( colInvTotalEstimated )
.head 8 -  Set dfEstimatedTotal = dfEstimatedTotal + colInvTotalEstimated
.head 7 +  ! Else
.head 8 -  Set dfEstimatedTotal = dfEstimatedTotal - colInvTotalEstimated
.head 8 -  Call SalClearField( colInvTotalEstimated )
.head 6 +  Else If wParam = 3
.head 7 +  If colCalcCatagory = 'Y'
.head 8 +  If colFetchedCatagory = 'N'
.head 9 +  If CalcCatagoryInvoiced( colFromDate, colToDate, colStockType, colInvTotalCatagory, SH_cls_Execute )
.head 10 -  Set colFetchedCatagory = 'Y'
.head 9 +  Else
.head 10 -  Call SalClearField( colInvTotalCatagory )
.head 8 -  Set dfCatagoryTotal = dfCatagoryTotal + colInvTotalCatagory
.head 7 +  ! Else
.head 8 -  ! If colFetchedCatagory = 'Y'
.head 8 -  Set dfCatagoryTotal = dfCatagoryTotal - colInvTotalCatagory
.head 8 -  Call SalClearField( colInvTotalActual )
.head 6 +  Else If wParam = 4
.head 7 -  Set colFetchedActual = 'N'
.head 7 -  Set dfActualTotal = dfActualTotal - colInvTotalActual
.head 7 -  Call SalClearField( colInvTotalActual )
.head 7 -  ! If colFetchedActual = 'N'
.head 7 +  ! Else
.head 8 -  Call SalClearField( colInvTotalCatagory )
.head 6 +  Else If wParam = 5
.head 7 -  Set colFetchedEstimate = 'N'
.head 7 -  Set dfEstimatedTotal = dfEstimatedTotal - colInvTotalEstimated
.head 7 -  Call SalClearField( colInvTotalEstimated )
.head 7 -  ! If colCalcEstimate = 'N'
.head 7 +  ! Else
.head 8 -  Call SalClearField( colInvTotalEstimated )
.head 6 +  Else If wParam = 6
.head 7 -  Set colFetchedCatagory = 'N'
.head 7 -  Set dfCatagoryTotal = dfCatagoryTotal - colInvTotalCatagory
.head 7 -  Call SalClearField( colInvTotalCatagory )
.head 7 -  ! If colFetchedCatagory = 'N'
.head 7 +  ! Else
.head 8 -  Call SalClearField( colInvTotalCatagory )
.head 6 +  Else
.head 7 -  Return FALSE
.head 6 -  Return TRUE
.head 5 +  On SAM_Destroy
.head 6 -  Call CalcActualInvoiced( colFromDate, colToDate, colInvTotalActual, SH_cls_Disconnect )
.head 6 -  Call CalcEstimateInvoiced( colFromDate, colToDate, colStockType, colInvTotalEstimated, 0, SH_cls_Disconnect )
.head 6 -  Call CalcCatagoryInvoiced( colFromDate, colToDate, colStockType, colInvTotalCatagory, SH_cls_Disconnect )
.head 6 -  Call CalcItemPriceForQueries( 0, 0, nTmp, nTmp, nTmp, SH_cls_Disconnect )
.head 6 -  Call GetTreeTypeStockType( '', sTmp, SH_cls_Disconnect )
.head 6 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )
.head 2 -  Functions
.head 2 -  Window Parameters
.head 2 +  Window Variables
.head 3 -  ! hcSqlHandle: fcCurrentHdl
.head 3 -  ! hcSqlHandle: fcHistoryHdl
.head 3 -  ! String: sSql
.head 3 -  ! Number: nInd
.head 3 -  !
.head 3 -  Number: nYear
.head 2 +  Message Actions
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set nYear = ccSeasonYear.GetSeasonYear()

.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetNextPickListNo' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT
  MAX( List_No ) + 1
FROM
  Day_Pts_Pck_Lst "
.head 7 -  Set sName = 'GTMXDPPLN'
.head 7 -  Set sBind = ''
.head 7 -  Set sInto = ':nGotListNo'
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set nListNo = NUMBER_Null
.head 7 -  Set nGotListNo = NUMBER_Null
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 +  If nGotListNo > 1
.head 10 -  Set nListNo = nGotListNo
.head 9 +  Else
.head 10 -  Set nListNo = 1
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 3 +  Function: InsPickListRow
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Number: nListNo
.head 5 -  Number: nRowNo
.head 5 -  Date/Time: dtFromDate
.head 5 -  Date/Time: dtToDate
.head 5 -  Number: nItemNo
.head 5 -  Number: nLocationId
.head 5 -  Number: nYear
.head 5 -  Number: nQuantity
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'InsPickListRow' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " INSERT INTO Day_Pts_Pck_Lst 
( 
  List_No, 
  Row_No, 
  From_Date, 
  To_Date, 
  Stock_Item_No, 
  Location_Id, 
  Year_Of_Sale, 
  Quantity 
) VALUES ( :1, :2, :3, :4, :5, :6, :7, :8 ) "
.head 7 -  Set sName = 'INSDPPLROW'
.head 7 -  Set sBind = ':nListNo,
:nRowNo,
:dtFromDate,
:dtToDate,
:nItemNo,
:nLocationId,
:nYear,
:nQuantity'
.head 7 -  Set sInto = ''
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Execute( )
.head 6 +  Case SH_cls_Commit
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Commit( )
.head 6 +  Case SH_cls_Rollback
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Rollback( )
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 2 +  Window Parameters
.head 3 -  Date/Time: dtFromDate
.head 3 -  Date/Time: dtToDate
.head 3 -  String: sReportTypeParam
.head 2 +  Window Variables
.head 3 -  Number: nListLineNo
.head 3 -  Boolean: bOk
.head 3 -  !
.head 3 -  Number: nItemNo
.head 3 -  Number: nLocationId
.head 3 -  Number: nYear
.head 3 -  ! REPORT COLUMNS
.head 3 -  Number: nListNo
.head 3 -  String: sVarietyType
.head 3 -  String: sUpperVariety
.head 3 -  String: sUpperCultDesc
.head 3 -  String: sUpperRootDesc
.head 3 -  String: sTreeTypeDesc
.head 3 -  String: sCultDesc
.head 3 -  String: sRootDesc
.head 3 -  String: sFarmName
.head 3 -  Number: nRowNo
.head 3 -  Number: nSeqNo
.head 3 -  Number: nCount
.head 3 -  Number: nForwardOrders
.head 2 +  Message Actions
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Call SetPrinter( 'LaserPrinter' )
.head 4 +  If sReportTypeParam = 'VIEW'
.head 5 -  Set nReportPrintFlags = nReportPrintFlags | RPT_NoPrint
.head 4 -  Set sReportFileNameNoPath = 'dordpck5.qrp'
.head 4 -  Set sReportBind = ':frmDailyChangesStockTakeList.nListNo, 
  :frmDailyChangesStockTakeList.dtFromDate, 
  :frmDailyChangesStockTakeList.dtToDate, 
  :frmDailyChangesStockTakeList.sVarietyType, 
  :frmDailyChangesStockTakeList.sUpperVariety, 
  :frmDailyChangesStockTakeList.sUpperCultDesc, 
  :frmDailyChangesStockTakeList.sUpperRootDesc, 
  :frmDailyChangesStockTakeList.sTreeTypeDesc, 
  :frmDailyChangesStockTakeList.sCultDesc, 
  :frmDailyChangesStockTakeList.sRootDesc, 
  :frmDailyChangesStockTakeList.sFarmName, 
  :frmDailyChangesStockTakeList.nRowNo, 
  :frmDailyChangesStockTakeList.nSeqNo, 
  :frmDailyChangesStockTakeList.nCount, 
  :frmDailyChangesStockTakeList.nForwardOrders'
.head 4 -  Set sReportInto = 'nListNo, 
  dtFromDate, 
  dtToDate, 
  sVarietyType, 
  sUpperVariety, 
  sUpperCultDesc, 
  sUpperRootDesc, 
  sTreeTypeDesc, 
  sCultDesc, 
  sRootDesc, 
  sFarmName, 
  nRowNo, 
  nSeqNo, 
  nCount, 
  nForwardOrders'
.head 4 -  Set sReportType = sReportTypeParam
.head 4 -  !
.head 4 -  Set sReportSql = "SELECT DISTINCT 
  Stock_Item.Variety_Type, 
  @UPPER( Stock_Item.Variety ), 
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Location.Farm_Name, 
  Location.Row#, 
  Location.Seq#, 
  Day_Item_Affected.Location_Id, 
  Day_Item_Affected.Year_Of_Sale, 
  Day_Item_Affected.Stock_Item_No, 
  Growing_Sale.Second_Count, 
  Growing_Sale.Forward_Orders
FROM 
  Day_Item_Affected, 
  Stock_Item, 
  Growing_Sale, 
  Location 
INTO 
  :frmDailyChangesStockTakeList.sVarietyType, 
  :frmDailyChangesStockTakeList.sUpperVariety, 
  :frmDailyChangesStockTakeList.sUpperCultDesc, 
  :frmDailyChangesStockTakeList.sUpperRootDesc, 
  :frmDailyChangesStockTakeList.sTreeTypeDesc, 
  :frmDailyChangesStockTakeList.sCultDesc, 
  :frmDailyChangesStockTakeList.sRootDesc, 
  :frmDailyChangesStockTakeList.sFarmName, 
  :frmDailyChangesStockTakeList.nRowNo, 
  :frmDailyChangesStockTakeList.nSeqNo, 
  :frmDailyChangesStockTakeList.nLocationId, 
  :frmDailyChangesStockTakeList.nYear, 
  :frmDailyChangesStockTakeList.nItemNo, 
  :frmDailyChangesStockTakeList.nCount, 
  :frmDailyChangesStockTakeList.nForwardOrders
WHERE 
  Day_Item_Affected.Day_SysDT BETWEEN :frmDailyChangesStockTakeList.dtFromDate AND :frmDailyChangesStockTakeList.dtToDate AND 
  Day_Item_Affected.List_No IS NULL AND 
  Day_Item_Affected.Stock_Item_No = Stock_Item.Item_No AND 
  Day_Item_Affected.Stock_Item_No = Growing_Sale.Stock_Item_No AND 
  Day_Item_Affected.Year_Of_Sale = Growing_Sale.Year_Of_Sale AND 
  Growing_Sale.Location_Id = Day_Item_Affected.Location_Id AND 
  Growing_Sale.Location_Id = Location.Location_Id AND 
  Stock_Item.Stock_Type = 'C' 
ORDER BY 
  8,9,10,12,1,2,3,4,5,11 "

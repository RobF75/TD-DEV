.head 2 +  Message Actions
.head 3 +  On PAM_clsPB_OKACTION
.head 4 -  Set bOk = TRUE
.head 4 +  If NOT ccFromDate.GetFocusDate( dtFromDate )
.head 5 -  Set bOk = FALSE
.head 4 +  If NOT ccToDate.GetFocusDate( dtToDate )
.head 5 -  Set bOk = FALSE
.head 4 -  !
.head 4 -  Set dtFromDate = SalDateConstruct( SalDateYear( dtFromDate ), SalDateMonth( dtFromDate ), SalDateDay( dtFromDate ), 0, 0, 0 )
.head 4 -  Set dtToDate = SalDateConstruct( SalDateYear( dtToDate ), SalDateMonth( dtToDate ), SalDateDay( dtToDate ), 23, 59, 59 )
.head 4 -  !
.head 4 +  If rbView
.head 5 -  Set sReportType = 'VIEW'
.head 4 +  Else
.head 5 -  Set sReportType = 'PRINT'
.head 4 +  If bOk
.head 5 -  Call SalCreateWindow( frmDailyChangesStockTakeList, hWndForm, dtFromDate, dtToDate, sReportType )
.head 4 +  Else
.head 5 -  Call SalMessageBox( 'A error has occured extracting the dates from the calanders.  Contact the developers.', 'Warning', MB_Ok )
.head 3 +  On PAM_clsFRM_REPORTCLOSED
.head 4 -  Return SalSendMsg( pbExit, SAM_Click, TRUE, 0 )

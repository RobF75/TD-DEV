.head 5 +      Select Case nActionType
.head 6 +      Case SH_cls_Execute
.head 7 -      Set sSql = " UPDATE Customer_Order 
SET 
  PickList_No = :3 
WHERE 
  Customer_Order.Stock_Item_No = :4 AND 
  Customer_Order.Batch_Location_Id = :5 AND 
  Customer_Order.Batch_Year_Of_Sale = :6 AND 
  ( Customer_Order.Invoiced_Flag = 'N' OR 
    Customer_Order.Invoiced_Flag IS NULL ) AND 
  Customer_Order.PickList_No IS NULL AND 
  Customer_Order.Conf_Amt > 0 AND 
  Customer_Order.Order_Date_Time BETWEEN :1 AND :2 "
.head 7 -      Set sName = 'UPDTDPPLRORD'
.head 7 -      Set sBind = ':dtFromDate, :dtToDate, :nListNo, :nItemNo, :nLocationId, :nYear'

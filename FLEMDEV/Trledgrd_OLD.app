  Trans_History.Hist_Trans_Type = 'INVOICE' AND 
  Trans_History.Hist_Trans_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate and
Trans_History.Hist_Company = :sCompany
ORDER BY 1 "

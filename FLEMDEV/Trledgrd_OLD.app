  :frmTransLedger.nTransAmount
FROM 
  Transaction 
WHERE 
  Transaction.Cust_No = :frmTransLedger.nCustNo AND 
  Transaction.Transaction_Type = 'INVOICE' AND 
  Transaction.Transaction_Date BETWEEN :frmTransLedger.dtFromDate AND :frmTransLedger.dtToDate and
Transaction.Company = :sCompany
UNION ALL 
SELECT 
  Trans_History.Hist_Trans_Date, 
  Trans_History.Hist_Reference_Id, 
  Trans_History.Hist_Trans_Amount
FROM 

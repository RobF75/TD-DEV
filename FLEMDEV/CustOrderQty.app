.head 4 +  Message Actions 
.head 5 +  On SAM_DropDown
.head 6 +  If sVariety = STRING_Null
.head 7 -  Call SalMessageBox( 'Please select a Variety first!', 'Invalid Selection', MB_Ok )
.head 6 -  Set sSqlSelection = '
	SELECT
		Cult_Desc
	FROM
		Cultivar
	WHERE
		@UPPER(Variety) = @UPPER(:sVariety)
	ORDER BY
		Cult_Desc '					! Query to get population data

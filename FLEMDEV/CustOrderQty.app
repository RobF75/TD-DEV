.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sQueryDialogName = ''
.head 6 -  !
.head 6 -  Set nCurrentYear =  WhichSeasonYear( SalDateCurrent(  ) )
.head 6 -  Call SalTblSetColumnTitle ( colYearNow, SalNumberToStrX( nCurrentYear, 0 ) )
.head 6 -  Call SalTblSetColumnTitle ( colYearMinus1, SalNumberToStrX( nCurrentYear -1, 0 ) )
.head 6 -  Call SalTblSetColumnTitle ( colYearMinus2, SalNumberToStrX( nCurrentYear -2, 0 ) )
.head 6 -  Call SalTblSetColumnTitle ( colYearMinus3, SalNumberToStrX( nCurrentYear -3, 0 ) )
.head 6 -  !
.head 6 +  If TRUE
.head 7 -  !
.head 7 -  !
.head 7 -  Set sSQLPopHandle = "SELECT
	DISTINCT(CM.Cust_No),
	CM.Cust_Name,
	CM.Bus_Name,
	CM.Region_ID,
	CM.Mailing_List_Flag,
	CM.Dont_Sell_Flag,
	CM.Credit_Stop,
	CM.Bad_Debt_Flag,
	CM.With_Debt_Collect
FROM
	Customer_Master CM
WHERE
	CM.Customer_Type LIKE :1
ORDER BY 2,1
"
.head 7 -  Set sNAMEPopHandle = '0206PopCustDetails'
.head 7 -  Set sBINDPopHandle = '
	:frmCustOrderQuantity.sCustType'
.head 7 -  Set sINTOPopHandle = '

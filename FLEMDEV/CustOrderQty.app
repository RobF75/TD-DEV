.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = "
SELECT
	Address_1,
	Suburb,
	State,
	Postcode
FROM
	Customer_Address
WHERE
	Cust_No = :1
AND	Main_Address_Flag = 'Y'
"					! Query to get population data

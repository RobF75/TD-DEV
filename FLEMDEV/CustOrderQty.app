.head 5 -  Number: nCurrentYear
.head 4 +  Message Actions
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sQueryDialogName = ''
.head 6 -  !
.head 6 -  Set nCurrentYear =  WhichSeasonYear( SalDateCurrent(  ) )
.head 6 -  !
.head 6 +  If TRUE 
.head 7 -  !
.head 7 -  Set sSQLPopHandle = "SELECT
	SI.Tree_Type_Desc,
	GS.Est_Sale_Date,
	SS.Tot_Avail,
	SUM(GS.Beg_Count),
	SUM(GS.First_Count),
	SUM(GS.Second_Count),
	SUM(GS.Forward_Orders)
FROM
	Stock_Item SI,
	Stock_Item_Sale SS,
	Growing_Sale GS
WHERE
	SI.Item_No = SS.Stock_Item_No
AND	SI.Item_No = GS.Stock_Item_No
AND	(GS.Not_For_Sale = 'N' OR GS.Not_For_Sale IS NULL)
AND	SI.Stock_Type LIKE :1
AND	SI.Variety_Type = :2
AND	SI.Variety = :3
AND	SI.Cult_Desc LIKE :4
AND	SS.Year_Of_Sale = :5
GROUP BY 1,2,3
ORDER BY 1,2,3"
.head 7 -  Set sNAMEPopHandle = '0504_STOCK_AVAIL'
.head 7 -  Set sBINDPopHandle = '
	:frmStockAvailableQty.sStockType,
	:frmStockAvailableQty.sVarietyType,
	:frmStockAvailableQty.sVariety,
	:frmStockAvailableQty.sCultivar,
	:frmStockAvailableQty.tblStockAvailQty.nCurrentYear'
.head 7 -  Set sINTOPopHandle = '
	:frmStockAvailableQty.tblStockAvailQty.colTreeTypeDesc,
	:frmStockAvailableQty.tblStockAvailQty.colEstSaleDate,
	:frmStockAvailableQty.tblStockAvailQty.colTotalAvail,
	:frmStockAvailableQty.tblStockAvailQty.colBudCount,
	:frmStockAvailableQty.tblStockAvailQty.colFirstCount,
	:frmStockAvailableQty.tblStockAvailQty.colSecondCount,
	:frmStockAvailableQty.tblStockAvailQty.colOnOrder'
.head 6 -  !
.head 6 -  Set bAddAllowed = FALSE
.head 6 -  Set bSaveAllowed = FALSE
.head 6 -  Set bDeleteAllowed = FALSE
.head 6 -  Set bUnDeleteAllowed = FALSE
.head 6 -  Set bRepopulateAllowed = FALSE
.head 6 -  Set bClearSelectAllowed = TRUE
.head 6 -  Set bQueryAllowed = FALSE
.head 6 -  Set bReportAllowed = TRUE
.head 6 -  Set bOrderAllowed = FALSE
.head 6 -  Set bSelectingColumnsAllowed = FALSE
.head 6 -  Set bSelectColsSUMTotalsAllowed = FALSE
.head 6 -  Set bMoveRowUpOneAllowed = FALSE
.head 6 -  Set bMakeCSVFileAllowed = FALSE
.head 6 -  Set bMoveRowDownOneAllowed = FALSE
.head 6 -  Set bZoomTableAllowed = FALSE
.head 6 -  Set bSelectFirstRow = FALSE
.head 6 -  !
.head 6 -  Set sPrinter = 'Laser'
.head 6 -  Set sReportFileName = 'StockAvailableQty1.qrp'
.head 6 -  Set sRepBind = '
	:frmStockAvailableQty.sVariety,
	:frmStockAvailableQty.sCultivar,
	:frmStockAvailableQty.sStockType,
	:frmStockAvailableQty.tblStockAvailQty.nCurrentYear,
	:frmStockAvailableQty.tblStockAvailQty.colTreeTypeDesc,
	:frmStockAvailableQty.tblStockAvailQty.colEstSaleDate,
	:frmStockAvailableQty.tblStockAvailQty.colTotalCount,
	:frmStockAvailableQty.tblStockAvailQty.colOnOrder,
	:frmStockAvailableQty.tblStockAvailQty.colAvailable,
	:frmStockAvailableQty.tblStockAvailQty.colTotalAvail'
.head 6 -  Set sRepInto = '
	Variety, 
	Cultivar,
	StockType,
	CurrentYear, 
	TreeTypeDesc,
	EstSalesDate,
	TotalCount,
	OnOrder,
	Available,
	TotalAvail'
.head 6 -  Set sTableHeading = 'Stock Available Quantities'
.head 6 -  !
.head 6 -  Set nTableFillType = TBL_FillAll
.head 6 -  !
.head 5 +  On SAM_FetchRowDone
.head 6 -  !
.head 6 +  If colSecondCount != NUMBER_Null
.head 7 -  Set colTotalCount = colSecondCount
.head 6 +  Else If colFirstCount != NUMBER_Null
.head 7 -  Set colTotalCount = colFirstCount
.head 6 +  Else
.head 7 -  Set colTotalCount = colBudCount
.head 6 -  !
.head 6 -  Set colAvailable = colTotalCount - colOnOrder
.head 6 -  !
.head 6 +  If colEstSaleDate > SalDateCurrent()
.head 7 -  Call SalTblSetCellTextColor( colEstSaleDate, COLOR_DarkRed, TRUE ) 
.head 6 -  !
.head 6 -  Return SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
.head 6 -  !

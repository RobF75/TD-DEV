.head 6 -  Set nCurrentYear =  WhichSeasonYear( SalDateCurrent(  ) )
.head 6 -  Call SalTblSetColumnTitle ( colYearNow, SalNumberToStrX( nCurrentYear, 0 ) )
.head 6 -  Call SalTblSetColumnTitle ( colYearMinus1, SalNumberToStrX( nCurrentYear -1, 0 ) )
.head 6 -  Call SalTblSetColumnTitle ( colYearMinus2, SalNumberToStrX( nCurrentYear -2, 0 ) )

.head 7 -  Set sSqlSelection = "
SELECT
	SUM(CO.Ordered_Amount)
FROM
	Customer_Order CO,
	Stock_Item SI
INTO	:frmCustOrderQuantity.tblOrderQuantity.colYearNow
WHERE
	CO.Cust_No = :nCustNo
AND	CO.Stock_Item_No = SI.Item_No 
AND	CO.Year_Of_Sale = :nCurrentYear
AND	SI.Stock_Type LIKE :sStockType
AND	SI.Variety_Type = :sVarietyType
AND	SI.Variety = :sVariety
AND	SI.Cult_Desc = :sCultivar
 "					! Query to get population data

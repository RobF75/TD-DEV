.head 7 -  Set sSQLPopHandle = "SELECT 
	DISTINCT(SI.Item_No),
	SI.Cult_Desc,
	SI.Type_Description
FROM
	Customer_Master CM,
	Customer_Order CO,
	Stock_Item SI
WHERE
	CM.Cust_No = CO.Cust_No 
AND	CO.Stock_Item_No = SI.Item_No
AND 	CM.Customer_Type = :1 
AND	CM.Cust_Name = :2 
AND	CO.Year_Of_Sale = :3
AND	SI.Stock_Type LIKE :4 
GROUP BY 1,2,3

UNION

SELECT 
	DISTINCT(SI.Item_No),
	SI.Cult_Desc,
	SI.Type_Description
FROM
	Customer_Master CM,
	Cust_Order_History CO,
	Stock_Item SI
WHERE
	CM.Cust_No = CO.Cust_No 
AND	CO.Stock_Item_No = SI.Item_No
AND 	CM.Customer_Type = :1 
AND	CM.Cust_Name = :2 
AND	CO.Year_Of_Sale = :3 - 1
AND	SI.Stock_Type LIKE :4 
GROUP BY 1,2,3

UNION

SELECT 
	DISTINCT(SI.Item_No),
	SI.Cult_Desc,
	SI.Type_Description
FROM
	Customer_Master CM,
	Cust_Order_History CO,
	Stock_Item SI
WHERE
	CM.Cust_No = CO.Cust_No 
AND	CO.Stock_Item_No = SI.Item_No
AND 	CM.Customer_Type = :1 
AND	CM.Cust_Name = :2 
AND	CO.Year_Of_Sale = :3 - 2
AND	SI.Stock_Type LIKE :4 
GROUP BY 1,2,3

UNION

SELECT 
	DISTINCT(SI.Item_No),
	SI.Cult_Desc,
	SI.Type_Description
FROM
	Customer_Master CM,
	Cust_Order_History CO,
	Stock_Item SI
WHERE
	CM.Cust_No = CO.Cust_No 
AND	CO.Stock_Item_No = SI.Item_No
AND 	CM.Customer_Type = :1 
AND	CM.Cust_Name = :2 
AND	CO.Year_Of_Sale = :3 - 3
AND	SI.Stock_Type LIKE :4 
GROUP BY 1,2,3
ORDER BY 2,3,1
"

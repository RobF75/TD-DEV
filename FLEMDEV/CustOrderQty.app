.head 6 +  Parameters
.head 7 -  Number: nCustNo					! Customer number
.head 7 -  Number: nYear					! Current Season
.head 7 -  String: sStockType					! Stock Type
.head 7 -  String: sVarietyType				! Variety Type
.head 7 -  String: sVariety					! Variety
.head 7 -  String: sCultivar					! Cultivar

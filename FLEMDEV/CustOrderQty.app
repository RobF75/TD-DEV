	:frmCustOrderQuantity.tblOrderQuantity.colCustomer,
	:frmCustOrderQuantity.tblOrderQuantity.colBusName,	
	:frmCustOrderQuantity.tblOrderQuantity.colRegion,
	:frmCustOrderQuantity.tblOrderQuantity.colMailFlag,
	:frmCustOrderQuantity.tblOrderQuantity.sDontSellFlag,
	:frmCustOrderQuantity.tblOrderQuantity.sCreditStopFlag,
	:frmCustOrderQuantity.tblOrderQuantity.sBadDebtFlag,
	:frmCustOrderQuantity.tblOrderQuantity.sWithDebtCollect'

.head 4 -  Set bQueryAllowed = TRUE
.head 4 -  Set bRepopulateAllowed = FALSE
.head 4 -  Set bClearSelectAllowed = TRUE
.head 4 -  Set bAddAllowed = FALSE
.head 4 -  Set bSaveAllowed = FALSE
.head 4 -  Set bDeleteAllowed = FALSE
.head 4 -  Set bUnDeleteAllowed = FALSE
.head 4 -  Set bReportAllowed = TRUE
.head 4 -  Set bOrderAllowed = FALSE
.head 4 -  Set nPopOrQueryOnStartUp = TBL_cls_NothingOnStartUp
.head 4 -  !
.head 4 -  Set hWndChildTable = tblStockAvailQty
.head 4 -  !
.head 3 +  On SAM_CreateComplete
.head 4 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )

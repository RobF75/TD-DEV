.head 7 -  !
.head 7 -  ! 10/07/02 (PXD) removed union SQL build, as all customers for the specified type 
are now wanted, rather than just the ones that have actually made orders in the time
frame period. 
.head 7 -  !
.head 7 -  ! Set sSQLPopHandle = "SELECT 
	DISTINCT(CM.Cust_No),
	CM.Cust_Name
FROM
	Customer_Master CM,
	Customer_Order CO,
	Stock_Item SI
WHERE
	CM.Cust_No = CO.Cust_No 
AND	CO.Stock_Item_No = SI.Item_No 
AND 	CM.Customer_Type = :1 
AND	CO.Year_Of_Sale = :2
AND	SI.Stock_Type = :3 
AND	SI.Variety_Type = :4
AND	SI.Variety = :5
AND	SI.Cult_Desc = :6
GROUP BY 1,2

UNION

SELECT 
	DISTINCT(CM.Cust_No),
	CM.Cust_Name
FROM
	Customer_Master CM,
	Cust_Order_History CO,
	Stock_Item SI
WHERE
	CM.Cust_No = CO.Cust_No 
AND	CO.Stock_Item_No = SI.Item_No 
AND 	CM.Customer_Type = :1 
AND	CO.Year_Of_Sale = :2 - 1
AND	SI.Stock_Type = :3 
AND	SI.Variety_Type = :4
AND	SI.Variety = :5
AND	SI.Cult_Desc = :6
GROUP BY 1,2

UNION

SELECT 
	DISTINCT(CM.Cust_No),
	CM.Cust_Name
FROM
	Customer_Master CM,
	Cust_Order_History CO,
	Stock_Item SI
WHERE
	CM.Cust_No = CO.Cust_No 
AND	CO.Stock_Item_No = SI.Item_No 
AND 	CM.Customer_Type = :1 
AND	CO.Year_Of_Sale = :2 - 2
AND	SI.Stock_Type = :3
AND	SI.Variety_Type = :4
AND	SI.Variety = :5
AND	SI.Cult_Desc = :6
GROUP BY 1,2

UNION

SELECT 
	DISTINCT(CM.Cust_No),
	CM.Cust_Name
FROM
	Customer_Master CM,
	Cust_Order_History CO,
	Stock_Item SI
WHERE
	CM.Cust_No = CO.Cust_No 
AND	CO.Stock_Item_No = SI.Item_No 
AND 	CM.Customer_Type = :1 
AND	CO.Year_Of_Sale = :2 - 3
AND	SI.Stock_Type = :3
AND	SI.Variety_Type = :4
AND	SI.Variety = :5
AND	SI.Cult_Desc = :6
GROUP BY 1,2
ORDER BY 2,1
"
.head 7 -  Set sSQLPopHandle = "SELECT 
	DISTINCT(CM.Cust_No),
	CM.Cust_Name
FROM
	Customer_Master CM
WHERE
	CM.Customer_Type = :1 
ORDER BY 2,1
"

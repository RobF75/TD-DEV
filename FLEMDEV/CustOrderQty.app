.head 5 +  On SAM_FetchRowDone
.head 6 -  !
.head 6 -  Call UpdateCurrentYearFigures(colCustNo, nCurrentYear, sStockType, sVarietyType, sVariety, sCultivar, colYearNow, SH_cls_Execute )
.head 6 -  Call SalColorSet( colYearNow, COLOR_IndexCellText, COLOR_Red )
.head 6 -  Call UpdatePriorYearFigures(colCustNo, nCurrentYear - 1, sStockType, sVarietyType, sVariety, sCultivar, colYearMinus1, SH_cls_Execute )
.head 6 -  Call SalColorSet( colYearMinus1, COLOR_IndexCellText, COLOR_Red )
.head 6 -  Call UpdatePriorYearFigures(colCustNo, nCurrentYear - 2, sStockType, sVarietyType, sVariety, sCultivar, colYearMinus2, SH_cls_Execute )
.head 6 -  Call SalColorSet( colYearMinus2, COLOR_IndexCellText, COLOR_Red )
.head 6 -  Call UpdatePriorYearFigures(colCustNo, nCurrentYear - 3, sStockType, sVarietyType, sVariety, sCultivar, colYearMinus3, SH_cls_Execute )
.head 6 -  Call SalColorSet( colYearMinus3, COLOR_IndexCellText, COLOR_Red )
.head 6 -  !
.head 6 -  Set dfTotalYearNow = dfTotalYearNow + colYearNow
.head 6 -  Set dfTotalYearMinus1 = dfTotalYearMinus1 + colYearMinus1
.head 6 -  Set dfTotalYearMinus2 = dfTotalYearMinus2 + colYearMinus2
.head 6 -  Set dfTotalYearMinus3 = dfTotalYearMinus3 + colYearMinus3
.head 6 -  !
.head 6 -  Set dfTotalCustCount = dfTotalCustCount + 1
.head 6 +  If colYearNow ! = NUMBER_Null
.head 7 -  Set dfYearNowCustCount = dfYearNowCustCount + 1
.head 6 +  If colYearMinus1 ! = NUMBER_Null
.head 7 -  Set dfYearMinus1CustCount = dfYearMinus1CustCount + 1
.head 6 +  If colYearMinus2 ! = NUMBER_Null
.head 7 -  Set dfYearMinus2CustCount = dfYearMinus2CustCount + 1
.head 6 +  If colYearMinus3 ! = NUMBER_Null
.head 7 -  Set dfYearMinus3CustCount = dfYearMinus3CustCount + 1
.head 6 -  !

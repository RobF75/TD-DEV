.head 6 +  If TRUE 
.head 7 -  !
.head 7 -  !
.head 7 -  Set sSQLPopHandle = "SELECT 
	DISTINCT(CM.Cust_No),
	CM.Cust_Name,
	CM.Region_ID,
	CM.Mailing_List_Flag
FROM
	Customer_Master CM
WHERE
	CM.Customer_Type = :1 
ORDER BY 2,1
"
.head 7 -  Set sNAMEPopHandle = '2207PopCustDetails'

.head 6 +  Actions
.head 7 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( '0206MainContact' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = "
SELECT
	Contact_Given_Name ||' '|| Contact_Surname,
	Wrk_Phone_Code ||' '|| Contact_Work_Phone
FROM
	Customer_Contacts
WHERE
	Cust_No = :1
AND	Main_Contact_Flag = 'Y'
"					! Query to get population data
.head 9 -  Set sName = '0206ContactDetails'
.head 9 -  Set sBind = ':nCustNo'
.head 9 -  Set sInto = ':sContact, :sPhone'

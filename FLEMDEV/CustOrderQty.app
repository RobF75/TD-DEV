.head 4 -  List Initialization 
.head 4 +  Message Actions 
.head 5 +  On SAM_DropDown
.head 6 -  Call SalListClear( cmbCultivar )
.head 6 +  If sVarietyType = STRING_Null
.head 7 -  Call SalMessageBox( 'Please select a Variety Type first!', 'Invalid Selection', MB_Ok )
.head 6 -  Set sSqlSelection = '
	SELECT
		Variety
	FROM
		Variety
	WHERE
		@UPPER(Type) = @UPPER(:sVarietyType)
	ORDER BY
		Variety '					! Query to get population data
.head 6 -  Call SqlConnect( hSqlSelection )					! Connect to Database
.head 6 -  Call SalListPopulate ( hWndItem, hSqlSelection, sSqlSelection )		! Return the results to the combo box
.head 6 -  Call SqlDisconnect ( hSqlSelection)					! Disconnect from Database
.head 6 -  Set sSqlSelection = ''
.head 5 +  On SAM_KillFocus
.head 6 -  Set nComboItem = SalListQuerySelection ( hWndItem )			! Get the index of the selected combo box item
.head 6 -  Set sVariety = SalListQueryTextX( hWndItem, nComboItem )		! Get the combo box item value
.head 5 +  On SAM_AnyEdit
.head 6 -  Set sVariety = cmbVariety || '%'
.head 6 -  Set sSqlSelection = '
	SELECT
		Variety
	FROM
		Variety
	WHERE
		@UPPER(Variety) LIKE @UPPER(:sVariety)
	ORDER BY
		Variety '					! Query to get population data
.head 6 -  Call SqlConnect( hSqlSelection )					! Connect to Database
.head 6 -  Call SalListPopulate ( hWndItem, hSqlSelection, sSqlSelection )		! Return the results to the combo box
.head 6 -  Call SqlDisconnect ( hSqlSelection)					! Disconnect from Database
.head 6 -  Set sSqlSelection = ''
.head 6 -  ! Call SalSendMsg( lbVariety, PAM_clsLB_POPULATE, 0, 0 )

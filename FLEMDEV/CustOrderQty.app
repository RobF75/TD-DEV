.head 4 +  Actions 
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GET_ITEM_NUMBER' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = "
SELECT
	Item_No
FROM
	Stock_Item
WHERE
	@UPPER(Variety_Type) = @UPPER(:1)
AND	@UPPER(Variety) = @UPPER(:2)
AND	Cust_Desc = :3
 "					
.head 7 -  Set sInto = ':nItemNo'
.head 7 -  Set sBind = ':sVarietyType, :sVariety, :sCultDesc'
.head 7 -  Set sName = 'GET_ITEM_NUMBER'
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set nItemNo = NUMBER_Null
.head 7 -  !
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 -  Return TRUE
.head 8 +  Else 
.head 9 -  Call SalMessageBox( 'Unable to resolve Stock Item Number', 'GetItemNumber', MB_IconStop|MB_Ok )
.head 9 -  Return FALSE
.head 7 +  Else 
.head 8 -  Return FALSE
.head 7 -  Return TRUE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )

.head 6 +  Actions
.head 7 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( '0209CurrentConf' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 -  Set sSql = '
SELECT
	SUM(CO.Conf_Amt)
FROM
	Customer_Order CO,
	Stock_Item SI
WHERE
	CO.Cust_No = :1
AND	CO.Stock_Item_No = SI.Item_No
AND	CO.Year_Of_Sale = :2
AND	SI.Stock_Type LIKE :3
AND	SI.Variety_Type LIKE :4
AND	SI.Variety LIKE :5
AND	SI.Cult_Desc LIKE :6
 '					! Query to get population data
.head 9 -  Set sName = '0209CurrentConf'
.head 9 -  Set sBind = ':nCustNo, :nYear, :sStockType, :sVarietyType, :sVariety, :sCultivar '
.head 9 -  Set sInto = ':nCount'
.head 9 -  !
.head 9 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 9 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 9 -  !
.head 9 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 10 -  Return haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 +  Else
.head 10 -  Return FALSE
.head 8 +  Case SH_cls_Disconnect
.head 9 -  Return haSqlHandles[ nSqlHandleNo ].Disconnect( )

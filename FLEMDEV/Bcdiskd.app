.head 4 +  Message Actions
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set pbFileSaveAs.sFilters[0] = 'CSV Files'
.head 6 -  Set pbFileSaveAs.sFilters[1] = '*.CSV'
.head 6 -  Set pbFileSaveAs.sFilters[2] = 'TXT Files'
.head 6 -  Set pbFileSaveAs.sFilters[3] = '*.txt'
.head 6 -  Set pbFileSaveAs.sFilters[4] = 'All Files'
.head 6 -  Set pbFileSaveAs.sFilters[5] = '*.*'
.head 6 -  Set pbFileSaveAs.nNumFilters = 6
.head 6 -  Set pbFileSaveAs.sHeading = 'Bar Code Stock Items File, Save'
.head 5 +  On PAM_clsPB_RETRIEVEFILENAME
.head 6 -  Set dfFileName = pbFileSaveAs.sFilePath
.head 6 -  Return TRUE
.head 2 +  Functions
.head 3 +  Function: GenerateBarCodeStockItemsCSVFile
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: sFileName
.head 5 -  ! sFileType = 'STORES', 'PRICE_LIST_POTS', 'PRICE_LIST_BARE_ROOT'
.head 5 -  String: sFileType
.head 5 -  Number: nActionType
.head 4 +  Static Variables
.head 5 -  ! hcSqlHandle: fcOurHandle
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  ! String: sBind
.head 5 -  ! String: sInto
.head 5 -  ! String: sName

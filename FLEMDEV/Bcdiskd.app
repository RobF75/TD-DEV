.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GenerateBarCodeStockItemsCSVFile' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Call fcCSVFile.Setup( sFileName, NUMBER_Null, NUMBER_Null )
.head 7 +  If fcCSVFile.Open( )
.head 8 +  If sFileType = 'STORE'
.head 9 -  Set sSql = "SELECT 
  Stock_Labels.Stock_Item_No, 
  Tree_Type.Type_Description, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Variety_Type, 
  @UPPER( Stock_Item.Variety ),
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  @UPPER( Stock_Item.Tree_Type_Desc )
FROM
  Stock_Labels,
  Stock_Item,
  Tree_Type 
INTO 
  :nGotItemNo, 
  :sGotTreeDesc, 
  :sGotCultDesc, 
  :sGotRootDesc, 
  :sGotVarietyType, 
  :sGotUpperVariety, 
  :sGotUpperCultDesc, 
  :sGotUpperRootDesc, 
  :sGotTreeTypeDesc 
WHERE
  Stock_Labels.Stock_Label_Use = 'BC' AND 
  Stock_Labels.Stock_Item_No = Stock_Item.Item_No AND 
  Stock_Item.Tree_Type = Tree_Type.Tree_Type 
ORDER BY 6,7,8,9,1 "
.head 8 +  Else If sFileType = 'BAREROOT'
.head 9 -  Set sSql = "SELECT 
  Stock_Labels.Stock_Item_No, 
  Tree_Type.Type_Description, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Variety_Type, 
  @UPPER( Stock_Item.Variety ),
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  @UPPER( Stock_Item.Tree_Type_Desc )
FROM
  Stock_Labels,
  Stock_Item,
  Tree_Type 
INTO 
  :nGotItemNo, 
  :sGotTreeDesc, 
  :sGotCultDesc, 
  :sGotRootDesc, 
  :sGotVarietyType, 
  :sGotUpperVariety, 
  :sGotUpperCultDesc, 
  :sGotUpperRootDesc, 
  :sGotTreeTypeDesc 
WHERE
  Stock_Labels.Stock_Label_Use = 'BC' AND 
  Stock_Labels.Stock_Item_No = Stock_Item.Item_No AND 
  Stock_Item.Tree_Type = Tree_Type.Tree_Type and
  Stock_Item.Stock_Type = 'B'
ORDER BY 6,7,8,9,1 "
.head 8 +  Else If sFileType = 'CONTAINER'
.head 9 -  Set sSql = "SELECT 
  Stock_Labels.Stock_Item_No, 
  Tree_Type.Type_Description, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Variety_Type, 
  @UPPER( Stock_Item.Variety ),
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  @UPPER( Stock_Item.Tree_Type_Desc )
FROM
  Stock_Labels,
  Stock_Item,
  Tree_Type 
INTO 
  :nGotItemNo, 
  :sGotTreeDesc, 
  :sGotCultDesc, 
  :sGotRootDesc, 
  :sGotVarietyType, 
  :sGotUpperVariety, 
  :sGotUpperCultDesc, 
  :sGotUpperRootDesc, 
  :sGotTreeTypeDesc 
WHERE
  Stock_Labels.Stock_Label_Use = 'BC' AND 
  Stock_Labels.Stock_Item_No = Stock_Item.Item_No AND 
  Stock_Item.Tree_Type = Tree_Type.Tree_Type and
  Stock_Item.Stock_Type = 'C'
ORDER BY 6,7,8,9,1 "
.head 8 +  Else If sFileType = 'PRICE_LIST_POTS'
.head 9 -  Set sSql = "SELECT 
  Stock_Labels.Stock_Item_No, 
  Tree_Type.Type_Description, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Variety_Type, 
  @UPPER( Stock_Item.Variety ),
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  @UPPER( Stock_Item.Tree_Type_Desc )
FROM
  Stock_Labels,
  Stock_Item,
  Tree_Type 
INTO 
  :nGotItemNo, 
  :sGotTreeDesc, 
  :sGotCultDesc, 
  :sGotRootDesc, 
  :sGotVarietyType, 
  :sGotUpperVariety, 
  :sGotUpperCultDesc, 
  :sGotUpperRootDesc, 
  :sGotTreeTypeDesc 
WHERE
  Stock_Labels.Stock_Label_Use = 'BC' AND 
  Stock_Labels.Stock_Item_No = Stock_Item.Item_No AND 
  Stock_Item.Tree_Type = Tree_Type.Tree_Type AND 
  Stock_Item.Stock_Type = 'C' 
ORDER BY 6,7,8,9,1 "
.head 9 -  Call fcPriceListNumOnlyCSVFile.Setup( sFileName||'.NoOnly', NUMBER_Null, NUMBER_Null )
.head 9 -  Call fcPriceListNumOnlyCSVFile.Open( )
.head 8 +  Else
.head 9 -  Set sSql = "SELECT 
  Stock_Labels.Stock_Item_No, 
  Tree_Type.Type_Description, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Variety_Type, 
  @UPPER( Stock_Item.Variety ),
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  @UPPER( Stock_Item.Tree_Type_Desc )
FROM
  Stock_Labels,
  Stock_Item,
  Tree_Type 
INTO 
  :nGotItemNo, 
  :sGotTreeDesc, 
  :sGotCultDesc, 
  :sGotRootDesc, 
  :sGotVarietyType, 
  :sGotUpperVariety, 
  :sGotUpperCultDesc, 
  :sGotUpperRootDesc, 
  :sGotTreeTypeDesc 
WHERE
  Stock_Labels.Stock_Label_Use = 'BC' AND 
  Stock_Labels.Stock_Item_No = Stock_Item.Item_No AND 
  Stock_Item.Tree_Type = Tree_Type.Tree_Type AND 
  Stock_Item.Stock_Type = 'B' 
ORDER BY 6,7,8,9,1 "
.head 9 -  Call fcPriceListNumOnlyCSVFile.Setup( sFileName||'.NoOnly', NUMBER_Null, NUMBER_Null )
.head 9 -  Call fcPriceListNumOnlyCSVFile.Open( )
.head 8 -  ! Set sName = 'BCSTKITMS'
.head 8 -  ! Set sBind = ''
.head 8 -  ! Set sInto = ':nGotItemNo, 
:sGotTreeDesc, 
:sGotCultDesc, 
:sGotRootDesc, 
:sGotVarietyType, 
:sGotUpperVariety, 
:sGotUpperCultDesc, 
:sGotUpperRootDesc, 
:sGotTreeTypeDesc'
.head 8 -  ! Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 8 -  Call haSqlHandles[ nOurHandleNo ].PrepareSetup( sSql )
.head 8 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 8 -  !
.head 8 +  If haSqlHandles[ nOurHandleNo ].PrepareAndExecute( )
.head 9 -  Call haSqlHandles[ nOurHandleNo ].ResultSetCount( nResultSet )
.head 9 -  Call fcMeterBar.Setup( 'Generating bar code stock item file', nResultSet )
.head 9 +  If sFileType = 'STORE' or sFileType = 'BAREROOT' or sFileType = 'CONTAINER'
.head 10 -  Set sTmp = '\"Product Number\", \"Description\"'
.head 10 -  Call fcCSVFile.Write( sTmp )
.head 9 +  While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 10 -  Set sTmp = SalNumberToStrX( nGotItemNo, 0 )
.head 10 -  Call StringStartPad( sTmp, '0', 5 )
.head 10 -  Set sBarCodeNum = '9317036'||sTmp
.head 10 -  Set sBarCodeCheckDigit = SalNumberToStrX( Mod10AlgorithmEAN13CheckDigit( sBarCodeNum ), 0 )
.head 10 -  ! Set sBarCodeNum = sBarCodeNum||SalNumberToStrX( Mod10AlgorithmEAN13CheckDigit( sBarCodeNum ), 0 )
.head 10 +  If sFileType = 'STORE' or sFileType = 'BAREROOT' or sFileType = 'CONTAINER'
.head 11 -  Set sBarCodeNum = sBarCodeNum || sBarCodeCheckDigit
.head 11 -  Set sTmp = FormatBarCodeNumToEAN13( sBarCodeNum )
.head 11 -  Set sTmp = '\"' || sTmp || '\", \"' || sGotTreeDesc || ' ' || sGotCultDesc || ' ' || sGotRootDesc || '\"'
.head 10 +  Else
.head 11 -  Set sTmp = sBarCodeNum || ' ~~ ' || sBarCodeCheckDigit || ' qq ' || sGotCultDesc || ' ' || sGotRootDesc || ' qq ' || sGotTreeDesc
.head 10 -  !
.head 10 -  Call fcCSVFile.Write( sTmp )
.head 10 +  If NOT sFileType = 'STORE' or sFileType = 'BAREROOT' or sFileType = 'CONTAINER'
.head 11 -  Call fcPriceListNumOnlyCSVFile.Write( sBarCodeNum )
.head 10 -  Call fcMeterBar.Increment( 1 )
.head 9 -  Call fcMeterBar.End( )
.head 8 -  !
.head 8 -  Call fcCSVFile.Close( )
.head 8 +  If NOT sFileType = 'STORE'
.head 9 -  Call fcPriceListNumOnlyCSVFile.Close( )
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 7 -  Return TRUE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 2 -  Window Parameters
.head 2 -  Window Variables
.head 2 +  Message Actions
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set bMapEnterToTab = TRUE
.head 3 +  On SAM_Destroy
.head 4 -  Call GenerateBarCodeStockItemsCSVFile( dfFileName, '', SH_cls_Disconnect )
.head 4 -  Return SalSendClassMessage( SAM_Destroy, wParam, lParam )

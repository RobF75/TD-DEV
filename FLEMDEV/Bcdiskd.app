.head 5 -  Number: nInd
.head 5 -  !
.head 5 -  Number: nGotItemNo
.head 5 -  String: sGotTreeDesc
.head 5 -  String: sGotCultDesc
.head 5 -  String: sGotRootDesc
.head 5 -  String: sGotVarietyType
.head 5 -  String: sGotUpperVariety
.head 5 -  String: sGotUpperCultDesc
.head 5 -  String: sGotUpperRootDesc

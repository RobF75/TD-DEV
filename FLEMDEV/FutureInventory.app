.head 8 -  Set nTableFillType = TBL_FillNormal
.head 8 -  Set bKeepSelectRowsOnRePop = TRUE
.head 8 -  ! Set sQueryDialogName = 'dlgQQCustMaster'
.head 8 -  Set nMonth = SalDateMonth( SalDateCurrent() )
.head 8 -  Set nYear = hWndForm.ccSeasonYear.GetSeasonYear()
.head 8 -  Set bMakeCSVFileAllowed = TRUE
.head 8 -  Call GetRegistryValue( 'ACCOUNTS', 'GSTPercent', sGST, '0.1' )
.head 8 -  Set nGST = SalStrToNumber( sGST )
.head 8 +  Select Case nMonth
.head 9 +  Case 1
.head 10 -  Call SalTblSetColumnTitle( colMonth1, 'January' )
.head 10 -  Call SalTblSetColumnTitle( colMonth2, 'February' )
.head 10 -  Call SalTblSetColumnTitle( colMonth3, 'March' )
.head 10 -  Call SalTblSetColumnTitle( colMonth4, 'April' )
.head 10 -  Call SalTblSetColumnTitle( colMonth5, 'May' )
.head 10 -  Call SalTblSetColumnTitle( colMonth6, 'June' )
.head 9 +  Case 2
.head 10 -  Call SalTblSetColumnTitle( colMonth1, 'February' )
.head 10 -  Call SalTblSetColumnTitle( colMonth2, 'March' )
.head 10 -  Call SalTblSetColumnTitle( colMonth3, 'April' )
.head 10 -  Call SalTblSetColumnTitle( colMonth4, 'May' )
.head 10 -  Call SalTblSetColumnTitle( colMonth5, 'June' )
.head 10 -  Call SalTblSetColumnTitle( colMonth6, 'July' )
.head 9 +  Case 3
.head 10 -  Call SalTblSetColumnTitle( colMonth1, 'March' )
.head 10 -  Call SalTblSetColumnTitle( colMonth2, 'April' )
.head 10 -  Call SalTblSetColumnTitle( colMonth3, 'May' )
.head 10 -  Call SalTblSetColumnTitle( colMonth4, 'June' )
.head 10 -  Call SalTblSetColumnTitle( colMonth5, 'July' )
.head 10 -  Call SalTblSetColumnTitle( colMonth6, 'August' )
.head 9 -  Default
.head 7 +  On PAM_clsTBL_POPFIELDS
.head 8 -  Call PopString( dfCustType, FALSE )
.head 8 -  Call PopString( dfBusName, FALSE )
.head 8 -  Call PopString( dfCustName, FALSE )
.head 8 -  Call PopNumber( dfCustNo, FALSE )
.head 8 -  Return TRUE
.head 7 +  On SAM_FetchRowDone
.head 8 -  Set dtAvalDate = SalDateConstruct( SalDateYear( SalDateCurrent() ), nMonth + 2, 1, 0, 0, 0 )
.head 8 -  Call CalcFutureAvailAtDate( colItemNo, nYear, colMonth1, nTmp, nTmp, dtAvalDate, SH_cls_Execute )
.head 8 -  Set dtAvalDate = SalDateConstruct( SalDateYear( SalDateCurrent() ), nMonth + 3, 1, 0, 0, 0 )
.head 8 -  Call CalcFutureAvailAtDate( colItemNo, nYear, colMonth2, nTmp, nTmp, dtAvalDate, SH_cls_Execute )
.head 8 -  Set dtAvalDate = SalDateConstruct( SalDateYear( SalDateCurrent() ), nMonth + 4, 1, 0, 0, 0 )
.head 8 -  Call CalcFutureAvailAtDate( colItemNo, nYear, colMonth3, nTmp, nTmp, dtAvalDate, SH_cls_Execute )
.head 8 -  Set dtAvalDate = SalDateConstruct( SalDateYear( SalDateCurrent() ), nMonth + 5, 1, 0, 0, 0 )
.head 8 -  Call CalcFutureAvailAtDate( colItemNo, nYear, colMonth4, nTmp, nTmp, dtAvalDate, SH_cls_Execute )
.head 8 -  Set dtAvalDate = SalDateConstruct( SalDateYear( SalDateCurrent() ), nMonth + 6, 1, 0, 0, 0 )
.head 8 -  Call CalcFutureAvailAtDate( colItemNo, nYear, colMonth5, nTmp, nTmp, dtAvalDate, SH_cls_Execute )
.head 8 -  Set dtAvalDate = SalDateConstruct( SalDateYear( SalDateCurrent() ), nMonth + 7, 1, 0, 0, 0 )
.head 8 -  Call CalcFutureAvailAtDate( colItemNo, nYear, colMonth6, nTmp, nTmp, dtAvalDate, SH_cls_Execute )
.head 8 +  If dfCustNo > 0
.head 9 -  Call GetFinelineDetails( colItemNo, dfCustNo, dfSupplierId, colCultDesc, colTreeType, colFineline, colPrice, sTmp, dfAssCustNo, nTmp, sIsFinlineCust, hWndNULL, SH_cls_Execute )
.head 8 -  Call GetCustItemQuotPrice( dfCustNo, nYear, dfSupplierId, colItemNo, bFound, colCostPrice, SH_cls_Execute )
.head 8 -  Set nBasePrice = colCostPrice
.head 8 +  If NOT bFound
.head 9 -  Call CalcItemPriceForQueries( colItemNo, nYear, colCostPrice, nTmp, nBasePrice, SH_cls_Execute )
.head 8 +  Else
.head 9 -  Call GetItemFullBasicDetails( colItemNo, sTreeType, sTreeTypeDesc, sCultId, sCultDesc, sRootId, sRootDesc, sStockType, sTmp, sTmp, SH_cls_Execute )
.head 9 -  Call CalcCultivarRoyalty( 0, sCultId, colItemNo, nCultRoy, SH_cls_Execute )
.head 9 -  Call CalcRootstockRoyalty( 0, sRootId, colItemNo, nRootRoy, SH_cls_Execute )
.head 9 -  Set colCostPrice = (colCostPrice +  nCultRoy + nRootRoy) * (1 + nGST)
.head 8 +  If colCurrentAvail + colTotalFutureAvail = 0
.head 9 -  Call CalculateSubsItems( colItemNo, nYear, colCurrentAvail, SH_cls_Execute )
.head 8 +  If ((colCurrentAvail + colTotalFutureAvail = 0) and (colMonth1 + colMonth2 + colMonth3 + colMonth4 + colMonth5 + colMonth6) = 0) or (colCostPrice = 0 or nBasePrice = 0 or nBasePrice = NUMBER_Null)
.head 9 -  Call SalTblSetRowFlags( hWndForm, lParam, ROW_Hidden, TRUE )
.head 9 -  ! Call SalTblDeleteRow( hWndForm, lParam, TBL_Adjust )
.head 8 -  Call SalSendClassMessage( SAM_FetchRowDone, wParam, lParam )
.head 7 +  On SAM_Destroy
.head 8 -  Call CalcItemPriceForQueries( colItemNo, nYear, colCostPrice, nTmp, nTmp, SH_cls_Disconnect)
.head 8 -  Call CalcFutureAvailAtDate( colItemNo, nYear, colMonth6, nTmp, nTmp, dtAvalDate, SH_cls_Disconnect )
.head 8 -  Call GetFinelineDetails( colItemNo, dfCustNo, dfSupplierId, colCultDesc, colTreeType, colFineline, colPrice, sTmp, dfAssCustNo, nTmp, sIsFinlineCust, hWndNULL, SH_cls_Disconnect )
.head 8 -  Call CalculateSubsItems( colItemNo, nYear, colCurrentAvail, SH_cls_Disconnect )
.head 8 -  Call GetItemFullBasicDetails( colItemNo, sTreeType, sTreeTypeDesc, sCultId, sCultDesc, sRootId, sRootDesc, sStockType, sTmp, sTmp, SH_cls_Disconnect )
.head 8 -  Call CalcCultivarRoyalty( 0, sCultId, colItemNo, nCultRoy, SH_cls_Disconnect )
.head 8 -  Call CalcRootstockRoyalty( 0, sRootId, colItemNo, nRootRoy, SH_cls_Disconnect )
.head 8 -  Return TRUE

.head 6 +  Message Actions
.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 -  Set sSQLPopHandle = "SELECT
	sis.stock_Item_No,
	Tree_Type_Desc,
	Cult_Desc,
	Root_Desc,
	Tot_Avail,
	Est_Avail_Count
FROM
	stock_item si,
	Stock_Item_Sale sis
WHERE
	si.item_no = sis.stock_item_no and
	Year_of_sale = :1 and
	Tot_avail + Est_Avail_Count >= 0 and
	(rootstock_id is null or
	Generic_Stock_Item = 'Y')
ORDER BY
	stock_type desc, Variety_Type, Variety, Cult_Desc"
.head 8 -  Set sNAMEPopHandle = 'GetStockDets5'
.head 8 -  Set sBINDPopHandle = ':tblInventory.nYear'
.head 8 -  Set sINTOPopHandle = ':clsfrmInventorySchedule.tblInventory.colItemNo,
:clsfrmInventorySchedule.tblInventory.colTreeType,
:clsfrmInventorySchedule.tblInventory.colCultDesc,
:clsfrmInventorySchedule.tblInventory.colRootDesc,
:clsfrmInventorySchedule.tblInventory.colCurrentAvail,
:clsfrmInventorySchedule.tblInventory.colTotalFutureAvail'
.head 8 -  !
.head 8 -  ! Set sSQLRefreshHandle = "SELECT
	Tree_Type,
	Cult_Desc,
	Root_Desc,
	Tot_Avail	
FROM
	stock_item si,
	Stock_Item_Sale sis,
WHERE
	si.item_no = sis.stock_item_no 
ORDER BY
	Variety_Type, Variety, Cult_Desc"
.head 8 -  ! Set sNAMERefreshHandle = 'RepopGetStockDets'
.head 8 -  ! Set sBINDRefreshHandle = ':hWndParent..dfCustNo'
.head 8 -  ! Set sINTORefreshHandle = ':clsfrmInventorySchedule.tblInventory.colTreeType,
:clsfrmInventorySchedule.tblInventory.colCultDesc,
:clsfrmInventorySchedule.tblInventory.colRootDesc'
.head 8 -  ! !
.head 8 +  ! ! If TRUE
.head 9 -  !
.head 9 -  Set sPrinter = 'LargeFanFold'
.head 9 -  Set sReportFileName = 'PrtCltLblInv5.qrp'
.head 9 -  Set sRepBind = ':frmCultivarLabelInventory.tblCultivars.colCultDesc,
:frmCultivarLabelInventory.tblCultivars.colLblStockTakeDate,
:frmCultivarLabelInventory.tblCultivars.colLblWesEst,
:frmCultivarLabelInventory.tblCultivars.colLblComingUp,
:frmCultivarLabelInventory.tblCultivars.colLblOurCount,
:frmCultivarLabelInventory.tblCultivars.colLblNorwCount,
:frmCultivarLabelInventory.tblCultivars.colLblMBirdCount,
:frmCultivarLabelInventory.tblCultivars.colLblUsaCount,
:frmCultivarLabelInventory.tblCultivars.colLblCompCount,
:frmCultivarLabelInventory.tblCultivars.colLblTagCount,
:frmCultivarLabelInventory.tblCultivars.colLblInfo,
:frmCultivarLabelInventory.tblCultivars.colInvoicedSince,
:frmCultivarLabelInventory.tblCultivars.colAvail,
:frmCultivarLabelInventory.tblCultivars.colLblsReq'
.head 9 -  Set sRepInto = 'sCultDesc,
dtLblStockTakeDate,
nLblWesEst,
nLblComingUp,
nLblOurCount,
nLblNorwCount,
nLblMBirdCount,
nLblUsaCount,
nLblCompCount,
nLblTagCount,
sLblInfo,
nInvoicedSince,
nAvail,
nLblsReq'
.head 9 -  !
.head 9 -  ! Set sSQLUpdateHandle = ' UPDATE Stock_Item
SET
  	Base_Price = :1,
	Changed_Date = :5,
	Changed_By = :6
WHERE
	Base_Price = :2 and
	Tree_Type = :3 and
	Variety_Type = :4 '
.head 9 -  ! Set sNAMEUpdateHandle = 'UPBASEPRICE3'
.head 9 -  ! Set sBINDUpdateHandle = ':frmPricing.tblPricingDetails.colnNewPrice,
:frmPricing.tblPricingDetails.colnCurrentPrice,
:frmPricing.tblPricingDetails.colsTreeType,
:frmPricing.tblPricingDetails.colsVarietyType,
:frmPricing.dtChangeDate,
:frmPricing.sChangedBy'
.head 9 -  ! Set sINTOUpdateHandle = ''
.head 9 -  ! !
.head 9 -  ! Set sSQLRefreshHandle =  ' SELECT
	distinct base_price,
	Tree_type,
	variety_type
FROM
	stock_item si
WHERE
	variety_type is not null and
	Base_Price = :1 and
	Tree_Type = :2 and
	Variety_Type = :3
'
.head 9 -  ! Set sINTORefreshHandle = ':frmPricing.tblPricingDetails.colnCurrentPrice,
:frmPricing.tblPricingDetails.colsTreeType,
:frmPricing.tblPricingDetails.colsVarietyType'
.head 9 -  ! Set sNAMERefreshHandle = '2101RFPRICE5'

.head 4 -  Set sReportSql = 'select
	roy_bus_name,
	cult_desc,
	currency_payable,
	currency_roy_amt,
	percentage_payable,
	amount_payable
from
	royalty_payable rp,
	royalty_owner ro,
	cultivar c
into
	:frmPrintCultRoyalty.sRoyOwner,
	:frmPrintCultRoyalty.sCultDesc,
	:frmPrintCultRoyalty.sCurrency,
	:frmPrintCultRoyalty.nCurrencyAmt,
	:frmPrintCultRoyalty.nPercentage,
	:frmPrintCultRoyalty.nAmountPayable
where
	cult_id = cultivar_id and
	rp.royalty_owner_id = ro.royalty_owner_id
order by
	rp.royalty_owner_id,
	variety_type,
	variety,
	cult_desc'
.head 4 -  Set sReportFileNameNoPath = 'CultRoyaltyReport.qrp'
.head 4 -  Set sReportBind = '
	:frmPrintCultRoyalty.sRoyOwner,
	:frmPrintCultRoyalty.sCultDesc,
	:frmPrintCultRoyalty.sCurrency,
	:frmPrintCultRoyalty.nCurrencyAmt,
	:frmPrintCultRoyalty.nPercentage,
	:frmPrintCultRoyalty.nAmountPayable'
.head 4 -  Set sReportInto = '
	sRoyOwner,
	sCultDesc,
	sCurrency,
	nCurrencyAmt,
	nPercentage,
	nAmountPayable'
.head 4 -  Set sPrinter = 'LaserPrinter'

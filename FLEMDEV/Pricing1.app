INTO
	:dlgCultivarPrices.tblStockItems.colnPrice, 
	:dlgCultivarPrices.tblStockItems.colsVarietyType,
	:dlgCultivarPrices.tblStockItems.colsVariety,
	:dlgCultivarPrices.tblStockItems.colsTreeType,
	:dlgCultivarPrices.tblStockItems.colsCultivar,

.head 6 -  Set sReportFileName = 'PriceDetail.QRP'
.head 6 -  Set sPrinter = 'WideFanFold'
.head 6 -  Set sSQLPopHandle = "SELECT
	Item_no,
	base_price,
	cult_desc,
	root_desc,
	tree_type,
	variety,
	Variety_type
FROM
	stock_item,
	stock_item_sale
WHERE
	stock_item.item_no = stock_item_sale.stock_item_no and
	year_of_sale = :1 and
	(amt_growing > 0 or
	amt_graded > 0 or
	amt_on_order > 0 or
	on_ord_as_subs > 0) and
	Stock_type = 'B'
ORDER BY
	variety_type,6,2,3,4 "

.head 6 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'UPdateItemPrices' )
.head 6 -  Set sSql = " UPDATE 
	Stock_Item
SET
  	Base_Price = :frmPricing.tblPricingDetails.colnNewPrice,
	Changed_Date = :frmPricing.dtSysDate,
	Changed_By = :frmPricing.sChangedBy
WHERE 
	Base_Price = :frmPricing.tblPricingDetails.colnCurrentPrice and
	Tree_Type = :frmPricing.tblPricingDetails.colsTreeType and
	Variety_Type = :frmPricing.tblPricingDetails.colsVarietyType and
	Generic_Stock_Item in ( " || frmPricing.sGenericFlag || " ) and
	cultivar_id in
(select 
	cult_id 
from
	Cultivar
where
	variety_type = :frmPricing.tblPricingDetails.colsVarietyType and
	Price_Group = :frmPricing.tblPricingDetails.sCultPriceGroup)  and
	rootstock_id in
(select 
	root_id 
from
	Rootstock
where
	Price_Group = :frmPricing.tblPricingDetails.sRootPriceGroup)"

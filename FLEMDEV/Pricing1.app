.head 6 -  Set sRepBind = 'frmPrintPotPriceDetails.tblPricingDetails.colnBasePrice, 
frmPrintPotPriceDetails.tblPricingDetails.colnGSTExcPrice,
frmPrintPotPriceDetails.tblPricingDetails.colnTotalPrice,
frmPrintPotPriceDetails.tblPricingDetails.colsCultDesc,
frmPrintPotPriceDetails.tblPricingDetails.colsRootDesc,
frmPrintPotPriceDetails.tblPricingDetails.colsTreeType,
frmPrintPotPriceDetails.tblPricingDetails.colsVariety'
.head 6 -  Set sRepInto = 'nBase_Price, 
nGSTExcPrice, 
nTotal_Price, 
sCult_Desc, 
sRoot_Desc, 
sTree_Type, 
sVariety'
.head 6 -  Set sReportFileName = 'PriceDetail.qrp'
.head 6 -  Set sPrinter = 'WideFanFold'
.head 6 -  Set sSQLPopHandle = "SELECT
	Item_no,
	base_price,
	cult_desc,
	root_desc,
	tree_type,
	variety,
	Variety_type
FROM
	stock_item,
	stock_item_sale
WHERE
	stock_item.item_no = stock_item_sale.stock_item_no and
	year_of_sale = :1 and
	(amt_growing > 0 or
	amt_graded > 0 or
	amt_on_order > 0 or
	on_ord_as_subs > 0) and
	Stock_type = 'C'
ORDER BY
	5,variety_type,6,2,3,4 "
.head 6 -  Set sNAMEPopHandle = 'POTPRICEPRINT1'
.head 6 -  Set sBINDPopHandle = ':frmPrintPotPriceDetails.nYear'
.head 6 -  Set sINTOPopHandle = ':frmPrintPotPriceDetails.tblPricingDetails.colnItemNo,
:frmPrintPotPriceDetails.tblPricingDetails.colnBasePrice,
:frmPrintPotPriceDetails.tblPricingDetails.colsCultDesc,
:frmPrintPotPriceDetails.tblPricingDetails.colsRootDesc,
:frmPrintPotPriceDetails.tblPricingDetails.colsTreeType,
:frmPrintPotPriceDetails.tblPricingDetails.colsVariety,
:frmPrintPotPriceDetails.tblPricingDetails.colsVarietyType'
.head 6 -  !

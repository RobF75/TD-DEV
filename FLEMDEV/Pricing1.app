WHERE
	Rootstock_id = root_id and
	si.cultivar_id = c.cult_id and
	( Base_Price = :dlgCultivarPrices.tblStockItems.nBasePrice ) and
	( si.Variety_Type = :dlgCultivarPrices.tblStockItems.sVarietyType ) and
	( Tree_Type = :dlgCultivarPrices.tblStockItems.sTreeType ) and
	( c.Price_Group = :dlgCultivarPrices.sCultPriceGroup ) and

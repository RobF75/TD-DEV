.head 5 +  Function: fnPrintBarcodes
.head 6 -  Description: This function will print a desired number of fineline item barcodes for a selected item
.head 6 -  Returns
.head 6 -  Parameters
.head 6 -  Static Variables
.head 6 +  Local variables
.head 7 -  Boolean: bOk
.head 7 -  Number: nCurrentRow
.head 7 -  ! String: sReportVars
.head 7 -  ! String: sReportInto
.head 7 -  String: sFineline
.head 7 -  String: sSupplier
.head 6 +  Actions
.head 7 -  Set bOk = TRUE
.head 7 +  If NOT SalTblAnyRows( hWndForm, ROW_Selected, 0 )
.head 8 -  Call SalMessageBox( 'No row selected', 'Print Fineline Barcodes', MB_Ok | MB_IconExclamation )
.head 8 -  Set bOk = FALSE
.head 7 +  ! Else
.head 8 -  Set nCurrentRow = TBL_MinRow
.head 8 -  Set nCount = 0
.head 8 +  While SalTblFindNextRow( hWndForm, nCurrentRow, ROW_Selected, 0 )
.head 9 +  If SalTblQueryRowFlags( hWndForm, nCurrentRow, ROW_New )
.head 10 -  Call SalMessageBox( 'Save row details first', 'Print Fineline Barcodes', MB_Ok | MB_IconExclamation )
.head 10 -  Set bOk = FALSE
.head 9 +  Else If SalTblQueryRowFlags( hWndForm, nCurrentRow, ROW_Edited )
.head 10 -  Call SalMessageBox( 'Save row changes first', 'Print Fineline Barcodes', MB_Ok | MB_IconExclamation )
.head 10 -  Set bOk = FALSE
.head 9 +  Else
.head 10 -  Set sFineline[nCount] = SalNumberToStrX( colnFinelineNo, 0 )
.head 10 -  Set nCount = nCount + 1
.head 10 -  Call SalModalDialog( dlgPrintBarCodeLabels, hWndForm, dfnCustomerNo, dfsCustomerName, colnStockItemNo,  saFineline, colnaRetailPrice, colsBarCode, sSupplier, dfnBarcodes, 'BC' )
.head 10 -  Call SalMessageBox( 'Barcodes Printed', 'Print Fineline Barcodes', MB_Ok | MB_IconExclamation )
.head 7 +  Else
.head 8 -  Set nCurrentRow = TBL_MinRow
.head 8 +  While SalTblFindNextRow( hWndForm, nCurrentRow, ROW_Selected, 0 )
.head 9 +  If SalTblQueryRowFlags( hWndForm, nCurrentRow, ROW_New )
.head 10 -  Call SalMessageBox( 'Save row details first', 'Print Fineline Barcodes', MB_Ok | MB_IconExclamation )
.head 10 -  Set bOk = FALSE
.head 9 +  Else If SalTblQueryRowFlags( hWndForm, nCurrentRow, ROW_Edited )
.head 10 -  Call SalMessageBox( 'Save row changes first', 'Print Fineline Barcodes', MB_Ok | MB_IconExclamation )
.head 10 -  Set bOk = FALSE
.head 9 +  Else
.head 10 -  Set sFineline = SalNumberToStrX( colnFinelineNo, 0 )
.head 10 -  ! Call SalModalDialog( dlgPrintBarCodeLabels, hWndForm, dfnCustomerNo, dfsCustomerName, colnStockItemNo, colsTreeType, colsItemDescription, sFineline, colnRetailPrice, colsBarCode, dfSupplierId, dfnBarcodes, 'BC' )
.head 10 -  Call SalMessageBox( 'Barcodes Printed', 'Print Fineline Barcodes', MB_Ok | MB_IconExclamation )
.head 7 -  Return bOk

.head 5 -  Set npAssCustomerNo = SalStrToNumber( strArgArray[5] )
.head 5 -  Set npSeasonYear = SalStrToNumber( strArgArray[6] )
.head 5 -  Set spCustType = strArgArray[7]
.head 4 +  Else
.head 5 -  ! Set SqlDatabase = 'STKLOCAL'
.head 5 -  Set SqlDatabase = 'STOCKDEV'
.head 5 -  ! Set SqlDatabase = 'STOCK'
.head 5 -  Set SqlUser = 'GRAHAM'
.head 5 -  Set SqlPassword = 'GRAHAM'
.head 5 -  Set npCustomerNo = 312067
.head 5 -  Set npAssCustomerNo = 611313 
.head 5 -  Set npSeasonYear = 2008
.head 5 -  Set spCustType = 'GCB'

.head 5 +  On PAM_clsTBL_SAVECSVROW
.head 6 +  ! If colnWholesalePrice != NUMBER_Null
.head 7 -  Call GetItemFullBasicDetails( colnStockItemNo, sTmp, sTmp, sCultId, sTmp, sRootId, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
.head 7 -  Call CalcCultivarRoyalty( 0, sCultId, colnStockItemNo, nCultRoy, SH_cls_Execute )
.head 7 -  Call CalcRootstockRoyalty( 0, sRootId, colnStockItemNo, nRootRoy, SH_cls_Execute )
.head 7 -  Set colnWholesalePrice = colnWholesalePrice + nCultRoy + nRootRoy 
.head 7 -  Set colnWholesalePrice = colnWholesalePrice + (colnWholesalePrice * nGSTPercent)
.head 6 +  ! Else
.head 7 -  Call CalcItemPriceForQueries( colnStockItemNo, npSeasonYear, hWndForm.nWholesalePrice, colnWholesalePrice, nTmp, SH_cls_Execute )
.head 6 -  Set colsBarCode = fnCalculateBarCode( colnStockItemNo, dfnCustomerNo, spCustType )
.head 6 -  ! If nOutputType = PAM_OurBarcode
.head 6 +  ! Else If nOutputType = PAM_TheirBarcode
.head 7 +  If colsBarCode != STRING_Null
.head 8 -  Set nStepOneResult = 0
.head 8 -  Set nStepThreeResult = 0
.head 8 -  Set nStepTwoResult = 0
.head 8 -  Set sPreliminaryValue = colsBarCode
.head 8 -  Set nCount = 0
.head 8 -  ! The following while loop goes through the preliminary string extracting all characters
one by one as numbers into an array. Eg if string was 123456789012 then the characters would be extracted
as follows:   nBarCodeNumbers[0] = 1,nBarCodeNumbers[1] = 2,nBarCodeNumbers[2] = 3
.head 8 +  While nCount <= 11
.head 9 -  Set nBarCodeNumbers[nCount] = SalStrToNumber( SalStrMidX( sPreliminaryValue, nCount, 1 ) )
.head 9 -  Set nCount = nCount + 1
.head 8 -  ! First step in check digit calculation requires all alternate number starting from the right be
added together and then multiplied by three.
.head 8 -  Call SalArrayGetUpperBound( nBarCodeNumbers, 1, nArrayUpper )
.head 8 -  ! Step 1. Starting with the first number on the right, add all the alternate numbers.
Multiply the result by three.
.head 8 -  Set nCount = nArrayUpper
.head 8 +  While nCount >= 0
.head 9 -  Set nStepOneResult = nStepOneResult + nBarCodeNumbers[nCount]
.head 9 -  Set nCount = nCount - 2
.head 8 -  Set nStepOneResult = nStepOneResult * 3
.head 8 -  ! Step 2. Starting with the second number on the right add all the alternate numbers
.head 8 -  Set nCount = nArrayUpper - 1
.head 8 +  While nCount >= 0
.head 9 -  Set nStepTwoResult = nStepTwoResult + nBarCodeNumbers[nCount]
.head 9 -  Set nCount = nCount - 2
.head 8 -  ! Step 3. Add the results of step one and step two together
.head 8 -  Set nStepThreeResult = nStepOneResult + nStepTwoResult
.head 8 -  ! Step 4. The number needed to bring nStepThreeResult to the next multiple of 10 becomes the check digit
.head 8 -  ! In the following code the call to SalNumberMod will return the number left over after dividing by ten.
! To workout the check digit simply take that value from 10.
.head 8 -  Set nCheckDigit = 10 - SalNumberMod( nStepThreeResult, 10 )
.head 8 +  If nCheckDigit = 10
.head 9 -  Set nCheckDigit = 0
.head 8 -  Set colsBarCode = sPreliminaryValue || SalNumberToStrX( nCheckDigit, 0 )
.head 6 +  ! Else If nOutputType = PAM_FinelineException
.head 7 +  If colnFinelineNo = NUMBER_Null
.head 8 -  Set colsBarCode = fnCalculateBarCode( colnStockItemNo )
.head 6 -  Return SalSendClassMessage( PAM_clsTBL_SAVECSVROW, wParam, lParam )
.head 5 +  On PAM_clsTBL_SAVECSVFILE
.head 6 -  Return SalSendClassMessage( PAM_clsTBL_SAVECSVFILE, wParam, lParam )
.head 5 +  On PAM_clsTBL_SAVECSVFILEDONE
.head 6 -  Call SalSendMsg( tblCustomerFinelines, PAM_clsTBL_REPOPULATE, 0, 0 )

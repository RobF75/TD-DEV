.head 6 +  Actions 
.head 7 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( '0406GetPullSheet' )
.head 7 +  Select Case nActionType
.head 8 +  Case SH_cls_Execute
.head 9 +  If NOT bFirstFetchDone
.head 10 -  Set sSql = " 
SELECT
  	l.Id,
  	User_ref,
	action,
	timestamp,
	load_id,
	cust_no,
	load_cust_inst_no,
	stock_item_no,
	new_item_no,
	order_date_time,
	conf_amt,
	name
FROM
  	HH_Logs l,
	HH_Users u
WHERE
  	u.id = l.user_ref and
	l.timestamp < :1
ORDER BY
	cust_no,
	timestamp"
.head 10 -  Set sName = '0406GetPullShet1'
.head 10 -  Set sBind = ':dtMonday'
.head 10 -  Set sInto = ':nGotId, 
:nGotUserRef, 
:nGotAction, 
:dtGotDateTime, 
:sGotLoadId, 
:nGotCustNo, 
:nGotInstNo, 
:nGotItemNo, 
:nGotNewItemNo, 
:dtGotOrdDateTime, 
:nGotConfAmt, 
:sGotUserName '
.head 10 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 10 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 10 -  Set dtMonday = SalDateWeekBegin( SalDateCurrent(  ) )
.head 10 +  If NOT haSqlHandles[ nSqlHandleNo ].Execute( )
.head 11 -  Return FALSE
.head 9 -  !
.head 9 -  Set bFirstFetchDone = TRUE
.head 9 -  !
.head 9 -  Set nPrevCustNo = NUMBER_Null
.head 9 -  Set nRow = 0

ORDER BY 2,4 "
.head 4 -  ! Call fcReportHdl.PrepareSetup( sReportSql )
.head 4 -  ! Call SqlVarSetup( fcReportHdl.hSqlHandle )
.head 4 -  Call SalFileOpen( fhOutputFile, 'c:\\temp\\PromoCustomers.txt', OF_Create | OF_ReadWrite )
.head 4 -  !
.head 4 -  ! Return fcReportHdl.PrepareAndExecute( )
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFETCHNEXT
.head 4 -  Set sCustNo = SalNumberToStrX( nCustNo, 0 )
.head 4 -  Call SalFilePutStr( fhOutputFile, sCustNo )
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTFINISH
.head 4 -  Call SalFileClose( fhOutputFile )
.head 4 -  Return TRUE

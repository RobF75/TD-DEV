.head 4 +  Message Actions
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sSQLPopHandle = "SELECT 
  Promo_Id, 
  @UPPER( Promo_Desc ), 
  Promo_Desc 
FROM 
  Promo 
ORDER BY 1,2,3"
.head 6 -  Set sNAMEPopHandle = 'POPPRMOSEL'
.head 6 -  Set sBINDPopHandle = ''
.head 6 -  Set sINTOPopHandle = ':frmPrintPromoInterface.tblSelectedPromos.colPromoId, 
:frmPrintPromoInterface.tblSelectedPromos.colUpperPromoDesc, 
:frmPrintPromoInterface.tblSelectedPromos.colPromoDesc'
.head 6 -  !
.head 6 -  Set bAddAllowed = FALSE
.head 6 -  Set bPopulated = FALSE
.head 5 +  On PAM_clsTBL_POPULATE
.head 6 -  Set bPopulated = TRUE
.head 6 -  Return SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
.head 5 +  On PAM_clsPRTPROMO_GETSELPROMOIDS
.head 6 -  Set sPromoIdList = ''
.head 6 +  If TableLoop( hWndForm, hWndForm, PAM_clsPRTPROMO_GETSELECTED, 0, ROW_Selected, 0, 'Extracting Selected Items', TBL_cls_LowToHi )
.head 7 +  If sPromoIdList = ''
.head 8 -  Return FALSE
.head 7 +  Else
.head 8 -  Call PushString( sPromoIdList )
.head 8 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  On PAM_clsPRTPROMO_GETSELECTED
.head 6 +  If sPromoIdList = ''
.head 7 -  Set sPromoIdList = "'" || colPromoId || "'"
.head 6 +  Else
.head 7 -  Set sPromoIdList = sPromoIdList || ', ' || "'" || colPromoId || "'"
.head 6 -  Return TRUE

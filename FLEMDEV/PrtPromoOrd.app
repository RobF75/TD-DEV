.head 2 -  Functions
.head 2 +  Window Parameters
.head 3 -  ! sSelectedPromoIdList is a comma separated list of promo ids
.head 3 -  String: sSelectedPromoIdList
.head 3 -  Number: nYear
.head 3 -  ! sPromoType = 'SELECTED' OR 'ALL'
.head 3 -  String: sPromoType
.head 3 -  ! sReportPrintOrView = 'VIEW' OR 'PRINT'
.head 3 -  String: sReportPrintOrView
.head 3 -  ! sInvoiced = 'Y' OR 'N'
.head 3 -  String: sInvoiced
.head 2 +  Window Variables
.head 3 -  FunctionalVar: fcReportHdl
.head 4 -  Class: hcSqlHandle
.head 3 -  ! REPORT FIELDS
.head 3 -  String: sPromoId
.head 3 -  String: sUpperPromoDesc
.head 3 -  String: sPromoDesc
.head 3 -  Number: nCustNo
.head 3 -  String: sCustName
.head 3 -  Number: nNoUnits
.head 3 -  File Handle: fhOutputFile
.head 3 -  String: sCustNo
.head 2 +  Message Actions
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set sPrinter = 'LaserPrinter'
.head 4 -  Set sReportFileNameNoPath = 'promord.qrp'
.head 4 -  !
.head 4 -  Set sReportBind = 'frmPrintPromoOrderedBy.nYear, 
frmPrintPromoOrderedBy.sPromoId,
frmPrintPromoOrderedBy.sUpperPromoDesc,
frmPrintPromoOrderedBy.sPromoDesc,
frmPrintPromoOrderedBy.nCustNo,
frmPrintPromoOrderedBy.sCustName,
frmPrintPromoOrderedBy.nNoUnits'
.head 4 -  Set sReportInto = 'nYearOfSale, 
sPromoId,
sUpperPromoDesc,
sPromoDesc,
nCustNo,
sCustName,
nNoUnits'
.head 4 -  Set sReportType = sReportPrintOrView
.head 4 -  Return TRUE
.head 3 +  On PAM_clsFRM_REPORTSTART
.head 4 -  ! 01/09/03 (PXD) Added option flag to signify whether invoiced promo items are requested
.head 4 +  ! 01/09/03 (PXD) If sPromoType = 'ALL'
.head 5 -  Set sReportSql = "SELECT 
  Cust_Promo.Promo_Id,
  @UPPER( Promo.Promo_Desc ),  
  Promo.Promo_Desc, 
  Cust_Promo.Cust_No, 
  Customer_Master.Cust_Name,  
  Cust_Promo.No_Units 
FROM 
  Cust_Promo, 
  Promo, 
  Customer_Master 
INTO 
  :frmPrintPromoOrderedBy.sPromoId, 
  :frmPrintPromoOrderedBy.sUpperPromoDesc, 
  :frmPrintPromoOrderedBy.sPromoDesc, 
  :frmPrintPromoOrderedBy.nCustNo, 
  :frmPrintPromoOrderedBy.sCustName, 
  :frmPrintPromoOrderedBy.nNoUnits 
WHERE 
  Cust_Promo.Cust_No = Customer_Master.Cust_No AND 
  Cust_Promo.Promo_Id = Promo.Promo_Id AND 
  Cust_Promo.Year_Of_Order = :frmPrintPromoOrderedBy.nYear AND 
  ( Cust_Promo.Promo_Sent_Flag = 'N' OR 
  Cust_Promo.Promo_Sent_Flag  IS NULL ) AND 
  ( Cust_Promo.Promo_Inv_Flag = 'N' OR 
  Cust_Promo.Promo_Inv_Flag IS NULL ) 
ORDER BY 2,4 "
.head 4 +  ! 01/09/03 (PXD) Else 
.head 5 -  Set sReportSql = "SELECT 
  Cust_Promo.Promo_Id,
  @UPPER( Promo.Promo_Desc ),  
  Promo.Promo_Desc, 
  Cust_Promo.Cust_No, 
  Customer_Master.Cust_Name,  
  Cust_Promo.No_Units 
FROM 
  Cust_Promo, 
  Promo, 
  Customer_Master 
INTO 
  :frmPrintPromoOrderedBy.sPromoId, 
  :frmPrintPromoOrderedBy.sUpperPromoDesc, 
  :frmPrintPromoOrderedBy.sPromoDesc, 
  :frmPrintPromoOrderedBy.nCustNo, 
  :frmPrintPromoOrderedBy.sCustName, 
  :frmPrintPromoOrderedBy.nNoUnits 
WHERE 
  Cust_Promo.Cust_No = Customer_Master.Cust_No AND 
  Cust_Promo.Promo_Id = Promo.Promo_Id AND 
  Cust_Promo.Year_Of_Order = :frmPrintPromoOrderedBy.nYear AND 
  Cust_Promo.Promo_Id  IN ( " || sSelectedPromoIdList || " ) AND 
  ( Cust_Promo.Promo_Sent_Flag = 'N' OR 
  Cust_Promo.Promo_Sent_Flag  IS NULL ) AND 
  ( Cust_Promo.Promo_Inv_Flag = 'N' OR 
  Cust_Promo.Promo_Inv_Flag IS NULL ) 
ORDER BY 2,4 "
.head 4 +  If sInvoiced = 'Y'		! 01/09/03 (PXD)
.head 5 +  If sPromoType = 'ALL'
.head 6 -  Set sReportSql = "SELECT 
  Cust_Promo.Promo_Id,
  @UPPER( Promo.Promo_Desc ),  
  Promo.Promo_Desc, 
  Cust_Promo.Cust_No, 
  Customer_Master.Cust_Name,  
  Cust_Promo.No_Units 
FROM 
  Cust_Promo, 
  Promo, 
  Customer_Master 
INTO 
  :frmPrintPromoOrderedBy.sPromoId, 
  :frmPrintPromoOrderedBy.sUpperPromoDesc, 
  :frmPrintPromoOrderedBy.sPromoDesc, 
  :frmPrintPromoOrderedBy.nCustNo, 
  :frmPrintPromoOrderedBy.sCustName, 
  :frmPrintPromoOrderedBy.nNoUnits 
WHERE 
  Cust_Promo.Cust_No = Customer_Master.Cust_No AND 
  Cust_Promo.Promo_Id = Promo.Promo_Id AND 
  Cust_Promo.Year_Of_Order = :frmPrintPromoOrderedBy.nYear AND 
  Cust_Promo.Promo_Inv_Flag = 'Y' 
ORDER BY 2,4 "
.head 5 +  Else
.head 6 -  Set sReportSql = "SELECT 
  Cust_Promo.Promo_Id,
  @UPPER( Promo.Promo_Desc ),  
  Promo.Promo_Desc, 
  Cust_Promo.Cust_No, 
  Customer_Master.Cust_Name,  
  Cust_Promo.No_Units 
FROM 
  Cust_Promo, 
  Promo, 
  Customer_Master 
INTO 
  :frmPrintPromoOrderedBy.sPromoId, 
  :frmPrintPromoOrderedBy.sUpperPromoDesc, 
  :frmPrintPromoOrderedBy.sPromoDesc, 
  :frmPrintPromoOrderedBy.nCustNo, 
  :frmPrintPromoOrderedBy.sCustName, 
  :frmPrintPromoOrderedBy.nNoUnits 
WHERE 
  Cust_Promo.Cust_No = Customer_Master.Cust_No AND 
  Cust_Promo.Promo_Id = Promo.Promo_Id AND 
  Cust_Promo.Year_Of_Order = :frmPrintPromoOrderedBy.nYear AND 
  Cust_Promo.Promo_Id  IN ( " || sSelectedPromoIdList || " ) AND 
  Cust_Promo.Promo_Inv_Flag = 'Y' 
ORDER BY 2,4 "
.head 4 +  Else
.head 5 +  If sPromoType = 'ALL'
.head 6 -  Set sReportSql = "SELECT 
  Cust_Promo.Promo_Id,
  @UPPER( Promo.Promo_Desc ),  
  Promo.Promo_Desc, 
  Cust_Promo.Cust_No, 
  Customer_Master.Cust_Name,  
  Cust_Promo.No_Units 
FROM 
  Cust_Promo, 
  Promo, 
  Customer_Master 
INTO 
  :frmPrintPromoOrderedBy.sPromoId, 
  :frmPrintPromoOrderedBy.sUpperPromoDesc, 
  :frmPrintPromoOrderedBy.sPromoDesc, 
  :frmPrintPromoOrderedBy.nCustNo, 
  :frmPrintPromoOrderedBy.sCustName, 
  :frmPrintPromoOrderedBy.nNoUnits 
WHERE 
  Cust_Promo.Cust_No = Customer_Master.Cust_No AND 
  Cust_Promo.Promo_Id = Promo.Promo_Id AND 
  Cust_Promo.Year_Of_Order = :frmPrintPromoOrderedBy.nYear AND 
  ( Cust_Promo.Promo_Sent_Flag = 'N' OR 
  Cust_Promo.Promo_Sent_Flag  IS NULL ) AND 
  ( Cust_Promo.Promo_Inv_Flag = 'N' OR 
  Cust_Promo.Promo_Inv_Flag IS NULL ) 
ORDER BY 2,4 "
.head 5 +  Else
.head 6 -  Set sReportSql = "SELECT 
  Cust_Promo.Promo_Id,
  @UPPER( Promo.Promo_Desc ),  
  Promo.Promo_Desc, 
  Cust_Promo.Cust_No, 
  Customer_Master.Cust_Name,  
  Cust_Promo.No_Units 
FROM 
  Cust_Promo, 
  Promo, 
  Customer_Master 
INTO 
  :frmPrintPromoOrderedBy.sPromoId, 
  :frmPrintPromoOrderedBy.sUpperPromoDesc, 
  :frmPrintPromoOrderedBy.sPromoDesc, 

  nOrdAmt, 
  nConfAmt, 
  dtHoldOrdDate, 
  sTreeTypeDesc, 
  sCultDesc, 
  sRootDesc, 
  dtEstSaleDate'
.head 4 -  Set sReportType = sReportPrintOrView
.head 4 -  !
.head 3 +  On PAM_clsFRM_REPORTSTART
.head 4 +  If sFarmType = 'ALL'
.head 5 -  Set sReportSql = "SELECT 
	L.Farm_Name,
	CO.Cust_No,
	CO.Batch_Year_Of_Sale,
	CO.Ordered_Amount,
	CO.Conf_Amt,
	CO.Hold_Order_Date,
	SI.Tree_Type_Desc,
	SI.Cult_Desc,
	SI.Root_Desc,
	GS.Est_Sale_Date
FROM
	Location L,
	Customer_Order CO,
	Growing_Sale GS,
	Stock_Item SI
WHERE
	L.Farm_Name LIKE 'C%' AND
	L.Location_Id = CO.Batch_Location_Id AND
	GS.Location_Id = CO.Batch_Location_Id AND
	GS.Year_Of_Sale = CO.Batch_Year_Of_Sale AND
	GS.Stock_Item_No = CO.Stock_Item_No AND
	CO.Stock_Item_No = SI.Item_No
ORDER BY
	L.Farm_Name,
	L.Row#,
	L.Seq#
INTO 
  :hWndForm.sFarmName, 
  :hWndForm.nCustNo, 
  :hWndForm.nBatchYear, 
  :hWndForm.nOrdAmt, 
  :hWndForm.nConfAmt, 
  :hWndForm.dtHoldOrdDate, 
  :hWndForm.sTreeTypeDesc, 
  :hWndForm.sCultDesc, 
  :hWndForm.sRootDesc, 
  :hWndForm.dtEstSaleDate
"
.head 4 +  Else
.head 5 -  Set sReportSql = "SELECT 
	L.Farm_Name,
	CO.Cust_No,
	CO.Batch_Year_Of_Sale,
	CO.Ordered_Amount,
	CO.Conf_Amt,
	CO.Hold_Order_Date,
	SI.Tree_Type_Desc,
	SI.Cult_Desc,
	SI.Root_Desc,
	GS.Est_Sale_Date
FROM
	Location L,
	Customer_Order CO,
	Growing_Sale GS,
	Stock_Item SI
WHERE
	L.Farm_Name IN ( " || sSelectedFarmNameList || " ) AND
	L.Location_Id = CO.Batch_Location_Id AND
	GS.Location_Id = CO.Batch_Location_Id AND
	GS.Year_Of_Sale = CO.Batch_Year_Of_Sale AND
	GS.Stock_Item_No = CO.Stock_Item_No AND
	CO.Stock_Item_No = SI.Item_No
ORDER BY
	L.Farm_Name,
	L.Row#,
	L.Seq#
INTO 
  :hWndForm.sFarmName, 
  :hWndForm.nCustNo, 
  :hWndForm.nBatchYear, 
  :hWndForm.nOrdAmt, 
  :hWndForm.nConfAmt, 
  :hWndForm.dtHoldOrdDate, 
  :hWndForm.sTreeTypeDesc, 
  :hWndForm.sCultDesc, 
  :hWndForm.sRootDesc, 
  :hWndForm.dtEstSaleDate
"
.head 4 -  Return TRUE

.head 5 +  Message Actions
.head 6 +  On PAM_clsPB_CLICK
.head 7 +  If rbSelectedFarms
.head 8 -  Set sFarmType = 'SELECTED'
.head 8 +  If SalSendMsg( tblSelectedFarms, PAM_clsPOTPLAND_GETSELFARMS, 0, 0 )
.head 9 -  Call PopString( sSelectedFarmNameList, TRUE )
.head 8 +  Else
.head 9 -  Call SalMessageBox( 'Please select some Farms by placing a tick in the Selected column first, or choose All.', 'Warning', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Set sFarmType = 'ALL'
.head 7 -  !
.head 7 +  If rbView
.head 8 -  Set sReportType = 'VIEW'
.head 7 +  Else
.head 8 -  Set sReportType = 'PRINT'
.head 7 -  !
.head 7 +  If hWndReport = hWndNULL
.head 8 +  If rbPotsPlan
.head 9 -  Set hWndReport = SalCreateWindow( frmPotPlan, hWndForm, sSelectedFarmNameList,
ccSeasonYear.GetSeasonYear( ), sFarmType, sReportType )
.head 8 +  Else
.head 9 -  Set hWndReport = SalCreateWindow( frmPotOrdered, hWndForm, sSelectedFarmNameList,
ccSeasonYear.GetSeasonYear( ), sFarmType, sReportType )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Call SalMessageBox( 'Please close down your first report!', 'Warning', MB_Ok )
.head 8 -  Return FALSE

.head 4 +  Message Actions
.head 5 +  On PAM_cls_SETINSTANCEVARS
.head 6 -  Set sSQLPopHandle = " SELECT
  Farm_Master.Farm_Name,
  Farm_Master.Farm_Description
FROM
  Farm_Master 
WHERE 
  Farm_Master.Farm_Name LIKE 'C%' 
ORDER BY
  Farm_Master.Farm_Name "
.head 6 -  Set sNAMEPopHandle = 'POPSELFRMS'
.head 6 -  Set sBINDPopHandle = ''
.head 6 -  Set sINTOPopHandle = ':frmPotPlanInterface.tblSelectedFarms.colFarmName,
  :frmPotPlanInterface.tblSelectedFarms.colFarmDesc'
.head 6 -  !
.head 6 -  Set bAddAllowed = TRUE
.head 6 -  Set bPopulated = FALSE
.head 5 +  On PAM_clsTBL_POPULATE
.head 6 -  Set bPopulated = TRUE
.head 6 -  Return SalSendClassMessage( PAM_clsTBL_POPULATE, wParam, lParam )
.head 5 +  On PAM_clsPOTPLAND_GETSELFARMS
.head 6 -  Set sFarmNameList = ''
.head 6 +  If TableLoop( hWndForm, hWndForm, PAM_clsPOTPLAND_GETSELECTED, 0, ROW_UnusedFlag1, 0, 'Extracting Selected Regions', TBL_cls_LowToHi )
.head 7 +  If sFarmNameList = ''
.head 8 -  Return FALSE
.head 7 +  Else
.head 8 -  Call PushString( sFarmNameList )
.head 8 -  Return TRUE
.head 6 +  Else
.head 7 -  Return FALSE
.head 5 +  On PAM_clsPOTPLAND_GETSELECTED
.head 6 +  If sFarmNameList = ''
.head 7 -  Set sFarmNameList = "'" || colFarmName || "'"
.head 6 +  Else
.head 7 -  Set sFarmNameList = sFarmNameList || ', ' || "'" || colFarmName || "'"
.head 6 -  Return TRUE
.head 3 -  !

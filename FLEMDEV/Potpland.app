.head 3 -  Number: nCustNo
.head 3 -  Number: nBatchYear
.head 3 -  Number: nOrdAmt
.head 3 -  Number: nConfAmt
.head 3 -  Date/Time: dtHoldOrdDate
.head 3 -  String: sTreeTypeDesc
.head 3 -  String: sCultDesc
.head 3 -  String: sRootDesc
.head 3 -  Date/Time: dtEstSaleDate
.head 2 +  Message Actions
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set sReportFileNameNoPath = 'PotOrdered.qrp'
.head 4 -  Set sPrinter = 'WideFanFold'
.head 4 -  Set sReportBind = ':hWndForm.sFarmName, 
  :hWndForm.nCustNo, 
  :hWndForm.nBatchYear, 
  :hWndForm.nOrdAmt, 
  :hWndForm.nConfAmt, 
  :hWndForm.dtHoldOrdDate, 
  :hWndForm.sTreeTypeDesc, 
  :hWndForm.sCultDesc, 
  :hWndForm.sRootDesc, 
  :hWndForm.dtEstSaleDate'
.head 4 -  Set sReportInto = 'sFarmName, 

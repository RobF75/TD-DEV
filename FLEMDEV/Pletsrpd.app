.head 6 -  Set sSql = '
	SELECT
		Variety
	FROM
		Variety
	WHERE
		@UPPER(Type) LIKE @UPPER(:sVarietyType)
	ORDER BY
		Variety '					! Query to get population data
.head 6 -  Call SqlConnect( hSql )					! Connect to Database
.head 6 -  Call SalListPopulate ( hWndItem, hSql, sSql )			! Return the results to the combo box
.head 6 -  Call SqlDisconnect ( hSql)					! Disconnect from Database
.head 6 -  Set sSql = ''
.head 6 -  Call SalWaitCursor( FALSE )
.head 5 +  On SAM_KillFocus
.head 6 -  Call SalSendClassMessage( SAM_KillFocus, 0, 0 )
.head 6 -  Set sVariety = cmbVariety
.head 2 -  Functions
.head 2 +  Window Parameters
.head 3 -  Receive String: sVarietyType
.head 3 -  Receive String: sVariety
.head 3 -  Receive Number: nYear
.head 3 -  Receive String: sReportType
.head 2 +  Window Variables
.head 3 -  String: sSql
.head 3 -  Sql Handle: hSql
.head 3 -  Window Handle: hWnd
.head 2 +  Message Actions
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set rbView = TRUE
.head 3 +  On SAM_CreateComplete
.head 4 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )

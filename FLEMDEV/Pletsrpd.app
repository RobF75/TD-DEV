.head 2 +  Message Actions
.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set sPrinter = 'WideFanFold'			! 17/05/04 (PXD) Printer setup done in parent class
.head 4 -  ! 17/05/04 (PXD) Call SetPrinter('WideFanFold')		
.head 4 -  Set sReportFileNameNoPath = 'pallets3.qrp'
.head 4 -  Set sReportBind = ':frmGradingPalletsReport.nItemNo, 
:frmGradingPalletsReport.sVarietyType, 
:frmGradingPalletsReport.sUpperVariety, 
:frmGradingPalletsReport.sUpperCultDesc, 
:frmGradingPalletsReport.sUpperRootDesc, 
:frmGradingPalletsReport.sVariety, 
:frmGradingPalletsReport.sTreeTypeDesc, 
:frmGradingPalletsReport.sCultDesc, 
:frmGradingPalletsReport.sRootDesc, 
:frmGradingPalletsReport.sProcessedBy, 
:frmGradingPalletsReport.nPalletCount, 
:frmGradingPalletsReport.nYear, 
:frmGradingPalletsReport.nTotalGraded, 
  :frmGradingPalletsReport.nPalletNumber'
.head 4 -  Set sReportInto = 'ItemNo, 
VarietyType, 
UpperVariety, 
UpperCultDesc, 
UpperRootDesc, 
Variety, 
TreeTypeDesc, 
CultDesc, 
RootDesc, 
ProcessedBy, 
PalletCount, 
YearOfSale, 
TotalGraded,
 PalletNumber'
.head 4 -  Set sReportType = 'VIEW'
.head 4 -  Call SalModalDialog( dlgGradingOptions, hWndForm, sVarietyType, sVariety, nYear, sReportType )
.head 3 +  On SAM_ReportStart
.head 4 -  Call WhichDateRangeSeasonYear( nYear, dtFromDate, dtToDate )
.head 4 -  !
.head 4 -  Set sSql = " SELECT 
  Stock_Item.Item_No, 
  Stock_Item.Variety_Type, 
  @UPPER( Stock_Item.Variety ), 
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  Stock_Item.Variety, 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Graded_Pallets.Processed_By, 
  Pallet_Contents.Pallet_Count, 
  Stock_Item_Sale.Total_Graded,
  Graded_Pallets.Pallet_Number   
FROM 
  Graded_Pallets,
  Pallet_Contents, 
  Stock_Item, 
  Stock_Item_Sale 
INTO 
  :frmGradingPalletsReport.nItemNo, 
  :frmGradingPalletsReport.sVarietyType, 
  :frmGradingPalletsReport.sUpperVariety, 
  :frmGradingPalletsReport.sUpperCultDesc, 
  :frmGradingPalletsReport.sUpperRootDesc, 
  :frmGradingPalletsReport.sVariety, 
  :frmGradingPalletsReport.sTreeTypeDesc, 
  :frmGradingPalletsReport.sCultDesc, 
  :frmGradingPalletsReport.sRootDesc, 
  :frmGradingPalletsReport.sProcessedBy, 
  :frmGradingPalletsReport.nPalletCount, 
  :frmGradingPalletsReport.nTotalGraded, 
  :frmGradingPalletsReport.nPalletNumber
WHERE 
  Graded_Pallets.Pallet_DateTime BETWEEN :frmGradingPalletsReport.dtFromDate AND :frmGradingPalletsReport.dtToDate AND 
  Graded_Pallets.Pallet_DateTime = Pallet_Contents.Content_Datetime AND 
  Pallet_Contents.Item_No = Stock_Item.Item_No AND 
  Stock_Item.Item_No = Stock_Item_Sale.Stock_Item_No AND 
  Stock_Item_Sale.Year_Of_Sale = :frmGradingPalletsReport.nYear AND
  Stock_Item.Variety_Type LIKE :frmGradingPalletsReport.sVarietyType AND
   @UPPER(Stock_Item.Variety) LIKE @UPPER(:frmGradingPalletsReport.sVariety)
ORDER BY 
  2,3,4,5,7,10 "
.head 4 -  Call fcReportHdl.PrepareSetup( sSql )
.head 4 -  Call SqlVarSetup( fcReportHdl.hSqlHandle )
.head 4 -  !
.head 4 -  Return fcReportHdl.PrepareAndExecute( )
.head 3 +  On SAM_ReportFetchInit
.head 4 -  Set bFirst = TRUE
.head 4 -  Return TRUE
.head 4 +  ! If fcReportHdl.FetchRow( 0, nInd )   ! gf 23/5/05 commented out, and mover return true out of If. This was failing to return first row onto report
.head 5 -  Call cReportHdl.FetchPrevious( 0, nInd ) 
.head 4 +  ! Else
.head 5 -  Return FALSE
.head 3 +  On SAM_ReportFetchNext
.head 4 +  If bFirst
.head 5 +  If fcReportHdl.FetchRow( 0, nInd ) 
.head 6 -  Set bFirst = FALSE
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 4 +  Else
.head 5 +  If fcReportHdl.FetchNext( nInd )
.head 6 -  Return TRUE
.head 5 +  Else
.head 6 -  Return FALSE
.head 3 +  On SAM_ReportFinish
.head 4 -  ! Call SetDefaultPrinter(  )			! 17/05/04 (PXD) Printer restore done in parent class
.head 4 -  Call fcReportHdl.Disconnect( )
.head 4 -  Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )

.head 7 -   Set sSql = " SELECT 
   SUM(Cust_Order_History.Ordered_Amount)
FROM 
  Cust_Order_History, 
  Stock_Item
WHERE 
  Cust_Order_History.Cust_No = :1 AND 
  Cust_Order_History.Year_Of_Sale = :2 AND 
  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
  NOT Stock_Item.Tree_Type LIKE 'C%' "

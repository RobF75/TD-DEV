.head 4 +   Actions 
.head 5 -   Set nOurHandleNo = SqlHandlesGetReferenceNo( 'CALCORTOTHISORD' )
.head 5 +   Select Case nActionType
.head 6 +   Case SH_cls_Execute
.head 7 -   Set sSql = " SELECT 
   SUM(Cust_Order_History.Ordered_Amount)
FROM 
  Customer_Master, 
  Cust_Order_History, 
  Stock_Item
WHERE 
  Customer_Master.Customer_Type LIKE '%OR%' AND 
  Customer_Master.Cust_No = Cust_Order_History.Cust_No AND 
  Cust_Order_History.Year_Of_Sale = :1 AND 
  Cust_Order_History.Ord_Date <= :2 AND 
  Cust_Order_History.Stock_Item_No = Stock_Item.Item_No AND 
  NOT Stock_Item.Tree_Type LIKE 'C%' "
.head 7 -   Set sName = 'CALCORTOTHISORD'
.head 7 -   Set sBind = ':nYear,:dtDate'
.head 7 -   Set sInto = ':nGotLastYearOrdAmt'
.head 7 -   Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -   Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -   Set nLastYearOrdAmt = NUMBER_Null
.head 7 -   Set nGotLastYearOrdAmt = NUMBER_Null
.head 7 +   If nYear >= 50 AND nYear <= 99
.head 8 -   Set dtDate = SalDateConstruct( nYear + 1900, SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 0, 0, 0 )
.head 7 +   Else If nYear >= 0 AND nYear <= 49
.head 8 -   Set dtDate = SalDateConstruct( nYear + 2000, SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 0, 0, 0 )
.head 7 +   Else 
.head 8 -   Set dtDate = SalDateConstruct( nYear, SalDateMonth( SalDateCurrent(  ) ), SalDateDay( SalDateCurrent(  ) ), 0, 0, 0 )
.head 7 -  !
.head 7 +   If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +   If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 -   Set nLastYearOrdAmt = nGotLastYearOrdAmt
.head 8 -   Return TRUE
.head 7 +   Else 
.head 8 -   Return FALSE
.head 6 +   Case SH_cls_Disconnect
.head 7 -   Return haSqlHandles[ nOurHandleNo ].Disconnect( )

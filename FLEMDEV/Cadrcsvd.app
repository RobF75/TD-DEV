.head 4 +  If fcCSVFile.Open( )
.head 5 +  If lbStates.GetSelectState( ) = 'ACT'
.head 6 +  If IDNO = SalMessageBox( 'ACT is included in NSW', 'Continue?', MB_YesNo )

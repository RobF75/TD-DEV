.head 6 -  !
.head 6 -  Set sSql = " SELECT 
  Customer_Master.Cust_No, 
  Customer_Master.Cust_Name, 
  Customer_Master.Bus_Name 
FROM 
  Customer_Master 
INTO 
  :hWndForm.nCustNo, 
  :hWndForm.sCustName, 
  :hWndForm.sBusName 
WHERE 
  Customer_Master.Cust_No BETWEEN :hWndForm.nLoCustNo AND :hWndForm.nHiCustNo AND 
  Customer_Master.Customer_Type LIKE :hWndForm.sCustType AND 
  Customer_Master.Mailing_List_Flag = 'Y' AND 
  ( Customer_Master.Dont_Sell_Flag = 'N' OR 
    Customer_Master.Dont_Sell_Flag IS NULL ) AND 
  ( Customer_Master.Bad_Debt_Flag = 'N' OR
    Customer_Master.Bad_Debt_Flag IS NULL ) AND 
  ( Customer_Master.Closed_Account = 'N' OR 
    Customer_Master.Closed_Account IS NULL ) 
ORDER BY Customer_Master.Cust_No "
.head 6 -  Call hSqlCustBasics.PrepareSetup( sSql )
.head 6 -  Call SqlVarSetup( hSqlCustBasics.hSqlHandle )
.head 6 -  !
.head 6 -  Set sSql = " SELECT 
  Main_Address_Flag, 
  Address_Type, 
  Address_1, 
  Address_2, 
  Suburb,
  State,
  Postcode,
  Area_Code,
  Phone_No,
  Area_Code_Fax,
  Fax_No
FROM 
  Customer_Address 
INTO 
  :hWndForm.sGotMainAddrFlag, 
  :hWndForm.sGotAddrType, 
  :hWndForm.sGotAddrLine1,
  :hWndForm.sGotAddrLine2,
  :hWndForm.sGotSuburb,
  :hWndForm.sGotState, 
  :hWndForm.sGotPostcode, 
  :hWndForm.sGotAreaCode, 
  :hWndForm.sGotPhoneNo, 
  :hWndForm.sGotFaxAreaCode, 
  :hWndForm.sGotFaxNo 
WHERE 
  Cust_No = :hWndForm.nCustNo 
ORDER BY 
  Address_Type "

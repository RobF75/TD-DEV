.head 6 +  Message Actions
.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 -  Set sSQLPopHandle = "
SELECT
	Supp_Order_OrdDT,
	si.Supplier_Item_Id,
	Description,
	Order_Multiples,
	Unit_Of_Measure,
	Price_Per_Multiple,
	Stock_On_Hand,
	Order_Quantity,
	Order_Sent_Date,
	Purchase_Order
FROM
	Supplier_items si,
	Supplier_Orders so
WHERE
	so.Supplier_Item_Id = si.Supplier_Item_Id and
	si.cust_no = :1 and
	Order_Sent_Date is NULL
ORDER BY
	Purchase_Order, Description"
.head 8 -  Set sNAMEPopHandle = '2105SuppOrdnSent5'
.head 8 -  Set sBINDPopHandle = ':frmSupplierOrdNOTSnt.nSupplierId'
.head 8 -  Set sINTOPopHandle = '
:clsfrmSupplierOrdNOTSnt.tblItems.colOrderDateTime,
:clsfrmSupplierOrdNOTSnt.tblItems.colSupplierItemNo,
:clsfrmSupplierOrdNOTSnt.tblItems.colDescription,
:clsfrmSupplierOrdNOTSnt.tblItems.colMultiples,
:clsfrmSupplierOrdNOTSnt.tblItems.colUnitOfMeasure,
:clsfrmSupplierOrdNOTSnt.tblItems.colPrice,
:clsfrmSupplierOrdNOTSnt.tblItems.colStockOnHand,
:clsfrmSupplierOrdNOTSnt.tblItems.colOrderQuantity,
:clsfrmSupplierOrdNOTSnt.tblItems.colOrderDate,
:clsfrmSupplierOrdNOTSnt.tblItems.colPurchaseOrder'
.head 8 -  !
.head 8 -  ! Set sSQLUpdateHandle = ' UPDATE Supplier_items
SET
  	Description = :3,
	Stock_On_Hand = :4,
	Order_Multiples = :5,
	Price_Per_Multiple = :6,
	Unit_Of_Measure = :7
WHERE
	Cust_No = :1 and
	Supplier_Item_Id = :2
	 '
.head 8 -  ! Set sNAMEUpdateHandle = '0705UpdSuppItem1'
.head 8 -  ! Set sBINDUpdateHandle = ':clsfrmSuppliers.tblItems.nSupplierId,
:clsfrmSuppliers.tblItems.colSupplierItemNo,
:clsfrmSuppliers.tblItems.colDescription,
:clsfrmSuppliers.tblItems.colStockOnHand,
:clsfrmSuppliers.tblItems.colMultiples,
:clsfrmSuppliers.tblItems.colPrice,
:clsfrmSuppliers.tblItems.colUnitOfMeasure'
.head 8 -  ! Set sINTOUpdateHandle = ''
.head 8 -  !
.head 8 -  ! Set sSQLInsertHandle = ' INSERT INTO
	Supplier_items (
		Cust_No,
		Supplier_Item_Id,
		Description,
		Stock_On_Hand,
		Order_Multiples,
		Unit_Of_Measure,
		Price_Per_Multiple)
VALUES
	  (:1, :2, :3, :4, :5, :6, :7 ) '
.head 8 -  ! Set sNAMEInsertHandle = '2105InsSuppItem3'
.head 8 -  ! Set sBINDInsertHandle = ':clsfrmSuppliers.tblItems.nSupplierId,
:clsfrmSuppliers.tblItems.colSupplierItemNo,
:clsfrmSuppliers.tblItems.colDescription,
:clsfrmSuppliers.tblItems.colStockOnHand,

.head 8 -  Set sSQLPopHandle = "
SELECT
	si.Supplier_Item_Id,
	Description,
	Order_Multiples,
	Unit_Of_Measure,
	Price_Per_Multiple,
	Stock_On_Hand,
	Order_Quantity,
	Order_Sent_Date
	
FROM
	Supplier_items si,
	Supplier_Orders so
WHERE
	so.cust_no = si.cust_no and
	si.cust_no = :1 and
	Order_Sent_Date is NULL
ORDER BY
	2"
.head 8 -  Set sNAMEPopHandle = '2105SuppOrdnSent'
.head 8 -  Set sBINDPopHandle = ':frmSupplierOrdNOTSnt.nSupplierId'
.head 8 -  Set sINTOPopHandle = '
:clsfrmSupplierOrdNOTSnt.tblItems.colSupplierItemNo,
:clsfrmSupplierOrdNOTSnt.tblItems.colDescription,
:clsfrmSupplierOrdNOTSnt.tblItems.colMultiples,
:clsfrmSupplierOrdNOTSnt.tblItems.colUnitOfMeasure,
:clsfrmSupplierOrdNOTSnt.tblItems.colPrice,
:clsfrmSupplierOrdNOTSnt.tblItems.colStockOnHand,
:clsfrmSupplierOrdNOTSnt.tblItems.colOrderQuantity,
:clsfrmSupplierOrdNOTSnt.tblItems.colOrderDate'
.head 8 -  !
.head 8 -  ! Set sSQLUpdateHandle = ' UPDATE Supplier_items
SET
  	Description = :3,
	Stock_On_Hand = :4,
	Order_Multiples = :5,
	Price_Per_Multiple = :6,
	Unit_Of_Measure = :7
WHERE
	Cust_No = :1 and
	Supplier_Item_Id = :2
	 '
.head 8 -  ! Set sNAMEUpdateHandle = '0705UpdSuppItem1'
.head 8 -  ! Set sBINDUpdateHandle = ':clsfrmSupplierOrdNOTSnt.nSupplierId,
:clsfrmSupplierOrdNOTSnt.tblItems.colSupplierItemNo,
:clsfrmSupplierOrdNOTSnt.tblItems.colDescription,
:clsfrmSupplierOrdNOTSnt.tblItems.colStockOnHand,
:clsfrmSupplierOrdNOTSnt.tblItems.colMultiples,
:clsfrmSupplierOrdNOTSnt.tblItems.colPrice,
:clsfrmSupplierOrdNOTSnt.tblItems.colUnitOfMeasure'
.head 8 -  ! Set sINTOUpdateHandle = ''
.head 8 -  !
.head 8 -  ! Set sSQLInsertHandle = ' INSERT INTO
	Supplier_items (
		Cust_No,
		Supplier_Item_Id,
		Description,
		Stock_On_Hand,
		Order_Multiples,
		Unit_Of_Measure,
		Price_Per_Multiple)
VALUES
	  (:1, :2, :3, :4, :5, :6, :7 ) '

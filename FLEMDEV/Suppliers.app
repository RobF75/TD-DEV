.head 6 +  Message Actions 
.head 7 +  On PAM_cls_SETINSTANCEVARS
.head 8 -  Set sSQLPopHandle = "
SELECT
	si.Supplier_Item_Id,
	Description,
	Order_Multiples,
	Unit_Of_Measure,
	Price_Per_Multiple,
	Stock_On_Hand
FROM
	Supplier_items si
WHERE
	si.cust_no = :1

.head 3 +  Function: UpdatePurshaseOrder
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  Date/Time: dtOrdDate
.head 5 -  Number: nSupplier
.head 5 -  String: sItemNo
.head 5 -  Number: nQuantity
.head 5 -  Number: nPONumber
.head 5 -  String: sUser
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 5 -  Number: nInd
.head 5 -  !
.head 5 -  Date/Time: dtSentDate
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( '2404UpdatePO' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " 
UPDATE
	Supplier_Orders
SET
	Order_Quantity = :nQuantity,
	Order_Sent_Date = :dtSentDate,
	Order_Sent_By = :sUser
WHERE	
	Supp_Order_OrdDT = :dtOrdDate and
	Cust_No = :nSupplier and
	Supplier_Item_Id = :sItemNo and
	Purchase_Order = :nPONumber"
.head 7 -  ! Set sName = '2404UpdatePO'
.head 7 -  ! Set sBind = ':dtOrdDate, :nSupplier, :nItemNo, :nQuantity, :nPONumber, :dtSentDate, :sUser'
.head 7 -  ! Set sInto = ''
.head 7 -  Call haSqlHandles[ nOurHandleNo ].PrepareSetup( sSql )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set dtSentDate = SalDateCurrent()
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].PrepareAndExecute( )
.head 8 -  Call haSqlHandles[ nOurHandleNo ].Commit( )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 3 +  Function: fnEX_HIWG_SupplierOrderLine
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  String:
.head 4 +  Parameters
.head 5 -  Window Handle: hWndTable
.head 5 -  Number: npPurchaseOrderLineNumber
.head 5 -  String: sPurchaseOrderNo
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sLine
.head 5 -  String: sTmp
.head 5 -  Number: nTmp
.head 5 -  Number: nGSTPercent
.head 4 +  Actions
.head 5 -  ! Detail
.head 5 -  Set sLine = ''
.head 5 -  Set sLine = sLine || ',,,,,,,,,,,,,,,,,' 					! Header Data only
.head 5 -  Set sLine = sLine || ',' 							! Currency
.head 5 -  Set sLine = sLine || ',,,,,' 		! 
.head 5 -  Set sLine = sLine || fnEX_StringField( '20', 2, 'N'  ) || ',' 			! Record Type	10 = Header 20 = Detail
.head 5 -  Set sLine = sLine || fnEX_StringField(sPurchaseOrderNo , 35, 'N'  ) || ',' 		! PO Number	
.head 5 -  Set sLine = sLine || fnEX_NumberField( npPurchaseOrderLineNumber, 0, 6, '' , 'N' ) || ',' 	! PO Line	 	PO Line Number
.head 5 -  Set sLine = sLine || fnEX_StringField( hWndTable.colGTIN, 14, 'N'  ) || ',' 			! GTIN		
.head 5 -  Set sLine = sLine || fnEX_StringField( hWndTable.colSupplierItemNo, 35,  'N'  ) || ',' 		! Supplier Item No	
.head 5 -  Set sLine = sLine || ',,,' 						! 
.head 5 -  Set sLine = sLine || fnEX_StringField( hWndTable.colDescription, 35, 'N'  ) || ',' 		! Description
.head 5 -  Set sLine = sLine || ',,,,,,,,' 						! 
.head 5 -  Set sLine = sLine || fnEX_StringField( hWndTable.colUnitOfMeasure, 3, 'N'  ) || ',' 			! Measure		PO measurement ie EA = EACH KGM = Kilograms
.head 5 -  Set sLine = sLine || ',,,,' 						! 
.head 5 -  Set sLine = sLine || fnEX_NumberField( hWndTable.colOrderQuantity/hWndTable.colMultiples, 0, 35, '', 'N'  ) || ',' 		! Ordered Quantity
.head 5 -  Set sLine = sLine || fnEX_StringField( hWndTable.colUnitOfMeasure, 3, 'N'  ) || ',' 			! Ourdered Measure		PO measurement ie EA = EACH KGM = Kilograms
.head 5 -  Set sLine = sLine || ',' 						! Delivery Date
.head 5 -  Set sLine = sLine || fnEX_NumberField( (hWndTable.colPrice ) , 2, 15, '', 'N'  ) || ',' 		! Unit Price
.head 5 -  Set sLine = sLine || fnEX_NumberField( (hWndTable.colMultiples ) , 2, 15, '', 'N'  ) || ',' 		! Unit Price
.head 5 -  ! Set sLine = sLine || ',' 						! 
.head 5 -  Set sLine = sLine || fnEX_StringField( hWndTable.colUnitOfMeasure, 3, 'N'  ) || ',' 			! Priced Measure		PO measurement ie EA = EACH KGM = Kilograms
.head 5 -  Set sLine = sLine || fnEX_NumberField( hWndTable.colPrice * (hWndTable.colOrderQuantity/hWndTable.colMultiples), 2, 18, '', 'N'   ) || ',' 		! Lval	Total Line Value (2 decimals, ex: $100.00 expressed as 100.00) GST Excl
.head 5 -  Call GetRegistryValue( 'ACCOUNTS', 'GSTPercent', sTmp, '0.1' )
.head 5 -  Set nGSTPercent = SalStrToNumber( sTmp )
.head 5 -  Set sLine = sLine || fnEX_NumberField( nGSTPercent * (hWndTable.colPrice  * (hWndTable.colOrderQuantity/hWndTable.colMultiples)), 2, 18, '', 'N'   ) || ',' 		! Line GST
.head 5 -  Set nTmp = ( hWndTable.colPrice ) * nGSTPercent
.head 5 -  Set sLine = sLine || fnEX_NumberField( (hWndTable.colPrice  * (hWndTable.colOrderQuantity/hWndTable.colMultiples)) + nTmp, 2, 18, '', 'N'   ) || ',' 		! Lval	Total Line Value (2 decimals, ex: $100.00 expressed as 100.00) GST Excl
.head 5 -  Set sLine = sLine || ',,,' 						! 
.head 5 +  If SqlDatabase != 'STOCK'			! Test Indicator	Invoice Line Number
.head 6 -  Set sLine = sLine || fnEX_StringField( 'This is a comment in the TEST data', 140, 'N'  ) || ',' 			! Comment
.head 5 +  Else
.head 6 -  Set sLine = sLine || ',' 						! 
.head 5 -  Set sLine = sLine || ',,,,,,,,,,,,' 						! 
.head 5 +  If SqlDatabase != 'STOCK'			! Test Indicator	Invoice Line Number
.head 6 -  Set sLine = sLine || fnEX_StringField( 'Last Column for testing only', 30, 'N'  ) || ','
.head 5 -  !
.head 5 -  !
.head 5 -  Return sLine

:clsfrmSuppliers.tblSuppliers.colPalletNumber'
.head 9 -  ! Set sINTOUpdateHandle = ''
.head 9 -  !
.head 9 -  ! Set sSQLDeleteHandle =  ' DELETE
FROM
	Graded_Pallets
WHERE
	Pallet_DateTime = :1'
.head 9 -  ! Set sINTODeleteHandle = ''
.head 9 -  ! Set sNAMEDeleteHandle = '1105DelPallet'
.head 9 -  ! Set sBINDDeleteHandle = ':clsfrmSuppliers.tblSuppliers.colDate'
.head 9 -  !
.head 9 -  ! Set sSQLInsertHandle = ' INSERT INTO
	Graded_Pallets (
		Pallet_DateTime,
		Processed_By,
		Processed_Date,
		Entered_By,
		Pallet_Number)
VALUES
	  (:1, :2, :3, :4, :5 ) '

.head 10 -  Call SalTblFetchRow( tblItems, nRow )
.head 10 +  If nOrder != NUMBER_Null
.head 11 +  If nOrder != tblItems.colPurchaseOrder
.head 12 -  Call SalMessageBox('Please Select orders with the SAME order Number Only', 'Stop', MB_Ok)
.head 12 -  Return FALSE
.head 10 -  Set nOrder = tblItems.colPurchaseOrder

.head 4 -  Functions
.head 4 +  Window Variables
.head 5 -  String: sSql
.head 5 -  FunctionalVar: hPopSalesHdl
.head 6 -  Class: hcSqlHandle
.head 5 -  Boolean: bOk
.head 5 -  Number: nTmp
.head 5 -  String: sTmp
.head 5 -  FunctionalVar: hWndMeter
.head 6 -  Class: clsMeterBar
.head 5 -  Number: nTotalItems
.head 4 +  Message Actions
.head 5 +  On SAM_Create
.head 6 -  Call hPopSalesHdl.Connect( )
.head 5 +  On PAM_SALES_POPULATE
.head 6 -  Set bOk = FALSE
.head 6 -  Set sSql = "SELECT 
  Promo.Promo_Desc,
  SUM(@IF(@SCAN(Customer_Type,'GC')+1,No_Units,0)),
  SUM(@IF(@SCAN(Customer_Type,'OR')+1,No_Units,0)), 
  SUM(No_Units),
  SUM(@IF(@SCAN(Customer_Type,'GC')+1,Override_Price*No_Units,0)), 
  SUM(@IF(@SCAN(Customer_Type,'OR')+1,Override_Price*No_Units,0)), 
  SUM(Override_Price*No_Units)
FROM 
  Promo, 
  Cust_Promo, 
  Customer_Master 
INTO 
  :frmEstSalesPOSReport.tblItems.colCultDesc, 
  :frmEstSalesPOSReport.tblItems.colGCTotalTrees, 
  :frmEstSalesPOSReport.tblItems.colORTotalTrees, 
  :frmEstSalesPOSReport.tblItems.colTotalTrees, 
  :frmEstSalesPOSReport.tblItems.colGCTotalSales, 
  :frmEstSalesPOSReport.tblItems.colORTotalSales, 
  :frmEstSalesPOSReport.tblItems.colTotalSales
WHERE 
  Promo.Promo_Id = Cust_Promo.Promo_Id AND 
  Cust_Promo.Year_Of_Order = :frmEstSalesPOSReport.nYear AND 
  Cust_Promo.Cust_No = Customer_Master.Cust_No "
.head 6 -  !
.head 6 +  If frmEstSalesPOSReport.sOrderDateType = 'BEFORE'
.head 7 -  Set sSql = sSql || " AND Cust_Promo.Promo_DT_Stamp <= :frmEstSalesPOSReport.dtOrderDate GROUP BY 1 "
.head 6 +  Else If frmEstSalesPOSReport.sOrderDateType = 'AFTER'
.head 7 -  Set sSql = sSql || " AND Cust_Promo.Promo_DT_Stamp > :frmEstSalesPOSReport.dtOrderDate  GROUP BY 1 "
.head 6 +  ! Else If frmEstSalesPOSReport.sOrderDateType = 'BETWEEN'
.head 7 -  Set sSql = sSql || " AND ( Cust_Promo.Promo_DT_Stamp >= :frmEstSalesPOSReport.dtOrderDate
 AND Cust_Promo.Promo_DT_Stamp <= :frmEstSalesPOSReport.dtOrderDate2 ) GROUP BY 1"
.head 6 +  Else
.head 7 -  Set sSql = sSql || " GROUP BY 1 "
.head 6 -  !
.head 6 +  If hPopSalesHdl.PrepareSetup( sSql )
.head 7 +  If hPopSalesHdl.PrepareAndExecute( )
.head 8 -  Call hPopSalesHdl.ResultSetCount( nTotalItems )
.head 8 -  Call hWndMeter.Setup( 'Populating POS Reports', nTotalItems )
.head 8 -  Set bOk = hPopSalesHdl.TablePopulate( hWndForm, TBL_FillAll )
.head 8 -  Call hWndMeter.End( )
.head 6 -  Return bOk
.head 5 +  On SAM_FetchRowDone
.head 6 -  Set colOtherTotalTrees = colTotalTrees - colGCTotalTrees - colORTotalTrees
.head 6 -  Set colOtherTotalSales = colTotalSales - colGCTotalSales - colORTotalSales
.head 6 +  If hWndSalesSeqPOS != hWndNULL

.head 3 +  On PAM_SALES_REPORT
.head 4 -  Set sReportName = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\estsale2.qrp'
.head 4 -  Call SetPrinter( 'SmallFanFold' )
.head 4 -  Set sReportBinds = ':frmVarietiesSalesSeqReport.sReportHeading, 
:frmVarietiesSalesSeqReport.nYear, 
:frmVarietiesSalesSeqReport.sOrderDateType, 
:frmVarietiesSalesSeqReport.dtOrderDate, 
:frmVarietiesSalesSeqReport.tblItems.colItemNo, 

.head 4 +  Message Actions
.head 5 +  On PAM_SALES_INSERTINDEX
.head 6 +  If SalSendMsg( hWndForm, PAM_SALES_POPFIELDS, 0, 0 )
.head 7 -  Set bInserted = FALSE
.head 7 -  Set nRow = TBL_MinRow
.head 7 +  While SalTblFindNextRow( hWndForm, nRow, 0, 0 ) AND NOT bInserted
.head 8 -  Call SalTblSetContext( hWndForm, nRow )
.head 8 +  If colUpperVariety = sNewUpperVariety
.head 9 +  If colTotalSales < nNewTotalSales
.head 10 -  Set nNewRow = SalTblInsertRow( hWndForm, nRow )
.head 10 -  Call SalTblSetContext( hWndForm, nNewRow )
.head 10 -  !
.head 10 -  ! Set colVarietyType = sNewVarietyType
.head 10 -  ! Set colUpperVariety = sNewUpperVariety
.head 10 -  ! Set colUpperCultDesc = sNewUpperCultDesc
.head 10 -  ! Set colUpperRootDesc = sNewUpperRootDesc
.head 10 -  ! Set colTreeTypeDesc = sNewTreeTypeDesc
.head 10 -  ! Set colVariety = sNewVariety
.head 10 -  ! Set colCultId = sNewCultId
.head 10 -  ! Set colCultDesc = sNewCultDesc

.head 5 -  Set sContainers = 'INCLUDE'
.head 4 +  Else If rbExcludeContainers
.head 5 -  Set sContainers = 'EXCLUDE'
.head 4 +  Else
.head 5 -  Set sContainers = 'ONLY'
.head 4 -  !
.head 4 +  If cbSelectSize 
.head 5 +  If SalIsNull( cmbSelectSize )
.head 6 -  Call SalMessageBox( "Please select a container size from the drop down list first", "Selected Container Sizes", MB_Ok )
.head 6 -  Return FALSE
.head 4 -  !
.head 4 +  If SalSendMsg( tblSelectedItems, PAM_SALES_GETSELECTEDITEMS, 0, 0 )
.head 5 -  Call PopString( sSelectedItems, TRUE )
.head 5 +  If sSelectedItems = 'YEARMISMATCH'
.head 6 -  Call OurWaitCursor( FALSE )
.head 6 -  Return FALSE
.head 4 +  Else
.head 5 -  Set sSelectedItems = ''

.head 2 +  Message Actions
.head 3 +  On SAM_CreateComplete
.head 4 -  Set sReportHeading = 'Best $ Sequence, Variety Summary'
.head 3 +  On PAM_SALES_REPORT
.head 4 -  Set sReportName = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\estsale2.qrp'
.head 4 -  Call SetPrinter( 'SmallFanFold' )
.head 4 -  Set sReportBinds = ':frmBestVarietySummaryReport.sReportHeading, 
:frmBestVarietySummaryReport.nYear, 
:frmBestVarietySummaryReport.sOrderDateType, 
:frmBestVarietySummaryReport.dtOrderDate, 
:frmBestVarietySummaryReport.tblItems.colItemNo, 
:frmBestVarietySummaryReport.tblItems.colVarietyType, 
:frmBestVarietySummaryReport.tblItems.colUpperVariety, 
:frmBestVarietySummaryReport.tblItems.colTreeTypeDesc, 
:frmBestVarietySummaryReport.tblItems.colCultDesc, 
:frmBestVarietySummaryReport.tblItems.colRootDesc, 
:frmBestVarietySummaryReport.tblItems.colGCTotalTrees, 
:frmBestVarietySummaryReport.tblItems.colORTotalTrees, 
:frmBestVarietySummaryReport.tblItems.colFCRPTotalTrees, 
:frmBestVarietySummaryReport.tblItems.colOtherTotalTrees, 
:frmBestVarietySummaryReport.tblItems.colTotalTrees, 
:frmBestVarietySummaryReport.tblItems.colGCTotalSales, 
:frmBestVarietySummaryReport.tblItems.colORTotalSales,
:frmBestVarietySummaryReport.tblItems.colOtherTotalSales,  
:frmBestVarietySummaryReport.tblItems.colTotalSales, 
:frmBestVarietySummaryReport.tblItems.colOwnerRoyalties, 
:frmBestVarietySummaryReport.tblItems.colFNARoyalties, 
:frmBestVarietySummaryReport.tblItems.colFMNRoyalties'
.head 4 -  Set sReportInputs = 'ReportHeading, 
YearOfSale, 
OrderDateType, 
OrderDate, 
ItemNo, 
VarietyType, 
Variety, 
TreeTypeDesc, 
CultDesc, 
RootDesc, 
GCTrees, 
ORTrees, 
FCRPTrees, 
OtherTrees, 
TotalTrees, 
GCSales, 
ORSales, 
OtherSales, 
TotalSales, 
OwnerRoyalties, 
FNARoyalties, 
FMNRoyalties'
.head 4 -  Set nError = 1
.head 4 +  If sViewPrint = 'PRINT'
.head 5 -  Set hWndReport = SalReportPrint( hWndForm, sReportName, sReportBinds, sReportInputs, 1, RPT_PrintAll | RPT_PrintNoWarn, 0, 0, nError )
.head 4 +  Else
.head 5 -  Set hWndReport = SalReportView( hWndForm, hWndForm, sReportName, sReportBinds, sReportInputs, nError )
.head 5 +  If hWndReport = hWndNULL
.head 6 -  Call SalMessageBox( 'Could not create the report! Possibly to many programs open!', 'Sales Report', MB_Ok )
.head 3 +  On PAM_SALES_INSERTINDEX
.head 4 -  Return SalSendMsg( tblItems, PAM_SALES_INSERTINDEX, wParam, lParam )
.head 3 +  On SAM_ReportStart
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchInit
.head 4 -  Set nItemsRow = TBL_MinRow
.head 4 -  Return TRUE
.head 3 +  On SAM_ReportFetchNext
.head 4 +  If SalTblFindNextRow( tblItems, nItemsRow, 0, 0 )
.head 5 -  Call SalTblFetchRow( tblItems, nItemsRow )
.head 5 -  Return TRUE
.head 4 +  Else
.head 5 -  Return FALSE
.head 3 +  On SAM_ReportFinish
.head 4 -  Call SetDefaultPrinter(  )
.head 4 -  Call SalDestroyWindow( hWndForm )
.head 4 -  Return TRUE

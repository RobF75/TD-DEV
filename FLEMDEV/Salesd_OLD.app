.head 6 +   Actions 
.head 7 +   Select Case nActionType
.head 8 +   Case SH_cls_Execute
.head 9 -   Set sSql = "SELECT 
  SUM(@IF(@ISNA(Conf_Amt), 
        @IF(@SCAN(Customer_Type,'GC')+1,
            @IF(@EXACT(Sale_Cat,'FC'), 0, 
            @IF(@EXACT(Sale_Cat,'RP'), 0, Ordered_Amount)),0), 
        @IF(@SCAN(Customer_Type,'GC')+1,
            @IF(@EXACT(Sale_Cat,'FC'), 0, 
            @IF(@EXACT(Sale_Cat,'RP'), 0, Conf_Amt)),0))), 
  SUM(@IF(@ISNA(Conf_Amt), 
        @IF(@SCAN(Customer_Type,'OR')+1,
            @IF(@EXACT(Sale_Cat,'FC'),0,
            @IF(@EXACT(Sale_Cat,'RP'),0,Ordered_Amount)),0), 
        @IF(@SCAN(Customer_Type,'OR')+1,
            @IF(@EXACT(Sale_Cat,'FC'),0,
            @IF(@EXACT(Sale_Cat,'RP'),0,Conf_Amt)),0))),  
  SUM(@IF(@ISNA(Conf_Amt), 
          @IF(@EXACT(Sale_Cat,'FC'),Ordered_Amount, 
          @IF(@EXACT(Sale_Cat,'RP'),Ordered_Amount,0)), 
      @IF(@EXACT(Sale_Cat,'FC'),Conf_Amt,
      @IF(@EXACT(Sale_Cat,'RP'),Conf_Amt,0)))), 
  SUM(@IF(@ISNA(Conf_Amt), Ordered_Amount, Conf_Amt)), 

  SUM(@IF(@SCAN(Customer_Type,'GC')+1,
      @IF(@ISNA(Contract_Price) , 
        @IF(@EXACT(Sale_Cat,'FC'),0,
          @IF(@EXACT(Sale_Cat,'RP'),0, 
            @IF(@EXACT(Sale_Cat,'HP'), 
              @IF(@ISNA(Conf_Amt),(Base_Price/2)*Ordered_Amount,(Base_Price/2) * Conf_Amt),
              @IF(@ISNA(Conf_Amt),Base_Price*Ordered_Amount,Base_Price * Conf_Amt ) ) ) ), 
        Contract_Price*Conf_Amt ),0 )), 

  SUM(@IF(@SCAN(Customer_Type,'OR')+1,
      @IF(@ISNA(Contract_Price) , 
        @IF(@EXACT(Sale_Cat,'FC'),0,
          @IF(@EXACT(Sale_Cat,'RP'),0, 
            @IF(@EXACT(Sale_Cat,'HP'), 
              @IF(@ISNA(Conf_Amt),(Base_Price/2)*Ordered_Amount,(Base_Price/2) * Conf_Amt),
              @IF(@ISNA(Conf_Amt),Base_Price*Ordered_Amount,Base_Price * Conf_Amt ) ) ) ), 
        Contract_Price*Conf_Amt ),0 )), 

  SUM(@IF(@ISNA(Contract_Price) , 
        @IF(@EXACT(Sale_Cat,'FC'),0,
          @IF(@EXACT(Sale_Cat,'RP'),0, 
            @IF(@EXACT(Sale_Cat,'HP'), 
              @IF(@ISNA(Conf_Amt),(Base_Price/2)*Ordered_Amount,(Base_Price/2) * Conf_Amt),
              @IF(@ISNA(Conf_Amt),Base_Price*Ordered_Amount,Base_Price * Conf_Amt ) ) ) ), 
        Contract_Price*Conf_Amt ) ) 
 FROM 
  Stock_Item,
  Cust_Order_History, 
  Customer_Master 
WHERE Stock_Item.Item_No = :1 AND 
  Stock_Item.Item_No = Stock_Item_No AND 
  Cust_Order_History.Cust_No = Customer_Master.Cust_No AND 
  Year_Of_Sale = :2 "
.head 9 -  !
.head 9 -   Set sName = 'TRSALEHIST'
.head 9 -   Set sBind = ':nItemNo, :nYear'
.head 9 -   Set sInto = ':nGotGCTotalTrees, :nGotORTotalTrees, :nGotFCRPTotalTrees, :nGotTotalTrees, :nGotGCTotalSales, :nGotORTotalSales, :nGotTotalSales'
.head 9 -  !
.head 9 -   Call fcOurHandle.Setup( sSql, sName, sBind, sInto )
.head 9 -   Call SqlVarSetup( fcOurHandle.hSqlHandle )
.head 9 -  !
.head 9 -   Set nGCTotalTrees = NUMBER_Null
.head 9 -   Set nORTotalTrees = NUMBER_Null
.head 9 -   Set nFCRPTotalTrees = NUMBER_Null
.head 9 -   Set nTotalTrees = NUMBER_Null
.head 9 -   Set nGCTotalSales = NUMBER_Null
.head 9 -   Set nORTotalSales = NUMBER_Null
.head 9 -   Set nTotalSales = NUMBER_Null
.head 9 -  !
.head 9 -   Set nGotGCTotalTrees = NUMBER_Null
.head 9 -   Set nGotORTotalTrees = NUMBER_Null
.head 9 -   Set nGotFCRPTotalTrees = NUMBER_Null
.head 9 -   Set nGotTotalTrees = NUMBER_Null
.head 9 -   Set nGotGCTotalSales = NUMBER_Null
.head 9 -   Set nGotORTotalSales = NUMBER_Null
.head 9 -   Set nGotTotalSales = NUMBER_Null
.head 9 -  !
.head 9 +   If fcOurHandle.Execute( )
.head 10 -   Call fcOurHandle.FetchNext( nInd )
.head 10 -   Set nGCTotalTrees = nGotGCTotalTrees
.head 10 -   Set nORTotalTrees = nGotORTotalTrees
.head 10 -   Set nFCRPTotalTrees = nGotFCRPTotalTrees
.head 10 -   Set nTotalTrees = nGotTotalTrees
.head 10 -   Set nGCTotalSales = nGotGCTotalSales
.head 10 -   Set nORTotalSales = nGotORTotalSales
.head 10 -   Set nTotalSales = nGotTotalSales
.head 10 -   Return TRUE
.head 9 +   Else 
.head 10 -   Return FALSE
.head 8 +   Case SH_cls_Disconnect
.head 9 -   Return fcOurHandle.Disconnect( )

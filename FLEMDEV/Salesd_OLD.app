.head 3 +  On PAM_SALES_REPORT
.head 4 -  Call SetPrinter( 'SmallFanFold' )
.head 4 -  Set sReportName = OurGetIniFileParameter( 'ACCOUNTS', 'ReportsPath', '' )||'\\estsale2.qrp'
.head 4 -  Set sReportBinds = ':frmEstSalesItemsReport.sReportHeading, 
:frmEstSalesItemsReport.nYear, 
:frmEstSalesItemsReport.sOrderDateType, 
:frmEstSalesItemsReport.dtOrderDate, 
:frmEstSalesItemsReport.tblItems.colItemNo, 
:frmEstSalesItemsReport.tblItems.colVarietyType, 
:frmEstSalesItemsReport.tblItems.colUpperVariety, 
:frmEstSalesItemsReport.tblItems.colTreeTypeDesc, 

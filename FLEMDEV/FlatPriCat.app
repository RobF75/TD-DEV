.head 8 -  Set sSQLPopHandle = "
SELECT
	Stock_Item_No
FROM
	customer_order co,
	stock_item si
WHERE
	co.stock_item_no = si.item_no and
	co.cust_no = :1 and
	co.Year_Of_Sale = :2 and 
	(co.Invoiced_Flag = 'N' or
	co.Invoiced_Flag is null)
ORDER BY
	variety_type, variety, cult_desc"

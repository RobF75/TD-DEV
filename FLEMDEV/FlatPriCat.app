.head 9 -  ! Detail
.head 9 -  Set sLine = ''
.head 9 -  Call GetItemFullBasicDetails( colnItemNo, sTreeType, sTreeTypeDesc, sTmp, sDesc, sTmp, sTmp, sTmp, sTmp, sTmp, SH_cls_Execute )
.head 9 -  Set sLine = sLine || ',,,,,,,,,,' 					! Header Data only
.head 9 -  Set sLine = sLine || fnEX_StringField( '20', 2, 'N'  ) || ',' 			! Record Type	10 = Header 20 = Detail
.head 9 -  Set sLine = sLine || fnEX_StringField( '38', 2, 'N'  ) || ',' 			! Record Type	10 = Header 20 = Detail
.head 9 -  Set sGTIN = fnCalculateBarCode( colnItemNo )
.head 9 -  Set sLine = sLine || fnEX_StringField( sGTIN, 14, 'N' ) || ',' 			! PO Number
.head 9 -  Set sLine = sLine || fnEX_NumberField(  colnItemNo, 0, 35, '' , 'N' ) || ',' 		! DelNote		Delivery Note Number
.head 9 -  Set sLine = sLine || ',' 			! Supplier Fineline
.head 9 -  Set sLine = sLine || fnEX_StringField( sTreeTypeDesc, 35, 'N' ) || ',' 			! Product Group use for Tree Type
.head 9 -  Set sLine = sLine || fnEX_StringField( sDesc, 70, 'N' ) || ',' 			! 
.head 9 -  Set sLine = sLine || ',' 			! 
.head 9 -  Set sLine = sLine || fnEX_StringField( 'Y', 1, 'N' ) || ',' 			! Tradable unit
.head 9 -  Set sLine = sLine || ',,,,,,,,,,,,,,,,,,,,,,,,,,,,,' 			! 
.head 9 -  Call CalcItemPriceForQueries( colnItemNo, nPricatYear, nPrice, nExPrice, nTmp, SH_cls_Execute )
.head 9 -  Set sLine = sLine || fnEX_NumberField(  nExPrice, 2, 15, '' , 'N' ) || ',' 		! 
.head 9 -  Set sLine = sLine || ',' 			! 
.head 9 -  Call GetRegistryValue( 'ACCOUNTS', 'GSTPercent', sGST, '0.1' )
.head 9 -  Set nGST = SalStrToNumber( sGST )
.head 9 -  Set sGST = SalNumberToStrX( nGST * 100, 2 )
.head 9 -  Set sLine = sLine || fnEX_StringField( sGST, 17, 'N' ) || ',' 			! 
.head 9 -  Set sLine = sLine || fnEX_NumberField(  nExPrice * nGST, 2, 15, '' , 'N' ) || ',' 		! 
.head 9 -  Set sLine = sLine || ',,' 			! 
.head 9 -  Set sLine = sLine || fnEX_NumberField(  nExPrice, 2, 15, '' , 'N' ) || ',' 		! DelNote		Delivery Note Number
.head 9 -  Set sLine = sLine || fnEX_NumberField(  nPrice, 2, 15, '' , 'N' ) || ',' 		! DelNote		Delivery Note Number
.head 9 -  Set sLine = sLine || ',,,,,' 					! Extra Stuff
.head 9 -  Set sLine = sLine || fnEX_DateField( dtPricatDate, 'yyyyMMdd', 8, 'N'  ) || ',' 	! Price Effective date		Date - format yyyyMMddhhmmss
.head 9 -  Set sLine = sLine || ',,,,,,,,,,,,,,,,,' 					! Extra Stuff
.head 9 +  If SqlDatabase != 'STOCK'			! Test Indicator	Invoice Line Number
.head 10 -  Set sLine = sLine || fnEX_StringField( 'Last Column for testing only.', 30, 'N'  ) || ','
.head 9 -  !
.head 9 -  !
.head 9 -  Return sLine

.head 8 -  Call GetRegistryValue( 'GENERAL', 'eMailSenderName', sSenderName, '' )
.head 8 -  Call GetRegistryValue( 'GENERAL', 'eMailSenderAddress', sSenderEmail, 'gfleming@flemings.com.au' )
.head 8 -  Set sMessageText = sMessageText || '

Attached is a HIWG Flat File version of the Price Cataogue, you may wish to incorporate this into your system using the HIWG standards available for download at
www.hiwg.org.au.

'  || sSenderName || '
' || sSenderEmail
.head 8 -  Call GetRegistryValue( 'GENERAL', 'AccountsManager', sAccountsUser, 'gfleming@flemings.com.au' )
.head 8 -  Call fnEX_CustCloseFile( hEX_PRICATFormatFile, bEX_PRICATFileOpened )
.head 8 -  Call GetMainEmailAddress( nPricatCustNo, sCustomerEmail, SH_cls_Execute )
.head 8 -  ! Call SendMail( sSubject , sMessageText, sCustomerEmail, sAccountsUser, 'gfleming@flemings.com.au', sSourceFile )
.head 8 -  Call SMTPSend( sCustomerEmail, sAccountsUser, 'gfleming@flemings.com.au', SqlUser, 'mail@flemings.com.au', sSubject, sMessageText, sSourceFile, 'mail', 25 )

.head 4 -  Set sReportType = 'VIEW'
.head 3 +  On SAM_CreateComplete
.head 4 +  If SalModalDialog( dlgPriceListDetails, hWndForm )
.head 5 -  Call PopNumber( nYear, TRUE )
.head 5 -  Call PopString( sStockType, TRUE )
.head 5 -  Return SalSendClassMessage( SAM_CreateComplete, wParam, lParam )
.head 4 +  Else
.head 5 -  Return SalDestroyWindow( hWndForm )
.head 3 +  On SAM_ReportStart
.head 4 +  If sStockType = 'ALL'
.head 5 -  Set sSql = " SELECT
  Stock_Item.Item_No, 
  Stock_Item.Variety_Type, 
  @UPPER( Stock_Item.Variety ), 
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Variety, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Generic_Stock_Item, 
  Stock_Item.Base_Price 
FROM 
  Stock_Item, 
  Stock_Item_Sale 
INTO 
  :frmPriceList.nItemNo, 
  :frmPriceList.sVarietyType, 
  :frmPriceList.sUpperVariety, 
  :frmPriceList.sUpperCultDesc, 
  :frmPriceList.sUpperRootDesc, 
  :frmPriceList.sTreeTypeDesc, 
  :frmPriceList.sVariety, 
  :frmPriceList.sCultDesc, 
  :frmPriceList.sRootDesc, 
  :frmPriceList.sGenericFlag, 
  :frmPriceList.nBasePrice 
WHERE 
  Stock_Item.Item_No = Stock_Item_Sale.Stock_Item_No AND 
  Stock_Item_Sale.Year_Of_Sale = :frmPriceList.nYear AND 
  ( Stock_Item_Sale.Amt_Growing > 0 OR 
    Stock_Item_Sale.Amt_On_Order > 0 )
ORDER BY 2,3,4,5,6"
.head 4 +  Else If sStockType = 'BAREROOT'
.head 5 -  Set sSql = " SELECT
  Stock_Item.Item_No, 
  Stock_Item.Variety_Type, 
  @UPPER( Stock_Item.Variety ), 
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Variety, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Generic_Stock_Item, 
  Stock_Item.Base_Price 
FROM 
  Stock_Item, 
  Stock_Item_Sale 
INTO 
  :frmPriceList.nItemNo, 
  :frmPriceList.sVarietyType, 
  :frmPriceList.sUpperVariety, 
  :frmPriceList.sUpperCultDesc, 
  :frmPriceList.sUpperRootDesc, 
  :frmPriceList.sTreeTypeDesc, 
  :frmPriceList.sVariety, 
  :frmPriceList.sCultDesc, 
  :frmPriceList.sRootDesc, 
  :frmPriceList.sGenericFlag, 
  :frmPriceList.nBasePrice 
WHERE 
  Stock_Item.Item_No = Stock_Item_Sale.Stock_Item_No AND 
  NOT Stock_Item.Tree_Type LIKE 'C%' AND 
  Stock_Item_Sale.Year_Of_Sale = :frmPriceList.nYear AND 
  ( Stock_Item_Sale.Amt_Growing > 0 OR 
    Stock_Item_Sale.Amt_On_Order > 0 )
ORDER BY 2,3,4,5,6"
.head 4 +  Else If sStockType = 'CONTAINERS'
.head 5 -  Set sSql = " SELECT
  Stock_Item.Item_No, 
  Stock_Item.Variety_Type, 
  @UPPER( Stock_Item.Variety ), 
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Variety, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Generic_Stock_Item, 
  Stock_Item.Base_Price 
FROM 
  Stock_Item, 
  Stock_Item_Sale 
INTO 
  :frmPriceList.nItemNo, 
  :frmPriceList.sVarietyType, 
  :frmPriceList.sUpperVariety, 
  :frmPriceList.sUpperCultDesc, 
  :frmPriceList.sUpperRootDesc, 
  :frmPriceList.sTreeTypeDesc, 
  :frmPriceList.sVariety, 
  :frmPriceList.sCultDesc, 
  :frmPriceList.sRootDesc, 
  :frmPriceList.sGenericFlag, 
  :frmPriceList.nBasePrice 
WHERE 
  Stock_Item.Item_No = Stock_Item_Sale.Stock_Item_No AND 
  Stock_Item.Tree_Type LIKE 'C%' AND 
  Stock_Item_Sale.Year_Of_Sale = :frmPriceList.nYear AND 
  ( Stock_Item_Sale.Amt_Growing > 0 OR 
    Stock_Item_Sale.Amt_On_Order > 0 )
ORDER BY 2,3,4,5,6"
.head 4 +  Else
.head 5 -  Return FALSE
.head 4 -  !
.head 4 -  Call fcReportHdl.PrepareSetup( sSql )
.head 4 -  Call SqlVarSetup( fcReportHdl.hSqlHandle )
.head 4 -  !
.head 4 -  Return fcReportHdl.PrepareAndExecute( )
.head 3 +  On SAM_ReportFetchInit
.head 4 +  If fcReportHdl.FetchRow( 0, nInd )
.head 5 -  Call CalcItemPriceForQueries( nItemNo, nYear, nTotalPrice, nTemp, nTemp, SH_cls_Execute )
.head 5 -  Return TRUE
.head 4 +  Else
.head 5 -  Return FALSE
.head 3 +  On SAM_ReportFetchNext
.head 4 +  If fcReportHdl.FetchNext( nInd )
.head 5 -  Call CalcItemPriceForQueries( nItemNo, nYear, nTotalPrice, nTemp, nTemp, SH_cls_Execute )
.head 5 -  Return TRUE
.head 4 +  Else
.head 5 -  Return FALSE
.head 3 +  On SAM_ReportFinish
.head 4 -  Call fcReportHdl.Disconnect( )
.head 4 -  Call CalcItemPriceForQueries( nItemNo, nYear, nTotalPrice, nTemp, nTemp, SH_cls_Disconnect )
.head 4 -  Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )

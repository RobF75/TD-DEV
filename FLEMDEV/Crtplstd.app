.head 3 +  On PAM_cls_SETINSTANCEVARS
.head 4 -  Set sReportFileNameNoPath = 'crntpls2.qrp'
.head 4 -  Set sReportBind = ':frmPriceList.nYear, 
:frmPriceList.nItemNo, 
:frmPriceList.sVarietyType, 
:frmPriceList.sUpperVariety, 

.head 5 -  String: sName
.head 5 -  Number: nInd
.head 5 -  Number: nSqlHandleNo
.head 5 -  !
.head 4 +  Actions
.head 5 -  Set nSqlHandleNo = SqlHandlesGetReferenceNo( 'GetScionEvalFromRFID' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  ! Dont want to include forward orders in the amt on order calculation
.head 7 -  Set sSql = " 
SELECT
	farm_name,
	row#,
	seq#,
	cultivar_id,
	cult_desc
FROM
	scion_evaluation se,
	location l,
	stock_item si
WHERE
	item_no = stock_item_no and
	l.location_id = se.location_id and
	rfid = :1"
.head 7 -  Set sName = 'GetScionEvalFromRFID'
.head 7 -  Set sBind = ':sRFIDTag'
.head 7 -  Set sInto = ':sFarm, :nRow, :nSeq, :sCultId, :sCultDesc'
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nSqlHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  !
.head 7 +  If haSqlHandles[ nSqlHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nSqlHandleNo ].FetchNext( nInd )
.head 9 -  Return TRUE
.head 8 +  Else
.head 9 -  Return FALSE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Call haSqlHandles[ nSqlHandleNo ].Disconnect( )
.head 7 -  Return TRUE
.head 2 -  Window Parameters
.head 2 +  Window Variables
.head 3 -  String: sCultId

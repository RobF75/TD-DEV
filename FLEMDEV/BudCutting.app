.head 4 -  Set hWndChildTable = tblBudwood
.head 4 -  Set bRFIDTableAllowed = TRUE
.head 4 -  Set hWndRFIDField = frmBudCutting.dfTag
.head 3 +  On PAM_clsRFID_DATARECEIVED
.head 4 -  Call GetScionEvalDataFromRFID( frmBudCutting.dfTag, dfFarmName, dfCultivar, dfRow,  dfSeq, sCultId,  SH_cls_Execute )
.head 4 -  Call SalSendMsg( hWndRFIDField, PAM_clsRFID_KillTimer, 0, 0 )
.head 4 -  Call SalSendMsg( pbRFIDClose, SAM_Click, 0, 0 )
.head 3 +  On PAM_cls_DESTROY
.head 4 -  Call GetScionEvalDataFromRFID( '', sTmp, sTmp, nTmp,  nTmp, sTmp,  SH_cls_Disconnect )
.head 4 -  Call SalSendClassMessage( PAM_cls_DESTROY, wParam, lParam )

.head 4 +                                Functions 
.head 5 +                                Function: LaunchApp
.head 6 -                                Description: 
.head 6 -                                Returns 
.head 6 -                                Parameters 
.head 6 -                                Static Variables 
.head 6 +                                Local variables 
.head 7 -                                Window Handle: hWnd
.head 6 +                                Actions 
.head 7 -  ! Try to find an existing instance of the app
and bring it to the top
.head 7 -                                Set hWnd = SalAppFind( __isProgramExePath, FALSE )
.head 7 -  ! If we found it
.head 7 +                                If hWnd
.head 8 -  ! GetLastActivePopup will return the handle of any modal dialogs in use
.head 8 -                                Set hWnd = GetLastActivePopup( hWnd )
.head 8 -                                Return SalBringWindowToTop( hWnd )
.head 7 +                                Else 
.head 8 -  ! The app was not found, try to load it
.head 8 -                                Return SalLoadApp( __isProgramExePath, isDBName||' '||SqlUser||' '||SqlPassword||' '||isParams )
.head 5 +                                Function: LaunchAppAndWait
.head 6 -                                Description: 
.head 6 -                                Returns 
.head 6 -                                Parameters 
.head 6 -                                Static Variables 
.head 6 +                                Local variables 
.head 7 -                                Window Handle: hWnd
.head 7 -                                Number: nRunModeReturn
.head 6 +                                Actions 
.head 7 -  ! Try to find an existing instance of the app
and bring it to the top
.head 7 -                                Set hWnd = SalAppFind( __isProgramExePath, FALSE )
.head 7 -  ! If we found it
.head 7 +                                If hWnd
.head 8 -  ! GetLastActivePopup will return the handle of any modal dialogs in use
.head 8 -                                Set hWnd = GetLastActivePopup( hWnd )
.head 8 -                                Return SalBringWindowToTop( hWnd )
.head 7 +                                Else 
.head 8 -  ! The app was not found, try to load it
.head 8 -                                Return SalLoadAppAndWait( __isProgramExePath, inRunMode, __inRunModeReturn )
.head 5 +                                Function: ExecProgram
.head 6 -                                Description: 
.head 6 +                                Returns 
.head 7 -                                Boolean: 
.head 6 -                                Parameters 
.head 6 -                                Static Variables 
.head 6 +                                Local variables 
.head 7 -                                Number: nTmp
.head 6 +                                Actions 
.head 7 -                                Set nTmp = WinExec( __isProgramExePath||' '||isParams, SW_SHOW )
.head 7 +                                If nTmp >= 32
.head 8 -                                Return TRUE
.head 7 +                                Else 
.head 8 -                                Return FALSE
.head 5 +                                Function: CloseApp
.head 6 -                                Description: 
.head 6 -                                Returns 
.head 6 +                                Parameters 
.head 7 -                                String: sApp
.head 6 -                                Static Variables 
.head 6 +                                Local variables 
.head 7 -                                Window Handle: hWnd
.head 7 -                                Window Handle: hWndChild
.head 6 +                                Actions 
.head 7 -  ! Try to find an existing instance of the app
and bring it to the top
.head 7 -                                Set hWnd = SalAppFind( sApp, FALSE )
.head 7 -  ! If we found it
.head 7 +                                If hWnd
.head 8 -  ! Post it a close message
.head 8 -  ! This message must be posted, if you send,
it screws up Windows
.head 8 -                                Call SalPostMsg( hWnd, SAM_Close, 0, 0 )
.head 7 -                                Return TRUE
.head 5 +                                Function: OnClose
.head 6 -                                Description: 
.head 6 +                                Returns 
.head 7 -                                Boolean: 
.head 6 +                                Parameters 
.head 7 -                                String: sProgName
.head 7 -                                Window Handle: hWndCalledFrom
.head 6 -                                Static Variables 
.head 6 -                                Local variables 
.head 6 +                                Actions 
.head 7 +                                If not CloseApp( sProgName )
.head 8 -                                Return FALSE
.head 7 -  ! Post ourselves a close message
.head 7 -                                Call SalPostMsg( hWndCalledFrom, PAM_cls_CLOSE, 0, 0  )
.head 5 +                                Function: ShutDown
.head 6 -                                Description: 
.head 6 +                                Returns 
.head 7 -                                Boolean: 
.head 6 +                                Parameters 
.head 7 -                                String: sProgName
.head 6 -                                Static Variables 
.head 6 -                                Local variables 
.head 6 +                                Actions 
.head 7 -  ! If either of the subsystem apps is still around, don't exit
.head 7 +                                If SalAppFind( sProgName, FALSE )
.head 8 -                                Return FALSE
.head 7 -                                Call SalQuit()
.head 5 +                                Function: Enabled
.head 6 -                                Description: 
.head 6 +                                Returns 
.head 7 -                                Boolean: 
.head 6 +                                Parameters 
.head 7 -                                Number: nUserType
.head 6 -                                Static Variables 
.head 6 -                                Local variables 
.head 6 +                                Actions 
.head 7 +                                Select Case nUserType
.head 8 +                                Case USR_ACCT
.head 9 +                                If SalStrScan( __csAccUsers, SqlUser ) >= 0
.head 10 -                                Return TRUE
.head 9 +                                Else 
.head 10 -                                Return FALSE
.head 8 +                                Case USR_FAMILY
.head 9 +                                If SalStrScan( __csFamUsers, SqlUser ) >= 0
.head 10 -                                Return TRUE
.head 9 +                                Else 
.head 10 -                                Return FALSE
.head 8 +                                Case USR_PRICEADJ
.head 9 +                                If SalStrScan( __csPAdjUsers, SqlUser ) >= 0
.head 10 -                                Return TRUE
.head 9 +                                Else 
.head 10 -                                Return FALSE
.head 8 +                                Case USR_STCKCONTROL
.head 9 +                                If SalStrScan( __csSContUsers, SqlUser ) >= 0
.head 10 -                                Return TRUE
.head 9 +                                Else 
.head 10 -                                Return FALSE
.head 8 +                                Case USR_SYSADM
.head 9 +                                If SalStrScan( __csSysAdmUsers, SqlUser ) >= 0
.head 10 -                                Return TRUE
.head 9 +                                Else 
.head 10 -                                Return FALSE
.head 8 +                                Case USR_GENERAL
.head 9 -                                Return TRUE
.head 8 +                                Default 
.head 9 -                                Return TRUE

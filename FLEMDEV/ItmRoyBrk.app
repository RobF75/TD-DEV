.head 7 -  Set sOSOwnerCode = ''
.head 7 -  Set nOSRoy = NUMBER_Null
.head 7 -  Set nFMNRoy = NUMBER_Null
.head 7 -  Set nFNARoy = NUMBER_Null
.head 7 -  Set nOSPercRoy = NUMBER_Null
.head 7 -  Set nFMNPercRoy = NUMBER_Null
.head 7 -  Set nFNAPercRoy = NUMBER_Null
.head 7 -  !
.head 7 -  Set sRoyOwner = ''
.head 7 -  Set nRoy = NUMBER_Null
.head 7 -  Set nPercPayable = NUMBER_Null
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 +  If sRoyOwner = 'FMN'
.head 10 +  If nPercPayable > 0
.head 11 -  Set nFMNPercRoy = nFMNPercRoy + nPercPayable
.head 10 +  Else
.head 11 -  Set nFMNRoy = nFMNRoy + nRoy
.head 9 +  Else If sRoyOwner = 'FNA'
.head 10 +  If nPercPayable > 0
.head 11 -  Set nFNAPercRoy = nFNAPercRoy + nPercPayable
.head 10 +  Else
.head 11 -  Set nFNARoy = nFNARoy + nRoy
.head 9 +  Else
.head 10 -  Set sOSOwnerCode = sRoyOwner
.head 10 +  If nPercPayable > 0
.head 11 -  Set nOSPercRoy = nOSPercRoy + nPercPayable
.head 10 +  Else
.head 11 -  Set nOSRoy = nOSRoy + nRoy
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )

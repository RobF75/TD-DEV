.head 5 -  Receive Number: nCustNo
.head 5 -  Number: nActionType
.head 4 -  Static Variables 
.head 4 +  Local variables 
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName

.head 5 +  Message Actions
.head 6 +  On PAM_clsPB_CLICK
.head 7 +  If rbSelectedItems
.head 8 -  Set sItemType = 'SELECTED'
.head 8 +  If SalSendMsg( tblSelectedItems, PAM_clsITMROYBRK_GETSELITEMS, 0, 0 )
.head 9 -  Call PopString( sSelectedItemNoList, TRUE )
.head 8 +  Else
.head 9 -  Call SalMessageBox( 'Please select some items first, or choose All Items.', 'Warning', MB_Ok )
.head 9 -  Return FALSE
.head 7 +  Else If rbBareRoot
.head 8 -  Set sItemType = 'BAREROOT'
.head 7 +  Else If rbContainers
.head 8 -  Set sItemType = 'CONT'
.head 7 +  Else
.head 8 -  Set sItemType = 'ALL'
.head 7 -  !
.head 7 +  If rbFruit
.head 8 -  Set sItemCatagory = 'FRUIT'
.head 7 +  Else If rbOrnam
.head 8 -  Set sItemCatagory = 'ORNAM'
.head 7 +  Else
.head 8 -  Set sItemCatagory = 'ALL'
.head 7 -  !
.head 7 +  If cbCurrentYear
.head 8 -  Set sActiveType = 'CURRENTYEAR'
.head 7 +  Else
.head 8 -  Set sActiveType = 'ALL'
.head 7 -  !
.head 7 +  If rbView
.head 8 -  Set sReportType = 'VIEW'
.head 7 +  Else
.head 8 -  Set sReportType = 'PRINT'
.head 7 -  !
.head 7 +  If rbItemSort
.head 8 -  Set sSortType = 'ITEM'
.head 7 +  Else If rbTreeTypeDescSort
.head 8 -  Set sSortType = 'TREETYPEDESC'
.head 7 +  Else If rbCultDescSort
.head 8 -  Set sSortType = 'CULTDESC'
.head 7 +  Else If rbRootDescSort
.head 8 -  Set sSortType = 'ROOTDESC'
.head 7 +  Else
.head 8 -  Set sSortType = 'BASEPRICE'
.head 7 -  !
.head 7 +  If rbAsc
.head 8 -  Set sSortOption = 'ASC'
.head 7 +  Else
.head 8 -  Set sSortOption = 'DESC'
.head 7 -  !
.head 7 +  If hWndReport = hWndNULL
.head 8 -  Set hWndReport = SalCreateWindow( frmPrintItemRoyDets, hWndForm, sSelectedItemNoList, 
sItemType, sActiveType, sItemCatagory, ccSeasonYear.GetSeasonYear( ), sReportType, sSortType, sSortOption )
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Call SalMessageBox( 'Please close down your first report!', 'Warning', MB_Ok )
.head 8 -  Return FALSE

.head 5 +  If NOT sCultId = ''
.head 6 -  ! Call CalcCultivarRoyalty( 0, sCultId, nItemNo, nTotalCultRoy, SH_cls_Execute )
.head 6 -  ! Call CalcCultivarRoyalty( nFNACustNo, sCultId, nItemNo, nTotalFNACultRoy, SH_cls_Execute )
.head 6 -  Call GetCultivarRoyPay( sCultId, sCultOSOwnerCode, nCultOSRoy, nCultFMNRoy, nCultFNARoy, nCultOSPercRoy, nCultFMNPercRoy, nCultFNAPercRoy, SH_cls_Execute )
.head 5 +  If NOT sRootId = ''
.head 6 -  ! Call CalcRootstockRoyalty( 0, sRootId, nItemNo, nTotalRootRoy, SH_cls_Execute )
.head 6 -  ! Call CalcRootstockRoyalty( nFNACustNo, sRootId, nItemNo, nTotalFNARootRoy, SH_cls_Execute )
.head 6 -  Call GetRootstockRoyPay( sRootId, sRootOSOwnerCode, nRootOSRoy, nRootFMNRoy, nRootFNARoy, nRootOSPercRoy, nRootFMNPercRoy, nRootFNAPercRoy, SH_cls_Execute )
.head 5 -  !
.head 5 +  If nCultOSPercRoy > 0
.head 6 -  Set nCultOSRoy = nBasePrice * nCultOSPercRoy / 100
.head 5 +  If nCultFMNPercRoy > 0
.head 6 -  Set nCultFMNRoy = nBasePrice * nCultFMNPercRoy / 100
.head 5 +  If nCultFNAPercRoy > 0
.head 6 -  Set nCultFNARoy = nBasePrice * nCultFNAPercRoy / 100
.head 5 -  Set nCultFNAMembRoy = ( nCultFMNRoy + nCultFNARoy ) / 2
.head 5 +  If nRootOSPercRoy > 0
.head 6 -  Set nRootOSRoy = nBasePrice * nRootOSPercRoy / 100
.head 5 +  If nRootFMNPercRoy > 0
.head 6 -  Set nRootFMNRoy = nBasePrice * nRootFMNPercRoy / 100
.head 5 +  If nRootFNAPercRoy > 0
.head 6 -  Set nRootFNARoy = nBasePrice * nRootFNAPercRoy / 100
.head 5 -  Set nRootFNAMembRoy = ( nRootFMNRoy + nRootFNARoy ) / 2
.head 5 -  Set nTotalCultRoy = nCultOSRoy + nCultFMNRoy + nCultFNARoy
.head 5 -  Set nTotalRootRoy = nRootOSRoy + nRootFMNRoy + nRootFNARoy
.head 5 -  Set nTotalFNACultRoy = nCultOSRoy + nCultFNAMembRoy
.head 5 -  Set nTotalFNARootRoy = nRootOSRoy + nRootFNAMembRoy
.head 5 -  Set nTotalRoy = nTotalCultRoy + nTotalRootRoy
.head 5 -  Set nTotalFNAMembRoy = nTotalFNACultRoy + nTotalFNARootRoy
.head 5 -  !
.head 5 -  Set nNonFNATotalPrice = nBasePrice + nTotalRoy
.head 5 -  Set nFNATotalPrice = nBasePrice + nTotalFNAMembRoy
.head 5 -  !
.head 5 +  If nFNATotalPrice = 0
.head 6 -  Set nFNATotalPrice = NUMBER_Null
.head 5 +  If nNonFNATotalPrice = 0
.head 6 -  Set nNonFNATotalPrice = NUMBER_Null
.head 5 +  If nTotalFNAMembRoy = 0
.head 6 -  Set nTotalFNAMembRoy = NUMBER_Null
.head 5 +  If nTotalRoy = 0
.head 6 -  Set nTotalRoy = NUMBER_Null
.head 5 +  If nTotalRootRoy = 0
.head 6 -  Set nTotalRootRoy = NUMBER_Null
.head 5 +  If nTotalCultRoy = 0
.head 6 -  Set nTotalCultRoy = NUMBER_Null
.head 5 +  If nTotalFNACultRoy = 0
.head 6 -  Set nTotalFNACultRoy = NUMBER_Null
.head 5 +  If nTotalFNARootRoy = 0
.head 6 -  Set nTotalFNARootRoy = NUMBER_Null
.head 5 +  If nRootFNAMembRoy = 0
.head 6 -  Set nRootFNAMembRoy = NUMBER_Null
.head 5 +  If nCultFNAMembRoy = 0
.head 6 -  Set nCultFNAMembRoy = NUMBER_Null
.head 5 -  Return TRUE
.head 4 +  Else
.head 5 -  Return FALSE
.head 3 +  On SAM_ReportFinish
.head 4 -  Call SetDefaultPrinter(  )
.head 4 -  Call fcSqlHandle.Disconnect( )
.head 4 -  ! Call CalcCultivarRoyalty( 0, '', 0, nTotalFNACultRoy, SH_cls_Disconnect )
.head 4 -  Call GetCultivarRoyPay( '', sCultOSOwnerCode, nCultOSRoy, nCultFMNRoy, nCultFNARoy, nCultOSPercRoy, nCultFMNPercRoy, nCultFNAPercRoy, SH_cls_Disconnect )
.head 4 -  Call GetRootstockRoyPay( '', sRootOSOwnerCode, nRootOSRoy, nRootFMNRoy, nRootFNARoy, nRootOSPercRoy, nRootFMNPercRoy, nRootFNAPercRoy, SH_cls_Disconnect )
.head 4 -  ! Call GetFNACustNoRoyOwnerCode( nFNACustNo, SH_cls_Disconnect )
.head 4 -  Return SalSendClassMessage( SAM_ReportFinish, wParam, lParam )

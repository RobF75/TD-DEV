.head 5 +  If sItemCatagory = 'FRUIT'
.head 6 +  If sActiveType = 'CURRENTYEAR'
.head 7 -  Set sSql = "SELECT 
  Stock_Item.Item_No, 
  @UPPER( Stock_Item.Variety_Type ), 
  @UPPER( Stock_Item.Variety ), 
  @UPPER( Stock_Item.Cult_Desc ), 
  @UPPER( Stock_Item.Root_Desc ), 
  Stock_Item.Tree_Type_Desc, 
  Stock_Item.Cult_Desc, 
  Stock_Item.Root_Desc, 
  Stock_Item.Base_Price, 
  Stock_Item.Variety, 
  Stock_Item.Cultivar_Id, 
  Stock_Item.Rootstock_Id, 
  Stock_Item.CV_Not_Sale_Flag, 
  Stock_Item.RT_Not_Sale_Flag 
FROM 
  Stock_Item, 
  Stock_Item_Sale 
INTO 
  :frmPrintItemRoyDets.nItemNo, 
  :frmPrintItemRoyDets.sUpperVarietyType,
  :frmPrintItemRoyDets.sUpperVariety,
  :frmPrintItemRoyDets.sUpperCultDesc,
  :frmPrintItemRoyDets.sUpperRootDesc, 
  :frmPrintItemRoyDets.sTreeType,
  :frmPrintItemRoyDets.sCultDesc,
  :frmPrintItemRoyDets.sRootDesc,
  :frmPrintItemRoyDets.nBasePrice, 
  :frmPrintItemRoyDets.sVariety, 
  :frmPrintItemRoyDets.sCultId, 
  :frmPrintItemRoyDets.sRootId, 
  :frmPrintItemRoyDets.sCVNFS, 
  :frmPrintItemRoyDets.sRTNFS 
WHERE 
  Stock_Item.Variety_Type = 'F' AND 
  Stock_Item.Item_No = Stock_Item_Sale.Stock_Item_No AND 
  Stock_Item_Sale.Year_Of_Sale = :frmPrintItemRoyDets.nCurrentYear 
ORDER BY " || sSortOrder

.head 5 -  !
.head 5 -  Number: nInd
.head 5 -  Number: nGotCustNo
.head 5 -  !
.head 4 +  Actions 
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetFNACustNoRoyOwnerCode' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT 
  Cust_No 
FROM 
  Customer_Master
WHERE 
  FNA_Flag = 'Y' AND 
  Royalty_Owner_Code IS NULL "
.head 7 -  Set sName = 'GTFNACSTNROC'
.head 7 -  Set sBind = ''
.head 7 -  Set sInto = ':nGotCustNo'
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set nCustNo = 0
.head 7 -  Set nGotCustNo = 0
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  If haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 -  Set nCustNo = nGotCustNo
.head 8 -  Return TRUE
.head 7 +  Else 
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
.head 3 +  Function: GetRootstockRoyPay
.head 4 -  Description:
.head 4 +  Returns
.head 5 -  Boolean:
.head 4 +  Parameters
.head 5 -  String: sRootId
.head 5 -  Receive String: sOSOwnerCode
.head 5 -  Receive Number: nOSRoy
.head 5 -  Receive Number: nFMNRoy
.head 5 -  Receive Number: nFNARoy
.head 5 -  Receive Number: nOSPercRoy
.head 5 -  Receive Number: nFMNPercRoy
.head 5 -  Receive Number: nFNAPercRoy
.head 5 -  Number: nActionType
.head 4 -  Static Variables
.head 4 +  Local variables
.head 5 -  String: sSql
.head 5 -  String: sBind
.head 5 -  String: sInto
.head 5 -  String: sName
.head 5 -  Number: nOurHandleNo
.head 5 -  !
.head 5 -  Number: nInd
.head 5 -  String: sRoyOwner
.head 5 -  Number: nRoy
.head 5 -  Number: nPercPayable
.head 5 -  !
.head 4 +  Actions
.head 5 -  Set nOurHandleNo = SqlHandlesGetReferenceNo( 'GetRootstockRoyPay' )
.head 5 +  Select Case nActionType
.head 6 +  Case SH_cls_Execute
.head 7 -  Set sSql = " SELECT 
  Royalty_Owner_Id, 
  Amount_Payable, 
  Percentage_Payable 
FROM 
  Royalty_Payable
WHERE 
  Rootstock_Id = :1 "
.head 7 -  Set sName = 'RTSROYDT'
.head 7 -  Set sBind = ':sRootId'
.head 7 -  Set sInto = ':sRoyOwner, :nRoy, :nPercPayable'
.head 7 -  Call haSqlHandles[ nOurHandleNo ].Setup( sSql, sName, sBind, sInto )
.head 7 -  Call SqlVarSetup( haSqlHandles[ nOurHandleNo ].hSqlHandle )
.head 7 -  !
.head 7 -  Set sOSOwnerCode = ''
.head 7 -  Set nOSRoy = NUMBER_Null
.head 7 -  Set nFMNRoy = NUMBER_Null
.head 7 -  Set nFNARoy = NUMBER_Null
.head 7 -  Set nOSPercRoy = NUMBER_Null
.head 7 -  Set nFMNPercRoy = NUMBER_Null
.head 7 -  Set nFNAPercRoy = NUMBER_Null
.head 7 -  !
.head 7 -  Set sRoyOwner = ''
.head 7 -  Set nRoy = NUMBER_Null
.head 7 -  Set nPercPayable = NUMBER_Null
.head 7 -  !
.head 7 +  If haSqlHandles[ nOurHandleNo ].Execute( )
.head 8 +  While haSqlHandles[ nOurHandleNo ].FetchNext( nInd )
.head 9 +  If sRoyOwner = 'FMN'
.head 10 +  If nPercPayable > 0
.head 11 -  Set nFMNPercRoy = nFMNPercRoy + nPercPayable
.head 10 +  Else
.head 11 -  Set nFMNRoy = nFMNRoy + nRoy
.head 9 +  Else If sRoyOwner = 'FNA'
.head 10 +  If nPercPayable > 0
.head 11 -  Set nFNAPercRoy = nFNAPercRoy + nPercPayable
.head 10 +  Else
.head 11 -  Set nFNARoy = nFNARoy + nRoy
.head 9 +  Else
.head 10 -  Set sOSOwnerCode = sRoyOwner
.head 10 +  If nPercPayable > 0
.head 11 -  Set nOSPercRoy = nOSPercRoy + nPercPayable
.head 10 +  Else
.head 11 -  Set nOSRoy = nOSRoy + nRoy
.head 8 -  Return TRUE
.head 7 +  Else
.head 8 -  Return FALSE
.head 6 +  Case SH_cls_Disconnect
.head 7 -  Return haSqlHandles[ nOurHandleNo ].Disconnect( )
